#!/bin/sh
# Block commits that introduce secrets. Scans only the staged diff.
# Enable once per clone with:  git config core.hooksPath .githooks
# Requires gitleaks on PATH (brew install gitleaks).

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not found on PATH — install it with 'brew install gitleaks'." >&2
  echo "pre-commit: skipping secret scan (commit allowed)." >&2
  exit 0
fi

gitleaks git --staged --redact -v
