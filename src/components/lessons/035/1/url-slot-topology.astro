---
// url-slot-topology — Chapter 035 Lesson 1, the chapter's spine drawn as a map:
// how ONE url resolves into a combination of named slots inside the two-column
// `invoices/layout.tsx` shell. Three columns:
//   LEFT   — three example URLs, each tinted with its own accent.
//   CENTER — the layout shell box that receives { children, list, detail }.
//   RIGHT  — the five route files that fill the slots, stacked.
// Colored leader-line arrows fan URL -> slot(s): each URL keeps its accent so a
// reader can trace "this URL lights up these regions" even where two curves share
// the gap. The arrows pass through the two side gaps and curve clear of the shell
// box's body — the shell sits centered between them as the thing they route past.
//
// Color carries the mapping (not just direction): the source URL, its arrow(s),
// and the slot box(es) it lights up all share one accent. The two slots NO example
// URL lights up — @detail/default (empty state) and new/ (the full-page twin) —
// stay neutral grey on purpose; the caption names them as the always-present
// fallback halves.
//
// This component renders the boxes + styles; the lesson wraps it in
// <Figure expandable={false}> — ArrowDiagram's leader lines are positioned from
// document.body and break if the figure is relocated into the expand lightbox.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Per-URL accent tones — mid-tones that read on light and dark.
const TONE = {
  filter: "#0ea5e9", // sky    — ?status=paid lights @list
  detail: "#16a34a", // green  — /inv_017 lights @list + @detail/[id]
  modal: "#8b5cf6", // violet — soft nav /new lights (.)new
} as const;
const NEUTRAL = "#94a3b8"; // slate — the always-present fallback halves

// Outer container — not-content, centered. Capped to the figure's inner content
// width (~700px) so the three columns + their curve gaps never overflow the card.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 700px",
  "margin-inline: auto",
].join("; ");

// Three-column stage: URLs | gap | shell | gap | slots. The two gaps are where
// the colored curves live and bow around the centered shell.
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: max-content 1fr max-content",
  "column-gap: 50px",
  "align-items: center",
].join("; ");

// LEFT — the three URL boxes, evenly stacked and vertically centered.
const urlStack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 18px",
].join("; ");

// One URL box. `tone` colours the left rail, the mono text, and a faint wash.
const urlBox = (tone: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "white-space: nowrap",
    "padding: 8px 11px",
    "border-radius: 10px",
    "font-size: 11.5px",
    "font-weight: 600",
    "line-height: 1.2",
    `color: color-mix(in srgb, ${tone} 78%, var(--sl-color-text))`,
    `border: 1.5px solid color-mix(in srgb, ${tone} 45%, var(--sl-color-gray-4))`,
    `border-left: 4px solid ${tone}`,
    `background: color-mix(in srgb, ${tone} 8%, var(--sl-color-gray-6))`,
  ].join("; ");

// CENTER — the layout shell box, vertically centered against both stacks.
const shellWrap = "display: flex; justify-content: center;";
const shell = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 7px",
  "align-items: center",
  "text-align: center",
  "max-width: 158px",
  "padding: 12px 13px",
  "border-radius: 12px",
  "border: 2px solid var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6)",
  "box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-3) 20%, transparent)",
].join("; ");
const shellName = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");
const shellSub = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-2)",
].join("; ");
const shellProps = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: var(--sl-color-gray-1)",
].join("; ");

// RIGHT — the five route files that fill the slots, stacked.
const slotStack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 9px",
].join("; ");

// One slot box. `tone` colours the left rail + path; lit slots get a faint wash,
// neutral fallback slots stay flat grey.
const slotBox = (tone: string, lit: boolean) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 2px",
    "width: 198px",
    "padding: 8px 11px",
    "border-radius: 10px",
    `border: 1.5px solid color-mix(in srgb, ${tone} ${lit ? 45 : 30}%, var(--sl-color-gray-4))`,
    `border-left: 4px solid ${tone}`,
    `background: color-mix(in srgb, ${tone} ${lit ? 8 : 0}%, var(--sl-color-gray-6))`,
  ].join("; ");
const slotPath = (tone: string, lit: boolean) =>
  [
    reset,
    mono,
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.2",
    lit
      ? `color: color-mix(in srgb, ${tone} 70%, var(--sl-color-text))`
      : "color: var(--sl-color-gray-2)",
  ].join("; ");
const slotNote = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

const slots = [
  {
    id: "slot-list",
    tone: TONE.filter,
    lit: true,
    path: "@list/page.tsx",
    note: "reads ?status=, renders the filtered list",
  },
  {
    id: "slot-detail",
    tone: TONE.detail,
    lit: true,
    path: "@detail/[id]/page.tsx",
    note: "loads the selected invoice",
  },
  {
    id: "slot-detail-default",
    tone: NEUTRAL,
    lit: false,
    path: "@detail/default.tsx",
    note: "“pick an invoice” empty state",
  },
  {
    id: "slot-intercept",
    tone: TONE.modal,
    lit: true,
    path: "(.)new/page.tsx",
    note: "intercepts a soft nav into a Dialog",
  },
  {
    id: "slot-twin",
    tone: NEUTRAL,
    lit: false,
    path: "new/page.tsx",
    note: "the full-page twin",
  },
];

// Colored arrows URL -> slot(s). Each URL keeps its accent so a reader can trace
// "this URL lights up these regions" even where curves share a gap. The shell sits
// dead-centre, so every curve has to clear the band it occupies: the three arrows
// aimed at the upper slots (@list x2, @detail/[id]) arch OVER the shell's top edge,
// and the one aimed at the lower slot ((.)new) runs UNDER its bottom edge. Strong
// vertical gravity components lift / drop each curve out of the shell's text before
// it crosses, and stagger the two arrows leaving url-detail into separate lanes.
const arrows = [
  // /invoices?status=paid -> @list. Starts level with the shell top, so it must
  // climb early: a strong upward start pull lifts it clear above the shell's top
  // edge before it reaches the shell's x-band.
  {
    from: "url-filter",
    to: "slot-list",
    color: TONE.filter,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [44, -120],
    endSocketGravity: [-90, -30],
  },
  // /invoices/inv_017 -> @list. Starts below the shell and climbs hardest of all to
  // the topmost slot. The big negative-Y start lifts it well over the shell's top.
  {
    from: "url-detail",
    to: "slot-list",
    color: TONE.detail,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [44, -210],
    endSocketGravity: [-95, 10],
  },
  // /invoices/inv_017 -> @detail/[id]. The shorter of url-detail's two arrows; rises
  // over the shell's top in its own lane just below the first green curve.
  {
    from: "url-detail",
    to: "slot-detail",
    color: TONE.detail,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [80, -118],
    endSocketGravity: [-92, -4],
  },
  // soft nav -> /invoices/new -> (.)new. Both endpoints sit below the shell, so a
  // low, near-level curve passes cleanly under its bottom edge.
  {
    from: "url-modal",
    to: "slot-intercept",
    color: TONE.modal,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [90, 26],
    endSocketGravity: [-100, 8],
  },
];
---

<div class="not-content ust" style={root}>
  <ArrowDiagram arrows={arrows}>
    <div style={stage}>
      {/* ---- LEFT — three example URLs ---------------------------------- */}
      <div style={urlStack}>
        <div id="url-filter" style={urlBox(TONE.filter)}>/invoices?status=paid</div>
        <div id="url-detail" style={urlBox(TONE.detail)}>/invoices/inv_017</div>
        <div id="url-modal" style={urlBox(TONE.modal)}>
          soft nav → /invoices/new
        </div>
      </div>

      {/* ---- CENTER — the two-slot layout shell ------------------------- */}
      <div style={shellWrap}>
        <div id="shell" style={shell}>
          <span style={shellName}>invoices/layout.tsx</span>
          <span style={shellSub}>two-column shell</span>
          <span style={shellProps}>{"{ children, list, detail }"}</span>
        </div>
      </div>

      {/* ---- RIGHT — the route files that fill the slots ---------------- */}
      <div style={slotStack}>
        {
          slots.map((s) => (
            <div id={s.id} style={slotBox(s.tone, s.lit)}>
              <code style={slotPath(s.tone, s.lit)}>{s.path}</code>
              <span style={slotNote}>{s.note}</span>
            </div>
          ))
        }
      </div>
    </div>
  </ArrowDiagram>
</div>

<style>
  /* The three-column geometry is the whole figure. On narrow viewports let the
     stage scroll horizontally rather than collapse (laptop viewports — the design
     target — show it whole). */
  @media (max-width: 700px) {
    .ust {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .ust > div {
      min-width: 660px;
    }
  }
</style>
