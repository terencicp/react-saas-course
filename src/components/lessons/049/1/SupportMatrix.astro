---
// "Support matrix" — Chapter 049 L1, "Why email HTML is its own subset".
//
// The whole job of this figure is the one-glance gulf: the everyday web layout
// toolkit, every row a feature the student reaches for daily, lined up green-
// check in a modern browser and red-cross in the worst-client email baseline.
// Five solid green checks on the left, five solid red crosses on the right —
// that visual asymmetry IS the argument for React Email, so the figure is
// deliberately small and quick to read, not a dense reference.
//
// Engine: a real semantic <table> styled with HTML + CSS — the diagram guidance
// calls a support matrix a "simple visual aid", and a <table> is the correct
// element for a feature × environment grid (header row + row headers). Plain
// HTML beats a graph engine here.
//
// Styling mirrors the sibling lesson figures (e.g. 017/6 WhoReadsThis): inline
// style arrays joined with '; ', theme-aware accents via color-mix on saturated
// 600-range hues so checks/crosses read on both light and dark themes,
// `not-content` to drop Starlight's prose/table chrome, and `margin: 0` resets
// to defeat the prose-margin selector. The email column is tinted with a faint
// red wash + a heavier border so it reads as THE constrained one at a glance.
//
// <Figure> + caption are supplied by the MDX, not here.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The two verdict hues: a saturated green for "trustworthy here", a saturated
// red for "don't rely on it". Both mid-tones that read on light and dark.
const green = "#16a34a";
const red = "#dc2626";

type Feature = {
  // The Tailwind/CSS handle, rendered monospace.
  code: string;
  // The plain-English name of the feature.
  name: string;
};

// Five features the student uses constantly on the web — all green in a browser,
// all red in the email matrix. Order from most-reached-for (flex/grid) down.
const features: Feature[] = [
  { code: "display: flex", name: "Flexbox" },
  { code: "display: grid", name: "CSS Grid" },
  { code: "--brand", name: "Custom properties" },
  { code: "@container", name: "Container queries" },
  { code: "vh, vw", name: "Viewport units" },
];

// ── Outer wrapper ───────────────────────────────────────────────────────────
// A capped, centred table. max-width keeps the three columns tight so the
// check/cross asymmetry stays legible rather than stretched across the page.
const wrap = [
  reset,
  sans,
  "box-sizing: border-box",
  "max-width: 620px",
  "margin: 0 auto",
].join("; ");

const table = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "border-collapse: separate",
  "border-spacing: 0",
  "table-layout: fixed",
].join("; ");

// ── Header row ──────────────────────────────────────────────────────────────
const headBase = [
  reset,
  sans,
  "box-sizing: border-box",
  "padding: 9px 12px",
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1.3",
  "letter-spacing: 0.01em",
  "text-align: center",
  "vertical-align: bottom",
  "border-bottom: 1.5px solid var(--sl-color-gray-4)",
];

// First header cell ("CSS feature") is left-aligned over the feature column.
const headFeature = [
  ...headBase,
  "text-align: left",
  "color: var(--sl-color-gray-2)",
].join("; ");

const headBrowser = [
  ...headBase,
  `color: color-mix(in srgb, ${green} 70%, var(--sl-color-text))`,
].join("; ");

// The email column header carries the constraint tint: red text, a faint red
// fill, and a heavier red side border that runs down the whole column.
const headEmail = [
  ...headBase,
  "border-top-right-radius: 10px",
  `color: color-mix(in srgb, ${red} 72%, var(--sl-color-text))`,
  `background: color-mix(in srgb, ${red} 8%, var(--sl-color-bg))`,
  `border-bottom-color: color-mix(in srgb, ${red} 40%, var(--sl-color-gray-4))`,
].join("; ");

// ── Body cells ──────────────────────────────────────────────────────────────
const cellBase = [
  reset,
  "box-sizing: border-box",
  "padding: 11px 12px",
  "vertical-align: middle",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
];

// The row-header cell: the feature. Monospace code on top, plain name under it.
const cellFeature = [...cellBase, "text-align: left"].join("; ");

const featureCode = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-block",
  "font-size: 13px",
  "font-weight: 600",
  "color: var(--sl-color-text)",
].join("; ");

const featureName = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "font-size: 11.5px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
  "margin: 2px 0 0",
].join("; ");

// Verdict cells centre a single large glyph.
const cellBrowser = [...cellBase, "text-align: center"].join("; ");

// The email column body cell keeps the faint red wash + heavier side borders so
// the whole column reads as one emphasised, constrained band.
const cellEmail = [
  ...cellBase,
  "text-align: center",
  `background: color-mix(in srgb, ${red} 6%, var(--sl-color-bg))`,
].join("; ");

// The verdict glyphs — large enough to read at a glance, in a coloured pill so
// the green/red asymmetry pops without relying on the glyph shape alone.
const badge = (accent: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "width: 26px",
    "height: 26px",
    "border-radius: 999px",
    "font-size: 16px",
    "font-weight: 800",
    "line-height: 1",
    `color: color-mix(in srgb, ${accent} 82%, var(--sl-color-text))`,
    `background: color-mix(in srgb, ${accent} 16%, transparent)`,
    `border: 1.5px solid color-mix(in srgb, ${accent} 42%, transparent)`,
  ].join("; ");

// Visually-hidden text so the glyph isn't a bare symbol to a screen reader.
const sr = [
  "position: absolute",
  "width: 1px",
  "height: 1px",
  "padding: 0",
  "margin: -1px",
  "overflow: hidden",
  "clip: rect(0 0 0 0)",
  "white-space: nowrap",
  "border: 0",
].join("; ");
---

<div class="not-content" style={wrap}>
  <table style={table}>
    <thead>
      <tr>
        <th scope="col" style={headFeature}>CSS feature</th>
        <th scope="col" style={headBrowser}>Modern browser</th>
        <th scope="col" style={headEmail}>Email<br />(worst-client baseline)</th>
      </tr>
    </thead>
    <tbody>
      {
        features.map((f) => (
          <tr>
            <th scope="row" style={cellFeature}>
              <code style={featureCode}>{f.code}</code>
              <span style={featureName}>{f.name}</span>
            </th>
            <td style={cellBrowser}>
              <span style={badge(green)} aria-hidden="true">
                ✓
              </span>
              <span style={sr}>Supported</span>
            </td>
            <td style={cellEmail}>
              <span style={badge(red)} aria-hidden="true">
                ✗
              </span>
              <span style={sr}>Not reliable</span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
