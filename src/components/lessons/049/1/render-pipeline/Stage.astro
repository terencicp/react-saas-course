---
// One frame of the render-pipeline DiagramSequence (Ch049 L1, "From JSX to a
// message on the wire"). The whole stage is identical across the five steps
// except for which node is lit and what shows in the detail panel beneath, so it
// lives here once and each DiagramStep passes a different `active` index plus a
// slotted detail. Keeping the strip stable frame-to-frame is the point: the eye
// tracks ONE artifact moving left-to-right through the pipeline, not five
// different pictures.
//
//   welcome.tsx → render() → HTML string → Resend SDK → Client
//
// The lit node carries the lesson's indigo brand accent (#4f46e5 — the same
// `bg-brand` hex the email config example uses), the rest dim to neutral gray.
// A fixed-min-height detail panel under the strip holds the per-step snippet so
// every frame is the same height and DiagramSequence's grid-stack never jumps.
//
// Pure HTML + CSS, matching the sibling figures (SupportMatrix, DkimSignVerify):
// `not-content` to drop Starlight's prose chrome, `margin: 0` resets, theme-aware
// `color-mix` accents that read on light and dark, SVG connectors between nodes.

interface Props {
  // Index (0-4) of the node lit this frame.
  active: number;
}

const { active } = Astro.props;

// The five pipeline stages, in order. `label` is the node's headline (mono for
// code-ish names), `sub` the one-word role under it.
const nodes: { label: string; sub: string; mono: boolean }[] = [
  { label: "welcome.tsx", sub: "author", mono: true },
  { label: "render()", sub: "server", mono: true },
  { label: "HTML string", sub: "email-safe", mono: false },
  { label: "Resend SDK", sub: "send", mono: false },
  { label: "Client", sub: "inbox", mono: false },
];

const ACCENT = "#4f46e5"; // indigo-600 — the lesson's brand accent
---

<div class="rp-stage not-content">
  <div class="rp-strip" role="img" aria-label="Pipeline: welcome.tsx to render() to HTML string to Resend SDK to Client. Active stage highlighted.">
    {
      nodes.map((node, i) => (
        <>
          <div class:list={["rp-node", { "is-on": i === active }]}>
            <span class:list={["rp-node-label", { "rp-mono": node.mono }]}>
              {node.label}
            </span>
            <span class="rp-node-sub">{node.sub}</span>
          </div>
          {i < nodes.length - 1 && (
            <span class:list={["rp-arrow", { "is-on": i < active }]} aria-hidden="true">
              <svg viewBox="0 0 34 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="1" y1="7" x2="26" y2="7" />
                <polyline points="21 2.5 27.5 7 21 11.5" />
              </svg>
            </span>
          )}
        </>
      ))
    }
  </div>

  <div class="rp-detail">
    <slot />
  </div>
</div>

<style define:vars={{ accent: ACCENT }}>
  .rp-stage {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* The horizontal pipeline. Wraps (never scrolls) on narrow viewports. */
  .rp-strip {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 6px;
  }

  .rp-node {
    margin: 0;
    flex: 1 1 0;
    min-width: 96px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 11px 10px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    text-align: center;
    transition:
      border-color 0.14s,
      background-color 0.14s,
      color 0.14s,
      box-shadow 0.14s;
  }
  .rp-node.is-on {
    border: 1.5px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 13%, transparent);
    color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .rp-node-label {
    margin: 0;
    font-size: 13.5px;
    font-weight: 700;
    line-height: 1.2;
  }
  .rp-mono {
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 13px;
  }
  .rp-node-sub {
    margin: 0;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.2;
    opacity: 0.85;
  }

  /* Connectors between nodes. Edges already crossed (left of the active node)
     light up so the strip reads as progress, not just a static chain. */
  .rp-arrow {
    margin: 0;
    flex: 0 0 auto;
    align-self: center;
    display: inline-flex;
    color: var(--sl-color-gray-4);
    transition: color 0.14s;
  }
  .rp-arrow.is-on {
    color: var(--accent);
  }
  .rp-arrow svg {
    width: 28px;
    height: 14px;
  }

  /* Detail panel under the strip — fixed min-height so every frame matches and
     the grid-stacked sequence never changes height between steps. */
  .rp-detail {
    margin: 0;
    box-sizing: border-box;
    min-height: 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    padding: 13px 15px;
    border-radius: 10px;
    border: 1px dashed var(--sl-color-gray-4);
    background: var(--sl-color-bg);
  }

  /* On the narrowest viewports the nodes stack; rotate the connectors so the
     flow still reads top-to-bottom. */
  @media (max-width: 560px) {
    .rp-strip {
      flex-direction: column;
      align-items: stretch;
    }
    .rp-arrow {
      align-self: center;
      transform: rotate(90deg);
    }
  }
</style>
