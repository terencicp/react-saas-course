---
// render-pipeline — Ch049 L1 "From JSX to a message on the wire".
//
// The load-bearing mental model of the whole chapter, stepped through in time:
// you author plain JSX, render() inlines every style into one email-safe HTML
// string, the Resend SDK derives a plain-text twin and packs both into a single
// multipart/alternative message, and the client picks the part it can render.
// Once this lands, the `react` prop, the free plain-text part, and "no CSS file
// is loaded" all stop being surprising — which is exactly why it's a scrubbable
// DiagramSequence and not a paragraph.
//
// Each frame reuses <Stage> (the stable five-node strip) and fills the detail
// panel with the one thing that frame is about: a tiny JSX skeleton, the inline-
// style pass, the 2004-shaped output, the two MIME parts, the client's choice.
// DiagramSequence supplies the outer card + per-step captions, so this is NOT
// wrapped in <Figure>.

import DiagramSequence from "../../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../figures/diagram-sequence/DiagramStep.astro";
import Stage from "./Stage.astro";

const ACCENT = "#4f46e5"; // indigo-600 — matches the lit node in <Stage>
---

<DiagramSequence>
  {/* 1 — author */}
  <DiagramStep caption="You author plain JSX — a component built from React Email primitives. No state, no effects: it renders once, on the server.">
    <Stage active={0}>
      <pre class="rp-code"><code><span class="rp-tag">&lt;Html&gt;</span><span class="rp-tag">&lt;Body&gt;</span>
  <span class="rp-tag">&lt;Text&gt;</span>Welcome, &#123;firstName&#125;!<span class="rp-tag">&lt;/Text&gt;</span>
<span class="rp-tag">&lt;/Body&gt;</span><span class="rp-tag">&lt;/Html&gt;</span></code></pre>
    </Stage>
  </DiagramStep>

  {/* 2 — render */}
  <DiagramStep caption="On the server, render() walks the JSX tree and inlines every style onto its own element — there's no stylesheet for the mailbox to load.">
    <Stage active={1}>
      <div class="rp-note">
        <span class="rp-note-line">JSX tree</span>
        <span class="rp-note-arrow" aria-hidden="true">→</span>
        <span class="rp-note-line rp-note-accent">inline-style pass</span>
        <span class="rp-note-arrow" aria-hidden="true">→</span>
        <span class="rp-note-line">table layout</span>
      </div>
    </Stage>
  </DiagramStep>

  {/* 3 — HTML string */}
  <DiagramStep caption="Out comes one email-safe HTML string: table layout, every style inline — the 2004-shaped markup the worst client still parses.">
    <Stage active={2}>
      <pre class="rp-code"><code><span class="rp-tag">&lt;table&gt;&lt;tr&gt;&lt;td&gt;</span>
  <span class="rp-tag">&lt;p</span> style=<span class="rp-str">"margin:0;font-size:16px"</span><span class="rp-tag">&gt;</span>Welcome, Ada!<span class="rp-tag">&lt;/p&gt;</span>
<span class="rp-tag">&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</span></code></pre>
    </Stage>
  </DiagramStep>

  {/* 4 — Resend SDK */}
  <DiagramStep caption="The Resend SDK takes that HTML, auto-derives a plain-text version of it, and packs both into one multipart/alternative message.">
    <Stage active={3}>
      <div class="rp-mime">
        <span class="rp-mime-head">multipart/alternative</span>
        <div class="rp-mime-parts">
          <span class="rp-part">text/html</span>
          <span class="rp-part rp-part--alt">text/plain</span>
        </div>
      </div>
    </Stage>
  </DiagramStep>

  {/* 5 — Client */}
  <DiagramStep caption="The mailbox client picks the part it can render — HTML for most, plain text for the rest. You wrote one component; two formats went out.">
    <Stage active={4}>
      <div class="rp-mime">
        <div class="rp-mime-parts">
          <span class="rp-part rp-part--picked">text/html ✓</span>
          <span class="rp-part rp-part--muted">text/plain</span>
        </div>
        <span class="rp-mime-sub">most clients render the HTML part; the rest fall back to plain text</span>
      </div>
    </Stage>
  </DiagramStep>
</DiagramSequence>

<style define:vars={{ accent: ACCENT }}>
  /* Code snippets in the detail panel — small monospace blocks, no scroll. */
  .rp-code {
    margin: 0;
    box-sizing: border-box;
    overflow-x: auto;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--sl-color-text);
  }
  .rp-code code {
    font: inherit;
    color: inherit;
    background: none;
    padding: 0;
    white-space: pre;
  }
  .rp-tag {
    color: color-mix(in srgb, var(--accent) 70%, var(--sl-color-text));
  }
  .rp-str {
    color: var(--sl-color-gray-2);
  }

  /* The render-pass note (step 2) — a small labelled flow, not code. */
  .rp-note {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .rp-note-line {
    margin: 0;
    padding: 4px 11px;
    border-radius: 7px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--sl-color-gray-2);
    white-space: nowrap;
  }
  .rp-note-accent {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--sl-color-gray-4));
    background: color-mix(in srgb, var(--accent) 11%, transparent);
    color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
  }
  .rp-note-arrow {
    margin: 0;
    color: var(--sl-color-gray-3);
    font-size: 14px;
    line-height: 1;
  }

  /* The MIME container (steps 4 & 5). */
  .rp-mime {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
  }
  .rp-mime-head {
    margin: 0;
    padding: 3px 11px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 38%, transparent);
    background: color-mix(in srgb, var(--accent) 12%, var(--sl-color-bg));
    color: color-mix(in srgb, var(--accent) 78%, var(--sl-color-text));
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12px;
    font-weight: 700;
  }
  .rp-mime-parts {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .rp-part {
    margin: 0;
    padding: 4px 12px;
    border-radius: 7px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12.5px;
    font-weight: 600;
    color: var(--sl-color-text);
    white-space: nowrap;
  }
  .rp-part--alt {
    background: var(--sl-color-bg);
  }
  /* Step 5: the chosen part lights up, the other dims. */
  .rp-part--picked {
    border: 1.5px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
  }
  .rp-part--muted {
    opacity: 0.5;
  }
  .rp-mime-sub {
    margin: 0;
    font-size: 11.5px;
    line-height: 1.4;
    text-align: center;
    color: var(--sl-color-gray-3);
  }
</style>
