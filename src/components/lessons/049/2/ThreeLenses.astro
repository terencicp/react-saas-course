---
// three-lenses — Chapter 049 Lesson 2, "The preview server loop".
//
// The "three lenses on the same template" figure for the section
// "Three lenses: desktop, mobile, and dark". The placeholder asked for a
// <TabbedContent> of three <Screenshot> captures of the React Email 6 preview
// UI (Desktop / Mobile / Dark). That UI is a third-party tool we can't capture
// here, so — exactly as the sibling PreviewDefaultState.astro and
// PropsPanelStress.astro do, per the teaching-chapter convention — we build a
// faithful HTML/CSS MOCKUP of each lens inside the lesson's <Screenshot> frames
// instead of embedding literal images.
//
// The pedagogical point is COMPARISON: the identical welcome.tsx (the lesson-1
// artifact, here at its honest `firstName: 'Ada'` baseline) viewed under three
// rendering conditions. So each tab keeps the SAME rendered-email card grammar
// the sibling figures established (.rep-email: logo, heading, body, verify
// button, footer) and varies only what the lens actually changes:
//
//   - Desktop — the baseline. A slim chrome bar with the desktop viewport lit;
//     the email rendered roomy in a full-width column.
//   - Mobile  — the SAME email in the <Screenshot viewport="mobile"> frame, so
//     the column is genuinely phone-narrow (~320px) and the content stacks. The
//     chrome bar shows the mobile viewport toggle lit.
//   - Dark    — the SAME email on the preview server's own dark-toggle canvas:
//     inverted surface + light text, the button still legible. The chrome bar
//     shows the dark toggle lit. (This is the server's emulation, NOT the
//     browser OS theme — the caption calibrates trust accordingly.)
//
// The redundant left sidebar/props panel from the sibling figures is dropped:
// this figure's only job is the lens-to-render comparison, so each tab spotlights
// the email render with just enough chrome to show WHICH switch is engaged.
//
// Built as plain HTML+CSS (the diagrams index's pick for a UI illustration).
// TabbedContent supplies its own figure card, so it is NOT wrapped in <Figure>.
// Each tab's mock carries an aria-label with the prose the placeholder specified
// as <img> alt text, so every lens is described to assistive tech despite having
// no <img>. `.not-content` opts out of Starlight prose styling; Starlight CSS
// variables (with hard fallbacks) keep the light tabs themed on the Figure card,
// while the dark tab is self-contained (fixed dark palette) since it depicts the
// server's own inversion regardless of the page theme.

import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';
import Screenshot from '../../../figures/screenshot/Screenshot.astro';

const ALT_DESKTOP =
	'The welcome email in the preview server at desktop width: a roomy full-width column with the heading and verify button comfortably laid out.';
const ALT_MOBILE =
	'The welcome email in the preview server with the mobile viewport engaged, rendered at roughly 375px: the content stacked into a narrow single column.';
const ALT_DARK =
	'The welcome email with the preview server dark-mode toggle engaged: a dark background with light text, the verify button still legible.';
---

<TabbedContent>
	<TabbedItem label="Desktop">
		<div class="rep not-content" role="img" aria-label={ALT_DESKTOP}>
			<div class="rep-topbar">
				<span class="rep-brand">
					<span class="rep-brand-mark">◢◣</span>
					<span class="rep-brand-text">React Email</span>
				</span>
				<span class="rep-lenses" aria-hidden="true">
					<span class="rep-lens is-on">Desktop</span>
					<span class="rep-lens">Mobile</span>
					<span class="rep-lens">Dark</span>
				</span>
			</div>
			<div class="rep-canvas">
				<div class="rep-email">
					<div class="rep-email-logo">YourApp</div>
					<h3 class="rep-email-h">Welcome, Ada!</h3>
					<p class="rep-email-p">
						Thanks for signing up. Confirm your address to activate your account
						and get started.
					</p>
					<span class="rep-email-btn">Verify email</span>
					<p class="rep-email-foot">
						If you didn’t create an account, you can ignore this email.
					</p>
				</div>
			</div>
		</div>
		<Fragment slot="caption">The baseline — your template at its roomiest.</Fragment>
	</TabbedItem>

	<TabbedItem label="Mobile">
		<Screenshot viewport="mobile">
			<div class="rep not-content" role="img" aria-label={ALT_MOBILE}>
				<div class="rep-topbar">
					<span class="rep-brand">
						<span class="rep-brand-mark">◢◣</span>
						<span class="rep-brand-text rep-hide-narrow">React Email</span>
					</span>
					<span class="rep-lenses" aria-hidden="true">
						<span class="rep-lens">Desktop</span>
						<span class="rep-lens is-on">Mobile</span>
						<span class="rep-lens">Dark</span>
					</span>
				</div>
				<div class="rep-canvas rep-canvas-mobile">
					<div class="rep-email">
						<div class="rep-email-logo">YourApp</div>
						<h3 class="rep-email-h">Welcome, Ada!</h3>
						<p class="rep-email-p">
							Thanks for signing up. Confirm your address to activate your
							account and get started.
						</p>
						<span class="rep-email-btn">Verify email</span>
						<p class="rep-email-foot">
							If you didn’t create an account, you can ignore this email.
						</p>
					</div>
				</div>
			</div>
		</Screenshot>
		<Fragment slot="caption">
			Check the stack at ~375px — where most of your recipients actually read it.
		</Fragment>
	</TabbedItem>

	<TabbedItem label="Dark">
		<div class="rep rep-dark not-content" role="img" aria-label={ALT_DARK}>
			<div class="rep-topbar">
				<span class="rep-brand">
					<span class="rep-brand-mark">◢◣</span>
					<span class="rep-brand-text">React Email</span>
				</span>
				<span class="rep-lenses" aria-hidden="true">
					<span class="rep-lens">Desktop</span>
					<span class="rep-lens">Mobile</span>
					<span class="rep-lens is-on">Dark</span>
				</span>
			</div>
			<div class="rep-canvas">
				<div class="rep-email">
					<div class="rep-email-logo">YourApp</div>
					<h3 class="rep-email-h">Welcome, Ada!</h3>
					<p class="rep-email-p">
						Thanks for signing up. Confirm your address to activate your account
						and get started.
					</p>
					<span class="rep-email-btn">Verify email</span>
					<p class="rep-email-foot">
						If you didn’t create an account, you can ignore this email.
					</p>
				</div>
			</div>
		</div>
		<Fragment slot="caption">
			Approximate only — the toggle <em>emulates</em> client inversion. The real
			client gets the final say.
		</Fragment>
	</TabbedItem>
</TabbedContent>

<style>
	/* ---- shell (shared grammar with the sibling preview-server figures) ----- */
	.rep {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-bg, #fff);
		/* Each lens is its own self-contained "capture": round + clip the corners
		   so the dark tab's dark surface doesn't bleed past the frame. */
		border-radius: 10px;
		overflow: hidden;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}

	/* ---- top chrome bar: brand + the three lens switches ------------------- */
	.rep-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 9px 14px;
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
	}
	.rep-brand {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-weight: 700;
		letter-spacing: 0.01em;
		min-width: 0;
	}
	.rep-brand-mark {
		font-size: 11px;
		letter-spacing: -2px;
		color: var(--sl-color-gray-2, #475569);
	}

	/* The three lens toggles, drawn as a segmented control. The one matching the
	   active tab is lit (.is-on), so the student sees WHICH switch made the view —
	   reinforcing the prose's "the preview chrome gives you three switches". */
	.rep-lenses {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		padding: 2px;
		border-radius: 8px;
		background: color-mix(
			in srgb,
			var(--sl-color-gray-5, #94a3b8) 22%,
			transparent
		);
	}
	.rep-lens {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 3px 9px;
		border-radius: 6px;
		font-size: 11px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
		white-space: nowrap;
	}
	.rep-lens.is-on {
		background: var(--sl-color-text-accent, #4f46e5);
		color: #fff;
	}

	/* ---- the render stage: a neutral backdrop the email card floats on ------ */
	.rep-canvas {
		display: flex;
		justify-content: center;
		min-height: 300px;
		padding: 24px 18px;
		background: color-mix(
			in srgb,
			var(--sl-color-gray-5, #94a3b8) 12%,
			var(--sl-color-bg, #fff)
		);
	}
	/* In the mobile <Screenshot> frame the whole figure is ~320px wide, so tighten
	   the canvas padding to leave the narrow email column its room. */
	.rep-canvas-mobile {
		min-height: 340px;
		padding: 16px 10px;
	}

	/* ---- the rendered welcome email (identical card across all three lenses) - */
	.rep-email {
		width: 100%;
		max-width: 340px;
		align-self: flex-start;
		box-sizing: border-box;
		padding: 26px 24px 22px;
		border-radius: 10px;
		background: #ffffff;
		border: 1px solid #e7e9ee;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
		text-align: center;
		color: #1e293b;
	}
	.rep-email-logo {
		font-weight: 800;
		font-size: 15px;
		letter-spacing: -0.01em;
		color: #4f46e5;
		margin: 0 0 18px;
	}
	.rep-email-h {
		margin: 0 0 10px;
		font-size: 21px;
		line-height: 1.25;
		font-weight: 700;
		color: #0f172a;
	}
	.rep-email-p {
		margin: 0 0 20px;
		font-size: 13.5px;
		line-height: 1.55;
		color: #475569;
	}
	.rep-email-btn {
		display: inline-block;
		padding: 10px 22px;
		border-radius: 8px;
		background: #4f46e5;
		color: #ffffff;
		font-size: 13.5px;
		font-weight: 600;
	}
	.rep-email-foot {
		margin: 20px 0 0;
		font-size: 11.5px;
		line-height: 1.5;
		color: #94a3b8;
	}

	/* ---- the DARK lens: the preview server's own inversion ------------------ *
	 * Self-contained fixed dark palette (not the page theme) — it depicts what
	 * the server's dark toggle does to the message, independent of whether the
	 * reader is on the light or dark Figure card. Surface goes dark, text goes
	 * light, the accent button keeps enough contrast to stay legible — the
	 * "obviously broken" cases the prose says this lens is good for catching are
	 * precisely the ones that would FAIL this contrast, so the happy path here
	 * shows the button surviving. */
	.rep-dark {
		color: #e5e7eb;
		background: #0b0f1a;
		border-color: #1f2937;
	}
	.rep-dark .rep-topbar {
		background: #11161f;
		border-bottom-color: #1f2937;
	}
	.rep-dark .rep-brand-mark {
		color: #9aa4b2;
	}
	.rep-dark .rep-lenses {
		background: rgba(148, 163, 184, 0.16);
	}
	.rep-dark .rep-lens {
		color: #cbd5e1;
	}
	.rep-dark .rep-canvas {
		background: #0b0f1a;
	}
	.rep-dark .rep-email {
		background: #161b26;
		border-color: #2a3140;
		box-shadow: none;
		color: #e5e7eb;
	}
	.rep-dark .rep-email-logo {
		color: #a5b4fc;
	}
	.rep-dark .rep-email-h {
		color: #f8fafc;
	}
	.rep-dark .rep-email-p {
		color: #cbd5e1;
	}
	.rep-dark .rep-email-btn {
		background: #6366f1;
		color: #ffffff;
	}
	.rep-dark .rep-email-foot {
		color: #8a93a3;
	}

	/* On the narrow mobile frame, drop the wordmark text so the lens switches
	   keep their room; the ◢◣ mark alone still reads as the same chrome. */
	.rep-hide-narrow {
		display: none;
	}
</style>
