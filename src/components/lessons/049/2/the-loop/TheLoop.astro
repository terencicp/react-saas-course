---
// the-loop — Ch049 L2 "The preview server loop", synthesis figure.
//
// The spine of the lesson made scrubbable: the seven-step template iteration loop,
// one node lit at a time. The pedagogical engine is "each step catches a class of
// failure the previous step CANNOT" — so the detail panel under the strip names
// that failure class at a glance (a small CATCHES tag), and the DiagramSequence
// caption carries the full sentence. The first and last steps frame instead of
// catch (the starting code on disk; the verified template going live), so they
// get a START / SHIP tag rather than a CATCHES one.
//
// It deliberately reuses lesson 1's render-pipeline visual grammar via <LoopStrip>
// (the stable lit/dimmed node strip + arrow connectors), so the two scrubbable
// diagrams in this chapter read as one language. DiagramSequence supplies the
// outer card + per-step captions, so this is NOT wrapped in <Figure>.

import DiagramSequence from "../../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../figures/diagram-sequence/DiagramStep.astro";
import LoopStrip from "./LoopStrip.astro";

const ACCENT = "#4f46e5"; // indigo-600 — matches the lit node in <LoopStrip>
---

<DiagramSequence>
	{/* 1 — Write template */}
	<DiagramStep caption="The starting point — code on disk, still unseen. Every later step exists to see what this one can't.">
		<LoopStrip active={0}>
			<span class="lp-tag lp-tag--frame">Start</span>
			<span class="lp-what">
				<code>emails/welcome.tsx</code> exists, but you've only read it as code.
			</span>
		</LoopStrip>
	</DiagramStep>

	{/* 2 — PreviewProps */}
	<DiagramStep caption="Without realistic mock data the preview has nothing to render. This is the step that makes the rest of the loop possible.">
		<LoopStrip active={1}>
			<span class="lp-tag">Unlocks</span>
			<span class="lp-what">A template is a pure function of its props — no values, nothing to show.</span>
		</LoopStrip>
	</DiagramStep>

	{/* 3 — Run dev server */}
	<DiagramStep caption="Turns code-on-disk into something you can look at — and the file watcher catches your next save automatically.">
		<LoopStrip active={2}>
			<span class="lp-tag">Catches</span>
			<span class="lp-what">the gap between code and a render — save, and it hot-reloads in a second.</span>
		</LoopStrip>
	</DiagramStep>

	{/* 4 — Eyeball desktop / mobile / dark */}
	<DiagramStep caption="Catches layout: the 600px desktop wrap, the 375px mobile stack, and the obviously-broken dark case the static code can't reveal.">
		<LoopStrip active={3}>
			<span class="lp-tag">Catches</span>
			<span class="lp-what"><strong>layout</strong> — the 600px wrap, the 375px stack, the broken-dark case.</span>
		</LoopStrip>
	</DiagramStep>

	{/* 5 — Read plain-text */}
	<DiagramStep caption="Catches the text-part incoherence the visual render hides — the half of the message screen readers and HTML-stripping clients actually get.">
		<LoopStrip active={4}>
			<span class="lp-tag">Catches</span>
			<span class="lp-what">an <strong>incoherent text part</strong> the visual render hides entirely.</span>
		</LoopStrip>
	</DiagramStep>

	{/* 6 — Test-send */}
	<DiagramStep caption="Catches what the preview can't fake: a real client's dark-mode inversion and Outlook's VML button path. This is the verification gate.">
		<LoopStrip active={5}>
			<span class="lp-tag lp-tag--gate">Gate</span>
			<span class="lp-what">what the preview <strong>can't fake</strong> — real client inversion, Outlook VML.</span>
		</LoopStrip>
	</DiagramStep>

	{/* 7 — Wire into Server Action */}
	<DiagramStep caption="The template, now verified, goes live behind real props — wired into the Server Action with the sendEmail wrapper from the last chapter.">
		<LoopStrip active={6}>
			<span class="lp-tag lp-tag--frame">Ship</span>
			<span class="lp-what"><code>sendEmail(&#123; react: &lt;WelcomeEmail … /&gt; &#125;)</code> — verified, now live.</span>
		</LoopStrip>
	</DiagramStep>
</DiagramSequence>

<style define:vars={{ accent: ACCENT }}>
	/* The CATCHES tag — the lesson's "each step catches what the last missed"
	   engine, made into a small glanceable pill. Indigo by default (matches the
	   lit node), neutral for the framing steps, stronger for the verification
	   gate so the test-send reads as the climax of the chain. */
	.lp-tag {
		flex: 0 0 auto;
		display: inline-block;
		padding: 2px 9px;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--accent) 38%, transparent);
		background: color-mix(in srgb, var(--accent) 12%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		line-height: 1.4;
	}
	.lp-tag--frame {
		border-color: var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
	}
	.lp-tag--gate {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 18%, transparent);
		color: color-mix(in srgb, var(--accent) 88%, var(--sl-color-text));
	}

	.lp-what {
		margin: 0;
		max-width: 46ch;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-text);
	}
	.lp-what strong {
		font-weight: 700;
		color: color-mix(in srgb, var(--accent) 70%, var(--sl-color-text));
	}
	.lp-what code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12px;
		padding: 1px 5px;
		border-radius: 5px;
		background: var(--sl-color-gray-6);
		color: var(--sl-color-text);
	}
</style>
