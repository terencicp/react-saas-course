---
// One frame of the "the-loop" DiagramSequence (Ch049 L2, "The preview server
// loop"). It echoes lesson 1's render-pipeline Stage on purpose: the same
// horizontal strip of nodes with one lit (`is-on`, indigo accent) and SVG arrow
// connectors that light as they're crossed, so the chapter reads as one visual
// language. Where lesson 1 walked an artifact through a render pipeline, this
// walks the developer through the seven-step iteration loop:
//
//   Write → PreviewProps → Run dev → Eyeball → Plain-text → Test-send → Wire in
//
// The whole strip is stable across the seven steps; only the lit node and the
// detail panel beneath it change, so it lives here once and each DiagramStep
// passes a different `active` index plus a slotted detail line. Keeping the strip
// fixed is the point — the eye tracks ONE position advancing left-to-right, the
// way the real loop advances stage by stage.
//
// The detail panel under the strip names the FAILURE CLASS this step catches (the
// lesson's "each step catches what the last one missed" engine), made glanceable;
// the DiagramStep caption carries the full sentence. A fixed min-height keeps
// every frame the same height so DiagramSequence's grid-stack never jumps.
//
// Pure HTML + CSS, matching the sibling figures: `.not-content` to drop
// Starlight's prose chrome, `margin: 0` resets, theme-aware `color-mix` accents
// that read on light and dark.

interface Props {
	// Index (0-6) of the node lit this frame.
	active: number;
}

const { active } = Astro.props;

// The seven loop stages, in order. `label` is the node's headline (mono for the
// CLI command), `sub` the one-word role under it. Labels are kept short so seven
// nodes fit one wrapping row without blowing the height cap.
const nodes: { label: string; sub: string; mono: boolean }[] = [
	{ label: "Write", sub: "template", mono: false },
	{ label: "PreviewProps", sub: "mock data", mono: true },
	{ label: "email dev", sub: "run", mono: true },
	{ label: "Eyeball", sub: "render", mono: false },
	{ label: "Plain-text", sub: "read", mono: false },
	{ label: "Test-send", sub: "verify", mono: false },
	{ label: "Wire in", sub: "ship", mono: false },
];

const ACCENT = "#4f46e5"; // indigo-600 — the chapter's brand accent
---

<div class="lp-stage not-content">
	<div
		class="lp-strip"
		role="img"
		aria-label="Iteration loop: Write template, PreviewProps, run email dev, eyeball render, read plain-text, test-send, wire into the Server Action. Active stage highlighted."
	>
		{
			nodes.map((node, i) => (
				<>
					<div class:list={["lp-node", { "is-on": i === active }]}>
						<span class:list={["lp-node-label", { "lp-mono": node.mono }]}>
							{node.label}
						</span>
						<span class="lp-node-sub">{node.sub}</span>
					</div>
					{i < nodes.length - 1 && (
						<span
							class:list={["lp-arrow", { "is-on": i < active }]}
							aria-hidden="true"
						>
							<svg
								viewBox="0 0 34 14"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<line x1="1" y1="7" x2="26" y2="7" />
								<polyline points="21 2.5 27.5 7 21 11.5" />
							</svg>
						</span>
					)}
				</>
			))
		}
	</div>

	<div class="lp-detail">
		<slot />
	</div>
</div>

<style define:vars={{ accent: ACCENT }}>
	.lp-stage {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* The horizontal loop strip. Wraps (never scrolls) on narrow viewports. */
	.lp-strip {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
	}

	.lp-node {
		margin: 0;
		flex: 1 1 0;
		min-width: 84px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		padding: 9px 8px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s;
	}
	.lp-node.is-on {
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
	}

	.lp-node-label {
		margin: 0;
		font-size: 13px;
		font-weight: 700;
		line-height: 1.2;
	}
	.lp-mono {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12px;
	}
	.lp-node-sub {
		margin: 0;
		font-size: 9.5px;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		line-height: 1.2;
		opacity: 0.85;
	}

	/* Connectors between nodes. Edges already crossed (left of the active node)
	   light up so the strip reads as progress, not a static chain. */
	.lp-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.lp-arrow.is-on {
		color: var(--accent);
	}
	.lp-arrow svg {
		width: 24px;
		height: 13px;
	}

	/* Detail panel under the strip — names the failure class this step catches.
	   Fixed min-height so every frame matches and the grid-stacked sequence never
	   changes height between steps. */
	.lp-detail {
		margin: 0;
		box-sizing: border-box;
		min-height: 76px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 7px;
		padding: 13px 15px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		text-align: center;
	}

	/* On the narrowest viewports the nodes stack; rotate the connectors so the
	   flow still reads top-to-bottom. */
	@media (max-width: 560px) {
		.lp-strip {
			flex-direction: column;
			align-items: stretch;
		}
		.lp-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
