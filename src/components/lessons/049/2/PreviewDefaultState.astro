---
// preview-default-state — Chapter 049 Lesson 2, "The preview server loop".
//
// The canonical "React Email preview server, default state" figure, referenced
// conceptually throughout the lesson. The placeholder asked for a real screenshot
// of the React Email 6 preview UI, but that UI is a third-party tool we can't
// capture here — so per the teaching-chapter convention we build a faithful
// HTML/CSS MOCKUP of it instead of embedding a literal screenshot image.
//
// What the mock depicts (the two-pane default layout):
//   - a slim top chrome bar with the React Email wordmark and the affordances the
//     rest of the lesson teaches (viewport toggle, dark toggle, Send) drawn as
//     small inert glyphs, so the student recognizes the chrome later;
//   - a left panel listing the templates found in `emails/`, with `welcome.tsx`
//     selected/highlighted and a couple of plausible siblings to make the list
//     read as a real directory scan;
//   - the main panel rendering the welcome email driven by its PreviewProps —
//     a heading greeting "Ada", a line of body copy, and the verify button — so
//     the caption's claim ("the name Ada and the verify URL come from
//     PreviewProps") is literally visible.
//
// Built as plain HTML+CSS (the diagrams index's pick for a UI illustration) and
// wrapped in the lesson's <Screenshot viewport="desktop"> inside <Figure>, exactly
// as the placeholder specified — the Screenshot frame supplies the bordered,
// internally-scrolling "capture" shell; this component supplies its contents.
//
// The mock carries an aria-label describing the two-pane layout (the prose that
// the placeholder specified as the <img> alt text) so the figure is still
// described to assistive tech even though there is no <img>. `.not-content` opts
// the whole thing out of Starlight prose styling; Starlight CSS variables (with
// fallbacks) keep it themed on both the light and dark Figure card.

import Figure from '../../../figures/Figure.astro';
import Screenshot from '../../../figures/screenshot/Screenshot.astro';

const ALT =
	'The React Email preview server. A left panel lists email templates with welcome.tsx selected; the main panel renders the welcome email addressed to Ada with a verification button.';

// The files the server found scanning the `emails/` directory. welcome.tsx is the
// lesson-1 artifact and the selected one; the siblings make the list read as real.
const templates = [
	{ name: 'welcome.tsx', selected: true },
	{ name: 'reset-password.tsx', selected: false },
	{ name: 'invoice-receipt.tsx', selected: false },
];
---

<Figure>
	<Screenshot viewport="desktop">
		<div class="rep not-content" role="img" aria-label={ALT}>
			<!-- Top chrome: wordmark on the left, the lesson's affordances on the right. -->
			<div class="rep-topbar">
				<span class="rep-brand">
					<span class="rep-brand-mark">◢◣</span>
					<span class="rep-brand-text">React Email</span>
				</span>
				<span class="rep-tools" aria-hidden="true">
					<span class="rep-tool">Desktop</span>
					<span class="rep-tool rep-tool-icon" title="Mobile viewport">▢</span>
					<span class="rep-tool rep-tool-icon" title="Dark mode">◑</span>
					<span class="rep-tool rep-tool-cta">Send</span>
				</span>
			</div>

			<div class="rep-body">
				<!-- Left panel: the templates the server found in emails/. -->
				<aside class="rep-sidebar">
					<div class="rep-sidebar-head">
						<span class="rep-sidebar-label">EMAILS</span>
					</div>
					<ul class="rep-list">
						{
							templates.map((t) => (
								<li
									class:list={['rep-item', { 'is-selected': t.selected }]}
									aria-current={t.selected ? 'true' : undefined}
								>
									<span class="rep-item-icon" aria-hidden="true">
										{'</>'}
									</span>
									<span class="rep-item-name">{t.name}</span>
								</li>
							))
						}
					</ul>
				</aside>

				<!-- Main panel: the rendered welcome email, driven by PreviewProps. -->
				<section class="rep-main">
					<div class="rep-main-bar" aria-hidden="true">
						<span class="rep-tabpill is-active">Preview</span>
						<span class="rep-tabpill">HTML</span>
						<span class="rep-tabpill">Plain Text</span>
					</div>
					<div class="rep-canvas">
						<div class="rep-email">
							<div class="rep-email-logo">YourApp</div>
							<h3 class="rep-email-h">Welcome, Ada!</h3>
							<p class="rep-email-p">
								Thanks for signing up. Confirm your address to activate your
								account and get started.
							</p>
							<span class="rep-email-btn">Verify email</span>
							<p class="rep-email-foot">
								If you didn’t create an account, you can ignore this email.
							</p>
						</div>
					</div>
				</section>
			</div>
		</div>
	</Screenshot>
	<Fragment slot="caption">
		Your lesson-1 template, rendered. The server reads <code>PreviewProps</code> —
		that’s where the name Ada and the verify URL come from.
	</Fragment>
</Figure>

<style>
	/* ---- shell ------------------------------------------------------------- */
	.rep {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-bg, #fff);
	}

	/* ---- top chrome bar ---------------------------------------------------- */
	.rep-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 9px 14px;
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
	}
	.rep-brand {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-weight: 700;
		letter-spacing: 0.01em;
	}
	.rep-brand-mark {
		font-size: 11px;
		letter-spacing: -2px;
		color: var(--sl-color-gray-2, #475569);
	}
	.rep-tools {
		display: inline-flex;
		align-items: center;
		gap: 7px;
	}
	.rep-tool {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 22px;
		height: 22px;
		padding: 0 8px;
		border-radius: 6px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
		color: var(--sl-color-gray-2, #475569);
		font-size: 11.5px;
		font-weight: 600;
	}
	.rep-tool-icon {
		padding: 0;
	}
	.rep-tool-cta {
		border-color: transparent;
		background: var(--sl-color-text-accent, #4f46e5);
		color: var(--sl-color-bg, #fff);
	}

	/* ---- two-pane body ----------------------------------------------------- */
	.rep-body {
		display: flex;
		min-height: 320px;
	}

	/* ---- left sidebar / template list ------------------------------------- */
	.rep-sidebar {
		flex: 0 0 38%;
		max-width: 220px;
		border-right: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		padding: 10px 8px;
	}
	.rep-sidebar-head {
		padding: 2px 8px 8px;
	}
	.rep-sidebar-label {
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3, #64748b);
	}
	.rep-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.rep-item {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 0;
		padding: 6px 8px;
		border-radius: 6px;
		color: var(--sl-color-gray-2, #475569);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12.5px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.rep-item.is-selected {
		background: color-mix(in srgb, var(--sl-color-text-accent, #4f46e5) 16%, transparent);
		color: var(--sl-color-white, #1e293b);
		font-weight: 600;
		box-shadow: inset 0 0 0 1px
			color-mix(in srgb, var(--sl-color-text-accent, #4f46e5) 35%, transparent);
	}
	.rep-item-icon {
		color: var(--sl-color-gray-3, #94a3b8);
		font-size: 11px;
	}
	.rep-item.is-selected .rep-item-icon {
		color: var(--sl-color-text-accent, #4f46e5);
	}
	.rep-item-name {
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* ---- main panel -------------------------------------------------------- */
	.rep-main {
		flex: 1 1 auto;
		min-width: 0;
		display: flex;
		flex-direction: column;
		background: var(--sl-color-bg, #fff);
	}
	.rep-main-bar {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px 12px;
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}
	.rep-tabpill {
		padding: 3px 10px;
		border-radius: 999px;
		font-size: 11.5px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
	}
	.rep-tabpill.is-active {
		background: color-mix(in srgb, var(--sl-color-gray-5, #94a3b8) 35%, transparent);
		color: var(--sl-color-white, #1e293b);
	}

	/* The render canvas — a neutral backdrop the email card floats on, as the
	   real preview shows the message centered on a plain stage. */
	.rep-canvas {
		flex: 1 1 auto;
		display: flex;
		justify-content: center;
		padding: 22px 16px;
		background: color-mix(in srgb, var(--sl-color-gray-5, #94a3b8) 12%, var(--sl-color-bg, #fff));
	}

	/* The rendered welcome email itself — a white card, brand-neutral, addressed
	   to Ada (the PreviewProps value) with the verify button. */
	.rep-email {
		width: 100%;
		max-width: 340px;
		align-self: flex-start;
		box-sizing: border-box;
		padding: 26px 24px 22px;
		border-radius: 10px;
		background: #ffffff;
		border: 1px solid #e7e9ee;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
		text-align: center;
		color: #1e293b;
	}
	.rep-email-logo {
		font-weight: 800;
		font-size: 15px;
		letter-spacing: -0.01em;
		color: #4f46e5;
		margin: 0 0 18px;
	}
	.rep-email-h {
		margin: 0 0 10px;
		font-size: 21px;
		line-height: 1.25;
		font-weight: 700;
		color: #0f172a;
	}
	.rep-email-p {
		margin: 0 0 20px;
		font-size: 13.5px;
		line-height: 1.55;
		color: #475569;
	}
	.rep-email-btn {
		display: inline-block;
		padding: 10px 22px;
		border-radius: 8px;
		background: #4f46e5;
		color: #ffffff;
		font-size: 13.5px;
		font-weight: 600;
	}
	.rep-email-foot {
		margin: 20px 0 0;
		font-size: 11.5px;
		line-height: 1.5;
		color: #94a3b8;
	}

	/* On a narrow Figure (mobile reading width) keep both panes legible: shrink
	   the sidebar a touch rather than letting the email card get squeezed. */
	@media (max-width: 520px) {
		.rep-sidebar {
			flex-basis: 42%;
			max-width: 150px;
		}
		.rep-canvas {
			padding: 16px 10px;
		}
	}
</style>
