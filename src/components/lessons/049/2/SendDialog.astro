---
// send-dialog — Chapter 049 Lesson 2, "The preview server loop".
//
// The "test-send is the gate" figure. The placeholder asked for a real screenshot
// of the React Email 6 preview server's Send dialog (a recipient email field + a
// Send button). That UI is a third-party tool we can't capture here, so — exactly
// as the sibling figures PreviewDefaultState.astro, PropsPanelStress.astro and
// ThreeLenses.astro do, per the teaching-chapter convention — we build a faithful
// HTML/CSS MOCKUP of it inside the lesson's <Screenshot> frame instead of
// embedding a literal image.
//
// What the mock depicts, and why each piece is here:
//   - the same slim top chrome bar the sibling figures established (wordmark +
//     viewport/dark glyphs), with the Send tool drawn ACTIVE (accent ring) so the
//     student reads the dialog as the thing that "Send" just opened — the trigger
//     made visible;
//   - the render canvas dimmed behind a scrim, the way a real modal darkens what
//     it sits over, so the dialog reads as an overlay on the running preview;
//   - the dialog itself, centered: a title, a recipient email field shown
//     mid-edit (focused accent ring + a plausible address + blinking caret), a
//     one-line note that it fires a real message through Resend, and the primary
//     Send button. The recipient field + Send button are the two elements the
//     placeholder named; everything else is just enough chrome to place them.
//
// Built as plain HTML+CSS (the diagrams index's pick for a UI illustration) and
// wrapped in the lesson's <Screenshot viewport="desktop"> inside <Figure>, exactly
// as the placeholder specified — the Screenshot frame supplies the bordered
// "capture" shell; this component supplies its contents.
//
// The mock carries an aria-label with the prose the placeholder specified as the
// <img> alt text, so the figure is described to assistive tech even though there
// is no <img>. `.not-content` opts out of Starlight prose styling; Starlight CSS
// variables (with hard fallbacks) keep it themed on both the light and dark
// Figure card.

import Figure from '../../../figures/Figure.astro';
import Screenshot from '../../../figures/screenshot/Screenshot.astro';

const ALT =
	"The preview server's send dialog, with a recipient email address field and a Send button for dispatching a real test email through Resend.";

// The recipient typed into the dialog — a personal inbox you actually open, the
// canonical practice the prose names. Split so the trailing caret is a sibling.
const RECIPIENT = 'you@gmail.com';
---

<Figure>
	<Screenshot viewport="desktop">
		<div class="rep not-content" role="img" aria-label={ALT}>
			<!-- Top chrome: same grammar as the sibling figures, but Send is ACTIVE
			     — it is the affordance that opened the dialog below. -->
			<div class="rep-topbar">
				<span class="rep-brand">
					<span class="rep-brand-mark">◢◣</span>
					<span class="rep-brand-text">React Email</span>
				</span>
				<span class="rep-tools" aria-hidden="true">
					<span class="rep-tool">Desktop</span>
					<span class="rep-tool rep-tool-icon" title="Mobile viewport">▢</span>
					<span class="rep-tool rep-tool-icon" title="Dark mode">◑</span>
					<span class="rep-tool rep-tool-cta is-active">Send</span>
				</span>
			</div>

			<!-- The stage: the running preview, dimmed behind the modal scrim. -->
			<div class="rep-stage">
				<div class="rep-canvas" aria-hidden="true">
					<div class="rep-email">
						<div class="rep-email-logo">YourApp</div>
						<h3 class="rep-email-h">Welcome, Ada!</h3>
						<p class="rep-email-p">
							Thanks for signing up. Confirm your address to activate your
							account and get started.
						</p>
						<span class="rep-email-btn">Verify email</span>
					</div>
				</div>

				<!-- Scrim + the Send dialog floating over the dimmed preview. -->
				<div class="rep-scrim"></div>
				<div class="rep-dialog" role="presentation">
					<div class="rep-dialog-head">
						<span class="rep-dialog-title">Send test email</span>
						<span class="rep-dialog-x" aria-hidden="true">×</span>
					</div>

					<label class="rep-dialog-field-label" for="rep-send-to">
						Send to
					</label>
					<div class="rep-dialog-input is-active">
						<span class="rep-dialog-input-val" id="rep-send-to">{RECIPIENT}</span
						><span class="rep-caret" aria-hidden="true"></span>
					</div>

					<p class="rep-dialog-note">
						<span class="rep-dialog-note-dot" aria-hidden="true"></span>
						Fires a real email through Resend, using your project's API key.
					</p>

					<div class="rep-dialog-actions">
						<span class="rep-dialog-btn rep-dialog-btn-ghost">Cancel</span>
						<span class="rep-dialog-btn rep-dialog-btn-send">Send</span>
					</div>
				</div>
			</div>
		</div>
	</Screenshot>
	<Fragment slot="caption">
		The gate — a real send through Resend to an inbox you actually read.
	</Fragment>
</Figure>

<style>
	/* ---- shell (shared grammar with the sibling preview-server figures) ----- */
	.rep {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-bg, #fff);
	}

	/* ---- top chrome bar ---------------------------------------------------- */
	.rep-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 9px 14px;
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
	}
	.rep-brand {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-weight: 700;
		letter-spacing: 0.01em;
	}
	.rep-brand-mark {
		font-size: 11px;
		letter-spacing: -2px;
		color: var(--sl-color-gray-2, #475569);
	}
	.rep-tools {
		display: inline-flex;
		align-items: center;
		gap: 7px;
	}
	.rep-tool {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 22px;
		height: 22px;
		padding: 0 8px;
		border-radius: 6px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
		color: var(--sl-color-gray-2, #475569);
		font-size: 11.5px;
		font-weight: 600;
	}
	.rep-tool-icon {
		padding: 0;
	}
	.rep-tool-cta {
		border-color: transparent;
		background: var(--sl-color-text-accent, #4f46e5);
		color: var(--sl-color-bg, #fff);
	}
	/* The Send tool is the one that opened the dialog — give it the pressed/active
	   ring so the trigger→dialog relationship reads at a glance. */
	.rep-tool-cta.is-active {
		box-shadow: 0 0 0 3px
			color-mix(in srgb, var(--sl-color-text-accent, #4f46e5) 30%, transparent);
	}

	/* ---- the stage: running preview behind a modal scrim ------------------- */
	.rep-stage {
		position: relative;
		min-height: 320px;
	}

	/* The dimmed preview render sitting under the modal. */
	.rep-canvas {
		display: flex;
		justify-content: center;
		min-height: 320px;
		padding: 24px 18px;
		background: color-mix(
			in srgb,
			var(--sl-color-gray-5, #94a3b8) 12%,
			var(--sl-color-bg, #fff)
		);
	}
	.rep-email {
		width: 100%;
		max-width: 340px;
		align-self: flex-start;
		box-sizing: border-box;
		padding: 26px 24px 22px;
		border-radius: 10px;
		background: #ffffff;
		border: 1px solid #e7e9ee;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
		text-align: center;
		color: #1e293b;
	}
	.rep-email-logo {
		font-weight: 800;
		font-size: 15px;
		letter-spacing: -0.01em;
		color: #4f46e5;
		margin: 0 0 18px;
	}
	.rep-email-h {
		margin: 0 0 10px;
		font-size: 21px;
		line-height: 1.25;
		font-weight: 700;
		color: #0f172a;
	}
	.rep-email-p {
		margin: 0 0 20px;
		font-size: 13.5px;
		line-height: 1.55;
		color: #475569;
	}
	.rep-email-btn {
		display: inline-block;
		padding: 10px 22px;
		border-radius: 8px;
		background: #4f46e5;
		color: #ffffff;
		font-size: 13.5px;
		font-weight: 600;
	}

	/* The scrim that darkens the preview behind the modal. */
	.rep-scrim {
		position: absolute;
		inset: 0;
		background: rgba(15, 23, 42, 0.42);
	}

	/* ---- the Send dialog --------------------------------------------------- */
	.rep-dialog {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: min(92%, 360px);
		box-sizing: border-box;
		padding: 18px 18px 16px;
		border-radius: 12px;
		background: var(--sl-color-bg, #fff);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		box-shadow: 0 18px 48px rgba(15, 23, 42, 0.32);
		color: var(--sl-color-white, #1e293b);
	}
	.rep-dialog-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 14px;
	}
	.rep-dialog-title {
		font-size: 14.5px;
		font-weight: 700;
		color: var(--sl-color-white, #0f172a);
	}
	.rep-dialog-x {
		font-size: 16px;
		line-height: 1;
		color: var(--sl-color-gray-3, #94a3b8);
	}
	.rep-dialog-field-label {
		display: block;
		margin-bottom: 6px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
	}
	.rep-dialog-input {
		display: flex;
		align-items: center;
		min-height: 34px;
		padding: 6px 10px;
		border-radius: 7px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
		font-size: 13px;
		overflow: hidden;
	}
	/* The recipient field is focused/mid-edit — accent ring, like the props field
	   in the sibling stress figure, so it reads as the thing you type into. */
	.rep-dialog-input.is-active {
		border-color: var(--sl-color-text-accent, #4f46e5);
		box-shadow: 0 0 0 3px
			color-mix(in srgb, var(--sl-color-text-accent, #4f46e5) 22%, transparent);
	}
	.rep-dialog-input-val {
		color: var(--sl-color-white, #0f172a);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	/* Blinking caret right after the typed address — sells "mid-edit". */
	.rep-caret {
		flex: 0 0 auto;
		width: 1.5px;
		height: 16px;
		margin-left: 1px;
		background: var(--sl-color-text-accent, #4f46e5);
		animation: rep-blink 1.05s step-end infinite;
	}
	@keyframes rep-blink {
		0%,
		50% {
			opacity: 1;
		}
		50.01%,
		100% {
			opacity: 0;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.rep-caret {
			animation: none;
		}
	}

	/* The "this is a real send" note — quiet, but it carries the gate's weight. */
	.rep-dialog-note {
		display: flex;
		align-items: flex-start;
		gap: 7px;
		margin: 11px 0 16px;
		font-size: 11.5px;
		line-height: 1.45;
		color: var(--sl-color-gray-3, #64748b);
	}
	.rep-dialog-note-dot {
		flex: 0 0 auto;
		width: 7px;
		height: 7px;
		margin-top: 4px;
		border-radius: 50%;
		background: var(--sl-color-text-accent, #4f46e5);
	}

	.rep-dialog-actions {
		display: flex;
		justify-content: flex-end;
		gap: 8px;
	}
	.rep-dialog-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 32px;
		padding: 0 16px;
		border-radius: 7px;
		font-size: 13px;
		font-weight: 600;
	}
	.rep-dialog-btn-ghost {
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
		color: var(--sl-color-gray-2, #475569);
	}
	.rep-dialog-btn-send {
		background: var(--sl-color-text-accent, #4f46e5);
		color: #fff;
	}

	/* On a narrow Figure (mobile reading width) tighten the canvas padding so the
	   dimmed preview keeps its room behind the dialog. */
	@media (max-width: 520px) {
		.rep-canvas {
			padding: 16px 10px;
		}
		.rep-dialog {
			padding: 16px 14px 14px;
		}
	}
</style>
