---
// RequestPathInversion — Chapter 091 Lesson 2, "Reading the test harness".
//
// The lesson's senior anchor: the production webhook route runs COMPLETELY
// UNEDITED, yet the test owns the transaction the route thinks it owns. This
// figure traces one signed request straight down through six boxes and then
// loops a green return arrow back up the right margin to show the rollback
// discarding everything at teardown.
//
// The conceptual beat is the INVERSION at the middle: the route calls
// db.transaction(fn) expecting to open its own tx; the @/db Proxy mock
// intercepts that call and instead runs fn on the OUTER tx that withRollback
// already opened. So the two middle boxes (the route's call + the Proxy that
// intercepts it) are tinted blue — that is where the harness quietly takes
// over. withRollback's tx is tinted green to color-match the rollback return
// arrow that discards everything it wrote.
//
// Built with <ArrowDiagram> (LeaderLine): the boxes are two-line custom HTML
// (a monospace title + a muted under-label), and the green loop-back arrow
// carrying semantic meaning is the whole point — D2/Mermaid plain-label nodes
// wouldn't carry the "harness owns the boundary" story. Arrows are positioned
// from document.body, so the wrapping <Figure> MUST be expandable={false}.
//
// Layout: a single vertical column (request flows top→bottom). Down-arrows use
// bottom→top sockets. The rollback return arrow leaves withRollback's tx on the
// RIGHT, swings up through the reserved right margin, and lands on the route's
// POST box — visually "the harness unwinds the whole call". Right margin is
// reserved on the column so the loop-back curve has a lane of its own.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// The six boxes, top → bottom. `tint`: 'harness' marks the inversion seam
// (blue), 'rollback' marks the tx withRollback owns (green, color-matched to the
// return arrow). `id` matches the arrow descriptors.
const boxes = [
	{
		id: 'rp-helper',
		title: 'postWebhook(event)',
		under: 'the test helper',
	},
	{
		id: 'rp-route',
		title: 'POST route handler',
		under: 'app/api/webhooks/stripe/route.ts — unedited',
	},
	{
		id: 'rp-call',
		title: 'db.transaction(fn)',
		under: 'what the route calls',
		tint: 'harness',
	},
	{
		id: 'rp-proxy',
		title: '@/db Proxy mock',
		under: 'intercepts the call',
		tint: 'harness',
	},
	{
		id: 'rp-tx',
		title: 'testTxContext tx',
		under: 'opened by withRollback',
		tint: 'rollback',
	},
	{
		id: 'rp-pg',
		title: 'test Postgres',
		under: 'localhost:55432',
	},
];

// Mid-tone accents reused verbatim in light + dark.
const HARNESS_BLUE = '#0ea5e9'; // the seam where the harness takes over
const ROLLBACK_GREEN = '#16a34a'; // the rollback the test owns

const arrows = [
	{
		from: 'rp-helper',
		to: 'rp-route',
		label: 'signed Request',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 40],
		endSocketGravity: [0, -40],
	},
	{
		from: 'rp-route',
		to: 'rp-call',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 36],
		endSocketGravity: [0, -36],
	},
	{
		from: 'rp-call',
		to: 'rp-proxy',
		label: 'intercepted',
		color: HARNESS_BLUE,
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 40],
		endSocketGravity: [0, -40],
	},
	{
		from: 'rp-proxy',
		to: 'rp-tx',
		label: 'runs fn on the outer tx',
		color: HARNESS_BLUE,
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 44],
		endSocketGravity: [0, -44],
	},
	{
		from: 'rp-tx',
		to: 'rp-pg',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 36],
		endSocketGravity: [0, -36],
	},
	// The teardown unwind: withRollback throws RollbackSignal, the whole tx is
	// discarded. Leaves the rollback tx on the right, swings up the reserved
	// right margin, lands on the route box — "everything the route wrote is
	// gone". Green to color-match the rollback tx box.
	{
		from: 'rp-tx',
		to: 'rp-route',
		label: 'RollbackSignal discards everything at teardown',
		color: ROLLBACK_GREEN,
		startSocket: 'right',
		endSocket: 'right',
		startSocketGravity: [180, 0],
		endSocketGravity: [180, 0],
		labelOffset: [40, 0],
		labelStyle:
			'background:#f0fdf4;border:1px solid #16a34a;color:#15803d;',
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="rp not-content">
			{
				boxes.map((box) => (
					<div class="rp-box" data-tint={box.tint} id={box.id}>
						<span class="rp-title">{box.title}</span>
						<span class="rp-under">{box.under}</span>
					</div>
				))
			}
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		The route thinks it opened its own transaction. The harness opened it, and
		the harness rolls it back — so the production code runs completely unedited.
	</Fragment>
</Figure>

<style>
	.rp {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 38px;
		margin: 0;
		/* Reserve a lane on the right for the loop-back rollback curve + label. */
		padding: 14px 250px 14px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.rp-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		padding: 10px 16px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
		min-width: 16rem;
	}

	/* The inversion seam — where the harness quietly takes over the route's call. */
	.rp-box[data-tint='harness'] {
		border-color: #0ea5e9;
		background: color-mix(in srgb, #0ea5e9 12%, var(--sl-color-bg, transparent));
	}

	/* The transaction withRollback owns; color-matched to the rollback arrow. */
	.rp-box[data-tint='rollback'] {
		border-color: #16a34a;
		background: color-mix(in srgb, #16a34a 12%, var(--sl-color-bg, transparent));
	}

	.rp-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.86rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.rp-under {
		font-size: 0.68rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: drop the reserved right lane; the loop-back curve degrades
	   to an arc on the right of the stacked column — readable, label still floats. */
	@media (max-width: 640px) {
		.rp {
			padding: 14px 4px;
			gap: 30px;
		}
		.rp-box {
			min-width: 0;
			width: min(20rem, 100%);
		}
		.rp-title {
			white-space: normal;
		}
		.rp-under {
			white-space: normal;
		}
	}
</style>
