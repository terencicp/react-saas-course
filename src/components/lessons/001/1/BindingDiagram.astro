---
import Figure from '../../../figures/Figure.astro';
---

<Figure caption="Two bindings, one shared object. The arrow is the part = copied.">
	<div style="overflow-x: auto;">
	<svg
		viewBox="0 0 720 290"
		role="img"
		aria-label="Two panels comparing assignment in JavaScript. Left: primitive assignment gives each name its own value box. Right: reference assignment gives both names an arrow into the same shared object."
		xmlns="http://www.w3.org/2000/svg"
		style="width: 100%; min-width: 560px; height: auto; display: block;"
	>
		<defs>
			<marker
				id="binding-arrow"
				viewBox="0 0 10 10"
				refX="9"
				refY="5"
				markerWidth="7"
				markerHeight="7"
				orient="auto-start-reverse"
			>
				<path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
			</marker>
		</defs>

		{/* Divider between the two panels */}
		<line
			x1="320"
			y1="20"
			x2="320"
			y2="270"
			stroke="#9ca3af"
			stroke-width="1"
			stroke-dasharray="4 4"
		/>

		{/* ---------- LEFT PANEL: Primitive assignment ---------- */}
		<g
			font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
			fill="currentColor"
		>
			<text x="160" y="30" font-size="14" font-weight="600" text-anchor="middle">
				Primitive assignment
			</text>
		</g>

		{/* Binding a */}
		<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
			<rect
				x="40"
				y="64"
				width="70"
				height="36"
				rx="6"
				ry="6"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
			/>
			<text
				x="75"
				y="82"
				font-size="13"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				a
			</text>
		</g>

		{/* Binding b */}
		<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
			<rect
				x="40"
				y="134"
				width="70"
				height="36"
				rx="6"
				ry="6"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
			/>
			<text
				x="75"
				y="152"
				font-size="13"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				b
			</text>
		</g>

		{/* Arrows for primitive panel */}
		<g stroke="currentColor" stroke-width="1.5" fill="none">
			<line x1="110" y1="82" x2="186" y2="82" marker-end="url(#binding-arrow)" />
			<line x1="110" y1="152" x2="186" y2="152" marker-end="url(#binding-arrow)" />
		</g>

		{/* Value box for a */}
		<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
			<rect
				x="195"
				y="64"
				width="70"
				height="36"
				rx="4"
				ry="4"
				fill="var(--sl-color-bg-sidebar, transparent)"
				stroke="#9ca3af"
				stroke-width="1.5"
			/>
			<text
				x="230"
				y="82"
				font-size="13"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				42
			</text>
		</g>

		{/* Value box for b */}
		<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
			<rect
				x="195"
				y="134"
				width="70"
				height="36"
				rx="4"
				ry="4"
				fill="var(--sl-color-bg-sidebar, transparent)"
				stroke="#9ca3af"
				stroke-width="1.5"
			/>
			<text
				x="230"
				y="152"
				font-size="13"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				42
			</text>
		</g>

		{/* Caption strip for left panel */}
		<g
			font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
			fill="currentColor"
			font-size="12"
		>
			<text x="160" y="220" text-anchor="middle">
				{'const a = 42;'}
			</text>
			<text x="160" y="240" text-anchor="middle">
				{'const b = a;'}
			</text>
		</g>

		{/* ---------- RIGHT PANEL: Reference assignment ---------- */}
		<g
			font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
			fill="currentColor"
		>
			<text x="510" y="30" font-size="14" font-weight="600" text-anchor="middle">
				Reference assignment
			</text>
		</g>

		{/* Binding user */}
		<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
			<rect
				x="340"
				y="64"
				width="70"
				height="36"
				rx="6"
				ry="6"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
			/>
			<text
				x="375"
				y="82"
				font-size="13"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				user
			</text>
		</g>

		{/* Binding alias */}
		<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
			<rect
				x="340"
				y="134"
				width="70"
				height="36"
				rx="6"
				ry="6"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
			/>
			<text
				x="375"
				y="152"
				font-size="13"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				alias
			</text>
		</g>

		{/* Arrows converging on the shared object */}
		<g stroke="currentColor" stroke-width="1.5" fill="none">
			<line x1="410" y1="82" x2="476" y2="105" marker-end="url(#binding-arrow)" />
			<line x1="410" y1="152" x2="476" y2="135" marker-end="url(#binding-arrow)" />
		</g>

		{/* Shared object box */}
		<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
			<rect
				x="480"
				y="88"
				width="210"
				height="64"
				rx="4"
				ry="4"
				fill="var(--sl-color-bg-sidebar, transparent)"
				stroke="#9ca3af"
				stroke-width="1.5"
			/>
			<text
				x="585"
				y="115"
				font-size="12"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				{"{ name: 'Ada',"}
			</text>
			<text
				x="585"
				y="133"
				font-size="12"
				fill="currentColor"
				text-anchor="middle"
				dominant-baseline="central"
			>
				{'  age: 36 }'}
			</text>
		</g>

		{/* Caption strip for right panel */}
		<g
			font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
			fill="currentColor"
			font-size="12"
		>
			<text x="510" y="220" text-anchor="middle">
				{"const user = { name: 'Ada', age: 36 };"}
			</text>
			<text x="510" y="240" text-anchor="middle">
				{'const alias = user;'}
			</text>
		</g>
	</svg>
	</div>
</Figure>
