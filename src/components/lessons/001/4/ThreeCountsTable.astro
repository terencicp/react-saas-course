---
import Figure from '../../../figures/Figure.astro';

// The café literal is built deliberately in decomposed form: 'c', 'a', 'f', 'e',
// followed by U+0301 (combining acute accent). The diagram's counts (5/5/4) only
// hold against this form — a precomposed 'café' would give 4/4/4 and break the lesson.
const cafeDecomposed = `café`;

const rows = [
	{
		input: cafeDecomposed,
		hint: 'combining acute',
		codeUnits: 5,
		codePoints: 5,
		clusters: 4,
	},
	{
		input: '🇺🇸',
		hint: 'US flag',
		codeUnits: 4,
		codePoints: 2,
		clusters: 1,
	},
	{
		input: '👨‍👩‍👧‍👦',
		hint: 'family',
		codeUnits: 11,
		codePoints: 7,
		clusters: 1,
	},
];

// Column header tints — saturated mid-tones with white text read in both themes.
const headerBase = {
	padding: '0.5rem 0.75rem',
	margin: '0',
	fontSize: '0.8125rem',
	fontWeight: '600',
	textAlign: 'center',
	borderBottom: '1px solid var(--sl-color-hairline)',
	whiteSpace: 'nowrap',
};

const tintedHeaderStyle = (bg: string) =>
	Object.entries({ ...headerBase, background: bg, color: '#ffffff' })
		.map(([k, v]) => `${k.replace(/[A-Z]/g, (m) => `-${m.toLowerCase()}`)}: ${v}`)
		.join('; ');

const neutralHeaderStyle = Object.entries({
	...headerBase,
	textAlign: 'left',
	color: 'var(--sl-color-text)',
})
	.map(([k, v]) => `${k.replace(/[A-Z]/g, (m) => `-${m.toLowerCase()}`)}: ${v}`)
	.join('; ');

const inputCellStyle =
	'padding: 0.5rem 0.75rem; margin: 0; border-bottom: 1px solid var(--sl-color-hairline); text-align: left; white-space: nowrap;';

const numberCellStyle =
	'padding: 0.5rem 0.75rem; margin: 0; border-bottom: 1px solid var(--sl-color-hairline); text-align: center; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9375rem;';

const hintStyle =
	'margin: 0 0 0 0.5rem; font-size: 0.75rem; color: var(--sl-color-gray-3);';

const codeStyle =
	'background: transparent; padding: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.875rem;';
---

<Figure
	caption="The same string, three different lengths. Pick the column whose intent matches yours."
>
	<div style="display: flex; justify-content: center; margin: 0;">
		<table
			style="border-collapse: collapse; margin: 0; background: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); border-radius: 6px; overflow: hidden;"
		>
			<thead>
				<tr style="margin: 0;">
					<th style={neutralHeaderStyle}>Input</th>
					<th style={tintedHeaderStyle('#dc2626')}>
						<code style={`${codeStyle} color: #ffffff;`}>.length</code>
						<span style="margin: 0 0 0 0.25rem; font-weight: 400; opacity: 0.85;">
							(code units)
						</span>
					</th>
					<th style={tintedHeaderStyle('#ea580c')}>
						<code style={`${codeStyle} color: #ffffff;`}>[...str].length</code>
						<span style="margin: 0 0 0 0.25rem; font-weight: 400; opacity: 0.85;">
							(code points)
						</span>
					</th>
					<th style={tintedHeaderStyle('#16a34a')}>
						<code style={`${codeStyle} color: #ffffff;`}>Intl.Segmenter</code>
						<span style="margin: 0 0 0 0.25rem; font-weight: 400; opacity: 0.85;">
							(grapheme clusters)
						</span>
					</th>
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row, i) => {
						const isLast = i === rows.length - 1;
						const rowBorder = isLast ? 'border-bottom: 0;' : '';
						return (
							<tr style="margin: 0;">
								<td style={`${inputCellStyle} ${rowBorder}`}>
									<code style={codeStyle}>{`'${row.input}'`}</code>
									<span style={hintStyle}>({row.hint})</span>
								</td>
								<td style={`${numberCellStyle} ${rowBorder}`}>{row.codeUnits}</td>
								<td style={`${numberCellStyle} ${rowBorder}`}>{row.codePoints}</td>
								<td style={`${numberCellStyle} ${rowBorder}`}>{row.clusters}</td>
							</tr>
						);
					})
				}
			</tbody>
		</table>
	</div>
</Figure>
