---
// ParaphraseVsLink — Chapter 101 Lesson 2, "The thin README and source-as-doc".
//
// The conceptual pivot of the lesson made spatial: a paraphrase drifts the
// instant the code changes; a link has nothing to drift on. Two vertical
// panels side by side, each showing the SAME event — `schema.ts` gains a
// `currency` column — but with different consequences for the README above it.
//
//   LEFT  (drift, red):  the README PARAPHRASES the column list. When the
//     schema gains `currency` the README still lists four columns, so it is
//     silently stale. The connector between them is dashed and severed — there
//     was never anything keeping the two in sync.
//   RIGHT (link, green): the README only POINTS at `src/db/schema.ts`. The
//     schema gains the same column; because the README copies nothing, the
//     pointer still resolves and the README stays correct. The connector is a
//     solid, intact line.
//
// Engine: plain HTML + CSS — the diagrams index's pick for a colour-coded
// annotated illustration. Short connectors are drawn with CSS borders rather
// than ArrowDiagram leader lines (which position from document.body and would
// force expandable={false}). Muted red/green tints (Tailwind 600-range mixed
// into the page background) read on both light and dark cards; `not-content`
// plus a `margin: 0` reset on every descendant defeats Starlight's
// prose-margin injection. flex-wrap lets the two panels stack on narrow widths.

const RED = "#dc2626"; // drift — the paraphrase falls silently behind
const GREEN = "#16a34a"; // link — the pointer still resolves

// The four columns the README hand-copied, and the fifth the schema gains.
const baseColumns = ["id", "org_id", "amount", "status"];
const newColumn = "currency";

const ALT =
	"Two panels comparing a paraphrased README against a linked one when the schema gains a column. " +
	"Left panel, titled Paraphrase: a README box hand-lists the invoices columns id, org_id, amount, status, " +
	"connected by a dashed severed line to a schema.ts box that has gained a new highlighted currency column; " +
	"the README is marked stale in red because it still lists only four columns. " +
	"Right panel, titled Link: a README box reads Data model points to src/db/schema.ts, " +
	"connected by a solid intact line to the same schema.ts box gaining the currency column; " +
	"the README is marked correct in green because it only points and copies nothing.";
---

<div class="pvl not-content" role="img" aria-label={ALT} style={`--red:${RED};--green:${GREEN}`}>
	{/* ── LEFT: the paraphrase drifts ─────────────────────────────────────── */}
	<section class="pvl-panel" data-tone="bad">
		<header class="pvl-head">
			<span class="pvl-title">Paraphrase</span>
			<span class="pvl-sub">the README copies the columns</span>
		</header>

		{/* The README box — hand-lists the columns, and is now stale. */}
		<div class="pvl-box pvl-readme">
			<div class="pvl-box-head">
				<span class="pvl-file">README.md</span>
				<span class="pvl-tag pvl-tag-bad">stale</span>
			</div>
			<p class="pvl-paraphrase">
				The <code>invoices</code> table has columns:
				<span class="pvl-cols">
					{baseColumns.map((c, i) => (
						<span class="pvl-col">{c}{i < baseColumns.length - 1 ? "," : ""}</span>
					))}
				</span>
			</p>
		</div>

		{/* The severed connector — nothing held these in sync. */}
		<div class="pvl-link pvl-link-bad" aria-hidden="true">
			<span class="pvl-link-line"></span>
			<span class="pvl-link-break">✕</span>
			<span class="pvl-link-line"></span>
		</div>

		{/* The schema.ts box — gains a fifth column. */}
		<div class="pvl-box pvl-schema">
			<div class="pvl-box-head">
				<span class="pvl-file">src/db/schema.ts</span>
				<span class="pvl-tag pvl-tag-add">+1 column</span>
			</div>
			<ul class="pvl-schema-cols">
				{baseColumns.map((c) => (
					<li class="pvl-schema-col">{c}</li>
				))}
				<li class="pvl-schema-col pvl-schema-col-new">{newColumn}</li>
			</ul>
		</div>

		<p class="pvl-caption pvl-caption-bad">Nothing kept these in sync.</p>
	</section>

	{/* ── RIGHT: the link stays correct ───────────────────────────────────── */}
	<section class="pvl-panel" data-tone="good">
		<header class="pvl-head">
			<span class="pvl-title">Link</span>
			<span class="pvl-sub">the README only points</span>
		</header>

		{/* The README box — a single pointer, still correct. */}
		<div class="pvl-box pvl-readme">
			<div class="pvl-box-head">
				<span class="pvl-file">README.md</span>
				<span class="pvl-tag pvl-tag-good">correct</span>
			</div>
			<p class="pvl-paraphrase">
				Data model <span class="pvl-arrow">→</span>
				<code class="pvl-pointer">src/db/schema.ts</code>
			</p>
		</div>

		{/* The intact connector — the pointer still resolves. */}
		<div class="pvl-link pvl-link-good" aria-hidden="true">
			<span class="pvl-link-line"></span>
			<span class="pvl-link-dot"></span>
			<span class="pvl-link-line"></span>
		</div>

		{/* The same schema.ts box — gains the same column. */}
		<div class="pvl-box pvl-schema">
			<div class="pvl-box-head">
				<span class="pvl-file">src/db/schema.ts</span>
				<span class="pvl-tag pvl-tag-add">+1 column</span>
			</div>
			<ul class="pvl-schema-cols">
				{baseColumns.map((c) => (
					<li class="pvl-schema-col">{c}</li>
				))}
				<li class="pvl-schema-col pvl-schema-col-new">{newColumn}</li>
			</ul>
		</div>

		<p class="pvl-caption pvl-caption-good">The link still resolves.</p>
	</section>
</div>

<style>
	.pvl {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		justify-content: center;
		align-items: stretch;
		width: 100%;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.pvl * {
		margin: 0;
		box-sizing: border-box;
	}

	/* ── A panel: title, README, connector, schema, caption ──────────────── */
	.pvl-panel {
		flex: 1 1 280px;
		min-width: 260px;
		max-width: 360px;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0;
		padding: 12px 12px 10px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-hairline, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.pvl-panel[data-tone="bad"] {
		border-color: color-mix(in srgb, var(--red) 38%, var(--sl-color-hairline));
		background: color-mix(in srgb, var(--red) 4%, var(--sl-color-bg));
	}
	.pvl-panel[data-tone="good"] {
		border-color: color-mix(in srgb, var(--green) 38%, var(--sl-color-hairline));
		background: color-mix(in srgb, var(--green) 4%, var(--sl-color-bg));
	}

	/* ── Panel header ────────────────────────────────────────────────────── */
	.pvl-head {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		margin: 0 0 10px;
		text-align: center;
	}
	.pvl-title {
		font-size: 14px;
		font-weight: 800;
		letter-spacing: 0.01em;
		line-height: 1.1;
	}
	.pvl-panel[data-tone="bad"] .pvl-title {
		color: color-mix(in srgb, var(--red) 80%, var(--sl-color-text));
	}
	.pvl-panel[data-tone="good"] .pvl-title {
		color: color-mix(in srgb, var(--green) 78%, var(--sl-color-text));
	}
	.pvl-sub {
		font-size: 10.5px;
		font-weight: 500;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── Boxes (README + schema share this chrome) ───────────────────────── */
	.pvl-box {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 9px 11px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.pvl-box-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
	}
	.pvl-file {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11px;
		font-weight: 700;
		color: var(--sl-color-gray-2, #475569);
	}
	.pvl-tag {
		font-size: 9px;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		line-height: 1;
		padding: 3px 7px;
		border-radius: 999px;
		white-space: nowrap;
	}
	.pvl-tag-bad {
		color: #fff;
		background: var(--red);
	}
	.pvl-tag-good {
		color: #fff;
		background: var(--green);
	}
	.pvl-tag-add {
		color: color-mix(in srgb, var(--green) 84%, var(--sl-color-text));
		background: color-mix(in srgb, var(--green) 16%, transparent);
		border: 1px solid color-mix(in srgb, var(--green) 40%, transparent);
	}

	/* The README's stale border on the drift side. */
	.pvl-panel[data-tone="bad"] .pvl-readme {
		border-color: color-mix(in srgb, var(--red) 55%, var(--sl-color-gray-5));
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--red) 12%, transparent);
	}
	.pvl-panel[data-tone="good"] .pvl-readme {
		border-color: color-mix(in srgb, var(--green) 50%, var(--sl-color-gray-5));
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--green) 12%, transparent);
	}

	/* ── README body text ────────────────────────────────────────────────── */
	.pvl-paraphrase {
		font-size: 12px;
		line-height: 1.5;
		color: var(--sl-color-text, #1e293b);
	}
	.pvl-paraphrase code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11px;
	}
	.pvl-cols {
		display: inline;
	}
	.pvl-col {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11px;
		font-weight: 600;
		color: color-mix(in srgb, var(--red) 70%, var(--sl-color-text));
	}
	.pvl-arrow {
		font-weight: 800;
		color: color-mix(in srgb, var(--green) 72%, var(--sl-color-text));
		padding: 0 2px;
	}
	.pvl-pointer {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11px;
		font-weight: 700;
		color: color-mix(in srgb, var(--green) 74%, var(--sl-color-text));
	}

	/* ── The connector between README and schema ─────────────────────────── */
	.pvl-link {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		padding: 4px 0;
		min-height: 44px;
	}
	.pvl-link-line {
		width: 0;
		flex: 1 1 auto;
		min-height: 10px;
	}
	.pvl-link-bad .pvl-link-line {
		border-left: 2px dashed color-mix(in srgb, var(--red) 60%, var(--sl-color-gray-4));
	}
	.pvl-link-good .pvl-link-line {
		border-left: 2px solid var(--green);
	}
	.pvl-link-break {
		font-size: 13px;
		font-weight: 800;
		line-height: 1;
		color: var(--red);
		background: var(--sl-color-bg-sidebar, var(--sl-color-bg));
		padding: 1px 3px;
		border-radius: 4px;
	}
	.pvl-link-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--green);
		flex: 0 0 auto;
	}

	/* ── The schema column list ──────────────────────────────────────────── */
	.pvl-schema-cols {
		list-style: none;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 5px;
	}
	.pvl-schema-col {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 10.5px;
		font-weight: 600;
		line-height: 1;
		padding: 3px 7px;
		border-radius: 6px;
		color: var(--sl-color-gray-2, #475569);
		background: color-mix(in srgb, var(--sl-color-gray-5) 40%, transparent);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}
	.pvl-schema-col-new {
		color: #fff;
		background: var(--green);
		border-color: var(--green);
	}

	/* ── Per-panel verdict caption ───────────────────────────────────────── */
	.pvl-caption {
		margin: 10px 0 0;
		text-align: center;
		font-size: 11px;
		font-weight: 700;
		line-height: 1.3;
	}
	.pvl-caption-bad {
		color: color-mix(in srgb, var(--red) 78%, var(--sl-color-text));
	}
	.pvl-caption-good {
		color: color-mix(in srgb, var(--green) 72%, var(--sl-color-text));
	}
</style>
