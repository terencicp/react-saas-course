---
// DiataxisQuadrantGrid — Chapter 101 Lesson 1 ("The four jobs of docs"),
// the lesson's primary visual: the canonical Diataxis 2x2.
//
// Makes the "exactly four, no more" claim spatial. Two axes drive four
// quadrants: horizontal = acquisition (study) <-> application (work);
// vertical = action (doing) <-> cognition (knowing). The four document types
// sit in their canonical Diataxis placement (Tutorial top-left, How-to
// top-right, Explanation bottom-left, Reference bottom-right) — NOT rotated.
//
// This file OWNS the quadrant color palette for the chapter: the same
// type -> color mapping is reused by the mixing-trap figure so each color
// keeps meaning across both diagrams. The palette is Tailwind 600-range
// saturated mid-tones with white text, so it survives light and dark mode.
//   Tutorial    -> blue   (#2563eb)
//   How-to      -> teal   (#0d9488)
//   Explanation -> violet (#7c3aed)
//   Reference   -> amber  (#d97706)
//
// Plain HTML + CSS per the diagrams INDEX (a layout concept rendered with real
// CSS, not a graph). Inline styles only; theme chrome via --sl-color-*;
// `margin: 0` on every descendant to defeat Starlight's prose-margin injection;
// `not-content` on the root for the same reason.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The chapter's canonical quadrant palette (type -> color). The mixing-trap
// figure reuses these exact values so each color keeps its meaning across both
// diagrams. Kept as a plain const (Astro frontmatter doesn't reliably support
// `export`); the downstream figure mirrors the same four hex values.
const QUADRANT_COLORS = {
  tutorial: "#2563eb", // blue-600
  howto: "#0d9488", // teal-600
  explanation: "#7c3aed", // violet-600
  reference: "#d97706", // amber-600
};

type Quadrant = {
  name: string;
  formula: string;
  gloss: string;
  color: string;
};

// Canonical Diataxis placement, read left-to-right, top-to-bottom.
const quadrants: Quadrant[] = [
  {
    name: "Tutorial",
    formula: "acquisition + action",
    gloss: "take me by the hand",
    color: QUADRANT_COLORS.tutorial,
  },
  {
    name: "How-to",
    formula: "application + action",
    gloss: "help me do this task",
    color: QUADRANT_COLORS.howto,
  },
  {
    name: "Explanation",
    formula: "acquisition + cognition",
    gloss: "help me understand why",
    color: QUADRANT_COLORS.explanation,
  },
  {
    name: "Reference",
    formula: "application + cognition",
    gloss: "tell me the exact fact",
    color: QUADRANT_COLORS.reference,
  },
];

const axisLabel = [
  reset,
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "color: var(--sl-color-gray-3)",
  "line-height: 1.2",
].join("; ");

// Outer grid: a thin left gutter (vertical-axis name + per-row labels) plus the
// two quadrant columns; a top row carries the per-column horizontal labels.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 760px",
  "margin: 0 auto",
  "display: grid",
  "grid-template-columns: 22px auto 1fr 1fr",
  "grid-template-rows: auto 1fr 1fr",
  "column-gap: 8px",
  "row-gap: 8px",
  "align-items: stretch",
].join("; ");

// Per-column horizontal-axis labels (top edge).
const topLabel = (col: number) =>
  [
    axisLabel,
    `grid-column: ${col}`,
    "grid-row: 1",
    "align-self: end",
    "padding-bottom: 2px",
    "text-align: center",
  ].join("; ");

// Vertical-axis name, rotated, spanning both quadrant rows in the first column.
const sideName = [
  axisLabel,
  "grid-column: 1",
  "grid-row: 2 / 4",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "writing-mode: vertical-rl",
  "transform: rotate(180deg)",
  "text-transform: uppercase",
  "letter-spacing: 0.08em",
  "font-size: 10px",
  "color: var(--sl-color-gray-4)",
].join("; ");

// Per-row vertical labels, stacked in the second gutter column.
const rowLabel = (row: number) =>
  [
    axisLabel,
    "grid-column: 2",
    `grid-row: ${row}`,
    "display: flex",
    "align-items: center",
    "justify-content: flex-end",
    "text-align: right",
    "writing-mode: vertical-rl",
    "transform: rotate(180deg)",
    "white-space: nowrap",
  ].join("; ");

const cell = (color: string, col: number, row: number) =>
  [
    reset,
    `grid-column: ${col}`,
    `grid-row: ${row}`,
    "box-sizing: border-box",
    "min-width: 0",
    "min-height: 128px",
    "display: flex",
    "flex-direction: column",
    "justify-content: center",
    "gap: 6px",
    "padding: 16px 18px",
    "border-radius: 12px",
    `background: ${color}`,
    "color: #fff",
  ].join("; ");

const cellName = [
  reset,
  "font-size: 19px",
  "font-weight: 700",
  "line-height: 1.1",
  "color: #fff",
].join("; ");

const cellFormula = [
  reset,
  "font-size: 12px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "opacity: 0.85",
  "color: #fff",
].join("; ");

const cellGloss = [
  reset,
  "margin: 4px 0 0",
  "font-size: 13.5px",
  "font-style: italic",
  "line-height: 1.3",
  "opacity: 0.95",
  "color: #fff",
].join("; ");
---

<div class="not-content" style={root}>
  {/* Top edge: horizontal-axis (mode) labels, one per quadrant column. */}
  <div style={topLabel(3)}>Acquisition &middot; study mode</div>
  <div style={topLabel(4)}>Application &middot; work mode</div>

  {/* Left edge: vertical-axis (content) name + per-row labels. */}
  <div style={sideName}>Content of the doc</div>
  <div style={rowLabel(2)}>Action &middot; doing</div>
  <div style={rowLabel(3)}>Cognition &middot; knowing</div>

  {/* Four quadrant cells, canonical placement (col 3/4, row 2/3). */}
  {
    quadrants.map((q, i) => (
      <div style={cell(q.color, 3 + (i % 2), 2 + Math.floor(i / 2))}>
        <div style={cellName}>{q.name}</div>
        <div style={cellFormula}>{q.formula}</div>
        <div style={cellGloss}>{q.gloss}</div>
      </div>
    ))
  }
</div>
