---
// ReadmeMixingTrap — Chapter 101 Lesson 1 ("The four jobs of docs"),
// the lesson's secondary visual: the README "mixing trap" as a before/after.
//
// BEFORE ("the novel"): one tall README.md rectangle sliced into four stacked,
// color-coded bands — each band tinted with the quadrant color of the Diataxis
// type it is smuggling in, plus a sample line. One block doing four jobs.
//
// AFTER ("the split"): a thin README band (tutorial color only) that keeps just
// the tutorial + pointers, with the other three bands relocated to the artifact
// that actually owns each job, each kept in its source type's quadrant color.
//
// The quadrant palette is MIRRORED from DiataxisQuadrantGrid.astro (which owns
// it) so each color keeps its meaning across both diagrams. Astro frontmatter
// doesn't reliably support `export`, so the hex values are duplicated here:
//   Tutorial    -> blue   (#2563eb)
//   How-to      -> teal   (#0d9488)
//   Explanation -> violet (#7c3aed)
//   Reference   -> amber  (#d97706)
//
// Plain HTML + CSS per the diagrams INDEX (a layout concept rendered with real
// CSS). Inline styles only; `margin: 0` on every descendant to defeat
// Starlight's prose-margin injection; `not-content` on the root.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

// Mirrored from DiataxisQuadrantGrid.astro — keep these in sync.
const QUADRANT_COLORS = {
  tutorial: "#2563eb", // blue-600
  howto: "#0d9488", // teal-600
  explanation: "#7c3aed", // violet-600
  reference: "#d97706", // amber-600
};

// The four bands of the mixed README, top-to-bottom in the order a real README
// drifts through them.
const bands = [
  {
    type: "Tutorial",
    color: QUADRANT_COLORS.tutorial,
    sample: "pnpm install && pnpm dev",
    mono: true,
  },
  {
    type: "How-to",
    color: QUADRANT_COLORS.howto,
    sample: "To add a feature: …",
    mono: false,
  },
  {
    type: "Reference",
    color: QUADRANT_COLORS.reference,
    sample: "Env vars: DATABASE_URL, STRIPE_SECRET_KEY, …",
    mono: false,
  },
  {
    type: "Explanation",
    color: QUADRANT_COLORS.explanation,
    sample: "We chose Postgres because …",
    mono: false,
  },
];

// The three relocated homes, in the AFTER column. Tutorial stays in the README.
const homes = [
  {
    type: "How-to",
    color: QUADRANT_COLORS.howto,
    dest: "AGENTS.md · /docs/how-to/",
  },
  {
    type: "Reference",
    color: QUADRANT_COLORS.reference,
    dest: "src/db/schema.ts · env.ts",
  },
  {
    type: "Explanation",
    color: QUADRANT_COLORS.explanation,
    dest: "/docs/adr/",
  },
];

// --- shared atoms -----------------------------------------------------------

// The pair wrapper: BEFORE | connector | AFTER. Wraps to stacked on narrow
// figure cards (prefer wrap over horizontal scroll).
const pair = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 14px",
  "row-gap: 18px",
].join("; ");

// A labeled column (BEFORE / AFTER) with its heading on top.
const column = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 240px",
  "min-width: 240px",
  "max-width: 340px",
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
].join("; ");

const colHead = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 2px",
  "text-align: center",
].join("; ");

const colTitle = [
  reset,
  "font-size: 13px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-white)",
].join("; ");

const colSub = [
  reset,
  "font-size: 12px",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The README "document" frame in the BEFORE column.
const doc = [
  reset,
  "box-sizing: border-box",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 10px",
  "overflow: hidden",
  "background: var(--sl-color-bg)",
  "display: flex",
  "flex-direction: column",
].join("; ");

const docTab = (mono: boolean) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "padding: 6px 10px",
    "font-size: 12px",
    "font-weight: 600",
    "color: var(--sl-color-gray-2)",
    "background: var(--sl-color-gray-6)",
    "border-bottom: 1px solid var(--sl-color-gray-5)",
  ].join("; ");

const band = (color: string, withBorder: boolean) =>
  [
    reset,
    "box-sizing: border-box",
    "padding: 11px 13px",
    "display: flex",
    "flex-direction: column",
    "gap: 3px",
    `background: ${color}`,
    "color: #fff",
    withBorder ? "border-top: 1px solid rgba(255,255,255,0.28)" : "",
  ]
    .filter(Boolean)
    .join("; ");

const bandType = [
  reset,
  "font-size: 12px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "color: #fff",
].join("; ");

const bandSample = (isMono: boolean) =>
  [
    reset,
    isMono ? mono : sans,
    "font-size: 12px",
    "line-height: 1.3",
    "opacity: 0.95",
    "color: #fff",
    "overflow-wrap: anywhere",
  ].join("; ");

// The connector between BEFORE and AFTER.
const connector = [
  reset,
  "flex: 0 0 auto",
  "align-self: center",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 2px",
  "color: var(--sl-color-gray-3)",
].join("; ");

const connectorArrow = [
  reset,
  "font-size: 22px",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");

const connectorLabel = [
  reset,
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

// The thin README in the AFTER column.
const thinDoc = [
  reset,
  "box-sizing: border-box",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 10px",
  "overflow: hidden",
  "background: var(--sl-color-bg)",
].join("; ");

const thinBand = [
  reset,
  "box-sizing: border-box",
  "padding: 11px 13px",
  "display: flex",
  "flex-direction: column",
  "gap: 3px",
  `background: ${QUADRANT_COLORS.tutorial}`,
  "color: #fff",
].join("; ");

// A relocated home card in the AFTER column: a quadrant-colored left rail + the
// destination path.
const homeRow = (color: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: stretch",
    "gap: 0",
    "border: 1px solid var(--sl-color-gray-5)",
    "border-left: 4px solid " + color,
    "border-radius: 8px",
    "overflow: hidden",
    "background: var(--sl-color-bg)",
  ].join("; ");

const homeBody = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 auto",
  "min-width: 0",
  "padding: 8px 11px",
  "display: flex",
  "flex-direction: column",
  "gap: 2px",
].join("; ");

const homeType = (color: string) =>
  [
    reset,
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.02em",
    `color: ${color}`,
  ].join("; ");

const homeDest = [
  reset,
  mono,
  "font-size: 12px",
  "line-height: 1.3",
  "color: var(--sl-color-white)",
  "overflow-wrap: anywhere",
].join("; ");

const afterStack = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 7px",
].join("; ");

const afterLabel = [
  reset,
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "margin: 2px 0 0",
].join("; ");
---

<div class="not-content" style={pair}>
  {/* BEFORE — the novel: one README doing four jobs. */}
  <div style={column}>
    <div style={colHead}>
      <div style={colTitle}>Before — the novel</div>
      <div style={colSub}>one document, four jobs</div>
    </div>
    <div style={doc}>
      <div style={docTab(mono)}>README.md</div>
      {
        bands.map((b, i) => (
          <div style={band(b.color, i > 0)}>
            <div style={bandType}>{b.type}</div>
            <div style={bandSample(b.mono)}>{b.sample}</div>
          </div>
        ))
      }
    </div>
  </div>

  {/* Connector. */}
  <div style={connector}>
    <div style={connectorArrow}>&rarr;</div>
    <div style={connectorLabel}>split</div>
  </div>

  {/* AFTER — the split: thin README + three relocated homes. */}
  <div style={column}>
    <div style={colHead}>
      <div style={colTitle}>After — the split</div>
      <div style={colSub}>each job in its real home</div>
    </div>
    <div style={afterStack}>
      <div style={thinDoc}>
        <div style={docTab(mono)}>README.md</div>
        <div style={thinBand}>
          <div style={bandType}>Tutorial + pointers</div>
          <div style={bandSample(false)}>Getting started, then links out</div>
        </div>
      </div>
      <div style={afterLabel}>the other three move out</div>
      {
        homes.map((h) => (
          <div style={homeRow(h.color)}>
            <div style={homeBody}>
              <div style={homeType(h.color)}>{h.type}</div>
              <div style={homeDest}>{h.dest}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
