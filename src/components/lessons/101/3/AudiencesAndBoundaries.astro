---
// AudiencesAndBoundaries — Chapter 101 Lesson 3 ("AGENTS.md, the conventions
// file"), the lesson's load-bearing mental model, shown as one figure.
//
// Two stacked bands, wide and short:
//
// TOP BAND — "Two readers, one file": a center AGENTS.md box flanked by a
// coding-agent glyph (left) and a new-hire-human glyph (right). Both glyphs
// point an arrow IN at the box, and both arrows carry the IDENTICAL label
// "same plain markdown" — cementing that the dual audience does NOT mean two
// files or two dialects.
//
// BOTTOM BAND — "Who owns what": three role cards (README · AGENTS.md · ADR),
// with AGENTS.md emphasized as the center. A "shared: overview + setup
// commands" connector bridges README↔AGENTS.md; a "links out for the why"
// arrow runs AGENTS.md→ADR. This previews the three boundaries taught later.
//
// Palette is MIRRORED from lesson 1's ReadmeMixingTrap.astro / the Diataxis
// quadrant grid so each doc keeps its color across the chapter. Astro
// frontmatter doesn't reliably support `export`, so hex values are duplicated:
//   README  -> blue   (#2563eb)   (tutorial / first-contact)
//   AGENTS  -> teal   (#0d9488)   (how-to / conventions — the subject)
//   ADR     -> violet (#7c3aed)   (explanation / the why)
//
// Plain HTML + CSS per the diagrams INDEX (a layout concept rendered with real
// CSS). Inline styles only; `margin: 0` on every descendant via reset to
// defeat Starlight's prose-margin injection; `not-content` on the root.

import { Icon } from 'astro-icon/components';

const reset = 'margin: 0';
const sans =
  'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';
const mono =
  'font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace)';

// Mirrored from ReadmeMixingTrap.astro — keep these in sync across the chapter.
const README = '#2563eb'; // blue-600
const AGENTS = '#0d9488'; // teal-600
const ADR = '#7c3aed'; // violet-600

// --- root + section scaffolding --------------------------------------------

const root = [
  reset,
  sans,
  'box-sizing: border-box',
  'width: 100%',
  'display: flex',
  'flex-direction: column',
  'gap: 14px',
].join('; ');

// A labeled section: a small uppercase eyebrow over the band content.
const sectionHead = [
  reset,
  'font-size: 11px',
  'font-weight: 700',
  'letter-spacing: 0.06em',
  'text-transform: uppercase',
  'color: var(--sl-color-gray-3)',
  'text-align: center',
].join('; ');

const divider = [
  reset,
  'height: 1px',
  'border: 0',
  'background: var(--sl-color-gray-5)',
  'width: 100%',
].join('; ');

// ── TOP BAND ───────────────────────────────────────────────────────────────

const topRow = [
  reset,
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'justify-content: center',
  'column-gap: 0',
  'row-gap: 16px',
].join('; ');

// A reader card (coding agent / new-hire human): icon over a two-line label.
const reader = [
  reset,
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'width: 132px',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'gap: 6px',
  'padding: 12px 10px',
  'border: 1px solid var(--sl-color-gray-5)',
  'border-radius: 12px',
  'background: var(--sl-color-bg)',
  'text-align: center',
].join('; ');

const readerIcon = [
  reset,
  'width: 26px',
  'height: 26px',
  'color: var(--sl-color-white)',
].join('; ');

const readerName = [
  reset,
  'font-size: 13px',
  'font-weight: 700',
  'color: var(--sl-color-white)',
  'line-height: 1.2',
].join('; ');

const readerSub = [
  reset,
  'font-size: 11px',
  'color: var(--sl-color-gray-3)',
  'line-height: 1.25',
].join('; ');

// The arrow connector between a reader and the center box. Direction differs
// per side (→ on the left, ← on the right) but the label is IDENTICAL — that
// sameness is the whole point.
const arrowCol = [
  reset,
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'width: 116px',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'gap: 3px',
].join('; ');

const arrowLine = (dir: 'right' | 'left') =>
  [
    reset,
    'font-size: 24px',
    'line-height: 1',
    'font-weight: 700',
    `color: ${AGENTS}`,
    dir === 'right' ? 'letter-spacing: 0' : '',
  ]
    .filter(Boolean)
    .join('; ');

const arrowLabel = [
  reset,
  mono,
  'font-size: 11px',
  'font-weight: 600',
  'color: var(--sl-color-gray-2)',
  'text-align: center',
  'line-height: 1.2',
].join('; ');

// The center AGENTS.md box — the prominent, saturated teal target.
const centerBox = [
  reset,
  mono,
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'padding: 16px 22px',
  'border-radius: 12px',
  `background: ${AGENTS}`,
  'color: #fff',
  'font-size: 18px',
  'font-weight: 700',
  'letter-spacing: 0.01em',
  `box-shadow: 0 2px 10px color-mix(in srgb, ${AGENTS} 45%, transparent)`,
  'white-space: nowrap',
].join('; ');

// ── BOTTOM BAND ──────────────────────────────────────────────────────────────

const cardsRow = [
  reset,
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 10px',
  'row-gap: 26px',
].join('; ');

// A role card. The emphasized AGENTS.md card gets a saturated fill + lift; the
// flanking README / ADR cards get a colored top rail with a neutral body.
const roleCard = (color: string, emphasized: boolean) =>
  [
    reset,
    'box-sizing: border-box',
    'flex: 1 1 200px',
    'min-width: 180px',
    'max-width: 250px',
    'display: flex',
    'flex-direction: column',
    'gap: 6px',
    'padding: 13px 14px',
    'border-radius: 11px',
    emphasized
      ? `background: ${color}`
      : 'background: var(--sl-color-bg)',
    emphasized
      ? 'border: 1px solid transparent'
      : 'border: 1px solid var(--sl-color-gray-5)',
    `border-top: 4px solid ${color}`,
    emphasized
      ? `box-shadow: 0 2px 12px color-mix(in srgb, ${color} 45%, transparent)`
      : '',
  ]
    .filter(Boolean)
    .join('; ');

const cardName = (color: string, emphasized: boolean) =>
  [
    reset,
    mono,
    'font-size: 14px',
    'font-weight: 700',
    emphasized ? 'color: #fff' : `color: ${color}`,
    'line-height: 1.2',
    'overflow-wrap: anywhere',
  ].join('; ');

const cardRole = (emphasized: boolean) =>
  [
    reset,
    'font-size: 12px',
    'font-weight: 600',
    emphasized ? 'color: #fff' : 'color: var(--sl-color-white)',
    'line-height: 1.3',
  ].join('; ');

const cardWho = (emphasized: boolean) =>
  [
    reset,
    'font-size: 11px',
    'font-style: italic',
    emphasized
      ? 'color: rgba(255,255,255,0.85)'
      : 'color: var(--sl-color-gray-3)',
    'line-height: 1.3',
  ].join('; ');

// The two relationship connectors, laid UNDER the card row so they read as the
// seams between the cards. Each is a pill-on-a-rule label.
const connectorsRow = [
  reset,
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'justify-content: center',
  'column-gap: 14px',
  'row-gap: 10px',
].join('; ');

const connectorPill = (color: string) =>
  [
    reset,
    'box-sizing: border-box',
    'display: inline-flex',
    'align-items: center',
    'gap: 7px',
    'padding: 6px 12px',
    'border-radius: 999px',
    `border: 1px solid color-mix(in srgb, ${color} 50%, transparent)`,
    `background: color-mix(in srgb, ${color} 10%, var(--sl-color-bg))`,
  ].join('; ');

const connectorEndpoints = (color: string) =>
  [
    reset,
    mono,
    'font-size: 11px',
    'font-weight: 700',
    `color: ${color}`,
    'white-space: nowrap',
  ].join('; ');

const connectorText = [
  reset,
  'font-size: 11px',
  'font-weight: 600',
  'color: var(--sl-color-gray-2)',
  'white-space: nowrap',
].join('; ');

const roles = [
  {
    name: 'README.md',
    color: README,
    role: 'First contact',
    who: 'recruiter, first hour',
    emphasized: false,
  },
  {
    name: 'AGENTS.md',
    color: AGENTS,
    role: 'Conventions + commands',
    who: 'agent, first week',
    emphasized: true,
  },
  {
    name: '/docs/adr/',
    color: ADR,
    role: 'Why the decisions were made',
    who: 'whoever asks "why?"',
    emphasized: false,
  },
];

const ALT =
  'One AGENTS.md file serves two readers: a coding agent and a new-hire human, ' +
  'each reaching the file through the same plain markdown — not two files or two ' +
  'dialects. Below, three role cards show ownership: README.md is first contact ' +
  'for a recruiter in the first hour; AGENTS.md owns conventions and commands for ' +
  'an agent in the first week; /docs/adr/ records why decisions were made. README ' +
  'and AGENTS.md share the project overview and setup commands; AGENTS.md links ' +
  'out to the ADR log for the why.';
---

<div class="not-content" role="img" aria-label={ALT} style={root}>
  {/* ── TOP BAND: two readers, one file ─────────────────────────────────── */}
  <p style={sectionHead}>Two readers, one file</p>
  <div style={topRow}>
    {/* Left reader: the coding agent. */}
    <div style={reader}>
      <Icon name="lucide:bot" style={readerIcon} />
      <span style={readerName}>Coding agent</span>
      <span style={readerSub}>Codex, Claude Code, Cursor…</span>
    </div>

    {/* Left arrow IN — label identical to the right one. */}
    <div style={arrowCol}>
      <span style={arrowLine('right')}>&rarr;</span>
      <span style={arrowLabel}>same plain<br />markdown</span>
    </div>

    {/* Center: the one file both readers reach. */}
    <div style={centerBox}>AGENTS.md</div>

    {/* Right arrow IN — same label. */}
    <div style={arrowCol}>
      <span style={arrowLine('left')}>&larr;</span>
      <span style={arrowLabel}>same plain<br />markdown</span>
    </div>

    {/* Right reader: the new-hire human. */}
    <div style={reader}>
      <Icon name="lucide:user-round" style={readerIcon} />
      <span style={readerName}>New-hire human</span>
      <span style={readerSub}>skimming "how we work"</span>
    </div>
  </div>

  <hr style={divider} />

  {/* ── BOTTOM BAND: who owns what ──────────────────────────────────────── */}
  <p style={sectionHead}>Who owns what</p>
  <div style={cardsRow}>
    {
      roles.map((r) => (
        <div style={roleCard(r.color, r.emphasized)}>
          <span style={cardName(r.color, r.emphasized)}>{r.name}</span>
          <span style={cardRole(r.emphasized)}>{r.role}</span>
          <span style={cardWho(r.emphasized)}>{r.who}</span>
        </div>
      ))
    }
  </div>

  {/* The two relationships between the cards. */}
  <div style={connectorsRow}>
    <span style={connectorPill(README)}>
      <span style={connectorEndpoints(README)}>README &harr; AGENTS</span>
      <span style={connectorText}>shared: overview + setup commands</span>
    </span>
    <span style={connectorPill(ADR)}>
      <span style={connectorEndpoints(ADR)}>AGENTS &rarr; ADR</span>
      <span style={connectorText}>links out for the why</span>
    </span>
  </div>
</div>
