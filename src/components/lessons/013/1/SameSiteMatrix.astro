---
// A 3x3 attach / don't-attach matrix for the three SameSite values against
// three request shapes. Rows are the SameSite values (Strict, Lax, None);
// columns are the request shapes the cookie might face. Each cell says
// whether the browser attaches the cookie (green check) or withholds it
// (red cross). The Lax row is visually emphasized because it is the only
// row that allows the cross-site GET navigation (sign-in links keep working)
// while blocking the cross-site POST (the CSRF attack fails).
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the layout:
// one row-header column plus three data columns, fixed column count so the
// matrix never wraps unpredictably — it reads at a glance. `margin: 0` reset
// on every inner element defeats Starlight's prose-margin injection.
// Saturated mid-tone fills (Tailwind ~600 range) with white text read in
// both light and dark theme; chrome (borders, header text) uses Starlight
// CSS variables so it flips with the theme.

const reset = "margin: 0";

// Request shapes — the three columns. Each pairs a short header with a
// one-line clarification so the column reads without leaning on the prose.
const columns = [
  { head: "Same-site fetch", sub: "request from your own site" },
  {
    head: "Cross-site nav",
    sub: "GET link from another site",
  },
  { head: "Cross-site POST / fetch", sub: "fired by another site" },
];

// Rows = the three SameSite values. `attach` is the per-column verdict,
// true = browser attaches the cookie. `emphasis` flags the Lax row.
const rows = [
  {
    value: "SameSite=Strict",
    note: "blocks the sign-in link too",
    attach: [true, false, false],
    emphasis: false,
  },
  {
    value: "SameSite=Lax",
    note: "the safe default",
    attach: [true, true, false],
    emphasis: true,
  },
  {
    value: "SameSite=None",
    note: "blocks nothing",
    attach: [true, true, true],
    emphasis: false,
  },
];

const grid = [
  reset,
  "display: grid",
  // row-header column is wider; three equal data columns.
  "grid-template-columns: minmax(140px, 1.3fr) repeat(3, minmax(110px, 1fr))",
  "gap: 6px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Top-left blank corner cell.
const cornerStyle = [reset, "padding: 0"].join("; ");

// Column header cells.
const colHeadStyle = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: flex-end",
  "gap: 4px",
  "padding: 4px 6px 8px",
  "text-align: center",
].join("; ");

const colHeadText = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const colSubText = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 11px",
  "font-weight: 400",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Row-header cell: the SameSite value (monospace token) + a one-line note.
const rowHeadBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 4px",
  "padding: 10px 12px",
  "border-radius: 8px",
  "box-sizing: border-box",
].join("; ");

const rowValueText = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.15",
].join("; ");

const rowNoteText = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 11px",
  "font-weight: 400",
  "line-height: 1.2",
].join("; ");

// Data cell: a colored tile carrying the verdict glyph + word.
const cellBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 4px",
  "padding: 12px 8px",
  "border-radius: 8px",
  "box-sizing: border-box",
  "color: #ffffff",
].join("; ");

const verdictWord = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: #ffffff",
].join("; ");

// green-600 / red-600 fills — the color carries the signal.
const attachBg = "#16a34a";
const blockBg = "#dc2626";

// Emphasis ring + tint for the Lax row, drawn with Starlight-aware blue.
const emphasisRowHead =
  "outline: 2px solid #38bdf8; background: rgba(56, 189, 248, 0.16)";
const plainRowHead = "background: var(--sl-color-gray-6, rgba(0,0,0,0.04))";
---

<div class="not-content ssm-root" style={grid}>
  {/* Header row: blank corner + three column headers */}
  <div style={cornerStyle}></div>
  {
    columns.map((c) => (
      <div style={colHeadStyle}>
        <span style={colHeadText}>{c.head}</span>
        <span style={colSubText}>{c.sub}</span>
      </div>
    ))
  }

  {/* One grid row per SameSite value */}
  {
    rows.map((r) => (
      <Fragment>
        <div
          style={`${rowHeadBase}; ${r.emphasis ? emphasisRowHead : plainRowHead}`}
        >
          <span
            style={`${rowValueText}; color: ${r.emphasis ? "var(--sl-color-white)" : "var(--sl-color-gray-1)"};`}
          >
            {r.value}
          </span>
          <span
            style={`${rowNoteText}; color: ${r.emphasis ? "#7dd3fc" : "var(--sl-color-gray-3)"};`}
          >
            {r.note}
          </span>
        </div>
        {r.attach.map((ok) => (
          <div style={`${cellBase}; background: ${ok ? attachBg : blockBg};`}>
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#ffffff"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              style="margin: 0; display: block;"
            >
              {ok ? <polyline points="20 6 9 17 4 12" /> : (
                <Fragment>
                  <line x1="18" y1="6" x2="6" y2="18" />
                  <line x1="6" y1="6" x2="18" y2="18" />
                </Fragment>
              )}
            </svg>
            <span style={verdictWord}>{ok ? "attached" : "not attached"}</span>
          </div>
        ))}
      </Fragment>
    ))
  }
</div>
