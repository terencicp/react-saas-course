---
// Parts-of-speech map of one Set-Cookie header. The literal header is
// broken into contiguous, tinted segments laid out left-to-right so the
// strip still reads as a single wire-format line; under each tinted
// segment sits a one-word role label naming what that segment controls.
//
// Header decomposed:
//   Set-Cookie: sid=abc123; HttpOnly; Secure; SameSite=Lax; Path=/; Max-Age=2592000
//
// Pure HTML + CSS. `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector. Saturated mid-tone fills (Tailwind
// ~600 range) with white text read in both light and dark theme — same
// palette family as the chapter's other reference strips, extended with
// teal and violet so all six segments stay distinct. Segments size to
// their content (so `HttpOnly` is narrow and `Max-Age=2592000` is wide),
// preserving the look of a real header; the row wraps on narrow
// viewports so no segment is ever clipped.

const reset = "margin: 0";

const root = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: flex-start",
  "justify-content: center",
  "column-gap: 6px",
  "row-gap: 16px",
  "width: 100%",
  "padding: 0",
  "box-sizing: border-box",
].join("; ");

// The literal "Set-Cookie:" header-name lead-in — untinted, monospace,
// muted, so the strip opens as a real HTTP header line before the tinted
// payload begins.
const prefixStyle = [
  reset,
  "align-self: center",
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 15px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 0 2px",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
].join("; ");

// One vertical unit per segment: the tinted token box on top, the role
// label directly beneath it.
const segStyle = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 6px",
].join("; ");

const tokenBase = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 15px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 9px 10px",
  "border-radius: 8px",
  "color: #ffffff",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

const labelStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1.15",
  "text-align: center",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Each segment is the literal token plus the one-word role it plays.
// Saturated 600-range fills, white text — distinct hue per segment.
const segments = [
  { token: "sid=abc123", role: "payload", bg: "#2563eb" }, // blue-600
  { token: "HttpOnly", role: "visibility", bg: "#7c3aed" }, // violet-600
  { token: "Secure", role: "transport", bg: "#0d9488" }, // teal-600
  { token: "SameSite=Lax", role: "cross-site rule", bg: "#dc2626" }, // red-600
  { token: "Path=/", role: "scope", bg: "#ea580c" }, // orange-600
  { token: "Max-Age=2592000", role: "lifetime", bg: "#16a34a" }, // green-600
];
---

<div class="not-content sca-root" style={root}>
  <span style={prefixStyle}>Set-Cookie:</span>
  {
    segments.map((s) => (
      <div style={segStyle}>
        <span style={`${tokenBase}; background: ${s.bg};`}>{s.token}</span>
        <span style={labelStyle}>{s.role}</span>
      </div>
    ))
  }
</div>
