---
// HalfIndexedJunction (diagram id: diagram-half-indexed, Chapter 037 Lesson 8 —
// "Many-to-many junction tables"). Makes the half-index trap *spatial*: the
// composite primary key on `(invoice_id, tag_id)` builds ONE index, and that
// index can only be read starting from its LEFT edge. So `invoice_id` (the
// leading column) is reachable and `tag_id` alone is not — one direction of the
// many-to-many is indexed, the other is a full table scan.
//
// Why a figure on top of the adjacent :::caution — the caution states the rule;
// this shows *why* the rule holds. "Left prefix" / "entry point on the left" is
// an inherently spatial idea (a B-tree index is a sorted thing you read
// left-to-right, like a phone book), and seeing the entry-point arrow pinned to
// the left edge of the two-cell bar is what makes the trap memorable when it
// later bites in production — the lesson's stated goal.
//
// Layout (top → bottom), one shared coordinate system:
//   1. The index bar — a single rounded bar split into two equal cells,
//      `invoice_id` (left, VIOLET = the live, reachable prefix) and `tag_id`
//      (right, MUTED = present in the index but not independently reachable).
//      A small "scan enters here" marker with a → arrow sits on the LEFT edge,
//      pointing into the bar; a faint "sorted left → right" caption under the
//      bar reinforces the single read direction. Each cell carries a tiny role
//      tag: "leading column" / "second column".
//   2. Two query rows, column-aligned under the bar. Each row: a monospace
//      `WHERE …` clause, a ✓/✗ pill (saturated fill + white glyph reads in both
//      themes — color IS the signal here), and a one-line verdict. The
//      invoice_id row points at the left cell (green ✓, "uses the index"); the
//      tag_id row at the buried right cell (red ✗, "full table scan").
//
// Pure HTML + CSS, inline styles only. `margin: 0` reset on every inner element
// to defeat Starlight's prose-margin selector. Saturated 600-range fills with
// white text (green/red), violet for the index theme (matches this chapter's
// composite-PK "keystone" violet and the UuidByteLayout timestamp segment).
// Height capped well under the 800px ceiling; no leader lines, so the figure
// stays expandable. Renders its own <Figure> — the MDX just imports and places.

import Figure from "../../../figures/Figure.astro";

const VIOLET = "#7c3aed"; // violet-600 — the composite-PK index, leading prefix
const GREEN = "#16a34a"; // green-600  — query served by the index
const RED = "#dc2626"; // red-600    — query that falls back to a full scan

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — centered, fluid, stacked.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 560px",
  "margin-inline: auto",
  "display: flex",
  "flex-direction: column",
  "row-gap: 26px",
].join("; ");

// ---- The index bar block (entry marker + bar + read-direction caption) ----
const barBlock = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "row-gap: 7px",
].join("; ");

// Row holding the left entry marker and the bar, so the marker hugs the bar's
// left edge and shares its vertical center.
const barRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "column-gap: 8px",
].join("; ");

// "scan enters here" marker on the left edge of the bar.
const entryMarker = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "row-gap: 2px",
  "flex: 0 0 auto",
  "width: 58px",
].join("; ");

const entryLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "line-height: 1.15",
  "text-align: center",
  `color: color-mix(in srgb, ${VIOLET} 70%, var(--sl-color-text))`,
].join("; ");

// The → arrow that points into the bar from the left.
const entryArrow = [
  reset,
  mono,
  "font-size: 20px",
  "font-weight: 700",
  "line-height: 1",
  `color: ${VIOLET}`,
].join("; ");

// The index bar itself — two equal cells, fixed height so the query rows below
// can align to its two halves.
const bar = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex: 1 1 auto",
  "min-width: 0",
  "height: 60px",
  "border-radius: 10px",
  "overflow: hidden",
  `border: 1px solid color-mix(in srgb, ${VIOLET} 45%, transparent)`,
].join("; ");

// A cell inside the bar. `live` = the reachable leading prefix (violet, white
// text); the buried second column is muted so it visibly reads as "present but
// not independently reachable".
const cell = (live: boolean) =>
  [
    reset,
    "box-sizing: border-box",
    "flex: 1",
    "min-width: 0",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "justify-content: center",
    "row-gap: 3px",
    "padding: 0 8px",
    "text-align: center",
    live
      ? `background: ${VIOLET}`
      : "background: color-mix(in srgb, var(--sl-color-gray-5) 70%, transparent)",
    live ? "color: #ffffff" : "color: var(--sl-color-gray-2)",
  ].join("; ");

// Divider between the two cells, on the muted (right) cell's leading edge.
const cellDivider = `border-left: 1px dashed color-mix(in srgb, ${VIOLET} 45%, transparent)`;

// Column name inside a cell.
const cellName = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 700",
  "letter-spacing: 0.01em",
  "line-height: 1.1",
].join("; ");

// Role tag under the column name ("leading column" / "second column").
const cellRole = (live: boolean) =>
  [
    reset,
    sans,
    "font-size: 10.5px",
    "font-weight: 600",
    "line-height: 1",
    live ? "color: rgba(255, 255, 255, 0.85)" : "color: var(--sl-color-gray-3)",
  ].join("; ");

// "sorted left → right" caption under the bar, offset to sit under the bar (not
// the entry marker) by reserving the marker's width + gap on the left.
const readDirRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "padding-left: 66px", // 58px marker + 8px gap → aligns under the bar
].join("; ");

const readDir = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");

// ---- The two query rows ----
const queries = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "row-gap: 10px",
].join("; ");

const queryRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "column-gap: 10px",
].join("; ");

// ✓ / ✗ pill — saturated fill + white glyph reads in both themes.
const pill = (ok: boolean) =>
  [
    reset,
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "flex: 0 0 auto",
    "width: 22px",
    "height: 22px",
    "border-radius: 999px",
    "font-size: 13px",
    "font-weight: 700",
    "line-height: 1",
    "color: #ffffff",
    `background: ${ok ? GREEN : RED}`,
  ].join("; ");

// The WHERE clause — monospace, fixed width so both clauses align and the
// verdict text starts at the same x on both rows.
const clause = [
  reset,
  mono,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "width: 188px",
  "font-size: 13px",
  "font-weight: 600",
  "line-height: 1.2",
  "white-space: nowrap",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The column name highlighted inside the clause, tinted to its verdict.
const clauseCol = (ok: boolean) =>
  [reset, "font-weight: 700", `color: ${ok ? GREEN : RED}`].join("; ");

// The one-line verdict after the pill.
const verdict = [
  reset,
  sans,
  "min-width: 0",
  "font-size: 12.5px",
  "font-weight: 500",
  "line-height: 1.35",
  "color: var(--sl-color-gray-3)",
].join("; ");

const verdictEm = (ok: boolean) =>
  [
    reset,
    "font-weight: 700",
    `color: color-mix(in srgb, ${ok ? GREEN : RED} 78%, var(--sl-color-text))`,
  ].join("; ");
---

<Figure>
  <div class="not-content half-indexed-junction" style={root}>
    {/* ---- The composite index, as a left-to-right bar ---------------- */}
    <div style={barBlock}>
      <div style={barRow}>
        <div style={entryMarker}>
          <span style={entryLabel}>scan enters here</span>
          <span style={entryArrow}>&rarr;</span>
        </div>

        <div style={bar}>
          <div style={cell(true)}>
            <span style={cellName}>invoice_id</span>
            <span style={cellRole(true)}>leading column</span>
          </div>
          <div style={[cell(false), cellDivider].join("; ")}>
            <span style={cellName}>tag_id</span>
            <span style={cellRole(false)}>second column</span>
          </div>
        </div>
      </div>

      <div style={readDirRow}>
        <span style={readDir}>index sorted left &rarr; right &mdash; one way in</span>
      </div>
    </div>

    {/* ---- What each filter direction gets ---------------------------- */}
    <div style={queries}>
      <div style={queryRow}>
        <span style={clause}>
          WHERE <span style={clauseCol(true)}>invoice_id</span> = &hellip;
        </span>
        <span style={pill(true)} aria-label="uses the index">&#10003;</span>
        <span style={verdict}>
          hits the <span style={verdictEm(true)}>left prefix</span> &mdash; uses the index
        </span>
      </div>

      <div style={queryRow}>
        <span style={clause}>
          WHERE <span style={clauseCol(false)}>tag_id</span> = &hellip;
        </span>
        <span style={pill(false)} aria-label="full table scan">&#10007;</span>
        <span style={verdict}>
          not a prefix &mdash; <span style={verdictEm(false)}>full table scan</span>
        </span>
      </div>
    </div>
  </div>
  <Fragment slot="caption">
    A composite index serves a <em>left prefix</em>. <code>invoice_id</code> is
    indexed; <code>tag_id</code> alone is not &mdash; the second-direction index
    (leading with <code>tag_id</code>) is still owed.
  </Fragment>
</Figure>
