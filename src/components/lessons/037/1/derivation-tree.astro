---
// derivation-tree — Chapter 037 Lesson 1, the PAYOFF picture for Principle #2.
// This is the RESOLUTION of the neutral five-surfaces hub from earlier in the
// lesson: the same surfaces, now given DIRECTION. One source on the left —
// `db/schema.ts`, the `invoices` table — fans rightward to the five shapes that
// are GENERATED from it, each arrow labelled with the generator that produces it.
// Where five-surfaces asked the question ("the same shape, restated five times,
// nothing connecting them"), this answers it: one root, every branch derived.
//
// The root box colour-matches the centre hub of five-surfaces exactly — the
// slate identity (gray-2 rail, gray-6 fill, gray-3 ring) AND the same column
// chips (id / total / status / dueDate / organizationId) — so the student reads
// the two figures as one picture, now resolved. The five derived cards reuse the
// neutral satellite treatment (grey, no per-box accent): none of them is special,
// each is just a branch pulling off the one root.
//
// Each derived card is split into a header strip (the shape name) and a body line
// (what it is). Every arrow lands on the HEADER strip — splitting the contact
// point is the doc's fix for many arrows sharing one target region, so the five
// arrowheads land tens of pixels apart on five different strips instead of
// stacking. The five curves leave the root's right edge with staggered
// start-gravity Y so they fan into five distinct lanes across the wide centre
// gap; each carries one short label naming its generator.
//
// This component renders the boxes + styles; the lesson wraps it in
// <Figure expandable={false}> — ArrowDiagram's leader lines are positioned from
// document.body and break if the figure is relocated into the expand lightbox.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const ARROW = "#94a3b8"; // slate — same neutral rail as five-surfaces

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — not-content, centred, capped well under the 800px ceiling.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 780px",
  "margin-inline: auto",
].join("; ");

// Two columns: the source on the left, the five derivations stacked on the right.
// A wide centre gap absorbs the five fanned curves and their generator labels.
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: minmax(160px, 210px) 168px minmax(190px, 250px)",
  "align-items: center",
  "justify-items: stretch",
].join("; ");

// LEFT — the source box. Slate identity, matched to the five-surfaces hub (same
// rails + ring + column chips) so the student reads the two figures as the same
// picture, now resolved.
const source = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 7px",
  "padding: 13px 15px",
  "border-radius: 12px",
  "border: 2px solid var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6)",
  "box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent)",
  "text-align: center",
].join("; ");

const sourceTitle = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const sourceSub = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Row of column-name chips inside the source — the SAME five chips the hub
// carried, so the root reads as "that exact shape, now the single source".
const colRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "justify-content: center",
  "gap: 4px 5px",
  "margin-top: 1px",
].join("; ");

const colChip = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 10.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "padding: 1px 5px",
  "border-radius: 5px",
  "color: var(--sl-color-gray-1)",
  "background: var(--sl-color-gray-5)",
  "border: 1px solid var(--sl-color-gray-4)",
].join("; ");

// RIGHT — the stacked column of derived-shape cards.
const stack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 9px",
].join("; ");

// One derived card. Neutral treatment (no per-box accent). Split into a header
// strip (the anchor every arrow lands on) and a body line.
const card = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "overflow: hidden",
  "border-radius: 10px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
].join("; ");

// Header strip — the arrow target. A faint tinted bar so the name reads as the
// "handle" the arrow grabs.
const cardHead = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "padding: 6px 11px",
  "color: var(--sl-color-text)",
  "background: var(--sl-color-gray-5)",
  "border-bottom: 1px solid var(--sl-color-gray-4)",
].join("; ");

const cardBody = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.3",
  "padding: 6px 11px 8px",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The five derivations, top → bottom, each with its generator label and a
// staggered start-gravity Y so the curves fan into five distinct lanes. Labels
// that are an actual code identifier are wrapped in backticks-as-text via the
// `mono` flag so they read as the generator, not prose.
const derivations = [
  {
    id: "der-row",
    name: "Row type",
    body: "the shape of an invoice you read back",
    label: "$inferSelect",
    gravity: [120, -74] as [number, number],
  },
  {
    id: "der-insert",
    name: "Insert type",
    body: "the shape you pass when creating one",
    label: "$inferInsert",
    gravity: [130, -37] as [number, number],
  },
  {
    id: "der-zod",
    name: "Zod validator",
    body: "guards the form and the Server Action",
    label: "createInsertSchema",
    gravity: [134, 0] as [number, number],
  },
  {
    id: "der-form",
    name: "Form field set",
    body: "the inputs the UI renders",
    label: "Zod field names",
    gravity: [130, 37] as [number, number],
  },
  {
    id: "der-rls",
    name: "RLS column names",
    body: "which rows a user may see (much later)",
    label: "same columns",
    gravity: [120, 74] as [number, number],
  },
];

// One slate arrow per derivation, source -> card header. Each leaves the source's
// right edge with a staggered Y so the five curves don't pile up, and lands on
// the header strip's left edge (heads spread across five strips, never stacked).
const arrows = derivations.map((d) => ({
  from: "der-source",
  to: d.id,
  label: d.label,
  color: ARROW,
  startSocket: "right" as const,
  endSocket: "left" as const,
  startSocketGravity: d.gravity,
  endSocketGravity: [-50, 0] as [number, number],
}));
---

<div class="not-content dtd" style={root}>
  <ArrowDiagram arrows={arrows}>
    <div style={stage}>
      {/* ---- LEFT: the single source — db/schema.ts ----------------- */}
      <div style="grid-column: 1; grid-row: 1; display: flex; justify-content: center;">
        <div id="der-source" style={source}>
          <span style={sourceTitle}>db/schema.ts</span>
          <span style={sourceSub}>the <code style={mono + "; color: inherit; background: none"}>invoices</code> table</span>
          <div style={colRow}>
            {
              ["id", "total", "status", "dueDate", "organizationId"].map((c) => (
                <code style={colChip}>{c}</code>
              ))
            }
          </div>
        </div>
      </div>

      {/* centre column is the empty gap the five curves + labels live in */}

      {/* ---- RIGHT: every shape generated from it ------------------- */}
      <div style="grid-column: 3; grid-row: 1;">
        <div style={stack}>
          {
            derivations.map((d) => (
              <div style={card}>
                <div id={d.id} style={cardHead}>
                  {d.name}
                </div>
                <div style={cardBody}>{d.body}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>

<style>
  /* The left-to-right fan is the whole figure, so don't let the two columns
     collapse. On narrow viewports allow horizontal scroll at a slimmer minimum
     width (laptop viewports — the design target — show it whole). */
  @media (max-width: 700px) {
    .dtd {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .dtd > div {
      min-width: 640px;
    }
  }
</style>
