---
// five-surfaces — Chapter 037 Lesson 1, the PROBLEM-STATEMENT picture for
// Principle #2. One invoice row shape sits at the centre of a radial hub; five
// satellite boxes surround it, one per surface that has to know the same columns
// (Drizzle table, Server Component prop, Zod validator, Server Action args, form
// field set). Each satellite carries a one-line "what it needs the shape for".
//
// Deliberately NEUTRAL: a single muted slate for every leader-line arrow, NO
// arrow labels, NO sense of direction or good/bad. The point is purely "the same
// handful of columns, restated in five separate places, nothing connecting them."
// The later derivation-tree diagram is the RESOLUTION of this same picture — it
// adds left-to-right direction and labelled generators — so this one stays
// directionless on purpose. The centre hub uses a recognisable slate identity so
// the resolution diagram can colour-match its `db/schema.ts` root to it.
//
// Layout is a 3x3 grid: the hub in the middle cell, the five satellites in the
// surrounding cells (two top corners, two side-middles, one bottom-centre). Each
// arrow leaves a distinct side/corner of the hub and lands on the satellite edge
// that faces the centre, so no curve crosses any box's text.
//
// This component renders the boxes + styles; the lesson wraps it in
// <Figure expandable={false}> — ArrowDiagram's leader lines are positioned from
// document.body and break if the figure is relocated into the expand lightbox.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const ARROW = "#94a3b8"; // slate — thin, neutral "touches the same shape"

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — not-content, centred, capped well under the 800px ceiling.
// ~720px wide keeps the radial geometry whole on a laptop viewport.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 720px",
  "margin-inline: auto",
].join("; ");

// 3x3 stage. Side columns hold the satellites; the centre column holds the hub.
// Generous row/column gaps give every radial curve room to bow out of the hub
// and into a satellite without crowding a neighbour.
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: 1fr minmax(150px, auto) 1fr",
  "grid-template-rows: auto auto auto",
  "column-gap: 54px",
  "row-gap: 26px",
  "align-items: center",
  "justify-items: center",
].join("; ");

// The central hub — the invoice row shape. Slate identity (gray rails + ring) so
// the resolution diagram can match its root box to it. Holds the column chips.
const hub = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 7px",
  "min-width: 150px",
  "max-width: 200px",
  "padding: 12px 14px",
  "border-radius: 12px",
  "border: 2px solid var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6)",
  "box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent)",
  "text-align: center",
].join("; ");

const hubTitle = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

// Row of column-name chips inside the hub.
const colRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "justify-content: center",
  "gap: 4px 5px",
].join("; ");

const colChip = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 10.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "padding: 1px 5px",
  "border-radius: 5px",
  "color: var(--sl-color-gray-1)",
  "background: var(--sl-color-gray-5)",
  "border: 1px solid var(--sl-color-gray-4)",
].join("; ");

// One satellite box. All five share the same neutral treatment — no per-box
// accent, because the whole point is that none of them is special yet.
const satellite = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 3px",
  "width: 100%",
  "max-width: 210px",
  "padding: 8px 11px",
  "border-radius: 10px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
].join("; ");

const satTitle = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-text)",
].join("; ");

const satNeed = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The five surfaces. `cell` places each in the 3x3 grid; `socket` is the hub side
// the arrow leaves from, picked so the curve exits toward that box.
const surfaces = [
  {
    id: "srf-table",
    title: "Drizzle table",
    need: "what's stored on disk",
    cell: "grid-column: 1; grid-row: 1;",
    socket: "left" as const,
    gravity: [-70, -34] as [number, number],
  },
  {
    id: "srf-prop",
    title: "Server Component prop",
    need: "what's passed in to render",
    cell: "grid-column: 3; grid-row: 1;",
    socket: "right" as const,
    gravity: [70, -34] as [number, number],
  },
  {
    id: "srf-zod",
    title: "Zod validator",
    need: "what the boundary checks before trusting input",
    cell: "grid-column: 1; grid-row: 2;",
    socket: "left" as const,
    gravity: [-80, 0] as [number, number],
  },
  {
    id: "srf-action",
    title: "Server Action args",
    need: "what the mutation accepts when you save",
    cell: "grid-column: 3; grid-row: 2;",
    socket: "right" as const,
    gravity: [80, 0] as [number, number],
  },
  {
    id: "srf-form",
    title: "Form field set",
    need: "what inputs the UI renders",
    cell: "grid-column: 2; grid-row: 3;",
    socket: "bottom" as const,
    gravity: [0, 70] as [number, number],
  },
];

// One thin neutral arrow per surface, hub -> satellite. Each leaves a distinct
// side/corner of the hub and lands on the satellite edge facing the centre, so no
// curve crosses any box's text. No labels, no colour variation — pure neutrality.
const arrows = surfaces.map((s) => ({
  from: "inv-hub",
  to: s.id,
  color: ARROW,
  startSocket: s.socket,
  endSocket:
    s.socket === "left" ? "right" : s.socket === "right" ? "left" : "top",
  startSocketGravity: s.gravity,
  endSocketGravity:
    s.socket === "left"
      ? ([40, 0] as [number, number])
      : s.socket === "right"
        ? ([-40, 0] as [number, number])
        : ([0, -40] as [number, number]),
}));
---

<div class="not-content fsd" style={root}>
  <ArrowDiagram arrows={arrows}>
    <div style={stage}>
      {/* ---- the four/five surrounding surfaces ---------------------- */}
      {
        surfaces.map((s) => (
          <div style={`${s.cell} width: 100%; display: flex; justify-content: center;`}>
            <div id={s.id} style={satellite}>
              <span style={satTitle}>{s.title}</span>
              <span style={satNeed}>{s.need}</span>
            </div>
          </div>
        ))
      }

      {/* ---- the centre — the one invoice row shape ------------------ */}
      <div style="grid-column: 2; grid-row: 2; display: flex; justify-content: center;">
        <div id="inv-hub" style={hub}>
          <span style={hubTitle}>the invoice row shape</span>
          <div style={colRow}>
            {
              ["id", "total", "status", "dueDate", "organizationId"].map((c) => (
                <code style={colChip}>{c}</code>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>

<style>
  /* The radial geometry is the whole figure, so don't let it collapse. On
     narrow viewports allow horizontal scroll at a slimmer minimum width
     (laptop viewports — the design target — show it whole). */
  @media (max-width: 680px) {
    .fsd {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .fsd > div {
      min-width: 600px;
    }
  }
</style>
