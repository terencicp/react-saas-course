---
// DriftFrame — one frame of the four-way-drift timeline, used inside
// <DiagramSequence>. This is the single most important visual in Ch037 L1:
// scrubbing the steps makes the drift visible in TIME — the gap between the
// renamed schema and the four hand-copied surfaces opens *silently*, then
// detonates in production, then (the counterfactual) is caught at edit time.
//
// The five surfaces are the SAME five from the neutral five-surfaces hub
// diagram above this section, now carrying state. One of them — the Drizzle
// table — is designated the SOURCE (slate identity, color-matched to the hub
// so the student reads it as the same picture). The other four are the
// hand-copied parallels: Invoice type (a Server Component prop), Zod validator,
// Server Action args, Form field set.
//
// Each surface box carries:
//   - a column-name pill: `total` (old) vs `amountDue` (renamed)
//   - a state badge: aligned / stale / runtime / compile
// A headline strip sits on top; steps 4 and 5 add an outcome banner below.
//
// `step` selects the frame (1..5):
//   1  Day one — all five name `total`, all aligned (green).
//   2  Rename lands — the Drizzle table flips to `amountDue` (green, correct);
//      the four copies still say `total` but are not yet flagged.
//   3  Four shapes drift — the four copies turn STALE (amber) and each carries
//      a "TypeScript is happy" badge. The teaching point is the silence.
//   4  Production — a red 500 banner; the first insert hits a missing column.
//   5  Counterfactual — the four were GENERATED from the schema, so the same
//      moment lights them up as red COMPILE errors at edit time instead.
//
// Pure HTML + CSS so it survives DiagramSequence's stacked grid (inactive
// steps stay in layout). No ArrowDiagram leader lines (those are positioned
// from document.body and break when only one stacked step is visible).
// `not-content` + `margin: 0` resets defeat Starlight's prose-margin selector.

interface Props {
  step: 1 | 2 | 3 | 4 | 5;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const OK = "#16a34a"; // green-600 — aligned / correct
const STALE = "#f59e0b"; // amber-500 — drifted but silent
const ERR = "#dc2626"; // red-600 — broke (runtime, or compile in the counterfactual)

// ---- per-surface, per-step state ---------------------------------------

type State = "aligned" | "stale" | "runtime" | "compile";

interface SurfaceFrame {
  col: "total" | "amountDue";
  state: State;
}

interface Surface {
  id: string;
  title: string;
  // what the surface needs the shape for — kept terse, echoes the hub diagram
  role: string;
  isSource: boolean;
  // state across the 5 steps
  frames: [SurfaceFrame, SurfaceFrame, SurfaceFrame, SurfaceFrame, SurfaceFrame];
}

// The source surface drifts to `amountDue` at step 2 and stays correct.
const SOURCE_FRAMES: Surface["frames"] = [
  { col: "total", state: "aligned" },
  { col: "amountDue", state: "aligned" },
  { col: "amountDue", state: "aligned" },
  { col: "amountDue", state: "aligned" },
  { col: "amountDue", state: "aligned" },
];

// A hand-copied surface: aligned, aligned, then stays on `total` and drifts.
// At step 3 it is stale-but-silent; at step 4 it is the runtime failure; at
// step 5 (the counterfactual) the same shape is instead a compile error.
const COPY_FRAMES: Surface["frames"] = [
  { col: "total", state: "aligned" },
  { col: "total", state: "aligned" },
  { col: "total", state: "stale" },
  { col: "total", state: "runtime" },
  { col: "total", state: "compile" },
];

const surfaces: Surface[] = [
  {
    id: "drizzle",
    title: "Drizzle table",
    role: "the source — what's stored",
    isSource: true,
    frames: SOURCE_FRAMES,
  },
  {
    id: "type",
    title: "Invoice type",
    role: "the Server Component prop",
    isSource: false,
    frames: COPY_FRAMES,
  },
  {
    id: "zod",
    title: "Zod validator",
    role: "what the form checks",
    isSource: false,
    frames: COPY_FRAMES,
  },
  {
    id: "action",
    title: "Server Action args",
    role: "what the mutation accepts",
    isSource: false,
    frames: COPY_FRAMES,
  },
  {
    id: "form",
    title: "Form field set",
    role: "the inputs the UI renders",
    isSource: false,
    frames: COPY_FRAMES,
  },
];

const idx = step - 1;

// In the counterfactual step, frame the whole picture as "the world where the
// four were generated" — so the four copies behave as derived shapes.
const isCounterfactual = step === 5;

// ---- per-step headline -------------------------------------------------

const headlines: Record<Props["step"], { kicker: string; line: string }> = {
  1: { kicker: "Day one", line: "Every spelling names the same column. The feature works." },
  2: {
    kicker: "The rename lands",
    line: "The column is renamed in Postgres and in the schema. The source of truth has moved.",
  },
  3: {
    kicker: "Four shapes drift",
    line: "The four hand-written copies still name total. TypeScript reports nothing.",
  },
  4: {
    kicker: "Production, first insert",
    line: "The deploy ships. The first save references a column that no longer exists.",
  },
  5: {
    kicker: "The world where the four were generated",
    line: "Same moment — but now the four shapes are derived from the schema.",
  },
};

const headline = headlines[step];

// ---- state badge copy + color ------------------------------------------

function badge(state: State): { text: string; color: string } {
  switch (state) {
    case "aligned":
      return { text: "aligned", color: OK };
    case "stale":
      return { text: "stale · no error", color: STALE };
    case "runtime":
      return { text: "runtime 500", color: ERR };
    case "compile":
      return { text: "compile error", color: ERR };
  }
}

// ---- styles ------------------------------------------------------------

const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 14px",
  "width: 100%",
  "max-width: 760px",
  "margin-inline: auto",
].join("; ");

// Headline strip — a kicker pill + a one-line summary.
const headRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: baseline",
  "justify-content: center",
  "gap: 8px 12px",
  "text-align: center",
].join("; ");

const stepNum = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

const kicker = [
  reset,
  sans,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const headLine = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
  "flex-basis: 100%",
].join("; ");

// The row of five surfaces. Five fixed-ish columns; wraps on narrow.
const grid = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: repeat(5, minmax(0, 1fr))",
  "gap: 10px",
  "width: 100%",
  "align-items: stretch",
].join("; ");

function surfaceBox(s: Surface, frame: SurfaceFrame): string {
  // Color the border/background by the surface's current state, except the
  // source which always reads as the calm slate "this is the root" identity.
  let accent: string;
  let bg: string;
  let ring: string;
  if (s.isSource) {
    accent = "var(--sl-color-gray-2)";
    bg = "var(--sl-color-gray-6)";
    ring = "box-shadow: 0 0 0 3px color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent)";
  } else {
    const c =
      frame.state === "aligned"
        ? OK
        : frame.state === "stale"
          ? STALE
          : ERR;
    accent = frame.state === "aligned" ? "var(--sl-color-gray-4)" : c;
    bg =
      frame.state === "aligned"
        ? "var(--sl-color-gray-6)"
        : `color-mix(in srgb, ${c} 12%, var(--sl-color-gray-6))`;
    ring =
      frame.state === "aligned"
        ? "box-shadow: none"
        : `box-shadow: 0 0 0 3px color-mix(in srgb, ${c} 16%, transparent)`;
  }
  return [
    reset,
    sans,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "gap: 6px",
    "height: 100%",
    "padding: 9px 8px 10px",
    "border-radius: 10px",
    `border: ${s.isSource ? "2px" : "1.5px"} solid ${accent}`,
    `background: ${bg}`,
    ring,
    "text-align: center",
  ].join("; ");
}

const sourceTag = [
  reset,
  sans,
  "font-size: 8.5px",
  "font-weight: 800",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 2px 6px",
  "border-radius: 999px",
  "color: var(--sl-color-white)",
  "background: var(--sl-color-gray-3)",
].join("; ");

const sTitle = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-weight: 700",
  "line-height: 1.15",
  "color: var(--sl-color-text)",
].join("; ");

const sRole = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The column-name pill — the load-bearing detail. `amountDue` reads green on
// the source; a stale/broken `total` reads in the surface's signal color.
function colPill(s: Surface, frame: SurfaceFrame): string {
  let c: string;
  if (frame.col === "amountDue") {
    c = OK;
  } else if (s.isSource) {
    c = "var(--sl-color-gray-2)";
  } else if (frame.state === "aligned") {
    c = "var(--sl-color-gray-2)";
  } else {
    c = frame.state === "stale" ? STALE : ERR;
  }
  const isColor = frame.col === "amountDue" || (!s.isSource && frame.state !== "aligned");
  return [
    reset,
    mono,
    "box-sizing: border-box",
    "display: inline-block",
    "font-size: 11px",
    "font-weight: 700",
    "line-height: 1.3",
    "padding: 2px 7px",
    "border-radius: 6px",
    `color: ${c}`,
    isColor
      ? `background: color-mix(in srgb, ${frame.col === "amountDue" ? OK : c} 13%, transparent); border: 1px solid color-mix(in srgb, ${frame.col === "amountDue" ? OK : c} 38%, transparent)`
      : "background: var(--sl-color-gray-5); border: 1px solid var(--sl-color-gray-4)",
  ].join("; ");
}

function badgeStyle(color: string, muted: boolean): string {
  return [
    reset,
    sans,
    "box-sizing: border-box",
    "margin-top: auto",
    "font-size: 9px",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "text-transform: uppercase",
    "line-height: 1.15",
    "padding: 2px 6px",
    "border-radius: 999px",
    muted ? "color: var(--sl-color-gray-3)" : `color: ${color}`,
    muted
      ? "background: var(--sl-color-gray-5); border: 1px solid var(--sl-color-gray-4)"
      : `background: color-mix(in srgb, ${color} 14%, transparent); border: 1px solid color-mix(in srgb, ${color} 40%, transparent)`,
  ].join("; ");
}

// A faint compile-error squiggle drawn under the column pill in the
// counterfactual step.
const squiggle = `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='8' height='4' viewBox='0 0 8 4'><path d='M0 3 Q2 0 4 3 T8 3' fill='none' stroke='${encodeURIComponent(
  ERR,
)}' stroke-width='1'/></svg>`;

const pillWrap = (squiggled: boolean) =>
  [
    reset,
    "box-sizing: border-box",
    "display: inline-flex",
    "padding-bottom: 4px",
    squiggled
      ? `background-image: url("${squiggle}"); background-repeat: repeat-x; background-position: bottom`
      : "",
  ]
    .filter(Boolean)
    .join("; ");

// Outcome banner (steps 4 and 5).
const banner = (color: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "gap: 9px",
    "width: 100%",
    "max-width: 560px",
    "padding: 9px 13px",
    "border-radius: 9px",
    `border: 1.5px solid color-mix(in srgb, ${color} 55%, transparent)`,
    `background: color-mix(in srgb, ${color} 12%, var(--sl-color-gray-6))`,
  ].join("; ");

const bannerDot = (color: string) =>
  `${reset}; flex: 0 0 auto; width: 9px; height: 9px; border-radius: 50%; background: ${color};`;

const bannerCode = [
  reset,
  mono,
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1.3",
  "color: var(--sl-color-text)",
].join("; ");

const bannerNote = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
  "margin-left: auto",
  "text-align: right",
].join("; ");

// Reserve the banner row's height on every step so the stage never reflows as
// the reader scrubs (DiagramSequence sizes to the tallest step, but keeping the
// slot present avoids the boxes jumping up and down).
const bannerSlot = [
  reset,
  "box-sizing: border-box",
  "width: 100%",
  "min-height: 42px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
].join("; ");
---

<div class="not-content dft" style={root}>
  {/* headline strip */}
  <div style={headRow}>
    <span style={stepNum}>STEP {step} / 5</span>
    <span style={kicker}>{headline.kicker}</span>
    <span style={headLine}>{headline.line}</span>
  </div>

  {/* the five surfaces */}
  <div style={grid}>
    {
      surfaces.map((s) => {
        const frame = s.frames[idx];
        // In the counterfactual, the copies are compile errors; otherwise use
        // the frame's own state.
        const effState: State =
          !s.isSource && isCounterfactual ? "compile" : frame.state;
        const effFrame: SurfaceFrame = { col: frame.col, state: effState };
        const b = badge(effState);
        const showSquiggle = !s.isSource && effState === "compile";
        return (
          <div style={surfaceBox(s, effFrame)}>
            {s.isSource ? (
              <span style={sourceTag}>source of truth</span>
            ) : (
              <span style={`${sourceTag}; visibility: hidden;`}>source</span>
            )}
            <span style={sTitle}>{s.title}</span>
            <span style={sRole}>{s.role}</span>
            <span style={pillWrap(showSquiggle)}>
              <code style={colPill(s, effFrame)}>{effFrame.col}</code>
            </span>
            <span
              style={badgeStyle(
                b.color,
                effState === "aligned" && !s.isSource,
              )}
            >
              {/* the four copies that are stale carry the "silence" label */}
              {effState === "stale" ? "TypeScript is happy" : b.text}
            </span>
          </div>
        );
      })
    }
  </div>

  {/* outcome banner slot — populated on steps 4 and 5 */}
  <div style={bannerSlot}>
    {
      step === 4 && (
        <div style={banner(ERR)}>
          <span style={bannerDot(ERR)} />
          <code style={bannerCode}>500 — column "total" does not exist</code>
          <span style={bannerNote}>surfaced at 3am, not in review</span>
        </div>
      )
    }
    {
      step === 5 && (
        <div style={banner(OK)}>
          <span style={bannerDot(OK)} />
          <span style={bannerCode}>4 silent failures → 4 compile errors</span>
          <span style={bannerNote}>caught the moment you save the file</span>
        </div>
      )
    }
  </div>
</div>

<style>
  /* The five-surface row is the whole figure; on narrow viewports let the
     grid relax to a 2-up wrap rather than crush five columns. Laptop
     viewports — the design target — show all five in a row. */
  @media (max-width: 640px) {
    .dft > div:nth-child(2) {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }
</style>
