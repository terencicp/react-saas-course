---
// read-write-containment — Chapter 037 Lesson 10 ("$inferSelect and
// $inferInsert"). Makes "select ⊇ insert" spatial: the WRITE shape is a
// projection of the READ shape. Same `users` columns as the CodeVariants diff
// just above (id / email / emailLowercased / createdAt) so the picture and the
// code line up column-for-column.
//
// Layout: two horizontal lanes, stacked, sharing one 4-column grid so each
// chip sits directly above its WRITE counterpart.
//
//   LANE 1  READ — $inferSelect : four solid, equal-weight chips. The full row.
//   LANE 2  WRITE — $inferInsert : the same four positions, restyled to show the
//           projection —
//             · id, createdAt  → dimmed + "optional" tag   (Rule 1, defaulted)
//             · emailLowercased → ghosted / struck through  (Rule 2, generated,
//               omitted; the WRITE cell shows an empty dashed slot so the
//               "dropped out" is literally a hole in the row)
//             · email          → solid + accent             (Rule 3, required)
//
// Faint vertical guides connect each READ chip to its WRITE cell, so the eye
// reads each column as one thing seen twice. A three-swatch legend names the
// states. Pure HTML + CSS; `not-content` + a `margin: 0` reset on every inner
// element defeat Starlight's prose-margin selector (which would otherwise shove
// the lower lane down and shrink it). Starlight theme variables + a saturated
// accent for "required" keep it native in light and dark. No leader lines, so
// the figure stays expandable.

import Figure from "../../../figures/Figure.astro";

// The four `users` columns, top → bottom of the CodeVariants diff. `write` is
// how each lands on $inferInsert: "required" | "optional" | "omitted".
const cols = [
  { name: "id", write: "optional" },
  { name: "email", write: "required" },
  { name: "emailLowercased", write: "omitted" },
  { name: "createdAt", write: "optional" },
] as const;
---

<Figure
  caption="The write shape is a projection of the read shape: defaulted columns become optional, generated columns drop out, and only the NOT NULL-without-a-default columns stay required."
>
  <div class="rw not-content">
    {/* ---- LANE 1 · READ — the full row, every chip solid -------------- */}
    <div class="rw-lane">
      <div class="rw-lane-head">
        <span class="rw-lane-kind">READ</span>
        <code class="rw-lane-helper">{"typeof users.$inferSelect"}</code>
      </div>
      <div class="rw-row">
        {cols.map((c) => (
          <div class="rw-cell">
            <code class="rw-chip rw-chip--read">{c.name}</code>
          </div>
        ))}
      </div>
    </div>

    {/* ---- the containment band: faint guides linking the two lanes ----- */}
    <div class="rw-band" aria-hidden="true">
      {cols.map((c) => (
        <div class="rw-guide-cell">
          <span class={`rw-guide rw-guide--${c.write}`}></span>
        </div>
      ))}
    </div>

    {/* ---- LANE 2 · WRITE — the same columns, projected ---------------- */}
    <div class="rw-lane">
      <div class="rw-lane-head">
        <span class="rw-lane-kind">WRITE</span>
        <code class="rw-lane-helper">{"typeof users.$inferInsert"}</code>
      </div>
      <div class="rw-row">
        {cols.map((c) => (
          <div class="rw-cell">
            {c.write === "omitted" ? (
              // Generated → not on the insert type at all. An empty dashed slot
              // makes "dropped out" a literal hole in the row.
              <div class="rw-chip rw-chip--omitted">
                <code class="rw-omit-name">{c.name}</code>
                <span class="rw-tag rw-tag--omitted">omitted</span>
              </div>
            ) : c.write === "required" ? (
              // NOT NULL, no default → the one column the app must supply.
              <code class="rw-chip rw-chip--required">{c.name}</code>
            ) : (
              // Has a default → optional (you may skip it, the DB fills it).
              <div class="rw-chip rw-chip--optional">
                <code class="rw-opt-name">{c.name}</code>
                <span class="rw-tag rw-tag--optional">optional</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    {/* ---- legend: the three states a column can land in on WRITE ------- */}
    <div class="rw-legend">
      <span class="rw-legend-item">
        <span class="rw-swatch rw-swatch--required"></span>required
        <span class="rw-legend-note">NOT NULL, no default</span>
      </span>
      <span class="rw-legend-item">
        <span class="rw-swatch rw-swatch--optional"></span>optional
        <span class="rw-legend-note">has a default</span>
      </span>
      <span class="rw-legend-item">
        <span class="rw-swatch rw-swatch--omitted"></span>omitted
        <span class="rw-legend-note">generated</span>
      </span>
    </div>
  </div>
</Figure>

<style>
  /* Stacked lanes, centred, capped well under the 800px ceiling. */
  .rw {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    max-width: 680px;
    margin-inline: auto;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- a lane (READ or WRITE) ---------------------------------------- */

  .rw-lane {
    box-sizing: border-box;
    padding: 12px 14px 14px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
    margin: 0;
  }

  .rw-lane-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 4px 10px;
    margin: 0 0 12px;
  }

  .rw-lane-kind {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* The `$infer*` helper, small + muted, so the lane names its source type. */
  .rw-lane-helper {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--sl-color-gray-3);
    background: transparent;
    padding: 0;
    margin: 0;
  }

  /* The four-column row, shared by both lanes so chips align column-for-column. */
  .rw-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
    margin: 0;
  }

  .rw-cell {
    display: flex;
    align-items: stretch;
    justify-content: center;
    min-width: 0;
    margin: 0;
  }

  /* A chip: a monospace column name in a rounded box. Fixed height so READ and
     WRITE rows share a baseline and the guides line up. */
  .rw-chip {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    width: 100%;
    min-height: 46px;
    padding: 6px 8px;
    border-radius: 9px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(11px, 1.7vw, 13.5px);
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    overflow-wrap: anywhere;
    margin: 0;
  }

  /* READ: every chip solid + equal weight. The full row, nothing special yet. */
  .rw-chip--read {
    border: 1px solid var(--sl-color-gray-4);
    background: color-mix(in srgb, var(--sl-color-gray-5) 65%, transparent);
    color: var(--sl-color-text);
  }

  /* WRITE · required (Rule 3): the loud one — accent fill, white text. This is
     the only column the app is on the hook for. */
  .rw-chip--required {
    border: 1px solid var(--sl-color-text-accent);
    background: var(--sl-color-text-accent);
    color: var(--sl-color-text-invert, #fff);
  }

  /* WRITE · optional (Rule 1): present but dimmed; a small "optional" tag. */
  .rw-chip--optional {
    border: 1px dashed color-mix(in srgb, var(--sl-color-gray-3) 70%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent);
    color: var(--sl-color-gray-2);
  }

  .rw-opt-name {
    background: transparent;
    padding: 0;
    margin: 0;
    color: inherit;
    font: inherit;
  }

  /* WRITE · omitted (Rule 2): a hole in the row — faint dashed slot, struck-out
     name, near-invisible. The column simply isn't on the insert type. */
  .rw-chip--omitted {
    border: 1px dashed color-mix(in srgb, var(--sl-color-gray-4) 60%, transparent);
    background: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 5px,
      color-mix(in srgb, var(--sl-color-gray-4) 22%, transparent) 5px,
      color-mix(in srgb, var(--sl-color-gray-4) 22%, transparent) 6px
    );
    color: var(--sl-color-gray-4);
  }

  .rw-omit-name {
    background: transparent;
    padding: 0;
    margin: 0;
    color: var(--sl-color-gray-3);
    font: inherit;
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
    opacity: 0.75;
  }

  /* The small state tags under the name inside optional / omitted chips. */
  .rw-tag {
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
    margin: 0;
  }

  .rw-tag--optional {
    color: var(--sl-color-gray-3);
  }

  .rw-tag--omitted {
    color: var(--sl-color-gray-4);
  }

  /* ---- the band between lanes: one faint guide per column ------------- */

  .rw-band {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
    /* line up the guides with the chips: the lanes have 14px side padding. */
    padding: 0 14px;
    margin: 0;
  }

  .rw-guide-cell {
    display: flex;
    justify-content: center;
    margin: 0;
  }

  /* A short vertical connector. Solid-ish for columns that carry through to
     WRITE, dashed + faint for the one that drops out. */
  .rw-guide {
    width: 2px;
    height: 18px;
    border-radius: 2px;
    margin: 0;
  }

  .rw-guide--required {
    background: color-mix(in srgb, var(--sl-color-text-accent) 55%, transparent);
  }

  .rw-guide--optional {
    background: color-mix(in srgb, var(--sl-color-gray-3) 45%, transparent);
  }

  /* omitted: the link is severed — a faint dotted stub that fades out. */
  .rw-guide--omitted {
    background: repeating-linear-gradient(
      to bottom,
      color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent),
      color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent) 2px,
      transparent 2px,
      transparent 5px
    );
  }

  /* ---- legend -------------------------------------------------------- */

  .rw-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    column-gap: 18px;
    row-gap: 6px;
    margin: 14px 0 0;
  }

  .rw-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--sl-color-text);
    margin: 0;
  }

  .rw-legend-note {
    font-size: 11px;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .rw-swatch {
    width: 13px;
    height: 13px;
    border-radius: 4px;
    box-sizing: border-box;
    margin: 0;
  }

  .rw-swatch--required {
    background: var(--sl-color-text-accent);
    border: 1px solid var(--sl-color-text-accent);
  }

  .rw-swatch--optional {
    background: color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent);
    border: 1px dashed color-mix(in srgb, var(--sl-color-gray-3) 70%, transparent);
  }

  .rw-swatch--omitted {
    background: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 3px,
      color-mix(in srgb, var(--sl-color-gray-4) 30%, transparent) 3px,
      color-mix(in srgb, var(--sl-color-gray-4) 30%, transparent) 4px
    );
    border: 1px dashed color-mix(in srgb, var(--sl-color-gray-4) 60%, transparent);
  }

  /* Narrow viewports: shrink chips/labels; the four-column read still holds. */
  @media (max-width: 460px) {
    .rw-chip {
      min-height: 42px;
      font-size: 10.5px;
    }
    .rw-lane-helper {
      font-size: 11px;
    }
  }
</style>
