---
// exports-fanout — Chapter 037 Lesson 2 ("pgTable and the snake_case bridge"),
// the CLOSING-LOOP picture for the file's exports. One source box on the left —
// `db/schema.ts`, the exported tables — fans rightward to the four tools that
// read it: db/relations.ts, db/index.ts, Drizzle Kit, drizzle-zod.
//
// This deliberately RHYMES with Lesson 1's derivation-tree resolution: same
// left-source / right-branches layout, one root, labelled fan-out. The root box
// colour-matches the centre hub of Lesson 1's five-surfaces diagram (the slate
// identity: gray-2 rail, gray-6 fill, gray-3 ring) so the student reads it as the
// same picture, now grounded in a real file. The consumer cards reuse the
// five-surfaces satellite treatment (neutral grey, no per-box accent) for the
// same reason — none of them is special; they all just pull on the one export.
//
// Each consumer card is split into a header strip (the file / tool name) and a
// body line (what it pulls), and every arrow lands on the HEADER strip. Splitting
// the contact point is the doc's fix for four arrows sharing one target region:
// the four arrowheads land tens of pixels apart on four different header strips
// instead of stacking. The four curves leave the root's right edge with
// staggered start-gravity Y so they fan into four distinct lanes across the gap;
// each carries one short label (imports / re-exports / migrations / validators).
//
// This component renders the boxes + styles; the lesson wraps it in
// <Figure expandable={false}> — ArrowDiagram's leader lines are positioned from
// document.body and break if the figure is relocated into the expand lightbox.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const ARROW = "#94a3b8"; // slate — same neutral rail as five-surfaces

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — not-content, centred, capped well under the 800px ceiling.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 760px",
  "margin-inline: auto",
].join("; ");

// Two columns: the source on the left, the four consumers stacked on the right.
// A wide centre gap absorbs the four fanned curves and their labels.
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: minmax(150px, 220px) 150px minmax(200px, 260px)",
  "align-items: center",
  "justify-items: stretch",
].join("; ");

// LEFT — the source box. Slate identity, matched to the five-surfaces hub so the
// student reads the two figures as the same picture.
const source = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 4px",
  "padding: 14px 16px",
  "border-radius: 12px",
  "border: 2px solid var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6)",
  "box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent)",
  "text-align: center",
].join("; ");

const sourceTitle = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const sourceSub = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

// RIGHT — the stacked column of consumer cards.
const stack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
].join("; ");

// One consumer card. Neutral satellite treatment (no per-box accent). Split into
// a header strip (the anchor every arrow lands on) and a body line.
const card = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "overflow: hidden",
  "border-radius: 10px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
].join("; ");

// Header strip — the arrow target. A faint tinted bar so the name reads as the
// "handle" the arrow grabs.
const cardHead = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "padding: 6px 11px",
  "color: var(--sl-color-text)",
  "background: var(--sl-color-gray-5)",
  "border-bottom: 1px solid var(--sl-color-gray-4)",
].join("; ");

const cardBody = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.3",
  "padding: 6px 11px 8px",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The four consumers, top → bottom, each with its arrow label and a staggered
// start-gravity Y so the curves fan into four distinct lanes.
const consumers = [
  {
    id: "fan-relations",
    name: "db/relations.ts",
    body: "imports the tables to describe how they connect (later this chapter)",
    label: "imports",
    gravity: [110, -52] as [number, number],
  },
  {
    id: "fan-index",
    name: "db/index.ts",
    body: "re-exports them as the schema namespace for the db client (later chapter)",
    label: "re-exports",
    gravity: [120, -18] as [number, number],
  },
  {
    id: "fan-kit",
    name: "Drizzle Kit",
    body: "reads the file to generate migrations",
    label: "input for migrations",
    gravity: [120, 18] as [number, number],
  },
  {
    id: "fan-zod",
    name: "drizzle-zod",
    body: "reads the same exports to generate validators",
    label: "input for validators",
    gravity: [110, 52] as [number, number],
  },
];

// One slate arrow per consumer, source -> card header. Each leaves the source's
// right edge with a staggered Y so the four curves don't pile up, and lands on
// the header strip's left edge (heads spread across four strips, never stacked).
const arrows = consumers.map((c) => ({
  from: "fan-source",
  to: c.id,
  label: c.label,
  color: ARROW,
  startSocket: "right" as const,
  endSocket: "left" as const,
  startSocketGravity: c.gravity,
  endSocketGravity: [-46, 0] as [number, number],
}));
---

<div class="not-content efd" style={root}>
  <ArrowDiagram arrows={arrows}>
    <div style={stage}>
      {/* ---- LEFT: the one exported source file ---------------------- */}
      <div style="grid-column: 1; grid-row: 1; display: flex; justify-content: center;">
        <div id="fan-source" style={source}>
          <span style={sourceTitle}>db/schema.ts</span>
          <span style={sourceSub}>the exported tables</span>
        </div>
      </div>

      {/* centre column is the empty gap the four curves + labels live in */}

      {/* ---- RIGHT: every tool that reads it ------------------------- */}
      <div style="grid-column: 3; grid-row: 1;">
        <div style={stack}>
          {
            consumers.map((c) => (
              <div style={card}>
                <div id={c.id} style={cardHead}>
                  {c.name}
                </div>
                <div style={cardBody}>{c.body}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>

<style>
  /* The left-to-right fan is the whole figure, so don't let the two columns
     collapse. On narrow viewports allow horizontal scroll at a slimmer minimum
     width (laptop viewports — the design target — show it whole). */
  @media (max-width: 660px) {
    .efd {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .efd > div {
      min-width: 600px;
    }
  }
</style>
