---
// casing-bridge-figure — Chapter 037 Lesson 2 ("pgTable and the snake_case
// bridge"). Turns the abstract "naming convention" into a literal two-lane
// picture so the student reads `casing` as a *bridge*, not a setting.
//
// Layout (left → centre → right), a 3-column CSS grid:
//
//   LEFT  "Your TypeScript" — three stacked camelCase chips, monospace:
//         createdAt / organizationId / amountDue.
//
//   CENTRE  the channel every row passes through. A faint vertical accent rail
//         runs the height of the three rows; on each row a double-headed ↔
//         connector spans the gap (translation goes both ways). Anchored over
//         the middle of the rail, one loud accent-tinted pill —
//         `casing: 'snake_case'` — the single hinge all three rows share. The
//         pill being one (not per-row) is the point: ONE config line does all
//         three.
//
//   RIGHT "Your Postgres" — the snake_case equivalents, row-for-row aligned
//         with the left: created_at / organization_id / amount_due.
//
// Pure HTML + CSS. `not-content` wrapper + a `margin: 0` reset on every inner
// element defeat Starlight's prose-margin selector (which would otherwise shove
// later grid rows down and shrink them). Starlight theme variables keep it
// native in light and dark; the accent pill uses --sl-color-text-accent so it
// reads as "the project's blue" in both themes. No leader lines, so the figure
// stays expandable.

import Figure from "../../../figures/Figure.astro";

// The three columns, each as a [camelCase, snake_case] pair, top → bottom.
const rows = [
  { ts: "createdAt", sql: "created_at" },
  { ts: "organizationId", sql: "organization_id" },
  { ts: "amountDue", sql: "amount_due" },
];
---

<Figure
  caption="One config line translates every camelCase key to its snake_case column — both directions, reads and writes."
>
  <div class="cb not-content">
    {/* LEFT LANE — what your TypeScript writes */}
    <div class="cb-lane cb-lane--ts">
      <div class="cb-lane-head">Your TypeScript</div>
      {rows.map((r) => <code class="cb-chip cb-chip--ts">{r.ts}</code>)}
    </div>

    {/* CENTRE CHANNEL — the bridge every row crosses */}
    <div class="cb-channel" aria-hidden="true">
      {/* invisible head placeholder: same box as a lane head, so the connector
          rows below it share the lanes' exact vertical rhythm and line up
          row-for-row with the chips without any magic offsets. */}
      <div class="cb-lane-head cb-lane-head--ghost">Your TypeScript</div>
      <div class="cb-rows">
        <div class="cb-rail"></div>
        {rows.map(() => (
          <div class="cb-row">
            <span class="cb-conn">&#8596;</span>
          </div>
        ))}
        <div class="cb-pill">
          <span class="cb-pill-text">casing: 'snake_case'</span>
        </div>
      </div>
    </div>

    {/* RIGHT LANE — what your Postgres stores */}
    <div class="cb-lane cb-lane--sql">
      <div class="cb-lane-head">Your Postgres</div>
      {rows.map((r) => <code class="cb-chip cb-chip--sql">{r.sql}</code>)}
    </div>
  </div>
</Figure>

<style>
  /* Three columns: TS lane | centre channel | SQL lane. The two lanes share the
     same row grid so chips align row-for-row; the channel column is sized so the
     pill has room without overpowering the lanes. */
  .cb {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(150px, 26%, 210px) minmax(0, 1fr);
    align-items: stretch;
    gap: 0;
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- The two lanes --------------------------------------------------- */

  .cb-lane {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 14px 14px 16px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
    box-sizing: border-box;
    margin: 0;
  }

  .cb-lane-head {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* Same box as a real head (so rows align) but invisible — it only reserves the
     head's height + the column gap in the channel. */
  .cb-lane-head--ghost {
    visibility: hidden;
  }

  /* A column chip: a monospace identifier. Fixed height so the three rows line
     up exactly with the channel's three connector rows. */
  .cb-chip {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 10px;
    border-radius: 8px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(12.5px, 2vw, 15px);
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    box-sizing: border-box;
    margin: 0;
  }

  /* TS lane: cool/blue-leaning tint. */
  .cb-chip--ts {
    border: 1px solid color-mix(in srgb, var(--sl-color-text-accent) 35%, var(--sl-color-hairline));
    background: color-mix(in srgb, var(--sl-color-text-accent) 9%, transparent);
    color: color-mix(in srgb, var(--sl-color-text-accent) 75%, var(--sl-color-text));
  }

  /* SQL lane: neutral/grey, to read as "the other world". */
  .cb-chip--sql {
    border: 1px solid var(--sl-color-gray-4);
    background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    color: var(--sl-color-text);
  }

  /* ---- The centre channel --------------------------------------------- */

  /* The channel mirrors a lane's column layout exactly: head placeholder on top,
     then the rows block — same 14px top padding and 14px gap as the lanes — so
     the connector rows share the chips' vertical rhythm with no magic offsets. */
  .cb-channel {
    display: flex;
    flex-direction: column;
    padding: 14px 6px 16px;
    gap: 14px;
    box-sizing: border-box;
    margin: 0;
  }

  /* The three connector rows, with the same 14px gap as the chips. This block's
     box is exactly the three rows, so the rail spans it and the pill centres on
     the middle row. */
  .cb-rows {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0;
  }

  /* The faint accent rail running behind the connectors, from the centre of the
     first row to the centre of the last; the pill sits centred on it. */
  .cb-rail {
    position: absolute;
    top: 20px;
    bottom: 20px;
    left: 50%;
    width: 3px;
    transform: translateX(-50%);
    border-radius: 3px;
    background: color-mix(in srgb, var(--sl-color-text-accent) 30%, transparent);
    margin: 0;
  }

  /* One connector row, the same 40px height as a chip so the ↔ centres on its
     pair. */
  .cb-row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    margin: 0;
  }

  .cb-conn {
    font-size: 20px;
    line-height: 1;
    font-weight: 700;
    color: color-mix(in srgb, var(--sl-color-text-accent) 70%, var(--sl-color-text));
    margin: 0;
  }

  /* The hinge: one accent-filled pill, centred over the middle connector,
     overlapping all three via the rail behind it. */
  .cb-pill {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: var(--sl-color-text-accent);
    box-shadow:
      0 0 0 4px var(--sl-color-bg-sidebar),
      0 0 0 5px color-mix(in srgb, var(--sl-color-text-accent) 45%, transparent),
      0 2px 8px rgba(0, 0, 0, 0.18);
    margin: 0;
    z-index: 1;
  }

  .cb-pill-text {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(12px, 1.9vw, 14px);
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    color: var(--sl-color-text-invert, #fff);
    margin: 0;
  }

  /* Narrow viewports: the channel collapses to a thin band; chips shrink. The
     three-column read still holds because the lanes stay side by side until
     it's genuinely too tight, then the pill wraps its label. */
  @media (max-width: 460px) {
    .cb {
      grid-template-columns: minmax(0, 1fr) clamp(96px, 22%, 150px) minmax(0, 1fr);
    }
    .cb-pill-text {
      white-space: normal;
      text-align: center;
    }
  }
</style>
