---
// Diagram: defaults-table — the keeper artifact of the "Postgres data types"
// lesson. A clean two-column lookup mapping the *kind* of column a SaaS app has
// (left) to the Drizzle builder you reach for (right). The right column is the
// payload, so it renders left-aligned and monospaced — the builder shapes line
// up vertically and read as code.
//
// Rendered inside the lesson's existing <Figure> (which supplies the card chrome
// + caption), so this component renders ONLY the table — no nested Figure, no
// caption here. `not-content` + per-element `margin: 0` defeat Starlight's
// prose-margin injection that would otherwise distort the grid rows. Chrome uses
// sl-color tokens so the table flips cleanly between light and dark themes.
//
// Style follows the lesson-table family (TwoRegistersTable, CvaLookup): a CSS
// grid laid out as `display: contents` rows, monospace <span>s for code (no
// Starlight <code> pill, which would add an unpredictable background + padding
// to every cell).

type Row = {
	kind: string;
	builder: string;
};

const rows: Row[] = [
	{ kind: 'Name / free text', builder: 'text()' },
	{ kind: 'Money', builder: 'numeric({ precision: 12, scale: 2 })' },
	{ kind: 'Count / small number', builder: 'integer()' },
	{ kind: 'Big number / Unix-ms', builder: "bigint({ mode: 'number' })" },
	{ kind: 'True / false', builder: 'boolean()' },
	{
		kind: 'Timestamp',
		builder: 'timestamp({ withTimezone: true }).defaultNow()',
	},
	{ kind: 'Calendar day', builder: 'date()' },
	{ kind: 'ID (surrogate key)', builder: 'uuid()' },
	{ kind: 'Fixed set of states', builder: 'pgEnum(...)' },
	{ kind: 'Flexible payload', builder: 'jsonb().$type<T>()' },
	{ kind: 'Small scalar list', builder: 'text().array()' },
	{ kind: 'IP address', builder: 'inet()' },
];
---

<div class="not-content dt-root">
	{/* Header row */}
	<div class="dt-row dt-header">
		<div class="dt-kind dt-head-cell">Kind of column</div>
		<div class="dt-builder dt-head-cell">Reach for</div>
	</div>

	{/* Data rows */}
	{
		rows.map((r) => (
			<div class="dt-row">
				<div class="dt-kind">{r.kind}</div>
				<div class="dt-builder">
					<span class="dt-mono">{r.builder}</span>
				</div>
			</div>
		))
	}
</div>

<style>
	.dt-root {
		display: grid;
		grid-template-columns: minmax(150px, max-content) 1fr;
		row-gap: 1px;
		padding: 8px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	.dt-row {
		display: contents;
	}

	.dt-kind,
	.dt-builder {
		padding: 9px 14px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 13.5px;
		line-height: 1.4;
		color: var(--sl-color-text);
		background: color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent);
		margin: 0;
		display: flex;
		align-items: center;
	}

	/* Left column — the human label. Quieter than the builder it maps to. */
	.dt-kind {
		font-weight: 500;
		color: var(--sl-color-gray-2);
		border-right: 1px solid
			color-mix(in srgb, var(--sl-color-gray-4) 60%, transparent);
	}

	/* Right column — the payload. Left-aligned monospace so the shapes stack. */
	.dt-builder {
		justify-content: flex-start;
	}

	.dt-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 13px;
		color: var(--sl-color-text);
		margin: 0;
	}

	/* Header row — distinguished by a stronger fill, weight, and uppercase. */
	.dt-head-cell {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-white);
		background: color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent);
		padding-top: 10px;
		padding-bottom: 10px;
	}

	.dt-header .dt-kind {
		border-right-color: color-mix(
			in srgb,
			var(--sl-color-gray-3) 60%,
			transparent
		);
	}

	@media (max-width: 460px) {
		.dt-kind,
		.dt-builder {
			padding: 8px 10px;
			font-size: 12.5px;
		}
		.dt-mono {
			font-size: 12px;
		}
	}
</style>
