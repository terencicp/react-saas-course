---
// column-anatomy — Chapter 037 Lesson 4, the opening mental model. One column
// declaration drawn as a left-to-right CHAIN of pill tokens, each link tagged by
// the checklist question it answers (TYPE / NULL? / DEFAULT? / DERIVED?). The
// student should read the column as a "slot machine of four decisions" before any
// prose: the type is the only required link, the rest are decisions you chain on.
//
// The line is:  createdAt: timestamp({ withTimezone: true }).defaultNow().notNull()
// plus a fourth, GHOSTED token  .generatedAlwaysAs(…)  drawn faint to the right —
// the derived slot, present in the model but rarely filled.
//
// Geometry, like UrlAnatomy (012/1), is derived from a fixed monospace advance so
// every pill hugs its token exactly: each token carries a char count, x positions
// accumulate left-to-right, and leaders drop from each token's centre to a label
// that staggers in height (a staircase) so adjacent labels never collide and each
// leader stays short and clearly owned. Token glyphs use currentColor so they flip
// with the theme; only the pill ring/fill and the bold tag carry a quiet tint.
// All <text> string content is wrapped in JS expressions ({'…'}) so
// remark-smartypants can't curl quotes or rewrite the braces/parens.

import Figure from '../../../figures/Figure.astro';

// Quiet accent tints from the highlight palette — readable on both themes. One
// hue per live slot purely to keep the three decisions visually distinct; the
// derived slot stays muted grey because it's the ghosted "rarely filled" link.
const TYPE = '#60a5fa'; // blue
const NULLC = '#34d399'; // green
const DEFAULT = '#a78bfa'; // violet
const GHOST = '#9ca3af'; // muted grey
const LEADER = '#9ca3af'; // fixed mid-gray for subordinate lines

const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";
const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// Per-character monospace advance at the code font-size below, and the pill's
// inner horizontal padding. X positions accumulate from X0.
const CW = 7.8; // advance for the 13px monospace code
const PAD = 7; // inner horizontal padding inside each pill
const X0 = 14; // left edge of the first pill

// Pill band geometry.
const PILL_Y = 118; // top of the pill row
const PILL_H = 30; // pill height
const TEXT_Y = PILL_Y + 20; // code baseline, vertically centred in the pill

// The chain, left → right. `tier` sets which vertical level the label sits at
// (a staircase, so neighbouring labels don't overlap); the column name has no
// label. `ghost` flags the dashed, faint derived slot.
const tokensIn = [
  { text: 'createdAt:', color: null, tag: null, desc: null, tier: 0 },
  {
    text: 'timestamp({ withTimezone: true })',
    color: TYPE,
    tag: 'TYPE',
    desc: 'what can be stored',
    sub: 'last lesson',
    tier: 1,
  },
  {
    text: '.defaultNow()',
    color: DEFAULT,
    tag: 'DEFAULT?',
    desc: 'what fills it in',
    tier: 3,
  },
  {
    text: '.notNull()',
    color: NULLC,
    tag: 'NULL?',
    desc: 'is absence allowed',
    tier: 1,
  },
  {
    text: '.generatedAlwaysAs(…)',
    color: GHOST,
    tag: 'DERIVED?',
    desc: 'does Postgres compute it',
    tier: 3,
    ghost: true,
  },
];

// Accumulate each token's x/width from its character count + padding.
type Tok = (typeof tokensIn)[number] & {
  x: number;
  w: number;
  mid: number;
};
let cursor = X0;
const tokens: Tok[] = tokensIn.map((t) => {
  const w = t.text.length * CW + PAD * 2;
  const tok = { ...t, x: cursor, w, mid: cursor + w / 2 } as Tok;
  cursor += w; // pills abut — the chain reads as one connected run
  return tok;
});
const chainRight = cursor;

// Label baselines per tier. Tier 1 sits high; tier 3 sits lower, so its leader is
// longer and the two rows of labels clear each other vertically.
const tagY = { 1: 30, 3: 70 } as Record<number, number>;
const descY = { 1: 46, 3: 86 } as Record<number, number>;
// Where a token's leader starts — just below its lowest label line, so a token
// that carries a `(sub)` row drops its leader from under the sub, not through it.
const leaderStart = (t: { tier: number; sub?: string }) =>
  descY[t.tier] + (t.sub ? 20 : 6);

const VW = chainRight + X0; // viewBox width: chain + symmetric right margin
const VH = 158; // cropped to the labels + pill band + a little breathing room
---

<Figure
  caption="One column declaration. The type is the only required link; the rest are decisions you chain on."
>
  <svg
    viewBox={`0 0 ${VW} ${VH}`}
    role="img"
    aria-label="The column declaration createdAt: timestamp({ withTimezone: true }).defaultNow().notNull() drawn as a chain of pill tokens. The type token is tagged TYPE (what can be stored), .defaultNow() is tagged DEFAULT? (what fills it in), .notNull() is tagged NULL? (is absence allowed), and a faint ghosted token .generatedAlwaysAs(…) to the right is tagged DERIVED? (does Postgres compute it)."
    xmlns="http://www.w3.org/2000/svg"
    style="width: 100%; height: auto; display: block;"
  >
    {/* ---------- the pill chain ---------- */}
    {
      tokens.map((t) => (
        <g>
          <rect
            x={t.x}
            y={PILL_Y}
            width={t.w}
            height={PILL_H}
            rx="8"
            ry="8"
            fill={
              t.color
                ? `color-mix(in srgb, ${t.color} ${t.ghost ? 7 : 13}%, transparent)`
                : 'color-mix(in srgb, currentColor 6%, transparent)'
            }
            stroke={t.color ?? 'currentColor'}
            stroke-opacity={t.ghost ? 0.5 : t.color ? 0.85 : 0.32}
            stroke-width="1.5"
            stroke-dasharray={t.ghost ? '4 3' : undefined}
          />
          <text
            x={t.mid}
            y={TEXT_Y}
            font-family={mono}
            font-size="13"
            fill="currentColor"
            fill-opacity={t.ghost ? 0.45 : 1}
            text-anchor="middle"
          >
            {t.text}
          </text>
        </g>
      ))
    }

    {/* ---------- leaders + staircase labels above each tagged token ---------- */}
    {
      tokens
        .filter((t) => t.tag)
        .map((t) => (
          <g>
            <line
              x1={t.mid}
              y1={leaderStart(t)}
              x2={t.mid}
              y2={PILL_Y - 4}
              stroke={LEADER}
              stroke-width="1"
              stroke-opacity={t.ghost ? 0.7 : 1}
            />
            <text
              x={t.mid}
              y={tagY[t.tier]}
              font-family={sans}
              font-size="11.5"
              font-weight="700"
              letter-spacing="0.4"
              fill={t.color ?? LEADER}
              fill-opacity={t.ghost ? 0.85 : 1}
              text-anchor="middle"
            >
              {t.tag}
            </text>
            <text
              x={t.mid}
              y={descY[t.tier]}
              font-family={sans}
              font-size="11"
              fill={LEADER}
              text-anchor="middle"
            >
              {t.desc}
            </text>
            {t.sub ? (
              <text
                x={t.mid}
                y={descY[t.tier] + 14}
                font-family={sans}
                font-size="10"
                fill={LEADER}
                fill-opacity="0.8"
                text-anchor="middle"
              >
                {`(${t.sub})`}
              </text>
            ) : null}
          </g>
        ))
    }
  </svg>
</Figure>
