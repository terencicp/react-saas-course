---
// two-layers — Chapter 037 Lesson 9 ("Drizzle Relations v2"), the BEFORE-any-code
// picture for the lesson's load-bearing distinction: the foreign key and the
// relation are two declarations of the SAME edge, for two different audiences.
//
// Layout (two columns, a 2-column CSS grid):
//
//   LEFT  "db/schema.ts → Postgres" — the write-time world. Two stacked boxes,
//         `invoices` above `organizations`, each a tiny table header. An amber
//         connector runs between them carrying a `FOREIGN KEY` pill with an
//         `ON DELETE` sub-label, arrowhead pointing down (invoices → organizations,
//         the FK's own direction). Muted footnote: a write-time rule Postgres
//         enforces.
//
//   RIGHT "db/relations.ts → db.query" — the read-time world. The SAME two boxes
//         in the SAME positions, joined instead by a blue (project-accent)
//         connector carrying a `relation` pill with a `with: { … }` sub-label.
//         Muted footnote: a read-time map only the query builder reads.
//
// The two boxes are visually IDENTICAL across the columns (neutral slate, matched
// to this chapter's `db/schema.ts` identity from L1/L2) so the parallel reads as
// "same two boxes". The distinction is carried entirely by the two differently
// tinted connectors — amber on the left (a constraint), accent-blue on the right
// (the TS query side, consistent with L2's casing bridge). A thin centre divider
// reinforces "two separate declarations".
//
// Pure HTML + CSS. `not-content` wrapper + a `margin: 0` reset on every rule
// defeat Starlight's prose-margin selector (which would otherwise shove the lower
// box down and shrink it). Starlight theme variables keep it native in light and
// dark. No leader lines, so the figure stays expandable.

import Figure from "../../../figures/Figure.astro";

// Each panel: a heading, two stacked table boxes joined by a connector, a footnote.
// `tone` selects the connector tint via a CSS var on the panel.
const panels = [
  {
    tone: "fk",
    file: "db/schema.ts",
    audience: "Postgres",
    edgeLabel: "FOREIGN KEY",
    edgeSub: "ON DELETE",
    note: "A write-time rule. Postgres enforces it on every insert and delete.",
  },
  {
    tone: "rel",
    file: "db/relations.ts",
    audience: "db.query",
    edgeLabel: "relation",
    edgeSub: "with: { … }",
    note: "A read-time map. Only the query builder ever reads it; Postgres never sees it.",
  },
];
---

<Figure
  caption="The same two tables, joined by two different edges for two different readers. The foreign key (left) governs writes; the relation (right) is a separate declaration the query builder reads. Declaring one never declares the other."
>
  <div class="tl not-content">
    {
      panels.map((p) => (
        <div class={`tl-panel tl-panel--${p.tone}`}>
          {/* heading: db/schema.ts → Postgres */}
          <div class="tl-head">
            <code class="tl-file">{p.file}</code>
            <span class="tl-arrow">&#8594;</span>
            <code class="tl-audience">{p.audience}</code>
          </div>

          {/* the two stacked tables + the connector between them */}
          <div class="tl-stack">
            <div class="tl-table">
              <div class="tl-table-head">invoices</div>
              <div class="tl-table-rule" />
            </div>

            <div class="tl-conn">
              <div class="tl-line" />
              <div class="tl-pill">
                <span class="tl-pill-label">{p.edgeLabel}</span>
                <code class="tl-pill-sub">{p.edgeSub}</code>
              </div>
              <div class="tl-head-tri" aria-hidden="true" />
            </div>

            <div class="tl-table">
              <div class="tl-table-head">organizations</div>
              <div class="tl-table-rule" />
            </div>
          </div>

          <p class="tl-note">{p.note}</p>
        </div>
      ))
    }

    {/* thin divider between the two declarations */}
    <div class="tl-divider" aria-hidden="true" />
  </div>
</Figure>

<style>
  /* Two equal columns side by side; a hairline divider sits in the gap (drawn as
     an overlaid element so it can span only the panels' height). */
  .tl {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    margin: 0;
    max-width: 720px;
    margin-inline: auto;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* One labelled panel. `--edge` is the connector tint, set per tone below. */
  .tl-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 4px 18px 0;
    margin: 0;
    box-sizing: border-box;
  }

  /* Left panel: amber edge — a constraint / guardrail. */
  .tl-panel--fk {
    --edge: #d97706;
  }
  /* Right panel: the project accent — the TS / query-builder side. */
  .tl-panel--rel {
    --edge: var(--sl-color-text-accent);
  }

  /* Heading line: db/schema.ts → Postgres */
  .tl-head {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 7px;
    margin: 0;
  }

  .tl-file {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(12.5px, 1.9vw, 14.5px);
    font-weight: 700;
    line-height: 1.2;
    padding: 2px 8px;
    border-radius: 7px;
    white-space: nowrap;
    background: color-mix(in srgb, var(--edge) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--edge) 32%, var(--sl-color-hairline));
    color: color-mix(in srgb, var(--edge) 70%, var(--sl-color-text));
    margin: 0;
  }

  .tl-arrow {
    font-size: 15px;
    line-height: 1;
    font-weight: 700;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .tl-audience {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(11.5px, 1.7vw, 13px);
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    color: var(--sl-color-gray-2);
    background: transparent;
    padding: 0;
    margin: 0;
  }

  /* The two-table stack + connector. Fixed-ish width so both panels match and the
     connector centres cleanly. */
  .tl-stack {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    max-width: 220px;
    margin: 0;
  }

  /* One table box — a header strip + a faint "rows" rule, the chapter's neutral
     slate `db/schema.ts` identity so both panels read as the SAME two boxes. */
  .tl-table {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 9px;
    border: 1.5px solid var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
    box-sizing: border-box;
    margin: 0;
  }

  .tl-table-head {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(12px, 1.8vw, 13.5px);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    padding: 7px 10px;
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5);
    margin: 0;
  }

  /* A faint body strip under the header so the box reads as a table, not a button. */
  .tl-table-rule {
    height: 12px;
    background: repeating-linear-gradient(
      var(--sl-color-gray-6),
      var(--sl-color-gray-6) 5px,
      var(--sl-color-gray-5) 5px,
      var(--sl-color-gray-5) 6px
    );
    border-top: 1px solid var(--sl-color-gray-4);
    margin: 0;
  }

  /* The connector between the two boxes: a tinted vertical line with a pill
     straddling it and a triangular arrowhead at the foot pointing into the lower
     box (the FK / relation's own direction). All in normal flow, so the figure
     survives being relocated into the expand lightbox. */
  .tl-conn {
    position: relative;
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 6px 0 2px;
    margin: 0;
  }

  .tl-line {
    width: 3px;
    height: 52px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--edge) 55%, transparent);
    margin: 0;
  }

  /* The edge label, centred on the line. Loud tinted pill so it reads as the
     declaration that names this edge. */
  .tl-pill {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 5px 11px;
    border-radius: 9px;
    background: var(--edge);
    box-shadow:
      0 0 0 4px var(--sl-color-bg-sidebar),
      0 2px 7px rgba(0, 0, 0, 0.18);
    margin: 0;
    z-index: 1;
  }

  .tl-pill-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1.15;
    white-space: nowrap;
    color: #fff;
    margin: 0;
  }

  .tl-pill-sub {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    font-weight: 600;
    line-height: 1.15;
    white-space: nowrap;
    color: color-mix(in srgb, #fff 82%, var(--edge));
    background: transparent;
    padding: 0;
    margin: 0;
  }

  /* Arrowhead at the foot of the line, pointing down into the lower box. */
  .tl-head-tri {
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 8px solid color-mix(in srgb, var(--edge) 55%, transparent);
    margin: -1px 0 0;
  }

  /* The per-panel footnote. */
  .tl-note {
    font-size: clamp(11px, 1.7vw, 12.5px);
    font-weight: 500;
    line-height: 1.35;
    text-align: center;
    max-width: 240px;
    color: var(--sl-color-gray-3);
    margin: 4px 0 0;
  }

  /* Hairline divider drawn in the centre gap, spanning the panels' height (it
     stops short of the top/bottom so it reads as a seam, not a full rule). */
  .tl-divider {
    position: absolute;
    top: 10%;
    bottom: 10%;
    left: 50%;
    width: 1px;
    transform: translateX(-50%);
    background: var(--sl-color-hairline);
    margin: 0;
  }

  /* Narrow viewports: stack the two panels, divider becomes horizontal. */
  @media (max-width: 520px) {
    .tl {
      grid-template-columns: 1fr;
      row-gap: 26px;
    }
    .tl-divider {
      top: 50%;
      bottom: auto;
      left: 12%;
      right: 12%;
      width: auto;
      height: 1px;
      transform: translateY(-50%);
    }
  }
</style>
