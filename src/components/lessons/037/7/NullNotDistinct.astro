---
// null-not-distinct (diagram id: diagram-null-not-distinct,
// Chapter 037 Lesson 7 — "UNIQUE and CHECK constraints"). The NULL ≠ NULL
// collision table. Its job is to make the lesson's highest-value gotcha
// *visible*: against a `UNIQUE (organization_id, slug)`, two rows with the same
// (org, slug) pair collide — UNLESS the slug is NULL, in which case every NULL
// counts as a distinct value and the unique waves them all through. The sticky
// moment is seeing the last two rows (acme / NULL, twice) BOTH pass.
//
// Layout — a real HTML <table> in the house style of this chapter's row tables
// (DenormalizedInvoicesTable / OrganizationsTable): border-collapse, inline
// style strings, Starlight theme vars, `margin: 0` resets to defeat Starlight's
// injected prose margins, flips clean light/dark. Rows are inserted in order
// against an already-present first row, so the result column reads as a replay
// of six INSERTs.
//
// Encoding:
//   - result ✓ accepted → green pill (saturated green, white glyph — reads in
//     both themes); ✗ rejected → red pill. Per the html-css guidance, saturated
//     mid-tones with white text are the safe choice when the color IS the signal.
//   - the two NULL rows (5, 6) get a tinted background + a left accent rule (the
//     same "highlighted block" device as DenormalizedInvoicesTable, but teal
//     here — amber there meant "duplication smell"; teal here means "watch this,
//     the surprising case"). A callout cell spans those two rows on the right and
//     pins the explanation to exactly the rows it's about.
//   - NULL renders as a small uppercase monospace token, visually distinct from a
//     real slug string, so the eye reads it as "absence of value" not the literal
//     text "null".
//
// Renders its own <Figure> (card chrome + caption) — the MDX just imports and
// places it, no outer Figure.

import Figure from '../../../figures/Figure.astro';

const mono =
	'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

type Row = {
	org: string;
	slug: string | null;
	ok: boolean;
	why: string;
	// `nullRow` flags the two surprising NULL rows that share the tint + accent.
	nullRow?: boolean;
};

const rows: Row[] = [
	{ org: 'acme', slug: 'home', ok: true, why: 'first of its kind' },
	{ org: 'acme', slug: 'about', ok: true, why: 'different slug' },
	{ org: 'acme', slug: 'home', ok: false, why: 'duplicate pair — same org, same slug' },
	{ org: 'globex', slug: 'home', ok: true, why: 'same slug, different org' },
	{ org: 'acme', slug: null, ok: true, why: 'NULL slug', nullRow: true },
	{ org: 'acme', slug: null, ok: true, why: 'a second NULL — not blocked (!)', nullRow: true },
];

// --- Header cell ---
const thStyle = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.55rem 0.9rem',
	'text-align: left',
	'vertical-align: bottom',
	'border-bottom: 2px solid var(--sl-color-hairline)',
	'background: var(--sl-color-bg)',
	mono,
	'font-size: 0.85rem',
	'font-weight: 600',
	'color: var(--sl-color-white)',
	'white-space: nowrap',
].join('; ');

// Result header is centered above the ✓/✗ pills.
const thResult = [thStyle, 'text-align: center'].join('; ');

// --- Body cells ---
const tdBase = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.5rem 0.9rem',
	'text-align: left',
	'font-size: 0.9rem',
	'color: var(--sl-color-text)',
	'white-space: nowrap',
];

const border = (isLast: boolean) =>
	isLast ? 'border-bottom: 0' : 'border-bottom: 1px solid var(--sl-color-hairline)';

// org / slug value cells → monospace, since they're literal data values.
const tdVal = (isLast: boolean) =>
	[...tdBase, border(isLast), mono].join('; ');

// The two NULL rows get the teal tint + left accent. `mid` keeps the vertical
// accent unbroken across the two stacked rows so they read as one block.
// Explicit teal (not the theme accent, which is blue here) so the "watch this
// surprising row" highlight stays distinct from both the blue accent and the
// green/red result pills. Teal mid-tones read in both light and dark.
const tealFill = 'color-mix(in srgb, #14b8a6 16%, transparent)';
const tealLine = 'color-mix(in srgb, #2dd4bf 34%, transparent)';
const tdValNull = (isLast: boolean, mid: boolean) =>
	[
		...tdBase,
		border(isLast),
		mono,
		`background: ${tealFill}`,
		mid ? `border-top: 1px solid ${tealLine}` : '',
	]
		.filter(Boolean)
		.join('; ');

// Left-most value cell of a NULL row also carries the accent rule.
const tdOrgNull = (isLast: boolean, mid: boolean) =>
	[tdValNull(isLast, mid), 'border-left: 3px solid #14b8a6'].join('; ');

// Result cell — centers the pill.
const tdResult = (isLast: boolean, isNull: boolean, mid: boolean) =>
	[
		...tdBase.filter((s) => s !== 'text-align: left'),
		'text-align: center',
		border(isLast),
		isNull ? `background: ${tealFill}` : '',
		isNull && mid ? `border-top: 1px solid ${tealLine}` : '',
	]
		.filter(Boolean)
		.join('; ');

// ✓ / ✗ pills — saturated fill + white glyph reads in both themes.
const pillBase = [
	'display: inline-flex',
	'align-items: center',
	'justify-content: center',
	'width: 1.5rem',
	'height: 1.5rem',
	'border-radius: 999px',
	'font-size: 0.95rem',
	'font-weight: 700',
	'line-height: 1',
	'color: #fff',
	'margin: 0',
];
const pillOk = [...pillBase, 'background: #16a34a'].join('; ');
const pillNo = [...pillBase, 'background: #dc2626'].join('; ');

// NULL token — uppercase muted monospace so it reads as "no value", not a slug.
const nullToken = [
	'display: inline-block',
	mono,
	'font-size: 0.78rem',
	'font-weight: 600',
	'letter-spacing: 0.04em',
	'color: var(--sl-color-gray-3)',
	'background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent)',
	'border: 1px dashed var(--sl-color-gray-4)',
	'border-radius: 4px',
	'padding: 0.05rem 0.4rem',
	'margin: 0',
].join('; ');

// The callout pinned to the two NULL rows, rendered in a cell that row-spans them.
const calloutCell = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.5rem 0.9rem',
	'vertical-align: middle',
	'border-bottom: 0',
	`background: ${tealFill}`,
	'border-left: 1px dashed ' + tealLine,
].join('; ');

const calloutInner = [
	'margin: 0',
	'max-width: 17rem',
	'font-size: 0.82rem',
	'line-height: 1.45',
	'color: var(--sl-color-text)',
].join('; ');
---

<Figure>
	<div style="display: flex; justify-content: center; margin: 0; overflow-x: auto;">
		<table
			style="border-collapse: collapse; margin: 0; background: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); border-radius: 7px; overflow: hidden;"
		>
			<thead>
				<tr style="margin: 0;">
					<th scope="col" style={thStyle}>organization_id</th>
					<th scope="col" style={thStyle}>slug</th>
					<th scope="col" style={thResult}>UNIQUE (organization_id, slug)</th>
					<th
						scope="col"
						style={[thStyle, 'background: transparent; border-bottom-color: transparent;'].join('; ')}
						aria-hidden="true"
					>
					</th>
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row, i) => {
						const isLast = i === rows.length - 1;
						const prevNull = i > 0 && rows[i - 1].nullRow;
						const mid = !!row.nullRow && !!prevNull;
						// The callout cell is rendered once, on the first NULL row, and
						// row-spans the rest of the NULL block.
						const firstNull = !!row.nullRow && !prevNull;
						const nullCount = rows.filter((r) => r.nullRow).length;
						return (
							<tr style="margin: 0;">
								<td style={row.nullRow ? tdOrgNull(isLast, mid) : tdVal(isLast)}>{row.org}</td>
								<td style={row.nullRow ? tdValNull(isLast, mid) : tdVal(isLast)}>
									{row.slug === null ? <span style={nullToken}>NULL</span> : row.slug}
								</td>
								<td style={tdResult(isLast, !!row.nullRow, mid)}>
									<span
										style={row.ok ? pillOk : pillNo}
										aria-label={row.ok ? 'accepted' : 'rejected'}
									>
										{row.ok ? '✓' : '✗'}
									</span>
								</td>
								{firstNull ? (
									<td rowspan={nullCount} style={calloutCell}>
										<div style={calloutInner}>
											<strong style="color: #0d9488; margin: 0;">
												NULL ≠ NULL.
											</strong>{' '}
											Every NULL counts as a distinct value, so the unique never
											sees these two as duplicates — both slip through.
										</div>
									</td>
								) : row.nullRow ? null : (
									<td
										style={[
											'margin: 0',
											'border-bottom: 0',
											'background: transparent',
											'padding: 0 0.4rem',
										].join('; ')}
									/>
								)}
							</tr>
						);
					})
				}
			</tbody>
		</table>
	</div>
	<Fragment slot="caption">
		Six rows inserted in order against a <code>UNIQUE (organization_id, slug)</code>.
		The same <code>(organization_id, slug)</code> pair collides (row 3) — unless the
		slug is <code>NULL</code>, in which case every NULL is treated as its own value
		and the unique lets them all through.
	</Fragment>
</Figure>
