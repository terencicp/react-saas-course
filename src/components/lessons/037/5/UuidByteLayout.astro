---
// UuidByteLayout — Chapter 037 Lesson 5 ("Primary keys: UUIDv7 and identity
// bigint"). Makes the v4-vs-v7 difference visible in a single glance: where the
// timestamp lives inside the 16 bytes, and therefore where a new insert lands in
// the sorted primary-key index.
//
// Layout (top → bottom), two stacked equal-width units sharing one coordinate
// system:
//   1. UUIDv4 — one flat SLATE strip labeled "random" (every byte is noise), with
//      three example values whose LEADING hex are all different (the scatter). A
//      one-line note: random leading bytes → inserts scatter across the index.
//   2. UUIDv7 — the leading ~6 bytes (40% of the strip) a VIOLET "timestamp (ms)"
//      segment, the trailing bytes a GREEN "random" segment, with three example
//      values minted seconds apart that share a near-identical VIOLET prefix
//      (0193b5a…). A one-line note: shared prefix → inserts append at the tail.
//
// The whole lesson of the figure is the contrast between the two example rows:
// scattered leading hex on top vs a shared prefix on the bottom. The example
// values are monospace and slightly larger than the labels, and their leading
// hex is tinted to match the strip segment it comes from, tying each value back
// to the bytes above it.
//
// Pure HTML + CSS, inline styles only. `margin: 0` reset on every inner element
// to defeat Starlight's prose-margin selector. Saturated 600-range fills with
// white labels read in both light and dark theme (same palette family as the
// rest of the chapter). Split column-gap / row-gap. Height capped well under the
// 800px ceiling. No leader lines, so the figure stays expandable.

const SLATE = "#64748b"; // slate-500 — pure randomness, the muted "default trap"
const VIOLET = "#7c3aed"; // violet-600 — the timestamp prefix (meaningful, ordered)
const GREEN = "#16a34a"; // green-600  — the random tail (still globally unique)

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — centered, fluid, stacked.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 660px",
  "margin-inline: auto",
  "display: flex",
  "flex-direction: column",
  "row-gap: 30px",
].join("; ");

// One labeled unit = a left version label + the strip + the examples, all
// sharing the unit's width.
const unit = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "row-gap: 12px",
].join("; ");

// The version name above each strip (UUIDv4 / UUIDv7).
const versionLabel = (tone: string) =>
  [
    reset,
    mono,
    "font-size: 14px",
    "font-weight: 700",
    "letter-spacing: 0.02em",
    "line-height: 1",
    `color: color-mix(in srgb, ${tone} 72%, var(--sl-color-text))`,
  ].join("; ");

// The byte strip itself — a horizontal bar split into tinted segments. Fixed
// height so both strips align; full width so v4 and v7 are the same length.
const strip = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "width: 100%",
  "height: 52px",
  "border-radius: 10px",
  "overflow: hidden",
].join("; ");

// A segment inside a strip. `flex` carries its share of the 16 bytes; min-width:0
// stops a long label from stealing width from a neighbour (html-css doc).
const segment = (tone: string, grow: number) =>
  [
    reset,
    "box-sizing: border-box",
    `flex: ${grow}`,
    "min-width: 0",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "justify-content: center",
    "row-gap: 3px",
    "padding: 0 8px",
    `background: ${tone}`,
    "color: #ffffff",
    "text-align: center",
  ].join("; ");

// The role word inside a segment ("timestamp (ms)" / "random").
const segLabel = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "line-height: 1.15",
  "color: #ffffff",
].join("; ");

// The byte-count subnote inside a segment (e.g. "6 bytes").
const segBytes = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "line-height: 1",
  "color: rgba(255, 255, 255, 0.82)",
].join("; ");

// The example-values block under a strip.
const examples = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "row-gap: 5px",
].join("; ");

// One example value line — monospace, larger than the labels so it reads as the
// focal point of the figure.
const exampleLine = [
  reset,
  mono,
  "font-size: clamp(15px, 2.6vw, 18px)",
  "font-weight: 600",
  "line-height: 1.25",
  "white-space: nowrap",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The leading hex of an example value — tinted to the strip segment it comes
// from. v4 leads are slate-and-different; v7 leads are violet-and-shared.
const lead = (tone: string) =>
  [
    reset,
    "font-weight: 700",
    `color: color-mix(in srgb, ${tone} 88%, var(--sl-color-text))`,
  ].join("; ");

// The one-line "what this means" note under each example block.
const note = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 500",
  "line-height: 1.4",
  "color: var(--sl-color-gray-3)",
  "margin-top: 3px",
].join("; ");

// The emphasised clause inside a note ("scatter" / "append at the tail").
const noteEm = (tone: string) =>
  [
    reset,
    "font-weight: 700",
    `color: color-mix(in srgb, ${tone} 70%, var(--sl-color-text))`,
  ].join("; ");

// Example values. Each splits into a `pre` (leading hex, tinted) and a `rest`
// (the shared tail, muted). v4 leads are deliberately all-different; v7 leads
// share 0193b5a and differ only in the final nibble.
const v4Examples = ["f47ac10b", "9c3e6d22", "2b6f04a1"];
const v7Examples = ["0193b5a1", "0193b5a2", "0193b5a4"];
// Shared illustrative tail; the version nibble (13th hex char) is 4 for v4 and 7
// for v7 so each truncated value reads as a real UUID of its version.
const v4Rest = "-58cc-4e7a-…";
const v7Rest = "-58cc-7e7a-…";
---

<div class="not-content uuid-byte-layout" style={root}>
  {/* ---- UUIDv4: one flat random strip ------------------------------- */}
  <div style={unit}>
    <span style={versionLabel(SLATE)}>UUIDv4</span>

    <div style={strip}>
      <div style={segment(SLATE, 16)}>
        <span style={segLabel}>random</span>
        <span style={segBytes}>16 bytes</span>
      </div>
    </div>

    <div style={examples}>
      {
        v4Examples.map((pre) => (
          <span style={exampleLine}>
            <span style={lead(SLATE)}>{pre}</span>
            {v4Rest}
          </span>
        ))
      }
      <span style={note}>
        Leading bytes are random → every insert lands at a{" "}
        <span style={noteEm(SLATE)}>random spot</span> → writes{" "}
        <span style={noteEm(SLATE)}>scatter</span> across the whole index.
      </span>
    </div>
  </div>

  {/* ---- UUIDv7: timestamp prefix + random tail ---------------------- */}
  <div style={unit}>
    <span style={versionLabel(VIOLET)}>UUIDv7</span>

    <div style={strip}>
      <div style={segment(VIOLET, 6)}>
        <span style={segLabel}>timestamp (ms)</span>
        <span style={segBytes}>~6 bytes</span>
      </div>
      <div style={segment(GREEN, 10)}>
        <span style={segLabel}>random</span>
        <span style={segBytes}>~10 bytes</span>
      </div>
    </div>

    <div style={examples}>
      {
        v7Examples.map((pre) => (
          <span style={exampleLine}>
            <span style={lead(VIOLET)}>{pre}</span>
            {v7Rest}
          </span>
        ))
      }
      <span style={note}>
        Shared timestamp prefix → new values sort{" "}
        <span style={noteEm(VIOLET)}>after</span> old ones → inserts{" "}
        <span style={noteEm(VIOLET)}>append at the tail</span>.
      </span>
    </div>
  </div>
</div>
