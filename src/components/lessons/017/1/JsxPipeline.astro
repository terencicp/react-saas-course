---
// jsx-pipeline — the core mental model of Chapter 017 Lesson 1, used inside
// <DiagramSequence>. One <button> travels the whole JSX pipeline so the student
// watches the "you write X, the browser gets Y" gap happen across four stages:
//
//   1  You write JSX        <button className="btn" onClick={handleSave}>Save</button>
//   2  The transform        jsx('button', { className: 'btn', onClick: handleSave, … })
//   3  An element descriptor { type: 'button', props: { className, onClick, … } }
//   4  React renders the DOM <button class="btn">Save</button>
//
// Each step carries the SAME example, so the only thing the eye tracks is what
// changes between author-time and the rendered DOM: `className` → `class`, and
// the click handler vanishing from the markup (bound at the React root instead).
//
// A persistent four-chip rail across the top shows which stage is active. The two
// middle stages (transform, descriptor) wear a "hidden" badge — they are the two
// invisible steps where the bugs live, which is the lesson's whole frame.
//
// The example is intentionally KEYLESS: `key` is special-cased by the transform
// (jsx(type, props, key)) and never lives inside `props`, so the descriptor in
// step 3 stays accurate (see the keys-section accuracy note in the outline).
//
// Pure HTML + CSS, matching the chapter's other figures (IndexDrift,
// ConstantTimeCompare): `not-content` wrapper, theme-gray variables for chrome,
// one saturated accent per signal, `margin: 0` reset on every inner element to
// defeat Starlight's prose-margin selector, height-capped, max-width 640.

interface Props {
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Accents. Blue tracks the renamed prop (className → class); pink tracks the
// handler that disappears from the rendered markup.
const RENAME = "#38bdf8"; // sky-400 — className / class
const HANDLER = "#f472b6"; // pink-400 — onClick / the bound handler
const ACTIVE = "#f59e0b"; // amber-500 — the active rail stage

// ---- the rail -----------------------------------------------------------

interface Stage {
  n: 1 | 2 | 3 | 4;
  label: string;
  hidden: boolean; // the two invisible middle stages
}

const stages: Stage[] = [
  { n: 1, label: "You write JSX", hidden: false },
  { n: 2, label: "Transform", hidden: true },
  { n: 3, label: "Descriptor", hidden: true },
  { n: 4, label: "Rendered DOM", hidden: false },
];

// ---- code rendering -----------------------------------------------------

// A code line is a list of typed tokens so we can tint the load-bearing pieces
// (the renamed prop, the vanishing handler) without a full highlighter.
type Tone = "plain" | "punct" | "str" | "rename" | "handler" | "muted";
interface Tok {
  t: string;
  tone?: Tone;
}
type Line = Tok[];

const toneColor: Record<Tone, string> = {
  plain: "var(--sl-color-white)",
  punct: "var(--sl-color-gray-3)",
  str: "var(--sl-color-gray-2)",
  rename: RENAME,
  handler: HANDLER,
  muted: "var(--sl-color-gray-3)",
};

// Per-step code body. Kept short and carried across all four steps.
const bodies: Record<Props["step"], Line[]> = {
  // 1 — authored JSX
  1: [
    [
      { t: "<button ", tone: "punct" },
      { t: "className", tone: "rename" },
      { t: "=", tone: "punct" },
      { t: '"btn"', tone: "str" },
      { t: " ", tone: "punct" },
      { t: "onClick", tone: "handler" },
      { t: "=", tone: "punct" },
      { t: "{", tone: "punct" },
      { t: "handleSave", tone: "handler" },
      { t: "}>", tone: "punct" },
      { t: "Save", tone: "plain" },
      { t: "</button>", tone: "punct" },
    ],
  ],
  // 2 — the jsx() call the transform emits
  2: [
    [
      { t: "jsx(", tone: "punct" },
      { t: "'button'", tone: "str" },
      { t: ", {", tone: "punct" },
    ],
    [
      { t: "  ", tone: "punct" },
      { t: "className", tone: "rename" },
      { t: ": ", tone: "punct" },
      { t: "'btn'", tone: "str" },
      { t: ",", tone: "punct" },
    ],
    [
      { t: "  ", tone: "punct" },
      { t: "onClick", tone: "handler" },
      { t: ": ", tone: "punct" },
      { t: "handleSave", tone: "handler" },
      { t: ",", tone: "punct" },
    ],
    [
      { t: "  children", tone: "plain" },
      { t: ": ", tone: "punct" },
      { t: "'Save'", tone: "str" },
    ],
    [{ t: "})", tone: "punct" }],
  ],
  // 3 — the element descriptor object the call returns (keyless — see header)
  3: [
    [{ t: "{", tone: "punct" }],
    [
      { t: "  type", tone: "plain" },
      { t: ": ", tone: "punct" },
      { t: "'button'", tone: "str" },
      { t: ",", tone: "punct" },
    ],
    [
      { t: "  props", tone: "plain" },
      { t: ": { ", tone: "punct" },
      { t: "className", tone: "rename" },
      { t: ", ", tone: "punct" },
      { t: "onClick", tone: "handler" },
      { t: ", children ", tone: "punct" },
      { t: "}", tone: "punct" },
    ],
    [{ t: "}", tone: "punct" }],
  ],
  // 4 — the rendered DOM the browser shows
  4: [
    [
      { t: "<button ", tone: "punct" },
      { t: "class", tone: "rename" },
      { t: "=", tone: "punct" },
      { t: '"btn"', tone: "str" },
      { t: ">", tone: "punct" },
      { t: "Save", tone: "plain" },
      { t: "</button>", tone: "punct" },
    ],
  ],
};

// Small label that sits on the code frame's title bar per step, telling the
// reader what language/shape they're looking at.
const frameLabel: Record<Props["step"], string> = {
  1: "JSX  ·  Counter.tsx",
  2: "JavaScript  ·  emitted by Turbopack",
  3: "JavaScript  ·  return value",
  4: "HTML  ·  DevTools Elements panel",
};

const body = bodies[step];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 16px",
  "width: 100%",
  "max-width: 640px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// The stage rail — four chips separated by chevrons.
const rail = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "justify-content: center",
  "flex-wrap: nowrap",
  "gap: 4px",
].join("; ");

const chipBase = [
  reset,
  "flex: 1 1 0",
  "min-width: 0",
  "box-sizing: border-box",
  "padding: 7px 6px",
  "border-radius: 9px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 3px",
  "text-align: center",
  "transition: opacity 180ms ease, border-color 180ms ease, background-color 180ms ease",
].join("; ");

const chipInactive = `${chipBase}; border: 1px solid var(--sl-color-gray-5); background: var(--sl-color-gray-6); opacity: 0.6;`;
const chipActive = `${chipBase}; border: 1.5px solid ${ACTIVE}; background: color-mix(in srgb, ${ACTIVE} 16%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, ${ACTIVE} 16%, transparent); opacity: 1;`;

const chipNum = [
  reset,
  mono,
  "font-size: 10px",
  "font-weight: 700",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");
const chipNumActive = `${chipNum}; color: color-mix(in srgb, ${ACTIVE} 70%, var(--sl-color-white));`;

const chipLabel = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.15",
  "color: var(--sl-color-gray-1)",
].join("; ");

const chipBadge = [
  reset,
  sans,
  "font-size: 8.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 2px 5px",
  "border-radius: 999px",
  "border: 1px solid var(--sl-color-gray-4)",
  "color: var(--sl-color-gray-3)",
].join("; ");

const chev = [
  reset,
  "align-self: center",
  "color: var(--sl-color-gray-4)",
  "font-size: 13px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");

// The code frame beneath the rail.
const frame = [
  reset,
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 11px",
  "overflow: hidden",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
].join("; ");

const frameBar = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 7px",
  "padding: 7px 12px",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
].join("; ");

const frameDot = [
  reset,
  "width: 8px",
  "height: 8px",
  "border-radius: 999px",
  "background: var(--sl-color-gray-4)",
  "flex: 0 0 auto",
].join("; ");

const frameTitle = [
  reset,
  mono,
  "font-size: 11px",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");

const codeWrap = [
  reset,
  mono,
  "font-size: 13px",
  "line-height: 1.7",
  "padding: 14px 16px",
  // A fixed min-height so the four steps (1 line vs 5 lines) don't make the
  // frame jump as the reader scrubs; DiagramSequence sizes to the tallest, but
  // matching the code box keeps the rail position rock-steady too.
  "min-height: 150px",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
].join("; ");

// pre-wrap keeps indentation on the multi-line stages while letting the long
// single-line JSX (steps 1 and 4) wrap inside the frame instead of clipping.
const codeLine = `${reset}; white-space: pre-wrap; word-break: break-word; min-height: 1.7em;`;
---

<div class="not-content" style={root}>
  {/* Stage rail — the persistent pipeline; active stage is amber, the two
      invisible middle stages wear a "hidden" badge. */}
  <div style={rail}>
    {
      stages.map((s, i) => (
        <>
          <div style={s.n === step ? chipActive : chipInactive}>
            <span style={s.n === step ? chipNumActive : chipNum}>
              STEP {s.n}
            </span>
            <span style={chipLabel}>{s.label}</span>
            {s.hidden && <span style={chipBadge}>hidden</span>}
          </div>
          {i < stages.length - 1 && (
            <span style={chev} aria-hidden="true">
              ▸
            </span>
          )}
        </>
      ))
    }
  </div>

  {/* The artifact at this stage, framed like an editor / DevTools panel. */}
  <div style={frame}>
    <div style={frameBar}>
      <span style={frameDot} aria-hidden="true"></span>
      <span style={frameTitle}>{frameLabel[step]}</span>
    </div>
    <div style={codeWrap}>
      {
        body.map((line) => (
          <span style={codeLine}>
            {line.map((tok) => (
              <span style={`${reset}; color: ${toneColor[tok.tone ?? "plain"]};`}>
                {tok.t}
              </span>
            ))}
          </span>
        ))
      }
    </div>
  </div>
</div>
