---
// "Who reads this markup?" — the opening frame of Chapter 017 L6.
//
// The lesson's whole spine is one sorting question: every custom attribute is
// markup written for a reader who ISN'T the sighted user, and you pick the tool
// by WHO that reader is. This figure lays the three answers side by side so the
// student carries the sort, not a list of attributes:
//   1. Your scripts        → data-*
//   2. Assistive tech       → aria-*
//   3. The browser engine   → <table> and its parts
//
// Deliberately NOT a boxes-and-arrows / system-graph engine (per the lesson
// outline): this is a classification, three parallel audiences, not a flow.
// A lightweight three-column HTML/CSS panel makes the parallelism the message —
// same shape repeated three times, distinguished only by the audience and its
// accent tint.
//
// Engine: plain HTML + CSS, inline style arrays joined with '; ', mirroring the
// sibling L3/L4 figures (DomVsA11yTree, FreeBehaviorMap). Theme-aware accents
// via color-mix on saturated 600-range hues so each column reads on both light
// and dark themes; a coloured top bar + accent header/token carry the tint while
// the card body stays a neutral panel (pastel fills wash out in dark mode).
// `not-content` drops Starlight prose chrome; `margin: 0` on every inner element
// defeats the prose-margin selector. Columns are flex items that wrap from a row
// to a single stacked column on narrow (~<600px) viewports.
//
// `<Figure>` + caption are supplied by the MDX, not here.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Three distinct accents, each a saturated mid-tone that reads on both themes.
// One per audience; the tint is the only thing that separates the repeated card.
const blue = "#2563eb"; // your scripts     → data-*
const teal = "#0d9488"; // assistive tech    → aria-*
const violet = "#7c3aed"; // the browser engine → <table>

type Column = {
  accent: string;
  header: string;
  reader: string;
  tool: string;
};

const columns: Column[] = [
  {
    accent: blue,
    header: "Your scripts",
    reader: "the JavaScript you wrote, your tests, your analytics",
    tool: "data-*",
  },
  {
    accent: teal,
    header: "Assistive tech",
    reader:
      "screen readers and other tools that read the page aloud or in braille",
    tool: "aria-*",
  },
  {
    accent: violet,
    header: "The browser engine",
    reader: "layout, and the accessibility tree it builds from your tags",
    tool: "<table>",
  },
];

// ── Outer layout ────────────────────────────────────────────────────────────
// A capped, centred row of three columns. flex-wrap lets the three drop to a
// single stacked column on a phone; row-gap keeps wrapped cards from touching.
const wrap = [
  reset,
  sans,
  "box-sizing: border-box",
  "max-width: 760px",
  "margin: 0 auto",
].join("; ");

// The "Who reads this markup?" title, centred above the three columns.
const title = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "text-align: center",
  "font-size: 13px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-2)",
  "margin: 0 0 16px",
].join("; ");

const row = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 14px",
  "row-gap: 14px",
].join("; ");

// ── A single audience column ────────────────────────────────────────────────
// Neutral card body; the accent lives in a top bar, the header text, and the
// tool token. flex: 1 1 200px → side by side on wide viewports, stacks narrow.
const card = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "flex: 1 1 200px",
    "min-width: 0",
    "display: flex",
    "flex-direction: column",
    "overflow: hidden",
    "border-radius: 12px",
    `border: 1.5px solid color-mix(in srgb, ${accent} 38%, var(--sl-color-gray-4))`,
    "background: var(--sl-color-bg)",
  ].join("; ");

// The accent bar pinned to the top edge of each card — the column's colour key.
const accentBar = (accent: string) =>
  [reset, "box-sizing: border-box", "height: 4px", `background: ${accent}`].join(
    "; ",
  );

const cardBody = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "flex: 1",
  "padding: 16px 16px 18px",
].join("; ");

const header = (accent: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: block",
    "font-size: 15px",
    "font-weight: 700",
    "line-height: 1.25",
    `color: color-mix(in srgb, ${accent} 72%, var(--sl-color-text))`,
  ].join("; ");

// The one-line "reader" — who actually consumes the markup. Muted, and it grows
// to fill the card so the three tool tokens align along a common baseline.
const reader = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "flex: 1",
  "font-size: 12.5px",
  "line-height: 1.45",
  "color: var(--sl-color-gray-2)",
  "margin: 6px 0 14px",
].join("; ");

// The tool — large monospace, the thing the student is meant to walk away with.
const tool = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "display: inline-block",
    "align-self: flex-start",
    "padding: 5px 11px",
    "font-size: 17px",
    "font-weight: 700",
    "border-radius: 8px",
    `border: 1.5px solid color-mix(in srgb, ${accent} 45%, transparent)`,
    `background: color-mix(in srgb, ${accent} 12%, transparent)`,
    `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`,
    "white-space: nowrap",
  ].join("; ");

// The third column's tool is "<table> and its parts": the tag in the token, a
// muted "and its parts" trailing it so the token doesn't grow too wide.
const toolSuffix = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "font-size: 11.5px",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
  "margin: 6px 0 0",
].join("; ");
---

<div class="not-content" style={wrap}>
  <span style={title}>Who reads this markup?</span>

  <div style={row}>
    {
      columns.map((col) => (
        <div style={card(col.accent)}>
          <div style={accentBar(col.accent)} />
          <div style={cardBody}>
            <span style={header(col.accent)}>{col.header}</span>
            <span style={reader}>{col.reader}</span>
            <span style={tool(col.accent)}>{col.tool}</span>
            {col.tool === "<table>" && (
              <span style={toolSuffix}>and its parts</span>
            )}
          </div>
        </div>
      ))
    }
  </div>
</div>
