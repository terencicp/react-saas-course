---
// Acme page-outline map — the anchor figure of Chapter 017 L3's
// "landmark elements partition the page" section.
//
// A *mocked page layout* built from real CSS boxes that visually resemble a
// page (a top bar, a content area, a footer band), each region labelled with
// its element name as a fieldset-legend pill straddling the box's top border.
// The takeaway it carries: every UI maps onto a small set of regions, and the
// job is to name each one with the right element.
//
// Layout, top to bottom:
//   <header> (amber)   — full-width top band; inside it <a> (the "Acme" logo)
//                        on the left, <nav> (blue) with the primary links right.
//   <main>   (green)   — large central area; an <h1> line at the top, then two
//                        stacked <section>s, each opened by an <h2> line.
//   <footer> (violet)  — full-width bottom band; a <nav> (blue) sitemap box and
//                        a line of copyright text.
//
// The four landmark accents (amber/blue/green/violet) are the SAME hues the
// DomVsA11yTree figure uses for header/nav/main/footer, so the student binds
// element name → visual region → accessibility-tree landmark across the two
// figures. <section> and the <h1>/<h2> headings are NOT landmarks of their own
// in that figure, so they wear neutral Starlight chrome — the saturated tints
// stay reserved for the landmark types, keeping the colour language honest.
//
// Pure HTML + CSS (nested divs = the real containment hierarchy) so a reader
// can open devtools and see the regions nest. `margin: 0` reset on every inner
// element defeats Starlight's prose-margin selector. Tints are color-mix
// mid-tones that read on both light and dark themes. `<` and `"` are escaped
// only inside JSX text; style attributes are unaffected.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The four landmark accents — identical hues to DomVsA11yTree.
const amber = "#d97706"; // <header>
const blue = "#2563eb"; // <nav>
const green = "#16a34a"; // <main>
const violet = "#7c3aed"; // <footer>

// ── Outer page frame ───────────────────────────────────────────────────────
// A single capped-width column that reads as one page. Stacks header / main /
// footer with a small gap so each band's pill has room to straddle its border.
const wrap = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 16px",
  "max-width: 560px",
  "margin: 0 auto",
].join("; ");

// ── Fieldset-legend pill ───────────────────────────────────────────────────
// A small pill straddling a box's top border. `display: block; width:
// fit-content` + a negative top margin lands the pill's centre on the border
// line; the background matches what paints behind it (the Figure card).
const pill = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "display: block",
    "width: fit-content",
    "padding: 2px 10px",
    "font-size: 12.5px",
    "font-weight: 600",
    "border-radius: 999px",
    "border: 1.5px solid",
    "background: var(--sl-color-bg-sidebar)",
    `border-color: color-mix(in srgb, ${accent} 55%, var(--sl-color-gray-4))`,
    `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`,
  ].join("; ");

// A landmark band/box: soft accent fill + accent border so each region's colour
// reads at a glance and matches DomVsA11yTree. The pill sits centred on the top
// border (negative margin), so the top padding must clear it.
const region = (accent: string) =>
  [
    reset,
    "position: relative",
    "box-sizing: border-box",
    "border-radius: 10px",
    `border: 1.5px solid color-mix(in srgb, ${accent} 50%, transparent)`,
    `background: color-mix(in srgb, ${accent} 9%, transparent)`,
    "padding: 22px 14px 14px",
  ].join("; ");

const regionPill = (accent: string) =>
  [pill(accent), "margin: -33px auto 0"].join("; ");

// The <header> band lays its <a> and <nav> side by side; they wrap on a narrow
// card so neither is clipped.
const headerInner = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "column-gap: 12px",
  "row-gap: 14px",
  "margin-top: 4px",
].join("; ");

// The "Acme" logo box — a small neutral <a> tile on the left of the header.
const logoBox = [
  reset,
  "position: relative",
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "flex: 0 0 auto",
  "min-width: 86px",
  "border-radius: 9px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-bg)",
  "padding: 18px 14px 10px",
].join("; ");

// A neutral element-name pill (for <a>, <section>, <h1>, <h2>) — no landmark
// tint, so the reader reads these as content/structure inside a region, not
// regions of their own. Built explicitly (the generic pill() takes an accent).
const tagPill = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: block",
  "width: fit-content",
  "padding: 2px 10px",
  "font-size: 12.5px",
  "font-weight: 600",
  "border-radius: 999px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-bg-sidebar)",
  "color: var(--sl-color-gray-2)",
].join("; ");

const logoPill = [tagPill, "margin: -29px auto 0"].join("; ");

const logoText = [
  reset,
  sans,
  "font-size: 14px",
  "font-weight: 700",
  "color: var(--sl-color-text)",
].join("; ");

// The <nav> box inside the header — fills the remaining width with the links.
const navBox = (extra = "") =>
  [
    reset,
    "position: relative",
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "flex: 1 1 220px",
    "min-width: 0",
    "border-radius: 9px",
    `border: 1.5px solid color-mix(in srgb, ${blue} 50%, transparent)`,
    `background: color-mix(in srgb, ${blue} 12%, transparent)`,
    "padding: 18px 14px 10px",
    extra,
  ].join("; ");

const navPill = [pill(blue), "margin: -29px auto 0"].join("; ");

const navText = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.4",
  `color: color-mix(in srgb, ${blue} 62%, var(--sl-color-text))`,
].join("; ");

// A heading line (<h1> / <h2>) inside a region — a neutral bar carrying the
// heading text on the left and its tag pill on the right.
const headingLine = (size: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "justify-content: space-between",
    "gap: 10px",
    "border-radius: 8px",
    "border: 1px dashed var(--sl-color-gray-4)",
    "background: var(--sl-color-bg)",
    "padding: 7px 12px",
    `font-size: ${size}`,
  ].join("; ");

const headingText = (weight: string) =>
  [reset, sans, `font-weight: ${weight}`, "color: var(--sl-color-text)"].join(
    "; ",
  );

// The inline tag pill sitting at the right end of a heading line.
const inlineTag = [
  reset,
  mono,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "padding: 1px 8px",
  "font-size: 11.5px",
  "font-weight: 600",
  "border-radius: 999px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-bg-sidebar)",
  "color: var(--sl-color-gray-2)",
].join("; ");

// Stack of the two <section> boxes inside <main>.
const sectionStack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 16px",
  "margin-top: 18px",
].join("; ");

// A <section> box — neutral chrome (it's only a landmark once named, which the
// next section teaches), opened by an <h2> line.
const sectionBox = [
  reset,
  "position: relative",
  "box-sizing: border-box",
  "border-radius: 9px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-bg)",
  "padding: 20px 12px 12px",
].join("; ");

const sectionPill = [tagPill, "margin: -29px auto 0"].join("; ");

// The footer lays its <nav> sitemap box above a copyright line.
const footerInner = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "margin-top: 4px",
].join("; ");

const copyrightText = [
  reset,
  sans,
  "text-align: center",
  "font-size: 11.5px",
  `color: color-mix(in srgb, ${violet} 55%, var(--sl-color-text))`,
].join("; ");
---

<div class="not-content" style={wrap}>
  {/* ── <header> band: <a> logo + <nav> primary navigation ── */}
  <div style={region(amber)}>
    <span style={regionPill(amber)}>{"<header>"}</span>
    <div style={headerInner}>
      <div style={logoBox}>
        <span style={logoPill}>{"<a>"}</span>
        <span style={logoText}>Acme</span>
      </div>
      <div style={navBox()}>
        <span style={navPill}>{"<nav>"}</span>
        <span style={navText}>Dashboard &middot; Invoices &middot; Customers</span>
      </div>
    </div>
  </div>

  {/* ── <main>: <h1> then two <section>s ── */}
  <div style={region(green)}>
    <span style={regionPill(green)}>{"<main>"}</span>
    <div style={headingLine("15px")}>
      <span style={headingText("700")}>Invoices</span>
      <span style={inlineTag}>{"<h1>"}</span>
    </div>
    <div style={sectionStack}>
      <div style={sectionBox}>
        <span style={sectionPill}>{"<section>"}</span>
        <div style={headingLine("13.5px")}>
          <span style={headingText("600")}>Overdue</span>
          <span style={inlineTag}>{"<h2>"}</span>
        </div>
      </div>
      <div style={sectionBox}>
        <span style={sectionPill}>{"<section>"}</span>
        <div style={headingLine("13.5px")}>
          <span style={headingText("600")}>This month</span>
          <span style={inlineTag}>{"<h2>"}</span>
        </div>
      </div>
    </div>
  </div>

  {/* ── <footer> band: <nav> sitemap + copyright ── */}
  <div style={region(violet)}>
    <span style={regionPill(violet)}>{"<footer>"}</span>
    <div style={footerInner}>
      <div style={navBox("flex: 1 1 auto")}>
        <span style={navPill}>{"<nav>"}</span>
        <span style={navText}>Product &middot; Pricing &middot; Docs &middot; Contact</span>
      </div>
      <span style={copyrightText}>&copy; 2026 Acme, Inc.</span>
    </div>
  </div>
</div>
