---
// Heading-outline-tree diagram — the anchor figure of Chapter 017 L3's
// "headings form the page's outline" section.
//
// Two tabs (a TabbedContent — already a figure card, so NOT wrapped in
// <Figure>) contrasting a valid heading outline with a broken one. Each tab is
// an indented tree of rows where INDENTATION encodes heading level: an <h1> sits
// at depth 0, its <h2>s one step in, their <h3>s another step in. Every row
// carries a small level pill (h1/h2/h3) plus the heading text, so depth is
// signalled twice — by indent and by pill — and reads at a glance.
//
//   Tab 1 "Clean outline" (green/calm):
//     h1 Invoices
//       h2 Overdue
//       h2 This month
//         h3 Drafts
//         h3 Sent
//     One h1; levels descend exactly one step at a time. This is the table of
//     contents a screen-reader user navigates.
//
//   Tab 2 "Skipped level (broken)" (red): the same start, but the <h2> that
//     should sit between <h1> and <h3> is MISSING. The hole is drawn explicitly
//     as a dashed "<h2> missing" placeholder row at the h2 depth, and the <h3>
//     that jumped a level is tinted red so the violation is the thing the eye
//     lands on.
//
// Pure HTML + CSS. The colour language matches this lesson's sibling figures
// (DomVsA11yTree, PageOutlineMap): green = the calm/valid accent (the heading
// colour), a saturated red = the error signal. `margin: 0` reset on every inner
// element defeats Starlight's prose-margin selector; the height is bounded by
// the small fixed row count. `<` and `"` are escaped only inside JSX text.

import TabbedContent from "../../../../components/figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../../components/figures/tabbed-content/TabbedItem.astro";

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Two accents, "colour is the signal" saturated mid-tones (read on both themes):
// green = the valid/calm outline (the heading colour, matching <main>), red =
// the broken-level error.
const green = "#16a34a"; // valid outline
const red = "#dc2626"; // skipped level

// One indent step per heading level, drawn as left margin on the row.
const STEP = 30;

// ── Outer tree column ───────────────────────────────────────────────────────
// A single capped-width stack of rows. Each tab owns its own copy.
const tree = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
  "max-width: 440px",
  "margin: 0 auto",
].join("; ");

// A tree row: a level pill + the heading text, indented by its level. `accent`
// tints the pill and (for the broken jump) the whole row; `depth` sets indent.
const row = (depth: number, accent: string, emphatic = false) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "gap: 10px",
    `margin-left: ${depth * STEP}px`,
    "padding: 7px 12px",
    "border-radius: 9px",
    "border: 1.5px solid",
    emphatic
      ? `border-color: color-mix(in srgb, ${accent} 60%, transparent)`
      : `border-color: color-mix(in srgb, ${accent} 42%, transparent)`,
    emphatic
      ? `background: color-mix(in srgb, ${accent} 16%, transparent)`
      : `background: color-mix(in srgb, ${accent} 8%, transparent)`,
  ].join("; ");

// The level pill (h1 / h2 / h3) at the start of each row.
const levelPill = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "flex: 0 0 auto",
    "padding: 1px 9px",
    "font-size: 12px",
    "font-weight: 700",
    "border-radius: 999px",
    "border: 1.5px solid",
    "background: var(--sl-color-bg-sidebar)",
    `border-color: color-mix(in srgb, ${accent} 55%, var(--sl-color-gray-4))`,
    `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`,
  ].join("; ");

const headingText = [
  reset,
  sans,
  "font-size: 14px",
  "font-weight: 600",
  "color: var(--sl-color-text)",
].join("; ");

// The "missing <h2>" placeholder row in the broken tab — a dashed, ghosted gap
// sitting at the h2 depth where a level was skipped.
const gapRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "gap: 10px",
  `margin-left: ${1 * STEP}px`,
  "padding: 7px 12px",
  "border-radius: 9px",
  "border: 1.5px dashed",
  `border-color: color-mix(in srgb, ${red} 55%, var(--sl-color-gray-4))`,
  "background: transparent",
].join("; ");

const gapPill = [
  reset,
  mono,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "padding: 1px 9px",
  "font-size: 12px",
  "font-weight: 700",
  "border-radius: 999px",
  "border: 1.5px dashed",
  `border-color: color-mix(in srgb, ${red} 55%, var(--sl-color-gray-4))`,
  "background: transparent",
  "color: var(--sl-color-gray-3)",
].join("; ");

const gapText = [
  reset,
  sans,
  "font-size: 13px",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
].join("; ");
---

<TabbedContent>
  <TabbedItem
    label="Clean outline"
    caption="A valid outline: one h1, and levels descend one step at a time. This is the table of contents a screen-reader user navigates."
  >
    <div class="not-content" style={tree}>
      <div style={row(0, green)}>
        <span style={levelPill(green)}>h1</span>
        <span style={headingText}>Invoices</span>
      </div>
      <div style={row(1, green)}>
        <span style={levelPill(green)}>h2</span>
        <span style={headingText}>Overdue</span>
      </div>
      <div style={row(1, green)}>
        <span style={levelPill(green)}>h2</span>
        <span style={headingText}>This month</span>
      </div>
      <div style={row(2, green)}>
        <span style={levelPill(green)}>h3</span>
        <span style={headingText}>Drafts</span>
      </div>
      <div style={row(2, green)}>
        <span style={levelPill(green)}>h3</span>
        <span style={headingText}>Sent</span>
      </div>
    </div>
  </TabbedItem>

  <TabbedItem
    label="Skipped level (broken)"
    caption="An h1 → h3 jump with no h2 between. The outline tree has a hole in it — a screen-reader user hears a level go missing and wonders what they skipped. This fails the heading-order audit."
  >
    <div class="not-content" style={tree}>
      <div style={row(0, green)}>
        <span style={levelPill(green)}>h1</span>
        <span style={headingText}>Invoices</span>
      </div>
      <div style={gapRow}>
        <span style={gapPill}>h2</span>
        <span style={gapText}>{"— missing —"}</span>
      </div>
      <div style={row(2, red, true)}>
        <span style={levelPill(red)}>h3</span>
        <span style={headingText}>Drafts</span>
      </div>
    </div>
  </TabbedItem>
</TabbedContent>
