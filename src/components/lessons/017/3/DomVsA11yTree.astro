---
// DOM-vs-accessibility-tree diagram — the anchor figure of Chapter 017 L3's
// "second audience" section.
//
// A side-by-side "two trees" picture. The takeaway it carries:
//   your markup is the API the accessibility tree is built from —
//   semantic elements feed it, <div>s starve it.
//
// LEFT  ("The DOM you wrote"): a nested-box tree of the intro's landmark
//   version. An outer, deliberately-muted `<div className="page">` wrapper
//   contains four semantic boxes, each with its own tint:
//     <header> (amber)  →  with <nav> (blue) nested inside it
//     <main>   (green)
//     <footer> (violet)
//
// RIGHT ("The accessibility tree"): the four regions a screen reader jumps
//   between, each shown as a landmark pill labelled by its ROLE —
//   banner / navigation / main / contentinfo — tinted the SAME colour as its
//   matching DOM element on the left. The eye reads the DOM→a11y correspondence
//   by tint, so no crossing arrows are needed. Crucially the
//   `<div className="page">` wrapper has NO counterpart on the right: it shows
//   up as a greyed, struck-through "(no landmark)" row, making concrete that a
//   plain <div> produces nothing navigable.
//
// Pure HTML + CSS (nested divs = the real containment hierarchy on the left) so
// a reader can open devtools and see the boxes nest. `margin: 0` reset on every
// inner element defeats Starlight's prose-margin selector. Tints are saturated
// 600-range mid-tones via color-mix so they read on both light and dark themes.
// Tag labels on the left are fieldset-legend pills straddling each box's top
// border. `<` and `"` are escaped only inside JSX text; style attributes are
// unaffected.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The four landmark accents — saturated mid-tones that read on both themes.
// Same hue used for a DOM element (left) and its matching landmark (right).
const amber = "#d97706"; // <header>  → banner
const blue = "#2563eb"; // <nav>     → navigation
const green = "#16a34a"; // <main>    → main
const violet = "#7c3aed"; // <footer>  → contentinfo

// ── Outer two-column layout ────────────────────────────────────────────────
// Side-by-side on wide viewports, stacks on narrow ones. Capped width keeps the
// picture compact on a wide-but-short laptop screen.
const wrap = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 18px",
  "row-gap: 24px",
  "max-width: 720px",
  "margin: 0 auto",
  sans,
].join("; ");

const column = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 300px",
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
].join("; ");

const columnTitle = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "text-align: center",
  "font-size: 12px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-2)",
  "margin: 0 0 12px",
].join("; ");

// ── LEFT column: the DOM tree ──────────────────────────────────────────────
// A fieldset-legend pill straddling a box's top border. `display: block;
// width: fit-content` + a negative top margin lands the pill's centre on the
// border line; the background matches what paints behind it.
const pillBase = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "display: block",
    "width: fit-content",
    "padding: 2px 10px",
    "font-size: 12.5px",
    "font-weight: 600",
    "border-radius: 999px",
    "border: 1.5px solid",
    "background: var(--sl-color-bg-sidebar)",
    accent === "neutral"
      ? "border-color: var(--sl-color-gray-4)"
      : `border-color: color-mix(in srgb, ${accent} 55%, var(--sl-color-gray-4))`,
    accent === "neutral"
      ? "color: var(--sl-color-gray-2)"
      : `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`,
  ].join("; ");

// The outer `<div className="page">` wrapper — deliberately muted + dashed so
// it reads as "a styling box, not a landmark". It is the box that vanishes on
// the right.
const pageBox = [
  reset,
  "position: relative",
  "box-sizing: border-box",
  "flex: 1",
  "border: 1.5px dashed var(--sl-color-gray-4)",
  "border-radius: 12px",
  "background: var(--sl-color-bg-sidebar)",
  "padding: 26px 14px 14px",
].join("; ");

const pagePill = [pillBase("neutral"), "margin: -39px auto 0"].join("; ");

// A tinted semantic box. Soft accent fill + accent border so each region's
// colour reads at a glance and matches its landmark on the right.
const semBox = (accent: string) =>
  [
    reset,
    "position: relative",
    "box-sizing: border-box",
    "border-radius: 10px",
    `border: 1.5px solid color-mix(in srgb, ${accent} 50%, transparent)`,
    `background: color-mix(in srgb, ${accent} 9%, transparent)`,
    "padding: 22px 12px 12px",
  ].join("; ");

const semPill = (accent: string) =>
  [pillBase(accent), "margin: -33px auto 0"].join("; ");

// Stack of the semantic boxes inside the page wrapper. The positive top margin
// pushes the first child (and its pill) clear of the page pill above.
const semStack = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 14px",
  "margin-top: 20px",
].join("; ");

// A plain content line inside a semantic box (logo text, heading text, …).
const contentLine = (accent: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: block",
    "text-align: center",
    "font-size: 12px",
    "line-height: 1.4",
    "padding: 4px 6px",
    "margin: 0",
    `color: color-mix(in srgb, ${accent} 60%, var(--sl-color-text))`,
  ].join("; ");

// ── RIGHT column: the accessibility tree ───────────────────────────────────
// A flat vertical list of jumpable landmarks. Each row is a "door" labelled by
// its ROLE, tinted to match its DOM source on the left. The outer wrapper is a
// neutral panel so the rows read as a single navigable list.
const treePanel = [
  reset,
  "box-sizing: border-box",
  "flex: 1",
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "border-radius: 12px",
  "background: var(--sl-color-bg)",
  "padding: 14px",
].join("; ");

// A landmark row — a filled accent "door" carrying its role name + a tiny
// "jump target" hint, so the row reads as something a screen reader lands on.
const landmarkRow = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: baseline",
    "justify-content: space-between",
    "gap: 8px",
    "padding: 9px 12px",
    "border-radius: 9px",
    `border: 1.5px solid color-mix(in srgb, ${accent} 55%, transparent)`,
    `background: color-mix(in srgb, ${accent} 14%, transparent)`,
  ].join("; ");

const roleName = (accent: string) =>
  [
    reset,
    mono,
    "font-size: 13.5px",
    "font-weight: 700",
    `color: color-mix(in srgb, ${accent} 78%, var(--sl-color-text))`,
  ].join("; ");

const roleHint = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

// The dropped `<div>` row — greyed + dashed + struck through, captioned so the
// disappearance is explicit rather than just an absence.
const droppedRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: baseline",
  "justify-content: space-between",
  "gap: 8px",
  "padding: 9px 12px",
  "border-radius: 9px",
  "border: 1.5px dashed var(--sl-color-gray-4)",
  "background: transparent",
].join("; ");

const droppedName = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 600",
  "text-decoration: line-through",
  "color: var(--sl-color-gray-3)",
].join("; ");
---

<div class="not-content" style={wrap}>
  {/* ── LEFT: the DOM you wrote ── */}
  <div style={column}>
    <span style={columnTitle}>The DOM you wrote</span>

    <div style={pageBox}>
      <span style={pagePill}>{'<div className="page">'}</span>

      <div style={semStack}>
        {/* <header> (amber) with <nav> (blue) nested inside */}
        <div style={semBox(amber)}>
          <span style={semPill(amber)}>{"<header>"}</span>
          <span style={contentLine(amber)}>Acme</span>
          <div style={[semBox(blue), "margin-top: 12px"].join("; ")}>
            <span style={semPill(blue)}>{"<nav>"}</span>
            <span style={contentLine(blue)}>Dashboard &middot; Invoices</span>
          </div>
        </div>

        {/* <main> (green) */}
        <div style={semBox(green)}>
          <span style={semPill(green)}>{"<main>"}</span>
          <span style={contentLine(green)}>Invoices</span>
        </div>

        {/* <footer> (violet) */}
        <div style={semBox(violet)}>
          <span style={semPill(violet)}>{"<footer>"}</span>
          <span style={contentLine(violet)}>&copy; 2026 Acme, Inc.</span>
        </div>
      </div>
    </div>
  </div>

  {/* ── RIGHT: the accessibility tree ── */}
  <div style={column}>
    <span style={columnTitle}>The accessibility tree</span>

    <div style={treePanel}>
      <div style={landmarkRow(amber)}>
        <span style={roleName(amber)}>banner</span>
        <span style={roleHint}>jump target</span>
      </div>
      <div style={landmarkRow(blue)}>
        <span style={roleName(blue)}>navigation</span>
        <span style={roleHint}>jump target</span>
      </div>
      <div style={landmarkRow(green)}>
        <span style={roleName(green)}>main</span>
        <span style={roleHint}>jump target</span>
      </div>
      <div style={landmarkRow(violet)}>
        <span style={roleName(violet)}>contentinfo</span>
        <span style={roleHint}>jump target</span>
      </div>
      <div style={droppedRow}>
        <span style={droppedName}>{"<div>"}</span>
        <span style={roleHint}>no landmark &mdash; dropped</span>
      </div>
    </div>
  </div>
</div>
