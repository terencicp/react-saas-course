---
// controls-to-formdata — Chapter 017 Lesson 5, the "what actually lands in the
// contract?" figure, rendered as one panel per tricky control inside a sibling
// <TabbedContent>. Each panel is a compact BEFORE / AFTER:
//
//   left   the rendered control state (a faux checkbox / radio group / listbox)
//   right  the resulting FormData entries — key → "value" rows
//
// The whole point of the figure is the controls where the answer is NON-obvious,
// above all the unchecked checkbox: it contributes NOTHING — no "false", no empty
// value, the key is simply absent. So the unchecked variant renders an explicit
// "not present" row (muted, dashed) instead of an entry, making the absence loud.
//
// Visual language is borrowed wholesale from the sibling FormContractRoundtrip
// figure so the two read as one family: teal (#2dd4bf) tints every `name`/key —
// the contract through-line — while all chrome stays on the theme-gray palette.
// Pure HTML + CSS, `not-content` wrapper, `margin: 0` reset on every inner node
// (defeats Starlight's prose-margin selector), height-capped, max-width 560.
// No <Figure>/<DiagramSequence> wrapper — TabbedContent is its own card.

interface Props {
  variant: "checkbox-checked" | "checkbox-unchecked" | "radio" | "multi-select";
}

const { variant } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The one accent — teal tracks the `name`/key, exactly as in the sibling figure.
const NAME = "#2dd4bf"; // teal-400 — the `name` / FormData-key through-line
const nameTone = `color: ${NAME}; font-weight: 700`;

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "justify-content: center",
  "flex-wrap: wrap",
  "column-gap: 16px",
  "row-gap: 16px",
  "width: 100%",
  "max-width: 560px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// A side card (the control on the left, the FormData on the right).
const card = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 220px",
  "min-width: 200px",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 12px",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "padding: 14px 16px",
  "min-height: 168px",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
].join("; ");

// Small uppercase tag that titles a card ("Control state" / "FormData").
const cardTag = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "line-height: 1",
].join("; ");

// The body of each card, vertically centred so short content sits nicely.
const cardBody = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 10px",
  "flex: 1 1 auto",
].join("; ");

// One control row: glyph + label.
const controlRow = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 9px",
].join("; ");

const controlLabel = [
  reset,
  sans,
  "font-size: 12.5px",
  "color: var(--sl-color-gray-2)",
  "line-height: 1.2",
].join("; ");

// A faux checkbox square.
const boxBase = [
  reset,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "width: 17px",
  "height: 17px",
  "border-radius: 4px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "line-height: 1",
  "font-size: 11px",
  "font-weight: 700",
].join("; ");
const boxChecked = `${boxBase}; border: 1.5px solid ${NAME}; background: color-mix(in srgb, ${NAME} 80%, var(--sl-color-white)); color: var(--sl-color-gray-7, #fff);`;
const boxUnchecked = `${boxBase}; border: 1.5px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6);`;

// A faux radio dot.
const radioBase = [
  reset,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "width: 17px",
  "height: 17px",
  "border-radius: 50%",
  "display: flex",
  "align-items: center",
  "justify-content: center",
].join("; ");
const radioChecked = `${radioBase}; border: 1.5px solid ${NAME};`;
const radioUnchecked = `${radioBase}; border: 1.5px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6);`;
const radioDot = `${reset}; width: 8px; height: 8px; border-radius: 50%; background: ${NAME};`;

// A faux <select multiple> listbox.
const listbox = [
  reset,
  "box-sizing: border-box",
  "border: 1px solid var(--sl-color-gray-4)",
  "border-radius: 7px",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "overflow: hidden",
  "width: 100%",
  "max-width: 168px",
].join("; ");
const optionBase = [
  reset,
  sans,
  "box-sizing: border-box",
  "padding: 5px 9px",
  "font-size: 12px",
  "line-height: 1.3",
].join("; ");
const optionOff = `${optionBase}; color: var(--sl-color-gray-2);`;
const optionOn = `${optionBase}; color: var(--sl-color-white); background: color-mix(in srgb, ${NAME} 78%, var(--sl-color-gray-2)); font-weight: 600;`;

// The name="…" tag pinned under a control group (radio / select), so the student
// sees which key the entries land under — same dashed teal pill as the sibling.
const nameTag = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "align-self: flex-start",
  "border: 1px dashed color-mix(in srgb, " + NAME + " 55%, var(--sl-color-gray-4))",
  "background: color-mix(in srgb, " + NAME + " 12%, transparent)",
  "border-radius: 6px",
  "padding: 3px 7px",
  "font-size: 10.5px",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
].join("; ");

// A FormData entry row: key → "value".
const entryRow = [
  reset,
  "display: grid",
  "grid-template-columns: max-content auto 1fr",
  "align-items: center",
  "column-gap: 9px",
].join("; ");
const codeLine = [
  reset,
  mono,
  "font-size: 12.5px",
  "line-height: 1.5",
  "color: var(--sl-color-gray-2)",
  "white-space: pre",
].join("; ");
const arrowGlyph = [
  reset,
  "color: var(--sl-color-gray-3)",
  "font-size: 14px",
  "line-height: 1",
  "user-select: none",
].join("; ");

// The "no entry at all" row — the load-bearing case (unchecked checkbox).
const absentRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
  "border: 1px dashed var(--sl-color-gray-4)",
  "border-radius: 8px",
  "background: var(--sl-color-gray-6)",
  "padding: 9px 11px",
].join("; ");
const absentKey = [
  reset,
  mono,
  "font-size: 12px",
  "color: var(--sl-color-gray-4)",
  "text-decoration: line-through",
  "text-decoration-color: var(--sl-color-gray-4)",
  "line-height: 1.3",
].join("; ");
const absentNote = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
  "line-height: 1.3",
].join("; ");

// A small footnote under the FormData entries (e.g. "read with getAll").
const note = [
  reset,
  sans,
  "font-size: 10.5px",
  "color: var(--sl-color-gray-3)",
  "line-height: 1.3",
].join("; ");
const noteCode = `${mono}; color: var(--sl-color-gray-2)`;

// The connecting arrow between the two cards (between, on its own track).
const linkArrow = [
  reset,
  "flex: 0 0 auto",
  "align-self: center",
  "color: var(--sl-color-gray-4)",
  "font-size: 20px",
  "line-height: 1",
  "user-select: none",
].join("; ");
---

<div class="not-content" style={root}>
  {/* LEFT — the rendered control state. */}
  <div style={card}>
    <span style={cardTag}>Control state</span>
    <div style={cardBody}>
      {
        variant === "checkbox-checked" && (
          <div style={controlRow}>
            <span style={boxChecked} aria-hidden="true">
              ✓
            </span>
            <span style={controlLabel}>I accept the terms</span>
          </div>
        )
      }

      {
        variant === "checkbox-unchecked" && (
          <div style={controlRow}>
            <span style={boxUnchecked} aria-hidden="true" />
            <span style={controlLabel}>I accept the terms</span>
          </div>
        )
      }

      {
        variant === "radio" && (
          <>
            <div style={controlRow}>
              <span style={radioUnchecked} aria-hidden="true" />
              <span style={controlLabel}>Monthly</span>
            </div>
            <div style={controlRow}>
              <span style={radioChecked} aria-hidden="true">
                <span style={radioDot} />
              </span>
              <span style={controlLabel}>Yearly</span>
            </div>
            <span style={nameTag}>
              name=<span style={nameTone}>"billing"</span>
            </span>
          </>
        )
      }

      {
        variant === "multi-select" && (
          <>
            <div style={listbox}>
              <div style={optionOn}>Seats</div>
              <div style={optionOn}>SSO</div>
              <div style={optionOff}>Audit log</div>
            </div>
            <span style={nameTag}>
              name=<span style={nameTone}>"addons"</span>
            </span>
          </>
        )
      }
    </div>
  </div>

  {/* The before → after link. */}
  <span style={linkArrow} aria-hidden="true">⟶</span>

  {/* RIGHT — the resulting FormData entries. */}
  <div style={card}>
    <span style={cardTag}>FormData</span>
    <div style={cardBody}>
      {
        variant === "checkbox-checked" && (
          <div style={entryRow}>
            <span style={`${codeLine}; ${nameTone}`}>acceptedTerms</span>
            <span style={arrowGlyph}>→</span>
            <span style={codeLine}>"true"</span>
          </div>
        )
      }

      {
        variant === "checkbox-unchecked" && (
          <div style={absentRow}>
            <span style={absentKey}>acceptedTerms</span>
            <span style={absentNote}>no entry — the key is absent</span>
          </div>
        )
      }

      {
        variant === "radio" && (
          <div style={entryRow}>
            <span style={`${codeLine}; ${nameTone}`}>billing</span>
            <span style={arrowGlyph}>→</span>
            <span style={codeLine}>"yearly"</span>
          </div>
        )
      }

      {
        variant === "multi-select" && (
          <div style={`${reset}; display: flex; flex-direction: column; gap: 8px;`}>
            <div style={entryRow}>
              <span style={`${codeLine}; ${nameTone}`}>addons</span>
              <span style={arrowGlyph}>→</span>
              <span style={codeLine}>"seats"</span>
            </div>
            <div style={entryRow}>
              <span style={`${codeLine}; ${nameTone}`}>addons</span>
              <span style={arrowGlyph}>→</span>
              <span style={codeLine}>"sso"</span>
            </div>
            <span style={note}>
              two entries — read with <span style={noteCode}>getAll</span>
            </span>
          </div>
        )
      }
    </div>
  </div>
</div>
