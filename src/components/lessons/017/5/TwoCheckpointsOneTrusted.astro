---
// two-checkpoints-one-trusted — Chapter 017 Lesson 5, the "Native constraints are
// UX, not security" section. Makes the lesson's load-bearing judgment SPATIAL:
// the server's Zod check is the one checkpoint that can't be skipped.
//
// Two lanes, left → right, sharing one emphasized Zod column in the middle:
//
//   Lane 1 (honest user)    User fills form → Browser check → │ Zod │ → Accepted
//   Lane 2 (scripted POST)   Scripted POST   ╌╌over the skip╌╌→ │safe │ → Rejected
//                                            (browser check     │Parse│
//                                             rendered SKIPPED) └─────┘
//
// One CSS grid for the whole stage; every cell is placed explicitly:
//
//   col: 1 tag | 2 origin | 3 → | 4 checkpoint | 5 → | 6 ZOD | 7 → | 8 outcome
//
// The Zod box is a single cell spanning BOTH rows — literally the one box both
// lanes pass through, with a stronger accent border + ring so it reads as "the
// wall". Because its column is reserved by the grid, the lane boxes can never
// drift underneath it, and the two lanes stay column-aligned by construction.
// The honest lane's Browser-check cell is tinted as a passable checkpoint
// (amber). The hostile lane's Browser-check cell is a faded, dashed,
// struck-through "skipped" cell, and the lane's connector is a dashed red line
// (a grid item spanning cols 3–5, ending in an arrowhead) that runs straight
// over the skipped cell into Zod — the bypass made literal, without a diagonal
// leader-line arrow crossing the figure (the ArrowDiagram guide's anti-pattern).
//
// Pure HTML + CSS, matching this lesson's sibling figures (FormContractRoundtrip,
// ControlToFormData): `not-content` wrapper, theme-gray vars for chrome, a small
// saturated palette for meaning, `margin: 0` reset on every element to defeat
// Starlight's prose-margin selector, height-capped, max-width 720. No <Figure>
// wrapper — the lesson wraps this in <Figure>.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Palette — saturated mid-tones that read on both light and dark themes.
const PASS = "#f59e0b"; // amber — the skippable browser checkpoint
const TRUST = "#2563eb"; // blue — the trusted server checkpoint (Zod)
const OK = "#16a34a"; // green — accepted outcome
const BAD = "#dc2626"; // red — scripted lane + rejected outcome

// ---- shared box chrome --------------------------------------------------

// A plain flow box (origin / checkpoint / outcome). `tone` colours its border +
// a faint background wash; a neutral box passes the bg var through. No
// align-self, so boxes stretch to their row's height and stay rectangular peers.
const box = (tone?: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "justify-content: center",
    "gap: 4px",
    "text-align: center",
    "border-radius: 10px",
    "padding: 11px 12px",
    "min-height: 62px",
    tone
      ? `border: 1.5px solid color-mix(in srgb, ${tone} 60%, var(--sl-color-gray-4))`
      : "border: 1px solid var(--sl-color-gray-5)",
    tone
      ? `background: color-mix(in srgb, ${tone} 9%, var(--sl-color-gray-6))`
      : "background: var(--sl-color-gray-6)",
  ].join("; ");

// Primary label inside a box.
const boxLabel = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.2",
  "color: var(--sl-color-gray-1)",
].join("; ");

// Sub-label / detail under a box label (monospace attrs).
const boxSub = [
  reset,
  mono,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

// A small uppercase lane tag pinned to the left of each row.
const laneTag = (tone: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "align-self: center",
    "justify-self: start",
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.05em",
    "text-transform: uppercase",
    "line-height: 1.2",
    "padding: 4px 8px",
    "border-radius: 999px",
    `color: color-mix(in srgb, ${tone} 78%, var(--sl-color-text))`,
    `background: color-mix(in srgb, ${tone} 14%, transparent)`,
    `border: 1px solid color-mix(in srgb, ${tone} 45%, transparent)`,
    "white-space: nowrap",
  ].join("; ");

// A connector glyph between two boxes (a right-pointing arrow), tinted.
const connector = (tone: string) =>
  [
    reset,
    "align-self: center",
    "justify-self: center",
    `color: color-mix(in srgb, ${tone} 70%, var(--sl-color-gray-3))`,
    "font-size: 17px",
    "line-height: 1",
    "user-select: none",
  ].join("; ");

// The browser-check cell on the hostile lane, rendered as SKIPPED: faded,
// dashed border, struck through.
const skippedBox = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 4px",
  "text-align: center",
  "border-radius: 10px",
  "padding: 11px 12px",
  "min-height: 62px",
  "border: 1.5px dashed var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "opacity: 0.5",
].join("; ");

const skippedLabel = [
  boxLabel,
  "text-decoration: line-through",
  "text-decoration-color: var(--sl-color-gray-3)",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The dashed "bypass" connector on the hostile lane — a grid item spanning the
// two arrow gaps and the skipped cell (cols 3–5), vertically centered, ending
// in an arrowhead that points into Zod. It replaces the lane's solid arrows and
// paints OVER the faded skipped cell, so the request visibly travels straight
// past the browser check.
const bypassLine = [
  reset,
  "box-sizing: border-box",
  "grid-column: 3 / 6",
  "grid-row: 2",
  "align-self: center",
  "display: flex",
  "align-items: center",
  "z-index: 2",
  "pointer-events: none",
].join("; ");

const bypassDash = [
  reset,
  "flex: 1 1 auto",
  "height: 0",
  `border-top: 2px dashed ${BAD}`,
].join("; ");

const bypassHead = [
  reset,
  `color: ${BAD}`,
  "font-size: 17px",
  "line-height: 1",
  "margin-left: -4px",
  "user-select: none",
].join("; ");

// A short "skipped" badge straddling the TOP border of the struck-out
// browser-check cell — anchored to that cell's grid column, so it labels the
// skipped checkpoint without covering its text or the bypass line.
const bypassBadge = [
  reset,
  sans,
  "box-sizing: border-box",
  "grid-column: 4",
  "grid-row: 2",
  "justify-self: center",
  "align-self: start",
  "transform: translateY(-50%)",
  "z-index: 3",
  "font-size: 8.5px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 3px 7px",
  "border-radius: 999px",
  "color: color-mix(in srgb, " + BAD + " 82%, var(--sl-color-text))",
  "background: var(--sl-color-bg)",
  "border: 1px solid color-mix(in srgb, " + BAD + " 55%, transparent)",
  "white-space: nowrap",
  "pointer-events: none",
].join("; ");

// The shared Zod checkpoint — one cell spanning both lane rows, the emphasized
// "wall" both lanes converge on. Stronger blue border, ring, faint blue wash.
const zodBox = [
  reset,
  sans,
  "box-sizing: border-box",
  "grid-column: 6",
  "grid-row: 1 / 3",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 6px",
  "text-align: center",
  "border-radius: 12px",
  "padding: 14px 12px",
  `border: 2px solid ${TRUST}`,
  `background: color-mix(in srgb, ${TRUST} 12%, var(--sl-color-gray-6))`,
  `box-shadow: 0 0 0 4px color-mix(in srgb, ${TRUST} 14%, transparent)`,
].join("; ");

const zodTag = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: color-mix(in srgb, " + TRUST + " 72%, var(--sl-color-text))",
].join("; ");

const zodTitle = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-gray-1)",
].join("; ");

const zodCode = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.2",
  "color: color-mix(in srgb, " + TRUST + " 80%, var(--sl-color-text))",
].join("; ");

const zodNote = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 600",
  "line-height: 1.25",
  "color: var(--sl-color-gray-2)",
  "max-width: 132px",
].join("; ");

// Outer container.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 720px",
  "margin-inline: auto",
].join("; ");

// The single stage grid. Fixed widths for the arrow gaps (16px) and the Zod
// column (132px); the origin / checkpoint / outcome columns share the rest with
// minmax(0, …) so they shrink instead of overflowing under Zod. The checkpoint
// column gets a touch more room for its monospace sub-label.
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: auto minmax(0, 1fr) 16px minmax(0, 1.15fr) 16px 132px 16px minmax(0, 1fr)",
  "grid-template-rows: auto auto",
  "column-gap: 7px",
  "row-gap: 18px",
  "align-items: stretch",
].join("; ");

// Inline helper: pin an element to its stage cell.
const at = (col: string, row: string) => `grid-column: ${col}; grid-row: ${row}`;
---

<div class="not-content tcot" style={root}>
  <div class="tcot-stage" style={stage}>
    {/* ---- Lane 1 — honest user: passes THROUGH the browser check. -------- */}
    <span style={`${laneTag(OK)}; ${at("1", "1")}`}>Honest</span>
    <div style={`${box()}; ${at("2", "1")}`}>
      <span style={boxLabel}>User fills form</span>
    </div>
    <span style={`${connector(OK)}; ${at("3", "1")}`} aria-hidden="true">→</span>
    <div style={`${box(PASS)}; ${at("4", "1")}`}>
      <span style={boxLabel}>Browser check</span>
      <span style={boxSub}>required, type</span>
    </div>
    <span style={`${connector(OK)}; ${at("5", "1")}`} aria-hidden="true">→</span>
    <span style={`${connector(OK)}; ${at("7", "1")}`} aria-hidden="true">→</span>
    <div style={`${box(OK)}; ${at("8", "1")}`}>
      <span style={boxLabel}>Accepted</span>
    </div>

    {/* ---- Lane 2 — scripted client: the browser check is SKIPPED, a dashed
        bypass runs over it straight to Zod. ------------------------------- */}
    <span style={`${laneTag(BAD)}; ${at("1", "2")}`}>Scripted</span>
    <div style={`${box(BAD)}; ${at("2", "2")}`}>
      <span style={boxLabel}>Scripted POST</span>
      <span style={boxSub}>curl, script</span>
    </div>
    <div style={`${skippedBox}; ${at("4", "2")}`}>
      <span style={skippedLabel}>Browser check</span>
      <span style={boxSub}>not run</span>
    </div>
    <span class="tcot-bypass-line" style={bypassLine} aria-hidden="true">
      <span style={bypassDash}></span>
      <span style={bypassHead}>→</span>
    </span>
    <span class="tcot-bypass-badge" style={bypassBadge}>skipped</span>
    <span style={`${connector(BAD)}; ${at("7", "2")}`} aria-hidden="true">→</span>
    <div style={`${box(BAD)}; ${at("8", "2")}`}>
      <span style={boxLabel}>Rejected</span>
      <span style={boxSub}>bad data</span>
    </div>

    {/* ---- The shared, trusted Zod checkpoint — spans both lane rows. ----- */}
    <div style={zodBox}>
      <span style={zodTag}>The server</span>
      <span style={zodTitle}>Zod</span>
      <span style={zodCode}>safeParse</span>
      <span style={zodNote}>The one checkpoint neither lane can skip</span>
    </div>
  </div>
</div>

<style>
  /* The shared-Zod box sits between two lanes, so the horizontal eight-column
     geometry is load-bearing and doesn't collapse cleanly to one column. On
     narrow viewports let the figure scroll horizontally at a slimmer minimum
     width, keeping the two-lane / shared-checkpoint shape intact (laptop
     viewports — the design target — show it whole without scrolling). */
  @media (max-width: 640px) {
    .tcot {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .tcot-stage {
      min-width: 600px;
    }
  }
</style>
