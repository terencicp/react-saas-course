---
// two-checkpoints-one-trusted — Chapter 017 Lesson 5, the "Native constraints are
// UX, not security" section. Makes the lesson's load-bearing judgment SPATIAL:
// the server's Zod check is the one checkpoint that can't be skipped.
//
// Two lanes, left → right, sharing one emphasized Zod column in the middle:
//
//   Lane 1 (honest user)    User fills form → Browser check → │ Zod │ → Accepted
//   Lane 2 (scripted POST)   Scripted POST   ╌╌over the skip╌╌→ │safe │ → Rejected
//                                            (browser check     │Parse│
//                                             rendered SKIPPED) └─────┘
//
// The Zod box is one tall cell spanning BOTH rows — literally the single box
// both lanes pass through, with a stronger accent border + ring so it reads as
// "the wall". The honest lane's Browser-check cell is tinted as a passable
// checkpoint (amber). The hostile lane's Browser-check cell is rendered as a
// faded, dashed, struck-through "skipped" cell, and a dashed connector arcs
// straight over it into Zod — the bypass made literal, without a diagonal
// leader-line arrow crossing the figure (the ArrowDiagram guide's anti-pattern).
//
// Pure HTML + CSS, matching this lesson's sibling figures (FormContractRoundtrip,
// ControlToFormData): `not-content` wrapper, theme-gray vars for chrome, a small
// saturated palette for meaning, `margin: 0` reset on every element to defeat
// Starlight's prose-margin selector, height-capped, max-width 720. No <Figure>
// wrapper — the lesson wraps this in <Figure>.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Palette — saturated mid-tones that read on both light and dark themes.
const PASS = "#f59e0b"; // amber — the skippable browser checkpoint
const TRUST = "#2563eb"; // blue — the trusted server checkpoint (Zod)
const OK = "#16a34a"; // green — accepted outcome
const BAD = "#dc2626"; // red — scripted lane + rejected outcome

// ---- shared box chrome --------------------------------------------------

// A plain flow box (origin / outcome). `tone` colours its border + a faint
// background wash; a neutral box passes the bg var through.
const box = (tone?: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "justify-content: center",
    "gap: 4px",
    "text-align: center",
    "border-radius: 10px",
    "padding: 11px 12px",
    "min-height: 62px",
    tone
      ? `border: 1.5px solid color-mix(in srgb, ${tone} 60%, var(--sl-color-gray-4))`
      : "border: 1px solid var(--sl-color-gray-5)",
    tone
      ? `background: color-mix(in srgb, ${tone} 9%, var(--sl-color-gray-6))`
      : "background: var(--sl-color-gray-6)",
  ].join("; ");

// Primary label inside a box.
const boxLabel = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.2",
  "color: var(--sl-color-gray-1)",
].join("; ");

// Sub-label / detail under a box label (monospace attrs).
const boxSub = [
  reset,
  mono,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

// A small uppercase lane tag pinned to the left of each row.
const laneTag = (tone: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "align-self: center",
    "justify-self: start",
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.05em",
    "text-transform: uppercase",
    "line-height: 1.2",
    "padding: 4px 8px",
    "border-radius: 999px",
    `color: color-mix(in srgb, ${tone} 78%, var(--sl-color-text))`,
    `background: color-mix(in srgb, ${tone} 14%, transparent)`,
    `border: 1px solid color-mix(in srgb, ${tone} 45%, transparent)`,
    "white-space: nowrap",
  ].join("; ");

// A connector glyph between two boxes (a right-pointing arrow), tinted.
const connector = (tone: string) =>
  [
    reset,
    "align-self: center",
    "justify-self: center",
    `color: color-mix(in srgb, ${tone} 70%, var(--sl-color-gray-3))`,
    "font-size: 17px",
    "line-height: 1",
    "user-select: none",
  ].join("; ");

// The browser-check cell on the hostile lane, rendered as SKIPPED: faded,
// dashed border, struck through.
const skippedBox = [
  reset,
  sans,
  "box-sizing: border-box",
  "position: relative",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 4px",
  "text-align: center",
  "border-radius: 10px",
  "padding: 11px 12px",
  "min-height: 62px",
  "border: 1.5px dashed var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "opacity: 0.5",
].join("; ");

const skippedLabel = [
  boxLabel,
  "text-decoration: line-through",
  "text-decoration-color: var(--sl-color-gray-3)",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The dashed "bypass" connector — a horizontal dashed line overlaid on the
// hostile lane, running from just past the "Scripted POST" box, across the
// struck-out browser-check cell, to the lane's right edge (on toward Zod). A
// small red badge centered over it names the move. Absolutely positioned
// inside the (relative) hostile lane segment; sits behind the skipped cell's
// own opacity so the line reads as passing over the gap, with the badge on top.
const bypassLine = [
  reset,
  "box-sizing: border-box",
  "position: absolute",
  // Start just past the "Scripted POST" box (col 1 tag + col 2 box ≈ 68% of the
  // segment), run to the lane's right edge — on toward Zod, over the skipped cell.
  "left: 68%",
  "right: 0",
  "top: 50%",
  "transform: translateY(-50%)",
  "border-top: 2px dashed " + BAD,
  "z-index: 2",
  "pointer-events: none",
].join("; ");

// A short "skipped" badge sitting ABOVE the dashed line, centered over the
// struck-out browser-check cell, so it never overlaps the origin box or the
// cell's own "not run" text.
const bypassBadge = [
  reset,
  sans,
  "box-sizing: border-box",
  "position: absolute",
  "left: 88%",
  "top: 50%",
  "transform: translate(-50%, calc(-50% - 13px))",
  "z-index: 3",
  "font-size: 8.5px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 3px 7px",
  "border-radius: 999px",
  "color: color-mix(in srgb, " + BAD + " 82%, var(--sl-color-text))",
  "background: var(--sl-color-bg)",
  "border: 1px solid color-mix(in srgb, " + BAD + " 55%, transparent)",
  "white-space: nowrap",
  "pointer-events: none",
].join("; ");

// The shared Zod checkpoint — one tall box between the two stacks, the
// emphasized "wall" both lanes converge on. Stronger blue border, ring, faint
// blue wash. Stretches to the full stage height via the flex row.
const zodBox = [
  reset,
  sans,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "align-self: stretch",
  "width: 132px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 6px",
  "text-align: center",
  "border-radius: 12px",
  "padding: 14px 12px",
  `border: 2px solid ${TRUST}`,
  `background: color-mix(in srgb, ${TRUST} 12%, var(--sl-color-gray-6))`,
  `box-shadow: 0 0 0 4px color-mix(in srgb, ${TRUST} 14%, transparent)`,
].join("; ");

const zodTag = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: color-mix(in srgb, " + TRUST + " 72%, var(--sl-color-text))",
].join("; ");

const zodTitle = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-gray-1)",
].join("; ");

const zodCode = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.2",
  "color: color-mix(in srgb, " + TRUST + " 80%, var(--sl-color-text))",
].join("; ");

const zodNote = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 600",
  "line-height: 1.25",
  "color: var(--sl-color-gray-2)",
  "max-width: 132px",
].join("; ");

// Outer container.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 720px",
  "margin-inline: auto",
].join("; ");

// Three-part layout that keeps the shared Zod box honestly shared without the
// fragility of a row-spanning grid cell:
//   [ left lanes ]  →  [ Zod box ]  →  [ right outcomes ]
// The left block stacks the two lanes' "origin → checkpoint" steps; the right
// block stacks the two outcomes. The Zod box sits between them, tall, so both
// lanes visibly converge on it. Each lane's arrow INTO Zod and OUT OF Zod is
// rendered in its own block so the eye reads a continuous left-to-right path.
const stageRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "justify-content: center",
  "gap: 8px",
].join("; ");

// A vertical block holding the two lanes' segments (left side) or the two
// outcomes (right side).
const laneStack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 18px",
  "flex: 1 1 0",
  "min-width: 0",
].join("; ");

// One lane segment on the left: tag → origin → arrow → checkpoint → arrow.
const laneSeg = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: auto minmax(96px, 1fr) 16px minmax(108px, 1fr) 16px",
  "align-items: center",
  "gap: 7px",
  "min-height: 62px",
].join("; ");

// The right-side outcome row: arrow leaving Zod → outcome box. (The arrow lives
// in the Zod-adjacent gap so the path reads continuously.)
const outcomeSeg = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 7px",
  "min-height: 62px",
].join("; ");

const outcomeBoxWrap = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 0",
  "min-width: 92px",
].join("; ");
---

<div class="not-content tcot" style={root}>
  <div class="tcot-stage" style={stageRow}>
    {/* ---- LEFT — both lanes' "origin → checkpoint" segments -------------- */}
    <div style={laneStack}>
      {/* Lane 1 — honest user: passes THROUGH the browser check. */}
      <div style={laneSeg}>
        <span style={laneTag(OK)}>Honest</span>
        <div style={box()}>
          <span style={boxLabel}>User fills form</span>
        </div>
        <span style={connector(OK)} aria-hidden="true">→</span>
        <div style={box(PASS)}>
          <span style={boxLabel}>Browser check</span>
          <span style={boxSub}>required, type</span>
        </div>
        <span style={connector(OK)} aria-hidden="true">→</span>
      </div>

      {/* Lane 2 — scripted client: the browser check is SKIPPED, a dashed
          bypass runs over it straight to Zod. */}
      <div style={`${laneSeg}; position: relative;`}>
        <span style={laneTag(BAD)}>Scripted</span>
        <div style={box(BAD)}>
          <span style={boxLabel}>Scripted POST</span>
          <span style={boxSub}>curl, script</span>
        </div>
        <span style={connector(BAD)} aria-hidden="true">→</span>
        <div style={skippedBox}>
          <span style={skippedLabel}>Browser check</span>
          <span style={boxSub}>not run</span>
        </div>
        <span style={connector(BAD)} aria-hidden="true">→</span>

        {/* The dashed bypass + badge, overlaid across the skipped cell and the
            two arrow gaps that flank it, pointing on toward Zod. */}
        <span class="tcot-bypass-line" style={bypassLine} aria-hidden="true"></span>
        <span class="tcot-bypass-badge" style={bypassBadge}>skipped</span>
      </div>
    </div>

    {/* ---- MIDDLE — the shared, trusted Zod checkpoint ------------------- */}
    <div style={zodBox}>
      <span style={zodTag}>The server</span>
      <span style={zodTitle}>Zod</span>
      <span style={zodCode}>safeParse</span>
      <span style={zodNote}>The one checkpoint neither lane can skip</span>
    </div>

    {/* ---- RIGHT — both lanes' outcomes --------------------------------- */}
    <div style={laneStack}>
      <div style={outcomeSeg}>
        <span style={connector(OK)} aria-hidden="true">→</span>
        <div style={outcomeBoxWrap}>
          <div style={box(OK)}>
            <span style={boxLabel}>Accepted</span>
          </div>
        </div>
      </div>
      <div style={outcomeSeg}>
        <span style={connector(BAD)} aria-hidden="true">→</span>
        <div style={outcomeBoxWrap}>
          <div style={box(BAD)}>
            <span style={boxLabel}>Rejected</span>
            <span style={boxSub}>bad data</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* The shared-Zod box sits between two stacks, so the horizontal three-part
     geometry is load-bearing and doesn't collapse cleanly to one column. On
     narrow viewports let the figure scroll horizontally at a slimmer minimum
     width, keeping the two-lane / shared-checkpoint shape intact (laptop
     viewports — the design target — show it whole without scrolling). */
  @media (max-width: 640px) {
    .tcot {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .tcot-stage {
      min-width: 600px;
    }
  }
</style>
