---
// form-contract-roundtrip — the conceptual spine of Chapter 017 Lesson 5, used
// inside <DiagramSequence>. The Acme sign-up form's two fields (email, password)
// travel the full round-trip so the student watches the `name` strings stay the
// SAME vocabulary from markup all the way to the validated object:
//
//   1  Labeled form        each <input> tagged with its name="…"
//   2  FormData            those same names become key/value entries
//   3  The wire            the FormData packet crosses browser → server
//   4  Zod + typed object  a z.object whose keys are the same strings, emitting
//                          { email: string, password: string }
//
// The load-bearing device is colour: the `name` strings (`email`, `password`)
// are tinted ACCENT in every step, so the eye tracks them across the journey —
// the contract made literal. Everything else (chrome, values, prose) stays in
// the neutral theme-gray palette so only the contract pops.
//
// A persistent four-chip rail across the top shows which stage is active, the
// same pattern as the sibling JsxPipeline figure (L1). Steps 2 and 4 are kept
// deliberately schematic (a key/value list; a single z.object glance) so the
// diagram doesn't drift into the later FormData-wiring / Zod-authoring chapters.
//
// Pure HTML + CSS, matching the chapter's other figures: `not-content` wrapper,
// theme-gray variables for chrome, one saturated accent for the contract,
// `margin: 0` reset on every inner element to defeat Starlight's prose-margin
// selector, height-capped, max-width 640. No <Figure> wrapper — DiagramSequence
// is its own card.

interface Props {
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The one accent. Teal tracks the `name` strings — the shared vocabulary that
// runs from the markup to the validated object. It appears, and only appears,
// on `email` / `password` wherever they show up as the contract key.
const NAME = "#2dd4bf"; // teal-400 — the `name` / schema-key through-line
const ACTIVE = "#f59e0b"; // amber-500 — the active rail stage (matches L1)

// A reusable teal pill for a `name="…"` tag / key chip.
const nameTone = `color: ${NAME}; font-weight: 700`;

// ---- the rail -----------------------------------------------------------

interface Stage {
  n: 1 | 2 | 3 | 4;
  label: string;
}

const stages: Stage[] = [
  { n: 1, label: "Labeled form" },
  { n: 2, label: "FormData" },
  { n: 3, label: "The wire" },
  { n: 4, label: "Zod → typed object" },
];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 16px",
  "width: 100%",
  "max-width: 640px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// The stage rail — four chips separated by chevrons.
const rail = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "justify-content: center",
  "flex-wrap: nowrap",
  "gap: 4px",
].join("; ");

const chipBase = [
  reset,
  "flex: 1 1 0",
  "min-width: 0",
  "box-sizing: border-box",
  "padding: 7px 6px",
  "border-radius: 9px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 3px",
  "text-align: center",
  "transition: opacity 180ms ease, border-color 180ms ease, background-color 180ms ease",
].join("; ");

const chipInactive = `${chipBase}; border: 1px solid var(--sl-color-gray-5); background: var(--sl-color-gray-6); opacity: 0.6;`;
const chipActive = `${chipBase}; border: 1.5px solid ${ACTIVE}; background: color-mix(in srgb, ${ACTIVE} 16%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, ${ACTIVE} 16%, transparent); opacity: 1;`;

const chipNum = [
  reset,
  mono,
  "font-size: 10px",
  "font-weight: 700",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");
const chipNumActive = `${chipNum}; color: color-mix(in srgb, ${ACTIVE} 70%, var(--sl-color-white));`;

const chipLabel = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.15",
  "color: var(--sl-color-gray-1)",
].join("; ");

const chev = [
  reset,
  "align-self: center",
  "color: var(--sl-color-gray-4)",
  "font-size: 13px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");

// The stage panel beneath the rail — a framed surface that holds each step's
// body. A fixed min-height keeps the rail rock-steady as the reader scrubs
// across steps of different heights (DiagramSequence sizes to the tallest).
const stage = [
  reset,
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 12px",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "padding: 20px 18px",
  "min-height: 196px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "box-sizing: border-box",
].join("; ");

// A panel "card" used for the form, the FormData list, the Zod box, etc.
const panel = [
  reset,
  "box-sizing: border-box",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 10px",
  "background: var(--sl-color-gray-6)",
  "padding: 12px 14px",
].join("; ");

// Small uppercase tag that titles a panel (e.g. "FormData", "Zod schema").
const panelTag = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "line-height: 1",
].join("; ");

const labelTxt = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "color: var(--sl-color-gray-2)",
  "line-height: 1",
].join("; ");

// A faux input box.
const inputBox = [
  reset,
  mono,
  "box-sizing: border-box",
  "border: 1px solid var(--sl-color-gray-4)",
  "border-radius: 7px",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "padding: 7px 9px",
  "font-size: 12px",
  "color: var(--sl-color-gray-2)",
  "min-width: 168px",
].join("; ");

// The little name="…" tag pinned to an input.
const nameTag = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "border: 1px dashed color-mix(in srgb, " + NAME + " 55%, var(--sl-color-gray-4))",
  "background: color-mix(in srgb, " + NAME + " 12%, transparent)",
  "border-radius: 6px",
  "padding: 3px 7px",
  "font-size: 10.5px",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
].join("; ");

const arrowGlyph = [
  reset,
  "color: var(--sl-color-gray-3)",
  "font-size: 18px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");

// A glyph tile for browser / server in step 3.
const glyphTile = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 6px",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 10px",
  "background: var(--sl-color-gray-6)",
  "padding: 12px 14px",
  "min-width: 96px",
].join("; ");

const glyphIcon = [
  reset,
  "font-size: 22px",
  "line-height: 1",
].join("; ");

const glyphLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "color: var(--sl-color-gray-2)",
  "line-height: 1",
].join("; ");

// The FormData packet that rides the wire (step 3) — a compact key/value chip.
const packet = [
  reset,
  mono,
  "box-sizing: border-box",
  "border: 1px solid color-mix(in srgb, " + NAME + " 45%, var(--sl-color-gray-4))",
  "border-radius: 8px",
  "background: color-mix(in srgb, " + NAME + " 8%, var(--sl-color-gray-7, var(--sl-color-gray-6)))",
  "padding: 8px 10px",
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
  "font-size: 10.5px",
  "color: var(--sl-color-gray-2)",
  "box-shadow: 0 6px 18px -10px color-mix(in srgb, " + NAME + " 60%, transparent)",
].join("; ");

const codeLine = [
  reset,
  mono,
  "font-size: 12.5px",
  "line-height: 1.6",
  "color: var(--sl-color-gray-2)",
  "white-space: pre",
].join("; ");
---

<div class="not-content" style={root}>
  {/* Stage rail — the persistent round-trip; active stage is amber. */}
  <div style={rail}>
    {
      stages.map((s, i) => (
        <>
          <div style={s.n === step ? chipActive : chipInactive}>
            <span style={s.n === step ? chipNumActive : chipNum}>STEP {s.n}</span>
            <span style={chipLabel}>{s.label}</span>
          </div>
          {i < stages.length - 1 && (
            <span style={chev} aria-hidden="true">
              ▸
            </span>
          )}
        </>
      ))
    }
  </div>

  <div style={stage}>
    {/* STEP 1 — the labeled form, each input tagged with its name="…". */}
    {
      step === 1 && (
        <div style={`${panel}; display: flex; flex-direction: column; gap: 14px; min-width: 0;`}>
          <span style={panelTag}>Acme sign-up form</span>
          <div style={`${reset}; display: flex; flex-direction: column; gap: 5px;`}>
            <span style={labelTxt}>Email</span>
            <div style={`${reset}; display: flex; align-items: center; gap: 9px; flex-wrap: wrap;`}>
              <span style={inputBox}>ada@acme.com</span>
              <span style={nameTag}>
                name=<span style={nameTone}>"email"</span>
              </span>
            </div>
          </div>
          <div style={`${reset}; display: flex; flex-direction: column; gap: 5px;`}>
            <span style={labelTxt}>Password</span>
            <div style={`${reset}; display: flex; align-items: center; gap: 9px; flex-wrap: wrap;`}>
              <span style={inputBox}>••••••••</span>
              <span style={nameTag}>
                name=<span style={nameTone}>"password"</span>
              </span>
            </div>
          </div>
        </div>
      )
    }

    {/* STEP 2 — those same names become FormData entries. */}
    {
      step === 2 && (
        <div style={`${panel}; display: flex; flex-direction: column; gap: 11px; min-width: 280px;`}>
          <span style={panelTag}>FormData</span>
          <div style={`${reset}; display: flex; flex-direction: column; gap: 8px;`}>
            <div style={`${reset}; display: grid; grid-template-columns: max-content auto 1fr; align-items: center; gap: 9px;`}>
              <span style={`${codeLine}; ${nameTone}`}>email</span>
              <span style={arrowGlyph}>→</span>
              <span style={codeLine}>"ada@acme.com"</span>
            </div>
            <div style={`${reset}; display: grid; grid-template-columns: max-content auto 1fr; align-items: center; gap: 9px;`}>
              <span style={`${codeLine}; ${nameTone}`}>password</span>
              <span style={arrowGlyph}>→</span>
              <span style={codeLine}>"••••••••"</span>
            </div>
          </div>
        </div>
      )
    }

    {/* STEP 3 — the FormData packet crosses the wire, browser → server. */}
    {
      step === 3 && (
        <div style={`${reset}; display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap;`}>
          <div style={glyphTile}>
            <span style={glyphIcon} aria-hidden="true">
              🖥
            </span>
            <span style={glyphLabel}>Browser</span>
          </div>
          <span style={arrowGlyph} aria-hidden="true">
            ⟶
          </span>
          <div style={packet}>
            <span>
              <span style={nameTone}>email</span> → "ada@acme.com"
            </span>
            <span>
              <span style={nameTone}>password</span> → "••••••••"
            </span>
          </div>
          <span style={arrowGlyph} aria-hidden="true">
            ⟶
          </span>
          <div style={glyphTile}>
            <span style={glyphIcon} aria-hidden="true">
              🗄
            </span>
            <span style={glyphLabel}>Server</span>
          </div>
        </div>
      )
    }

    {/* STEP 4 — a Zod schema whose keys are the same strings, emitting a
        typed object. Kept deliberately schematic — one glance, not authored. */}
    {
      step === 4 && (
        <div style={`${reset}; display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap;`}>
          <div style={`${panel}; display: flex; flex-direction: column; gap: 9px;`}>
            <span style={panelTag}>Zod schema</span>
            <div style={`${reset}; display: flex; flex-direction: column;`}>
              <span style={codeLine}>z.object({"{"}</span>
              <span style={codeLine}>
                {"  "}
                <span style={nameTone}>email</span>: z.email(),
              </span>
              <span style={codeLine}>
                {"  "}
                <span style={nameTone}>password</span>: z.string(),
              </span>
              <span style={codeLine}>{"}"})</span>
            </div>
          </div>
          <span style={arrowGlyph} aria-hidden="true">
            ⟶
          </span>
          <div style={`${panel}; display: flex; flex-direction: column; gap: 9px;`}>
            <span style={panelTag}>Typed object</span>
            <div style={`${reset}; display: flex; flex-direction: column;`}>
              <span style={codeLine}>{"{"}</span>
              <span style={codeLine}>
                {"  "}
                <span style={nameTone}>email</span>: string,
              </span>
              <span style={codeLine}>
                {"  "}
                <span style={nameTone}>password</span>: string,
              </span>
              <span style={codeLine}>{"}"}</span>
            </div>
          </div>
        </div>
      )
    }
  </div>
</div>
