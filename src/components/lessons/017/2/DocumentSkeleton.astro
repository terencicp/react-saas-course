---
// Document-skeleton diagram — the anchor figure of Chapter 017 L2.
//
// A static, labelled picture of the universal HTML document shell that the rest
// of the lesson refers back to ("the layout owns this box, metadata owns that
// box"). Top to bottom:
//   - A thin DASHED, muted pill: `<!DOCTYPE html>`, set apart as "not an element
//     — a parser instruction" so the student never mistakes it for a tag.
//   - A large outer box labelled `<html lang="en">` (the root element), holding
//     two stacked child boxes:
//       - `<head>` (BLUE tint) — "metadata, not rendered on the page" — with
//         three example child rows: <meta charset>, <title>, <link rel=icon>.
//       - `<body>` (GREEN tint) — "everything visible" — with one highlighted
//         row: "your React tree mounts here".
//   The two boxes carry distinct tints so later prose can say "the blue part" /
//   "the green part".
//
// Pure HTML + CSS (nested divs = the real containment hierarchy) so a reader can
// open devtools and see the boxes nest the way <head>/<body> nest inside <html>.
// `margin: 0` reset on every inner element defeats Starlight's prose-margin
// selector. Box tints use blue-600 / green-600 mid-tones via color-mix so they
// read on both light and dark themes. Tag labels are fieldset-legend pills
// straddling each box's top border, in monospace, with REAL tag text. `<` and
// `"` are escaped only inside JSX text; style attributes are unaffected.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The two box accents — saturated mid-tones that read on both themes.
const blue = "#2563eb"; // <head>
const green = "#16a34a"; // <body>

// Outer wrapper: centered, capped so the picture stays compact on a
// wide-but-short laptop viewport.
const wrap = [
  reset,
  "box-sizing: border-box",
  "max-width: 520px",
  "margin: 0 auto",
  sans,
].join("; ");

// The DOCTYPE pill — dashed + muted, deliberately NOT styled like the element
// boxes below it.
const doctype = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: block",
  "width: fit-content",
  "margin: 0 auto 4px",
  "padding: 4px 12px",
  "font-size: 13px",
  "font-weight: 600",
  "border: 1.5px dashed var(--sl-color-gray-4)",
  "border-radius: 8px",
  "background: var(--sl-color-bg-sidebar)",
  "color: var(--sl-color-gray-2)",
].join("; ");

const doctypeNote = [
  reset,
  sans,
  "display: block",
  "width: fit-content",
  "margin: 0 auto 16px",
  "font-size: 11px",
  "font-style: italic",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The root <html> box — neutral chrome; it's the container, not a tint.
const htmlBox = [
  reset,
  "position: relative",
  "box-sizing: border-box",
  "border: 1.5px solid var(--sl-color-gray-3)",
  "border-radius: 12px",
  "background: var(--sl-color-bg-sidebar)",
  "padding: 28px 16px 16px",
].join("; ");

// A tag-name pill straddling a box's top border (fieldset-legend technique).
// `display: block; width: fit-content` + negative margin lands the pill's
// centre on the border line; the background must match what paints behind it.
const pillBase = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "display: block",
    "width: fit-content",
    "padding: 3px 12px",
    "font-size: 13px",
    "font-weight: 600",
    "border-radius: 999px",
    "border: 1.5px solid",
    accent === "neutral"
      ? "border-color: var(--sl-color-gray-3)"
      : `border-color: color-mix(in srgb, ${accent} 55%, var(--sl-color-gray-4))`,
    accent === "neutral"
      ? "color: var(--sl-color-text)"
      : `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`,
  ].join("; ");

// Root <html> pill — sits centred on the outer box's top border.
const htmlPill = [pillBase("neutral"), "margin: -42px auto 0"].join("; ");

// A tinted child box (<head> / <body>). Soft accent fill + accent border so the
// "blue part" / "green part" reads at a glance.
const childBox = (accent: string) =>
  [
    reset,
    "position: relative",
    "box-sizing: border-box",
    "border-radius: 10px",
    `border: 1.5px solid color-mix(in srgb, ${accent} 45%, transparent)`,
    `background: color-mix(in srgb, ${accent} 9%, transparent)`,
    "padding: 24px 14px 14px",
  ].join("; ");

// Child pill — sits centred on the child box's top border, tinted to match.
// The positive top margin pushes this box (and so its pill) clear of the
// <html> pill above so the two never collide.
const childPill = (accent: string) =>
  [pillBase(accent), "margin: -36px auto 9px"].join("; ");

const subCaption = [
  reset,
  sans,
  "display: block",
  "text-align: center",
  "font-size: 11px",
  "font-style: italic",
  "line-height: 1.3",
  "margin: 0 0 11px",
  "color: var(--sl-color-gray-3)",
].join("; ");

// An inner row listing one example child tag inside <head>.
const metaRow = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "display: block",
    "text-align: center",
    "font-size: 12.5px",
    "line-height: 1.5",
    "padding: 5px 8px",
    "margin: 0",
    "border-radius: 6px",
    `border: 1px solid color-mix(in srgb, ${accent} 30%, transparent)`,
    "background: var(--sl-color-bg)",
    `color: color-mix(in srgb, ${accent} 70%, var(--sl-color-text))`,
  ].join("; ");

const metaStack = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 6px",
].join("; ");

// The single highlighted row inside <body> — this is where the React tree
// mounts, so it gets a filled accent and bolder weight.
const mountRow = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "text-align: center",
  "font-size: 13px",
  "font-weight: 600",
  "line-height: 1.4",
  "padding: 11px 10px",
  "border-radius: 7px",
  `border: 1.5px solid color-mix(in srgb, ${green} 55%, transparent)`,
  `background: color-mix(in srgb, ${green} 16%, transparent)`,
  `color: color-mix(in srgb, ${green} 78%, var(--sl-color-text))`,
].join("; ");

// Gap between the <head> and <body> child boxes. The positive top margin
// pushes the first child box (and so its pill) clear of the <html> pill above —
// the child pill's own -36px margin-top would otherwise pull it up under the
// <html> pill and the two would collide.
const childGap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "margin-top: 22px",
].join("; ");
---

<div class="not-content" style={wrap}>
  {/* DOCTYPE — a parser instruction, set apart from the element boxes */}
  <span style={doctype}>{"<!DOCTYPE html>"}</span>
  <span style={doctypeNote}>not an element &mdash; a parser instruction</span>

  {/* The root element box */}
  <div style={htmlBox}>
    <span style={htmlPill}>{'<html lang="en">'}</span>

    <div style={childGap}>
      {/* <head> — blue: metadata machines read */}
      <div style={childBox(blue)}>
        <span style={childPill(blue)}>{"<head>"}</span>
        <span style={subCaption}>metadata &mdash; not rendered on the page</span>
        <div style={metaStack}>
          <span style={metaRow(blue)}>{'<meta charset="utf-8">'}</span>
          <span style={metaRow(blue)}>{"<title>Acme</title>"}</span>
          <span style={metaRow(blue)}>{'<link rel="icon">'}</span>
        </div>
      </div>

      {/* <body> — green: everything visible */}
      <div style={childBox(green)}>
        <span style={childPill(green)}>{"<body>"}</span>
        <span style={subCaption}>everything visible</span>
        <span style={mountRow}>your React tree mounts here</span>
      </div>
    </div>
  </div>
</div>
