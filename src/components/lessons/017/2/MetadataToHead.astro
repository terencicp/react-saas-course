---
// Metadata-object → rendered <head> mapping — Chapter 017 L2, "metadata API
// writes the head" section.
//
// Two code-styled panels side by side:
//   - LEFT  "What you export"        — the three fields of the metadata object.
//   - RIGHT "What Next.js renders into <head>" — the three <head> tags Next.js
//     emits from those fields.
//
// The relationship is pure correspondence ("this field IS that tag"), three
// parallel pairs sharing one gap — the textbook "use tints, not three crossing
// curves" case from the ArrowDiagram guide. So instead of arrows, each matching
// field/tag pair carries the SAME background tint plus a 1px inset ring, and
// identity alone carries the mapping. The three accents reuse the lesson's
// established palette (blue/green for <head>/<body> in DocumentSkeleton) plus
// orange for the third pair.
//
// Pure HTML + CSS. `margin: 0` reset on every element defeats Starlight's
// prose-margin selector. Tints use color-mix mid-tones so they read on both
// themes. Real tag text — `<`, `>`, `"` are escaped only inside JSX text; style
// attributes are unaffected.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Pair accents — saturated mid-tones that read on both themes.
const blue = "#2563eb"; // title
const green = "#16a34a"; // description
const orange = "#ea580c"; // icons / favicon

// Outer grid: two columns with a gap wide enough to read as a separation
// between "what you write" and "what the framework emits". Collapses to a
// single stacked column on narrow viewports.
const flow = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: 1fr 1fr",
  "gap: 28px",
  "align-items: start",
  "max-width: 760px",
  "margin: 0 auto",
  sans,
].join("; ");

// One code panel (a faux editor surface). Both panels share this chrome.
const panel = [
  reset,
  "box-sizing: border-box",
  "border: 1px solid var(--sl-color-gray-4)",
  "border-radius: 10px",
  "background: var(--sl-color-bg)",
  "overflow: hidden",
].join("; ");

// Panel title strip — sits above the code, muted, sans-serif.
const panelTitle = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "padding: 8px 12px",
  "font-size: 12px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
  "background: var(--sl-color-bg-sidebar)",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
].join("; ");

// The code body inside a panel.
const codeBody = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 6px",
  "padding: 12px",
].join("; ");

// A single code line. Tinted by its pair accent; a 1px inset ring sharpens the
// match between the two panels. `white-space: pre-wrap` keeps long lines
// readable when a panel is narrow without an overflow scrollbar.
const line = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "display: block",
    "padding: 6px 9px",
    "font-size: 13px",
    "line-height: 1.5",
    "border-radius: 6px",
    "white-space: pre-wrap",
    "word-break: break-word",
    `background: color-mix(in srgb, ${accent} 15%, transparent)`,
    `box-shadow: inset 0 0 0 1px color-mix(in srgb, ${accent} 45%, transparent)`,
    `color: color-mix(in srgb, ${accent} 78%, var(--sl-color-text))`,
  ].join("; ");

// The non-tinted scaffolding lines around the object (the `export const …` head
// and the closing brace) — neutral so the eye lands on the three tinted fields.
const scaffold = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: block",
  "padding: 0 9px",
  "font-size: 13px",
  "line-height: 1.5",
  "white-space: pre-wrap",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The non-tinted <head> wrapper lines on the right panel.
const headTag = [scaffold, "font-weight: 600"].join("; ");
---

<div class="not-content meta-head-flow" style={flow}>
  {/* LEFT — the object you export */}
  <div style={panel}>
    <span style={panelTitle}>What you export</span>
    <div style={codeBody}>
      <span style={scaffold}>{"export const metadata = {"}</span>
      <span style={line(blue)}>{"  title: 'Acme',"}</span>
      <span style={line(green)}>{"  description: 'Invoicing for small teams.',"}</span>
      <span style={line(orange)}>{"  icons: { icon: '/favicon.ico' },"}</span>
      <span style={scaffold}>{"};"}</span>
    </div>
  </div>

  {/* RIGHT — the tags Next.js renders */}
  <div style={panel}>
    <span style={panelTitle}>{"What Next.js renders into <head>"}</span>
    <div style={codeBody}>
      <span style={headTag}>{"<head>"}</span>
      <span style={line(blue)}>{"  <title>Acme</title>"}</span>
      <span style={line(green)}
        >{'  <meta name="description" content="Invoicing for small teams." />'}</span
      >
      <span style={line(orange)}>{'  <link rel="icon" href="/favicon.ico" />'}</span>
      <span style={headTag}>{"</head>"}</span>
    </div>
  </div>
</div>

<style>
  /* Stack the two panels on narrow viewports — side-by-side code panels get
     cramped below ~640px. The color-match still carries the mapping when
     stacked (top pair → top pair), so no arrows to misroute. */
  @media (max-width: 640px) {
    .meta-head-flow {
      grid-template-columns: 1fr !important;
    }
  }
</style>
