---
// "Free behavior" map — Chapter 017 L4's "What <div role=button> really costs"
// section. One <button> box on the left; the five behaviors the browser hands
// a real <button> for nothing on the right, one arrow per behavior, each
// labelled "free". The visual weight of five arrows fanning out of one bare tag
// IS the argument: choose a <div> instead and every one of these becomes code
// you own.
//
// Engine: <ArrowDiagram> (leader-line). The nodes are real styled HTML (a
// monospace tag tile + behavior cards), so this is an ArrowDiagram fit rather
// than D2/Mermaid. Cross-region layout: button on the left (socket 'right'),
// cards stacked on the right (socket 'left'), a wide grid gap so the five
// curves + their "free" labels live in the column gap, never crossing a card.
//
// All five arrows share one meaning ("free"), so they share one colour (the
// chapter's "correct choice" green). The five curves are separated into lanes
// by staggering startSocketGravity X (outer arrows pull hard, the middle one
// barely) and the labels are spread by labelOffset Y so the five "free" badges
// don't pile up at the gap midline.
//
// Must live inside <Figure expandable={false}> — leader-line positions its
// arrows from document.body, so relocating the figure into the expand lightbox
// breaks them.
//
// Styling mirrors PageOutlineMap.astro (sibling L3 figure): inline style arrays
// joined with ';', theme-aware color-mix mid-tones, `not-content` to drop
// Starlight prose chrome, `margin: 0` reset to defeat the prose-margin selector.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// One hue for everything: the "right choice / free win" green, the same green
// the lesson's CodeVariants use to mark the semantic element.
const green = "#16a34a";

// Two-column grid: the <button> tile on the left, the five behavior cards
// stacked on the right. A generous gap reserves room for five curves and their
// "free" labels; the curves and badges all live inside this gap.
const grid = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: minmax(120px, 168px) 130px minmax(190px, 1fr)",
  "align-items: center",
  "max-width: 620px",
  "margin: 0 auto",
].join("; ");

// The bare <button> tile — the whole subject of the figure. A solid green
// border + soft fill makes it read as the one correct element; the column it
// sits in spans the full height so its right-socket midpoint is centred against
// the card stack.
const buttonCell = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
].join("; ");

const buttonTile = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "padding: 16px 18px",
  "font-size: 16px",
  "font-weight: 700",
  "border-radius: 12px",
  "border: 2px solid",
  `border-color: color-mix(in srgb, ${green} 60%, var(--sl-color-gray-4))`,
  `background: color-mix(in srgb, ${green} 12%, transparent)`,
  `color: color-mix(in srgb, ${green} 78%, var(--sl-color-text))`,
].join("; ");

// The right-hand stack of behavior cards. A small, even gap; each card is the
// landing zone for one arrow, so their differing Y positions keep the five
// arrowheads from stacking.
const cardStack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
].join("; ");

const card = [
  reset,
  "box-sizing: border-box",
  "border-radius: 9px",
  `border: 1.5px solid color-mix(in srgb, ${green} 40%, var(--sl-color-gray-4))`,
  `background: color-mix(in srgb, ${green} 7%, transparent)`,
  "padding: 9px 13px",
].join("; ");

const cardLabel = [
  reset,
  sans,
  "font-size: 13.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: var(--sl-color-text)",
].join("; ");

// Inline mono fragment inside a card label (e.g. the announced role string,
// the disabled attribute) so the code-y bits read as code.
const codeBit = [
  mono,
  "font-size: 12.5px",
  `color: color-mix(in srgb, ${green} 72%, var(--sl-color-text))`,
].join("; ");

// The five arrow targets, in the lesson's order. `grav` is the startSocket X
// pull (outer arrows pull hard, the middle one barely) so the five curves fan
// into distinct lanes. `dy` spreads the five identical "free" labels: each
// label sits halfway between the (fixed) button centre and its card centre, so
// outer cards already pull their labels apart — dy fine-tunes the lift/drop.
const targets = [
  { id: "fb-tab", grav: 26, dy: -8 },
  { id: "fb-keys", grav: 80, dy: -6 },
  { id: "fb-ring", grav: 130, dy: 0 },
  { id: "fb-role", grav: 80, dy: 6 },
  { id: "fb-disabled", grav: 26, dy: 8 },
];

const arrows = targets.map((b) => ({
  from: "fb-button",
  to: b.id,
  label: "free",
  color: green,
  startSocket: "right" as const,
  endSocket: "left" as const,
  startSocketGravity: [b.grav, 0] as [number, number],
  endSocketGravity: [-40, 0] as [number, number],
  labelOffset: [0, b.dy] as [number, number],
}));
---

<div class="not-content">
  <ArrowDiagram arrows={arrows}>
    {/* One grid is the sole child of ArrowDiagram's .arrow-stage wrapper, so its
        three tracks lay out as real columns: button | gap (curves) | card stack.
        (Putting display:grid on an ancestor of .arrow-stage would lay out the
        stage as a single grid item and collapse the columns.) */}
    <div style={grid}>
      <div style={buttonCell}>
        <span id="fb-button" style={buttonTile}>{"<button>"}</span>
      </div>
      <div></div>
      <div style={cardStack}>
        <div id="fb-tab" style={card}>
          <span style={cardLabel}>
            In the <span style={codeBit}>Tab</span> order
          </span>
        </div>
        <div id="fb-keys" style={card}>
          <span style={cardLabel}>
            <span style={codeBit}>Enter</span> / <span style={codeBit}>Space</span> activate
          </span>
        </div>
        <div id="fb-ring" style={card}>
          <span style={cardLabel}>A visible focus ring</span>
        </div>
        <div id="fb-role" style={card}>
          <span style={cardLabel}>
            Announced as <span style={codeBit}>"button"</span>
          </span>
        </div>
        <div id="fb-disabled" style={card}>
          <span style={cardLabel}>
            <span style={codeBit}>disabled</span> drops it from the path
          </span>
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>
