---
// SeamMapping — Chapter 046 Lesson 1 ("When to reach past Server Actions"),
// the closing payoff figure for "the same seam, a different wire format."
//
// A route handler runs the EXACT same five seams as a Server Action
// (parse -> authorize -> mutate -> revalidate -> return); only the last two
// change shape. This figure makes that land at a glance: a three-column grid
// with the shared seam name on a centre spine, the Server Action shape on the
// left and the Route handler shape on the right.
//
// The first three rows (parse / authorize / mutate) are visually plain and
// carry a "= identical" marker because both sides are the same. The last two
// rows (revalidate / return) are tinted with the accent so the eye lands on the
// only two cells that differ.
//
// Plain HTML + CSS per the diagram guidance for clean comparison tables
// (NOT a diagram engine — the outline calls for a styled table here). Inline
// styles only, theme tokens via --sl-color-*, color-mix for tints so it reads
// on both light and dark. `margin: 0` everywhere to defeat Starlight's
// prose-margin injection; `not-content` on the root for the same reason.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const ACCENT = "#7c3aed"; // violet-600 — marks the two seams that change shape

type Row = {
  spine: string;
  action: string;
  handler: string;
  differs: boolean;
};

// The five seams in run order. `differs` flags the last two — the only seams
// whose shape changes between the two boundaries.
const rows: Row[] = [
  { spine: "parse", action: "safeParse", handler: "safeParse", differs: false },
  { spine: "authorize", action: "authorize", handler: "authorize", differs: false },
  { spine: "mutate", action: "mutate", handler: "mutate", differs: false },
  {
    spine: "revalidate",
    action: "updateTag(tag)",
    handler: "set headers / revalidateTag(tag, profile)",
    differs: true,
  },
  {
    spine: "return",
    action: "return Result",
    handler: "return Response + status",
    differs: true,
  },
];

const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 720px",
  "margin-inline: auto",
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
].join("; ");

// One grid: left shape | centre spine | right shape.
const grid = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: 1fr auto 1fr",
  "align-items: stretch",
  "column-gap: 8px",
  "row-gap: 8px",
  "width: 100%",
].join("; ");

// Column headers above the two boundary columns.
const colHead = [
  reset,
  "box-sizing: border-box",
  "font-size: 12px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "text-align: center",
  "padding: 0 4px 2px",
  "color: var(--sl-color-gray-2)",
].join("; ");

// A shape cell (left = action, right = handler).
const cellBase = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "text-align: center",
  "gap: 6px",
  "padding: 10px 12px",
  "border-radius: 9px",
  "font-size: 12.5px",
  "line-height: 1.25",
  "min-width: 0",
].join("; ");

const cellPlain = [
  cellBase,
  "border: 1px solid color-mix(in srgb, var(--sl-color-gray-3) 45%, transparent)",
  "background: color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent)",
  "color: var(--sl-color-gray-1)",
].join("; ");

const cellDiffers = [
  cellBase,
  "font-weight: 600",
  `border: 1.5px solid color-mix(in srgb, ${ACCENT} 55%, transparent)`,
  `background: color-mix(in srgb, ${ACCENT} 13%, transparent)`,
  "color: var(--sl-color-white)",
].join("; ");

// The centre spine pill carrying the shared seam name.
const spineBase = [
  reset,
  sans,
  "box-sizing: border-box",
  "align-self: center",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "padding: 8px 14px",
  "border-radius: 999px",
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "white-space: nowrap",
].join("; ");

const spinePlain = [
  spineBase,
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-white)",
].join("; ");

const spineDiffers = [
  spineBase,
  `border: 1.5px solid color-mix(in srgb, ${ACCENT} 60%, transparent)`,
  `background: color-mix(in srgb, ${ACCENT} 20%, transparent)`,
  "color: var(--sl-color-white)",
].join("; ");

// Small "identical" marker that sits in plain rows after the shape token.
const sameTag = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "text-transform: uppercase",
  "padding: 2px 6px",
  "border-radius: 999px",
  "white-space: nowrap",
  "color: var(--sl-color-gray-2)",
  "background: color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent)",
].join("; ");

// Footer legend: explains the violet tint.
const legend = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "justify-content: center",
  "gap: 6px",
  "margin-top: 2px",
  "font-size: 11.5px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");

const legendSwatch = [
  "display: inline-block",
  "width: 11px",
  "height: 11px",
  "border-radius: 3px",
  "vertical-align: -1px",
  `border: 1px solid color-mix(in srgb, ${ACCENT} 55%, transparent)`,
  `background: color-mix(in srgb, ${ACCENT} 22%, transparent)`,
].join("; ");
---

<div class="not-content" style={root}>
  <div style={grid}>
    {/* Column headers — the two boundaries being compared. */}
    <div style={colHead}>Server Action</div>
    <div style={`${colHead}; text-transform: none; letter-spacing: 0; font-weight: 600; color: var(--sl-color-gray-3);`}>
      seam
    </div>
    <div style={colHead}>Route handler</div>

    {/* Five seam rows: action shape | shared spine | handler shape. */}
    {
      rows.map((row) => (
        <>
          <div style={row.differs ? cellDiffers : cellPlain}>
            <span>{row.action}</span>
            {!row.differs && <span style={sameTag}>same</span>}
          </div>
          <div style={row.differs ? spineDiffers : spinePlain}>{row.spine}</div>
          <div style={row.differs ? cellDiffers : cellPlain}>
            <span>{row.handler}</span>
            {!row.differs && <span style={sameTag}>same</span>}
          </div>
        </>
      ))
    }
  </div>

  <div style={legend}>
    <span style={legendSwatch}></span>
    <span>
      Only <strong style="color: var(--sl-color-white); font-weight: 700;">revalidate</strong> and
      <strong style="color: var(--sl-color-white); font-weight: 700;"> return</strong> change shape —
      everything above is identical.
    </span>
  </div>
</div>
