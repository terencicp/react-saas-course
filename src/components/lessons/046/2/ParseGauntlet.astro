---
// One frame of the inbound parse gauntlet, used inside <DiagramSequence>.
// A request enters at the top and falls through four gates in fixed order —
// params, headers, query, body — each guarded by its own safeParse. The handler
// bails the instant a gate rejects; cheaper gates sit above more expensive ones,
// so an early failure means the costly reads below it never run.
//
// `active`  — index (0..3) of the gate currently being parsed. Gates above it
//             have passed (done); gates below it are not yet reached (pending).
// `failedAt`— index of a gate that rejected the request. That gate reads as
//             failed; every other gate stays pending (untouched), which is the
//             whole point of the short-circuit step.

interface Props {
  active?: number;
  failedAt?: number;
}

const { active, failedAt } = Astro.props;

const GREEN = "#16a34a"; // green-600 — a passed gate; reads on both themes
const RED = "#dc2626"; // red-600 — a rejecting gate
const AMBER = "#f59e0b"; // amber-500 — the gate being parsed right now

type Gate = {
  name: string;
  schema: string;
  cost: string;
};

// Source order is the cost order: cheapest disqualifier on top.
const gates: Gate[] = [
  { name: "params", schema: "ParamsSchema", cost: "cheapest" },
  { name: "headers", schema: "HeadersSchema", cost: "cheap" },
  { name: "query", schema: "QuerySchema", cost: "cheap" },
  { name: "body", schema: "BodySchema", cost: "most expensive" },
];

type State = "done" | "active" | "pending" | "failed";

const stateFor = (i: number): State => {
  if (failedAt !== undefined) return i === failedAt ? "failed" : "pending";
  if (active === undefined) return "pending";
  if (i < active) return "done";
  if (i === active) return "active";
  return "pending";
};

// Whether the request made it all the way past the last gate this frame.
const allPassed = failedAt === undefined && active === gates.length - 1;

const boxBase = [
  "margin: 0",
  "padding: 9px 12px",
  "border-radius: 9px",
  "display: flex",
  "align-items: center",
  "gap: 10px",
  "min-width: 0",
  "transition: opacity 200ms ease, border-color 200ms ease, background-color 200ms ease, box-shadow 200ms ease",
].join("; ");

const styleFor = (s: State) => {
  switch (s) {
    case "done":
      return `${boxBase}; border: 1px solid color-mix(in srgb, ${GREEN} 45%, transparent); background: color-mix(in srgb, ${GREEN} 10%, transparent); opacity: 1;`;
    case "active":
      return `${boxBase}; border: 1.5px solid ${AMBER}; background: color-mix(in srgb, ${AMBER} 16%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, ${AMBER} 16%, transparent); opacity: 1;`;
    case "failed":
      return `${boxBase}; border: 1.5px solid ${RED}; background: color-mix(in srgb, ${RED} 16%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, ${RED} 16%, transparent); opacity: 1;`;
    case "pending":
      return `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 16%, transparent); background: color-mix(in srgb, currentColor 3%, transparent); opacity: 0.4;`;
  }
};

// The little round status badge on the left of each gate.
const badgeBase = [
  "flex: 0 0 auto",
  "width: 22px",
  "height: 22px",
  "border-radius: 999px",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1",
].join("; ");

const badgeFor = (s: State) => {
  switch (s) {
    case "done":
      return `${badgeBase}; color: #fff; background: ${GREEN};`;
    case "active":
      return `${badgeBase}; color: #fff; background: ${AMBER};`;
    case "failed":
      return `${badgeBase}; color: #fff; background: ${RED};`;
    case "pending":
      return `${badgeBase}; color: color-mix(in srgb, currentColor 55%, transparent); background: color-mix(in srgb, currentColor 12%, transparent);`;
  }
};

const glyphFor = (s: State, i: number) => {
  if (s === "done") return "✓";
  if (s === "failed") return "✕";
  return String(i + 1);
};

const nameStyle =
  "margin: 0; font-size: 13px; font-weight: 700; font-family: var(--__sl-font-mono, ui-monospace, monospace); line-height: 1.2;";
const schemaStyle =
  "margin: 0; font-size: 11px; opacity: 0.62; font-family: var(--__sl-font-mono, ui-monospace, monospace); line-height: 1.2;";
const costStyle =
  "margin-left: auto; flex: 0 0 auto; font-size: 10px; letter-spacing: 0.04em; text-transform: uppercase; opacity: 0.5; white-space: nowrap;";

const connectorStyle = (lit: boolean, color: string) =>
  [
    "width: 2px",
    "height: 14px",
    "margin: 0 auto",
    "border-radius: 1px",
    lit
      ? `background: ${color};`
      : "background: color-mix(in srgb, currentColor 14%, transparent);",
    "transition: background-color 200ms ease",
  ].join("; ");
---

<div
  style="margin: 0; max-width: 440px; margin-inline: auto; display: flex; flex-direction: column; align-items: stretch; gap: 0; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* Request enters at the top */}
  <div
    style={`margin: 0 auto; padding: 5px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; font-family: var(--__sl-font-mono, ui-monospace, monospace); border: 1px solid color-mix(in srgb, currentColor 22%, transparent); background: color-mix(in srgb, currentColor 6%, transparent); white-space: nowrap;`}
  >
    POST /api/invoices/[invoiceId]/line-items
  </div>

  <div
    style={connectorStyle(
      failedAt === undefined || failedAt === 0,
      failedAt !== undefined ? RED : AMBER,
    )}
  >
  </div>

  {/* The four gates, stacked top to bottom in source = cost order */}
  {
    gates.map((gate, i) => {
      const s = stateFor(i);
      // The connector below gate i lights only while the request is still
      // flowing past it (i.e. gate i passed and we haven't failed).
      const litBelow = failedAt === undefined && i < (active ?? -1);
      return (
        <>
          <div style={styleFor(s)}>
            <span style={badgeFor(s)}>{glyphFor(s, i)}</span>
            <div style="display: flex; flex-direction: column; gap: 2px; min-width: 0;">
              <span style={nameStyle}>{gate.name}</span>
              <span style={schemaStyle}>{gate.schema}.safeParse</span>
            </div>
            <span style={costStyle}>{gate.cost}</span>
          </div>
          {i < gates.length - 1 && (
            <div style={connectorStyle(litBelow, GREEN)} />
          )}
        </>
      );
    })
  }

  <div style={connectorStyle(allPassed, GREEN)}></div>

  {/* Outcome chip: business logic on a clean pass, or a 400 short-circuit */}
  {
    failedAt !== undefined ? (
      <div
        style={`margin: 0 auto; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; color: #fff; background: ${RED}; white-space: nowrap;`}
      >
        400 · body never read
      </div>
    ) : (
      <div
        style={`margin: 0 auto; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; white-space: nowrap; ${
          allPassed
            ? `color: #fff; background: ${GREEN};`
            : "color: color-mix(in srgb, currentColor 55%, transparent); border: 1px dashed color-mix(in srgb, currentColor 22%, transparent);"
        }`}
      >
        {allPassed ? "✓ business logic runs" : "business logic — not yet"}
      </div>
    )
  }
</div>
