---
// CursorRoundtrip — Chapter 046 Lesson 4 ("List endpoints: filter, sort,
// search, paginate"), the pagination section's scrubbable diagram.
//
// Walks the opaque-cursor round trip across five steps:
//   1. Page 1 request (no cursor)
//   2. Handler asks the DB for limit + 1 = 21 rows
//   3. 21 came back -> slice to 20, encode nextCursor from row 20, hasMore: true
//   4. Page 2 request carries the cursor verbatim
//   5. Last page: < 21 rows -> nextCursor: null, hasMore: false
//
// Built on <DiagramSequence>/<DiagramStep> (its own card; NOT wrapped in
// <Figure>). The component composes the whole sequence so the DiagramStep
// children stay direct children of DiagramSequence (the runtime finds them via
// [data-ds-step]).
//
// Layout discipline: every step shares the SAME three stacked lanes -- a "wire"
// line (the HTTP request/response), a "rows" lane (the DB result, shown as a
// compact tile strip with a count badge rather than 21 literal tiles), and an
// "envelope" lane (the JSON the handler returns). Lanes that don't apply to a
// step render as an empty placeholder of the same height, so the grid stage
// sizes once to the tallest step and never jumps as the reader scrubs.
//
// Colour: pagination is GREEN in this lesson's four-dimension key
// (see UrlDimensionStrip.astro). Green marks the cursor/limit signal; the
// "probe" 21st row is amber to read as "extra, about to be dropped"; neutral
// greys carry structure. Plain HTML + CSS, scoped styles.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";
---

<DiagramSequence>
  {/* Step 1 — page 1 request, no cursor */}
  <DiagramStep caption="Page 1: the client GETs the list with no cursor — there's nothing to carry yet.">
    <div class="crt">
      <div class="crt-wire">
        <span class="crt-actor crt-actor--client">Client</span>
        <span class="crt-arrow" aria-hidden="true">→</span>
        <code class="crt-req"
          >GET /api/invoices?<span class="crt-mut">limit=20</span></code
        >
        <span class="crt-actor crt-actor--server">Handler</span>
      </div>
      <p class="crt-note">No <code>cursor</code> param on the first page.</p>

      <div class="crt-rows crt-rows--empty" aria-hidden="true"></div>
      <div class="crt-env crt-env--empty" aria-hidden="true"></div>
    </div>
  </DiagramStep>

  {/* Step 2 — handler asks the DB for limit + 1 rows */}
  <DiagramStep caption="The handler asks the database for limit + 1 = 21 rows — one extra, to find out if a next page exists.">
    <div class="crt">
      <div class="crt-wire">
        <span class="crt-actor crt-actor--server">Handler</span>
        <span class="crt-arrow" aria-hidden="true">→</span>
        <code class="crt-req"
          >SELECT … LIMIT <span class="crt-mut">21</span></code
        >
        <span class="crt-actor crt-actor--db">Database</span>
      </div>
      <p class="crt-note">
        Fetch <code>limit + 1</code> — the <span class="crt-amber-text"
          >21st</span
        > row is the probe.
      </p>

      <div class="crt-rows">
        <span class="crt-rows-badge">21 rows</span>
        <div class="crt-tilestrip">
          {
            Array.from({ length: 20 }).map(() => (
              <span class="crt-tile" />
            ))
          }
          <span class="crt-tile crt-tile--probe">+1</span>
        </div>
      </div>

      <div class="crt-env crt-env--empty" aria-hidden="true"></div>
    </div>
  </DiagramStep>

  {/* Step 3 — slice to 20, encode nextCursor from row 20, hasMore: true */}
  <DiagramStep caption="21 came back, so there's a next page: drop the probe, return 20, and build nextCursor from row 20 — the last row you actually return.">
    <div class="crt">
      <div class="crt-wire">
        <span class="crt-actor crt-actor--server">Handler</span>
        <span class="crt-arrow" aria-hidden="true">→</span>
        <code class="crt-req crt-req--resp"
          ><span class="crt-status">200</span> response</code
        >
        <span class="crt-actor crt-actor--client">Client</span>
      </div>
      <p class="crt-note">
        Probe dropped; <code>nextCursor</code> encodes <strong>row 20</strong>,
        not the dropped row.
      </p>

      <div class="crt-rows">
        <span class="crt-rows-badge crt-rows-badge--green">20 returned</span>
        <div class="crt-tilestrip">
          {
            Array.from({ length: 19 }).map(() => (
              <span class="crt-tile" />
            ))
          }
          <span class="crt-tile crt-tile--cursor">20</span>
          <span class="crt-tile crt-tile--dropped">+1</span>
        </div>
      </div>

      <pre class="crt-env"><code>{`{ "data": [ /* 20 invoices */ ],
  "pageInfo": {`}
<span class="crt-line crt-line--green">{`    "nextCursor": "eyJ…",  // from row 20`}</span>
<span class="crt-line crt-line--green">{`    "hasMore": true`}</span>
{`  } }`}</code></pre>
    </div>
  </DiagramStep>

  {/* Step 4 — page 2 request carries the cursor verbatim */}
  <DiagramStep caption="Page 2: the client hands back the exact cursor string it was given — it never looks inside.">
    <div class="crt">
      <div class="crt-wire">
        <span class="crt-actor crt-actor--client">Client</span>
        <span class="crt-arrow" aria-hidden="true">→</span>
        <code class="crt-req"
          >GET /api/invoices?<span class="crt-cursor-token">cursor=eyJ…</span
          >&<span class="crt-mut">limit=20</span></code
        >
        <span class="crt-actor crt-actor--server">Handler</span>
      </div>
      <p class="crt-note">
        The <span class="crt-cursor-token">cursor</span> is the verbatim string from
        step 3 — opaque to the client.
      </p>

      <div class="crt-rows crt-rows--echo">
        <span class="crt-echo-out">step 3 → <code>"eyJ…"</code></span>
        <span class="crt-arrow crt-arrow--round" aria-hidden="true">↩</span>
        <span class="crt-echo-in"><code>cursor=eyJ…</code> → step 4</span>
      </div>

      <div class="crt-env crt-env--empty" aria-hidden="true"></div>
    </div>
  </DiagramStep>

  {/* Step 5 — last page: fewer than 21 rows -> nextCursor null, hasMore false */}
  <DiagramStep caption="Last page: fewer than 21 rows come back, so there's no probe to drop — nextCursor is null and hasMore is false. The client stops.">
    <div class="crt">
      <div class="crt-wire">
        <span class="crt-actor crt-actor--server">Handler</span>
        <span class="crt-arrow" aria-hidden="true">→</span>
        <code class="crt-req crt-req--resp"
          ><span class="crt-status">200</span> response</code
        >
        <span class="crt-actor crt-actor--client">Client</span>
      </div>
      <p class="crt-note">
        Only 12 rows — fewer than <code>21</code>, so this is the end.
      </p>

      <div class="crt-rows">
        <span class="crt-rows-badge">12 rows</span>
        <div class="crt-tilestrip">
          {
            Array.from({ length: 12 }).map(() => (
              <span class="crt-tile" />
            ))
          }
        </div>
      </div>

      <pre class="crt-env"><code>{`{ "data": [ /* 12 invoices */ ],
  "pageInfo": {`}
<span class="crt-line crt-line--green">{`    "nextCursor": null,`}</span>
<span class="crt-line crt-line--green">{`    "hasMore": false`}</span>
{`  } }`}</code></pre>
    </div>
  </DiagramStep>
</DiagramSequence>

<style>
  .crt {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- wire line: actor → message → actor ---------------------------- */
  .crt-wire {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .crt-actor {
    flex: 0 0 auto;
    padding: 5px 12px;
    border-radius: 8px;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.02em;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .crt-actor--client {
    background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-gray-3) 40%, transparent);
    color: var(--sl-color-white);
  }
  .crt-actor--server {
    background: color-mix(in srgb, #16a34a 18%, transparent);
    border-color: color-mix(in srgb, #16a34a 45%, transparent);
    color: var(--sl-color-white);
  }
  .crt-actor--db {
    background: color-mix(in srgb, #7c3aed 18%, transparent);
    border-color: color-mix(in srgb, #7c3aed 45%, transparent);
    color: var(--sl-color-white);
  }
  .crt-arrow {
    flex: 0 0 auto;
    font-size: 18px;
    line-height: 1;
    color: var(--sl-color-gray-3);
  }
  .crt-req {
    flex: 0 1 auto;
    padding: 5px 12px;
    border-radius: 8px;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      monospace
    );
    font-size: 13px;
    font-weight: 600;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-text);
    white-space: nowrap;
  }
  .crt-req--resp {
    background: color-mix(in srgb, #16a34a 10%, var(--sl-color-bg));
    border-color: color-mix(in srgb, #16a34a 40%, transparent);
  }
  .crt-status {
    color: #16a34a;
    font-weight: 700;
  }
  /* the limit / count value the reader should track */
  .crt-mut {
    color: #16a34a;
    font-weight: 700;
  }
  .crt-cursor-token {
    color: #16a34a;
    font-weight: 700;
  }

  .crt-note {
    margin: 0;
    text-align: center;
    font-size: 13px;
    line-height: 1.5;
    color: var(--sl-color-gray-3);
  }
  .crt-note code {
    font-size: 0.92em;
  }
  .crt-amber-text {
    color: #d97706;
    font-weight: 700;
  }

  /* ---- rows lane ----------------------------------------------------- */
  /* Fixed min-height so empty placeholders match the populated lane and the
     stage height stays constant across steps. */
  .crt-rows {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 46px;
  }
  .crt-rows--empty {
    min-height: 46px;
  }
  .crt-rows-badge {
    flex: 0 0 auto;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-3) 40%, transparent);
    color: var(--sl-color-white);
    white-space: nowrap;
  }
  .crt-rows-badge--green {
    background: color-mix(in srgb, #16a34a 20%, transparent);
    border-color: color-mix(in srgb, #16a34a 50%, transparent);
  }

  .crt-tilestrip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 3px;
    max-width: 540px;
  }
  .crt-tile {
    width: 14px;
    height: 22px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--sl-color-gray-4) 60%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-3) 35%, transparent);
  }
  /* the probe 21st row — amber, "extra, about to be dropped" */
  .crt-tile--probe,
  .crt-tile--dropped {
    width: auto;
    min-width: 22px;
    padding: 0 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      monospace
    );
    background: color-mix(in srgb, #d97706 22%, transparent);
    border: 1px solid color-mix(in srgb, #d97706 60%, transparent);
    color: var(--sl-color-white);
  }
  /* the dropped probe in step 3 — struck through, faded */
  .crt-tile--dropped {
    opacity: 0.5;
    text-decoration: line-through;
  }
  /* the row nextCursor is built from — green, the kept boundary */
  .crt-tile--cursor {
    width: auto;
    min-width: 22px;
    padding: 0 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    font-size: 10px;
    font-weight: 700;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      monospace
    );
    background: color-mix(in srgb, #16a34a 28%, transparent);
    border: 1px solid #16a34a;
    color: var(--sl-color-white);
  }

  /* step 4's echo lane reuses the rows-lane height */
  .crt-rows--echo {
    gap: 14px;
    font-size: 12.5px;
  }
  .crt-echo-out,
  .crt-echo-in {
    padding: 5px 10px;
    border-radius: 8px;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-gray-2);
    white-space: nowrap;
  }
  .crt-echo-out code,
  .crt-echo-in code {
    color: #16a34a;
    font-weight: 700;
  }
  .crt-arrow--round {
    font-size: 20px;
    color: #16a34a;
  }

  /* ---- envelope lane ------------------------------------------------- */
  /* Fixed min-height so steps without an envelope (1, 2, 4) reserve the same
     space and the grid stage never reflows. */
  .crt-env {
    margin: 0;
    min-height: 104px;
    box-sizing: border-box;
    padding: 12px 14px;
    border-radius: 10px;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    overflow-x: auto;
  }
  .crt-env code {
    display: block;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      monospace
    );
    font-size: 12.5px;
    line-height: 1.55;
    white-space: pre;
    color: var(--sl-color-gray-2);
  }
  .crt-env--empty {
    background: transparent;
    border: 1px dashed color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent);
  }
  /* Inline, not block: the surrounding "\n" text nodes (white-space: pre)
     supply the line breaks, so the coloured span must not add its own or the
     JSON gains spurious blank lines. */
  .crt-line--green {
    color: #16a34a;
    font-weight: 600;
  }

  @media (max-width: 30rem) {
    .crt-req {
      white-space: normal;
      word-break: break-all;
    }
    .crt-tilestrip {
      max-width: 100%;
    }
  }
</style>
