---
// UrlDimensionStrip — Chapter 046 Lesson 4 ("List endpoints: filter, sort,
// search, paginate"), the intro figure that installs the four-dimension frame.
//
// Decomposes the worked example URL
//   /api/invoices?status=sent&sort=-issuedAt&q=acme&cursor=…&limit=20
// into its four query dimensions, each tinted a distinct, reusable colour:
//   filter = blue, sort = violet, search = orange, paginate = green.
// The leading resource path (/api/invoices) stays neutral grey so the four
// dimensions visually stand apart from the path. Each colour is the key the
// reader meets again as the matching body section opens.
//
// Plain HTML + CSS per the diagram guidance for colour-coded labelled strips
// (NOT a diagram engine). Inline styles only; saturated mid-tone fills with
// white text so the colour itself is the signal and reads on both light and
// dark. The strip is a flex row that WRAPS (never scrolls) on narrow viewports;
// each cell stacks its URL fragment over its dimension label so a wrapped cell
// carries its label with it. `margin: 0` everywhere defeats Starlight's
// prose-margin injection; `not-content` on the root does the same.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

// The four dimension colours (Tailwind 600-range) — saturated mid-tones that
// hold contrast against both the white and near-black page backgrounds. These
// are the reusable key: each returns as its body section opens.
const BLUE = "#2563eb"; // filter
const VIOLET = "#7c3aed"; // sort
const ORANGE = "#ea580c"; // search
const GREEN = "#16a34a"; // paginate

type Segment = {
  /** URL fragment exactly as it appears in the query string. */
  fragment: string;
  /** Dimension name shown beneath the fragment. */
  label: string;
  /** Saturated fill colour, or null for the neutral resource path. */
  color: string | null;
};

// In URL order: the neutral path, then the four tinted dimensions.
const segments: Segment[] = [
  { fragment: "/api/invoices", label: "resource path", color: null },
  { fragment: "?status=sent", label: "Filter", color: BLUE },
  { fragment: "&sort=-issuedAt", label: "Sort", color: VIOLET },
  { fragment: "&q=acme", label: "Search", color: ORANGE },
  { fragment: "&cursor=…&limit=20", label: "Paginate", color: GREEN },
];

const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "display: flex",
  "flex-wrap: wrap",
  "justify-content: center",
  "column-gap: 6px",
  "row-gap: 12px",
].join("; ");

// One cell: URL fragment (mono) stacked over its dimension label.
const cellBase = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 4px",
  "min-width: 0",
].join("; ");

// The fragment chip — saturated fill, white text, for the four dimensions.
const fragTinted = (color: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "display: block",
    "padding: 8px 12px",
    "border-radius: 8px",
    "font-size: 13.5px",
    "line-height: 1.3",
    "font-weight: 600",
    "white-space: nowrap",
    `background: ${color}`,
    "color: #ffffff",
  ].join("; ");

// The neutral path chip — un-tinted, muted, so the path stands apart.
const fragPath = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: block",
  "padding: 8px 12px",
  "border-radius: 8px",
  "font-size: 13.5px",
  "line-height: 1.3",
  "font-weight: 600",
  "white-space: nowrap",
  "background: color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent)",
  "border: 1px solid color-mix(in srgb, var(--sl-color-gray-3) 45%, transparent)",
  "color: var(--sl-color-gray-1)",
].join("; ");

// The dimension label beneath a tinted chip — same hue, bold, small caps.
const labelTinted = (color: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "font-size: 11.5px",
    "font-weight: 700",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "white-space: nowrap",
    `color: ${color}`,
  ].join("; ");

// The label beneath the neutral path chip — muted grey, lower-case.
const labelPath = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 11.5px",
  "font-weight: 600",
  "letter-spacing: 0.01em",
  "white-space: nowrap",
  "color: var(--sl-color-gray-3)",
].join("; ");
---

<div class="not-content" style={root}>
  {
    segments.map((seg) => (
      <div style={cellBase}>
        <span style={seg.color ? fragTinted(seg.color) : fragPath}>
          {seg.fragment}
        </span>
        <span style={seg.color ? labelTinted(seg.color) : labelPath}>
          {seg.label}
        </span>
      </div>
    ))
  }
</div>
