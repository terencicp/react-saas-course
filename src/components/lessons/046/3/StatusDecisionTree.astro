---
/**
 * Status-code decision tree for Chapter 046, Lesson 3.
 *
 * The reviewer's mental flowchart for picking a status code, rendered as the
 * early-return ladder the surrounding handler walks: a vertical "happy-path"
 * spine of yes/no questions, each peeling off to the status code it produces
 * on the answer that fails it. Reach the bottom only when every gate passes.
 *
 * Plain HTML + CSS (inline styles only) so the layout is devtools-inspectable
 * and stays readable at any figure-card width, instead of a Mermaid flowchart
 * whose wide viewBox scales its text down to a few pixels in the content column.
 * The layout is intrinsically responsive (flex-wrap, no viewport breakpoint):
 * on a wide column the code chip sits beside its question; when the card is
 * narrow the chip wraps directly beneath it.
 */

type Rung = {
  /** The question the reviewer / handler asks at this gate. */
  q: string;
  /** The answer that fails this gate ("No", or "Yes" for the conflict check). */
  fail: string;
  /** Status code returned on failure. */
  code: string;
  /** One-word reason shown under the code. */
  reason: string;
  /** The pass label on the down-arrow to the next gate. */
  pass: string;
};

const rungs: Rung[] = [
  { q: 'Could you parse the body?', fail: 'No', code: '400', reason: 'malformed', pass: 'parsed' },
  { q: 'Could you identify the caller?', fail: 'No', code: '401', reason: 'no identity', pass: 'known' },
  { q: 'Is the caller allowed?', fail: 'No', code: '403', reason: 'no permission', pass: 'allowed' },
  { q: 'Does it exist in this tenant?', fail: 'No', code: '404', reason: 'missing / cross-tenant', pass: 'found' },
  { q: 'Conflicts with current state?', fail: 'Yes', code: '409', reason: 'conflict', pass: 'no clash' },
  { q: 'Passed the schema?', fail: 'No', code: '422', reason: 'validation', pass: 'valid' },
];

// The final gate is special: the failing branch is an uncaught throw -> 500,
// and the passing branch reaches the green success terminal, not a next gate.
const finalGate = { q: 'Did the work succeed?', fail: 'uncaught throw', code: '500', reason: 'server fault' };
---

<div class="sdt" style="margin: 0;">
  {
    rungs.map((r) => (
      <div class="sdt-rung" style="margin: 0;">
        <div class="sdt-row" style="margin: 0;">
          <div class="sdt-q" style="margin: 0;">{r.q}</div>
          <div class="sdt-fail" style="margin: 0;">
            <span class="sdt-fail-label" style="margin: 0;">{r.fail}</span>
            <span class="sdt-arrow" style="margin: 0;" aria-hidden="true">&#8594;</span>
            <span class="sdt-code sdt-code-err" style="margin: 0;">
              <span class="sdt-code-num" style="margin: 0;">{r.code}</span>
              <span class="sdt-code-sep" style="margin: 0;" aria-hidden="true">&middot;</span>
              <span class="sdt-code-reason" style="margin: 0;">{r.reason}</span>
            </span>
          </div>
        </div>
        <div class="sdt-down" style="margin: 0;">
          <span class="sdt-rail" style="margin: 0;" aria-hidden="true" />
          <span class="sdt-pass" style="margin: 0;">{r.pass}</span>
        </div>
      </div>
    ))
  }

  {/* Final gate: pass -> green terminal, fail -> 500 */}
  <div class="sdt-rung" style="margin: 0;">
    <div class="sdt-row" style="margin: 0;">
      <div class="sdt-q" style="margin: 0;">{finalGate.q}</div>
      <div class="sdt-fail" style="margin: 0;">
        <span class="sdt-fail-label" style="margin: 0;">{finalGate.fail}</span>
        <span class="sdt-arrow" style="margin: 0;" aria-hidden="true">&#8594;</span>
        <span class="sdt-code sdt-code-err" style="margin: 0;">
          <span class="sdt-code-num" style="margin: 0;">{finalGate.code}</span>
          <span class="sdt-code-sep" style="margin: 0;" aria-hidden="true">&middot;</span>
          <span class="sdt-code-reason" style="margin: 0;">{finalGate.reason}</span>
        </span>
      </div>
    </div>
    <div class="sdt-down" style="margin: 0;">
      <span class="sdt-rail" style="margin: 0;" aria-hidden="true" />
      <span class="sdt-pass" style="margin: 0;">Yes</span>
    </div>
  </div>

  <div class="sdt-ok" style="margin: 0;">
    <span class="sdt-code-num" style="margin: 0;">200 / 201 / 202 / 204</span>
    <span class="sdt-code-sep" style="margin: 0;" aria-hidden="true">&middot;</span>
    <span class="sdt-code-reason" style="margin: 0;">it worked</span>
  </div>
</div>

<style>
  .sdt {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    width: 100%;
    font-size: 0.875rem;
    line-height: 1.25;
  }

  .sdt-rung {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  /* Question + its fail-branch. Wraps the branch beneath the question on a
     narrow card; keeps them side by side when there is room. */
  .sdt-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: 0.85rem;
    row-gap: 0.4rem;
    width: 100%;
  }

  /* The question pill — the neutral spine, so the saturated codes are the signal. */
  .sdt-q {
    flex: 1 1 14rem;
    max-width: 22rem;
    min-width: 0;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 10px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-weight: 600;
  }

  /* The failing branch: LABEL -> [code]. These three stay glued together so the
     code never wraps away from its arrow. */
  .sdt-fail {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .sdt-fail-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
    color: var(--sl-color-gray-2);
  }

  .sdt-arrow {
    font-size: 1.2rem;
    line-height: 1;
    color: #ef4444;
  }

  /* Status-code chips — a single line: NUM · reason. */
  .sdt-code {
    box-sizing: border-box;
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 0.4rem;
    border-radius: 9px;
    white-space: nowrap;
  }

  .sdt-code-err {
    padding: 0.3rem 0.65rem;
    background: #dc2626;
    border: 1px solid #ef4444;
    color: #fff;
  }

  .sdt-code-num {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
  }

  .sdt-code-sep {
    opacity: 0.65;
  }

  .sdt-code-reason {
    font-size: 0.78rem;
    opacity: 0.95;
  }

  /* The down-connector between gates — a short rail with the pass label,
     reading "this answer passes, on to the next question." */
  .sdt-down {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    height: 1.15rem;
    padding-left: 1.1rem;
  }

  .sdt-rail {
    display: block;
    width: 2px;
    height: 100%;
    background: #22c55e;
    border-radius: 1px;
  }

  .sdt-pass {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #22c55e;
    white-space: nowrap;
  }

  /* The green success terminal — sized like a question pill, single line. */
  .sdt-ok {
    align-self: flex-start;
    max-width: 22rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    border-radius: 10px;
    background: #16a34a;
    border: 1px solid #22c55e;
    color: #fff;
    white-space: nowrap;
  }
</style>
