---
/**
 * Idempotency replay sequence for Chapter 046, Lesson 3.
 *
 * A scrubbable two-pass walk of the `Idempotency-Key` dedup contract, rendered
 * inside the lesson's <DiagramSequence>. The punch is temporal: the reader scrubs
 * from the first request (claim WINS -> side effect runs) to the retry (claim
 * LOSES -> side effect is SKIPPED, cached response replayed), then to a summary
 * that contrasts "2 requests" against "1 charge".
 *
 * Plain HTML + CSS (scoped) rather than per-step Mermaid sequence diagrams:
 *   - The four actors stay in a fixed legend strip across all three steps, so
 *     scrubbing animates the *same* picture changing instead of swapping three
 *     differently-sized diagrams (the grid-stack stage sizes to the tallest).
 *   - Coloring one arrow active-green and dashing/greying *another* arrow on the
 *     retry is the whole aha; that per-edge control is awkward in Mermaid and
 *     trivial in CSS. The sibling StatusDecisionTree in this lesson chose HTML+CSS
 *     over Mermaid for the same readability reason.
 *
 * Palette intentionally mirrors StatusDecisionTree: green #16a34a/#22c55e for the
 * live path, red #dc2626 for the conflict, neutral grays for the spine, mono for
 * codes/keys.
 *
 * DiagramSequence provides its own card and must NOT be wrapped in <Figure>.
 */
import DiagramSequence from '../../../../components/figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../../components/figures/diagram-sequence/DiagramStep.astro';

const actors = [
  { key: 'client', label: 'Client' },
  { key: 'handler', label: 'Route Handler' },
  { key: 'table', label: 'processed_requests', mono: true },
  { key: 'effect', label: 'Stripe charge' },
];
---

<DiagramSequence>
  {/* ── Step 1: first request, claim wins, side effect runs ─────────────── */}
  <DiagramStep>
    <div class="ir">
      <div class="ir-lanes" aria-hidden="true">
        {
          actors.map((a) => (
            <span class={`ir-lane${a.key === 'effect' ? ' is-live' : ''}`}>
              <span class={a.mono ? 'ir-mono' : ''}>{a.label}</span>
            </span>
          ))
        }
      </div>

      <ol class="ir-flow">
        <li class="ir-msg">
          <span class="ir-from">Client</span>
          <span class="ir-edge" aria-hidden="true">&#8594;</span>
          <span class="ir-to">Route Handler</span>
          <span class="ir-note">
            <code>POST /charge</code> &nbsp;<code>Idempotency-Key: k1</code>
          </span>
        </li>

        <li class="ir-msg">
          <span class="ir-from">Handler</span>
          <span class="ir-edge ir-edge-self" aria-hidden="true">&#8635;</span>
          <span class="ir-to">hashes the claim</span>
          <span class="ir-note">
            <code>hash(k1 + route + tenant)</code>
          </span>
        </li>

        <li class="ir-msg is-win">
          <span class="ir-from">Handler</span>
          <span class="ir-edge" aria-hidden="true">&#8594;</span>
          <span class="ir-to ir-mono">processed_requests</span>
          <span class="ir-note">
            <code>INSERT … ON CONFLICT DO NOTHING</code>
            <span class="ir-tag ir-tag-win">claim WINS &middot; row inserted</span>
          </span>
        </li>

        <li class="ir-msg is-live">
          <span class="ir-from">Handler</span>
          <span class="ir-edge" aria-hidden="true">&#8594;</span>
          <span class="ir-to">Stripe charge</span>
          <span class="ir-note">
            side effect runs <span class="ir-tag ir-tag-live">card charged</span>
          </span>
        </li>

        <li class="ir-msg">
          <span class="ir-from">Handler</span>
          <span class="ir-edge ir-edge-store" aria-hidden="true">&#8594;</span>
          <span class="ir-to ir-mono">processed_requests</span>
          <span class="ir-note">store the response in the row</span>
        </li>

        <li class="ir-msg">
          <span class="ir-from">Handler</span>
          <span class="ir-edge ir-edge-back" aria-hidden="true">&#8592;</span>
          <span class="ir-to">Client</span>
          <span class="ir-note">
            <code>201 Created</code> returned
          </span>
        </li>
      </ol>
    </div>
    <Fragment slot="caption">
      <strong>First request — the key is new.</strong> The handler hashes
      <code>k1</code> with the route and tenant, wins the atomic claim, runs the
      charge, stores the response in the row, and returns <code>201</code>.
    </Fragment>
  </DiagramStep>

  {/* ── Step 2: retry, same key, claim loses, side effect skipped ───────── */}
  <DiagramStep>
    <div class="ir">
      <div class="ir-lanes" aria-hidden="true">
        {
          actors.map((a) => (
            <span class={`ir-lane${a.key === 'effect' ? ' is-skip' : ''}`}>
              <span class={a.mono ? 'ir-mono' : ''}>{a.label}</span>
            </span>
          ))
        }
      </div>

      <ol class="ir-flow">
        <li class="ir-msg">
          <span class="ir-from">Client</span>
          <span class="ir-edge" aria-hidden="true">&#8594;</span>
          <span class="ir-to">Route Handler</span>
          <span class="ir-note">
            <em>same</em> <code>POST /charge</code> &nbsp;<code>Idempotency-Key: k1</code>
            <span class="ir-tag ir-tag-muted">first response was lost</span>
          </span>
        </li>

        <li class="ir-msg">
          <span class="ir-from">Handler</span>
          <span class="ir-edge ir-edge-self" aria-hidden="true">&#8635;</span>
          <span class="ir-to">hashes the claim</span>
          <span class="ir-note">
            <code>hash(k1 + route + tenant)</code> — identical
          </span>
        </li>

        <li class="ir-msg is-conflict">
          <span class="ir-from">Handler</span>
          <span class="ir-edge" aria-hidden="true">&#8594;</span>
          <span class="ir-to ir-mono">processed_requests</span>
          <span class="ir-note">
            <code>INSERT … ON CONFLICT DO NOTHING</code>
            <span class="ir-tag ir-tag-conflict">claim LOSES &middot; row already exists</span>
          </span>
        </li>

        <li class="ir-msg is-skip">
          <span class="ir-from">Handler</span>
          <span class="ir-edge ir-edge-cut" aria-hidden="true">&#10005;</span>
          <span class="ir-to">Stripe charge</span>
          <span class="ir-note">
            side effect <strong>skipped</strong>
            <span class="ir-tag ir-tag-skip">never re-runs</span>
          </span>
        </li>

        <li class="ir-msg is-live">
          <span class="ir-from">Handler</span>
          <span class="ir-edge ir-edge-back" aria-hidden="true">&#8592;</span>
          <span class="ir-to ir-mono">processed_requests</span>
          <span class="ir-note">read the <strong>cached</strong> response from the row</span>
        </li>

        <li class="ir-msg is-live">
          <span class="ir-from">Handler</span>
          <span class="ir-edge ir-edge-back" aria-hidden="true">&#8592;</span>
          <span class="ir-to">Client</span>
          <span class="ir-note">
            same <code>201 Created</code> returned
          </span>
        </li>
      </ol>
    </div>
    <Fragment slot="caption">
      <strong>Retry — same key, claim loses.</strong> The identical request hashes
      to the same value, so the insert hits the conflict. The handler short-circuits:
      <strong>the charge is skipped</strong> and the stored response is replayed.
      That fork is the entire idea.
    </Fragment>
  </DiagramStep>

  {/* ── Step 3: net result, 2 requests -> 1 charge ──────────────────────── */}
  <DiagramStep>
    <div class="ir ir-summary">
      <div class="ir-tally">
        <div class="ir-card ir-card-neutral">
          <span class="ir-num">2</span>
          <span class="ir-cap">requests arrived</span>
          <span class="ir-sub">original + retry, same key</span>
        </div>
        <span class="ir-yields" aria-hidden="true">&#8594;</span>
        <div class="ir-card ir-card-win">
          <span class="ir-num">1</span>
          <span class="ir-cap">charge happened</span>
          <span class="ir-sub">the side effect ran exactly once</span>
        </div>
        <span class="ir-yields" aria-hidden="true">&#8594;</span>
        <div class="ir-card ir-card-neutral">
          <span class="ir-num">2</span>
          <span class="ir-cap">identical responses</span>
          <span class="ir-sub">client sees the same <code>201</code> both times</span>
        </div>
      </div>
      <p class="ir-conclusion">
        The dedup row absorbs the retry. The customer's card is charged once, the
        client gets a consistent answer, and the system stays correct under retry.
      </p>
    </div>
    <Fragment slot="caption">
      <strong>Net result: one charge, two identical responses.</strong> No matter
      how many times the request with key <code>k1</code> arrives, the side effect
      runs exactly once.
    </Fragment>
  </DiagramStep>
</DiagramSequence>

<style>
  .ir {
    --ir-win: #22c55e;
    --ir-win-bg: #16a34a;
    --ir-err: #ef4444;
    --ir-err-bg: #dc2626;
    width: 100%;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  /* The fixed actor legend — identical position across every step so scrubbing
     animates one diagram, not three. The relevant actor lights up per step. */
  .ir-lanes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-bottom: 0.9rem;
  }
  .ir-lane {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-width: 0;
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 9px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-weight: 600;
    font-size: 0.78rem;
    line-height: 1.2;
  }
  .ir-lane.is-live {
    border-color: var(--ir-win);
    background: color-mix(in srgb, var(--ir-win) 18%, var(--sl-color-gray-6));
  }
  .ir-lane.is-skip {
    border-style: dashed;
    color: var(--sl-color-gray-3);
    opacity: 0.6;
  }
  .ir-mono {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.92em;
  }

  /* Message list — one row per message in the exchange. */
  .ir-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .ir-msg {
    display: grid;
    grid-template-columns: auto auto auto 1fr;
    align-items: center;
    column-gap: 0.5rem;
    row-gap: 0.25rem;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--sl-color-hairline);
    border-left: 3px solid var(--sl-color-gray-4);
    border-radius: 8px;
    background: var(--sl-color-bg);
  }

  .ir-from,
  .ir-to {
    font-weight: 600;
    color: var(--sl-color-white);
    white-space: nowrap;
  }
  .ir-edge {
    font-size: 1.15rem;
    line-height: 1;
    color: var(--sl-color-gray-2);
  }
  .ir-edge-self {
    font-size: 1rem;
  }
  .ir-edge-back {
    color: var(--sl-color-gray-3);
  }
  .ir-note {
    grid-column: 4;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    color: var(--sl-color-gray-2);
    min-width: 0;
  }
  .ir-note code {
    font-size: 0.82em;
  }

  /* State-colored message rows. */
  .ir-msg.is-win {
    border-left-color: var(--ir-win);
  }
  .ir-msg.is-live {
    border-left-color: var(--ir-win);
    background: color-mix(in srgb, var(--ir-win) 9%, var(--sl-color-bg));
  }
  .ir-msg.is-live .ir-edge {
    color: var(--ir-win);
  }
  .ir-msg.is-conflict {
    border-left-color: var(--ir-err);
  }
  .ir-msg.is-conflict .ir-edge {
    color: var(--ir-err);
  }

  /* The skipped side-effect — the aha: greyed, dashed border, cut arrow,
     strike-through target. */
  .ir-msg.is-skip {
    border-style: dashed;
    border-left-color: var(--sl-color-gray-4);
    opacity: 0.62;
  }
  .ir-msg.is-skip .ir-to {
    text-decoration: line-through;
    text-decoration-color: var(--sl-color-gray-3);
  }
  .ir-edge-cut {
    color: var(--ir-err);
    font-weight: 700;
  }

  /* Inline status tags. */
  .ir-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.12rem 0.5rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .ir-tag-win,
  .ir-tag-live {
    background: var(--ir-win-bg);
    color: #fff;
  }
  .ir-tag-conflict {
    background: var(--ir-err-bg);
    color: #fff;
  }
  .ir-tag-skip {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-1);
  }
  .ir-tag-muted {
    background: transparent;
    border: 1px dashed var(--sl-color-gray-4);
    color: var(--sl-color-gray-3);
    text-transform: none;
    letter-spacing: 0;
    font-weight: 600;
  }

  /* ── Summary step ──────────────────────────────────────────────────── */
  .ir-summary {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ir-tally {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 0.75rem;
  }
  .ir-card {
    flex: 1 1 9rem;
    max-width: 13rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.2rem;
    padding: 0.9rem 0.8rem;
    border-radius: 11px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
  }
  .ir-card-win {
    border-color: var(--ir-win);
    background: var(--ir-win-bg);
  }
  .ir-num {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 2.1rem;
    font-weight: 800;
    line-height: 1;
    color: var(--sl-color-white);
  }
  .ir-card-win .ir-num {
    color: #fff;
  }
  .ir-cap {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--sl-color-white);
  }
  .ir-card-win .ir-cap {
    color: #fff;
  }
  .ir-sub {
    font-size: 0.72rem;
    color: var(--sl-color-gray-2);
  }
  .ir-card-win .ir-sub {
    color: color-mix(in srgb, #fff 88%, transparent);
  }
  .ir-yields {
    display: flex;
    align-items: center;
    font-size: 1.6rem;
    color: var(--sl-color-gray-3);
  }
  .ir-conclusion {
    margin: 0;
    text-align: center;
    color: var(--sl-color-gray-2);
    font-size: 0.85rem;
    line-height: 1.55;
  }

  /* Narrow cards: drop the side labels to a stacked layout so nothing clips. */
  @media (max-width: 34rem) {
    .ir-lanes {
      grid-template-columns: repeat(2, 1fr);
    }
    .ir-msg {
      grid-template-columns: auto auto 1fr;
    }
    .ir-msg .ir-to {
      grid-column: 3;
    }
    .ir-note {
      grid-column: 1 / -1;
    }
    .ir-yields {
      transform: rotate(90deg);
    }
  }
</style>
