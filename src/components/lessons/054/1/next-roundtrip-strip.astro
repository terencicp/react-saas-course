---
// next-roundtrip-strip — Chapter 054 Lesson 1, "The two-layer gate in proxy.ts".
//
// A compact horizontal sequential phase strip (the html-css "timeline without
// parallelism" use case) that traces the ?next= value once around its full
// round-trip: written by the proxy, carried by the browser into the sign-in
// URL, read back out on the form, validated, and finally landed on.
//
// The single teaching point the figure exists to make: phase 3 (the sign-in
// form reading `next` off the URL) is ATTACKER-REACHABLE surface — `next` is
// user-controllable input there — which is *why* phase 4 (safeNext) is not
// optional. So the strip is built around that danger -> guard adjacency:
//
//   phase 3  = danger   (amber, the lesson's caution colour; "user-controlled")
//   phase 4  = guard     (green, safeNext re-validates and falls back to /dashboard)
//
// Everything else (the protected URL, the proxy write, the landing) is quiet
// neutral chrome so the eye lands on the 3 -> 4 pair. Cells sit on ONE row at
// the Figure's content width connected by short arrows; they wrap to a stacked
// column only on a narrow viewport. Theme-adaptive chrome rides Starlight gray
// vars; the two saturated accents are fixed mid-tones (amber-600 / green-600)
// with text that reads on both backgrounds. `margin: 0` everywhere defeats
// Starlight's injected prose margins. The component is wrapped in <Figure> at
// the call site, where the caption lives.

// The five phases, left to right. `kind` selects the visual treatment:
//   'plain'  — neutral plumbing
//   'danger' — the attacker-reachable surface (amber)
//   'guard'  — the validating gate (green)
const phases = [
  {
    kind: 'plain',
    eyebrow: 'where they were headed',
    name: 'Protected URL',
    value: '/billing?status=open',
    sub: 'a signed-out user hits a deep link',
  },
  {
    kind: 'plain',
    eyebrow: 'proxy writes next',
    name: 'Proxy redirect',
    value: '/sign-in?next=%2Fbilling%3Fstatus%3Dopen',
    sub: 'original path URL-encoded into the query',
  },
  {
    kind: 'danger',
    eyebrow: 'attacker-reachable',
    name: 'Sign-in form',
    value: "reads next from the URL",
    sub: 'user authenticates · next is user-controllable here',
  },
  {
    kind: 'guard',
    eyebrow: 'the reason phase 3 is safe',
    name: 'safeNext(next)',
    value: 'safe in-app path? keep it',
    sub: 'anything else falls back to /dashboard',
  },
  {
    kind: 'plain',
    eyebrow: 'round-trip complete',
    name: 'Land',
    value: '/billing?status=open',
    sub: 'or /dashboard, if next was unsafe',
  },
];
---

<div class="nrt not-content">
  {
    phases.map((phase, i) => (
      <>
        <div class:list={['nrt-cell', `nrt-${phase.kind}`]}>
          <span class="nrt-eyebrow">{phase.eyebrow}</span>
          <span class="nrt-name">{phase.name}</span>
          <code class="nrt-value">{phase.value}</code>
          <span class="nrt-sub">{phase.sub}</span>
        </div>
        {i < phases.length - 1 && (
          <span class="nrt-arrow" aria-hidden="true">
            <svg
              viewBox="0 0 34 14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="2" y1="7" x2="28" y2="7" />
              <polyline points="23 2.5 29 7 23 11.5" />
            </svg>
          </span>
        )}
      </>
    ))
  }
</div>

<style>
  .nrt {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 12px 4px;
    margin: 0;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* --- shared cell chrome --- */
  .nrt-cell {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 4px;
    flex: 1 1 7.75rem;
    min-width: 0;
    max-width: 10rem;
    min-height: 7.75rem;
    padding: 10px 10px;
    border-radius: 10px;
    margin: 0;
  }

  /* Neutral plumbing — the protected URL, the proxy write, the landing. */
  .nrt-plain {
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
  }

  /* The attacker-reachable surface: where `next` is user-controllable. Amber is
     the lesson's caution colour — it reads "be careful here", not "broken". */
  .nrt-danger {
    border: 1px solid #b45309; /* amber 700 */
    background: #d97706; /* amber 600 — reads on light and dark */
    box-shadow: 0 1px 3px rgba(217, 119, 6, 0.4);
  }

  /* The validating gate: safeNext, the single reason the danger cell is safe. */
  .nrt-guard {
    border: 1px solid #15803d; /* green 700 */
    background: #16a34a; /* green 600 */
    box-shadow: 0 1px 3px rgba(22, 163, 74, 0.4);
  }

  .nrt-eyebrow {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3, #64748b);
    margin: 0;
  }

  .nrt-name {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--sl-color-white, #1e293b);
    margin: 1px 0 0;
  }

  /* The concrete value carried at this phase. Transparent so it isn't a prose
     pill stealing width; wraps freely rather than forcing the cell wider. */
  .nrt-value {
    margin: 2px 0 0;
    padding: 0;
    background: transparent;
    font-family:
      var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Consolas, monospace);
    font-size: 0.7rem;
    line-height: 1.3;
    color: var(--sl-color-text, #334155);
    overflow-wrap: anywhere;
  }

  .nrt-sub {
    font-size: 0.7rem;
    line-height: 1.28;
    color: var(--sl-color-gray-2, #475569);
    margin: auto 0 0;
  }

  /* On the two saturated cells, every text line must be light for contrast. */
  .nrt-danger .nrt-eyebrow,
  .nrt-guard .nrt-eyebrow {
    color: rgba(255, 255, 255, 0.88);
  }
  .nrt-danger .nrt-name,
  .nrt-guard .nrt-name,
  .nrt-danger .nrt-value,
  .nrt-guard .nrt-value,
  .nrt-danger .nrt-sub,
  .nrt-guard .nrt-sub {
    color: #ffffff;
  }

  .nrt-arrow {
    align-self: center;
    flex: 0 0 auto;
    display: inline-flex;
    color: var(--sl-color-gray-3, #64748b);
    margin: 0;
  }
  .nrt-arrow svg {
    width: 30px;
    height: 13px;
  }

  /* Narrow viewports: stack into a column, rotate the arrows to point down. */
  @media (max-width: 620px) {
    .nrt {
      flex-direction: column;
      align-items: center;
      gap: 0;
    }
    .nrt-cell {
      flex: 0 0 auto;
      width: 100%;
      max-width: 20rem;
      min-height: 0;
    }
    .nrt-sub {
      margin: 2px 0 0;
    }
    .nrt-arrow {
      transform: rotate(90deg);
      margin: 5px 0;
    }
  }
</style>
