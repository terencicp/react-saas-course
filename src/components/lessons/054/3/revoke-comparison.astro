---
// revoke-comparison — Chapter 054 Lesson 3, "Active sessions and revoke-across-devices".
//
// The section's anchor: three revoke calls that LOOK interchangeable, collapsed into
// one glanceable contrast. The whole point is the one fact the user actually feels —
// does the session reading this page die? — so that column is the load-bearing one,
// rendered as a dominant violet-framed vertical stripe, and it's what every word of
// button copy must answer.
//
//   revokeSession({ token })   one named row      current UNTOUCHED → you stay
//   revokeOtherSessions()      all but the current current SURVIVES  → you stay
//   revokeSessions()           all incl. current   current DIES      → /sign-in
//
// A comparison table (the outline + MDX both call for one), but built as CSS grid so
// the differentiator column can be visually elevated rather than sit flat among its
// neighbours. Calls are rows; the columns are: Call (orange), What it deletes, The
// current session (violet, dominant — survive/dies pill), Where you land, The button
// copy. The "also triggered by" parallel (changePassword's L2 flag) rides as a small
// inline note on the revokeOtherSessions row, so the table stays tight enough for a
// wide-but-short laptop viewport.
//
// Chapter palette (matches this lesson's siblings — session-row-anatomy.astro,
// sessions-after-change.astro):
//   orange  — the library call / endpoint name        (#ea580c / #c2410c)
//   violet  — the hinge / load-bearing column          (#7c3aed) — "does the current
//             session die?", the one fact that drives the copy
//   green   — the current session SURVIVES             (#16a34a / #15803d)
//   red     — the current session DIES, signed out here (#dc2626 / #b91c1c)
//   neutral — plain cells                               (Starlight gray vars)
//
// Plain HTML + CSS, no interactivity — a static comparison, so per the diagrams index
// HTML+CSS is the right engine. Chrome rides Starlight gray/bg vars so it flips
// light/dark; mid-tone accents ride as-is in both themes. Wrapped in <Figure> at the
// call site (the caption lives there).

type Fate = 'untouched' | 'survives' | 'dies';

type Call = {
  name: string; // the Better Auth call, orange
  arg?: string; // the argument shown inside the call's parens
  deletes: string; // "What it deletes"
  fate: Fate; // "The current session" — the load-bearing column
  fateLabel: string; // the pill text in that column
  fateNote: string; // the one-clause gloss under the pill
  lands: string; // "Where you land"
  landsRedirect?: boolean; // render the destination as a route chip
  copy: string; // "The button copy" — the guardrail
  alsoBy?: string; // the inline "also triggered by" note
};

const CALLS: Call[] = [
  {
    name: 'revokeSession',
    arg: '{ token }',
    deletes: 'one named row',
    fate: 'untouched',
    fateLabel: 'untouched',
    fateNote: 'you stay signed in',
    lands: 'stays here',
    copy: 'Sign out this session',
  },
  {
    name: 'revokeOtherSessions',
    arg: '',
    deletes: 'every row but the current',
    fate: 'survives',
    fateLabel: 'survives',
    fateNote: 'you stay signed in',
    lands: 'stays here',
    copy: 'Sign out other devices',
    alsoBy: 'Also fired by changePassword({ revokeOtherSessions: true }) — L2',
  },
  {
    name: 'revokeSessions',
    arg: '',
    deletes: 'every row, the current included',
    fate: 'dies',
    fateLabel: 'killed',
    fateNote: 'signed out here too',
    lands: '/sign-in',
    landsRedirect: true,
    copy: 'Sign out everywhere, including this device',
  },
];

const HEADS = [
  'Call',
  'What it deletes',
  'The current session',
  'Where you land',
  'The button copy',
];
---

<div class="rvc" role="table" aria-label="The three revoke calls compared">
  <div class="rvc-grid">
    {/* ── header row ── */}
    <div class="rvc-row rvc-row--head" role="row">
      {
        HEADS.map((head, i) => (
          <div
            class="rvc-cell rvc-cell--head"
            role="columnheader"
            data-col={i === 2 ? 'fate' : undefined}
          >
            {head}
            {i === 2 && <span class="rvc-head-tag">the fact that drives the copy</span>}
          </div>
        ))
      }
    </div>

    {/* ── one row per call ── */}
    {
      CALLS.map((call) => (
        <div class="rvc-row" role="row" data-fate={call.fate}>
          {/* Call — orange */}
          <div class="rvc-cell rvc-cell--call" role="cell">
            <code class="rvc-call">
              <span class="rvc-call-name">{call.name}</span>
              <span class="rvc-call-paren">({call.arg})</span>
            </code>
            {call.alsoBy && <span class="rvc-also">{call.alsoBy}</span>}
          </div>

          {/* What it deletes */}
          <div class="rvc-cell rvc-cell--deletes" role="cell">
            {call.deletes}
          </div>

          {/* The current session — the load-bearing violet column */}
          <div class="rvc-cell rvc-cell--fate" role="cell" data-col="fate">
            <span class="rvc-pill" data-fate={call.fate}>
              <span class="rvc-pill-icon" aria-hidden="true">
                {call.fate === 'dies' ? (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round">
                    <path d="M6 6l12 12M18 6L6 18" />
                  </svg>
                ) : (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                )}
              </span>
              {call.fateLabel}
            </span>
            <span class="rvc-fate-note">{call.fateNote}</span>
          </div>

          {/* Where you land */}
          <div class="rvc-cell rvc-cell--lands" role="cell">
            {call.landsRedirect ? (
              <span class="rvc-route">
                <span class="rvc-route-arrow" aria-hidden="true">
                  →
                </span>
                <code>{call.lands}</code>
              </span>
            ) : (
              call.lands
            )}
          </div>

          {/* The button copy — the guardrail */}
          <div class="rvc-cell rvc-cell--copy" role="cell">
            <span class="rvc-btn" data-fate={call.fate}>
              {call.copy}
            </span>
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .rvc {
    margin: 0;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── the grid: 5 columns, the fate column given the most room ──────── */
  .rvc-grid {
    display: grid;
    grid-template-columns:
      minmax(150px, 1.15fr) /* Call */
      minmax(110px, 1fr) /* What it deletes */
      minmax(140px, 1.1fr) /* The current session (dominant) */
      minmax(82px, 0.7fr) /* Where you land */
      minmax(150px, 1.25fr); /* The button copy */
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    border-radius: 12px;
    overflow: hidden;
    background: var(--sl-color-bg, transparent);
  }

  .rvc-row {
    display: contents;
  }

  .rvc-cell {
    display: flex;
    flex-direction: column;
    gap: 4px;
    justify-content: center;
    margin: 0;
    padding: 11px 13px;
    font-size: 0.74rem;
    line-height: 1.35;
    color: var(--sl-color-gray-2, #475569);
    border-top: 1px solid var(--sl-color-gray-6, #e2e8f0);
  }
  /* first body row sits under the header, which has its own bottom rule */
  .rvc-row--head + .rvc-row .rvc-cell {
    border-top: none;
  }

  /* ── header row ── */
  .rvc-cell--head {
    gap: 2px;
    padding: 9px 13px;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3, #64748b);
    background: color-mix(
      in srgb,
      var(--sl-color-gray-6, #e2e8f0) 45%,
      var(--sl-color-bg, transparent)
    );
    border-top: none;
    border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
  }
  .rvc-head-tag {
    font-size: 0.54rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: none;
    color: #7c3aed;
  }

  /* ── the load-bearing column: a violet vertical stripe spanning every row ── */
  .rvc-cell[data-col='fate'] {
    background: color-mix(in srgb, #7c3aed 7%, var(--sl-color-bg, transparent));
    border-left: 1px solid color-mix(in srgb, #7c3aed 28%, transparent);
    border-right: 1px solid color-mix(in srgb, #7c3aed 28%, transparent);
  }
  .rvc-cell--head[data-col='fate'] {
    background: color-mix(in srgb, #7c3aed 13%, var(--sl-color-bg, transparent));
    color: #6d28d9;
  }

  /* ── Call cell: the orange endpoint name ── */
  .rvc-cell--call {
    gap: 5px;
  }
  .rvc-call {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    align-self: flex-start;
    margin: 0;
    padding: 2px 8px;
    border-radius: 7px;
    font-size: 0.72rem;
    line-height: 1.3;
    background: color-mix(in srgb, #ea580c 12%, var(--sl-color-bg, transparent));
    border: 1px solid color-mix(in srgb, #ea580c 32%, transparent);
  }
  .rvc-call-name {
    font-weight: 700;
    color: #c2410c;
  }
  .rvc-call-paren {
    font-weight: 600;
    color: color-mix(in srgb, #c2410c 75%, var(--sl-color-gray-3, #64748b));
  }
  .rvc-also {
    margin: 0;
    font-size: 0.6rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--sl-color-gray-3, #64748b);
  }

  .rvc-cell--deletes {
    font-weight: 600;
    color: var(--sl-color-gray-2, #475569);
  }

  /* ── the fate pill: survives (green) vs killed (red) ── */
  .rvc-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    align-self: flex-start;
    margin: 0;
    padding: 3px 10px 3px 7px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .rvc-pill-icon {
    display: inline-flex;
    width: 0.92em;
    height: 0.92em;
  }
  .rvc-pill-icon svg {
    width: 100%;
    height: 100%;
  }
  .rvc-pill[data-fate='untouched'],
  .rvc-pill[data-fate='survives'] {
    color: #15803d;
    background: color-mix(in srgb, #16a34a 15%, var(--sl-color-bg, transparent));
    border: 1px solid color-mix(in srgb, #16a34a 40%, transparent);
  }
  .rvc-pill[data-fate='dies'] {
    color: #b91c1c;
    background: color-mix(in srgb, #dc2626 14%, var(--sl-color-bg, transparent));
    border: 1px solid color-mix(in srgb, #dc2626 42%, transparent);
  }
  .rvc-fate-note {
    margin: 0;
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-gray-2, #475569);
  }
  .rvc-row[data-fate='dies'] .rvc-fate-note {
    color: #b91c1c;
  }

  /* ── Where you land ── */
  .rvc-cell--lands {
    font-weight: 700;
    color: var(--sl-color-gray-2, #475569);
  }
  .rvc-route {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    align-self: flex-start;
  }
  .rvc-route-arrow {
    color: #b91c1c;
    font-weight: 800;
  }
  .rvc-route code {
    margin: 0;
    padding: 1px 7px;
    border-radius: 6px;
    font-size: 0.68rem;
    font-weight: 700;
    background: color-mix(in srgb, #dc2626 12%, var(--sl-color-bg, transparent));
    color: #b91c1c;
    border: 1px solid color-mix(in srgb, #dc2626 32%, transparent);
  }

  /* ── the button copy: a faux button tinted by the fate, the guardrail ── */
  .rvc-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    margin: 0;
    padding: 5px 12px;
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-gray-1, #334155);
    background: var(--sl-color-gray-6, #e2e8f0);
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
  }
  /* the "you go" copy wears the red edge — the destructive-to-self control */
  .rvc-btn[data-fate='dies'] {
    color: #b91c1c;
    background: color-mix(in srgb, #dc2626 10%, var(--sl-color-bg, transparent));
    border-color: color-mix(in srgb, #dc2626 38%, var(--sl-color-gray-5, #cbd5e1));
  }

  /* ── narrow viewports: the grid stops being a grid; each call becomes a
        stacked card with inline "label: value" rows, the fate row elevated. ── */
  @media (max-width: 640px) {
    .rvc-grid {
      display: flex;
      flex-direction: column;
      gap: 10px;
      border: none;
      background: transparent;
      overflow: visible;
    }
    /* hide the column-header row — labels move inline per cell */
    .rvc-row--head {
      display: none;
    }
    .rvc-row {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--sl-color-gray-5, #cbd5e1);
      border-radius: 11px;
      overflow: hidden;
      background: var(--sl-color-bg, transparent);
    }
    .rvc-cell {
      flex-direction: row;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-top: 1px solid var(--sl-color-gray-6, #e2e8f0);
    }
    .rvc-row .rvc-cell:first-child {
      border-top: none;
    }
    /* re-introduce the column name as an inline label before each value */
    .rvc-cell::before {
      flex: none;
      width: 7.5em;
      font-size: 0.56rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--sl-color-gray-3, #64748b);
    }
    .rvc-cell--call::before {
      content: 'Call';
    }
    .rvc-cell--deletes::before {
      content: 'Deletes';
    }
    .rvc-cell--fate::before {
      content: 'Current session';
      color: #6d28d9;
    }
    .rvc-cell--lands::before {
      content: 'You land';
    }
    .rvc-cell--copy::before {
      content: 'Button copy';
    }
    /* the call cell keeps its own column so the "also by" note wraps under */
    .rvc-cell--call {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .rvc-cell--call .rvc-also {
      flex-basis: 100%;
      margin-left: 7.5em;
    }
    /* the fate stripe becomes a full-width tinted band at the top of each card */
    .rvc-cell[data-col='fate'] {
      border-left: none;
      border-right: none;
    }
  }
</style>
