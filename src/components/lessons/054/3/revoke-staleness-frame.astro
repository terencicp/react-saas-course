---
// revoke-staleness-frame — Chapter 054 Lesson 3, "Active sessions and revoke-across-devices".
//
// The section's load-bearing visual, one frame of the `revoke-staleness`
// DiagramSequence. Makes ONE surprising fact intuitive: revocation is eventually
// consistent, and the lag the user feels IS the cookie-cache window. The protagonist
// is the phone's cache band — a shaded stretch of time during which the phone keeps
// reading its cached decode and never asks the database, so it stays "signed in"
// even though the row is already gone.
//
// The frame is a fixed two-lane timeline over a shared horizontal time axis:
//   LAPTOP lane (top)  — where the user clicks revoke; the DELETE lands instantly.
//   PHONE  lane (bottom) — the revoked device; carries the cache band + the beats.
// Every step renders the SAME skeleton (axis, both lanes, the band, every beat dot)
// so the DiagramSequence stage sizes to the tallest step once and never reflows as
// the reader scrubs. Only the ACTIVE beat lights up per step, in the chapter palette,
// and a "database row" chip on the right flips from present → gone at t=0.
//
// The cache band stays FRESH (green-tinted) through steps 1–3, lapses (greyed, with
// the live edge marked) at step 4, and in step 6 the `disableCookieCache` variant
// shows the band removed entirely — the phone hits the DB on every read, so there is
// no staleness window at all.
//
// Chip + palette vocabulary is lifted from this lesson's siblings — session-row-
// anatomy.astro and Ch 054 L2's sessions-after-change.astro — same Starlight gray/bg
// vars (flips light/dark), same mid-tone accents, so the chapter's session figures
// read as one continuous visual language.
//
// Chapter palette:
//   violet  (#7c3aed) — the hinge: the revoke click (step 1)
//   orange  (#d97706) — the cookie cache / the un-cached DB read (steps 2, 4)
//   green   (#16a34a) — a live/fresh state, and the resolution (steps 3, 5, 6)
//   red     (#dc2626) — the moment the phone is bounced out (step 5 transition)
//
// Plain HTML + CSS, no interactivity — a static frame swapped by DiagramSequence, so
// per the diagrams index HTML+CSS is the right engine.

interface Props {
  step: number;
}

const { step } = Astro.props;

// ── derived per-step state ─────────────────────────────────────────────────
// The DELETE lands at t=0 (step 1 on), so the DB row is gone from step 1 onward.
const rowGone = step >= 1;

// The cache band is fresh while the phone reads it (1–3); it lapses at step 4–5;
// in the disableCookieCache variant (6) there is no band at all.
const bandState: 'fresh' | 'lapsed' | 'none' =
  step >= 6 ? 'none' : step >= 4 ? 'lapsed' : 'fresh';

// Which beat is the active (lit) one this frame. Beats live at fixed x positions
// on the phone lane so the timeline never shifts.
//   'revoke'  — t=0, the click (violet), drawn on the LAPTOP lane
//   'hold'    — t=0, the cache still holds (orange), left edge of the band
//   'cached'  — t<expiry, phone reads cache (green), inside the band
//   'dbread'  — t=expiry, the un-cached read finds nothing (orange), band's end
//   'out'     — t=expiry, phone bounced to /sign-in (red→green), past the band
const activeBeat =
  step === 1
    ? 'revoke'
    : step === 2
      ? 'hold'
      : step === 3
        ? 'cached'
        : step === 4
          ? 'dbread'
          : step === 5
            ? 'out'
            : 'nocache'; // step 6 lights the whole phone lane as direct-to-DB

const palette =
  step === 1
    ? 'violet'
    : step === 2 || step === 4
      ? 'orange'
      : step === 5
        ? 'resolve' // red→green
        : 'green'; // 3 and 6

// the time label that anchors this frame, shown on the axis
const tLabel =
  step <= 2
    ? 't = 0'
    : step === 3
      ? 't < 5 min'
      : step <= 5
        ? 't = cache expiry'
        : 'every read';
---

<div class="rsf" data-palette={palette} data-band={bandState}>
  {/* ── the database-row state chip (top-right): present → gone at t=0 ── */}
  <div class="rsf-db" data-gone={rowGone ? '' : undefined}>
    <span class="rsf-db-icon" aria-hidden="true">
      {/* a tiny stacked-disks database glyph */}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <ellipse cx="12" cy="5" rx="8" ry="3"></ellipse>
        <path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5"></path>
        <path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6"></path>
      </svg>
    </span>
    <span class="rsf-db-text">
      <span class="rsf-db-title">session row</span>
      <span class="rsf-db-state">{rowGone ? 'deleted' : 'present'}</span>
    </span>
  </div>

  {/* ── the two-lane timeline ── */}
  <div class="rsf-grid">
    {/* LAPTOP lane — where revoke is clicked; the DELETE lands here at t=0 */}
    <div class="rsf-lanename">Laptop</div>
    <div class="rsf-lane rsf-lane--laptop">
      <span class="rsf-rail"></span>
      <span
        class="rsf-beat rsf-beat--revoke"
        data-active={activeBeat === 'revoke' ? '' : undefined}
      >
        <span class="rsf-beat-dot"></span>
        <span class="rsf-beat-label">revoke clicked · <code>delete</code></span>
      </span>
    </div>

    {/* PHONE lane — the revoked device; carries the cache band + the beats */}
    <div class="rsf-lanename">Phone</div>
    <div class="rsf-lane rsf-lane--phone">
      <span class="rsf-rail"></span>

      {/* the cookie-cache window — the protagonist. Spans t=0 → cache expiry. */}
      {
        bandState !== 'none' && (
          <span class="rsf-band">
            <span class="rsf-band-label">
              cookie-cache window{bandState === 'lapsed' ? ' — lapsed' : ''}
            </span>
          </span>
        )
      }

      {/* beat: cache still holds (left edge, t=0) */}
      <span
        class="rsf-beat rsf-beat--hold"
        data-active={activeBeat === 'hold' ? '' : undefined}
      >
        <span class="rsf-beat-dot"></span>
        <span class="rsf-beat-label">cache still holds</span>
      </span>

      {/* beat: phone reads the cache (mid-band, t<expiry) */}
      <span
        class="rsf-beat rsf-beat--cached"
        data-active={activeBeat === 'cached' ? '' : undefined}
      >
        <span class="rsf-beat-dot"></span>
        <span class="rsf-beat-label">reads cache, not the row</span>
      </span>

      {/* beat: the un-cached read hits the DB and finds nothing (band's end) */}
      <span
        class="rsf-beat rsf-beat--dbread"
        data-active={activeBeat === 'dbread' ? '' : undefined}
      >
        <span class="rsf-beat-dot"></span>
        <span class="rsf-beat-label">un-cached read → no row</span>
      </span>

      {/* beat: phone bounced to /sign-in (past the band) */}
      <span
        class="rsf-beat rsf-beat--out"
        data-active={activeBeat === 'out' ? '' : undefined}
      >
        <span class="rsf-beat-dot"></span>
        <span class="rsf-beat-label">→ <code>/sign-in</code></span>
      </span>

      {/* step-6 overlay: no cache → every read goes straight to the DB */}
      {
        bandState === 'none' && (
          <span class="rsf-direct" data-active="">
            <span class="rsf-direct-label">
              <code>disableCookieCache</code> — every read hits the database
            </span>
          </span>
        )
      }
    </div>

    {/* shared time axis under both lanes */}
    <div class="rsf-axisname">time</div>
    <div class="rsf-axis">
      <span class="rsf-axis-line"></span>
      <span class="rsf-axis-tick rsf-axis-tick--start">t = 0</span>
      <span class="rsf-axis-tick rsf-axis-tick--end">cache expiry</span>
      <span class="rsf-axis-now">{tLabel}</span>
    </div>
  </div>
</div>

<style>
  .rsf {
    --violet: #7c3aed;
    --orange: #d97706;
    --green: #16a34a;
    --red: #dc2626;

    position: relative;
    margin: 0;
    padding: 14px 14px 12px;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    /* the active accent for this frame, resolved from data-palette */
    --accent: var(--green);
  }
  .rsf[data-palette='violet'] {
    --accent: var(--violet);
  }
  .rsf[data-palette='orange'] {
    --accent: var(--orange);
  }
  .rsf[data-palette='green'] {
    --accent: var(--green);
  }
  .rsf[data-palette='resolve'] {
    --accent: var(--green);
  }

  /* ── the database-row state chip ─────────────────────────────────── */
  .rsf-db {
    position: absolute;
    top: 12px;
    right: 14px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 11px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
  }
  .rsf-db-icon {
    display: inline-flex;
    color: var(--sl-color-gray-3, #64748b);
  }
  .rsf-db-icon svg {
    width: 18px;
    height: 18px;
  }
  .rsf-db-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .rsf-db-title {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3, #64748b);
  }
  .rsf-db-state {
    font-size: 0.74rem;
    font-weight: 800;
    color: var(--green);
  }
  /* once the row is deleted: the chip greys, the glyph fades, the word turns red */
  .rsf-db[data-gone] {
    border-color: color-mix(in srgb, var(--red) 32%, var(--sl-color-gray-5, #cbd5e1));
    background: color-mix(in srgb, var(--red) 6%, var(--sl-color-bg, transparent));
  }
  .rsf-db[data-gone] .rsf-db-icon {
    color: color-mix(in srgb, var(--red) 55%, var(--sl-color-gray-4, #94a3b8));
    opacity: 0.7;
  }
  .rsf-db[data-gone] .rsf-db-state {
    color: var(--red);
  }

  /* ── the timeline grid: [name] [lane] across three rows ──────────── */
  .rsf-grid {
    display: grid;
    grid-template-columns: 58px 1fr;
    align-items: center;
    row-gap: 14px;
    column-gap: 12px;
    margin-top: 40px; /* clear the absolutely-positioned db chip */
  }
  .rsf-lanename,
  .rsf-axisname {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3, #64748b);
    text-align: right;
  }

  /* ── a lane: a horizontal rail with beats pinned at fixed x positions ── */
  .rsf-lane {
    position: relative;
    height: 56px;
  }
  .rsf-rail {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    transform: translateY(-50%);
    background: var(--sl-color-gray-5, #cbd5e1);
    border-radius: 2px;
  }
  .rsf-lane--phone .rsf-rail {
    /* the phone rail reads "live" while cached, dim after it's out */
    background: var(--sl-color-gray-5, #cbd5e1);
  }

  /* ── the cookie-cache window band on the phone lane ──────────────── */
  .rsf-band {
    position: absolute;
    left: 6%;
    right: 28%;
    top: 50%;
    height: 30px;
    transform: translateY(-50%);
    border-radius: 7px;
    border: 1px dashed color-mix(in srgb, var(--green) 50%, transparent);
    background: color-mix(in srgb, var(--green) 12%, var(--sl-color-bg, transparent));
    z-index: 0;
  }
  .rsf-band-label {
    position: absolute;
    top: -9px;
    left: 9px;
    padding: 0 5px;
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
    color: color-mix(in srgb, var(--green) 72%, var(--sl-color-white, #1e293b));
    background: var(--sl-color-bg, transparent);
  }
  /* lapsed: the band goes grey and a hard right edge marks where "live" ended */
  .rsf[data-band='lapsed'] .rsf-band {
    border-color: var(--sl-color-gray-4, #94a3b8);
    border-right-style: solid;
    border-right-width: 2px;
    background: color-mix(
      in srgb,
      var(--sl-color-gray-5, #cbd5e1) 30%,
      var(--sl-color-bg, transparent)
    );
  }
  .rsf[data-band='lapsed'] .rsf-band-label {
    color: var(--sl-color-gray-3, #64748b);
  }

  /* ── a beat: a dot on the rail + a label that clears the rail ────── */
  .rsf-beat {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 1;
    /* idle beats are quiet ghosts; the active one lights up */
    opacity: 0.42;
    transition: opacity 0.2s ease;
  }
  .rsf-beat[data-active] {
    opacity: 1;
  }
  .rsf-beat-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--sl-color-gray-5, #cbd5e1);
    border: 2px solid var(--sl-color-bg, #fff);
    box-shadow: 0 0 0 1px var(--sl-color-gray-4, #94a3b8);
  }
  .rsf-beat[data-active] .rsf-beat-dot {
    background: var(--accent);
    box-shadow:
      0 0 0 1px var(--accent),
      0 0 0 5px color-mix(in srgb, var(--accent) 22%, transparent);
  }
  .rsf-beat-label {
    position: absolute;
    width: max-content;
    max-width: 130px;
    font-size: 0.62rem;
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    color: var(--sl-color-gray-2, #475569);
  }
  .rsf-beat-label code {
    font-size: 0.92em;
    padding: 0 3px;
    border-radius: 4px;
    background: var(--sl-color-gray-6, #e2e8f0);
    color: var(--sl-color-gray-1, #334155);
  }
  .rsf-beat[data-active] .rsf-beat-label {
    color: var(--sl-color-white, #1e293b);
    font-weight: 700;
  }

  /* the laptop beat label sits ABOVE its rail; phone beats vary (see below) */
  .rsf-beat--revoke .rsf-beat-label {
    bottom: calc(50% + 12px);
  }
  /* phone beats: alternate above/below so labels never collide on the rail */
  .rsf-beat--hold .rsf-beat-label,
  .rsf-beat--dbread .rsf-beat-label {
    top: calc(50% + 12px);
  }
  .rsf-beat--cached .rsf-beat-label,
  .rsf-beat--out .rsf-beat-label {
    bottom: calc(50% + 12px);
  }

  /* ── fixed x positions for each beat (so the timeline never shifts) ── */
  .rsf-beat--revoke {
    left: 6%;
  }
  .rsf-beat--hold {
    left: 6%;
  }
  .rsf-beat--cached {
    left: 38%;
  }
  .rsf-beat--dbread {
    left: 72%;
  }
  .rsf-beat--out {
    left: 90%;
  }

  /* the active accent recolors each phone beat to its OWN role colour, so the
     palette reads even when several beats are near each other. */
  .rsf-beat--hold[data-active] .rsf-beat-dot,
  .rsf-beat--dbread[data-active] .rsf-beat-dot {
    background: var(--orange);
    box-shadow:
      0 0 0 1px var(--orange),
      0 0 0 5px color-mix(in srgb, var(--orange) 22%, transparent);
  }
  .rsf-beat--cached[data-active] .rsf-beat-dot {
    background: var(--green);
    box-shadow:
      0 0 0 1px var(--green),
      0 0 0 5px color-mix(in srgb, var(--green) 22%, transparent);
  }
  /* the "out" beat resolves red→green: a red core ringed in green */
  .rsf-beat--out[data-active] .rsf-beat-dot {
    background: var(--red);
    box-shadow:
      0 0 0 1px var(--red),
      0 0 0 5px color-mix(in srgb, var(--green) 30%, transparent);
  }

  /* ── step-6: the disableCookieCache overlay (no band, direct to DB) ── */
  .rsf-direct {
    position: absolute;
    left: 6%;
    right: 8%;
    top: 50%;
    height: 30px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 7px;
    border: 1px solid color-mix(in srgb, var(--green) 50%, transparent);
    background: color-mix(in srgb, var(--green) 12%, var(--sl-color-bg, transparent));
    z-index: 1;
  }
  .rsf-direct-label {
    font-size: 0.66rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--green) 70%, var(--sl-color-white, #1e293b));
  }
  .rsf-direct-label code {
    font-size: 0.94em;
    padding: 0 3px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--green) 16%, var(--sl-color-bg, transparent));
  }

  /* ── the shared time axis ────────────────────────────────────────── */
  .rsf-axis {
    position: relative;
    height: 22px;
  }
  .rsf-axis-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 4px;
    height: 2px;
    background: var(--sl-color-gray-5, #cbd5e1);
    border-radius: 2px;
  }
  .rsf-axis-line::before,
  .rsf-axis-line::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 7px;
    height: 7px;
    border-top: 2px solid var(--sl-color-gray-4, #94a3b8);
    border-right: 2px solid var(--sl-color-gray-4, #94a3b8);
  }
  .rsf-axis-line::after {
    right: 0;
    transform: translateY(-50%) rotate(45deg);
  }
  .rsf-axis-line::before {
    left: 0;
    transform: translateY(-50%) rotate(-135deg);
  }
  .rsf-axis-tick {
    position: absolute;
    top: 11px;
    font-size: 0.58rem;
    font-weight: 600;
    color: var(--sl-color-gray-3, #64748b);
    white-space: nowrap;
  }
  .rsf-axis-tick--start {
    left: 6%;
    transform: translateX(-50%);
  }
  .rsf-axis-tick--end {
    right: 0;
  }
  /* the moving "now" marker — the time label for the active frame */
  .rsf-axis-now {
    position: absolute;
    top: -3px;
    right: 0;
    padding: 1px 8px;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    white-space: nowrap;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, var(--sl-color-bg, transparent));
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
  }

  /* ── narrow viewports: tighten label widths, shrink lane names ────── */
  @media (max-width: 560px) {
    .rsf-grid {
      grid-template-columns: 44px 1fr;
      column-gap: 8px;
    }
    .rsf-beat-label {
      max-width: 96px;
      font-size: 0.56rem;
    }
    .rsf-lanename,
    .rsf-axisname {
      font-size: 0.54rem;
    }
  }
</style>
