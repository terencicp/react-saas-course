---
// new-device-loop — Chapter 054 Lesson 3, "Active sessions and revoke-across-devices".
//
// The closing synthesis figure. Makes "the list + the email" legible as a LOOP the
// student can see: the active-sessions list is detection ON DEMAND (there when the
// user thinks to look); the "new device signed in" email is detection THAT FINDS YOU
// (it arrives whether or not they're looking). Together they're one cycle — a fresh
// sign-in pushes a "wasn't you?" signal that pulls the user back to the list to shut
// the intruder out.
//
// Shape: a compact horizontal sequential phase strip (the html-css "timeline without
// parallelism" use case), built on the SAME idiom as this chapter's L1
// next-roundtrip-strip.astro — phase cards on one row joined by short inline-SVG
// arrows, wrapping to a stacked column on narrow viewports. The loop is closed by a
// labeled RETURN RAIL beneath the strip (robust HTML+CSS — a border line + an
// arrowhead, NOT fragile leader lines), arcing from the recovery node back to the
// list where the cycle began. The two halves are labeled: the forward run is the
// PUSH (the email), the return is the PULL (the list).
//
// The four nodes, left to right, in the chapter palette:
//   1. New sign-in writes a `session` row        — RED   (#dc2626) the unrecognized sign-in
//   2. databaseHooks.session.create.after fires   — AMBER (#d97706) the hook / library seam
//   3. "New device signed in" email sent          — neutral notify chrome (the push out)
//   4. Recover on the sessions list               — GREEN (#16a34a) revokeOtherSessions + reset
//
// Chapter palette (continuous with Ch 053 L4 / Ch 054 L1–L2 figures):
//   red    — the attacker / unrecognized-but-live sign-in   (#dc2626 / #b91c1c)
//   amber  — the library call / hook firing                 (#d97706 / #b45309)
//   green  — the recovery / a fresh safe state              (#16a34a / #15803d)
//   neutral chrome rides Starlight gray/bg vars so it flips light/dark.
//
// Plain HTML + CSS, no interactivity — a static phase strip, so per the diagrams
// index HTML+CSS is the right engine. `margin: 0` everywhere defeats Starlight's
// injected prose margins. Wrapped in <Figure> at the call site, where the caption
// lives.

// The four phases. `kind` selects the visual treatment:
//   'signin'  — the unrecognized sign-in (red)
//   'hook'    — the database hook firing (amber)
//   'email'   — the push notification (neutral notify chrome)
//   'recover' — the recovery on the list (green)
const phases = [
  {
    kind: 'signin',
    eyebrow: '3am · a stranger',
    name: 'New sign-in',
    value: 'writes a session row',
    sub: 'a new ipAddress + userAgent the user has never been seen with',
  },
  {
    kind: 'hook',
    eyebrow: 'the library seam',
    name: 'session.create.after',
    value: 'combo not seen before',
    sub: 'your code compares the new IP + UA against the prior rows',
  },
  {
    kind: 'email',
    eyebrow: 'the push out',
    name: '“New device signed in”',
    value: 'device · location · time',
    sub: 'carries a “This wasn’t me” call to action',
  },
  {
    kind: 'recover',
    eyebrow: 'the user acts',
    name: 'Recover on the list',
    value: 'revokeOtherSessions() + reset',
    sub: 'the “This wasn’t me” link lands them here and shuts the intruder out',
  },
];
---

<div class="ndl not-content">
  {/* the forward run: the PUSH — detection that finds you (the email) */}
  <p class="ndl-rail ndl-rail--push">
    <span class="ndl-rail-dot" data-push="" aria-hidden="true"></span>
    detection that finds you <span class="ndl-rail-em">— the email</span>
  </p>

  <div class="ndl-strip">
    {
      phases.map((phase, i) => (
        <>
          <div class:list={['ndl-cell', `ndl-${phase.kind}`]}>
            <span class="ndl-step" aria-hidden="true">
              {i + 1}
            </span>
            <span class="ndl-eyebrow">{phase.eyebrow}</span>
            <span class="ndl-name">{phase.name}</span>
            <code class="ndl-value">{phase.value}</code>
            <span class="ndl-sub">{phase.sub}</span>
          </div>
          {i < phases.length - 1 && (
            <span class="ndl-arrow" aria-hidden="true">
              <svg
                viewBox="0 0 34 14"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="2" y1="7" x2="28" y2="7" />
                <polyline points="23 2.5 29 7 23 11.5" />
              </svg>
            </span>
          )}
        </>
      ))
    }
  </div>

  {/* the return run: the PULL — detection on demand (the list). An arrowed rail
      that arcs from the recovery node back to the list where the cycle began. */}
  <div class="ndl-return" aria-hidden="true">
    <span class="ndl-return-head">
      <svg
        viewBox="0 0 14 34"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="7" y1="32" x2="7" y2="6" />
        <polyline points="2.5 11 7 5 11.5 11" />
      </svg>
    </span>
    <span class="ndl-return-line"></span>
    <span class="ndl-return-tail">
      <svg
        viewBox="0 0 14 34"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="7" y1="2" x2="7" y2="28" />
      </svg>
    </span>
  </div>
  <p class="ndl-rail ndl-rail--pull" aria-hidden="true">
    <span class="ndl-rail-dot" data-pull="" aria-hidden="true"></span>
    detection on demand <span class="ndl-rail-em">— the list</span>
  </p>
</div>

<style>
  .ndl {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── the two half-labels (push above, pull below) ─────────────────── */
  .ndl-rail {
    display: flex;
    align-items: center;
    gap: 7px;
    margin: 0;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2, #475569);
  }
  .ndl-rail--push {
    justify-content: flex-end;
    text-align: right;
  }
  .ndl-rail--pull {
    justify-content: flex-start;
  }
  .ndl-rail-em {
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.01em;
    color: var(--sl-color-gray-3, #64748b);
  }
  .ndl-rail-dot {
    flex: none;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    margin: 0;
  }
  /* push dot = amber (the email goes out); pull dot = green (the list pulls back) */
  .ndl-rail-dot[data-push] {
    background: #d97706;
    box-shadow: 0 0 0 3px color-mix(in srgb, #d97706 22%, transparent);
  }
  .ndl-rail-dot[data-pull] {
    background: #16a34a;
    box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 22%, transparent);
  }

  /* ── the forward phase strip ──────────────────────────────────────── */
  .ndl-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 12px 4px;
    margin: 0;
  }

  /* shared cell chrome — echoes L1's next-roundtrip-strip cell */
  .ndl-cell {
    box-sizing: border-box;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 4px;
    flex: 1 1 8.5rem;
    min-width: 0;
    max-width: 11rem;
    min-height: 8.5rem;
    padding: 11px 11px 10px;
    border-radius: 10px;
    margin: 0;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
  }

  /* the small ordinal in the corner */
  .ndl-step {
    position: absolute;
    top: 7px;
    right: 9px;
    margin: 0;
    font-size: 0.62rem;
    font-weight: 800;
    line-height: 1;
    color: var(--sl-color-gray-4, #94a3b8);
  }

  /* node 1 — the unrecognized sign-in. Red: hostile, but a live session. */
  .ndl-signin {
    border-color: color-mix(in srgb, #dc2626 55%, var(--sl-color-gray-5, #cbd5e1));
    background: color-mix(in srgb, #dc2626 9%, var(--sl-color-bg, transparent));
  }
  /* node 2 — the database hook firing. Amber: the library seam / endpoint work. */
  .ndl-hook {
    border-color: color-mix(in srgb, #d97706 58%, var(--sl-color-gray-5, #cbd5e1));
    background: color-mix(in srgb, #d97706 10%, var(--sl-color-bg, transparent));
  }
  /* node 3 — the email. Neutral notify chrome: the push out, not a verdict. */
  .ndl-email {
    border-style: dashed;
    border-color: var(--sl-color-gray-4, #94a3b8);
    background: color-mix(
      in srgb,
      var(--sl-color-gray-6, #e2e8f0) 32%,
      var(--sl-color-bg, transparent)
    );
  }
  /* node 4 — recovery on the list. Green: the intruder is shut out. */
  .ndl-recover {
    border-color: color-mix(in srgb, #16a34a 58%, var(--sl-color-gray-5, #cbd5e1));
    background: color-mix(in srgb, #16a34a 10%, var(--sl-color-bg, transparent));
  }

  .ndl-eyebrow {
    margin: 0;
    padding-right: 1rem; /* clear the ordinal */
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3, #64748b);
  }
  .ndl-signin .ndl-eyebrow {
    color: #b91c1c;
  }
  .ndl-hook .ndl-eyebrow {
    color: #b45309;
  }
  .ndl-recover .ndl-eyebrow {
    color: #15803d;
  }

  .ndl-name {
    margin: 1px 0 0;
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.18;
    color: var(--sl-color-white, #1e293b);
  }
  .ndl-signin .ndl-name {
    color: #b91c1c;
  }
  .ndl-hook .ndl-name {
    color: #b45309;
  }
  .ndl-recover .ndl-name {
    color: #15803d;
  }

  /* the concrete value carried at this phase — transparent so it isn't a prose
     pill stealing width; wraps freely rather than forcing the cell wider. */
  .ndl-value {
    margin: 3px 0 0;
    padding: 0;
    background: transparent;
    font-family:
      var(
        --__sl-font-mono,
        ui-monospace,
        SFMono-Regular,
        Menlo,
        Consolas,
        monospace
      );
    font-size: 0.68rem;
    line-height: 1.3;
    color: var(--sl-color-text, #334155);
    overflow-wrap: anywhere;
  }

  .ndl-sub {
    margin: auto 0 0;
    padding-top: 6px;
    font-size: 0.68rem;
    line-height: 1.3;
    color: var(--sl-color-gray-2, #475569);
  }

  /* the short forward arrows between cells */
  .ndl-arrow {
    align-self: center;
    flex: 0 0 auto;
    display: inline-flex;
    margin: 0;
    color: var(--sl-color-gray-3, #64748b);
  }
  .ndl-arrow svg {
    width: 30px;
    height: 13px;
  }

  /* ── the return rail: closes the loop back to the list ────────────── */
  .ndl-return {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 2px 0 0;
    height: 22px;
  }
  /* up-arrow head on the LEFT — points back up into node 1 (the list / sign-in) */
  .ndl-return-head {
    flex: none;
    display: inline-flex;
    align-items: flex-start;
    width: 14px;
    color: #16a34a;
  }
  .ndl-return-head svg {
    width: 14px;
    height: 100%;
  }
  /* the long horizontal return line, drawn as a top-border under the strip */
  .ndl-return-line {
    flex: 1 1 auto;
    align-self: flex-start;
    height: 0;
    margin: 6px 0 0;
    border-top: 2px dashed color-mix(in srgb, #16a34a 55%, var(--sl-color-gray-4, #94a3b8));
  }
  /* the tail drop on the RIGHT — descends from node 4 (recovery) into the line */
  .ndl-return-tail {
    flex: none;
    display: inline-flex;
    align-items: flex-start;
    width: 14px;
    color: color-mix(in srgb, #16a34a 55%, var(--sl-color-gray-4, #94a3b8));
  }
  .ndl-return-tail svg {
    width: 14px;
    height: 100%;
  }

  /* ── narrow viewports: stack the strip, rotate forward arrows down,
        and collapse the return rail into a simple labeled loop-back. ─── */
  @media (max-width: 640px) {
    .ndl-strip {
      flex-direction: column;
      align-items: center;
      gap: 0;
    }
    .ndl-cell {
      flex: 0 0 auto;
      width: 100%;
      max-width: 21rem;
      min-height: 0;
    }
    .ndl-sub {
      margin: 4px 0 0;
    }
    .ndl-arrow {
      transform: rotate(90deg);
      margin: 5px 0;
    }
    .ndl-rail--push {
      justify-content: flex-start;
      text-align: left;
    }
    /* the horizontal return rail doesn't read when stacked — hide the line,
       keep the labeled "pull" rail so the loop is still named. */
    .ndl-return {
      display: none;
    }
  }
</style>
