---
// session-row-anatomy — Chapter 054 Lesson 3, "Active sessions and revoke-across-devices".
//
// The per-row UX figure. Makes two facts single-glance:
//   (1) two opaque columns — `userAgent` + `ipAddress` — plus the cookie's `token`
//       become a row a human can audit ("Chrome on macOS · San Francisco · 2 min ago");
//   (2) the session reading this page is special and GUARDED — it carries a violet
//       "This device" badge and has no per-row Sign out, so the user can't boot
//       themselves out by accident.
//
// The callout layer is provenance-by-marker, not leader lines (those are fragile and
// the diagrams index reserves them for ArrowDiagram). Each traceable token in the
// chips wears a distinct underline marker; a compact source map below ties every
// marker back to the column it came from. So the "annotation" is robust HTML+CSS.
//
// The chip vocabulary is lifted from this lesson's siblings — Ch 054 L2's
// sessions-after-change.astro and Ch 053 L4's sessions-after-reset.astro — same chip
// shape (name + sub + state pill, grid areas), same Starlight gray/bg vars so it
// flips light/dark, same mid-tone accents. The three Ch 054 figures read as one
// continuous visual language.
//
// Chapter palette:
//   neutral — a plain live session            (Starlight gray vars)
//   green   — a live session / live state pill (#16a34a / #15803d)
//   violet  — the hinge / load-bearing move    (#7c3aed) — here: current-session
//             detection (the "This device" badge + the token-match callout)
//   amber   — a soft recognition flag          (#d97706) — here: the "you're in
//             Boston, why does it say Bangalore?" location token, flagged not alarmed
//
// Plain HTML + CSS, no interactivity — a static annotated illustration, so per the
// diagrams index HTML+CSS is the right engine. Wrapped in <Figure> at the call site;
// the caption lives there.

type Source = 'ua' | 'ip' | 'time' | 'token';

type Token = {
  text: string;
  source?: Source; // which column this span traces back to (drives the marker)
  flag?: boolean; // the soft amber recognition flag (the "Bangalore" moment)
};

type Row = {
  // the human row, as three traceable tokens: device · location · recency
  device: Token;
  location: Token;
  recency: Token;
  current?: boolean; // the session reading this page — badged + guarded
};

const ROWS: Row[] = [
  {
    device: { text: 'Chrome on macOS', source: 'ua' },
    location: { text: 'San Francisco', source: 'ip' },
    recency: { text: 'last active 2 min ago', source: 'time' },
    current: true,
  },
  {
    device: { text: 'Safari on iPhone' },
    location: { text: 'San Francisco' },
    recency: { text: 'last active 3 days ago' },
  },
  {
    device: { text: 'Firefox on Windows' },
    location: { text: 'Bangalore', flag: true },
    recency: { text: 'last active 1 hour ago' },
  },
];

// the source map under the chips — each marker ↔ the column it came from
const LEGEND: { source: Source; from: string; gloss: string }[] = [
  { source: 'ua', from: 'userAgent', gloss: 'the device text' },
  { source: 'ip', from: 'ipAddress', gloss: 'the location text' },
  { source: 'time', from: 'updatedAt', gloss: 'the “last active” time' },
  { source: 'token', from: 'token = cookie', gloss: 'marks “This device”' },
];
---

<div class="sra">
  <div class="sra-chips">
    {
      ROWS.map((row) => (
        <article class="sra-chip" data-current={row.current ? '' : undefined}>
          <span class="sra-chip-name">
            <span class="sra-tok" data-source={row.device.source}>
              {row.device.text}
            </span>
            <span class="sra-dot">·</span>
            <span
              class="sra-tok"
              data-source={row.location.source}
              data-flag={row.location.flag ? '' : undefined}
            >
              {row.location.text}
            </span>
          </span>

          <span class="sra-chip-sub">
            <span class="sra-tok" data-source={row.recency.source}>
              {row.recency.text}
            </span>
          </span>

          {row.current && (
            <span class="sra-badge" data-source="token">
              This device
            </span>
          )}

          <span class="sra-action">
            {row.current ? (
              <span class="sra-guard" aria-label="current session, guarded">
                <svg
                  class="sra-lock"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="4" y="11" width="16" height="9" rx="2" />
                  <path d="M8 11V7a4 4 0 0 1 8 0v4" />
                </svg>
                current session
              </span>
            ) : (
              <span class="sra-signout">Sign out</span>
            )}
          </span>
        </article>
      ))
    }
  </div>

  <div class="sra-map">
    <p class="sra-map-title">where each piece comes from</p>
    <ul class="sra-legend">
      {
        LEGEND.map((item) => (
          <li class="sra-legend-item">
            <span class="sra-swatch" data-source={item.source} />
            <code class="sra-col">{item.from}</code>
            <span class="sra-arrow" aria-hidden="true">
              →
            </span>
            <span class="sra-gloss">{item.gloss}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  .sra {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── the stacked session chips ──────────────────────────────────── */
  .sra-chips {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 11px 10px 12px;
    border-radius: 11px;
    border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
    background: color-mix(
      in srgb,
      var(--sl-color-gray-6, #e2e8f0) 28%,
      var(--sl-color-bg, transparent)
    );
  }

  /* a session chip echoes the sibling figures' .sar-chip / .sac-chip shape:
     name + sub on the left, a trailing action on the right. */
  .sra-chip {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'name   action'
      'sub    action';
    align-items: center;
    column-gap: 10px;
    row-gap: 2px;
    margin: 0;
    padding: 8px 11px;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
  }

  .sra-chip-name {
    grid-area: name;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 5px;
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--sl-color-white, #1e293b);
  }
  .sra-dot {
    color: var(--sl-color-gray-4, #94a3b8);
    font-weight: 600;
  }
  .sra-chip-sub {
    grid-area: sub;
    margin: 0;
    font-size: 0.62rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: 0.01em;
    color: var(--sl-color-gray-3, #64748b);
  }

  /* the violet "This device" badge — sits on the name row of the current chip */
  .sra-badge {
    flex: none;
    align-self: center;
    margin: 0;
    padding: 1px 8px;
    border-radius: 999px;
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    white-space: nowrap;
    color: #6d28d9;
    background: color-mix(in srgb, #7c3aed 14%, var(--sl-color-bg, transparent));
    border: 1px solid color-mix(in srgb, #7c3aed 42%, transparent);
  }

  /* ── traceable tokens: each wears a marker tied to its source column ── */
  .sra-tok {
    position: relative;
    padding-bottom: 1px;
    /* default token (rows 2 & 3, untraced): a flat neutral underline, so the
       row still reads as composed pieces without claiming a source. */
    box-shadow: inset 0 -2px 0 0 color-mix(in srgb, var(--sl-color-gray-4, #94a3b8) 40%, transparent);
  }
  .sra-tok[data-source='ua'] {
    box-shadow: inset 0 -2px 0 0 color-mix(in srgb, #2563eb 60%, transparent);
  }
  .sra-tok[data-source='ip'] {
    box-shadow: inset 0 -2px 0 0 color-mix(in srgb, #0d9488 62%, transparent);
  }
  .sra-tok[data-source='time'] {
    box-shadow: inset 0 -2px 0 0 color-mix(in srgb, #db2777 58%, transparent);
  }

  /* the soft amber recognition flag — the "you're in Boston" moment. A warning
     tint, deliberately NOT an alarm: faint background + amber underline. */
  .sra-tok[data-flag] {
    color: #b45309;
    font-weight: 800;
    border-radius: 3px;
    padding: 0 3px 1px;
    background: color-mix(in srgb, #d97706 13%, var(--sl-color-bg, transparent));
    box-shadow: inset 0 -2px 0 0 color-mix(in srgb, #d97706 60%, transparent);
  }

  /* ── the trailing action: Sign out, or the guarded current-session label ── */
  .sra-action {
    grid-area: action;
    justify-self: end;
    display: flex;
    align-items: center;
    margin: 0;
  }
  /* a faux "Sign out" button — looks like the per-row control the user clicks */
  .sra-signout {
    display: inline-flex;
    align-items: center;
    margin: 0;
    padding: 4px 12px;
    border-radius: 7px;
    font-size: 0.68rem;
    font-weight: 700;
    white-space: nowrap;
    color: var(--sl-color-gray-1, #334155);
    background: var(--sl-color-gray-6, #e2e8f0);
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
  }
  /* the guard: a lock + muted label, NOT a button — the current session can't be
     revoked from its own row without an explicit, differently-worded confirm. */
  .sra-guard {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin: 0;
    padding: 4px 11px;
    border-radius: 7px;
    font-size: 0.66rem;
    font-weight: 700;
    white-space: nowrap;
    color: #6d28d9;
    background: color-mix(in srgb, #7c3aed 9%, var(--sl-color-bg, transparent));
    border: 1px dashed color-mix(in srgb, #7c3aed 45%, var(--sl-color-gray-5, #cbd5e1));
  }
  .sra-lock {
    width: 0.82em;
    height: 0.82em;
    flex: none;
  }

  /* the current chip: a faint violet wash + violet edge, marking it apart */
  .sra-chip[data-current] {
    border-color: color-mix(in srgb, #7c3aed 48%, var(--sl-color-gray-5, #cbd5e1));
    background: color-mix(in srgb, #7c3aed 7%, var(--sl-color-bg, transparent));
  }

  /* ── the source map: marker ↔ column, the callout layer without leader lines ── */
  .sra-map {
    margin: 0;
    padding: 10px 12px 11px;
    border-radius: 10px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
  }
  .sra-map-title {
    margin: 0 0 7px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3, #64748b);
  }
  .sra-legend {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px 18px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .sra-legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.3;
    color: var(--sl-color-gray-2, #475569);
  }
  /* the swatch carries the same marker colour as the matching token underline */
  .sra-swatch {
    flex: none;
    width: 16px;
    height: 0;
    border-bottom: 3px solid var(--sl-color-gray-4, #94a3b8);
    border-radius: 2px;
  }
  .sra-swatch[data-source='ua'] {
    border-bottom-color: color-mix(in srgb, #2563eb 75%, transparent);
  }
  .sra-swatch[data-source='ip'] {
    border-bottom-color: color-mix(in srgb, #0d9488 78%, transparent);
  }
  .sra-swatch[data-source='time'] {
    border-bottom-color: color-mix(in srgb, #db2777 72%, transparent);
  }
  /* the token-match swatch is a small violet pill, echoing the "This device" badge */
  .sra-swatch[data-source='token'] {
    width: 16px;
    height: 10px;
    border: 1px solid color-mix(in srgb, #7c3aed 48%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, #7c3aed 16%, var(--sl-color-bg, transparent));
  }
  .sra-col {
    margin: 0;
    padding: 1px 6px;
    border-radius: 5px;
    font-size: 0.66rem;
    font-weight: 600;
    white-space: nowrap;
    background: var(--sl-color-gray-6, #e2e8f0);
    color: var(--sl-color-gray-1, #334155);
  }
  .sra-arrow {
    color: var(--sl-color-gray-4, #94a3b8);
    font-weight: 700;
  }
  .sra-gloss {
    color: var(--sl-color-gray-2, #475569);
  }

  /* ── narrow viewports: one-column legend, let chips breathe ── */
  @media (max-width: 560px) {
    .sra-legend {
      grid-template-columns: 1fr;
    }
  }
</style>
