---
// change-email-flow — Chapter 054 Lesson 2, "Changing the password and the email".
//
// The lesson's named load-bearing visual, and the direct counterpart to Ch 053
// L3's `verify-flow`: the change-email motion held as one scrubbable sequence.
//
// Shape: a horizontal pipeline strip of six stages. Scrubbing lights one stage at
// a time; stages already passed go to a muted "done" state so the reader feels
// forward motion, and the per-step caption carries the one-sentence "what's true
// now". The lit stage takes its PHASE colour from the chapter palette:
//
//   blue    — parse / config knob               (#2563eb)
//   orange  — library / endpoint work           (#ea580c)
//   violet  — the hinge: confirm on the address they're LEAVING  (#7c3aed)
//   green   — session / success                 (#16a34a)
//
// The pedagogical job is to make stage 3 — "confirm on the CURRENT address" — the
// visually dominant fact, AND that it's the opt-in, not the library default. So the
// violet hinge carries an extra "the opt-in, not the default" badge that rides along
// when it's the lit stage, lifting it above the others at a glance.
//
// Built as a thin wrapper that composes <DiagramSequence> + <DiagramStep> from a
// data array so the six near-identical strips aren't hand-repeated — the same shape
// as verify-flow, for one continuous visual vocabulary across the two lessons. Each
// step renders the SAME strip with a different active index; the strip styling lives
// once in scoped CSS. The captions are rich (inline <code>), so they go through the
// DiagramStep `caption` slot.
//
// Colours are mid-tones reused as-is in both themes; the neutral chrome rides
// Starlight gray/white vars so it flips light/dark. `not-content` (carried by
// DiagramSequence) opts the figure out of Starlight prose styling.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Phase = 'blue' | 'orange' | 'violet' | 'green';

// The fixed pipeline. `label` is the short strip glyph; `phase` is the colour the
// node takes when it's the active (lit) stage. `hinge` marks the one stage that gets
// the extra "opt-in, not the default" emphasis. Captions live on each step below.
const STAGES: { label: string; phase: Phase; hinge?: boolean }[] = [
	{ label: 'Submit\nnew email', phase: 'blue' },
	{ label: 'Mint token', phase: 'orange' },
	{ label: 'Confirm the\nCURRENT address', phase: 'violet', hinge: true },
	{ label: 'User clicks\nthe link', phase: 'orange' },
	{ label: 'Verify new,\nflip user.email', phase: 'green' },
	{ label: 'Notify both\naddresses', phase: 'green' },
];
---

<DiagramSequence>
	{
		STAGES.map((_, active) => (
			<DiagramStep>
				<div class="cef-strip" data-phase={STAGES[active].phase}>
					{STAGES.map((stage, i) => (
						<div
							class="cef-stage"
							data-state={i < active ? 'done' : i === active ? 'on' : 'todo'}
							data-phase={stage.phase}
							data-hinge={stage.hinge ? '' : undefined}
						>
							{stage.hinge && (
								<span class="cef-badge">the opt-in, not the default</span>
							)}
							<span class="cef-num">{i + 1}</span>
							<span class="cef-label">
								{stage.label.split('\n').map((line, k) => (
									<>
										{k > 0 && <br />}
										{line}
									</>
								))}
							</span>
						</div>
					))}
				</div>

				{/* Per-step caption — the "what's true now" sentence. */}
				<Fragment slot="caption">
					{active === 0 && (
						<>
							The user types the new address in <code>/settings/security</code>.
							The current email is shown <strong>read-only</strong>.
						</>
					)}
					{active === 1 && (
						<>
							A row appears in the same <code>verification</code> table as
							email-verification, under a different namespace —{' '}
							<code>{'change-email:<userId>:<newEmail>'}</code>.
						</>
					)}
					{active === 2 && (
						<>
							With <code>sendChangeEmailConfirmation</code> wired, the confirmation
							goes to the address they're <strong>leaving</strong> — proving they
							control the account <em>now</em>. The library's default skips this
							and verifies only the new inbox; turning it on is the deliberate
							choice that closes the takeover path.
						</>
					)}
					{active === 3 && (
						<>
							Out-of-band. The inbox they <strong>already own</strong> is the side
							channel — the same click-the-link motion as email verification.
						</>
					)}
					{active === 4 && (
						<>
							<code>user.email</code> flips to <code>newEmail</code> — but only
							after the current-inbox owner confirmed <em>and</em> the new inbox is
							verified.
						</>
					)}
					{active === 5 && (
						<>
							Your app sends a "your email was changed" notice to{' '}
							<strong>both</strong> old and new, carrying a{' '}
							<strong>"wasn't you?"</strong> escape hatch that revokes sessions and
							forces a reset.
						</>
					)}
				</Fragment>
			</DiagramStep>
		))
	}
</DiagramSequence>

<style>
	.cef-strip {
		--cef-on: var(--sl-color-gray-3, #64748b);
		display: flex;
		align-items: stretch;
		justify-content: center;
		flex-wrap: wrap;
		gap: 6px;
		padding: 18px 2px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The strip's accent is set by the active stage's phase, so connectors and the
	   lit node share one hue per step. */
	.cef-strip[data-phase='blue'] {
		--cef-on: #2563eb;
	}
	.cef-strip[data-phase='orange'] {
		--cef-on: #ea580c;
	}
	.cef-strip[data-phase='violet'] {
		--cef-on: #7c3aed;
	}
	.cef-strip[data-phase='green'] {
		--cef-on: #16a34a;
	}

	.cef-stage {
		position: relative;
		flex: 1 1 0;
		min-width: 84px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 6px;
		margin: 0;
		padding: 9px 5px 8px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			opacity 0.16s,
			transform 0.16s;
	}

	/* Connector tab between stages (drawn on the left edge, skipped on the first). */
	.cef-stage::before {
		content: '';
		position: absolute;
		left: -7px;
		top: 50%;
		width: 7px;
		height: 2px;
		transform: translateY(-50%);
		background: var(--sl-color-gray-5, #cbd5e1);
	}
	.cef-stage:first-child::before {
		display: none;
	}

	.cef-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 19px;
		height: 19px;
		flex: 0 0 auto;
		margin: 0;
		border-radius: 50%;
		font-size: 0.66rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		transition:
			color 0.16s,
			background-color 0.16s;
	}

	.cef-label {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 600;
		line-height: 1.22;
		color: var(--sl-color-gray-2, #475569);
		overflow-wrap: anywhere;
		transition: color 0.16s;
	}

	/* The hinge's "opt-in, not the default" badge — straddles the top border of the
	   violet stage. Hidden until that stage is the lit one, so it foregrounds the
	   beat exactly when the reader lands on it. */
	.cef-badge {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translate(-50%, -50%) scale(0.9);
		margin: 0;
		padding: 1px 7px;
		border-radius: 999px;
		font-size: 0.55rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1.3;
		white-space: nowrap;
		color: #fff;
		background: #7c3aed;
		box-shadow: 0 1px 4px color-mix(in srgb, #7c3aed 35%, transparent);
		opacity: 0;
		transition:
			opacity 0.16s,
			transform 0.16s;
		pointer-events: none;
	}

	/* ---- not yet reached ---- */
	.cef-stage[data-state='todo'] {
		opacity: 0.5;
	}

	/* ---- already passed: muted tint in that stage's own phase colour ---- */
	.cef-stage[data-state='done'][data-phase='blue'] {
		border-color: color-mix(in srgb, #2563eb 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.cef-stage[data-state='done'][data-phase='orange'] {
		border-color: color-mix(in srgb, #ea580c 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.cef-stage[data-state='done'][data-phase='violet'] {
		border-color: color-mix(in srgb, #7c3aed 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.cef-stage[data-state='done'][data-phase='green'] {
		border-color: color-mix(in srgb, #16a34a 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.cef-stage[data-state='done'] .cef-num {
		color: #fff;
		background: var(--sl-color-gray-4, #94a3b8);
	}
	.cef-stage[data-state='done'][data-phase='blue'] .cef-num {
		background: color-mix(in srgb, #2563eb 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.cef-stage[data-state='done'][data-phase='orange'] .cef-num {
		background: color-mix(in srgb, #ea580c 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.cef-stage[data-state='done'][data-phase='violet'] .cef-num {
		background: color-mix(in srgb, #7c3aed 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.cef-stage[data-state='done'][data-phase='green'] .cef-num {
		background: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.cef-stage[data-state='done']::before {
		background: var(--cef-on);
	}

	/* ---- the lit stage: full phase colour, lifted ---- */
	.cef-stage[data-state='on'] {
		border-color: var(--cef-on);
		border-width: 1.5px;
		background: color-mix(in srgb, var(--cef-on) 10%, var(--sl-color-bg, transparent));
		transform: translateY(-2px);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--cef-on) 22%, transparent);
	}
	.cef-stage[data-state='on'] .cef-num {
		color: #fff;
		background: var(--cef-on);
	}
	.cef-stage[data-state='on'] .cef-label {
		color: var(--sl-color-white, #1e293b);
	}

	/* The hinge stage, when lit, gets the dominant treatment: a fatter ring, a
	   stronger lift, and its badge revealed. This is the beat the diagram exists to
	   foreground. */
	.cef-stage[data-hinge][data-state='on'] {
		border-width: 2px;
		transform: translateY(-3px);
		box-shadow: 0 4px 16px color-mix(in srgb, #7c3aed 32%, transparent);
	}
	.cef-stage[data-hinge][data-state='on'] .cef-label {
		font-weight: 700;
	}
	.cef-stage[data-hinge][data-state='on'] .cef-badge {
		opacity: 1;
		transform: translate(-50%, -50%) scale(1);
	}

	/* Mobile: let the strip become two rows of compact chips that read left→right,
	   top→bottom. Connector tabs are hidden once wrapped so they don't dangle. */
	@media (max-width: 560px) {
		.cef-stage {
			flex: 1 1 40%;
			min-width: 0;
			flex-direction: row;
			justify-content: flex-start;
			gap: 7px;
			padding: 7px 8px;
			text-align: left;
		}
		.cef-stage::before {
			display: none;
		}
		.cef-label {
			font-size: 0.7rem;
		}
		/* On the wrapped layout the centred badge would collide with the row above;
		   pin it to the stage's top-right corner instead. */
		.cef-badge {
			left: auto;
			right: 6px;
			top: -7px;
			transform: scale(0.85);
		}
		.cef-stage[data-hinge][data-state='on'] .cef-badge {
			transform: scale(0.85);
		}
	}
</style>
