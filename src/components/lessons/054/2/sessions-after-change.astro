---
// sessions-after-change — Chapter 054 Lesson 2, "Changing the password and the email".
//
// The subsection climax: the reset↔change-from-settings symmetry made a single-
// glance fact. Two panels show the SAME account, with the SAME three starting
// sessions, the instant after a password change — and the ONLY thing that differs
// is which sessions survive, because reset can't trust the current session and
// change-from-settings can.
//
//   Left  ("Reset (unauthenticated)"):  all three old keys DEAD (struck-through,
//          grey) plus one fresh green "This device" the post-reset sign-in minted.
//          Caption: no current session to trust — everything dies, then sign in fresh.
//   Right ("Change from settings"):     "This device" stays GREEN/live (the session
//          you're using), the other two DEAD. The all-but-current disposition.
//
// The chip vocabulary is lifted from this lesson's sibling figure in Ch 053 L4
// (sessions-after-reset.astro) — same chip shape (live=neutral, dead=struck-through-
// grey, fresh/current=green) — so the two figures read as one continuous visual
// language, and both echo the Ch 052 session-table row styling.
//
// Chapter palette:
//   neutral — a plain live session   (Starlight gray vars)
//   green   — the surviving / fresh session  (#16a34a)  /  verdict (#15803d)
//
// Plain HTML + CSS, no interactivity — a static annotated illustration, so per the
// diagrams index HTML+CSS is the right engine. Mid-tone accents ride as-is in both
// themes; chrome rides Starlight gray/bg vars so it flips light/dark. The component
// is wrapped in <Figure> at the call site (the caption lives there).

type Chip = {
  label: string;
  sub: string;
};

// The three sessions the account already had before the change. Identical in both
// panels — the "This device" one is the session the user is actively using.
const OLD_KEYS: Chip[] = [
  { label: 'This device', sub: 'the session you are using' },
  { label: 'Phone', sub: 'old session' },
  { label: 'Old laptop', sub: 'old session' },
];
---

<div class="sac">
  {/* ── LEFT: reset — nothing to trust, everything dies ── */}
  <section class="sac-panel">
    <header class="sac-head">
      <span class="sac-verdict">Reset (unauthenticated)</span>
      <span class="sac-flag">
        <code>revokeSessionsOnPasswordReset: true</code>
      </span>
    </header>

    <div class="sac-stage">
      <p class="sac-tag">After the change</p>
      <div class="sac-chips">
        {
          OLD_KEYS.map((chip) => (
            <span class="sac-chip" data-dead="">
              <span class="sac-chip-name">{chip.label}</span>
              <span class="sac-chip-sub">{chip.sub}</span>
              <span class="sac-chip-state" data-dead="">
                revoked
              </span>
            </span>
          ))
        }
        <span class="sac-chip sac-chip--fresh">
          <span class="sac-chip-name">This device</span>
          <span class="sac-chip-sub">new session</span>
          <span class="sac-chip-state" data-live="">just signed in</span>
        </span>
      </div>
    </div>

    <p class="sac-foot">
      No current session to trust — <strong>everything</strong> dies, then the
      user signs in fresh.
    </p>
  </section>

  {/* ── RIGHT: change from settings — the current session survives ── */}
  <section class="sac-panel" data-verdict="good">
    <header class="sac-head">
      <span class="sac-verdict">Change from settings (authenticated)</span>
      <span class="sac-flag">
        <code>revokeOtherSessions: true</code>
      </span>
    </header>

    <div class="sac-stage">
      <p class="sac-tag">After the change</p>
      <div class="sac-chips">
        <span class="sac-chip sac-chip--fresh">
          <span class="sac-chip-name">This device</span>
          <span class="sac-chip-sub">the session you are using</span>
          <span class="sac-chip-state" data-live="">survives</span>
        </span>
        {
          OLD_KEYS.slice(1).map((chip) => (
            <span class="sac-chip" data-dead="">
              <span class="sac-chip-name">{chip.label}</span>
              <span class="sac-chip-sub">{chip.sub}</span>
              <span class="sac-chip-state" data-dead="">
                revoked
              </span>
            </span>
          ))
        }
      </div>
    </div>

    <p class="sac-foot">
      The session you are using <strong>survives</strong>; every other key is
      revoked.
    </p>
  </section>
</div>

<style>
  .sac {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 0;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── panel ──────────────────────────────────────────────────────── */
  .sac-panel {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 12px 12px 11px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
  }
  /* a hairline of the verdict colour up the left edge of each panel */
  .sac-panel {
    border-left: 3px solid color-mix(in srgb, #64748b 35%, var(--sl-color-gray-5, #cbd5e1));
  }
  .sac-panel[data-verdict='good'] {
    border-left: 3px solid color-mix(in srgb, #16a34a 70%, var(--sl-color-gray-5, #cbd5e1));
  }

  /* ── header: which flow + the one flag that decides the disposition ── */
  .sac-head {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin: 0;
  }
  .sac-verdict {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 1.2;
    color: var(--sl-color-gray-2, #475569);
  }
  .sac-panel[data-verdict='good'] .sac-verdict {
    color: #15803d;
  }
  .sac-flag {
    margin: 0;
  }
  .sac-flag code {
    display: inline-block;
    margin: 0;
    padding: 2px 7px;
    border-radius: 6px;
    font-size: 0.62rem;
    font-weight: 600;
    line-height: 1.3;
    white-space: nowrap;
    max-width: 100%;
    overflow-wrap: anywhere;
    background: var(--sl-color-gray-6, #e2e8f0);
    color: var(--sl-color-gray-2, #475569);
  }

  /* ── the chip stage ─────────────────────────────────────────────── */
  .sac-stage {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 9px 8px 10px;
    border-radius: 9px;
    border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
    background: color-mix(
      in srgb,
      var(--sl-color-gray-6, #e2e8f0) 28%,
      var(--sl-color-bg, transparent)
    );
  }
  .sac-tag {
    margin: 0;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3, #64748b);
  }

  .sac-chips {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin: 0;
  }

  /* a session chip echoes the Better Auth session-row styling — the same shape
     this chapter's reset figure uses, for one continuous vocabulary. */
  .sac-chip {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'name state'
      'sub  state';
    align-items: center;
    column-gap: 8px;
    row-gap: 0;
    margin: 0;
    padding: 6px 10px;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
  }
  .sac-chip-name {
    grid-area: name;
    margin: 0;
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-white, #1e293b);
  }
  .sac-chip-sub {
    grid-area: sub;
    margin: 0;
    font-size: 0.58rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: var(--sl-color-gray-3, #64748b);
  }

  /* the per-chip state pill: live or revoked */
  .sac-chip-state {
    grid-area: state;
    justify-self: end;
    margin: 0;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .sac-chip-state[data-live] {
    background: color-mix(in srgb, #16a34a 16%, var(--sl-color-bg, transparent));
    color: #15803d;
    border: 1px solid color-mix(in srgb, #16a34a 35%, transparent);
  }
  .sac-chip-state[data-dead] {
    background: var(--sl-color-gray-6, #e2e8f0);
    color: var(--sl-color-gray-3, #64748b);
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
  }

  /* DEAD: struck-through, greyed, flattened — the visible death */
  .sac-chip[data-dead] {
    border-color: var(--sl-color-gray-5, #cbd5e1);
    background: color-mix(
      in srgb,
      var(--sl-color-gray-6, #e2e8f0) 50%,
      var(--sl-color-bg, transparent)
    );
    opacity: 0.6;
  }
  .sac-chip[data-dead] .sac-chip-name {
    color: var(--sl-color-gray-3, #64748b);
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
  }
  .sac-chip[data-dead] .sac-chip-sub {
    color: var(--sl-color-gray-4, #94a3b8);
    text-decoration: line-through;
  }

  /* the surviving / fresh session: green, the one key that lives */
  .sac-chip--fresh {
    border-color: color-mix(in srgb, #16a34a 55%, var(--sl-color-gray-5, #cbd5e1));
    background: color-mix(in srgb, #16a34a 10%, var(--sl-color-bg, transparent));
  }
  .sac-chip--fresh .sac-chip-name {
    color: #15803d;
  }
  .sac-chip--fresh .sac-chip-sub {
    color: color-mix(in srgb, #16a34a 65%, var(--sl-color-gray-3, #64748b));
  }

  /* ── the panel's one-line verdict ── */
  .sac-foot {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.4;
    color: var(--sl-color-gray-2, #475569);
  }
  .sac-foot strong {
    color: var(--sl-color-white, #1e293b);
    font-weight: 800;
  }

  /* ── narrow viewports: stack the two panels ── */
  @media (max-width: 560px) {
    .sac {
      grid-template-columns: 1fr;
    }
  }
</style>
