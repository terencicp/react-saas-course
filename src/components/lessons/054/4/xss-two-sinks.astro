---
// xss-two-sinks — Chapter 054 Lesson 4, "CSRF and XSS: the defaults and the footguns".
//
// The XSS mental model made single-glance: the danger isn't the input, it's the
// SINK — the prop that receives it. The SAME attacker string sits on top of both
// panels; the only thing that changes between them is which prop it flows into, and
// that one choice decides harmless-vs-catastrophic.
//
//   Left  ("{value}"):                React escapes it → it lands in the DOM as
//          inert, literal text. The browser SHOWS the characters, never parses a
//          tag. Green chip: "inert — displayed as text".
//   Right ("dangerouslySetInnerHTML"): the string is injected as raw HTML → the
//          browser PARSES it, so a live <script> node appears and runs. Red chip:
//          "parsed as HTML — script runs".
//
// The chip + panel vocabulary is lifted from this chapter's sibling figures —
// Ch 054 L3 session-row-anatomy.astro / revoke-comparison.astro and Ch 053 L4
// sessions-after-reset.astro — same two-panel good/bad shape, the green/red verdict
// edge up the left of each panel, the `.sar-chip`-style status pill, the Starlight
// gray/bg vars so it flips light/dark, the same mid-tone green/red accents. The
// chapter's figures read as one continuous visual language.
//
// Chapter palette:
//   green   — the safe default / inert text   (#16a34a / #15803d)
//   red     — the footgun / the script runs   (#dc2626 / #b91c1c)
//   neutral — chrome, code, the input string  (Starlight gray vars)
//
// Plain HTML + CSS, no interactivity — a static annotated illustration, so per the
// diagrams index HTML+CSS is the right engine. Strings are held as JS so MDX/HTML
// escaping can't mangle the angle brackets. Wrapped in <Figure> at the call site
// (the caption lives there).

// The one attacker string, shown verbatim above BOTH panels. Held as a JS literal so
// the angle brackets render as text, not parsed markup.
const INPUT = '<script>steal()</script>';

// The escaped form React actually writes into the DOM for the safe sink — the
// HTML-significant characters turned into their inert entity equivalents.
const ESCAPED = '&lt;script&gt;steal()&lt;/script&gt;';
---

<div class="xts">
	{/* ── the shared input: the SAME string feeds both sinks ── */}
	<div class="xts-input">
		<span class="xts-input-tag">attacker types, into a comment box</span>
		<code class="xts-input-code">{INPUT}</code>
	</div>

	<div class="xts-fork" aria-hidden="true">
		<span class="xts-fork-arm xts-fork-arm--left"></span>
		<span class="xts-fork-label">same string, two sinks</span>
		<span class="xts-fork-arm xts-fork-arm--right"></span>
	</div>

	<div class="xts-panels">
		{/* ── LEFT: the safe sink ── */}
		<section class="xts-panel" data-verdict="good">
			<header class="xts-head">
				<span class="xts-head-tag">the sink</span>
				<code class="xts-sink">{'<div>'}<span class="xts-sink-hot">{'{value}'}</span>{'</div>'}</code>
			</header>

			<div class="xts-stage">
				<p class="xts-stage-tag">rendered DOM</p>
				<div class="xts-dom">
					<span class="xts-text" set:html={ESCAPED} />
				</div>
				<span class="sar-chip" data-tone="good">
					<span class="sar-chip-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
							<path d="M5 13l4 4L19 7"></path>
						</svg>
					</span>
					inert — displayed as text
				</span>
			</div>

			<p class="xts-foot">
				React escaped every character. The browser <strong>shows</strong> the tag, never parses it.
			</p>
		</section>

		{/* ── RIGHT: the dangerous sink ── */}
		<section class="xts-panel" data-verdict="bad">
			<header class="xts-head">
				<span class="xts-head-tag">the sink</span>
				<code class="xts-sink xts-sink--danger">{'<div '}<span class="xts-sink-hot">dangerouslySetInnerHTML</span>{'={{ __html: value }} />'}</code>
			</header>

			<div class="xts-stage">
				<p class="xts-stage-tag">rendered DOM</p>
				<div class="xts-dom">
					{/* a live, PARSED <script> node — depicted as a real DOM element */}
					<span class="xts-node">
						<span class="xts-node-tag">&lt;script&gt;</span>
						<span class="xts-node-body">steal()</span>
						<span class="xts-node-tag">&lt;/script&gt;</span>
						<span class="xts-node-run" aria-hidden="true">▶ runs</span>
					</span>
				</div>
				<span class="sar-chip" data-tone="bad">
					<span class="sar-chip-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round">
							<path d="M6 6l12 12M18 6L6 18"></path>
						</svg>
					</span>
					parsed as HTML — script runs
				</span>
			</div>

			<p class="xts-foot">
				The string was injected as raw HTML. The browser <strong>parses</strong> it — the script executes.
			</p>
		</section>
	</div>
</div>

<style>
	.xts {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── the shared input string, spanning the top ──────────────────────── */
	.xts-input {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 6px 12px;
		margin: 0;
		padding: 9px 13px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 32%,
			var(--sl-color-bg, transparent)
		);
	}
	.xts-input-tag {
		margin: 0;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.xts-input-code {
		margin: 0;
		padding: 3px 10px;
		border-radius: 7px;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.35;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-bg, transparent);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
	}

	/* ── the fork: one string splitting toward two sinks ── */
	.xts-fork {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 0;
		padding: 0 6px;
	}
	.xts-fork-arm {
		flex: 1;
		height: 0;
		margin: 0;
		border-top: 2px dashed var(--sl-color-gray-4, #94a3b8);
	}
	.xts-fork-label {
		flex: none;
		margin: 0;
		font-size: 0.58rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── the two panels, side by side ── */
	.xts-panels {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
		margin: 0;
	}

	.xts-panel {
		display: flex;
		flex-direction: column;
		gap: 9px;
		margin: 0;
		padding: 12px 12px 11px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
	}
	/* a hairline of the verdict colour up the left edge of each panel */
	.xts-panel[data-verdict='good'] {
		border-left: 3px solid color-mix(in srgb, #16a34a 70%, var(--sl-color-gray-5, #cbd5e1));
	}
	.xts-panel[data-verdict='bad'] {
		border-left: 3px solid color-mix(in srgb, #dc2626 70%, var(--sl-color-gray-5, #cbd5e1));
	}

	/* ── panel header: the sink prop the string flows into ── */
	.xts-head {
		display: flex;
		flex-direction: column;
		gap: 5px;
		margin: 0;
	}
	.xts-head-tag {
		margin: 0;
		font-size: 0.58rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.xts-sink {
		display: block;
		margin: 0;
		padding: 5px 9px;
		border-radius: 7px;
		font-size: 0.74rem;
		font-weight: 600;
		line-height: 1.4;
		overflow-wrap: anywhere;
		color: var(--sl-color-gray-1, #334155);
		background: var(--sl-color-gray-6, #e2e8f0);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
	}
	/* the dangerous sink wears a faint red edge — the prop IS the footgun */
	.xts-sink--danger {
		color: #b91c1c;
		background: color-mix(in srgb, #dc2626 9%, var(--sl-color-bg, transparent));
		border-color: color-mix(in srgb, #dc2626 38%, var(--sl-color-gray-5, #cbd5e1));
	}
	/* the receiving slot inside the sink, emphasised so the eye lands on it */
	.xts-sink-hot {
		font-weight: 800;
		color: var(--sl-color-white, #1e293b);
	}
	.xts-sink--danger .xts-sink-hot {
		color: #b91c1c;
	}

	/* ── the rendered-DOM stage: what the browser actually built ── */
	.xts-stage {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
		padding: 9px 9px 10px;
		border-radius: 9px;
		border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 28%,
			var(--sl-color-bg, transparent)
		);
	}
	.xts-stage-tag {
		margin: 0;
		font-size: 0.58rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.xts-dom {
		display: flex;
		align-items: center;
		min-height: 2.4em;
		margin: 0;
		padding: 7px 10px;
		border-radius: 7px;
		background: var(--sl-color-bg, transparent);
		border: 1px solid var(--sl-color-gray-6, #e2e8f0);
	}

	/* LEFT: the escaped string, rendered as plain inert text */
	.xts-text {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1.4;
		overflow-wrap: anywhere;
		color: var(--sl-color-gray-1, #334155);
	}

	/* RIGHT: a live, PARSED <script> node — a real DOM element the browser built */
	.xts-node {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0 6px;
		margin: 0;
		padding: 4px 8px;
		border-radius: 6px;
		font-size: 0.76rem;
		line-height: 1.35;
		background: color-mix(in srgb, #dc2626 10%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #dc2626 42%, transparent);
	}
	.xts-node-tag {
		margin: 0;
		font-weight: 800;
		color: #b91c1c;
	}
	.xts-node-body {
		margin: 0;
		font-weight: 700;
		color: color-mix(in srgb, #b91c1c 80%, var(--sl-color-gray-1, #334155));
	}
	.xts-node-run {
		margin: 0;
		padding: 1px 7px;
		border-radius: 999px;
		font-size: 0.58rem;
		font-weight: 800;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		white-space: nowrap;
		color: #fff;
		background: #dc2626;
	}

	/* ── the status pill — `.sar-chip` vocabulary, shared across the chapter ── */
	.sar-chip {
		display: inline-flex;
		align-items: center;
		align-self: flex-start;
		gap: 5px;
		margin: 0;
		padding: 3px 11px 3px 8px;
		border-radius: 999px;
		font-size: 0.64rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		white-space: nowrap;
	}
	.sar-chip-icon {
		display: inline-flex;
		width: 0.92em;
		height: 0.92em;
	}
	.sar-chip-icon svg {
		width: 100%;
		height: 100%;
	}
	.sar-chip[data-tone='good'] {
		color: #15803d;
		background: color-mix(in srgb, #16a34a 15%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #16a34a 40%, transparent);
	}
	.sar-chip[data-tone='bad'] {
		color: #b91c1c;
		background: color-mix(in srgb, #dc2626 14%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #dc2626 42%, transparent);
	}

	/* ── the panel's one-line verdict ── */
	.xts-foot {
		margin: 0;
		font-size: 0.72rem;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
	}
	.xts-foot strong {
		color: var(--sl-color-white, #1e293b);
		font-weight: 800;
	}
	.xts-panel[data-verdict='bad'] .xts-foot strong {
		color: #b91c1c;
	}

	/* ── narrow viewports: stack the two panels, drop the fork arms ── */
	@media (max-width: 560px) {
		.xts-panels {
			grid-template-columns: 1fr;
		}
		.xts-fork-arm {
			display: none;
		}
		.xts-fork {
			justify-content: center;
		}
	}
</style>
