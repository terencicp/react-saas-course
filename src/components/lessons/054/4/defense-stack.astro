---
// defense-stack — Chapter 054 Lesson 4, "CSRF and XSS: the defaults and the footguns".
//
// The lesson's closing synthesis, made single-glance: both vulnerabilities are the
// SAME shape — a stack of layers, every one safe by default, and beside each layer
// the one specific line of code that disables THAT layer and nothing else. The skill
// the whole lesson teaches is "point at a footgun in a diff, name the layer it turns
// off", and this figure is that skill drawn as a picture.
//
//   Left  column — CSRF (the REQUEST side), top to bottom:
//     SameSite=Lax cookie          → footgun: SameSite=None
//     __Host- (no Domain)          → footgun: Domain= added
//     Server Actions origin check  → footgun: widened allowedOrigins
//     requireUser validating read  → (no footgun — the always-on backstop)
//   Right column — XSS (the OUTPUT side), top to bottom:
//     React auto-escaping {value}  → footgun: unsanitized dangerouslySetInnerHTML
//     URL scheme validation        → footgun: raw href={userUrl}
//     HttpOnly cookie              → footgun: token in localStorage
//     CSP                          → (no footgun — the roof, built later in Ch 082)
//
// Read each column top to bottom: a green layer (safe, already on) and, across the
// gap, the red chip that punches through it. The two final rows carry a neutral chip
// instead of a red one — they have no footgun: requireUser is the backstop that always
// runs, CSP is the roof this lesson names but Chapter 082 configures.
//
// The chip + green/red verdict vocabulary is lifted from this chapter's sibling
// figures — Ch 054 L4 xss-two-sinks.astro, L3 revoke-comparison.astro /
// session-row-anatomy.astro — same `.sar-chip` status pill, the same mid-tone
// green/red accents, the Starlight gray/bg vars so it flips light/dark, margin:0 reset
// on inner elements. The chapter's figures read as one continuous visual language.
//
// Chapter palette:
//   green   — the safe default layer (already on)   (#16a34a / #15803d)
//   red     — the footgun chip (one line punches through) (#dc2626 / #b91c1c)
//   neutral — the no-footgun rows + chrome          (Starlight gray vars)
//
// Plain HTML + CSS, no interactivity — a static annotated illustration / nested
// hierarchy, so per the diagrams index HTML+CSS is the right engine. Two side-by-side
// column cards keep the whole thing horizontal and short for a laptop viewport.
// Wrapped in <Figure> at the call site (the caption lives there).

type Layer = {
  label: string; // the safe-by-default layer, green
  code?: string; // the inline code fragment inside the label, if any
  footgun?: string; // the red chip — the one line that disables THIS layer
  footgunCode?: string; // a code fragment inside the footgun chip, if any
  backstop?: string; // for the no-footgun rows: the neutral chip text instead
};

type Column = {
  track: string; // "CSRF" / "XSS"
  side: string; // "the request side" / "the output side"
  ask: string; // the one-line "this track asks…" gloss
  layers: Layer[];
};

const COLUMNS: Column[] = [
  {
    track: 'CSRF',
    side: 'the request side',
    ask: 'can another site make requests as your user?',
    layers: [
      {
        label: 'cookie attribute',
        code: 'SameSite=Lax',
        footgun: 'flip to',
        footgunCode: 'SameSite=None',
      },
      {
        label: 'cookie prefix',
        code: '__Host- (no Domain)',
        footgun: 'add',
        footgunCode: 'Domain=example.com',
      },
      {
        label: 'Server Actions origin check',
        footgun: 'widen',
        footgunCode: 'allowedOrigins',
      },
      {
        label: 'validating read',
        code: 'requireUser()',
        backstop: 'the always-on backstop',
      },
    ],
  },
  {
    track: 'XSS',
    side: 'the output side',
    ask: "can an attacker's input run as code?",
    layers: [
      {
        label: 'React auto-escaping',
        code: '{value}',
        footgun: 'unsanitized',
        footgunCode: 'dangerouslySetInnerHTML',
      },
      {
        label: 'URL scheme validation',
        footgun: 'raw',
        footgunCode: 'href={userUrl}',
      },
      {
        label: 'cookie flag',
        code: 'HttpOnly',
        footgun: 'token in',
        footgunCode: 'localStorage',
      },
      {
        label: 'Content Security Policy',
        backstop: 'the roof — built later',
      },
    ],
  },
];
---

<div class="dfs">
	{
		COLUMNS.map((col) => (
			<section class="dfs-col" data-track={col.track}>
				<header class="dfs-col-head">
					<span class="dfs-col-track">{col.track}</span>
					<span class="dfs-col-side">{col.side}</span>
					<span class="dfs-col-ask">{col.ask}</span>
				</header>

				{/* the column legend, shown once at the top of each stack */}
				<div class="dfs-legend" aria-hidden="true">
					<span class="dfs-legend-item dfs-legend-item--safe">
						safe by default
					</span>
					<span class="dfs-legend-item dfs-legend-item--footgun">
						the footgun
					</span>
				</div>

				<ol class="dfs-stack">
					{col.layers.map((layer) => (
						<li class="dfs-row" data-kind={layer.backstop ? 'backstop' : 'guarded'}>
							{/* LEFT: the green safe-default layer (already on) */}
							<span class="dfs-layer">
								<span class="dfs-layer-icon" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
										<path d="M5 13l4 4L19 7" />
									</svg>
								</span>
								<span class="dfs-layer-text">
									{layer.label}
									{layer.code && <code class="dfs-layer-code">{layer.code}</code>}
								</span>
							</span>

							{/* the gap the footgun punches through */}
							<span class="dfs-punch" aria-hidden="true">
								{layer.backstop ? '·' : '✕'}
							</span>

							{/* RIGHT: the red footgun chip, or a neutral no-footgun chip */}
							{layer.backstop ? (
								<span class="sar-chip" data-tone="neutral">
									{layer.backstop}
								</span>
							) : (
								<span class="sar-chip" data-tone="bad">
									<span class="sar-chip-icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round">
											<path d="M6 6l12 12M18 6L6 18" />
										</svg>
									</span>
									<span class="dfs-chip-text">
										{layer.footgun}
										{layer.footgunCode && <code class="dfs-chip-code">{layer.footgunCode}</code>}
									</span>
								</span>
							)}
						</li>
					))}
				</ol>
			</section>
		))
	}
</div>

<style>
	.dfs {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── one column = one vulnerability's defense stack ──────────────────── */
	.dfs-col {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
		padding: 13px 13px 14px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
	}

	/* ── column header: the track name + the question it answers ── */
	.dfs-col-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 3px 9px;
		margin: 0;
	}
	.dfs-col-track {
		margin: 0;
		font-size: 0.96rem;
		font-weight: 800;
		letter-spacing: 0.01em;
		color: var(--sl-color-white, #1e293b);
	}
	.dfs-col-side {
		margin: 0;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.dfs-col-ask {
		flex-basis: 100%;
		margin: 0;
		font-size: 0.72rem;
		font-weight: 500;
		font-style: italic;
		line-height: 1.35;
		color: var(--sl-color-gray-2, #475569);
	}

	/* ── the per-column legend, naming the two halves of each row once ── */
	.dfs-legend {
		display: flex;
		align-items: center;
		gap: 16px;
		margin: 0;
		padding: 0 2px;
	}
	.dfs-legend-item {
		position: relative;
		margin: 0;
		padding-left: 15px;
		font-size: 0.56rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
	.dfs-legend-item::before {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		width: 9px;
		height: 9px;
		margin-top: -4.5px;
		border-radius: 3px;
	}
	.dfs-legend-item--safe {
		color: #15803d;
	}
	.dfs-legend-item--safe::before {
		background: color-mix(in srgb, #16a34a 26%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #16a34a 55%, transparent);
	}
	.dfs-legend-item--footgun {
		color: #b91c1c;
	}
	.dfs-legend-item--footgun::before {
		background: color-mix(in srgb, #dc2626 22%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #dc2626 55%, transparent);
	}

	/* ── the stack: layers top to bottom ── */
	.dfs-stack {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.dfs-row {
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: center;
		gap: 7px;
		margin: 0;
		padding: 7px 8px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-6, #e2e8f0);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 24%,
			var(--sl-color-bg, transparent)
		);
	}

	/* ── LEFT: the green safe-default layer ── */
	.dfs-layer {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		min-width: 0;
		margin: 0;
		padding: 4px 9px 4px 7px;
		border-radius: 8px;
		background: color-mix(in srgb, #16a34a 11%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #16a34a 34%, transparent);
	}
	.dfs-layer-icon {
		display: inline-flex;
		flex: none;
		width: 0.92em;
		height: 0.92em;
		color: #16a34a;
	}
	.dfs-layer-icon svg {
		width: 100%;
		height: 100%;
	}
	.dfs-layer-text {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 2px 6px;
		min-width: 0;
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1.3;
		color: #15803d;
	}
	.dfs-layer-code {
		margin: 0;
		padding: 1px 6px;
		border-radius: 5px;
		font-size: 0.68rem;
		font-weight: 700;
		line-height: 1.3;
		overflow-wrap: anywhere;
		color: #15803d;
		background: color-mix(in srgb, #16a34a 14%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #16a34a 30%, transparent);
	}

	/* ── the gap the footgun punches through ── */
	.dfs-punch {
		flex: none;
		margin: 0;
		font-size: 0.66rem;
		font-weight: 800;
		line-height: 1;
		color: var(--sl-color-gray-4, #94a3b8);
	}
	.dfs-row[data-kind='guarded'] .dfs-punch {
		color: color-mix(in srgb, #dc2626 55%, var(--sl-color-gray-4, #94a3b8));
	}

	/* ── the status chip — `.sar-chip` vocabulary, shared across the chapter ── */
	.sar-chip {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		margin: 0;
		padding: 4px 10px 4px 8px;
		border-radius: 999px;
		font-size: 0.64rem;
		font-weight: 800;
		letter-spacing: 0.01em;
		line-height: 1.25;
	}
	.sar-chip-icon {
		display: inline-flex;
		flex: none;
		width: 0.88em;
		height: 0.88em;
	}
	.sar-chip-icon svg {
		width: 100%;
		height: 100%;
	}
	.sar-chip[data-tone='bad'] {
		color: #b91c1c;
		background: color-mix(in srgb, #dc2626 13%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #dc2626 42%, transparent);
	}
	.sar-chip[data-tone='neutral'] {
		font-weight: 700;
		font-style: italic;
		color: var(--sl-color-gray-2, #475569);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 55%,
			var(--sl-color-bg, transparent)
		);
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
	}
	.dfs-chip-text {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 2px 5px;
		min-width: 0;
	}
	.dfs-chip-code {
		margin: 0;
		padding: 0;
		font-size: 0.64rem;
		font-weight: 800;
		line-height: 1.25;
		overflow-wrap: anywhere;
		color: #b91c1c;
		background: none;
		border: none;
	}

	/* the no-footgun rows read calmer — neutral chrome, no red punch */
	.dfs-row[data-kind='backstop'] {
		border-style: dashed;
	}

	/* ── narrow viewports: the two stacks drop under each other, and each row
	      stacks its layer over its footgun so nothing is squeezed ── */
	@media (max-width: 640px) {
		.dfs {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 420px) {
		.dfs-row {
			grid-template-columns: 1fr;
			justify-items: start;
			gap: 5px;
		}
		.dfs-punch {
			display: none;
		}
	}
</style>
