---
// One frame of the async-submit timeline, used inside <DiagramSequence>.
// Shows the reducer's status machine (idle -> submitting -> saved, error
// returning to idle) moving as dispatches fire around a single await.
//
// The pedagogical point: the component re-renders into `submitting` (spinner
// on screen, button disabled) BEFORE the await resolves — exactly the moment
// the scattered five-useState version forgot to reset out of.
//
// `step` selects which frame to show.

interface Props {
  step: "submit" | "await" | "success" | "error";
}

const { step } = Astro.props;

// Which status pill is "current" in this frame. `error` returns the machine to
// `idle` (carrying submitError) — it is not a fourth status.
const currentStatus: "idle" | "submitting" | "saved" =
  step === "submit" || step === "await"
    ? "submitting"
    : step === "success"
      ? "saved"
      : "idle";

// Where the "now" marker sits along the timeline (0 = start, 1 = end).
const nowAt =
  step === "submit" ? 0 : step === "await" ? 0.5 : 1;

// ---- shared chrome ------------------------------------------------------

const wrap =
  "margin: 0; display: flex; flex-direction: column; gap: 16px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif); max-width: 640px; margin-inline: auto;";

// status pills
const pillBase = [
  "margin: 0",
  "padding: 7px 12px",
  "border-radius: 8px",
  "font-size: 13px",
  "font-weight: 600",
  "font-family: ui-monospace, SFMono-Regular, Menlo, monospace",
  "line-height: 1.2",
  "white-space: nowrap",
  "text-align: center",
  "box-sizing: border-box",
  "transition: opacity 200ms ease, transform 200ms ease, background-color 200ms ease, border-color 200ms ease, box-shadow 200ms ease",
].join("; ");

const pillIdle = `${pillBase}; border: 1px solid color-mix(in srgb, currentColor 16%, transparent); background: color-mix(in srgb, currentColor 5%, transparent); opacity: 0.4;`;

// active fills, colored by status family
const activeBlue =
  "border: 1.5px solid #0ea5e9; background: color-mix(in srgb, #0ea5e9 22%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #0ea5e9 16%, transparent); transform: translateY(-1px); opacity: 1;";
const activeGreen =
  "border: 1.5px solid #16a34a; background: color-mix(in srgb, #16a34a 22%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 16%, transparent); transform: translateY(-1px); opacity: 1;";
const activeAmber =
  "border: 1.5px solid #f59e0b; background: color-mix(in srgb, #f59e0b 22%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 16%, transparent); transform: translateY(-1px); opacity: 1;";

// For the error step, `idle` is current but carries an error — flag it amber.
const idleStyle =
  currentStatus === "idle"
    ? step === "error"
      ? `${pillBase}; ${activeAmber}`
      : `${pillBase}; ${activeBlue}`
    : pillIdle;
const submittingStyle =
  currentStatus === "submitting" ? `${pillBase}; ${activeBlue}` : pillIdle;
const savedStyle =
  currentStatus === "saved" ? `${pillBase}; ${activeGreen}` : pillIdle;

const arrowStyle =
  "margin: 0; color: currentColor; opacity: 0.35; font-size: 15px; line-height: 1; user-select: none; flex: 0 0 auto;";

// label above the arrow that names the action driving this transition
const dispatchTagBase =
  "margin: 0; font-size: 10.5px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; line-height: 1.1; white-space: nowrap; padding: 2px 5px; border-radius: 5px; box-sizing: border-box;";
const dispatchTagOn =
  "color: #16a34a; background: color-mix(in srgb, #16a34a 14%, transparent); border: 1px solid color-mix(in srgb, #16a34a 35%, transparent); opacity: 1;";
const dispatchTagOff =
  "color: currentColor; background: transparent; border: 1px solid transparent; opacity: 0.32;";

// which transition arrow is "lit" this frame
const submitArrowLit = step === "submit";
const resolveArrowLit = step === "success" || step === "error";

// ---- timeline -----------------------------------------------------------

const railStyle =
  "margin: 0; position: relative; height: 4px; border-radius: 2px; background: color-mix(in srgb, currentColor 14%, transparent);";
// the await span occupies the middle half of the rail
const awaitSpanStyle = `margin: 0; position: absolute; top: 0; left: 25%; width: 50%; height: 100%; border-radius: 2px; background: ${
  step === "await"
    ? "color-mix(in srgb, #0ea5e9 55%, transparent)"
    : "color-mix(in srgb, currentColor 22%, transparent)"
}; transition: background-color 200ms ease;`;

const tickStyle = (lit: boolean, color: string) =>
  `margin: 0; position: absolute; top: 50%; width: 11px; height: 11px; border-radius: 50%; transform: translate(-50%, -50%); box-sizing: border-box; border: 2px solid ${color}; background: ${
    lit ? color : "var(--sl-color-bg, #fff)"
  };`;

const nowStyle = `margin: 0; position: absolute; top: -7px; left: ${nowAt * 100}%; width: 2px; height: 18px; transform: translateX(-50%); background: #0ea5e9; border-radius: 1px; transition: left 220ms ease;`;

const timeLabel =
  "margin: 0; font-size: 10.5px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; line-height: 1.2; white-space: nowrap; opacity: 0.7;";

// ---- "on screen" status line -------------------------------------------

const screenNote =
  step === "submit"
    ? { dot: "#0ea5e9", text: "Button disabled, spinner shown — re-rendered already" }
    : step === "await"
      ? { dot: "#0ea5e9", text: "Still disabled, spinner still spinning — no re-render here" }
      : step === "success"
        ? { dot: "#16a34a", text: "Success UI shown" }
        : { dot: "#f59e0b", text: "Button re-enabled, error message shown" };

const screenRow =
  "margin: 0; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 12px; line-height: 1.3;";
const screenDot = `margin: 0; flex: 0 0 auto; width: 8px; height: 8px; border-radius: 50%; background: ${screenNote.dot};`;
const screenLabel = "margin: 0; font-weight: 600; opacity: 0.55; letter-spacing: 0.02em;";
---

<div style={wrap}>
  {/* State machine track */}
  <div
    style="margin: 0; display: flex; flex-direction: row; align-items: flex-end; justify-content: center; gap: 6px; min-height: 56px;"
  >
    <div style={idleStyle}>
      {step === "error" ? "idle + error" : "idle"}
    </div>

    {/* submit transition */}
    <div
      style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 3px; flex: 0 0 auto;"
    >
      <div style={`${dispatchTagBase}; ${submitArrowLit ? dispatchTagOn : dispatchTagOff}`}>
        {"dispatch('submit')"}
      </div>
      <div style={arrowStyle}>{"→"}</div>
    </div>

    <div style={submittingStyle}>submitting</div>

    {/* resolve transition */}
    <div
      style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 3px; flex: 0 0 auto;"
    >
      <div style={`${dispatchTagBase}; ${resolveArrowLit ? dispatchTagOn : dispatchTagOff}`}>
        {step === "error" ? "dispatch('error')" : "dispatch('success')"}
      </div>
      <div style={arrowStyle}>{"→"}</div>
    </div>

    <div style={savedStyle}>saved</div>
  </div>

  {/* Timeline rail: dispatch -> await -> resolve, with a "now" marker */}
  <div style="margin: 0; display: flex; flex-direction: column; gap: 6px;">
    <div style={railStyle}>
      <div style={awaitSpanStyle}></div>
      {/* start tick: the submit dispatch */}
      <div style={`${tickStyle(nowAt >= 0, "#0ea5e9")}; left: 0%;`}></div>
      {/* end tick: the resolving dispatch */}
      <div
        style={`${tickStyle(nowAt >= 1, resolveArrowLit ? (step === "error" ? "#f59e0b" : "#16a34a") : "#0ea5e9")}; left: 100%;`}
      ></div>
      <div style={nowStyle}></div>
    </div>
    <div style="margin: 0; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 8px;">
      <div style={`${timeLabel}; text-align: left;`}>{"dispatch('submit')"}</div>
      <div style={`${timeLabel}; text-align: center; opacity: 0.85;`}>{"await saveInvoice(…)"}</div>
      <div style={`${timeLabel}; text-align: right;`}>resolves</div>
    </div>
  </div>

  {/* What the user actually sees on screen this frame */}
  <div style={screenRow}>
    <span style={screenLabel}>ON SCREEN</span>
    <span style={screenDot}></span>
    <span style="margin: 0;">{screenNote.text}</span>
  </div>
</div>
