---
// useId vs Math.random across the server boundary (diagram id:
// useid-tree-position, Chapter 024 L6). A two-panel HTML+CSS figure that makes
// "same tree position -> same id -> no mismatch" land in one glance.
//
// Both panels draw the SAME two mini React trees, stacked: "Server render" and
// "Browser render". Each tree is a <App> root containing two leaf nodes, the
// second being <TextField>, highlighted. The trees are byte-for-byte identical
// across the two renders — that is the load-bearing fact the figure leans on:
// the only thing guaranteed the same on the server and the client is the shape
// of the tree.
//
//   Left panel  — useId. Under the highlighted <TextField> in BOTH trees we
//                 print the SAME opaque token «r1» in green. Caption ties it:
//                 same position -> same id -> no mismatch.
//   Right panel — Math.random(). Muted/greyed so it reads as the loser. Same
//                 two trees, but the highlighted node carries two DIFFERENT
//                 numbers — 0.81… on the server, 0.45… on the browser — in
//                 orange. Caption: different roll each run -> mismatch.
//
// «r1» is illustrative, not contractual (React 19.1's current guillemet
// format); the prose around the figure stays format-agnostic. Style follows
// this chapter-arc's StaleFrameSequence: fixed slate ink, color-scheme pinned
// light so the hand-picked green/orange tints survive dark mode, and `margin: 0`
// on every inner element to defeat Starlight's injected prose margins. The two
// panels are flex siblings that wrap to a stack on narrow figure cards.

import Figure from '../../../figures/Figure.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary node surface
const BORDER = '#cbd5e1'; // ordinary node edge (slate-300)
const RAIL = '#94a3b8'; // tree connector lines (slate-400)

const GREEN = '#16a34a'; // green-600 — the matching id (correct)
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800
const GREEN_PANEL = '#f0fdf4'; // green-50 — left panel wash

const ORANGE = '#d97706'; // amber-600 — the diverging roll (the smell)
const ORANGE_BG = '#fef3c7'; // amber-100
const ORANGE_INK = '#92400e'; // amber-800
const ORANGE_PANEL = '#fffbeb'; // amber-50 — right panel wash

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage: pinned light, slate ink, two panels side by side that wrap to a
// stack on narrow cards.
const stage = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 16px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// One panel (useId / Math.random). `accent` tints the border + header.
const panel = (accent: string, wash: string) =>
	`flex: 1 1 300px; min-width: 280px; max-width: 420px; display: flex; flex-direction: column; gap: 12px; margin: 0; padding: 14px; border: 1.5px solid ${accent}; border-radius: 14px; background: ${wash}; box-sizing: border-box;`;

// Panel header: a method name + a one-line "how the id is made".
const panelHead = `display: flex; flex-direction: column; gap: 2px; margin: 0; text-align: center;`;
const panelName = (accent: string) =>
	`margin: 0; font-family: ${mono}; font-size: 15px; font-weight: 700; line-height: 1.2; color: ${accent};`;
const panelSub = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 600; line-height: 1.25; color: ${INK_SOFT};`;

// The two-tree stack inside a panel.
const treeStack = `display: flex; flex-direction: column; gap: 10px; margin: 0;`;

// One labelled mini-tree: an eyebrow ("Server render"), then the tree itself.
const treeBlock = `display: flex; flex-direction: column; align-items: center; gap: 5px; margin: 0; padding: 9px 8px 11px; border: 1px solid ${BORDER}; border-radius: 10px; background: ${SURFACE};`;
const runLabel = `margin: 0; align-self: flex-start; font-family: ${sans}; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;

// A tree node pill. `tag` flag marks the highlighted <TextField> node.
const node = (accent: string, highlighted: boolean) =>
	`display: inline-flex; align-items: center; justify-content: center; margin: 0; padding: 3px 9px; font-family: ${mono}; font-size: 11.5px; font-weight: 700; line-height: 1.2; border-radius: 7px; white-space: nowrap; ` +
	(highlighted
		? `color: ${accent}; background: #ffffff; border: 1.5px solid ${accent}; box-shadow: 0 1px 4px ${accent}40;`
		: `color: ${INK_SOFT}; background: ${SURFACE}; border: 1px solid ${BORDER};`);

// The two-leaf row under the root, with little connector rails drawn via borders.
const leafRow = `display: flex; align-items: flex-start; justify-content: center; gap: 14px; margin: 0;`;
// A leaf cell: a short vertical rail, then the node, then (for TextField) the id.
const leafCell = `display: flex; flex-direction: column; align-items: center; gap: 4px; margin: 0;`;
const rail = `width: 1.5px; height: 9px; margin: 0; background: ${RAIL}; border-radius: 1px;`;

// The id chip printed under the highlighted node.
const idChip = (accent: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; margin: 1px 0 0; padding: 2px 8px; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.2; color: ${ink}; background: ${bg}; border: 1px solid ${accent}; border-radius: 6px; white-space: nowrap;`;

// The bottom verdict strip inside each panel.
const verdict = (accent: string, bg: string, ink: string) =>
	`margin: 0; padding: 7px 10px; font-family: ${sans}; font-size: 11.5px; font-weight: 700; line-height: 1.3; text-align: center; color: ${ink}; background: ${bg}; border: 1px solid ${accent}; border-radius: 8px;`;
---

<Figure caption="Both renders walk the same tree. useId reads the TextField's position, so it lands on the same id on the server and in the browser. Math.random ignores the tree and rolls a fresh number each run, so the two ids disagree and React reports a mismatch.">
	<div style={stage}>
		{/* ---- Left panel: useId — derived from tree position ---- */}
		<div style={panel(GREEN, GREEN_PANEL)}>
			<div style={panelHead}>
				<p style={panelName(GREEN)}>useId()</p>
				<p style={panelSub}>derived from tree position</p>
			</div>
			<div style={treeStack}>
				{/* Server render */}
				<div style={treeBlock}>
					<span style={runLabel}>Server render</span>
					<span style={node(GREEN, false)}>&lt;App&gt;</span>
					<div style={rail}></div>
					<div style={leafRow}>
						<div style={leafCell}>
							<span style={node(GREEN, false)}>&lt;Header&gt;</span>
						</div>
						<div style={leafCell}>
							<span style={node(GREEN, true)}>&lt;TextField&gt;</span>
							<span style={idChip(GREEN, GREEN_BG, GREEN_INK)}>id = &laquo;r1&raquo;</span>
						</div>
					</div>
				</div>
				{/* Browser render */}
				<div style={treeBlock}>
					<span style={runLabel}>Browser render</span>
					<span style={node(GREEN, false)}>&lt;App&gt;</span>
					<div style={rail}></div>
					<div style={leafRow}>
						<div style={leafCell}>
							<span style={node(GREEN, false)}>&lt;Header&gt;</span>
						</div>
						<div style={leafCell}>
							<span style={node(GREEN, true)}>&lt;TextField&gt;</span>
							<span style={idChip(GREEN, GREEN_BG, GREEN_INK)}>id = &laquo;r1&raquo;</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(GREEN, GREEN_BG, GREEN_INK)}>Same tree position &rarr; same id &rarr; no mismatch</p>
		</div>

		{/* ---- Right panel: Math.random() — rolled each run ---- */}
		<div style={panel(ORANGE, ORANGE_PANEL)}>
			<div style={panelHead}>
				<p style={panelName(ORANGE)}>Math.random()</p>
				<p style={panelSub}>rolled fresh each run</p>
			</div>
			<div style={treeStack}>
				{/* Server render */}
				<div style={treeBlock}>
					<span style={runLabel}>Server render</span>
					<span style={node(ORANGE, false)}>&lt;App&gt;</span>
					<div style={rail}></div>
					<div style={leafRow}>
						<div style={leafCell}>
							<span style={node(ORANGE, false)}>&lt;Header&gt;</span>
						</div>
						<div style={leafCell}>
							<span style={node(ORANGE, true)}>&lt;TextField&gt;</span>
							<span style={idChip(ORANGE, ORANGE_BG, ORANGE_INK)}>id = 0.81&hellip;</span>
						</div>
					</div>
				</div>
				{/* Browser render */}
				<div style={treeBlock}>
					<span style={runLabel}>Browser render</span>
					<span style={node(ORANGE, false)}>&lt;App&gt;</span>
					<div style={rail}></div>
					<div style={leafRow}>
						<div style={leafCell}>
							<span style={node(ORANGE, false)}>&lt;Header&gt;</span>
						</div>
						<div style={leafCell}>
							<span style={node(ORANGE, true)}>&lt;TextField&gt;</span>
							<span style={idChip(ORANGE, ORANGE_BG, ORANGE_INK)}>id = 0.45&hellip;</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(ORANGE, ORANGE_BG, ORANGE_INK)}>Different roll each run &rarr; mismatch</p>
		</div>
	</div>
</Figure>
