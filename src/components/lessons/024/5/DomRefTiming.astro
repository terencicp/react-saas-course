---
// DOM ref timing (diagram id: dom-ref-timing, Chapter 024 L5). A four-step
// scrubbable DiagramSequence that makes the temporal gap between *render runs*
// and *the node exists* felt — the gap that explains why a DOM ref is null in
// the render body and live only in effects/handlers.
//
// The case: <input ref={inputRef} />, walked through one render -> commit cycle.
// Every step shows the SAME two-lane stage so the grid stack never reflows:
//   - a "React" lane (top): the component function and the render pass.
//   - a "DOM / screen" lane (bottom): the real document.
//   - a persistent `inputRef.current` callout box on the right whose value is
//     the payload — it reads `null` until step 3, then points at the node.
// A tiny phase eyebrow per step ("render", "commit", "assign ref", "after
// commit") tells the reader which moment they are in.
//
//   Step 1  Render runs. React lane active; the component returns <input> JSX
//           (a faint, not-yet-real chip). DOM lane empty. ref.current = null,
//           and the caption nails that reading it HERE gets null.
//   Step 2  Commit. DOM lane lights up — the real <input> appears in the
//           document. ref.current still null (assignment is the next beat).
//   Step 3  React sets inputRef.current to the node. An arrow runs from the DOM
//           node up into the ref box; the box flips to <input> (green).
//   Step 4  Effects/handlers run. Both lanes settled, ref points at the node, a
//           .focus() call lands on the input — the only safe place to read it.
//
// Style mirrors this chapter-arc's StaleFrameSequence: color-scheme pinned light
// so the hand-picked slate/blue/green/amber tints survive dark mode, `margin: 0`
// on every inner element to defeat Starlight's injected prose margins, one fixed
// shape across steps. The component owns its DiagramSequence + steps so the MDX
// stays a single import. Why DiagramSequence + HTML/CSS (not ArrowDiagram): the
// teaching IS the transition between two parallel worlds over time, which the
// scrubber makes felt, and the one vertical connector in step 3 is a trivial
// absolutely-positioned element that needs no LeaderLine bookkeeping.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const BORDER = '#cbd5e1'; // ordinary chip edge (slate-300)
const DIM_BG = '#f1f5f9'; // inactive lane wash (slate-100)
const DIM_INK = '#94a3b8'; // inactive lane ink (slate-400)
const LANE_BG = '#f8fafc'; // a settled lane wash (slate-50)

const BLUE = '#2563eb'; // blue-600 — the React lane accent
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const GREEN = '#16a34a'; // green-600 — the live DOM / live ref accent
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const AMBER = '#d97706'; // amber-600 — the "null, do not read" warning
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all four steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: stretch; gap: 0; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK}; max-width: 460px; margin-inline: auto;`;

// The two-lane board: the React lane and DOM lane stacked, with the ref box to
// their right. A CSS grid keeps the lanes column aligned and the ref box fixed.
const board = `display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto auto; column-gap: 12px; row-gap: 10px; align-items: stretch; margin: 0;`;

// A lane card. `tone` lights it up (its accent) or leaves it dim/empty.
type Tone = 'idle' | 'blue' | 'green';
const lane = (tone: Tone) => {
	const base =
		'display: flex; flex-direction: column; gap: 7px; margin: 0; padding: 10px 12px; border-radius: 12px; min-height: 84px; box-sizing: border-box; transition: background 0.2s, border-color 0.2s;';
	if (tone === 'blue')
		return base + ` background: ${BLUE_BG}; border: 1.5px solid ${BLUE};`;
	if (tone === 'green')
		return base + ` background: ${GREEN_BG}; border: 1.5px solid ${GREEN};`;
	return base + ` background: ${DIM_BG}; border: 1px dashed ${BORDER};`;
};

// The lane's label row: an uppercase eyebrow naming the world.
const laneLabel = (tone: Tone) => {
	const ink = tone === 'blue' ? BLUE_INK : tone === 'green' ? GREEN_INK : DIM_INK;
	return `display: flex; align-items: center; gap: 6px; margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${ink};`;
};

// The contents row inside a lane.
const laneBody = `display: flex; align-items: center; flex-wrap: wrap; gap: 8px; margin: 0; min-height: 30px;`;

// A chip that lives inside a lane — the component fn, the JSX, the real node.
type ChipTone = 'blue' | 'green' | 'ghost';
const chip = (tone: ChipTone) => {
	if (tone === 'blue')
		return `display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 5px 10px; font-family: ${mono}; font-size: 12px; font-weight: 600; line-height: 1.3; border-radius: 8px; white-space: nowrap; color: ${BLUE_INK}; background: #ffffff; border: 1.5px solid ${BLUE};`;
	if (tone === 'green')
		return `display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 5px 10px; font-family: ${mono}; font-size: 12px; font-weight: 600; line-height: 1.3; border-radius: 8px; white-space: nowrap; color: ${GREEN_INK}; background: #ffffff; border: 1.5px solid ${GREEN};`;
	// ghost: a not-yet-real element — dashed, dim, italic note that it is only JSX.
	return `display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 5px 10px; font-family: ${mono}; font-size: 12px; font-weight: 500; line-height: 1.3; border-radius: 8px; white-space: nowrap; color: ${DIM_INK}; background: transparent; border: 1.5px dashed ${BORDER};`;
};

// The faint "empty" placeholder shown in a lane that has nothing yet.
const emptyNote = `margin: 0; font-family: ${sans}; font-size: 11px; font-style: italic; color: ${DIM_INK};`;

// The persistent ref box on the right: spans both lane rows so it reads as the
// box React is filling. Its border/fill flips green once it holds the node.
const refBox = (filled: boolean) =>
	`grid-row: 1 / 3; align-self: center; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; margin: 0; padding: 12px 12px; width: 124px; border-radius: 12px; box-sizing: border-box; transition: background 0.2s, border-color 0.2s; ` +
	(filled
		? `background: ${GREEN_BG}; border: 1.5px solid ${GREEN};`
		: `background: #ffffff; border: 1.5px solid ${AMBER};`);

const refName = `margin: 0; font-family: ${mono}; font-size: 11.5px; font-weight: 700; line-height: 1.2; color: ${INK};`;

// The value pill inside the ref box — amber `null`, green `<input>`.
const refValue = (filled: boolean) =>
	`display: inline-flex; align-items: center; margin: 0; padding: 3px 9px; font-family: ${mono}; font-size: 13px; font-weight: 700; line-height: 1.2; border-radius: 999px; white-space: nowrap; ` +
	(filled
		? `color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN};`
		: `color: ${AMBER_INK}; background: ${AMBER_BG}; border: 1px solid ${AMBER};`);

// The vertical arrow from the DOM node up into the ref box (step 3 only). Sits
// in the gap between the lane column and the ref box, pointing up-right.
const assignArrowWrap = `position: relative; grid-column: 1 / 3; grid-row: 1 / 3; pointer-events: none; margin: 0;`;
const assignArrow = `position: absolute; right: 130px; bottom: 26px; display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 3px 9px; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1; color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN}; border-radius: 999px; white-space: nowrap;`;

// A small status pill that rides in a lane label (e.g. "RUNNING", "COMMITTED").
const statusPill = (tone: 'blue' | 'green') =>
	`display: inline-flex; align-items: center; margin: 0; padding: 1px 6px; font-family: ${sans}; font-size: 8.5px; font-weight: 700; letter-spacing: 0.04em; border-radius: 999px; line-height: 1.3; ` +
	(tone === 'blue'
		? `color: ${BLUE_INK}; background: #ffffff; border: 1px solid ${BLUE};`
		: `color: ${GREEN_INK}; background: #ffffff; border: 1px solid ${GREEN};`);

// The phase eyebrow above the board, naming the moment in the cycle.
const phaseRow = `display: flex; align-items: center; justify-content: center; gap: 6px; margin: 0 0 9px; flex-wrap: wrap;`;
const phaseStep = (active: boolean, tone: Tone) => {
	const accent = tone === 'green' ? GREEN : BLUE;
	const ink = tone === 'green' ? GREEN_INK : BLUE_INK;
	return (
		`display: inline-flex; align-items: center; margin: 0; padding: 3px 9px; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.2; border-radius: 999px; white-space: nowrap; ` +
		(active
			? `color: ${ink}; background: ${tone === 'green' ? GREEN_BG : BLUE_BG}; border: 1.5px solid ${accent};`
			: `color: ${DIM_INK}; background: transparent; border: 1px solid ${BORDER};`)
	);
};
const phaseArrow = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; color: ${INK_SOFT};`;

// A focus() command landing on the input (step 4 only) — a green tag in the DOM
// lane showing the imperative call now works.
const focusTag = `display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 3px 9px; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN}; border-radius: 8px; white-space: nowrap;`;

// The four phase labels, reused per step with one active.
const phases = ['render runs', 'commit', 'assign ref', 'after commit'];
const phaseTone: Tone[] = ['blue', 'green', 'green', 'green'];

// Renders the shared phase eyebrow with `idx` active.
const phaseFor = (idx: number) =>
	phases.map((label, i) => ({
		label,
		active: i === idx,
		tone: phaseTone[i],
	}));
---

<DiagramSequence>
	{/* ---- Step 1: Render runs — ref is null in the render body ---- */}
	<DiagramStep caption="First render runs. The component function executes and returns the <input> JSX, but React hasn't put anything on screen yet — so inputRef.current is still null. Reading the ref here, in the render body, gets you null.">
		<div style={stage}>
			<div style={phaseRow}>
				{phaseFor(0).map((p, i) => (
					<Fragment key={i}>
						{i > 0 && <span style={phaseArrow} aria-hidden="true">&rarr;</span>}
						<span style={phaseStep(p.active, p.tone)}>{p.label}</span>
					</Fragment>
				))}
			</div>
			<div style={board}>
				<div style={lane('blue')}>
					<span style={laneLabel('blue')}>
						React <span style={statusPill('blue')}>RUNNING</span>
					</span>
					<div style={laneBody}>
						<span style={chip('blue')}>SearchBox()</span>
						<span style={phaseArrow} aria-hidden="true">&rarr;</span>
						<span style={chip('ghost')}>&lt;input&gt; JSX (not real yet)</span>
					</div>
				</div>
				<div style={refBox(false)}>
					<span style={refName}>inputRef.current</span>
					<span style={refValue(false)}>null</span>
				</div>
				<div style={lane('idle')}>
					<span style={laneLabel('idle')}>DOM / screen</span>
					<div style={laneBody}>
						<span style={emptyNote}>nothing on screen yet</span>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Commit — the real <input> appears in the document ---- */}
	<DiagramStep caption="React commits. It creates the real <input> element and inserts it into the document. Now there's an actual node — but the ref box hasn't been pointed at it yet.">
		<div style={stage}>
			<div style={phaseRow}>
				{phaseFor(1).map((p, i) => (
					<Fragment key={i}>
						{i > 0 && <span style={phaseArrow} aria-hidden="true">&rarr;</span>}
						<span style={phaseStep(p.active, p.tone)}>{p.label}</span>
					</Fragment>
				))}
			</div>
			<div style={board}>
				<div style={lane('idle')}>
					<span style={laneLabel('idle')}>React</span>
					<div style={laneBody}>
						<span style={emptyNote}>render done — committing to the DOM</span>
					</div>
				</div>
				<div style={refBox(false)}>
					<span style={refName}>inputRef.current</span>
					<span style={refValue(false)}>null</span>
				</div>
				<div style={lane('green')}>
					<span style={laneLabel('green')}>
						DOM / screen <span style={statusPill('green')}>COMMITTED</span>
					</span>
					<div style={laneBody}>
						<span style={chip('green')}>&lt;input&gt; real node</span>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: React sets inputRef.current to the node ---- */}
	<DiagramStep caption="React sets inputRef.current to the node. This happens after the commit — the box now points at the live <input>.">
		<div style={stage}>
			<div style={phaseRow}>
				{phaseFor(2).map((p, i) => (
					<Fragment key={i}>
						{i > 0 && <span style={phaseArrow} aria-hidden="true">&rarr;</span>}
						<span style={phaseStep(p.active, p.tone)}>{p.label}</span>
					</Fragment>
				))}
			</div>
			<div style={board}>
				<div style={lane('idle')}>
					<span style={laneLabel('idle')}>React</span>
					<div style={laneBody}>
						<span style={emptyNote}>filling the ref box</span>
					</div>
				</div>
				<div style={refBox(true)}>
					<span style={refName}>inputRef.current</span>
					<span style={refValue(true)}>&lt;input&gt;</span>
				</div>
				<div style={lane('green')}>
					<span style={laneLabel('green')}>DOM / screen</span>
					<div style={laneBody}>
						<span style={chip('green')}>&lt;input&gt; real node</span>
					</div>
				</div>
				<div style={assignArrowWrap} aria-hidden="true">
					<span style={assignArrow}>&uarr; assign node</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Effects/handlers run — the ref is safe to read ---- */}
	<DiagramStep caption="Effects and handlers run. From here on, inputRef.current is the live element — .focus(), .scrollTo(), .getBoundingClientRect() all work. This is the only place it's safe to read.">
		<div style={stage}>
			<div style={phaseRow}>
				{phaseFor(3).map((p, i) => (
					<Fragment key={i}>
						{i > 0 && <span style={phaseArrow} aria-hidden="true">&rarr;</span>}
						<span style={phaseStep(p.active, p.tone)}>{p.label}</span>
					</Fragment>
				))}
			</div>
			<div style={board}>
				<div style={lane('blue')}>
					<span style={laneLabel('blue')}>
						React <span style={statusPill('blue')}>EFFECTS / HANDLERS</span>
					</span>
					<div style={laneBody}>
						<span style={chip('blue')}>inputRef.current?.focus()</span>
					</div>
				</div>
				<div style={refBox(true)}>
					<span style={refName}>inputRef.current</span>
					<span style={refValue(true)}>&lt;input&gt;</span>
				</div>
				<div style={lane('green')}>
					<span style={laneLabel('green')}>DOM / screen</span>
					<div style={laneBody}>
						<span style={chip('green')}>&lt;input&gt; real node</span>
						<span style={focusTag}>&#9889; focused</span>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
