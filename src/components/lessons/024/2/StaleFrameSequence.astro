---
// Two renders, or one (diagram id: two-renders-or-one, Chapter 024 L2). A
// five-step scrubbable DiagramSequence that makes the cost of mirroring a value
// into state + syncing with an effect literally visible, then contrasts it with
// the single-render derived path.
//
// The keystroke: the user changes firstName from "Ada" to "Adam". The truth in
// the input updates immediately; the question the whole strip answers is when
// the <h1> (built from fullName) catches up.
//
//   Steps 1-4  the mirror-and-sync path. The phase strip shows the FULL run a
//              setState-in-effect forces — Render #1 -> Commit -> Effect ->
//              Render #2 -> Commit — i.e. TWO renders. The active phase lights
//              up per step; the heading on the "screen" card reads the STALE
//              "Ada Lovelace" (amber) until the second commit, where it finally
//              flips to "Adam Lovelace" (green).
//     Step 1   firstName -> "Adam". Render #1 runs, but fullName still holds the
//              last-committed "Ada Lovelace" — the input and heading disagree.
//     Step 2   Commit. The stale heading is painted to the DOM for this frame.
//     Step 3   Effect runs, calls setFullName('Adam Lovelace') -> schedules a
//              re-render. The screen has not changed yet.
//     Step 4   Render #2 + Commit. Only now does the heading show the right name.
//   Step 5     the derived path. The strip collapses to ONE Render + Commit; a
//              `const fullName = …` chip stands in for the effect, and the
//              heading is correct from the very first paint (green).
//
// Style follows this chapter-arc's KeyChangeRemountSequence: fixed slate ink,
// color-scheme pinned light so the hand-picked amber/green tints survive dark
// mode, `margin: 0` on every inner element to defeat Starlight's injected prose
// margins. Every step is the same shape — a phase strip, a down arrow, one
// "screen" card, and a one-line verdict — so the grid stack never reflows as the
// reader scrubs. The strip caps its own height, so the 5-box sync track and the
// 2-box derived track sit at the same height.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary chip surface
const BORDER = '#cbd5e1'; // ordinary chip edge (slate-300)
const DIM_BG = '#f1f5f9'; // inactive phase box wash (slate-100)
const DIM_INK = '#94a3b8'; // inactive phase ink (slate-400)
const SCREEN_BG = '#f8fafc'; // the "screen" card wash (slate-50)
const ROW_BG = '#ffffff'; // a row inside the screen card

const AMBER = '#d97706'; // amber-600 — the stale value (the smell)
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const GREEN = '#16a34a'; // green-600 — the correct value
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const BLUE = '#2563eb'; // blue-600 — the active phase accent
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all five steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The phase strip: a horizontal row of phase boxes joined by arrows. Capped in
// height so the long sync track and the short derived track line up.
const strip = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 4px; margin: 0; min-height: 52px;`;

// A single phase box. `active` lights it up (blue); otherwise it sits dim.
const phaseBox = (active: boolean) =>
	`display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1px; margin: 0; padding: 6px 10px; border-radius: 8px; min-width: 64px; ` +
	(active
		? `border: 1.5px solid ${BLUE}; background: ${BLUE_BG}; box-shadow: 0 1px 3px rgba(37, 99, 235, 0.3);`
		: `border: 1px solid ${BORDER}; background: ${DIM_BG};`);
const phaseName = (active: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 700; line-height: 1.15; color: ${active ? BLUE_INK : DIM_INK};`;
const phaseEyebrow = (active: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${active ? BLUE : DIM_INK};`;

// The little arrow between phase boxes.
const stripArrow = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 700; color: ${INK_SOFT};`;

// The "schedules re-render" tag that appears on the Effect step.
const scheduleTag = `display: inline-flex; align-items: center; margin: 0; padding: 3px 8px; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.2; color: ${BLUE_INK}; background: ${BLUE_BG}; border: 1px solid ${BLUE}; border-radius: 999px; white-space: nowrap;`;

// The `const fullName = …` chip that stands in for the deleted effect (step 5).
const codeChip = `display: inline-flex; align-items: center; margin: 0; padding: 6px 10px; font-family: ${mono}; font-size: 12px; font-weight: 600; line-height: 1.3; color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1.5px solid ${GREEN}; border-radius: 8px; white-space: nowrap;`;

// The vertical down-arrow joining the phase strip to the screen.
const downArrow = `margin: 0; font-family: ${sans}; font-size: 18px; font-weight: 700; line-height: 1; color: ${INK_SOFT};`;

// The "screen" card — a tiny mock of the rendered <Profile/>: a top chrome bar,
// then an input row and an h1 row. Fixed width so it never reflows.
const screen = `display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 11px; border: 1px solid ${BORDER}; border-radius: 12px; background: ${SCREEN_BG}; width: 100%; max-width: 360px;`;
const screenLabel = `display: inline-flex; flex: 0 0 auto; align-self: flex-start; align-items: center; margin: 0; padding: 3px 8px; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT}; background: ${ROW_BG}; border: 1px solid ${BORDER}; border-radius: 6px; white-space: nowrap;`;

// A row inside the screen: a faint tag on the left, the live value on the right.
const screenRow = `display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 10px; border-radius: 8px; background: ${ROW_BG}; border: 1px solid ${BORDER};`;
const rowTag = `display: inline-block; flex: 0 0 auto; margin: 0; padding: 1px 6px; font-family: ${mono}; font-size: 9px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #ffffff; background: ${INK_SOFT}; border-radius: 4px;`;
const inputValue = `margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 600; color: ${INK};`;

// The h1 value — tinted amber when it shows the stale name, green when correct.
const headingValue = (correct: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 700; color: ${correct ? GREEN_INK : AMBER_INK};`;
const headingPill = (correct: boolean) =>
	`display: inline-flex; flex: 0 0 auto; align-items: center; margin: 0 0 0 auto; padding: 1px 7px; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.3; border-radius: 999px; white-space: nowrap; ` +
	(correct
		? `color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN};`
		: `color: ${AMBER_INK}; background: ${AMBER_BG}; border: 1px solid ${AMBER};`);
const headingRow = (correct: boolean) =>
	`display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 10px; border-radius: 8px; ` +
	(correct
		? `background: ${GREEN_BG}; border: 1px solid ${GREEN};`
		: `background: ${AMBER_BG}; border: 1px solid ${AMBER};`);

// The one-line verdict under the screen. `tone` picks the ink.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.35; color: ${tone}; max-width: 380px; text-align: center; min-height: 30px;`;
---

<DiagramSequence>
	{/* ---- Step 1: Render #1 runs, but fullName is still the last commit ---- */}
	<DiagramStep caption="firstName changes to 'Adam'. Render #1 runs — but fullName still holds 'Ada Lovelace' from the last commit, so the heading is built from stale state.">
		<div style={stage}>
			<div style={strip}>
				<div style={phaseBox(true)}>
					<span style={phaseEyebrow(true)}>pass 1</span>
					<span style={phaseName(true)}>Render #1</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>then</span>
					<span style={phaseName(false)}>Commit</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>then</span>
					<span style={phaseName(false)}>Effect</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>then</span>
					<span style={phaseName(false)}>Render #2</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>then</span>
					<span style={phaseName(false)}>Commit</span>
				</div>
			</div>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={screen}>
				<span style={screenLabel}>screen — what the user sees</span>
				<div style={screenRow}>
					<span style={rowTag}>input</span>
					<span style={inputValue}>Adam</span>
				</div>
				<div style={headingRow(false)}>
					<span style={rowTag}>h1</span>
					<span style={headingValue(false)}>Ada Lovelace</span>
					<span style={headingPill(false)}>stale</span>
				</div>
			</div>
			<p style={verdict(AMBER_INK)}>The input already says <strong>Adam</strong>, but the heading still reads the old <strong>fullName</strong>.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Commit — the stale heading is painted to the DOM ---- */}
	<DiagramStep caption="Commit. React paints that render to the DOM. For this frame, the screen genuinely shows the old name.">
		<div style={stage}>
			<div style={strip}>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>done</span>
					<span style={phaseName(false)}>Render #1</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(true)}>
					<span style={phaseEyebrow(true)}>now</span>
					<span style={phaseName(true)}>Commit</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>then</span>
					<span style={phaseName(false)}>Effect</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>then</span>
					<span style={phaseName(false)}>Render #2</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>then</span>
					<span style={phaseName(false)}>Commit</span>
				</div>
			</div>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={screen}>
				<span style={screenLabel}>screen — what the user sees</span>
				<div style={screenRow}>
					<span style={rowTag}>input</span>
					<span style={inputValue}>Adam</span>
				</div>
				<div style={headingRow(false)}>
					<span style={rowTag}>h1</span>
					<span style={headingValue(false)}>Ada Lovelace</span>
					<span style={headingPill(false)}>stale</span>
				</div>
			</div>
			<p style={verdict(AMBER_INK)}>This wrong frame is real — it is painted to the screen, not just held in memory.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: Effect runs, setFullName schedules another render ---- */}
	<DiagramStep caption="Now the effect runs and calls setFullName('Adam Lovelace'). That schedules another render — the screen has not changed yet.">
		<div style={stage}>
			<div style={strip}>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>done</span>
					<span style={phaseName(false)}>Render #1</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>done</span>
					<span style={phaseName(false)}>Commit</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(true)}>
					<span style={phaseEyebrow(true)}>now</span>
					<span style={phaseName(true)}>Effect</span>
				</div>
				<span style={scheduleTag}>&rarr; schedules re-render</span>
			</div>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={screen}>
				<span style={screenLabel}>screen — what the user sees</span>
				<div style={screenRow}>
					<span style={rowTag}>input</span>
					<span style={inputValue}>Adam</span>
				</div>
				<div style={headingRow(false)}>
					<span style={rowTag}>h1</span>
					<span style={headingValue(false)}>Ada Lovelace</span>
					<span style={headingPill(false)}>stale</span>
				</div>
			</div>
			<p style={verdict(AMBER_INK)}>setFullName runs <em>after</em> the commit — too late for this frame. It only queues a second pass.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Render #2 + Commit — heading finally correct ---- */}
	<DiagramStep caption="Render #2 and Commit. Only now — on the second render — does the heading show the right name.">
		<div style={stage}>
			<div style={strip}>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>done</span>
					<span style={phaseName(false)}>Render #1</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>done</span>
					<span style={phaseName(false)}>Commit</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(false)}>
					<span style={phaseEyebrow(false)}>done</span>
					<span style={phaseName(false)}>Effect</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(true)}>
					<span style={phaseEyebrow(true)}>now</span>
					<span style={phaseName(true)}>Render #2</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(true)}>
					<span style={phaseEyebrow(true)}>now</span>
					<span style={phaseName(true)}>Commit</span>
				</div>
			</div>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={screen}>
				<span style={screenLabel}>screen — what the user sees</span>
				<div style={screenRow}>
					<span style={rowTag}>input</span>
					<span style={inputValue}>Adam</span>
				</div>
				<div style={headingRow(true)}>
					<span style={rowTag}>h1</span>
					<span style={headingValue(true)}>Adam Lovelace</span>
					<span style={headingPill(true)}>correct</span>
				</div>
			</div>
			<p style={verdict(INK_SOFT)}>One keystroke, <strong>two renders</strong>, and a frame of stale UI in between — all to produce one value.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 5: Derived — one render, correct from the first paint ---- */}
	<DiagramStep caption="Derive it instead, and there is no second render and no stale frame. One render computes the name and paints it correctly the first time.">
		<div style={stage}>
			<div style={strip}>
				<div style={phaseBox(true)}>
					<span style={phaseEyebrow(true)}>one pass</span>
					<span style={phaseName(true)}>Render</span>
				</div>
				<span style={stripArrow} aria-hidden="true">&rarr;</span>
				<div style={phaseBox(true)}>
					<span style={phaseEyebrow(true)}>then</span>
					<span style={phaseName(true)}>Commit</span>
				</div>
				<span style={codeChip}>const fullName = firstName + ' ' + lastName</span>
			</div>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={screen}>
				<span style={screenLabel}>screen — what the user sees</span>
				<div style={screenRow}>
					<span style={rowTag}>input</span>
					<span style={inputValue}>Adam</span>
				</div>
				<div style={headingRow(true)}>
					<span style={rowTag}>h1</span>
					<span style={headingValue(true)}>Adam Lovelace</span>
					<span style={headingPill(true)}>correct</span>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>The heading is computed in the render body, so it is right on the <strong>first</strong> paint. No second render, nothing to keep in sync.</p>
		</div>
	</DiagramStep>
</DiagramSequence>
