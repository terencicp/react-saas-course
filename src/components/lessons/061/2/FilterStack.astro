---
// FilterStack — Chapter 061 Lesson 2 ("Making the missing filter impossible").
//
// The lesson's conceptual anchor: TWO filters stack into ONE `WHERE`, and the
// caller hand-typed NEITHER. Three contributed layers, top → bottom, collapse
// downward into the single clause the database actually runs:
//
//   Your call            — ordering & paging only        (neutral: NOT a filter)
//   Lifecycle layer      — deleted_at IS NULL AND …      (blue:    this helper)
//   Tenancy layer        — organization_id = :orgId      (violet:  tenantDb)
//          │ collapse ▼
//   WHERE organization_id = :orgId AND deleted_at IS NULL AND archived_at IS NULL
//          (green: the one clause Postgres runs — each predicate tinted to its
//           source layer so the eye traces where every slice came from)
//
// Each band is a horizontal row (source label left, contributed SQL right) so
// the three-high stack stays compact and the figure clears the ~800px cap with
// room to spare. The resolved box re-colours each predicate token to match the
// layer it came from, making "neither of these was hand-typed" literally
// visible.
//
// Pure HTML+CSS per the diagrams guide (an annotated illustration with
// colour-coded segments collapsing into a result, not a graph engine), modeled
// on this chapter family's 057/5 ThreeLayerDefense and 058/2 SignedUrlAnatomy.
// `not-content` + a margin:0 reset on every node defeats Starlight's injected
// prose margins. Goes inside <Figure>, which the MDX supplies with the caption.
//
// Colour language: blue (#2563eb) = the lifecycle layer (this helper); violet
// (#7c3aed) = the tenancy layer (tenantDb); green (#16a34a) = the resolved
// clause that arrives at the database; the caller's slice stays neutral grey —
// it contributes ordering, not a predicate. Saturated mid-tones reused verbatim
// in light + dark since the colour itself is the signal; tints derived with
// color-mix so they track the page background.

// The three contributed layers, top → bottom in collapse order.
const layers = [
	{
		kind: 'caller',
		source: 'Your call',
		role: 'ordering & paging — not a filter',
		code: '.orderBy(…).limit(20)',
	},
	{
		kind: 'lifecycle',
		source: 'Lifecycle layer',
		role: 'this helper — scopedInvoices',
		code: 'deleted_at IS NULL AND archived_at IS NULL',
	},
	{
		kind: 'tenancy',
		source: 'Tenancy layer',
		role: 'tenantDb(orgId)',
		code: 'organization_id = :orgId',
	},
];
---

<div class="fst not-content">
	{/* ── The contributed stack: three layers, top → bottom ──────────────── */}
	<div class="fst-stack">
		{
			layers.map((layer) => (
				<div class={`fst-band fst-band--${layer.kind}`}>
					<span class="fst-band-meta">
						<span class="fst-band-source">{layer.source}</span>
						<span class="fst-band-role">{layer.role}</span>
					</span>
					<code class="fst-band-code">
						{layer.kind === 'caller' ? (
							layer.code
						) : (
							<span class="fst-contrib">{layer.code}</span>
						)}
					</code>
				</div>
			))
		}
	</div>

	{/* ── The collapse: the two real predicates fold down into one clause ── */}
	<div class="fst-collapse" aria-hidden="true">
		<span class="fst-collapse-rule" />
		<span class="fst-collapse-eq">=</span>
		<span class="fst-collapse-rule" />
	</div>

	{/* ── The resolved WHERE — each predicate tinted to its source layer ──── */}
	<div class="fst-result">
		<span class="fst-result-tag">one WHERE the database runs</span>
		<code class="fst-result-code">
			<span class="fst-kw">WHERE</span>{' '}
			<span class="fst-pred fst-pred--tenancy">organization_id = :orgId</span>{' '}
			<span class="fst-and">AND</span>{' '}
			<span class="fst-pred fst-pred--lifecycle">deleted_at IS NULL</span>{' '}
			<span class="fst-and">AND</span>{' '}
			<span class="fst-pred fst-pred--lifecycle">archived_at IS NULL</span>
		</code>
		<span class="fst-result-note">
			Both predicates supplied by construction — the caller typed neither.
		</span>
	</div>
</div>

<style>
	.fst {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		/* Saturated mid-tones — the colour is the signal, identical in both themes. */
		--fst-blue: #2563eb; /* the lifecycle layer (this helper) */
		--fst-violet: #7c3aed; /* the tenancy layer (tenantDb) */
		--fst-green: #16a34a; /* the resolved clause the database runs */
	}

	/* ── The contributed stack ──────────────────────────────────────────── */
	.fst-stack {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
	}

	.fst-band {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		min-width: 0;
		padding: 10px 14px;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 22%, transparent);
		margin: 0;
	}

	.fst-band-meta {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
		flex: 0 1 auto;
		margin: 0;
	}
	.fst-band-source {
		font-size: 13px;
		font-weight: 800;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.fst-band-role {
		font-size: 11px;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The contributed SQL — override Starlight's inline-code pill to a clean,
	   single-line label so the predicate reads as the layer's payload. */
	.fst-band-code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.3;
		text-align: right;
		min-width: 0;
		color: var(--sl-color-gray-1, #334155);
		background: transparent;
		border: 0;
		padding: 0;
		margin: 0;
		overflow-wrap: anywhere;
	}

	/* The caller's band stays neutral; its row is muted to read as "no filter". */
	.fst-band--caller {
		border-style: dashed;
		background: color-mix(in srgb, var(--sl-color-gray-5) 12%, transparent);
	}
	.fst-band--caller .fst-band-code {
		color: var(--sl-color-gray-3, #64748b);
		font-weight: 600;
	}

	/* Lifecycle band — blue, this helper's contribution. */
	.fst-band--lifecycle {
		border-color: color-mix(in srgb, var(--fst-blue) 60%, transparent);
		background: color-mix(in srgb, var(--fst-blue) 11%, transparent);
	}
	.fst-band--lifecycle .fst-contrib {
		color: color-mix(in srgb, var(--fst-blue) 84%, var(--sl-color-text));
	}

	/* Tenancy band — violet, the lower layer tenantDb already pinned. */
	.fst-band--tenancy {
		border-color: color-mix(in srgb, var(--fst-violet) 60%, transparent);
		background: color-mix(in srgb, var(--fst-violet) 11%, transparent);
	}
	.fst-band--tenancy .fst-contrib {
		color: color-mix(in srgb, var(--fst-violet) 84%, var(--sl-color-text));
	}

	.fst-contrib {
		margin: 0;
	}

	/* ── The collapse connector ─────────────────────────────────────────── */
	.fst-collapse {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin: 10px 0;
	}
	.fst-collapse-rule {
		flex: 1 1 auto;
		max-width: 180px;
		height: 0;
		border-top: 2px dashed var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}
	.fst-collapse-eq {
		flex: 0 0 auto;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 20px;
		font-weight: 800;
		line-height: 1;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* ── The resolved WHERE clause ──────────────────────────────────────── */
	.fst-result {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 8px;
		min-width: 0;
		padding: 13px 15px;
		border-radius: 12px;
		border: 1.5px solid color-mix(in srgb, var(--fst-green) 60%, transparent);
		background: color-mix(in srgb, var(--fst-green) 12%, transparent);
		margin: 0;
	}
	.fst-result-tag {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--fst-green) 78%, var(--sl-color-text));
		margin: 0;
	}

	.fst-result-code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.5;
		min-width: 0;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		border: 0;
		padding: 0;
		margin: 0;
		overflow-wrap: anywhere;
	}
	.fst-kw {
		font-weight: 800;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.fst-and {
		font-weight: 700;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.fst-pred {
		font-weight: 800;
		border-radius: 5px;
		padding: 1px 4px;
		margin: 0;
		white-space: nowrap;
	}
	/* Each predicate re-tinted to the layer it was contributed by. */
	.fst-pred--lifecycle {
		color: color-mix(in srgb, var(--fst-blue) 86%, var(--sl-color-text));
		background: color-mix(in srgb, var(--fst-blue) 14%, transparent);
	}
	.fst-pred--tenancy {
		color: color-mix(in srgb, var(--fst-violet) 86%, var(--sl-color-text));
		background: color-mix(in srgb, var(--fst-violet) 14%, transparent);
	}

	.fst-result-note {
		font-size: 11.5px;
		font-weight: 500;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* Narrow viewports: each band stacks its label above its SQL so the long
	   predicate never collides with the source label. */
	@media (max-width: 560px) {
		.fst-band {
			flex-direction: column;
			align-items: flex-start;
			gap: 5px;
		}
		.fst-band-code {
			text-align: left;
		}
		.fst-pred {
			white-space: normal;
		}
	}
</style>
