---
// LifecycleTabsMockup — Chapter 061 Lesson 1 ("Two timestamps, three actions"),
// the figure that lands "The UI affordances and the visibility filter" section.
//
// A faithful, STATIC mockup of an invoices list-view surface that shows two
// things at once and ties them together:
//
//   1. the TAB STRIP (Active | Archived | All) with Archived active, sitting
//      under a browser address bar reading /invoices?status=archived — the
//      ?status=archived fragment highlighted so the "which tab = URL state"
//      tie is unmissable. This is the same tri-state filter, riding the exact
//      URL-state machinery the student built in ch 060 (whose 060/1
//      ListViewMockup this deliberately echoes for visual continuity).
//   2. one LIST ROW carrying an "Archived" status pill (the user sees the
//      label, never the raw deletedAt) with an open action menu offering the
//      three affordances — Archive, Restore, and a destructive, confirm-gated
//      Delete rendered in red to signal it's the role-restricted, gone-for-good
//      path that is never the default row action.
//
// Colour language carried from this chapter family: blue (#2563eb) is the
// lifecycle/URL-state accent (matches 061/2 FilterStack and ch 046/060's filter
// blue), so the highlighted ?status=archived and the active Archived tab share
// one hue; red (#ef4444 / #b91c1c) is the destructive Delete treatment (matches
// 060/1's overdue badge reds).
//
// Built as plain HTML + CSS — the diagrams index's pick for an annotated UI
// illustration — themed with Starlight CSS variables so it reads as a native app
// surface in both light and dark. `not-content` + margin:0 resets on every node
// defeat Starlight's injected prose margins; a role="img" + aria-label describes
// the figure for assistive tech since there is no <img>. The MDX call site wraps
// this in <Figure> and supplies the caption.

const ALT =
	'An invoices list-view surface. A browser address bar reads ' +
	'/invoices?status=archived, with the ?status=archived part highlighted. ' +
	'Below it a tab strip shows Active, Archived, and All, with Archived as the ' +
	'active tab. One list row, "Acme rebrand", carries an "Archived" status pill ' +
	'and an open action menu offering three items: Archive, Restore, and a ' +
	'destructive Delete shown in red.';

// The tri-state filter, in URL order. `archived` is the active tab here.
const tabs = [
	{ label: 'Active', active: false },
	{ label: 'Archived', active: true },
	{ label: 'All', active: false },
];

// The open row's action menu. Delete is the destructive, confirm-gated,
// role-restricted affordance — flagged so it gets the red treatment + a hint.
const menu = [
	{ label: 'Archive', icon: '▾', hint: null, danger: false },
	{ label: 'Restore', icon: '↺', hint: null, danger: false },
	{ label: 'Delete', icon: '🗑', hint: 'confirm · admin', danger: true },
];
---

<div class="ltm not-content" role="img" aria-label={ALT}>
	<div class="ltm-card">
		{/* browser chrome — the address bar ties the active tab to URL state */}
		<div class="ltm-chrome" aria-hidden="true">
			<span class="ltm-dot"></span>
			<span class="ltm-dot"></span>
			<span class="ltm-dot"></span>
			<span class="ltm-url">
				<span class="ltm-url-path">/invoices</span><span class="ltm-url-query"
					>?status=archived</span
				>
			</span>
		</div>

		{/* (1) the tri-state tab strip — Archived is active */}
		<div class="ltm-tabs">
			{
				tabs.map((tab) => (
					<span class={`ltm-tab${tab.active ? ' ltm-tab--active' : ''}`}>
						{tab.label}
					</span>
				))
			}
		</div>

		{/* (2) one list row with its status pill and an open action menu */}
		<div class="ltm-row">
			<span class="ltm-row-name">Acme rebrand</span>
			<span class="ltm-row-status">Archived</span>
			<span class="ltm-row-trigger" aria-hidden="true">⋯</span>

			{/* the open action menu — the three affordances for this row */}
			<div class="ltm-menu" role="menu">
				{
					menu.map((item) => (
						<span
							class={`ltm-menu-item${item.danger ? ' ltm-menu-item--danger' : ''}`}
							role="menuitem"
						>
							<span class="ltm-menu-icon" aria-hidden="true">
								{item.icon}
							</span>
							<span class="ltm-menu-label">{item.label}</span>
							{item.hint && <span class="ltm-menu-hint">{item.hint}</span>}
						</span>
					))
				}
			</div>
		</div>
	</div>
</div>

<style>
	/* ---- shell ----------------------------------------------------------- */
	.ltm {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		color: var(--sl-color-white, #1e293b);
		/* the lifecycle / URL-state accent — one hue shared by the highlighted
		   query fragment and the active tab (matches 061/2 FilterStack blue). */
		--ltm-accent: #2563eb;
	}
	.ltm * {
		box-sizing: border-box;
	}

	/* the app-surface card */
	.ltm-card {
		margin: 0;
		max-width: 460px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		border-radius: 12px;
		background: var(--sl-color-bg, #fff);
		overflow: hidden;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
	}

	/* ---- browser chrome -------------------------------------------------- */
	.ltm-chrome {
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 9px 14px;
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
	}
	.ltm-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--sl-color-gray-4, #cbd5e1);
	}
	.ltm-url {
		margin: 0 0 0 8px;
		flex: 1 1 auto;
		min-width: 0;
		padding: 4px 11px;
		border-radius: 6px;
		background: var(--sl-color-bg, #fff);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12.5px;
		line-height: 1.4;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.ltm-url-path {
		color: var(--sl-color-gray-2, #475569);
	}
	/* the ?status=archived fragment — highlighted so the tie to URL state is
	   unmissable; same accent hue as the active tab below. */
	.ltm-url-query {
		margin: 0;
		padding: 1px 4px;
		border-radius: 4px;
		font-weight: 700;
		color: var(--ltm-accent);
		background: color-mix(in srgb, var(--ltm-accent) 14%, transparent);
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--ltm-accent) 30%, transparent);
	}

	/* ---- the tri-state tab strip ----------------------------------------- */
	.ltm-tabs {
		display: flex;
		align-items: stretch;
		gap: 4px;
		padding: 10px 14px 0;
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}
	.ltm-tab {
		padding: 7px 13px 9px;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
	}
	/* the active tab — accent text + underline, matching the highlighted query */
	.ltm-tab--active {
		color: var(--ltm-accent);
		border-bottom-color: var(--ltm-accent);
	}

	/* ---- the list row + its open action menu ----------------------------- */
	.ltm-row {
		position: relative;
		display: flex;
		align-items: center;
		gap: 12px;
		/* generous bottom padding reserves room for the open menu, which is
		   absolutely positioned and would otherwise be clipped by the card's
		   overflow:hidden. */
		padding: 14px 14px 156px;
	}
	.ltm-row-name {
		flex: 1 1 auto;
		min-width: 0;
		font-size: 14px;
		font-weight: 600;
		color: var(--sl-color-white, #0f172a);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	/* the status the USER sees — the label "Archived", never the raw deletedAt */
	.ltm-row-status {
		flex: 0 0 auto;
		padding: 2px 10px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--ltm-accent);
		background: color-mix(in srgb, var(--ltm-accent) 13%, var(--sl-color-bg, #fff));
		border: 1px solid color-mix(in srgb, var(--ltm-accent) 30%, transparent);
	}
	/* the kebab trigger that "opened" the menu — drawn pressed */
	.ltm-row-trigger {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 7px;
		font-size: 17px;
		line-height: 1;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}

	/* the open dropdown, anchored to the row's bottom-right under the trigger */
	.ltm-menu {
		position: absolute;
		top: 44px;
		right: 14px;
		display: flex;
		flex-direction: column;
		min-width: 188px;
		padding: 5px;
		border-radius: 10px;
		background: var(--sl-color-bg, #fff);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		box-shadow: 0 8px 22px rgba(15, 23, 42, 0.16);
	}
	.ltm-menu-item {
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 7px 9px;
		border-radius: 7px;
		font-size: 13.5px;
		font-weight: 500;
		color: var(--sl-color-white, #0f172a);
	}
	.ltm-menu-icon {
		flex: 0 0 auto;
		width: 16px;
		text-align: center;
		font-size: 13px;
		color: var(--sl-color-gray-2, #475569);
	}
	.ltm-menu-label {
		flex: 1 1 auto;
	}
	.ltm-menu-hint {
		flex: 0 0 auto;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: color-mix(in srgb, #b91c1c 75%, var(--sl-color-text));
	}
	/* Delete — the destructive, confirm-gated, role-restricted affordance */
	.ltm-menu-item--danger {
		color: #b91c1c;
		background: color-mix(in srgb, #ef4444 9%, transparent);
	}
	.ltm-menu-item--danger .ltm-menu-icon {
		color: #b91c1c;
	}
	/* a hairline separating Delete from the safe actions above it */
	.ltm-menu-item--danger {
		margin-top: 4px;
		border-top: 1px solid
			color-mix(in srgb, var(--sl-color-gray-5, #d0d5dd) 70%, transparent);
		border-top-left-radius: 0;
		border-top-right-radius: 0;
		padding-top: 9px;
	}

	@media (max-width: 480px) {
		.ltm-card {
			max-width: 100%;
		}
		.ltm-menu {
			min-width: 168px;
		}
	}
</style>
