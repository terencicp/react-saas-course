---
// MutationStateMachineStrip — Chapter 061 Lesson 3 ("Version columns and the
// honest 409").
//
// The optimistic-mutation state machine the student already carries from ch 005:
//
//   idle ──submit──▶ submitting ──┬──▶ success
//                                 ├──▶ conflict   ← the state THIS lesson adds
//                                 └──▶ error
//
// The whole point of the figure: slot ONE new terminal state (`conflict`) into a
// model the student already holds, rather than presenting a fresh diagram. So
// `idle`, `submitting`, `success`, and `error` are neutral grey, and only
// `conflict` is tinted (amber/accent) to read as "the new arrival" — the state
// that exists because the second tab's write lost the optimistic-concurrency
// race and the user is shown the current row to decide.
//
// Layout: a single horizontal strip. Two sequential nodes on the left
// (idle → submitting) then a fan-out, via a small fork connector, into a
// vertical stack of the three terminal nodes. Horizontal + compact, well under
// the ~800px height cap; the three terminals stack vertically so the strip stays
// short and reads left-to-right.
//
// Pure HTML+CSS per the diagrams guide (a simple labeled state strip, not a
// graph engine), modeled on this chapter's 061/2 FilterStack. `not-content` plus
// a margin:0 reset on every node defeats Starlight's injected prose margins.
// Goes inside <Figure>, which the MDX supplies with the caption.
//
// Colour language: neutral grey = the states the student already knows; amber
// (#f59e0b) = `conflict`, the state this lesson introduces. The amber mid-tone
// reads against both light and dark page backgrounds (the colour is the signal);
// tints derived with color-mix so they track the page background.

// The terminal states the machine fans out into. `conflict` is flagged `new`.
const terminals = [
	{ label: 'success', new: false },
	{ label: 'conflict', new: true },
	{ label: 'error', new: false },
];
---

<div class="msm not-content">
	{/* ── idle ──submit──▶ submitting ───────────────────────────────────── */}
	<div class="msm-node">idle</div>

	<div class="msm-arrow">
		<span class="msm-arrow-label">submit</span>
		<span class="msm-arrow-glyph" aria-hidden="true">→</span>
	</div>

	<div class="msm-node">submitting</div>

	{/* ── fan-out: a fork connector, then the three stacked terminals. The
	   fanout wrapper is align-items:stretch so the fork bar spans the
	   terminals' full height. ─────────────────────────────────────────── */}
	<div class="msm-fanout">
		<div class="msm-fork" aria-hidden="true">
			<span class="msm-fork-stem"></span>
			<span class="msm-fork-bar"></span>
		</div>

		<div class="msm-terminals">
			{
				terminals.map((t) => (
					<div class="msm-branch">
						<span class="msm-branch-arrow" aria-hidden="true">
							→
						</span>
						<div class={`msm-node msm-node--terminal${t.new ? ' msm-node--new' : ''}`}>
							{t.label}
						</div>
					</div>
				))
			}
		</div>
	</div>
</div>

<style>
	.msm {
		box-sizing: border-box;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 14px 4px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		/* The accent — the colour is the signal, identical in both themes. */
		--msm-accent: #f59e0b; /* `conflict`: the state this lesson adds */
	}

	/* ── State node (pill) ──────────────────────────────────────────────── */
	.msm-node {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		flex: 0 0 auto;
		padding: 9px 13px;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 22%, transparent);
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	/* Terminals stretch to their shared column width (set on .msm-terminals
	   below) so the fan-out reads as a tidy, aligned stack. */
	.msm-node--terminal {
		width: 100%;
	}

	/* `conflict` — the only tinted node: the new arrival this lesson adds. */
	.msm-node--new {
		border-color: color-mix(in srgb, var(--msm-accent) 70%, transparent);
		background: color-mix(in srgb, var(--msm-accent) 16%, transparent);
		color: color-mix(in srgb, var(--msm-accent) 82%, var(--sl-color-text));
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--msm-accent) 14%, transparent);
	}

	/* ── idle → submitting arrow ────────────────────────────────────────── */
	.msm-arrow {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		flex: 0 0 auto;
		margin: 0;
	}
	.msm-arrow-label {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 10.5px;
		font-weight: 600;
		line-height: 1.1;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.msm-arrow-glyph {
		font-size: 20px;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-2, #475569);
		user-select: none;
		margin: 0;
	}

	/* ── Fan-out: the fork connector sits left of the stacked terminals; the
	   wrapper stretches so the fork bar can span the terminals' height. ──── */
	.msm-fanout {
		display: flex;
		flex-direction: row;
		align-items: stretch;
		gap: 0;
		flex: 0 0 auto;
		min-width: 0;
		margin: 0;
	}

	/* The fork: a centered horizontal stem off `submitting`, then a full-height
	   vertical bar that ties the three branch arrows together. */
	.msm-fork {
		display: flex;
		flex-direction: row;
		align-items: center;
		flex: 0 0 auto;
		margin: 0;
	}
	.msm-fork-stem {
		width: 12px;
		height: 0;
		border-top: 2px solid var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}
	.msm-fork-bar {
		/* Vertical connector spanning the terminals' stacked height. */
		width: 0;
		align-self: stretch;
		border-left: 2px solid var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	/* ── The three stacked terminal branches ────────────────────────────── */
	.msm-terminals {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 9px;
		flex: 0 0 auto;
		min-width: 0;
		margin: 0;
	}
	.msm-branch {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 6px;
		min-width: 0;
		margin: 0;
	}
	.msm-branch-arrow {
		font-size: 17px;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-2, #475569);
		user-select: none;
		flex: 0 0 auto;
		margin: 0;
	}

	/* Narrow viewports: the strip wraps the fan-out below the linear pair so the
	   three terminals never get crushed. */
	@media (max-width: 520px) {
		.msm {
			flex-wrap: wrap;
			row-gap: 16px;
		}
		.msm-fanout {
			flex: 1 1 100%;
		}
		.msm-fork {
			display: none;
		}
	}
</style>
