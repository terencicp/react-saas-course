---
// OrphanTimeline — Chapter 068 Lesson 4 ("Postgres owns identity, R2 owns
// bytes"), the orphan-drift closer. Scrubs one upload's timeline so the
// asymmetry the section lands — "orphan bytes are a cleanup chore; orphan rows
// are a correctness bug" — becomes a spatial fact, not an assertion.
//
// One <OrphanTimeline step={n} /> renders inside each <DiagramStep>. Every step
// renders the SAME two-column stage (R2 bucket left, Postgres right) and only
// toggles which chips are present and how they're tinted, so the
// DiagramSequence grid stack never reflows as the reader scrubs. The tallest
// step (step 2, both chips present) sets the height; the stage carries a
// min-height so the single-chip steps don't shrink the card.
//
// Colour language, theme-stable (the colour itself is the signal): neutral =
// in-sync / expected; AMBER (#f59e0b, R2's accent from this chapter's
// OwnershipSplit) = orphan bytes, the cheap litter; RED (#dc2626) = orphan rows,
// the correctness bug. The two orphan tints are deliberately the two cost
// signals, not decoration.
//
// Pure HTML+CSS per the diagrams guide (a sequential phase strip, not a graph).
// `not-content` + margin:0 on every node defeats Starlight's injected prose
// margins. DiagramSequence supplies the outer card; this component is only the
// step body, so no <Figure>/<DiagramSequence> wrapper here.

interface Props {
	/** Active step, 1–4, matching the four DiagramStep captions. */
	step: number;
}

const { step } = Astro.props;

// Per-step presence + tint of the two chips. `tone` drives the chip colour:
// 'sync' = neutral/expected, 'orphan-bytes' = amber, 'orphan-row' = red.
type Tone = 'sync' | 'orphan-bytes' | 'orphan-row';

const config: Record<
	number,
	{
		object: { present: boolean; tone: Tone; tag?: string };
		row: { present: boolean; tone: Tone; tag?: string };
	}
> = {
	1: {
		object: { present: true, tone: 'sync' },
		row: { present: false, tone: 'sync' },
	},
	2: {
		object: { present: true, tone: 'sync' },
		row: { present: true, tone: 'sync' },
	},
	3: {
		object: { present: true, tone: 'orphan-bytes', tag: 'orphan bytes' },
		row: { present: false, tone: 'sync' },
	},
	4: {
		object: { present: false, tone: 'sync' },
		row: { present: true, tone: 'orphan-row', tag: 'orphan row' },
	},
};

const c = config[step] ?? config[1];

const objectKey = 'org/acme/files/0192f…pdf';

const AMBER = '#f59e0b';
const RED = '#dc2626';

// Document-icon and table-row glyphs, inlined so the chips read at a glance.
const docIcon = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;display:block;flex:0 0 auto;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
const rowIcon = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;display:block;flex:0 0 auto;"><rect x="3" y="5" width="18" height="14" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="9" y1="10" x2="9" y2="19"/></svg>`;
---

<div class="ot not-content" data-step={step}>
	<div class="ot-stage">
		{/* LEFT — R2 bucket */}
		<div class="ot-panel ot-panel--r2">
			<div class="ot-head">
				<span class="ot-title">R2 bucket</span>
				<span class="ot-sub">the bytes</span>
			</div>
			<div class="ot-slot">
				{
					c.object.present ? (
						<div class:list={['ot-chip', `is-${c.object.tone}`]}>
							<span class="ot-chip-icon">
								<Fragment set:html={docIcon} />
							</span>
							<div class="ot-chip-body">
								<code class="ot-chip-key">{objectKey}</code>
								{c.object.tag && <span class="ot-chip-tag">{c.object.tag}</span>}
							</div>
						</div>
					) : (
						<div class="ot-empty">no object</div>
					)
				}
			</div>
		</div>

		{/* RIGHT — Postgres */}
		<div class="ot-panel ot-panel--pg">
			<div class="ot-head">
				<span class="ot-title">Postgres</span>
				<span class="ot-sub">file_metadata</span>
			</div>
			<div class="ot-slot">
				{
					c.row.present ? (
						<div class:list={['ot-chip', `is-${c.row.tone}`]}>
							<span class="ot-chip-icon">
								<Fragment set:html={rowIcon} />
							</span>
							<div class="ot-chip-body">
								<code class="ot-chip-key">id 0192f… · 84 KB</code>
								{c.row.tag && <span class="ot-chip-tag">{c.row.tag}</span>}
							</div>
						</div>
					) : (
						<div class="ot-empty">no row</div>
					)
				}
			</div>
		</div>
	</div>
</div>

<style
	define:vars={{
		'ot-amber': AMBER,
		'ot-red': RED,
	}}
>
	.ot {
		margin: 0;
		padding: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* ── Two-column stage ─────────────────────────────────────────────────── */
	.ot-stage {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		gap: 16px;
		width: 100%;
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	.ot-panel {
		flex: 1 1 240px;
		min-width: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
		padding: 16px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5);
	}
	.ot-panel--r2 {
		background: color-mix(in srgb, var(--ot-amber) 8%, var(--sl-color-bg));
	}
	.ot-panel--pg {
		background: color-mix(in srgb, #2563eb 8%, var(--sl-color-bg));
	}

	.ot-head {
		display: flex;
		flex-direction: column;
		gap: 1px;
		margin: 0;
	}
	.ot-title {
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
		margin: 0;
	}
	.ot-sub {
		font-size: 0.76rem;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* The chip area — fixed min-height so the empty + filled states match, and
	   so the single-chip steps don't collapse the stage. */
	.ot-slot {
		display: flex;
		align-items: center;
		min-height: 78px;
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	/* ── A chip (object or row) ───────────────────────────────────────────── */
	.ot-chip {
		display: flex;
		align-items: center;
		gap: 10px;
		width: 100%;
		box-sizing: border-box;
		margin: 0;
		padding: 11px 13px;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-2);
	}
	.ot-chip-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--sl-color-gray-2);
		margin: 0;
	}
	.ot-chip-body {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 0;
		margin: 0;
	}
	.ot-chip-key {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-white);
		background: transparent;
		border: 0;
		margin: 0;
		padding: 0;
		overflow-wrap: anywhere;
	}
	.ot-chip-tag {
		align-self: flex-start;
		font-size: 0.66rem;
		font-weight: 800;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		border-radius: 999px;
		margin: 0;
		padding: 1.5px 8px;
	}

	/* Orphan-bytes chip — amber, the cheap litter. */
	.ot-chip.is-orphan-bytes {
		border-color: color-mix(in srgb, var(--ot-amber) 60%, transparent);
		background: color-mix(in srgb, var(--ot-amber) 12%, var(--sl-color-bg));
	}
	.ot-chip.is-orphan-bytes .ot-chip-icon,
	.ot-chip.is-orphan-bytes .ot-chip-key {
		color: color-mix(in srgb, var(--ot-amber) 75%, var(--sl-color-text));
	}
	.ot-chip.is-orphan-bytes .ot-chip-tag {
		color: #fff;
		background: var(--ot-amber);
	}

	/* Orphan-row chip — red, the correctness bug. */
	.ot-chip.is-orphan-row {
		border-color: color-mix(in srgb, var(--ot-red) 60%, transparent);
		background: color-mix(in srgb, var(--ot-red) 11%, var(--sl-color-bg));
	}
	.ot-chip.is-orphan-row .ot-chip-icon,
	.ot-chip.is-orphan-row .ot-chip-key {
		color: color-mix(in srgb, var(--ot-red) 78%, var(--sl-color-text));
	}
	.ot-chip.is-orphan-row .ot-chip-tag {
		color: #fff;
		background: var(--ot-red);
	}

	/* Empty slot — a dashed placeholder so absence reads as a deliberate state. */
	.ot-empty {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		box-sizing: border-box;
		margin: 0;
		padding: 11px 13px;
		border-radius: 10px;
		border: 1.5px dashed var(--sl-color-gray-5);
		background: transparent;
		font-size: 0.8rem;
		font-style: italic;
		color: var(--sl-color-gray-4);
	}

	@media (max-width: 560px) {
		.ot-slot {
			min-height: 70px;
		}
	}
</style>
