---
import Figure from '../../../figures/Figure.astro';

// Two signal colors carry the whole contrast: red = the naive shape (wrong),
// green = the signed shape (right). Saturated so they read on either theme;
// box labels stay on currentColor / Starlight grays so they're theme-safe.
const red = '#dc2626';
const green = '#16a34a';
const signedBlue = '#2563eb';

// Shared box styling. Reset margin on every inner element (Starlight prose
// margins) and box-sizing: border-box throughout per the html-css constraints.
const box =
  'display: inline-flex; align-items: center; justify-content: center; box-sizing: border-box; padding: 8px 14px; border-radius: 8px; border: 1px solid var(--sl-color-gray-4); background: color-mix(in srgb, var(--sl-color-gray-6) 55%, transparent); font-size: 0.85rem; font-weight: 700; color: var(--sl-color-white); white-space: nowrap; margin: 0;';

// A connector = the arrow glyph plus a small tinted label of what travels it.
const connectorWrap =
  'display: inline-flex; flex-direction: column; align-items: center; gap: 2px; box-sizing: border-box; margin: 0;';
const arrowGlyph =
  'font-size: 1.15rem; line-height: 1; font-weight: 700; margin: 0;';
const connectorLabel =
  'font-size: 0.68rem; font-weight: 700; letter-spacing: 0.02em; white-space: nowrap; margin: 0;';

const rowCaption =
  'font-size: 0.78rem; color: var(--sl-color-gray-3); margin: 0;';
const rowHeader =
  'display: inline-flex; align-items: center; gap: 6px; font-size: 0.8rem; font-weight: 700; white-space: nowrap; margin: 0;';
---

<Figure
  caption="The byte path goes around the function, not through it. The function signs; the browser transfers."
>
  <div
    style="display: flex; flex-direction: column; gap: 22px; width: 100%; box-sizing: border-box; margin: 0;"
  >
    {/* ROW 1 — naive: bytes through the function (wrong) */}
    <div
      style={`display: flex; flex-direction: column; gap: 12px; box-sizing: border-box; padding: 16px; border-radius: 12px; border: 1px solid color-mix(in srgb, ${red} 35%, var(--sl-color-gray-5)); border-left: 4px solid ${red}; background: color-mix(in srgb, ${red} 6%, var(--sl-color-bg)); margin: 0;`}
    >
      <span style={`${rowHeader} color: ${red};`}>
        <span aria-hidden="true" style="margin: 0;">✕</span>
        Naive — bytes through the function
      </span>

      <div
        style="display: flex; flex-wrap: wrap; align-items: center; gap: 10px 12px; box-sizing: border-box; margin: 0;"
      >
        <span style={box}>Browser</span>

        <span style={connectorWrap}>
          <span aria-hidden="true" style={`${arrowGlyph} color: ${red};`}>→</span>
          <span style={`${connectorLabel} color: ${red};`}>file bytes</span>
        </span>

        <span style={`${box} border-color: color-mix(in srgb, ${red} 55%, transparent);`}
          >Your function</span
        >

        <span style={connectorWrap}>
          <span aria-hidden="true" style={`${arrowGlyph} color: ${red};`}>→</span>
          <span style={`${connectorLabel} color: ${red};`}>file bytes</span>
        </span>

        <span style={box}>R2</span>
      </div>

      <span style={rowCaption}
        >Bytes travel twice, through the function — timeout on large files.</span
      >
    </div>

    {/* ROW 2 — signed: bytes go direct, function off to the side (right) */}
    <div
      style={`display: flex; flex-direction: column; gap: 14px; box-sizing: border-box; padding: 16px; border-radius: 12px; border: 1px solid color-mix(in srgb, ${green} 35%, var(--sl-color-gray-5)); border-left: 4px solid ${green}; background: color-mix(in srgb, ${green} 6%, var(--sl-color-bg)); margin: 0;`}
    >
      <span style={`${rowHeader} color: ${green};`}>
        <span aria-hidden="true" style="margin: 0;">✓</span>
        Signed — bytes go direct
      </span>

      {/* The function sits above, linked to the browser only by the signed URL */}
      <div
        style="display: flex; flex-direction: column; align-items: flex-start; gap: 4px; box-sizing: border-box; margin: 0;"
      >
        <span style={`${box} border-color: color-mix(in srgb, ${signedBlue} 55%, transparent);`}
          >Your function</span
        >
        <span
          style="display: inline-flex; align-items: center; gap: 6px; box-sizing: border-box; margin: 0;"
        >
          <span aria-hidden="true" style={`${arrowGlyph} color: ${signedBlue};`}
            >↓</span
          >
          <span style={`${connectorLabel} color: ${signedBlue}; font-weight: 600;`}
            >signs &amp; hands back a signed URL</span
          >
        </span>
      </div>

      {/* The unbroken Browser → R2 byte path */}
      <div
        style="display: flex; flex-wrap: wrap; align-items: center; gap: 10px 12px; box-sizing: border-box; margin: 0;"
      >
        <span style={box}>Browser</span>

        <span style={connectorWrap}>
          <span aria-hidden="true" style={`${arrowGlyph} color: ${green};`}>→</span>
          <span style={`${connectorLabel} color: ${green};`}>file bytes</span>
        </span>

        <span style={box}>R2</span>
      </div>

      <span style={rowCaption}
        >Function signs a URL; bytes go browser → R2 directly.</span
      >
    </div>
  </div>
</Figure>
