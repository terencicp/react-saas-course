---
import Figure from '../../../figures/Figure.astro';

// Illustrative 2026 list-price estimates for a read-heavy SaaS:
// 10 TB stored, 50 TB/month egress. Same files, same downloads.
const SCALE_MAX = 3800; // $/mo — shared horizontal scale for both bars

const storageOps = 150; // storage + per-operation fees, ~equal on both providers
const r2Egress = 0; // R2 charges nothing for egress
const s3Egress = 3500; // 50 TB out at tiered ~$0.09 -> $0.07 per GB
const r2Total = storageOps + r2Egress;
const s3Total = storageOps + s3Egress;

const pct = (value: number) => `${(value / SCALE_MAX) * 100}%`;

const blue = '#2563eb';
const red = '#dc2626';
---

<Figure
  caption="Same files, same downloads. The only difference in the bill is the thing R2 doesn't charge for — egress (illustrative 2026 list-price estimates)."
>
  <div style="display: flex; flex-direction: column; gap: 20px; width: 100%; box-sizing: border-box; margin: 0;">
    {/* R2 row */}
    <div style="display: flex; flex-direction: column; gap: 6px; margin: 0;">
      <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin: 0;">
        <span style="font-weight: 700; font-size: 0.95rem; color: var(--sl-color-white); margin: 0;">R2</span>
        <span style="font-weight: 700; font-size: 0.95rem; color: var(--sl-color-white); margin: 0;">≈ ${r2Total}/mo</span>
      </div>
      <div style="display: flex; align-items: stretch; width: 100%; height: 44px; box-sizing: border-box; margin: 0;">
        <div
          style={`display: flex; align-items: center; justify-content: center; height: 44px; min-width: 0; box-sizing: border-box; background: ${blue}; color: #fff; font-size: 0.8rem; font-weight: 600; white-space: nowrap; padding: 0 10px; border-radius: 6px; margin: 0; width: ${pct(storageOps)};`}
        >
          storage + ops ${storageOps}
        </div>
        <div style="display: flex; align-items: center; gap: 6px; min-width: 0; box-sizing: border-box; margin: 0;">
          <span
            style={`display: inline-block; height: 44px; width: 6px; box-sizing: border-box; background: ${red}; border-radius: 3px; margin: 0 0 0 4px;`}
          ></span>
          <span style="font-size: 0.8rem; font-weight: 600; color: var(--sl-color-gray-2); white-space: nowrap; margin: 0;">egress $0</span>
        </div>
      </div>
    </div>

    {/* S3 row */}
    <div style="display: flex; flex-direction: column; gap: 6px; margin: 0;">
      <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin: 0;">
        <span style="font-weight: 700; font-size: 0.95rem; color: var(--sl-color-white); margin: 0;">S3</span>
        <span style="font-weight: 700; font-size: 0.95rem; color: var(--sl-color-white); margin: 0;">≈ ${s3Total.toLocaleString()}/mo</span>
      </div>
      <div style="display: flex; align-items: stretch; width: 100%; height: 44px; box-sizing: border-box; margin: 0;">
        <div
          style={`display: flex; align-items: center; justify-content: center; height: 44px; min-width: 0; box-sizing: border-box; background: ${blue}; color: #fff; font-size: 0.8rem; font-weight: 600; white-space: nowrap; padding: 0 10px; border-radius: 6px 0 0 6px; margin: 0; width: ${pct(storageOps)};`}
        >
          storage + ops ${storageOps}
        </div>
        <div
          style={`display: flex; align-items: center; justify-content: center; height: 44px; min-width: 0; box-sizing: border-box; background: ${red}; color: #fff; font-size: 0.8rem; font-weight: 600; white-space: nowrap; padding: 0 10px; border-radius: 0 6px 6px 0; margin: 0; width: ${pct(s3Egress)};`}
        >
          egress ${s3Egress.toLocaleString()}
        </div>
      </div>
    </div>

    {/* Legend */}
    <div style="display: flex; flex-wrap: wrap; column-gap: 18px; row-gap: 8px; align-items: center; font-size: 0.8rem; color: var(--sl-color-gray-2); margin: 0;">
      <span style="display: inline-flex; align-items: center; gap: 6px; margin: 0;">
        <span style={`display: inline-block; width: 12px; height: 12px; border-radius: 3px; background: ${blue}; margin: 0;`}></span>
        storage + operations
      </span>
      <span style="display: inline-flex; align-items: center; gap: 6px; margin: 0;">
        <span style={`display: inline-block; width: 12px; height: 12px; border-radius: 3px; background: ${red}; margin: 0;`}></span>
        egress (data transfer out)
      </span>
    </div>
  </div>
</Figure>
