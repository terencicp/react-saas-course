---
import Figure from '../../../figures/Figure.astro';

// The accent that IS the join: the objectKey token is the same violet on both
// sides, so the eye connects the row's field to the object's path without an
// arrow (color-matching beats arrows for pure correspondence).
const violet = '#7c3aed';

// Object key contains ${...}; keep it in a JS string so MDX never evaluates it.
const objectKeyPath = 'org/${organizationId}/files/${fileId}';

// file_metadata row fields. `key` flags the one matched to the R2 side.
const fields: { name: string; key?: boolean }[] = [
  { name: 'id' },
  { name: 'organizationId' },
  { name: 'objectKey', key: true },
  { name: 'contentType' },
  { name: 'byteSize' },
  { name: 'uploadedBy' },
  { name: 'uploadedAt' },
];

const panelBase =
  'flex: 1 1 280px; min-width: 0; box-sizing: border-box; display: flex; flex-direction: column; gap: 14px; padding: 18px; border-radius: 12px; border: 1px solid var(--sl-color-gray-5); margin: 0;';
const pgPanel = `${panelBase} background: color-mix(in srgb, #2563eb 8%, var(--sl-color-bg));`;
const r2Panel = `${panelBase} background: color-mix(in srgb, #f59e0b 9%, var(--sl-color-bg));`;
---

<Figure
  caption="Two stores, one key. Postgres owns the record; R2 owns the bytes; the object key is the seam between them."
>
  <div
    style="display: flex; flex-direction: column; gap: 18px; width: 100%; box-sizing: border-box; margin: 0;"
  >
    {/* The two panels */}
    <div
      style="display: flex; flex-wrap: wrap; gap: 16px; align-items: stretch; width: 100%; box-sizing: border-box; margin: 0;"
    >
      {/* LEFT — Postgres */}
      <div style={pgPanel}>
        <div style="display: flex; flex-direction: column; gap: 2px; margin: 0;">
          <span
            style="font-weight: 700; font-size: 1rem; color: var(--sl-color-white); margin: 0;"
            >Postgres</span
          >
          <span
            style="font-size: 0.78rem; color: var(--sl-color-gray-3); margin: 0;"
            >file_metadata row (source of truth)</span
          >
        </div>
        <div
          style="display: flex; flex-direction: column; gap: 4px; box-sizing: border-box; margin: 0;"
        >
          {
            fields.map((field) => (
              <div
                style={`display: flex; align-items: center; box-sizing: border-box; padding: 6px 10px; border-radius: 6px; background: ${
                  field.key
                    ? `color-mix(in srgb, ${violet} 16%, transparent)`
                    : 'color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent)'
                }; margin: 0;`}
              >
                <code
                  style={`font-size: 0.85rem; font-weight: ${
                    field.key ? 700 : 600
                  }; color: ${
                    field.key ? violet : 'var(--sl-color-white)'
                  }; background: transparent; margin: 0; padding: 0;`}
                >
                  {field.name}
                </code>
              </div>
            ))
          }
        </div>
      </div>

      {/* RIGHT — R2 bucket */}
      <div style={r2Panel}>
        <div style="display: flex; flex-direction: column; gap: 2px; margin: 0;">
          <span
            style="font-weight: 700; font-size: 1rem; color: var(--sl-color-white); margin: 0;"
            >R2 bucket</span
          >
          <span
            style="font-size: 0.78rem; color: var(--sl-color-gray-3); margin: 0;"
            >the object (just bytes)</span
          >
        </div>
        <div
          style="display: flex; flex-direction: column; gap: 10px; justify-content: center; flex: 1 1 auto; box-sizing: border-box; margin: 0;"
        >
          <div
            style="display: flex; flex-direction: column; gap: 8px; box-sizing: border-box; padding: 16px; border-radius: 10px; border: 1px dashed var(--sl-color-gray-4); background: color-mix(in srgb, var(--sl-color-gray-6) 55%, transparent); margin: 0;"
          >
            <div
              style="display: flex; align-items: center; gap: 8px; box-sizing: border-box; margin: 0;"
            >
              <span
                aria-hidden="true"
                style="font-size: 1.1rem; line-height: 1; margin: 0;">📄</span
              >
              <code
                style={`font-size: 0.82rem; font-weight: 700; color: ${violet}; background: transparent; word-break: break-all; margin: 0; padding: 0;`}
                >{objectKeyPath}</code
              >
            </div>
            <span
              style="font-size: 0.78rem; color: var(--sl-color-gray-3); margin: 0;"
              >≈ 2.4 MB · application/pdf</span
            >
          </div>
        </div>
      </div>
    </div>

    {/* The join label, in the matched accent */}
    <div
      style="display: flex; justify-content: center; align-items: center; box-sizing: border-box; margin: 0;"
    >
      <span
        style={`display: inline-flex; align-items: center; gap: 6px; box-sizing: border-box; padding: 4px 12px; border-radius: 999px; background: color-mix(in srgb, ${violet} 12%, transparent); border: 1px solid color-mix(in srgb, ${violet} 35%, transparent); font-size: 0.78rem; font-weight: 600; color: ${violet}; margin: 0;`}
        >join = object key</span
      >
    </div>
  </div>
</Figure>
