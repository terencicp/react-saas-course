---
// artifacts-env-map — Chapter 068 Lesson 2, "Standing up R2 — buckets, scoped
// tokens, and CORS".
//
// The whole surface on one screen, before any clicking or code: the FOUR
// artifacts this lesson stands up, the config value each produces/consumes, and
// the single failure each one prevents. The reassurance is that it's a closed
// set — four artifacts, four config values, four failures — nothing else to
// configure.
//
// Layout is a four-row "swimlane" grid:
//   [ artifact card ]   →   [ env chip(s) ]   →   [ protects-against badge ]
// Each artifact lives on its own row, so every arrow is a short horizontal hop
// that never crosses another row's content. Left→middle arrows carry the env
// var(s) the artifact produces/consumes; left→right arrows carry the protection.
// The CORS row has NO env chip (it lives on the bucket, reusing the app's
// existing NEXT_PUBLIC_APP_URL) — so its only arrow runs straight to the badge.
//
// The two arrows the lesson dwells on — the scoped token and the CORS rule — are
// the trust boundaries, colored ORANGE. Everything else is the theme blue.
//
// Built with <ArrowDiagram> (LeaderLine) because each artifact box is a two-zone
// card (title strip + body) and the env chips are code-styled — the per-zone
// anchors and the semantic arrow coloring are the whole point; D2/Mermaid
// plain-label boxes wouldn't carry them. LeaderLine positions arrows from
// document.body, so the wrapping <Figure> MUST be expandable={false}: relocating
// the body into a lightbox breaks the lines.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Mid-tone accents reused verbatim in light + dark.
const BLUE = '#0ea5e9'; // ordinary wiring
const ORANGE = '#f97316'; // the two trust boundaries the lesson dwells on

const arrows = [
	// Row 1 — the bucket.
	{
		from: 'aem-a-bucket',
		to: 'aem-e-name',
		color: BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [50, 0],
		endSocketGravity: [-50, 0],
	},
	{
		from: 'aem-b-bucket',
		to: 'aem-p-bucket',
		color: BLUE,
		startSocket: 'right',
		endSocket: 'left',
		// Bow down through the row-gap so the curve clears its own row's env chip
		// instead of grazing it on the way across.
		startSocketGravity: [60, 46],
		endSocketGravity: [-60, 46],
	},
	// Row 2 — the scoped token. TRUST BOUNDARY → orange. Produces TWO chips
	// (access key + secret), so its left→middle arrow splits to land on each.
	{
		from: 'aem-a-token',
		to: 'aem-e-akid',
		color: ORANGE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [50, -8],
		endSocketGravity: [-50, 0],
	},
	{
		from: 'aem-a-token',
		to: 'aem-e-secret',
		color: ORANGE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [50, 22],
		endSocketGravity: [-50, 0],
	},
	{
		from: 'aem-b-token',
		to: 'aem-p-token',
		color: ORANGE,
		startSocket: 'right',
		endSocket: 'left',
		// Row 2 has two stacked chips; bow further down to clear the lower one.
		startSocketGravity: [60, 58],
		endSocketGravity: [-60, 58],
	},
	// Row 3 — the CORS rule. TRUST BOUNDARY → orange. NO env chip: the only arrow
	// runs straight from the card to its protection badge.
	{
		from: 'aem-b-cors',
		to: 'aem-p-cors',
		color: ORANGE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [50, 0],
		endSocketGravity: [-50, 0],
	},
	// Row 4 — lib/r2.ts. Consumes the account id (the endpoint is derived from it).
	{
		from: 'aem-a-r2',
		to: 'aem-e-account',
		color: BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [50, 0],
		endSocketGravity: [-50, 0],
	},
	{
		from: 'aem-b-r2',
		to: 'aem-p-r2',
		color: BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 46],
		endSocketGravity: [-60, 46],
	},
];
---

<Figure expandable={false}>
	<div class="aem not-content">
		<ArrowDiagram arrows={arrows}>
			<div class="aem-grid">
				<!-- Column headers -->
				<div class="aem-head">Artifact</div>
				<div class="aem-head">Config value</div>
				<div class="aem-head">Protects against</div>

				<!-- Row 1 — Bucket -->
				<div class="aem-card aem-blue">
					<div class="aem-card-tab" id="aem-a-bucket">Bucket</div>
					<div class="aem-card-body" id="aem-b-bucket">
						namespace, one per environment
					</div>
				</div>
				<div class="aem-chips">
					<code class="aem-chip" id="aem-e-name">R2_BUCKET_NAME</code>
				</div>
				<div class="aem-badge" id="aem-p-bucket">Staging bytes in prod</div>

				<!-- Row 2 — Scoped token -->
				<div class="aem-card aem-orange">
					<div class="aem-card-tab" id="aem-a-token">Scoped token</div>
					<div class="aem-card-body" id="aem-b-token">
						this bucket, read + write only
					</div>
				</div>
				<div class="aem-chips">
					<code class="aem-chip" id="aem-e-akid">R2_ACCESS_KEY_ID</code>
					<code class="aem-chip" id="aem-e-secret">R2_SECRET_ACCESS_KEY</code>
				</div>
				<div class="aem-badge" id="aem-p-token">
					A leaked key deleting every bucket
				</div>

				<!-- Row 3 — CORS rule (no env chip) -->
				<div class="aem-card aem-orange">
					<div class="aem-card-tab" id="aem-a-cors">CORS rule</div>
					<div class="aem-card-body" id="aem-b-cors">
						your origin, GET + PUT, content-type
					</div>
				</div>
				<div class="aem-chips aem-chips-empty">
					<span class="aem-none">no env var — lives on the bucket</span>
				</div>
				<div class="aem-badge" id="aem-p-cors">
					A leaked URL replayed from anywhere
				</div>

				<!-- Row 4 — lib/r2.ts -->
				<div class="aem-card aem-blue">
					<div class="aem-card-tab" id="aem-a-r2">lib/r2.ts</div>
					<div class="aem-card-body" id="aem-b-r2">
						one configured S3 client
					</div>
				</div>
				<div class="aem-chips">
					<code class="aem-chip" id="aem-e-account">R2_ACCOUNT_ID</code>
				</div>
				<div class="aem-badge" id="aem-p-r2">A new client per request</div>
			</div>
		</ArrowDiagram>
	</div>
	<Fragment slot="caption">
		Four artifacts, four config values, four failures prevented — and nothing
		else to configure. The two orange arrows are the trust boundaries this
		lesson dwells on.
	</Fragment>
</Figure>

<style>
	.aem {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.aem-grid {
		display: grid;
		grid-template-columns: minmax(160px, 1.1fr) minmax(150px, 1fr) minmax(
				140px,
				1fr
			);
		column-gap: 96px;
		row-gap: 30px;
		align-items: center;
		padding: 6px 4px 10px;
	}

	.aem-head {
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
		padding-bottom: 2px;
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
	}

	/* Artifact cards — two anchorable zones: a title strip + a one-line body. */
	.aem-card {
		box-sizing: border-box;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		overflow: hidden;
		margin: 0;
	}

	.aem-card-tab {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.2;
		padding: 7px 12px;
		color: var(--sl-color-white, #1e293b);
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}

	.aem-card-body {
		font-size: 0.72rem;
		line-height: 1.3;
		padding: 7px 12px;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* Trust-boundary cards get an orange left rail; ordinary ones a blue rail. */
	.aem-orange {
		border-left: 3px solid #f97316;
	}
	.aem-blue {
		border-left: 3px solid #0ea5e9;
	}

	/* Middle column — code-styled env chips. */
	.aem-chips {
		display: flex;
		flex-direction: column;
		gap: 6px;
		align-items: flex-start;
		margin: 0;
	}

	.aem-chip {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 600;
		line-height: 1.2;
		padding: 4px 8px;
		border-radius: 6px;
		white-space: nowrap;
		background: color-mix(in srgb, var(--sl-color-gray-6, #e2e8f0) 70%, transparent);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.aem-chips-empty {
		align-items: flex-start;
	}

	.aem-none {
		font-size: 0.64rem;
		font-style: italic;
		line-height: 1.3;
		color: var(--sl-color-gray-4, #94a3b8);
	}

	/* Right column — "protects against" badges. */
	.aem-badge {
		font-size: 0.72rem;
		font-weight: 500;
		line-height: 1.25;
		padding: 7px 11px;
		border-radius: 8px;
		background: color-mix(in srgb, #ef4444 12%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, #ef4444 38%, transparent);
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	/* Narrow viewports: the cross-region sockets have no horizontal gap to live
	   in once columns collapse, so drop to a single readable column. The arrows
	   degrade to vertical arcs between stacked cells — still legible. */
	@media (max-width: 760px) {
		.aem-grid {
			grid-template-columns: 1fr;
			column-gap: 0;
			row-gap: 10px;
		}
		.aem-head {
			display: none;
		}
		.aem-chips,
		.aem-badge {
			margin-left: 14px;
		}
	}
</style>
