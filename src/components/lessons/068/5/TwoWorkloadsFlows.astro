---
// two-workloads-flows — Chapter 068 Lesson 5, "Wiring R2 into our app — two
// workloads, one mechanism".
//
// The lesson's whole payload is a contrast, so the figure is two tabs the
// student flips between. Two signal colors carry the asymmetry across BOTH
// tabs: orange = the file-byte path, blue = the metadata round-trip. The eye
// should read the same two colors meaning the same two things in either tab.
//
//   Tab 1 (User upload): the orange byte arrow ARCS OVER the Server Action box
//   straight to R2 — bytes bypass the function. The blue arrows form the small
//   metadata round-trip THROUGH the function: sign + finalize, HEAD-verify,
//   INSERT. A file_metadata box is present — it's the canonical record.
//
//   Tab 2 (Export output): the Trigger.dev worker sits directly ON the orange
//   byte path (server-side PUT), and there is DELIBERATELY no file_metadata box
//   at all — the missing box is the point. A short blue presigned-GET arrow
//   feeds the emailed link.
//
// ArrowDiagram supplies only the arrow layer; the boxes are authored HTML here
// and styled by the shared classes below. Imports reach the shared figures dir
// three levels up (this file lives at components/lessons/068/5/), matching the
// sibling 068 components.

import ArrowDiagram from '../../../figures/ArrowDiagram.astro';
import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

// Byte path vs metadata path — mid-tones that read on both themes.
const orange = '#ea580c';
const blue = '#2563eb';
---

<TabbedContent>
	<TabbedItem
		label="User upload"
		caption="The bytes bypass your function entirely (orange); only the small metadata round-trip touches it (blue). The row is the canonical record."
	>
		<ArrowDiagram
			arrows={[
				{
					from: 'up-browser',
					to: 'up-r2',
					label: 'presigned PUT (bytes)',
					color: orange,
					startSocket: 'top',
					endSocket: 'top',
					startSocketGravity: [0, -150],
					endSocketGravity: [0, -150],
					labelOffset: [0, -12],
				},
				{
					from: 'up-browser',
					to: 'up-action',
					label: 'sign + finalize (small JSON)',
					color: blue,
					startSocket: 'right',
					endSocket: 'left',
					startSocketGravity: [50, 0],
					endSocketGravity: [-50, 0],
					labelOffset: [0, 26],
				},
				{
					from: 'up-r2',
					to: 'up-action',
					label: 'HEAD',
					color: blue,
					startSocket: 'left',
					endSocket: 'right',
					startSocketGravity: [-30, 0],
					endSocketGravity: [30, 0],
					labelOffset: [0, -12],
				},
				{
					from: 'up-action',
					to: 'up-meta',
					label: 'INSERT',
					color: blue,
					startSocket: 'bottom',
					endSocket: 'left',
					startSocketGravity: [60, 30],
					endSocketGravity: [-50, 0],
					labelOffset: [12, 14],
				},
			]}
		>
			<div class="twf not-content">
				<div class="twf-row twf-row--up">
					<div class="twf-box" id="up-browser">
						<span class="twf-box-title">Browser</span>
						<span class="twf-box-sub">member picks a file</span>
					</div>
					<div class="twf-box twf-box--fn" id="up-action">
						<span class="twf-box-title">Server Action</span>
						<span class="twf-box-sub">signs &amp; records</span>
					</div>
					<div class="twf-stack">
						<div class="twf-box twf-box--store" id="up-r2">
							<span class="twf-box-title">R2</span>
							<span class="twf-box-sub">files/ prefix</span>
						</div>
						<div class="twf-box twf-box--meta" id="up-meta">
							<span class="twf-box-title">file_metadata row</span>
							<span class="twf-box-sub">canonical record</span>
						</div>
					</div>
				</div>
			</div>
		</ArrowDiagram>
	</TabbedItem>

	<TabbedItem
		label="Export output"
		caption="The worker IS in the byte path (orange) — and there's no file_metadata box at all. A lifecycle rule reclaims the object later."
	>
		<ArrowDiagram
			arrows={[
				{
					from: 'ex-worker',
					to: 'ex-r2',
					label: 'server-side PUT (bytes)',
					color: orange,
					startSocket: 'right',
					endSocket: 'left',
					startSocketGravity: [60, 0],
					endSocketGravity: [-60, 0],
					labelOffset: [0, -14],
				},
				{
					from: 'ex-r2',
					to: 'ex-email',
					label: 'presigned GET',
					color: blue,
					startSocket: 'right',
					endSocket: 'left',
					startSocketGravity: [60, 0],
					endSocketGravity: [-60, 0],
					labelOffset: [0, -14],
				},
			]}
		>
			<div class="twf not-content">
				<div class="twf-row twf-row--ex">
					<div class="twf-box twf-box--fn" id="ex-worker">
						<span class="twf-box-title">Trigger.dev worker</span>
						<span class="twf-box-sub">holds the whole CSV</span>
					</div>
					<div class="twf-box twf-box--store" id="ex-r2">
						<span class="twf-box-title">R2</span>
						<span class="twf-box-sub">exports/ prefix</span>
					</div>
					<div class="twf-box twf-box--mail" id="ex-email">
						<span class="twf-box-title">Email link</span>
						<span class="twf-box-sub">clicked once</span>
					</div>
				</div>
				<div class="twf-noteline" aria-hidden="false">
					<span class="twf-noteline-tag">no file_metadata row</span>
					<span class="twf-noteline-text"
						>a lifecycle rule on the <code>exports/</code> prefix reclaims it
						later</span
					>
				</div>
			</div>
		</ArrowDiagram>
	</TabbedItem>
</TabbedContent>

<style>
	.twf {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* Tab 1 reserves vertical room for the orange arc over the Server Action and
	   the blue round-trip below; tab 2 is a flat left-to-right strip. */
	.twf-row {
		display: flex;
		align-items: center;
		justify-content: center;
		box-sizing: border-box;
		margin: 0;
	}
	.twf-row--up {
		gap: 64px;
		padding: 58px 8px 40px;
	}
	.twf-row--ex {
		gap: 90px;
		padding: 24px 8px 18px;
	}

	/* A vertical pair (R2 over its metadata row) so the upload diagram stays
	   flat horizontally while still showing the INSERT into a separate box. */
	.twf-stack {
		display: flex;
		flex-direction: column;
		gap: 38px;
		box-sizing: border-box;
		margin: 0;
	}

	.twf-box {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		box-sizing: border-box;
		padding: 9px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		white-space: nowrap;
		margin: 0;
	}

	.twf-box-title {
		font-size: 0.84rem;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.twf-box-sub {
		font-size: 0.66rem;
		font-weight: 500;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Colored top-rails group the box by role: function (the thing the byte rule
	   is about), object store, the metadata row, the email sink. */
	.twf-box--fn {
		border-top: 3px solid #6366f1;
	}
	.twf-box--store {
		border-top: 3px solid #ea580c;
	}
	.twf-box--meta {
		border-top: 3px solid #2563eb;
	}
	.twf-box--mail {
		border-top: 3px solid #0d9488;
	}

	/* The "no row" callout under the export strip — the absent box made explicit. */
	.twf-noteline {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: center;
		gap: 9px;
		margin: 4px 0 0;
		padding: 8px 11px;
		border-radius: 9px;
		border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 30%,
			transparent
		);
	}
	.twf-noteline-tag {
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		line-height: 1;
		padding: 4px 8px;
		border-radius: 6px;
		color: var(--sl-color-gray-3, #64748b);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-5, #cbd5e1) 35%,
			transparent
		);
		text-decoration: line-through;
		margin: 0;
	}
	.twf-noteline-text {
		font-size: 0.72rem;
		font-style: italic;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.twf-noteline-text code {
		font-size: 0.68rem;
	}

	/* Narrow viewports: the upload row's three columns get cramped — let the
	   stack wrap under and tighten gaps. Arrows reflow on resize. */
	@media (max-width: 640px) {
		.twf-row--up {
			gap: 40px;
			padding-top: 52px;
		}
		.twf-row--ex {
			gap: 64px;
		}
	}
</style>
