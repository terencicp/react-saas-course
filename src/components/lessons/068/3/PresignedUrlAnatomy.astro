---
// presigned-url-anatomy — a labeled string, not a graph.
// One presigned PUT URL broken into four tinted segments, each with a
// matching callout below. Colors reuse the course's theme-aware --mark-*
// variables (custom.css) so tints flip correctly between light and dark.
//
// Segments (colors match the PUT-walkthrough convention: green = the
// content-type pin, and orange — the size trap — is deliberately absent
// because no URL segment carries it):
//   A (blue)   base address — which object, which operation
//   B (violet) X-Amz-Expires — the fuse, in seconds
//   C (green)  X-Amz-SignedHeaders — the content-type pin the client must send unchanged
//   D (red)    X-Amz-Signature — seals everything above; tamper and it's a 403

const segStyle = (color: string) =>
  [
    'background: var(--mark-' + color + '-bg)',
    'box-shadow: inset 0 0 0 1px var(--mark-' + color + '-brd)',
    'border-radius: 4px',
    'padding: 1px 3px',
    'margin: 0',
    'white-space: nowrap',
  ].join('; ');

const swatchStyle = (color: string) =>
  [
    'flex: 0 0 auto',
    'width: 14px',
    'height: 14px',
    'border-radius: 4px',
    'margin: 2px 0 0',
    'background: var(--mark-' + color + '-bg)',
    'box-shadow: inset 0 0 0 1px var(--mark-' + color + '-brd)',
  ].join('; ');

const calloutStyle =
  'display: flex; gap: 10px; align-items: flex-start; margin: 0; padding: 0;';

const callouts = [
  {
    color: 'blue',
    title: 'Which object, which operation.',
    body: 'The bucket and the tenancy-scoped key — PUT to this path and no other.',
  },
  {
    color: 'violet',
    code: 'X-Amz-Expires',
    title: 'The fuse, in seconds.',
    body: '300 = five minutes. After that the signature is dead.',
  },
  {
    color: 'green',
    code: 'X-Amz-SignedHeaders',
    title: 'The content-type pin the client must send unchanged.',
    body: 'Here, content-type. Send a different one and the signature won’t match.',
  },
  {
    color: 'red',
    code: 'X-Amz-Signature',
    title: 'Seals everything above.',
    body: 'Tamper with the key, the method, the expiry, or a signed header and R2 returns 403.',
  },
];
---

<div style="margin: 0;">
  {/* The URL — tinted segments that wrap naturally across lines. */}
  <div
    style="margin: 0; padding: 14px 16px; border-radius: 8px; background: var(--sl-color-bg); border: 1px solid var(--sl-color-gray-5); font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Consolas, monospace); font-size: 0.9rem; line-height: 2.1; word-break: break-all; color: var(--sl-color-gray-2);"
  >
    <span style={segStyle('blue')}
      >https://&lt;account&gt;.r2.cloudflarestorage.com/acme-saas-prod/org/8f3a/files/9b2e…d41.png</span
    ><span style="margin: 0;">?X-Amz-Algorithm=AWS4-HMAC-SHA256&amp;…&amp;</span><span
      style={segStyle('violet')}>X-Amz-Expires=300</span
    ><span style="margin: 0;">&amp;</span><span style={segStyle('green')}
      >X-Amz-SignedHeaders=content-type</span
    ><span style="margin: 0;">&amp;</span><span style={segStyle('red')}
      >X-Amz-Signature=…a1b2c3</span
    >
  </div>

  {/* Callouts — one per tinted segment, two-up grid, color-matched. */}
  <div
    style="margin: 16px 0 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 24px; row-gap: 14px;"
  >
    {
      callouts.map((c) => (
        <div style={calloutStyle}>
          <span style={swatchStyle(c.color)} aria-hidden="true" />
          <div style="margin: 0; min-width: 0;">
            <div style="margin: 0; font-size: 0.9rem; line-height: 1.45;">
              {c.code && (
                <code style="background: transparent; padding: 0; font-size: 0.85rem; color: var(--sl-color-white);">
                  {c.code}
                </code>
              )}
              {c.code && ' — '}
              <strong style="color: var(--sl-color-white);">{c.title}</strong>
            </div>
            <div style="margin: 3px 0 0; font-size: 0.85rem; line-height: 1.45; color: var(--sl-color-gray-2);">
              {c.body}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</div>
