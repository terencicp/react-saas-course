---
// SendPath — Chapter 050 Lesson 1, "Project: the welcome email send path".
//
// The project overview's spine: one send walks a straight line through five
// hops, and a single box on that line — the lib/email.ts wrapper — is the
// CHOKEPOINT every future email re-enters at. This figure traces that line
// left→right and highlights box 3 so the eye lands on the seam the whole
// chapter is about.
//
//   Inspector form ─(FormData)─▶ sendWelcomeEmail ─(react element + idempotency key)─▶
//     sendEmail()  ─(send)─▶ Resend ───▶ your inbox
//                   ↑ CHOKEPOINT: the single seam every send passes through
//
// This is the project-scale sibling of Chapter 048's SendPath (four boxes,
// responsibility boundary). Here we add the inspector form at the front, split
// the Server Action from the wrapper, and recolor the highlight to mark the
// chokepoint rather than a vendor boundary — the prose's numbered walk carries
// the per-seam detail, so each box stays a title + one muted under-label to
// keep cognitive load low.
//
// Built with <ArrowDiagram> (LeaderLine): boxes are two-line custom HTML and
// the chokepoint box needs a distinct accent treatment a plain D2/Mermaid label
// can't carry. Arrows are positioned from document.body, so the wrapping
// <Figure> MUST be expandable={false} — relocating the body into the lightbox
// breaks the leader lines.
//
// Sockets are right→left between adjacent boxes in one horizontal row. The three
// labels sit in the gaps; the long middle label is lifted well above the wire and
// the two short labels sit just under it so the badges never collide at desktop
// width. Chrome is theme-aware (Starlight gray/white vars flip light/dark); the
// chokepoint accent (#0ea5e9 blue) is used as-is in both themes. A margin:0 reset
// defeats Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// The five boxes, left → right. `id` matches the arrow descriptors; `under` is
// the small muted label beneath each box title; `choke` marks the chokepoint box.
const boxes = [
	{ id: 'sp-form', title: 'Inspector form', under: 'client component' },
	{ id: 'sp-action', title: 'sendWelcomeEmail', under: 'Server Action' },
	{ id: 'sp-wrapper', title: 'sendEmail', under: 'src/lib/email.ts', choke: true },
	{ id: 'sp-resend', title: 'Resend', under: 'the vendor' },
	{ id: 'sp-inbox', title: 'Your inbox', under: 'verified domain' },
];

// Mid-tone accent reused verbatim in light + dark — marks the chokepoint.
const CHOKE_BLUE = '#0ea5e9';

const arrows = [
	// The native <form action={…}> post.
	{
		from: 'sp-form',
		to: 'sp-action',
		label: 'FormData',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [55, 0],
		endSocketGravity: [-55, 0],
		labelOffset: [0, -26],
	},
	// The in-process call into the chokepoint — lands on box 3. The long label is
	// lifted high above the row to clear the two short labels on either side.
	{
		from: 'sp-action',
		to: 'sp-wrapper',
		label: 'react element + idempotency key',
		color: CHOKE_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
		labelOffset: [0, -46],
	},
	// Leaves the chokepoint for the vendor.
	{
		from: 'sp-wrapper',
		to: 'sp-resend',
		label: 'send',
		color: CHOKE_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [55, 0],
		endSocketGravity: [-55, 0],
		labelOffset: [0, -26],
	},
	// The vendor's wire — no label, theme-neutral; deliverability is the point but
	// that detail belongs to Lesson 2, not this shape-only figure.
	{
		from: 'sp-resend',
		to: 'sp-inbox',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [55, 0],
		endSocketGravity: [-55, 0],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="sp not-content">
			{
				boxes.map((box) => (
					<div class:list={['sp-box', { 'sp-box-choke': box.choke }]} id={box.id}>
						{box.choke && <span class="sp-tag">chokepoint</span>}
						<span class="sp-title">{box.title}</span>
						<span class="sp-under">{box.under}</span>
					</div>
				))
			}
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		One send, five hops — and a single chokepoint. Every future email re-enters
		this line at the wrapper.
	</Fragment>
</Figure>

<style>
	.sp {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: space-between;
		gap: 76px;
		margin: 0;
		padding: 22px 4px 14px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.sp-box {
		position: relative;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		flex: 0 1 auto;
		padding: 11px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	/* The chokepoint box — accent border + faint tint so the eye lands on the one
	   seam the chapter is about. */
	.sp-box-choke {
		border-color: #0ea5e9;
		border-width: 2px;
		background: color-mix(in srgb, #0ea5e9 9%, var(--sl-color-bg, transparent));
	}

	.sp-tag {
		position: absolute;
		top: -10px;
		left: 50%;
		transform: translateX(-50%);
		padding: 1px 8px;
		border-radius: 999px;
		background: #0ea5e9;
		color: #fff;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		white-space: nowrap;
		line-height: 1.4;
	}

	.sp-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.84rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.sp-under {
		font-size: 0.64rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: stack the five boxes; the right→left sockets degrade to
	   vertical arcs between stacked boxes — readable, and the labels still float in
	   the gaps. */
	@media (max-width: 760px) {
		.sp {
			flex-direction: column;
			gap: 50px;
		}
		.sp-box {
			width: min(18rem, 100%);
		}
	}
</style>
