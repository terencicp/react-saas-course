---
// removed-member-self-heal (diagram id: removed-member-self-heal, Ch 057 L4 —
// "The five member-management flows", section "Why removed members don't need a
// logout").
//
// A 2-step DiagramSequence (self-carding — NOT wrapped in <Figure>) the reader
// scrubs:
//
//   STEP 1 (the remove):  [admin] --delete--> [member table, Bob's row struck]
//                         and, set apart, [Bob's session cookie — STILL VALID]
//   STEP 2 (next request): [Bob's browser + same valid cookie] --request-->
//                         [requireOrgUser reads membership FRESH] --no row-->
//                         [redirect out]  ("no logout was ever issued")
//
// The load-bearing teaching point: the removal action does NOTHING to Bob's
// session — the cookie is valid the whole time. Correctness self-heals only
// because requireOrgUser reads (org, user) membership FRESH from the DB on the
// next request, finds nothing, and redirects. So the session cookie is drawn as
// a persistent, untouched INDIGO chip present in BOTH steps (the surprising
// through-line); the eject channel (the delete, the missing row, the redirect)
// is RED. Neutral slate for chrome (admin, table, requireOrgUser, browser).
//
// House style (cf. 043/5 CommitVsRollback, the directly-prerequisite chapter's
// DiagramSequence): pinned `color-scheme: light` so the hand-picked tints
// survive dark mode; inline style strings (no <style> block) so each primitive
// shows exactly what styled it; `box-sizing: border-box`; `margin: 0` on every
// inner node to defeat Starlight's injected prose margins. Both steps reserve
// the same column structure + a fixed-height note row so the grid-stacked panels
// never jump as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ------------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted sub-labels
const SURFACE = '#ffffff';
const PANEL_BORDER = '#e2e8f0'; // slate-200 — neutral chrome
const CHROME_BG = '#f8fafc'; // slate-50 — neutral card wash

// RED — the eject channel: the delete, the missing row, the redirect out.
const RED = '#dc2626'; // red-600
const RED_BG = '#fef2f2'; // red-50
const RED_INK = '#b91c1c'; // red-700

// INDIGO — Bob's session cookie: still valid, untouched. The through-line.
const INDIGO = '#4f46e5'; // indigo-600
const INDIGO_BG = '#eef2ff'; // indigo-50
const INDIGO_INK = '#3730a3'; // indigo-800

// ---- shared atoms ----------------------------------------------------------
// Stage: the row of boxes, then a fixed-height note row reserved on every step
// so the panels stack without height jumps.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 0; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The horizontal machine: boxes + connectors, wraps on narrow cards.
const machine = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 9px; margin: 0; width: 100%;`;

// A neutral chrome card (actor / function / browser). Fixed min-height so the
// row reads as one band and the two steps reserve matching height.
const card = `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 5px; width: 158px; min-height: 104px; margin: 0; padding: 11px 12px; border: 1.5px solid ${PANEL_BORDER}; border-radius: 12px; background: ${CHROME_BG};`;
const cardEyebrow = `margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; line-height: 1.2; color: ${INK_SOFT};`;
const cardTitle = `margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 800; line-height: 1.25; color: ${INK};`;
const cardSub = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT};`;

// The member-table card — a tiny roster with one struck (removed) row.
const tableCard = `box-sizing: border-box; display: flex; flex-direction: column; gap: 0; width: 184px; min-height: 104px; margin: 0; border: 1.5px solid ${PANEL_BORDER}; border-radius: 12px; background: ${SURFACE}; overflow: hidden;`;
const tableHead = `box-sizing: border-box; margin: 0; padding: 6px 11px; border-bottom: 1.5px solid ${PANEL_BORDER}; background: ${CHROME_BG}; font-family: ${mono}; font-size: 11px; font-weight: 800; line-height: 1.2; color: ${INK};`;
const tableBody = `box-sizing: border-box; display: flex; flex-direction: column; flex: 1 1 auto; justify-content: center; gap: 3px; margin: 0; padding: 7px 9px;`;
const memberRow = (removed: boolean) => {
	const c = removed ? RED_INK : INK;
	const strike = removed
		? ` text-decoration: line-through; text-decoration-color: ${RED}; text-decoration-thickness: 1.5px;`
		: '';
	return `box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; gap: 8px; margin: 0; padding: 3px 7px; border-radius: 6px; background: ${removed ? RED_BG : 'transparent'}; opacity: ${removed ? '0.85' : '1'}; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${c};${strike}`;
};
const memberRole = (removed: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 700; line-height: 1.2; color: ${removed ? RED_INK : INK_SOFT};`;

// The session-cookie chip — indigo, "still valid", the untouched through-line.
const cookieCard = `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 5px; width: 168px; min-height: 104px; margin: 0; padding: 11px 12px; border: 1.5px solid ${INDIGO}; border-radius: 12px; background: ${INDIGO_BG};`;
const cookieEyebrow = `margin: 0; display: inline-flex; align-items: center; gap: 5px; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; line-height: 1.2; color: ${INDIGO_INK};`;
const cookieTitle = `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 800; line-height: 1.25; color: ${INDIGO_INK};`;
const cookieSub = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.3; color: ${INDIGO_INK};`;
const cookiePin = `box-sizing: border-box; align-self: flex-start; margin: 1px 0 0; padding: 1px 7px; border: 1.5px solid ${INDIGO}; border-radius: 999px; background: ${SURFACE}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.6; color: ${INDIGO_INK};`;

// The redirect outcome box — red, the eject verdict.
const outcomeBox = `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 4px; width: 158px; min-height: 104px; margin: 0; padding: 11px 12px; border: 2px solid ${RED}; border-radius: 12px; background: ${RED_BG}; text-align: center;`;
const outcomeWord = `margin: 0; font-family: ${mono}; font-size: 13.5px; font-weight: 900; letter-spacing: 0.02em; line-height: 1.15; color: ${RED_INK};`;
const outcomeSub = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.3; color: ${RED_INK};`;

// A labelled connector arrow between two boxes. `tone` colours the channel.
const conn = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; align-self: center; margin: 0; min-width: 52px;`;
const connArrow = (c: string) =>
	`margin: 0; font-size: 21px; font-weight: 900; line-height: 0.7; color: ${c};`;
const connLabel = (c: string) =>
	`margin: 0; max-width: 78px; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.2; text-align: center; color: ${c};`;

// The note row beneath the machine — fixed height on both steps so the panels
// never change height as the reader scrubs.
const noteRow = `display: flex; align-items: center; justify-content: center; min-height: 40px; margin: 14px 0 0;`;
const note = (tone: 'indigo' | 'red') => {
	const edge = tone === 'indigo' ? INDIGO : RED;
	const bg = tone === 'indigo' ? INDIGO_BG : RED_BG;
	const fg = tone === 'indigo' ? INDIGO_INK : RED_INK;
	return `box-sizing: border-box; display: inline-flex; align-items: center; gap: 8px; max-width: 100%; margin: 0; padding: 7px 14px; border: 1.5px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${fg}; font-family: ${sans}; font-size: 12px; font-weight: 700; line-height: 1.35; text-align: center;`;
};
const noteDot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 8px; height: 8px; margin: 0; border-radius: 50%; background: ${c};`;
---

<DiagramSequence>
	{/* ============ STEP 1 — the admin removes Bob ============ */}
	<DiagramStep caption="An admin removes Bob — the member row for (this org, Bob) is deleted. Bob's browser session is untouched and still valid.">
		<div style={stage}>
			<div style={machine}>
				{/* the admin who triggers the remove */}
				<div style={card}>
					<p style={cardEyebrow}>admin</p>
					<p style={cardTitle}>removeMember</p>
					<p style={cardSub}>deletes one row</p>
				</div>

				{/* --delete--> */}
				<div style={conn}>
					<span style={connArrow(RED)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(RED_INK)}>hard delete</span>
				</div>

				{/* the member table — Bob's row struck through */}
				<div style={tableCard}>
					<p style={tableHead}>member</p>
					<div style={tableBody}>
						<div style={memberRow(false)}>
							<span>Alice</span>
							<span style={memberRole(false)}>owner</span>
						</div>
						<div style={memberRow(true)}>
							<span>Bob</span>
							<span style={memberRole(true)}>member</span>
						</div>
						<div style={memberRow(false)}>
							<span>Carol</span>
							<span style={memberRole(false)}>admin</span>
						</div>
					</div>
				</div>

				{/* the session cookie — untouched, still valid (the through-line) */}
				<div style={cookieCard}>
					<p style={cookieEyebrow}>Bob&rsquo;s browser</p>
					<p style={cookieTitle}>session cookie</p>
					<span style={cookiePin}>still valid</span>
					<p style={cookieSub}>not touched by the delete</p>
				</div>
			</div>

			<div style={noteRow}>
				<span style={note('indigo')}>
					<span style={noteDot(INDIGO)} aria-hidden="true"></span>
					No logout was issued &mdash; the cookie still works.
				</span>
			</div>
		</div>
	</DiagramStep>

	{/* ============ STEP 2 — Bob's next request self-heals ============ */}
	<DiagramStep caption="Bob's next request: requireOrgUser reads membership fresh, finds no row for (this org, Bob), and redirects him out. No logout was ever issued.">
		<div style={stage}>
			<div style={machine}>
				{/* Bob's browser, carrying the same still-valid cookie */}
				<div style={cookieCard}>
					<p style={cookieEyebrow}>Bob&rsquo;s browser</p>
					<p style={cookieTitle}>session cookie</p>
					<span style={cookiePin}>still valid</span>
					<p style={cookieSub}>active org = this org</p>
				</div>

				{/* --request--> */}
				<div style={conn}>
					<span style={connArrow(INDIGO)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(INDIGO_INK)}>next request</span>
				</div>

				{/* requireOrgUser reads membership fresh from the DB */}
				<div style={card}>
					<p style={cardEyebrow}>per request</p>
					<p style={cardTitle}>requireOrgUser</p>
					<p style={cardSub}>reads membership fresh</p>
				</div>

				{/* --no row--> */}
				<div style={conn}>
					<span style={connArrow(RED)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(RED_INK)}>no member row</span>
				</div>

				{/* the redirect — the eject verdict */}
				<div style={outcomeBox}>
					<p style={outcomeWord}>redirect</p>
					<p style={outcomeSub}>&rarr; /onboarding/create-org</p>
				</div>
			</div>

			<div style={noteRow}>
				<span style={note('red')}>
					<span style={noteDot(RED)} aria-hidden="true"></span>
					Authority is read per request &mdash; the missing row ejects him.
				</span>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
