---
// ThreeLayerDefense — Chapter 057 Lesson 5 ("The append-only audit log").
//
// Makes "append-only is enforced THREE independent ways" a spatial fact rather
// than a bullet list. Two write attempts enter on the left and run, left to
// right, through the same three gates:
//
//   UPDATE / DELETE (red) ─✗─ Column shape ─✗─ DB policy ─✗─ App discipline ──╳  (never reaches)
//   INSERT          (grn) ─✓─ Column shape ─✓─ DB policy ─✓─ App discipline ──▶ audit_logs
//
// The three gates are shared grid COLUMNS, so the two verdict rows line up
// under each gate: a red ✗ for the destructive lane at every gate, a green ✓
// for the insert lane at every gate. Reading down a column shows "this layer
// refuses UPDATE/DELETE on its own"; reading across a row shows "blocked
// everywhere / passes everywhere". The destructive lane dead-ends before the
// table; the insert lane arrives.
//
// Pure HTML+CSS per the diagrams guide (a conceptual layered-defense strip with
// colour-coded segments, not a graph engine), modeled on this chapter family's
// 056/3 LayeredDefenseGates. `not-content` + a margin:0 reset on every node
// defeats Starlight's injected prose margins. Goes inside <Figure>, which the
// MDX supplies along with the caption.
//
// Colour language: red (#dc2626) = the blocked UPDATE/DELETE attempt; green
// (#16a34a) = the permitted INSERT. Saturated mid-tones reused verbatim in
// light + dark since the colour itself is the signal; tints derived with
// color-mix so they track the page background. Gate chrome stays neutral grey —
// the gates are the same for both lanes; only the verdicts differ.

const RED = '#dc2626'; // the blocked destructive attempt
const GREEN = '#16a34a'; // the permitted append

// The three independent layers, in the left-to-right order the prose walks them.
const gates = [
	{
		title: 'Column shape',
		sub: 'no updated_at / deleted_at',
		note: 'nothing to mutate',
	},
	{
		title: 'DB policy',
		sub: 'USING (false)',
		note: 'Postgres refuses',
	},
	{
		title: 'App discipline',
		sub: 'only logAudit() inserts',
		note: 'no code path asks',
	},
];

// Small ✗ / ✓ glyphs for the verdict cells.
const xIcon = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>`;
const checkIcon = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
---

<div class="tld not-content">
	{/* ── Header row: source column + the three shared gate columns + table ── */}
	<div class="tld-head tld-head--source">Write attempt</div>
	{
		gates.map((gate) => (
			<div class="tld-head tld-gate-head">
				<span class="tld-gate-title">{gate.title}</span>
				<code class="tld-gate-sub">{gate.sub}</code>
				<span class="tld-gate-note">{gate.note}</span>
			</div>
		))
	}
	<div class="tld-head tld-head--table">audit_logs</div>

	{/* ── Lane 1: UPDATE / DELETE — blocked at every gate, never arrives ── */}
	<div class="tld-source tld-source--blocked">
		<span class="tld-source-verb">UPDATE</span>
		<span class="tld-source-verb">DELETE</span>
	</div>
	{
		gates.map(() => (
			<div class="tld-cell tld-cell--blocked">
				<span class="tld-mark tld-mark--x">
					<Fragment set:html={xIcon} />
				</span>
				<span class="tld-cell-label">refused</span>
			</div>
		))
	}
	<div class="tld-end tld-end--blocked">
		<span class="tld-end-label">never reaches the table</span>
	</div>

	{/* ── Lane 2: INSERT — passes every gate, lands in the table ── */}
	<div class="tld-source tld-source--pass">
		<span class="tld-source-verb">INSERT</span>
	</div>
	{
		gates.map(() => (
			<div class="tld-cell tld-cell--pass">
				<span class="tld-mark tld-mark--check">
					<Fragment set:html={checkIcon} />
				</span>
				<span class="tld-cell-label">allowed</span>
			</div>
		))
	}
	<div class="tld-end tld-end--pass">
		<span class="tld-end-label">row written</span>
	</div>
</div>

<style>
	.tld {
		display: grid;
		/* source | gate | gate | gate | table */
		grid-template-columns: minmax(0, 0.95fr) repeat(3, minmax(0, 1fr)) minmax(
				0,
				0.95fr
			);
		gap: 10px;
		align-items: stretch;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* ── Header row ─────────────────────────────────────────────────────── */
	.tld-head {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		min-width: 0;
		padding: 9px 10px;
		border-radius: 10px;
		text-align: center;
		margin: 0;
	}

	/* The two neutral terminals in the header — "Write attempt" and the table. */
	.tld-head--source,
	.tld-head--table {
		font-size: 12.5px;
		font-weight: 700;
		color: var(--sl-color-gray-2, #475569);
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 25%, transparent);
	}

	.tld-head--table {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		border-style: solid;
	}

	/* A gate header — neutral chrome; the gate is identical for both lanes. */
	.tld-gate-head {
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent);
	}

	.tld-gate-title {
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	/* The mono subtitle — override Starlight's inline-code pill to a clean label. */
	.tld-gate-sub {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		background: transparent;
		border: 0;
		padding: 0;
		margin: 0;
	}

	.tld-gate-note {
		font-size: 11px;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
		margin: 1px 0 0;
	}

	/* ── Source cells (one per lane, left edge) ─────────────────────────── */
	.tld-source {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 5px;
		min-width: 0;
		padding: 10px;
		border-radius: 10px;
		margin: 0;
	}

	.tld-source-verb {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 12.5px;
		font-weight: 800;
		letter-spacing: 0.02em;
		line-height: 1.1;
		margin: 0;
	}

	.tld-source--blocked {
		border: 1.5px solid color-mix(in srgb, var(--tld-red) 60%, transparent);
		background: color-mix(in srgb, var(--tld-red) 12%, transparent);
	}
	.tld-source--blocked .tld-source-verb {
		color: color-mix(in srgb, var(--tld-red) 78%, var(--sl-color-text));
	}

	.tld-source--pass {
		border: 1.5px solid color-mix(in srgb, var(--tld-green) 60%, transparent);
		background: color-mix(in srgb, var(--tld-green) 12%, transparent);
	}
	.tld-source--pass .tld-source-verb {
		color: color-mix(in srgb, var(--tld-green) 72%, var(--sl-color-text));
	}

	/* ── Verdict cells (one per gate, per lane) ─────────────────────────── */
	.tld-cell {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		min-width: 0;
		padding: 10px;
		border-radius: 10px;
		margin: 0;
	}

	.tld-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 999px;
		margin: 0;
	}

	.tld-cell-label {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		margin: 0;
	}

	/* Blocked verdict — red, the destructive lane refused at this gate. */
	.tld-cell--blocked {
		border: 1.5px solid color-mix(in srgb, var(--tld-red) 45%, transparent);
		background: color-mix(in srgb, var(--tld-red) 9%, transparent);
	}
	.tld-mark--x {
		background: var(--tld-red);
		color: #ffffff;
	}
	.tld-cell--blocked .tld-cell-label {
		color: color-mix(in srgb, var(--tld-red) 80%, var(--sl-color-text));
	}

	/* Allowed verdict — green, the insert lane passes this gate. */
	.tld-cell--pass {
		border: 1.5px solid color-mix(in srgb, var(--tld-green) 45%, transparent);
		background: color-mix(in srgb, var(--tld-green) 9%, transparent);
	}
	.tld-mark--check {
		background: var(--tld-green);
		color: #ffffff;
	}
	.tld-cell--pass .tld-cell-label {
		color: color-mix(in srgb, var(--tld-green) 72%, var(--sl-color-text));
	}

	/* ── Lane end cells (right edge) ────────────────────────────────────── */
	.tld-end {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-width: 0;
		padding: 10px;
		border-radius: 10px;
		text-align: center;
		margin: 0;
	}

	.tld-end-label {
		font-size: 11px;
		font-weight: 700;
		line-height: 1.25;
		margin: 0;
	}

	/* The destructive lane dead-ends — dashed, muted, no arrival. */
	.tld-end--blocked {
		border: 1.5px dashed color-mix(in srgb, var(--tld-red) 45%, transparent);
		background: transparent;
	}
	.tld-end--blocked .tld-end-label {
		color: color-mix(in srgb, var(--tld-red) 78%, var(--sl-color-text));
	}

	/* The insert lane lands a row — solid green, the one path that arrives. */
	.tld-end--pass {
		border: 1.5px solid color-mix(in srgb, var(--tld-green) 55%, transparent);
		background: color-mix(in srgb, var(--tld-green) 14%, transparent);
	}
	.tld-end--pass .tld-end-label {
		color: color-mix(in srgb, var(--tld-green) 72%, var(--sl-color-text));
	}

	/* Saturated mid-tones — the colour is the signal, identical in both themes. */
	.tld {
		--tld-red: #dc2626;
		--tld-green: #16a34a;
	}

	/* Narrow viewports: a 5-track grid crushes. Collapse to a single column —
	   the source pill, then each gate's verdict pair, then the lane end, stacked
	   per lane. Re-add a "Lane" prefix isn't needed: colour carries the lane. */
	@media (max-width: 640px) {
		.tld {
			grid-template-columns: 1fr;
			gap: 7px;
		}
		.tld-head--source,
		.tld-head--table {
			display: none;
		}
		.tld-gate-head {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: flex-start;
			gap: 4px 8px;
			text-align: left;
		}
		.tld-source,
		.tld-cell,
		.tld-end {
			flex-direction: row;
			justify-content: flex-start;
			gap: 9px;
		}
	}
</style>
