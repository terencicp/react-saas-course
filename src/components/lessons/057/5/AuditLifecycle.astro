---
// AuditLifecycle — Chapter 057 Lesson 5 ("The append-only audit log"), the
// closing centerpiece. Scrubs one privileged action (removing a member) through
// its full lifecycle so the chapter's spine — "work + audit = ONE atomic unit"
// — becomes a single timeline the reader can locate every concept on.
//
// One <AuditLifecycle step={n} /> renders inside each <DiagramStep>. Every step
// renders the SAME six-phase vertical stack and only changes which phase is
// active, so the DiagramSequence stage never reflows as the reader scrubs (its
// grid stack sizes to the tallest step, and here every step is identical height).
//
// The load-bearing visual is the TRANSACTION ENVELOPE: a single bordered box
// wraps the BEGIN…COMMIT phases (2–5). The two phases outside it — the action
// body entering (1) and revalidatePath after commit (6) — sit visibly outside
// the box. Reading the picture, "the delete and the audit insert live inside the
// same envelope, and the envelope commits as a unit" is spatial, not asserted.
//
// Progress language: phases before the active one are DONE (muted, ticked),
// the active phase is lit, later phases are PENDING (faint). At COMMIT (step 5)
// the delete result and the audit-row result light green TOGETHER — the iff made
// visible: both land, or (on rollback) neither would.
//
// Pure HTML+CSS per the diagrams guide (a sequential phase strip, not a graph).
// `not-content` + margin:0 on every node defeats Starlight's injected prose
// margins. DiagramSequence supplies the outer card; this component is only the
// step body, so no <Figure>/<DiagramSequence> wrapper here.
//
// Colour language, theme-stable (the colour itself is the signal): blue (#3b82f6,
// matching DiagramSequence's own accent) = the currently-active phase; green
// (#16a34a, matching this lesson's ThreeLayerDefense) = a committed / landed row;
// neutral grey = done-but-past and not-yet phases. Tints via color-mix so they
// track the page background.

interface Props {
	/** Active phase, 1–6, matching the six DiagramStep captions. */
	step: number;
}

const { step } = Astro.props;

// The six phases of the lifecycle, in order. `inTx` marks the phases that live
// inside the transaction envelope (BEGIN…COMMIT). `mono` is rendered as a code
// fragment; `label` as the plain phase name.
const phases = [
	{
		n: 1,
		label: 'authedAction body',
		mono: 'ctx = { user, orgId, role, db }',
		note: 'session, role + input already checked',
		inTx: false,
	},
	{
		n: 2,
		label: 'open transaction',
		mono: "set_config('app.org_id', orgId, true)",
		note: 'every query inside is now pinned to this org',
		inTx: true,
	},
	{
		n: 3,
		label: 'the work',
		mono: 'tx.delete(member)',
		note: 'the member row is removed',
		inTx: true,
	},
	{
		n: 4,
		label: 'the audit row',
		mono: 'logAudit(tx, { action, subjectId, payload })',
		note: 'same tx · WITH CHECK pins org · INSERT permitted',
		inTx: true,
	},
	{
		n: 5,
		label: 'COMMIT',
		mono: 'COMMIT',
		note: 'both rows land together, or neither does',
		inTx: true,
	},
	{
		n: 6,
		label: 'after commit',
		mono: 'revalidatePath(...)',
		note: 'member list refreshes · audit row is durable',
		inTx: false,
	},
];

// State of a phase relative to the active one, for the progress styling.
const stateOf = (n: number): 'done' | 'active' | 'pending' =>
	n < step ? 'done' : n === step ? 'active' : 'pending';

// The two rows that the transaction either commits together or not at all.
// They light green ONLY once we've reached / passed COMMIT (step 5) — that's the
// moment the iff resolves.
const committed = step >= 5;
const GREEN = '#16a34a';
const BLUE = '#3b82f6';

const tickIcon = `<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;display:block;"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
---

<div class="al not-content" data-step={step}>
	{
		phases.map((p, i) => {
			const st = stateOf(p.n);
			// The transaction envelope is a left rail drawn on the in-tx phases.
			// Mark its top and bottom so the box reads as one container.
			const isTxTop = p.inTx && !phases[i - 1]?.inTx;
			const isTxBottom = p.inTx && !phases[i + 1]?.inTx;
			return (
				<div
					class:list={[
						'al-row',
						`is-${st}`,
						p.inTx && 'al-row--tx',
						isTxTop && 'al-row--tx-top',
						isTxBottom && 'al-row--tx-bottom',
						p.n === 5 && 'al-row--commit',
					]}
				>
					{/* timeline gutter: tick / dot per phase state */}
					<span class="al-marker">
						{st === 'done' ? (
							<span class="al-dot al-dot--done">
								<Fragment set:html={tickIcon} />
							</span>
						) : st === 'active' ? (
							<span class="al-dot al-dot--active" />
						) : (
							<span class="al-dot al-dot--pending" />
						)}
					</span>

					{/* phase body */}
					<div class="al-body">
						<div class="al-head">
							<span class="al-label">{p.label}</span>
							{isTxTop && <span class="al-tx-tag">one transaction</span>}
						</div>
						<code class="al-mono">{p.mono}</code>
						<span class="al-note">{p.note}</span>

						{/* COMMIT phase: the two paired results that land together */}
						{p.n === 5 && (
							<div class="al-lands" data-committed={committed}>
								<span
									class:list={['al-land', committed && 'is-on']}
								>
									<span class="al-land-x">
										{committed && <Fragment set:html={tickIcon} />}
									</span>
									member deleted
								</span>
								<span class="al-amp">+</span>
								<span
									class:list={['al-land', committed && 'is-on']}
								>
									<span class="al-land-x">
										{committed && <Fragment set:html={tickIcon} />}
									</span>
									audit row written
								</span>
							</div>
						)}
					</div>
				</div>
			);
		})
	}
</div>

<style
	define:vars={{
		'al-green': GREEN,
		'al-blue': BLUE,
	}}
>
	.al {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 2px 2px 2px 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* ── A phase row: timeline gutter + body ──────────────────────────────── */
	.al-row {
		display: grid;
		grid-template-columns: 26px 1fr;
		align-items: stretch;
		gap: 10px;
		margin: 0;
		padding: 0;
	}

	/* The timeline gutter, holding the dot/tick and the connecting spine. */
	.al-marker {
		position: relative;
		display: flex;
		justify-content: center;
		padding: 7px 0;
		margin: 0;
	}
	/* vertical spine connecting consecutive markers */
	.al-marker::before {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 2px;
		transform: translateX(-50%);
		background: var(--sl-color-gray-5, #cbd5e1);
	}
	.al-row:first-child .al-marker::before {
		top: 50%;
	}
	.al-row:last-child .al-marker::before {
		bottom: 50%;
	}

	.al-dot {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		border-radius: 999px;
		margin: 0;
		flex: 0 0 auto;
	}
	.al-dot--pending {
		width: 11px;
		height: 11px;
		background: var(--sl-color-bg);
		border: 2px solid var(--sl-color-gray-4, #94a3b8);
		opacity: 0.7;
	}
	.al-dot--active {
		background: var(--al-blue);
		border: 3px solid color-mix(in srgb, var(--al-blue) 28%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--al-blue) 14%, transparent);
	}
	.al-dot--done {
		background: var(--sl-color-gray-4, #94a3b8);
		color: #fff;
	}

	/* ── Phase body ───────────────────────────────────────────────────────── */
	.al-body {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 3px;
		min-width: 0;
		margin: 5px 0;
		padding: 9px 12px;
		border: 1.5px solid var(--sl-color-hairline, #e2e8f0);
		border-radius: 10px;
		background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
		transition:
			border-color 0.14s,
			background-color 0.14s,
			opacity 0.14s;
	}

	.al-head {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
		margin: 0;
	}
	.al-label {
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	/* "one transaction" pill, on the first in-tx phase. */
	.al-tx-tag {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--al-blue) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--al-blue) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--al-blue) 35%, transparent);
		border-radius: 999px;
		padding: 1.5px 8px;
		margin: 0;
	}
	.al-mono {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 12px;
		font-weight: 600;
		line-height: 1.35;
		color: var(--sl-color-gray-1, #334155);
		background: transparent;
		border: 0;
		padding: 0;
		margin: 0;
		overflow-wrap: anywhere;
	}
	.al-note {
		font-size: 11.5px;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── Progress states ──────────────────────────────────────────────────── */
	.al-row.is-pending .al-body {
		opacity: 0.5;
	}
	.al-row.is-active .al-body {
		border-color: color-mix(in srgb, var(--al-blue) 60%, transparent);
		background: color-mix(in srgb, var(--al-blue) 9%, transparent);
		box-shadow: 0 1px 4px color-mix(in srgb, var(--al-blue) 16%, transparent);
	}
	.al-row.is-active .al-mono {
		color: color-mix(in srgb, var(--al-blue) 82%, var(--sl-color-text));
	}

	/* ── Transaction envelope: a continuous accent rail down the in-tx phases ─ */
	.al-row--tx .al-body {
		border-left-width: 3px;
		border-left-color: color-mix(in srgb, var(--al-blue) 45%, var(--sl-color-hairline));
	}
	.al-row--tx.is-active .al-body {
		border-left-color: color-mix(in srgb, var(--al-blue) 70%, transparent);
	}

	/* ── COMMIT phase emphasis + the two rows landing together ────────────── */
	.al-row--commit.is-active .al-body,
	.al-row--commit.is-done .al-body {
		border-color: color-mix(in srgb, var(--al-green) 55%, transparent);
		background: color-mix(in srgb, var(--al-green) 9%, transparent);
	}
	.al-row--commit.is-active .al-mono,
	.al-row--commit.is-done .al-mono {
		color: color-mix(in srgb, var(--al-green) 78%, var(--sl-color-text));
		font-weight: 800;
		letter-spacing: 0.04em;
	}

	.al-lands {
		display: flex;
		align-items: center;
		gap: 7px;
		flex-wrap: wrap;
		margin: 4px 0 0;
	}
	.al-land {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 11px;
		font-weight: 700;
		line-height: 1.1;
		color: var(--sl-color-gray-3, #64748b);
		background: var(--sl-color-bg);
		border: 1.5px dashed var(--sl-color-gray-4, #94a3b8);
		border-radius: 7px;
		padding: 3px 8px;
		margin: 0;
		transition:
			color 0.14s,
			border-color 0.14s,
			background-color 0.14s;
	}
	.al-land.is-on {
		color: color-mix(in srgb, var(--al-green) 80%, var(--sl-color-text));
		border-style: solid;
		border-color: color-mix(in srgb, var(--al-green) 55%, transparent);
		background: color-mix(in srgb, var(--al-green) 12%, transparent);
	}
	.al-land-x {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 15px;
		height: 15px;
		border-radius: 999px;
		margin: 0;
		flex: 0 0 auto;
	}
	.al-land.is-on .al-land-x {
		background: var(--al-green);
		color: #fff;
	}
	.al-amp {
		font-size: 13px;
		font-weight: 800;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.al-land.is-on ~ .al-amp,
	.al-lands[data-committed='true'] .al-amp {
		color: color-mix(in srgb, var(--al-green) 70%, var(--sl-color-text));
	}

	@media (max-width: 600px) {
		.al-row {
			grid-template-columns: 22px 1fr;
			gap: 8px;
		}
		.al-mono {
			font-size: 11px;
		}
	}
</style>
