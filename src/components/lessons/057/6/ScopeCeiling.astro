---
// ScopeCeiling — Chapter 057 Lesson 6 ("API keys for machine callers").
//
// Makes "a key's scopes are a ceiling UNDER its role — the role ∩ scope
// intersection, narrowest wins" glanceable. Three stacked rows:
//
//   Role allows     [ invoices:read | invoices:write | members:manage | settings:edit ]   (blue)
//        ∩  (the key carves a smaller box beneath the role)
//   Key scoped to   [ invoices:read ]                                                      (orange)
//        =  narrowest wins
//   Effective       [ invoices:read | i̶n̶v̶o̶i̶c̶e̶s̶:̶w̶r̶i̶t̶e̶ | m̶e̶m̶b̶e̶r̶s̶:̶m̶a̶n̶a̶g̶e̶ | s̶e̶t̶t̶i̶n̶g̶s̶:̶e̶d̶i̶t̶ ]      (green)
//
// The visual point is the contrast across rows: the role row is wide (what an
// admin COULD do); the key row is one chip (what the issuer GRANTED); the
// effective row keeps only the chip both rows agree on, the rest struck through
// and greyed. The set operators between rows (∩ then =) name the operation so
// the picture reads as an intersection whose result is the narrower side.
//
// Pure HTML+CSS per the diagrams guide (colour-coded segments + labels, no
// graph engine). `not-content` + margin:0 on every node defeats Starlight's
// injected prose margins. Goes inside <Figure>, which the MDX supplies along
// with the caption.
//
// Colour language matches the chapter's sibling figures (KeyTrustBoundaries):
// blue (#2563eb) = the role's full reach (the ceiling), orange (#ea580c) = the
// key's narrower grant, green (#16a34a) = the effective result. Tints via
// color-mix so they track the page background in either theme.

const BLUE = '#2563eb'; // the role — the full ceiling of what the caller could do
const ORANGE = '#ea580c'; // the key's grant — the narrower box beneath the role
const GREEN = '#16a34a'; // the effective intersection — what the key may actually do

// The admin role's full reach (the ceiling), and the one scope this key was
// granted. The effective row marks each role capability as kept (it's in the
// grant) or dropped (struck through — outside the grant).
const GRANT = 'invoices:read';
const roleScopes = [
	'invoices:read',
	'invoices:write',
	'members:manage',
	'settings:edit',
] as const;

const effective = roleScopes.map((scope) => ({
	scope,
	kept: scope === GRANT,
}));
---

<div
	class="sc not-content"
	style={`--sc-blue:${BLUE};--sc-orange:${ORANGE};--sc-green:${GREEN};`}
>
	{/* Row 1 — what the org role permits: the wide ceiling. */}
	<div class="sc-row sc-row--role">
		<div class="sc-head">
			<span class="sc-label">Role allows</span>
			<span class="sc-sub">admin — the ceiling</span>
		</div>
		<div class="sc-chips">
			{roleScopes.map((scope) => <code class="sc-chip sc-chip--role">{scope}</code>)}
		</div>
	</div>

	<div class="sc-op" aria-hidden="true">
		<span class="sc-op-sym">∩</span>
		<span class="sc-op-text">the key carves a smaller box beneath the role</span>
	</div>

	{/* Row 2 — what the issuer actually granted this key: the narrower box. */}
	<div class="sc-row sc-row--key">
		<div class="sc-head">
			<span class="sc-label">Key scoped to</span>
			<span class="sc-sub">the grant</span>
		</div>
		<div class="sc-chips">
			<code class="sc-chip sc-chip--key">{GRANT}</code>
		</div>
	</div>

	<div class="sc-op sc-op--result" aria-hidden="true">
		<span class="sc-op-sym">=</span>
		<span class="sc-op-text">narrowest wins</span>
	</div>

	{/* Row 3 — the intersection: only where both agree survives. */}
	<div class="sc-row sc-row--eff">
		<div class="sc-head">
			<span class="sc-label">Effective</span>
			<span class="sc-sub">what the key may do</span>
		</div>
		<div class="sc-chips">
			{
				effective.map(({ scope, kept }) =>
					kept ? (
						<code class="sc-chip sc-chip--eff">{scope}</code>
					) : (
						<code class="sc-chip sc-chip--dropped">{scope}</code>
					),
				)
			}
		</div>
	</div>
</div>

<style>
	.sc {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 6px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* ── A row: a label block on the left, a strip of scope chips on the right ── */
	.sc-row {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 16px;
		min-width: 0;
		padding: 12px 14px;
		border-radius: 12px;
		margin: 0;
	}

	.sc-row--role {
		border: 1.5px solid color-mix(in srgb, var(--sc-blue) 42%, transparent);
		background: color-mix(in srgb, var(--sc-blue) 7%, transparent);
	}

	.sc-row--key {
		border: 1.5px solid color-mix(in srgb, var(--sc-orange) 50%, transparent);
		background: color-mix(in srgb, var(--sc-orange) 9%, transparent);
	}

	/* The result row reads as "the answer" — heavier border, stronger tint. */
	.sc-row--eff {
		border: 2px solid color-mix(in srgb, var(--sc-green) 58%, transparent);
		background: color-mix(in srgb, var(--sc-green) 11%, transparent);
	}

	/* ── The left-hand label block ───────────────────────────────────────── */
	.sc-head {
		display: flex;
		flex-direction: column;
		gap: 2px;
		flex: 0 0 8.5rem;
		min-width: 0;
	}

	.sc-label {
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.sc-sub {
		font-size: 11px;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── The strip of scope chips ────────────────────────────────────────── */
	.sc-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 7px;
		min-width: 0;
	}

	.sc-chip {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 12px;
		font-weight: 600;
		line-height: 1.3;
		padding: 4px 9px;
		border-radius: 7px;
		margin: 0;
		white-space: nowrap;
	}

	/* Role capabilities — neutral blue, the full set the ceiling allows. */
	.sc-chip--role {
		color: color-mix(in srgb, var(--sc-blue) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--sc-blue) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--sc-blue) 40%, transparent);
	}

	/* The single granted scope — orange, the narrower box. */
	.sc-chip--key {
		color: color-mix(in srgb, var(--sc-orange) 82%, var(--sl-color-text));
		background: color-mix(in srgb, var(--sc-orange) 14%, transparent);
		border: 1px solid color-mix(in srgb, var(--sc-orange) 50%, transparent);
		font-weight: 700;
	}

	/* The surviving capability — green, the effective grant. */
	.sc-chip--eff {
		color: color-mix(in srgb, var(--sc-green) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--sc-green) 16%, transparent);
		border: 1px solid color-mix(in srgb, var(--sc-green) 52%, transparent);
		font-weight: 700;
	}

	/* The dropped capabilities — struck through and faded; allowed by the role
	   but never granted to the key, so the intersection drops them. */
	.sc-chip--dropped {
		color: var(--sl-color-gray-3, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent);
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 35%, transparent);
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
		text-decoration-color: color-mix(
			in srgb,
			var(--sl-color-gray-3, #94a3b8) 80%,
			transparent
		);
	}

	/* ── The operator line between rows (∩ then =) ───────────────────────── */
	.sc-op {
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 1px 14px;
		margin: 0;
	}

	.sc-op-sym {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.6rem;
		height: 1.6rem;
		flex: 0 0 auto;
		border-radius: 999px;
		font-size: 15px;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-2, #475569);
		background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 40%, transparent);
	}

	.sc-op-text {
		font-size: 12px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The "=" that produces the result reads in the green of the answer. */
	.sc-op--result .sc-op-sym {
		color: color-mix(in srgb, var(--sc-green) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--sc-green) 14%, transparent);
		border-color: color-mix(in srgb, var(--sc-green) 48%, transparent);
	}

	.sc-op--result .sc-op-text {
		color: color-mix(in srgb, var(--sc-green) 72%, var(--sl-color-text));
		font-weight: 700;
	}

	/* Narrow viewports: stack the label above its chip strip. */
	@media (max-width: 560px) {
		.sc-row {
			flex-direction: column;
			align-items: flex-start;
			gap: 9px;
		}
		.sc-head {
			flex-basis: auto;
		}
		.sc-op-text {
			font-size: 11px;
		}
	}
</style>
