---
// KeyTrustBoundaries — Chapter 057 Lesson 6 ("API keys for machine callers").
//
// Answers, at a glance, "WHERE is the raw secret allowed to exist?" — a short
// list, and the whole at-rest security posture of an API key. Three trust
// zones sit left to right, each a card showing what that place actually holds:
//
//   The database          Your logs            The create response
//   prefix + keyHash       prefix                prefix.secret  (one time)
//   [ hash only ]          [ redacted ]          [ shown once ]
//   green / safe           green / safe          orange / the one exit
//
// The visual point is the contrast: the two steady-state zones (green) hold
// only the safe, hashable halves — a full dump reconstructs no working key —
// while the THIRD zone is the single, momentary place the raw `prefix.secret`
// is allowed to appear. It is highlighted distinctly (orange) as "the one
// legitimate exit"; the others are calm green. The stored value in each card
// is rendered as real mono text so the reader sees the literal difference
// between "keyHash" and the raw secret.
//
// This deliberately parallels the next chapter's TokenTrustBoundaries figure
// for invitation tokens — same visual language (zone cards + status pill +
// one orange "show once" exit) so the recurring store-the-hash / show-once
// posture is recognisable across both lessons.
//
// Pure HTML+CSS per the diagrams guide (labelled zone cards with colour-coded
// segments, no graph engine needed). `not-content` + margin:0 on every node
// defeats Starlight's injected prose margins. Goes inside <Figure>, which the
// MDX supplies along with the caption.
//
// Colour language, theme-stable (the colour itself is the signal): green
// (#16a34a, matching this chapter's ThreeLayerDefense / AuditLifecycle) = a
// safe steady-state store; orange (#ea580c) = the one momentary place the raw
// secret legitimately exists. Tints via color-mix so they track the page bg.

const GREEN = '#16a34a'; // a safe, steady-state store (hash / prefix only)
const ORANGE = '#ea580c'; // the one legitimate exit — the raw secret, shown once

// The three places data could leak from, left to right. `tone: 'safe'` zones
// are calm green; the single `tone: 'exit'` zone is the orange highlight.
const zones = [
	{
		title: 'The database',
		where: 'api_keys row',
		// Two stored halves, neither recoverable into a working key.
		stored: [
			{ label: 'prefix', kind: 'plain' },
			{ label: 'keyHash', kind: 'plain' },
		],
		pill: 'hash only',
		note: 'A full table dump reconstructs no working key.',
		tone: 'safe',
	},
	{
		title: 'Your logs',
		where: 'access + app logs',
		stored: [{ label: 'prefix', kind: 'plain' }],
		pill: 'redacted',
		note: 'The prefix identifies the key; the secret never appears.',
		tone: 'safe',
	},
	{
		title: 'The create response',
		where: 'returned once',
		// The ONE place the raw secret exists — both halves, joined.
		stored: [{ label: 'prefix.secret', kind: 'secret' }],
		pill: 'shown once',
		note: 'The single moment the raw secret is allowed to exist.',
		tone: 'exit',
	},
] as const;
---

<div class="ktb not-content" style={`--ktb-green:${GREEN};--ktb-orange:${ORANGE};`}>
	{
		zones.map((zone) => (
			<div class={`ktb-zone ktb-zone--${zone.tone}`}>
				<div class="ktb-zone-head">
					<span class="ktb-zone-title">{zone.title}</span>
					<span class="ktb-zone-where">{zone.where}</span>
				</div>

				<div class="ktb-store">
					<span class="ktb-store-label">stores</span>
					<div class="ktb-store-vals">
						{zone.stored.map((s) => (
							<code class={`ktb-val ktb-val--${s.kind}`}>{s.label}</code>
						))}
					</div>
				</div>

				<span class={`ktb-pill ktb-pill--${zone.tone}`}>{zone.pill}</span>

				<p class="ktb-note">{zone.note}</p>
			</div>
		))
	}
</div>

<style>
	.ktb {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		align-items: stretch;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* ── A trust zone card ───────────────────────────────────────────────── */
	.ktb-zone {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 10px;
		min-width: 0;
		padding: 14px 14px 13px;
		border-radius: 12px;
		margin: 0;
	}

	/* Steady-state safe zones — calm green, solid hairline. */
	.ktb-zone--safe {
		border: 1.5px solid color-mix(in srgb, var(--ktb-green) 42%, transparent);
		background: color-mix(in srgb, var(--ktb-green) 8%, transparent);
	}

	/* The one legitimate exit — orange, heavier border to read as "different". */
	.ktb-zone--exit {
		border: 2px solid color-mix(in srgb, var(--ktb-orange) 60%, transparent);
		background: color-mix(in srgb, var(--ktb-orange) 11%, transparent);
	}

	/* ── Zone header: title + the place it lives ─────────────────────────── */
	.ktb-zone-head {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.ktb-zone-title {
		font-size: 14px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.ktb-zone-where {
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── "stores …": the actual value(s) kept in this zone ───────────────── */
	.ktb-store {
		display: flex;
		flex-direction: column;
		gap: 5px;
		min-width: 0;
	}

	.ktb-store-label {
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.ktb-store-vals {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		min-width: 0;
	}

	/* Mono value chips — override Starlight's inline-code pill to a clean chip. */
	.ktb-val {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 12px;
		font-weight: 600;
		line-height: 1.3;
		padding: 3px 8px;
		border-radius: 7px;
		margin: 0;
		white-space: nowrap;
		max-width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* A safe, hashable / public half — neutral grey chip. */
	.ktb-val--plain {
		color: var(--sl-color-gray-1, #334155);
		background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent);
	}

	/* The raw secret — orange, the only chip that carries the live credential. */
	.ktb-val--secret {
		color: color-mix(in srgb, var(--ktb-orange) 82%, var(--sl-color-text));
		background: color-mix(in srgb, var(--ktb-orange) 14%, transparent);
		border: 1px solid color-mix(in srgb, var(--ktb-orange) 50%, transparent);
		font-weight: 700;
	}

	/* ── Status pill ─────────────────────────────────────────────────────── */
	.ktb-pill {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		padding: 3px 9px;
		border-radius: 999px;
		margin: 0;
	}

	.ktb-pill::before {
		content: '';
		display: inline-block;
		width: 7px;
		height: 7px;
		border-radius: 999px;
		background: currentColor;
		flex: 0 0 auto;
	}

	.ktb-pill--safe {
		color: color-mix(in srgb, var(--ktb-green) 78%, var(--sl-color-text));
		background: color-mix(in srgb, var(--ktb-green) 14%, transparent);
	}

	.ktb-pill--exit {
		color: color-mix(in srgb, var(--ktb-orange) 84%, var(--sl-color-text));
		background: color-mix(in srgb, var(--ktb-orange) 16%, transparent);
	}

	/* ── Caption line under each zone ────────────────────────────────────── */
	.ktb-note {
		font-size: 12px;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
		margin-top: auto;
	}

	/* Narrow viewports: three side-by-side cards crush. Stack to one column. */
	@media (max-width: 640px) {
		.ktb {
			grid-template-columns: 1fr;
			gap: 10px;
		}
		.ktb-note {
			margin-top: 6px;
		}
	}
</style>
