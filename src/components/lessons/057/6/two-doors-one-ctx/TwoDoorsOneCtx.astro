---
// two-doors-one-ctx — Ch057 L6 "API keys for machine callers", the lesson's
// load-bearing visual for the "second identity branch in authedRoute" section.
//
// A deliberate evolution of L3's TwoDoorsOneRoom figure ("two doors, one room"):
// the same blue/orange branch-colour grammar and the same converge-on-one-
// neutral-box payoff, but now the convergence point is the resolved `ctx` and
// the two branches are the two *identity* paths, not the two call shapes.
//
//   [Incoming request to route.ts]
//        │
//   ◇ Has Authorization: Bearer? ─── yes ─▶ [ API-key resolver  (orange) ]
//        │                                   split prefix.secret
//        │ no                                look up row by prefix
//        ▼                                   reject if missing / revoked
//   [ requireOrgUser — cookie (blue) ]       constant-time hash compare
//        │                                   bump lastUsedAt
//        └──────────────┬───────────────────────────┘
//                       ▼
//        [ ctx = { user, orgId, role, db } ]   ← emphasised, NEUTRAL
//                       │
//                       ▼
//        authorize (roleAtLeast) → parse → call fn   ← neutral, unchanged
//
// The whole teaching beat is colour: the key branch is orange, the cookie branch
// is blue, but the converged `ctx` box and EVERYTHING after it is a single
// neutral grey — so it is visually undeniable that past `ctx` nothing knows
// which door the caller used. The two branches resolve identity differently;
// the difference ends at `ctx`.
//
// Plain HTML + CSS (matching this chapter's flow grammar — 057/3 TwoDoorsOneRoom,
// 057/6 KeyTrustBoundaries — and the diagrams guide's call for HTML+CSS on
// colour-coded converging flows; ArrowDiagram's doc flags converging arrows +
// many gap labels as the fiddly case). `not-content` + margin:0 resets defeat
// Starlight's prose-margin selector. Goes inside <Figure> (supplied at the call
// site, with the caption). Static — no interactivity.
//
// Layout: a left "resolve identity" zone (entry → decision → two branches that
// converge) and a right "shared, blind to the door" zone (ctx + gates), joined
// by a converging connector. Wraps to a vertical stack on narrow cards so the
// flow still reads top-to-bottom.

const BLUE = '#2563eb'; // the cookie door — requireOrgUser (session)
const ORANGE = '#ea580c'; // the key door — resolveApiKey (Bearer)

// The API-key branch is a short chain of resolver steps rendered inside one
// box. Kept terse — the AnnotatedCode below the figure carries the detail.
const keySteps = [
	'split prefix.secret',
	'look up row by prefix',
	'reject if missing / revoked',
	'constant-time hash compare',
	'bump lastUsedAt',
] as const;
---

<div class="tdc not-content" style={`--tdc-blue:${BLUE};--tdc-orange:${ORANGE};`}>
	{/* ── LEFT: resolve identity — entry, the branch decision, two paths ── */}
	<div class="tdc-resolve">
		<div class="tdc-entry">
			<span class="tdc-entry-glyph" aria-hidden="true">
				<svg
					viewBox="0 0 24 24"
					width="15"
					height="15"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M5 12h14"></path>
					<path d="m12 5 7 7-7 7"></path>
				</svg>
			</span>
			<span class="tdc-entry-text">
				Incoming request to <code>route.ts</code>
			</span>
		</div>

		<div class="tdc-decision">
			<span class="tdc-decision-q">
				Has <code>Authorization: Bearer</code>?
			</span>
		</div>

		{/* Two branches, side by side. Orange = key (yes), blue = cookie (no). */}
		<div class="tdc-branches">
			<div class="tdc-branch tdc-branch--key">
				<span class="tdc-branch-tag">yes</span>
				<span class="tdc-branch-title">
					<code>resolveApiKey</code> — Bearer key
				</span>
				<ol class="tdc-steps">
					{keySteps.map((step) => <li class="tdc-step">{step}</li>)}
				</ol>
			</div>

			<div class="tdc-branch tdc-branch--cookie">
				<span class="tdc-branch-tag">no</span>
				<span class="tdc-branch-title">
					<code>requireOrgUser</code> — session cookie
				</span>
				<p class="tdc-branch-note">reads the cookie, the only path before today</p>
			</div>
		</div>
	</div>

	{/* Converging connector: both branches → the one ctx box. The arrowhead is
	    neutral grey — the merge is where the colour stops mattering. */}
	<div class="tdc-merge" aria-hidden="true">
		<svg
			class="tdc-merge-svg"
			viewBox="0 0 120 120"
			preserveAspectRatio="none"
			fill="none"
		>
			{/* key branch (upper) → center */}
			<path
				d="M2 30 C 60 30, 60 60, 118 60"
				stroke="var(--tdc-orange)"
				stroke-width="2.5"
				stroke-linecap="round"></path>
			{/* cookie branch (lower) → center */}
			<path
				d="M2 90 C 60 90, 60 60, 118 60"
				stroke="var(--tdc-blue)"
				stroke-width="2.5"
				stroke-linecap="round"></path>
			{/* shared neutral arrowhead into ctx */}
			<path
				d="M112 55 L 120 60 L 112 65"
				stroke="var(--sl-color-gray-2)"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
		<span class="tdc-merge-label">resolve to</span>
	</div>

	{/* ── RIGHT: shared — the converged ctx and the unchanged gates. Neutral. ── */}
	<div class="tdc-shared">
		<div class="tdc-ctx">
			<span class="tdc-ctx-label">one identical context</span>
			<code class="tdc-ctx-code">{'ctx = { user, orgId, role, db }'}</code>
		</div>

		<div class="tdc-flow-down" aria-hidden="true">
			<svg viewBox="0 0 24 30" preserveAspectRatio="none" fill="none">
				<line
					x1="12"
					y1="2"
					x2="12"
					y2="20"
					stroke="var(--sl-color-gray-2)"
					stroke-width="2.5"
					stroke-linecap="round"></line>
				<path
					d="M6 18 L 12 28 L 18 18"
					stroke="var(--sl-color-gray-2)"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
		</div>

		<div class="tdc-gates">
			<span class="tdc-gate"><code>roleAtLeast</code></span>
			<span class="tdc-gate-arrow" aria-hidden="true">→</span>
			<span class="tdc-gate">parse</span>
			<span class="tdc-gate-arrow" aria-hidden="true">→</span>
			<span class="tdc-gate">call <code>fn</code></span>
		</div>
		<span class="tdc-shared-note">blind to which door the caller used</span>
	</div>
</div>

<style>
	.tdc {
		margin: 0;
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 8px;
		width: 100%;
		box-sizing: border-box;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
	}

	/* ── LEFT: resolve-identity column ─────────────────────────────────────── */
	.tdc-resolve {
		flex: 1 1 320px;
		min-width: 280px;
		max-width: 440px;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 9px;
		margin: 0;
	}

	.tdc-entry {
		display: flex;
		align-items: center;
		gap: 8px;
		align-self: center;
		padding: 9px 14px;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		margin: 0;
	}
	.tdc-entry-glyph {
		display: inline-flex;
		color: var(--sl-color-gray-2);
	}
	.tdc-entry-text {
		font-size: 13px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.tdc-entry-text code {
		font-size: 12px;
		font-weight: 700;
		background: var(--sl-color-gray-5);
		padding: 1px 5px;
		border-radius: 5px;
		color: var(--sl-color-white);
	}

	/* The branch question — a pill, set apart so the split reads as a decision. */
	.tdc-decision {
		align-self: center;
		padding: 7px 14px;
		border-radius: 999px;
		border: 1.5px dashed var(--sl-color-gray-3);
		background: var(--sl-color-bg);
		margin: 0;
	}
	.tdc-decision-q {
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.tdc-decision-q code {
		font-size: 11.5px;
		font-weight: 700;
		background: transparent;
		padding: 0;
		color: var(--sl-color-white);
	}

	/* The two branches sit side by side and are top-aligned so the eye reads
	   them as the two outcomes of the one decision above. */
	.tdc-branches {
		display: flex;
		flex-direction: row;
		gap: 10px;
		align-items: stretch;
		margin: 0;
	}

	.tdc-branch {
		flex: 1 1 0;
		min-width: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 10px 12px 11px;
		border-radius: 11px;
		margin: 0;
	}
	.tdc-branch--key {
		border: 1.5px solid color-mix(in srgb, var(--tdc-orange) 55%, transparent);
		background: color-mix(in srgb, var(--tdc-orange) 11%, var(--sl-color-bg));
	}
	.tdc-branch--cookie {
		border: 1.5px solid color-mix(in srgb, var(--tdc-blue) 55%, transparent);
		background: color-mix(in srgb, var(--tdc-blue) 11%, var(--sl-color-bg));
	}

	.tdc-branch-tag {
		align-self: flex-start;
		font-size: 9.5px;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 2px 8px;
		border-radius: 999px;
		margin: 0;
	}
	.tdc-branch--key .tdc-branch-tag {
		color: color-mix(in srgb, var(--tdc-orange) 86%, var(--sl-color-text));
		background: color-mix(in srgb, var(--tdc-orange) 18%, transparent);
	}
	.tdc-branch--cookie .tdc-branch-tag {
		color: color-mix(in srgb, var(--tdc-blue) 86%, var(--sl-color-text));
		background: color-mix(in srgb, var(--tdc-blue) 18%, transparent);
	}

	.tdc-branch-title {
		font-size: 12px;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-white);
		margin: 0;
	}
	.tdc-branch-title code {
		font-size: 11.5px;
		font-weight: 700;
		background: transparent;
		padding: 0;
	}
	.tdc-branch--key .tdc-branch-title code {
		color: color-mix(in srgb, var(--tdc-orange) 90%, var(--sl-color-text));
	}
	.tdc-branch--cookie .tdc-branch-title code {
		color: color-mix(in srgb, var(--tdc-blue) 90%, var(--sl-color-text));
	}

	/* The resolver step chain — a tight ordered list, dot-separated rows. */
	.tdc-steps {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 3px;
		counter-reset: step;
	}
	.tdc-step {
		position: relative;
		margin: 0;
		padding: 0 0 0 16px;
		font-size: 11px;
		font-weight: 600;
		line-height: 1.35;
		color: var(--sl-color-gray-1);
		counter-increment: step;
	}
	.tdc-step::before {
		content: counter(step);
		position: absolute;
		left: 0;
		top: 0.05em;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 12px;
		height: 12px;
		font-size: 8px;
		font-weight: 800;
		border-radius: 999px;
		color: color-mix(in srgb, var(--tdc-orange) 90%, var(--sl-color-text));
		background: color-mix(in srgb, var(--tdc-orange) 20%, transparent);
	}

	.tdc-branch-note {
		font-size: 11px;
		font-weight: 600;
		line-height: 1.35;
		color: var(--sl-color-gray-2);
		margin: 0;
	}

	/* ── MIDDLE: converging connector ──────────────────────────────────────── */
	.tdc-merge {
		flex: 0 0 116px;
		width: 116px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		margin: 0;
	}
	.tdc-merge-svg {
		width: 116px;
		height: 104px;
		display: block;
	}
	.tdc-merge-label {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* ── RIGHT: shared column — converged ctx + unchanged gates ─────────────── */
	.tdc-shared {
		flex: 1 1 230px;
		min-width: 210px;
		max-width: 290px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		margin: 0;
	}

	/* The payoff box: emphasised but NEUTRAL — a thicker grey border, no tint,
	   so it reads as "the shared thing" and not as belonging to either branch. */
	.tdc-ctx {
		box-sizing: border-box;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 5px;
		padding: 13px 14px;
		border-radius: 12px;
		border: 2.5px solid var(--sl-color-gray-2);
		background: var(--sl-color-gray-6);
		text-align: center;
		margin: 0;
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-4) 30%, transparent);
	}
	.tdc-ctx-label {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-2);
		margin: 0;
	}
	.tdc-ctx-code {
		font-size: 13px;
		font-weight: 700;
		line-height: 1.3;
		color: var(--sl-color-white);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	.tdc-flow-down {
		display: flex;
		justify-content: center;
		margin: 0;
	}
	.tdc-flow-down svg {
		width: 22px;
		height: 26px;
		display: block;
	}

	.tdc-gates {
		box-sizing: border-box;
		width: 100%;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 5px 7px;
		padding: 10px 12px;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		margin: 0;
	}
	.tdc-gate {
		font-size: 12px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.tdc-gate code {
		font-size: 11.5px;
		font-weight: 700;
		background: transparent;
		padding: 0;
		color: var(--sl-color-white);
	}
	.tdc-gate-arrow {
		font-size: 12px;
		font-weight: 700;
		color: var(--sl-color-gray-3);
	}
	.tdc-shared-note {
		font-size: 10.5px;
		font-weight: 600;
		line-height: 1.3;
		text-align: center;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* Narrow cards: drop to a single top-to-bottom column. The converging
	   connector rotates so both branches still feed down into ctx. */
	@media (max-width: 720px) {
		.tdc {
			flex-direction: column;
		}
		.tdc-resolve,
		.tdc-shared {
			max-width: none;
			width: 100%;
		}
		.tdc-merge {
			flex: 0 0 auto;
			width: auto;
		}
		.tdc-merge-svg {
			width: 96px;
			height: 56px;
			transform: rotate(90deg);
		}
	}

	@media (max-width: 460px) {
		.tdc-branches {
			flex-direction: column;
		}
	}
</style>
