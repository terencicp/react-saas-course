---
// authed-action-gates — Ch057 L2 "The authedAction wrapper", the load-bearing
// runtime figure.
//
// One form submission scrubbed through the wrapper's four gates (plus the inbound
// FormData), one gate lit at a time. The teaching goal, straight from the lesson:
// the student should see the ORDER and the EXIT at each gate BEFORE reading the
// implementation — and especially that the Resolve gate exits via a framework
// REDIRECT while Authorize and Parse exit via a RETURNED Result. So the detail
// panel under the strip carries each gate's exit, and the exit TAG is colour-coded
// by exit kind:
//   - input  (neutral)  — raw FormData, nothing checked yet
//   - redirect (amber)  — leaves the wrapper entirely as a navigation
//   - returns 'forbidden' / 'validation' (red) — a returned err() Result
//   - returns Result<T> (green) — the success path, fn's own Result passed through
//
// It reuses the chapter's horizontal strip grammar via <GateStrip> (lit/dimmed
// node strip + arrow connectors that light as crossed). DiagramSequence supplies
// the outer card + per-step captions, so this is NOT wrapped in <Figure>.

import DiagramSequence from "../../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../figures/diagram-sequence/DiagramStep.astro";
import GateStrip from "./GateStrip.astro";

const ACCENT = "#2563eb"; // blue-600 — matches the lit node in <GateStrip>
---

<DiagramSequence>
	{/* 0 — Form submit */}
	<DiagramStep caption="A form submits. FormData arrives at the wrapper. Nothing has been checked yet — these are raw bytes from the browser.">
		<GateStrip active={0}>
			<span class="gs-tag gs-tag--input">Input</span>
			<span class="gs-exit">
				Raw <code>FormData</code> enters the wrapper. No gate has run.
			</span>
		</GateStrip>
	</DiagramStep>

	{/* 1 — Resolve */}
	<DiagramStep caption="Resolve: requireOrgUser() reads the session and the active org. No session redirects to /sign-in; no active org redirects to /select-org. That is a framework redirect, not a Result — it leaves the wrapper entirely.">
		<GateStrip active={1}>
			<span class="gs-tag gs-tag--redirect">Redirects out ↗</span>
			<span class="gs-exit">
				No session or no org → <code>redirect('/sign-in')</code>. A navigation,
				<strong>not</strong> a value — it flies straight out of the wrapper.
			</span>
		</GateStrip>
	</DiagramStep>

	{/* 2 — Authorize */}
	<DiagramStep caption="Authorize: roleAtLeast(role, required). If the user's role is below the floor the wrapper RETURNS err('forbidden') — it does not redirect. The form stays on the page and shows the message in place.">
		<GateStrip active={2}>
			<span class="gs-tag gs-tag--err">Returns ↩</span>
			<span class="gs-exit">
				Role below the floor → <code>err('forbidden')</code>. A returned Result,
				<strong>not</strong> a redirect — the form stays put and shows it.
			</span>
		</GateStrip>
	</DiagramStep>

	{/* 3 — Parse */}
	<DiagramStep caption="Parse: safeParse the FormData against the schema. On failure the wrapper returns err('validation') with the field errors attached, so the form can highlight the offending inputs.">
		<GateStrip active={3}>
			<span class="gs-tag gs-tag--err">Returns ↩</span>
			<span class="gs-exit">
				Input fails the schema → <code>err('validation', …, fieldErrors)</code>.
				A returned Result, so the form highlights the bad fields.
			</span>
		</GateStrip>
	</DiagramStep>

	{/* 4 — Call */}
	<DiagramStep caption="Call: only now does your business function run — fn(input, ctx) — with validated input and the pre-built ctx. Whatever Result it returns passes straight back to the form.">
		<GateStrip active={4}>
			<span class="gs-tag gs-tag--ok">Returns ↩</span>
			<span class="gs-exit">
				All gates passed → <code>fn(input, ctx)</code> runs and its
				<code>Result&lt;T&gt;</code> passes straight back.
			</span>
		</GateStrip>
	</DiagramStep>
</DiagramSequence>

<style define:vars={{ accent: ACCENT }}>
	/* The exit tag — a small glanceable pill naming HOW this gate exits. Its
	   colour is the teaching beat: amber for the framework redirect (leaves the
	   wrapper), red for a returned err() Result, green for the success path's
	   Result. Neutral for the inbound-FormData framing step. */
	.gs-tag {
		flex: 0 0 auto;
		display: inline-block;
		padding: 2px 10px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		line-height: 1.4;
	}
	.gs-tag--input {
		border-color: var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
	}
	/* Redirect: a framework navigation that leaves the wrapper — amber, distinct
	   from the returned-Result gates, because this is the one exit that is NOT a
	   value. */
	.gs-tag--redirect {
		border-color: color-mix(in srgb, #d97706 55%, transparent);
		background: color-mix(in srgb, #d97706 14%, var(--sl-color-bg));
		color: color-mix(in srgb, #b45309 78%, var(--sl-color-text));
	}
	/* Returned err() Result — refusal. Red. */
	.gs-tag--err {
		border-color: color-mix(in srgb, #dc2626 52%, transparent);
		background: color-mix(in srgb, #dc2626 13%, var(--sl-color-bg));
		color: color-mix(in srgb, #b91c1c 78%, var(--sl-color-text));
	}
	/* Returned success Result — the work ran. Green. */
	.gs-tag--ok {
		border-color: color-mix(in srgb, #16a34a 52%, transparent);
		background: color-mix(in srgb, #16a34a 13%, var(--sl-color-bg));
		color: color-mix(in srgb, #15803d 80%, var(--sl-color-text));
	}

	.gs-exit {
		margin: 0;
		max-width: 52ch;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-text);
	}
	.gs-exit strong {
		font-weight: 700;
		color: color-mix(in srgb, var(--accent) 72%, var(--sl-color-text));
	}
	.gs-exit code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12px;
		padding: 1px 5px;
		border-radius: 5px;
		background: var(--sl-color-gray-6);
		color: var(--sl-color-text);
	}
</style>
