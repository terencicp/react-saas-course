---
// One frame of the "authed-action-gates" DiagramSequence (Ch057 L2, "The
// authedAction wrapper"). It deliberately reuses the chapter-wide horizontal
// strip grammar (Ch049's render-pipeline / loop strips): a row of nodes with one
// lit (`is-on`, the accent) and SVG arrow connectors that light as they're
// crossed, so the wrapper's runtime picture reads in the same visual language as
// the rest of the course.
//
// The five gates a privileged Server Action flows through, in execution order:
//
//   Form submit → Resolve → Authorize → Parse → Call
//
// The strip is fixed across the five steps; only the lit node, the dimmed
// already-passed nodes, and the detail panel beneath change. Keeping the strip
// stable is the point — the eye tracks ONE position advancing left-to-right, the
// way a single request advances gate by gate.
//
// The detail panel under the strip carries the per-gate EXIT: what leaves on this
// gate's branch and HOW it exits. That distinction is the lesson's teaching beat
// — Resolve exits via a framework REDIRECT, while Authorize and Parse exit via a
// RETURNED Result — so the panel slot renders an exit tag whose styling encodes
// the exit kind. A fixed min-height keeps every frame the same height so
// DiagramSequence's grid-stack never jumps.
//
// Pure HTML + CSS, matching the sibling figures: `.not-content` to drop
// Starlight's prose chrome, `margin: 0` resets, theme-aware `color-mix` accents
// that read on light and dark.

interface Props {
	// Index (0-4) of the gate lit this frame.
	active: number;
}

const { active } = Astro.props;

// The five gates, in order. `label` is the node's headline, `sub` the one-word
// role under it. Labels are kept short so five nodes fit one row under the cap.
const nodes: { label: string; sub: string }[] = [
	{ label: "Form submit", sub: "FormData" },
	{ label: "Resolve", sub: "session" },
	{ label: "Authorize", sub: "role" },
	{ label: "Parse", sub: "schema" },
	{ label: "Call", sub: "fn(input, ctx)" },
];

const ACCENT = "#2563eb"; // blue-600 — the wrapper's accent (the "authz" colour)
---

<div class="gs-stage not-content">
	<div
		class="gs-strip"
		role="img"
		aria-label="A privileged Server Action flows through five gates in order: Form submit, Resolve the session, Authorize the role, Parse the input, Call the business function. Active gate highlighted."
	>
		{
			nodes.map((node, i) => (
				<>
					<div
						class:list={[
							"gs-node",
							{ "is-on": i === active, "is-done": i < active },
						]}
					>
						<span class="gs-node-label">{node.label}</span>
						<span class="gs-node-sub">{node.sub}</span>
					</div>
					{i < nodes.length - 1 && (
						<span
							class:list={["gs-arrow", { "is-on": i < active }]}
							aria-hidden="true"
						>
							<svg
								viewBox="0 0 34 14"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<line x1="1" y1="7" x2="26" y2="7" />
								<polyline points="21 2.5 27.5 7 21 11.5" />
							</svg>
						</span>
					)}
				</>
			))
		}
	</div>

	<div class="gs-detail">
		<slot />
	</div>
</div>

<style define:vars={{ accent: ACCENT }}>
	.gs-stage {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* The horizontal gate strip. Wraps (never scrolls) on narrow viewports. */
	.gs-strip {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
	}

	.gs-node {
		margin: 0;
		flex: 1 1 0;
		min-width: 92px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		padding: 10px 8px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s,
			opacity 0.14s;
	}
	/* Gates already crossed: tinted but receded, so the strip reads as a path
	   already walked up to the lit gate. */
	.gs-node.is-done {
		border-color: color-mix(in srgb, var(--accent) 32%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--accent) 7%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 45%, var(--sl-color-gray-3));
		opacity: 0.75;
	}
	.gs-node.is-on {
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
		opacity: 1;
	}

	.gs-node-label {
		margin: 0;
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.2;
	}
	.gs-node-sub {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.2;
		opacity: 0.9;
	}

	/* Connectors between gates. Edges already crossed (left of the active gate)
	   light up so the strip reads as a request moving through, not a static row. */
	.gs-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.gs-arrow.is-on {
		color: var(--accent);
	}
	.gs-arrow svg {
		width: 24px;
		height: 13px;
	}

	/* Detail panel under the strip — carries this gate's EXIT (what leaves on the
	   branch, and how). Fixed min-height so every frame matches and the
	   grid-stacked sequence never changes height between steps. */
	.gs-detail {
		margin: 0;
		box-sizing: border-box;
		min-height: 92px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 9px;
		padding: 14px 16px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		text-align: center;
	}

	/* On the narrowest viewports the gates stack; rotate the connectors so the
	   flow still reads top-to-bottom. */
	@media (max-width: 620px) {
		.gs-strip {
			flex-direction: column;
			align-items: stretch;
		}
		.gs-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
