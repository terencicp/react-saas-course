---
// shared-fn-trace — Ch057 L3 "The authedRoute twin", the figure for the "One
// business function, both doors" section.
//
// One logical request scrubbed through the shared-function pattern, one stage lit
// at a time. The teaching goal, straight from the lesson: the MIDDLE two stages
// are identical regardless of which door the request came in — only the FIRST
// (which door it entered) and the LAST (how the Result is presented) differ. So
// the strip colours the first and last nodes with the chapter's two-door palette
// (blue authedAction + orange authedRoute) and leaves the middle two neutral and
// dashed ("shared"); and the detail panel under each stage carries a scope tag —
// DOOR-SPECIFIC, with both variants spelled out, on the ends; IDENTICAL ON BOTH
// DOORS in the shared middle.
//
// It reuses the chapter's horizontal strip grammar via <SeamStrip> (the same
// lit/dimmed node strip + arrow connectors as L2's <GateStrip>). DiagramSequence
// supplies the outer card + per-step captions, so this is NOT wrapped in <Figure>.

import DiagramSequence from "../../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../figures/diagram-sequence/DiagramStep.astro";
import SeamStrip from "./SeamStrip.astro";
---

<DiagramSequence>
	{/* 0 — Caller hits a door */}
	<DiagramStep caption="A request arrives at its door. The door is decided by the caller's shape, not by preference — a React form takes authedAction, a partner's JSON POST takes authedRoute.">
		<SeamStrip active={0}>
			<span class="sft-scope sft-scope--split">Door-specific</span>
			<span class="sft-rows">
				<span class="sft-row">
					<span class="sft-tag sft-tag--blue">authedAction</span>
					<span class="sft-row-text">a same-origin React form / <code>useActionState</code></span>
				</span>
				<span class="sft-row">
					<span class="sft-tag sft-tag--orange">authedRoute</span>
					<span class="sft-row-text">a webhook, partner server, or mobile client POSTing JSON</span>
				</span>
			</span>
		</SeamStrip>
	</DiagramStep>

	{/* 1 — Wrapper: the four gates */}
	<DiagramStep caption="The wrapper runs the same four gates either way — resolve the session, authorize the role, parse the input. This stage is identical on both doors; only the failure exits change shape.">
		<SeamStrip active={1}>
			<span class="sft-scope sft-scope--shared">Identical on both doors</span>
			<span class="sft-shared-text">
				<code>resolve → authorize → parse</code>. Same order, same checks, same
				<code>ctx = &#123; user, orgId, role, db &#125;</code> handed down — whichever door the request came in.
			</span>
		</SeamStrip>
	</DiagramStep>

	{/* 2 — Shared /lib function */}
	<DiagramStep caption="The wrapper calls the shared business function — createInvoice(input, ctx). It does the database work and returns a Result. It has no notion of HTTP or FormData, and no idea which door called it.">
		<SeamStrip active={2}>
			<span class="sft-scope sft-scope--shared">Identical on both doors</span>
			<span class="sft-shared-text">
				One pure function in <code>/lib</code>: <code>createInvoice(input, ctx): Promise&lt;Result&gt;</code>.
				The work is written <strong>once</strong> — neither door owns it.
			</span>
		</SeamStrip>
	</DiagramStep>

	{/* 3 — Door presents the Result */}
	<DiagramStep caption="Each door presents the same Result differently. The action returns it inline for the form to read; the route translates it — ok to Response.json(data, { status: 201 }), error to problemFrom(error). Same value, two presentations.">
		<SeamStrip active={3}>
			<span class="sft-scope sft-scope--split">Door-specific</span>
			<span class="sft-rows">
				<span class="sft-row">
					<span class="sft-tag sft-tag--blue">authedAction</span>
					<span class="sft-row-text">returns the <code>Result</code> inline — the form reads it as-is</span>
				</span>
				<span class="sft-row">
					<span class="sft-tag sft-tag--orange">authedRoute</span>
					<span class="sft-row-text">translates it: <code>ok</code> → <code>Response.json</code>, error → <code>problemFrom</code></span>
				</span>
			</span>
		</SeamStrip>
	</DiagramStep>
</DiagramSequence>

<style define:vars={{ blue: "#2563eb", orange: "#ea580c" }}>
	/* The scope tag — a glanceable pill naming whether this stage is door-specific
	   or shared. This is the figure's teaching beat: the ends are split by door,
	   the middle is one shared thing. */
	.sft-scope {
		flex: 0 0 auto;
		display: inline-block;
		padding: 2px 11px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		line-height: 1.4;
	}
	/* Door-specific: tinted across both door colours, echoing the split node. */
	.sft-scope--split {
		border-color: transparent;
		background:
			linear-gradient(
					color-mix(in srgb, var(--blue) 13%, var(--sl-color-bg)),
					color-mix(in srgb, var(--orange) 13%, var(--sl-color-bg))
				)
				padding-box,
			linear-gradient(100deg, var(--blue), var(--orange)) border-box;
		border: 1px solid transparent;
		color: var(--sl-color-text);
	}
	/* Shared: neutral, matching the dashed shared nodes. */
	.sft-scope--shared {
		border-style: dashed;
		border-color: var(--sl-color-gray-3);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
	}

	/* The two door rows shown on a door-specific stage. */
	.sft-rows {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 7px;
		max-width: 56ch;
		text-align: left;
	}
	.sft-row {
		margin: 0;
		display: flex;
		align-items: baseline;
		gap: 9px;
	}
	.sft-tag {
		flex: 0 0 auto;
		display: inline-block;
		min-width: 92px;
		text-align: center;
		padding: 2px 8px;
		border-radius: 6px;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 11px;
		font-weight: 700;
		line-height: 1.4;
	}
	.sft-tag--blue {
		border: 1px solid color-mix(in srgb, var(--blue) 50%, transparent);
		background: color-mix(in srgb, var(--blue) 13%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--blue) 85%, var(--sl-color-text));
	}
	.sft-tag--orange {
		border: 1px solid color-mix(in srgb, var(--orange) 50%, transparent);
		background: color-mix(in srgb, var(--orange) 13%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--orange) 88%, var(--sl-color-text));
	}
	.sft-row-text {
		margin: 0;
		font-size: 12.5px;
		line-height: 1.45;
		color: var(--sl-color-text);
	}

	/* The single shared line shown on a shared stage. */
	.sft-shared-text {
		margin: 0;
		max-width: 56ch;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-text);
	}
	.sft-shared-text strong {
		font-weight: 700;
		color: var(--sl-color-white);
	}

	.sft-row-text code,
	.sft-shared-text code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 11.5px;
		padding: 1px 5px;
		border-radius: 5px;
		background: var(--sl-color-gray-6);
		color: var(--sl-color-text);
	}
</style>
