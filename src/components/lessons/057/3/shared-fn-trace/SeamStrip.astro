---
// One frame of the "shared-fn-trace" DiagramSequence (Ch057 L3, "The authedRoute
// twin"). It reuses the chapter's horizontal strip grammar — the same lit/dimmed
// node row + arrow connectors as L2's <GateStrip> and the course's pipeline
// strips — so one logical request reads as a single position advancing
// left-to-right through four stages.
//
// The four stages a request flows through, whichever door it came in:
//
//   Caller hits a door → Wrapper (resolve·authorize·parse) → Shared /lib fn → Door presents
//
// The teaching beat lives in the COLOUR of each node, not just which one is lit.
// The chapter's door palette carries it: blue = the React door (authedAction),
// orange = the HTTP door (authedRoute), neutral grey = the SHARED middle. The
// first node (which door) and the last node (how the Result is presented) are
// door-specific, so they're split blue/orange; the middle two — the wrapper's
// gates and the /lib function — are identical on both doors, so they stay
// neutral. That contrast IS the lesson: same room, two doors; only the ends
// diverge.
//
// The detail panel under the strip carries this stage's scope: DOOR-SPECIFIC
// (both door variants shown) for the ends, IDENTICAL ON BOTH DOORS for the
// shared middle. A fixed min-height keeps every frame the same height so
// DiagramSequence's grid-stack never jumps between steps.
//
// Pure HTML + CSS, matching the sibling figures: `.not-content` to drop
// Starlight's prose chrome, `margin: 0` resets, theme-aware `color-mix` accents
// that read on light and dark.

interface Props {
	// Index (0-3) of the stage lit this frame.
	active: number;
}

const { active } = Astro.props;

// The four stages, in order. `kind` drives the node's colour:
//   "split"  — door-specific, tinted on both blue and orange edges
//   "shared" — identical on both doors, neutral
const nodes: { label: string; sub: string; kind: "split" | "shared" }[] = [
	{ label: "Caller hits a door", sub: "form · JSON POST", kind: "split" },
	{ label: "Wrapper", sub: "resolve · authorize · parse", kind: "shared" },
	{ label: "Shared /lib fn", sub: "→ Result", kind: "shared" },
	{ label: "Door presents", sub: "Result · Response", kind: "split" },
];

const BLUE = "#2563eb"; // React door — authedAction → Result
const ORANGE = "#ea580c"; // HTTP door — authedRoute → Response
---

<div class="ss-stage not-content">
	<div
		class="ss-strip"
		role="img"
		aria-label="One request flows through four stages: caller hits a door, the wrapper resolves, authorizes and parses, the shared /lib function returns a Result, then the door presents the result. The first and last stages are door-specific; the middle two are identical on both doors. Active stage highlighted."
	>
		{
			nodes.map((node, i) => (
				<>
					<div
						class:list={[
							"ss-node",
							`is-${node.kind}`,
							{ "is-on": i === active, "is-done": i < active },
						]}
					>
						{node.kind === "split" && (
							<span class="ss-node-doors" aria-hidden="true">
								<span class="ss-dot ss-dot--blue" />
								<span class="ss-dot ss-dot--orange" />
							</span>
						)}
						{node.kind === "shared" && (
							<span class="ss-node-shared" aria-hidden="true">
								shared
							</span>
						)}
						<span class="ss-node-label">{node.label}</span>
						<span class="ss-node-sub">{node.sub}</span>
					</div>
					{i < nodes.length - 1 && (
						<span
							class:list={["ss-arrow", { "is-on": i < active }]}
							aria-hidden="true"
						>
							<svg
								viewBox="0 0 34 14"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<line x1="1" y1="7" x2="26" y2="7" />
								<polyline points="21 2.5 27.5 7 21 11.5" />
							</svg>
						</span>
					)}
				</>
			))
		}
	</div>

	<div class="ss-detail">
		<slot />
	</div>
</div>

<style define:vars={{ blue: BLUE, orange: ORANGE }}>
	.ss-stage {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* The horizontal stage strip. Wraps (never scrolls) on narrow viewports. */
	.ss-strip {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
	}

	.ss-node {
		margin: 0;
		flex: 1 1 0;
		min-width: 116px;
		box-sizing: border-box;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		padding: 12px 9px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s,
			opacity 0.14s;
	}

	/* Shared (middle) stages: a single neutral identity, the same on both doors. */
	.ss-node.is-shared {
		border-style: dashed;
	}

	.ss-node-shared {
		margin: 0;
		display: inline-block;
		padding: 0 7px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		color: var(--sl-color-gray-2);
		font-size: 8.5px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		line-height: 1.6;
	}

	/* Split (end) stages: the two doors, shown as a blue + orange pair, so the
	   eye reads "this stage differs by door" at a glance. */
	.ss-node-doors {
		margin: 0;
		display: inline-flex;
		gap: 4px;
	}
	.ss-dot {
		display: inline-block;
		width: 9px;
		height: 9px;
		border-radius: 999px;
	}
	.ss-dot--blue {
		background: var(--blue);
	}
	.ss-dot--orange {
		background: var(--orange);
	}

	.ss-node-label {
		margin: 0;
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.2;
	}
	.ss-node-sub {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.2;
		opacity: 0.9;
	}

	/* Already-passed stages: receded so the strip reads as a path walked up to
	   the lit stage. Tint tracks the node's kind. */
	.ss-node.is-done {
		opacity: 0.7;
	}
	.ss-node.is-done.is-shared {
		border-color: var(--sl-color-gray-4);
		background: color-mix(in srgb, var(--sl-color-gray-5) 60%, var(--sl-color-bg));
		color: var(--sl-color-gray-3);
	}
	.ss-node.is-done.is-split {
		border-color: color-mix(in srgb, var(--blue) 24%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--blue) 5%, var(--sl-color-bg));
		color: var(--sl-color-gray-3);
	}

	/* Lit stage. A shared stage lights neutral (it has no door colour); a split
	   stage lights with a blue→orange wash to keep its two-door identity. */
	.ss-node.is-on {
		opacity: 1;
		color: var(--sl-color-white);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent);
	}
	.ss-node.is-on.is-shared {
		border: 1.5px dashed var(--sl-color-gray-2);
		background: var(--sl-color-gray-5);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-2) 18%, transparent);
	}
	.ss-node.is-on.is-split {
		border: 1.5px solid transparent;
		background:
			linear-gradient(var(--sl-color-bg), var(--sl-color-bg)) padding-box,
			linear-gradient(100deg, var(--blue), var(--orange)) border-box;
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--blue) 12%, transparent);
	}
	.ss-node.is-on.is-split {
		background:
			linear-gradient(
					color-mix(in srgb, var(--blue) 9%, var(--sl-color-bg)),
					color-mix(in srgb, var(--orange) 9%, var(--sl-color-bg))
				)
				padding-box,
			linear-gradient(100deg, var(--blue), var(--orange)) border-box;
	}

	/* Connectors between stages. Edges already crossed light so the strip reads
	   as a request moving through, not a static row. */
	.ss-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.ss-arrow.is-on {
		color: var(--sl-color-gray-2);
	}
	.ss-arrow svg {
		width: 24px;
		height: 13px;
	}

	/* Detail panel under the strip — carries this stage's scope (door-specific vs
	   shared) and what happens. Fixed min-height so every frame matches and the
	   grid-stacked sequence never changes height between steps. */
	.ss-detail {
		margin: 0;
		box-sizing: border-box;
		min-height: 118px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 11px;
		padding: 15px 16px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		text-align: center;
	}

	/* On the narrowest viewports the stages stack; rotate the connectors so the
	   flow still reads top-to-bottom. */
	@media (max-width: 640px) {
		.ss-strip {
			flex-direction: column;
			align-items: stretch;
		}
		.ss-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
