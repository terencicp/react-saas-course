---
// two-doors-one-room — Ch057 L3 "The authedRoute twin", the conceptual-spine
// figure for the "Two doors, one discipline" section.
//
// The mental model the section opens with, made literal: TWO distinct entry
// doors converge on ONE shared business function, which writes to the DB.
//
//   [React form]  ──via authedAction → Result──┐
//                                               ├─▶ [createInvoice(input, ctx)] ─▶ [Database]
//   [JSON POST]   ──via authedRoute → Response──┘
//
// The teaching beat is correspondence, not direction: the student should SEE
// two doors leading to the same room BEFORE the shared-function pattern is
// taught in prose, with the two return types (Result vs Response) planted as
// the *only* divergence. So each door box is tinted to match its connector and
// label — blue door ↦ "→ Result", orange door ↦ "→ Response" — and the center
// + DB stay neutral (the shared part).
//
// Built as plain HTML + CSS rather than <ArrowDiagram>, matching this chapter's
// flow grammar (056/2 RegistryToSurface, 057/2 GateStrip): two converging
// sources onto one target + long gap labels are exactly the leader-line case
// the ArrowDiagram doc flags as fiddly (stacked arrowheads, label collisions in
// a shared gap). Colour-matched tints + SVG connector glyphs carry the
// correspondence at near-zero risk and read in the same visual language as the
// figures just above it. `not-content` + margin:0 resets defeat Starlight's
// prose-margin selector. Goes inside <Figure> (supplied at the call site).
//
// Static figure — no interactivity. Wraps to a vertical stack on narrow cards;
// connectors rotate to point downward so the flow still reads top-to-bottom.

const reset = "margin: 0";
const mono =
	"font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Saturated mid-tones (project palette), reused verbatim in light + dark — the
// colour itself is the signal. Blue = the React door (Result); orange = the
// HTTP door (Response). Tints are derived with color-mix so they track the page
// background in both themes.
const BLUE = "#2563eb"; // React door — authedAction → Result
const ORANGE = "#ea580c"; // HTTP door — authedRoute → Response
---

<div class="tdr not-content">
	{/* LEFT column — the two doors, stacked. Each tinted to its return type. */}
	<div class="tdr-doors">
		<div class="tdr-door tdr-door--blue">
			<span class="tdr-door-glyph" aria-hidden="true">
				<svg
					viewBox="0 0 24 24"
					width="16"
					height="16"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M13 4h3a2 2 0 0 1 2 2v14"></path>
					<path d="M2 20h3"></path>
					<path d="M13 20h9"></path>
					<path d="M10 12v.01"></path>
					<path d="M13 4.562v16.157a1 1 0 0 1-1.242.97L5 20V5.562a2 2 0 0 1 1.515-1.94l4-1A2 2 0 0 1 13 4.562z"
					></path>
				</svg>
			</span>
			<span class="tdr-door-title">React form</span>
			<span class="tdr-door-sub">same-origin, useActionState</span>
		</div>

		<div class="tdr-door tdr-door--orange">
			<span class="tdr-door-glyph" aria-hidden="true">
				<svg
					viewBox="0 0 24 24"
					width="16"
					height="16"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M13 4h3a2 2 0 0 1 2 2v14"></path>
					<path d="M2 20h3"></path>
					<path d="M13 20h9"></path>
					<path d="M10 12v.01"></path>
					<path d="M13 4.562v16.157a1 1 0 0 1-1.242.97L5 20V5.562a2 2 0 0 1 1.515-1.94l4-1A2 2 0 0 1 13 4.562z"
					></path>
				</svg>
			</span>
			<span class="tdr-door-title">JSON POST</span>
			<span class="tdr-door-sub">webhook, partner, mobile</span>
		</div>
	</div>

	{/* Connectors from the two doors → the shared function. Each is a labelled
	    arrow colour-matched to its door, so the eye reads form↦Result and
	    POST↦Response. A wrapping brace-like bracket would over-engineer it; two
	    angled SVG connectors converging on the center read cleanly. */}
	<div class="tdr-link tdr-link--converge" aria-hidden="true">
		<svg
			class="tdr-link-svg"
			viewBox="0 0 120 120"
			preserveAspectRatio="none"
			fill="none"
		>
			{/* top door → center (lands mid-height) */}
			<path
				d="M2 30 C 60 30, 60 60, 118 60"
				stroke={BLUE}
				stroke-width="2.5"
				stroke-linecap="round"></path>
			{/* bottom door → center (lands mid-height) */}
			<path
				d="M2 90 C 60 90, 60 60, 118 60"
				stroke={ORANGE}
				stroke-width="2.5"
				stroke-linecap="round"></path>
			{/* shared arrowhead into the center box */}
			<path
				d="M112 55 L 120 60 L 112 65"
				stroke="var(--sl-color-gray-2)"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
		<span class="tdr-label tdr-label--blue">via <code>authedAction</code> → Result</span>
		<span class="tdr-label tdr-label--orange">via <code>authedRoute</code> → Response</span>
	</div>

	{/* CENTER column — the shared business function (the "one room"). Neutral. */}
	<div class="tdr-core">
		<span class="tdr-core-title"><code>createInvoice(input, ctx)</code></span>
		<span class="tdr-core-sub">business logic in <code>/lib</code></span>
	</div>

	{/* Connector center → DB. Neutral — the shared write. */}
	<div class="tdr-link tdr-link--single" aria-hidden="true">
		<svg
			class="tdr-link-svg"
			viewBox="0 0 60 24"
			preserveAspectRatio="none"
			fill="none"
		>
			<line
				x1="2"
				y1="12"
				x2="48"
				y2="12"
				stroke="var(--sl-color-gray-2)"
				stroke-width="2.5"
				stroke-linecap="round"></line>
			<path
				d="M50 6 L 60 12 L 50 18"
				stroke="var(--sl-color-gray-2)"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
		<span class="tdr-label tdr-label--muted">tenant-scoped write</span>
	</div>

	{/* RIGHT column — the database (tenant-scoped tables). Neutral. */}
	<div class="tdr-db">
		<span class="tdr-db-glyph" aria-hidden="true">
			<svg
				viewBox="0 0 24 24"
				width="18"
				height="18"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
				<path d="M3 5V19A9 3 0 0 0 21 19V5"></path>
				<path d="M3 12A9 3 0 0 0 21 12"></path>
			</svg>
		</span>
		<span class="tdr-db-title">Database</span>
		<span class="tdr-db-sub">tenant-scoped tables</span>
	</div>
</div>

<style define:vars={{ blue: BLUE, orange: ORANGE, monoFont: mono, sansFont: sans }}>
	.tdr {
		margin: 0;
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 8px;
		width: 100%;
		box-sizing: border-box;
		font-family: var(--sansFont);
	}

	/* ---- LEFT: the two stacked doors ---- */
	.tdr-doors {
		margin: 0;
		flex: 1 1 190px;
		min-width: 180px;
		max-width: 260px;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.tdr-door {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 11px 13px 12px;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
	}
	.tdr-door--blue {
		border-color: color-mix(in srgb, var(--blue) 55%, transparent);
		background: color-mix(in srgb, var(--blue) 12%, var(--sl-color-bg));
	}
	.tdr-door--orange {
		border-color: color-mix(in srgb, var(--orange) 55%, transparent);
		background: color-mix(in srgb, var(--orange) 12%, var(--sl-color-bg));
	}

	.tdr-door-glyph {
		margin: 0;
		display: inline-flex;
	}
	.tdr-door--blue .tdr-door-glyph {
		color: color-mix(in srgb, var(--blue) 85%, var(--sl-color-text));
	}
	.tdr-door--orange .tdr-door-glyph {
		color: color-mix(in srgb, var(--orange) 85%, var(--sl-color-text));
	}

	.tdr-door-title {
		margin: 0;
		font-size: 14.5px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.tdr-door-sub {
		margin: 0;
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.02em;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
	}

	/* ---- CENTER: the shared function ---- */
	.tdr-core {
		margin: 0;
		flex: 1 1 200px;
		min-width: 190px;
		max-width: 270px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 14px 15px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-3);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		text-align: center;
		align-items: center;
	}
	.tdr-core-title {
		margin: 0;
		line-height: 1.25;
	}
	.tdr-core-title code {
		font-family: var(--monoFont);
		font-size: 13.5px;
		font-weight: 700;
		background: transparent;
		padding: 0;
		color: var(--sl-color-white);
	}
	.tdr-core-sub {
		margin: 0;
		font-size: 11px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
	}
	.tdr-core-sub code {
		font-family: var(--monoFont);
		font-size: 10.5px;
		background: var(--sl-color-gray-5);
		padding: 0 4px;
		border-radius: 4px;
		color: var(--sl-color-white);
	}

	/* ---- RIGHT: the database ---- */
	.tdr-db {
		margin: 0;
		flex: 0 1 150px;
		min-width: 130px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		padding: 14px 15px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-3);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		text-align: center;
	}
	.tdr-db-glyph {
		margin: 0;
		display: inline-flex;
		color: var(--sl-color-gray-2);
	}
	.tdr-db-title {
		margin: 0;
		font-size: 14px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.tdr-db-sub {
		margin: 0;
		font-size: 10.5px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
	}

	/* ---- Connectors ---- */
	.tdr-link {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 5px;
	}
	.tdr-link--converge {
		flex: 0 0 132px;
		width: 132px;
	}
	.tdr-link--converge .tdr-link-svg {
		width: 132px;
		height: 110px;
		display: block;
	}
	.tdr-link--single {
		flex: 0 0 74px;
		width: 74px;
	}
	.tdr-link--single .tdr-link-svg {
		width: 60px;
		height: 24px;
		display: block;
	}

	.tdr-label {
		margin: 0;
		display: inline-block;
		font-size: 11px;
		font-weight: 600;
		line-height: 1.25;
		text-align: center;
		white-space: nowrap;
	}
	.tdr-label code {
		font-family: var(--monoFont);
		font-size: 10.5px;
		background: transparent;
		padding: 0;
		font-weight: 700;
	}
	.tdr-label--blue {
		color: color-mix(in srgb, var(--blue) 78%, var(--sl-color-text));
	}
	.tdr-label--blue code {
		color: color-mix(in srgb, var(--blue) 88%, var(--sl-color-text));
	}
	.tdr-label--orange {
		color: color-mix(in srgb, var(--orange) 80%, var(--sl-color-text));
	}
	.tdr-label--orange code {
		color: color-mix(in srgb, var(--orange) 90%, var(--sl-color-text));
	}
	.tdr-label--muted {
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	/* On narrow figure cards the row wraps to a column. Make the converging
	   connector point downward and the labels sit beside the (now horizontal)
	   curves, so the flow still reads top-to-bottom door → function → DB. */
	@media (max-width: 640px) {
		.tdr {
			flex-direction: column;
		}
		.tdr-doors {
			flex-direction: row;
			max-width: none;
			width: 100%;
		}
		.tdr-doors .tdr-door {
			flex: 1 1 0;
		}
		.tdr-link--converge {
			flex: 0 0 auto;
			width: auto;
		}
		.tdr-link--converge .tdr-link-svg {
			width: 90px;
			height: 56px;
			transform: rotate(90deg);
		}
		.tdr-link--single {
			flex: 0 0 auto;
			width: auto;
		}
		.tdr-link--single .tdr-link-svg {
			width: 24px;
			height: 36px;
			transform: rotate(90deg);
		}
		.tdr-core,
		.tdr-db {
			max-width: none;
			width: 100%;
		}
	}
</style>
