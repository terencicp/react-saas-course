---
// accounts-before-after-link — Chapter 053 Lesson 9, "Account linking".
//
// The section's load-bearing figure: make "linking = one more `account` row
// against the SAME `user`" literally visible. The whole point is that the `user`
// row in the middle never changes — all that happens when Ada links Google is
// that a second `account` card slots in beside her password credential, pointing
// at the same `userId`.
//
// Layout — a horizontal three-zone strip (stacks vertically on narrow viewports):
//
//   [ Before linking ]        [  user  ]        [ After linking ]
//     account (credential) ─▶  id: usr_a1  ◀─ account (credential)
//                              (unchanged)  ◀─ account (google)   ← NEW
//
// The shared `user` card sits dead-centre between the two states, captioned
// "unchanged", so one glance carries "same row on both sides". Every `account`
// card carries an explicit `userId: usr_a1` field that matches the centre card's
// `id: usr_a1` — that shared id is the join the prose keeps naming; small CSS
// connector stubs point each account stack at the centre without LeaderLines
// (so the figure survives the <Figure> lightbox; no document.body positioning).
//
// COLOUR — this lesson re-points the chapter's row-card palette on purpose. The
// hinge here is the row that LINKING INSERTS, so violet (the chapter's "hinge"
// accent) marks the NEW google card alone. The `user` keeps its ER identity blue
// (from L1's rows-after-signup); the unchanged `credential` card drops to neutral
// gray so the violet google card is unmistakably the one thing that changed. This
// is the deliberate per-lesson adaptation the MDX author called for — violet =
// "what linking added", not "the credential row" as in L1.
//
// Plain HTML + scoped CSS per the diagrams index (annotated-illustration shape;
// NOT a diagram engine, NOT ArrowDiagram). Theme-aware via Starlight gray/white
// vars (flip light/dark); the two accents (#2563eb blue, #7c3aed violet) are
// mid-tones reused as-is on both backgrounds. `not-content` + `margin: 0` resets
// defeat Starlight's injected prose styling inside the figure. The <Figure>
// wrapper and caption are authored in the MDX, not here.

interface Field {
	key: string;
	val: string;
	/** the shared foreign key / primary key — rendered emphasised so the join reads */
	link?: boolean;
}

interface AccountCard {
	provider: string;
	accent: 'neutral' | 'violet';
	isNew?: boolean;
	fields: Field[];
}

const credentialFields: Field[] = [
	{ key: 'providerId', val: "'credential'" },
	{ key: 'accountId', val: 'ada@acme.com' },
	{ key: 'password', val: '********' },
	{ key: 'userId', val: 'usr_a1', link: true },
];

const googleFields: Field[] = [
	{ key: 'providerId', val: "'google'" },
	{ key: 'accountId', val: '117…204' },
	{ key: 'password', val: '—' },
	{ key: 'userId', val: 'usr_a1', link: true },
];

const beforeCards: AccountCard[] = [
	{ provider: 'credential', accent: 'neutral', fields: credentialFields },
];

const afterCards: AccountCard[] = [
	{ provider: 'credential', accent: 'neutral', fields: credentialFields },
	{ provider: 'google', accent: 'violet', isNew: true, fields: googleFields },
];
---

<div class="bal not-content">
	{/* ── BEFORE ─────────────────────────────────────────────── */}
	<section class="bal-zone bal-zone--before">
		<span class="bal-band">Before linking</span>
		<div class="bal-stack">
			{
				beforeCards.map((card) => (
					<div class={`bal-acct bal-acct--${card.accent}`}>
						<div class="bal-acct-head">
							<code class="bal-acct-name">account</code>
							<span class="bal-acct-tag">{card.provider}</span>
						</div>
						<div class="bal-acct-body">
							{card.fields.map((f) => (
								<span class={`bal-field${f.link ? ' bal-field--link' : ''}`}>
									<span class="bal-key">{f.key}</span>
									<span class="bal-val">{f.val}</span>
								</span>
							))}
						</div>
					</div>
				))
			}
		</div>
		<span class="bal-foot">One credential — her password.</span>
	</section>

	{/* ── connector: before → user ── */}
	<div class="bal-link bal-link--in" aria-hidden="true"></div>

	{/* ── THE SHARED USER (unchanged across both states) ──────── */}
	<section class="bal-zone bal-zone--user">
		<span class="bal-band bal-band--user">Same row, both sides</span>
		<div class="bal-user">
			<div class="bal-user-head">
				<code class="bal-user-name">user</code>
				<span class="bal-user-tag">the human</span>
			</div>
			<div class="bal-user-body">
				<span class="bal-field bal-field--link">
					<span class="bal-key">id</span>
					<span class="bal-val">usr_a1</span>
				</span>
				<span class="bal-field">
					<span class="bal-key">email</span>
					<span class="bal-val">ada@acme.com</span>
				</span>
			</div>
			<span class="bal-user-pill">unchanged</span>
		</div>
	</section>

	{/* ── connector: after → user ── */}
	<div class="bal-link bal-link--out" aria-hidden="true"></div>

	{/* ── AFTER ──────────────────────────────────────────────── */}
	<section class="bal-zone bal-zone--after">
		<span class="bal-band">After linking</span>
		<div class="bal-stack">
			{
				afterCards.map((card) => (
					<div
						class={`bal-acct bal-acct--${card.accent}${card.isNew ? ' bal-acct--new' : ''}`}
					>
						<div class="bal-acct-head">
							<code class="bal-acct-name">account</code>
							{card.isNew ? (
								<span class="bal-acct-badge">+ new</span>
							) : (
								<span class="bal-acct-tag">{card.provider}</span>
							)}
						</div>
						<div class="bal-acct-body">
							{card.fields.map((f) => (
								<span class={`bal-field${f.link ? ' bal-field--link' : ''}`}>
									<span class="bal-key">{f.key}</span>
									<span class="bal-val">{f.val}</span>
								</span>
							))}
						</div>
					</div>
				))
			}
		</div>
		<span class="bal-foot">A second row appears — same <code>userId</code>.</span>
	</section>
</div>

<style>
	.bal {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1.1fr) auto minmax(0, 1fr);
		align-items: center;
		justify-items: center;
		column-gap: 10px;
		row-gap: 14px;
		margin: 0;
		padding: 12px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.bal-zone {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		min-width: 0;
		width: 100%;
		margin: 0;
	}

	/* ── the small group label above each zone ── */
	.bal-band {
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		line-height: 1.2;
		padding: 2px 9px;
		border-radius: 999px;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #e2e8f0);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
		white-space: nowrap;
	}
	.bal-band--user {
		color: #1d4ed8;
		background: color-mix(in srgb, #2563eb 12%, transparent);
		border-color: color-mix(in srgb, #2563eb 38%, transparent);
	}

	.bal-stack {
		display: flex;
		flex-direction: column;
		gap: 12px;
		width: 100%;
		margin: 0;
	}

	/* ───────────────────────── account cards ───────────────────────── */
	.bal-acct {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		border-radius: 10px;
		overflow: hidden;
		width: 100%;
		margin: 0;
	}

	/* neutral — the unchanged `credential` row (deliberately NOT violet here) */
	.bal-acct--neutral {
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 18%, var(--sl-color-bg, transparent));
	}

	/* violet — the NEW google row: the hinge of the whole lesson */
	.bal-acct--violet {
		border: 1.5px solid #7c3aed; /* violet-600 */
		background: color-mix(in srgb, #7c3aed 8%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 10px rgba(124, 58, 237, 0.22);
	}

	.bal-acct-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 6px 11px;
		margin: 0;
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
	}
	.bal-acct--neutral .bal-acct-head {
		border-bottom-color: var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-4, #94a3b8) 13%, transparent);
	}
	.bal-acct--violet .bal-acct-head {
		border-bottom-color: color-mix(in srgb, #7c3aed 35%, transparent);
		background: color-mix(in srgb, #7c3aed 13%, transparent);
	}

	.bal-acct-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	.bal-acct-tag {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.64rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* the "+ new" badge on the inserted google card — violet, the hinge marker */
	.bal-acct-badge {
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1;
		white-space: nowrap;
		padding: 3px 7px;
		border-radius: 999px;
		color: #fff;
		background: #7c3aed;
		margin: 0;
	}

	.bal-acct-body,
	.bal-user-body {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 8px 11px;
		margin: 0;
	}

	/* ── one `column: value` line ── */
	.bal-field {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		line-height: 1.3;
		margin: 0;
	}
	.bal-key {
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.bal-val {
		color: var(--sl-color-white, #1e293b);
		text-align: right;
		white-space: nowrap;
		margin: 0;
	}

	/* the shared id / userId — emphasised everywhere it appears, so the join reads.
	   blue, matching the `user` it points at. */
	.bal-field--link {
		border-radius: 5px;
		padding: 1px 5px;
		margin: 0 -5px;
		background: color-mix(in srgb, #2563eb 10%, transparent);
	}
	.bal-field--link .bal-key {
		color: #1d4ed8;
		font-weight: 700;
	}
	.bal-field--link .bal-val {
		color: #1d4ed8;
		font-weight: 700;
	}

	/* ───────────────────────── the user card ───────────────────────── */
	.bal-user {
		box-sizing: border-box;
		position: relative;
		display: flex;
		flex-direction: column;
		border-radius: 11px;
		overflow: hidden;
		width: 100%;
		border: 1.5px solid #2563eb; /* blue-600 — the identity row, from L1 */
		background: color-mix(in srgb, #2563eb 7%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 10px rgba(37, 99, 235, 0.18);
		margin: 0;
	}
	.bal-user-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 6px 11px;
		margin: 0;
		border-bottom: 1px solid color-mix(in srgb, #2563eb 32%, transparent);
		background: color-mix(in srgb, #2563eb 12%, transparent);
	}
	.bal-user-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.9rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.bal-user-tag {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.bal-user-pill {
		align-self: center;
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		line-height: 1;
		padding: 3px 9px;
		margin: 0 0 9px;
		border-radius: 999px;
		color: #1d4ed8;
		background: color-mix(in srgb, #2563eb 13%, transparent);
		border: 1px dashed color-mix(in srgb, #2563eb 45%, transparent);
	}

	/* ───────────── connector stubs: each account stack → the user ───────────── */
	/* short CSS arrows (no LeaderLine) — direction only, always in empty gap. */
	.bal-link {
		position: relative;
		width: 26px;
		height: 2.5px;
		border-radius: 2px;
		background: color-mix(in srgb, #2563eb 55%, var(--sl-color-gray-4, #94a3b8));
		margin: 0;
	}
	.bal-link::after {
		content: '';
		position: absolute;
		top: 50%;
		width: 0;
		height: 0;
		border-top: 5px solid transparent;
		border-bottom: 5px solid transparent;
		transform: translateY(-50%);
	}
	/* before → user : arrowhead points RIGHT (into the user) */
	.bal-link--in::after {
		right: -1px;
		border-left: 8px solid color-mix(in srgb, #2563eb 55%, var(--sl-color-gray-4, #94a3b8));
	}
	/* after → user : arrowhead points LEFT (into the user) */
	.bal-link--out::after {
		left: -1px;
		border-right: 8px solid color-mix(in srgb, #2563eb 55%, var(--sl-color-gray-4, #94a3b8));
	}

	/* ── footers under each state ── */
	.bal-foot {
		font-size: 0.66rem;
		line-height: 1.35;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.bal-foot code {
		font-size: 0.92em;
		background: transparent;
		padding: 0;
	}

	/* ───────────────── narrow viewports: stack the three zones ───────────────── */
	/* Before → user → After, top to bottom; connectors rotate to point downward. */
	@media (max-width: 760px) {
		.bal {
			grid-template-columns: minmax(0, 22rem);
			justify-content: center;
			row-gap: 6px;
		}
		.bal-zone {
			width: 100%;
		}
		.bal-link {
			width: 2.5px;
			height: 20px;
		}
		.bal-link::after {
			top: auto;
			left: 50%;
			transform: translateX(-50%);
		}
		.bal-link--in::after {
			right: auto;
			bottom: -1px;
			border-left: 5px solid transparent;
			border-right: 5px solid transparent;
			border-top: 8px solid color-mix(in srgb, #2563eb 55%, var(--sl-color-gray-4, #94a3b8));
		}
		.bal-link--out::after {
			/* after sits BELOW the user when stacked → arrow points UP into the user */
			left: 50%;
			top: -1px;
			border-left: 5px solid transparent;
			border-right: 5px solid transparent;
			border-bottom: 8px solid color-mix(in srgb, #2563eb 55%, var(--sl-color-gray-4, #94a3b8));
		}
	}
</style>
