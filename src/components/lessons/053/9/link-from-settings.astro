---
// link-from-settings — Chapter 053 Lesson 9, "Account linking".
//
// The explicit / from-settings link path, held as one scrubbable sequence, and
// the deliberate MIRROR of this lesson's sibling figure link-on-sign-in. Same
// DiagramSequence + horizontal five-stage pipeline STRIP that only changes which
// node is LIT per step, same reserved FOCUS ZONE below it, same chapter palette —
// so the two figures read as a matched pair. The whole teaching point of the
// mirror lives in the TWO ENDS, which differ from the implicit path:
//
//   • Up front, the hinge is an ELEVATION CHECK (violet), not a trust check.
//     The implicit path asked "is the provider trusted?"; this path already
//     knows who is asking (she is signed in) and instead asks "is the session
//     fresh enough to change the account's security posture?" — re-proving the
//     password when the session is stale (`requires-re-authentication`).
//   • At the back, the inserted row attaches to THE SESSION'S user — there is no
//     find-or-create and no email match to vouch for. The session already
//     identifies her, so the new `account` row simply carries her existing
//     `userId`. The step-4 spotlight makes this literal: the session card feeds
//     its `userId` straight into the new google card, no email branch in sight.
//
// The OAuth round-trip in the middle (step 3) is the SAME machinery as sign-in —
// the parity with link-on-sign-in is the point, so step 3 stays a quiet orange
// node, not a spotlight.
//
// Like the sibling, two steps get a spotlight and the rest get a single quiet
// contextual line, and the zone RESERVES its full (tallest) height on every
// render via a stacked grid cell so the DiagramSequence stage sizes once at first
// paint and never reflows as the reader scrubs.
//
// Palette is the chapter's, verbatim from link-on-sign-in / oauth-callback-flow:
//   neutral — request plumbing / the unchanged session identity
//   orange  — library / callback / OAuth round-trip      (#ea580c)
//   violet  — the hinge: the elevation gate              (#7c3aed)
//   green   — session / success / the inserted row        (#16a34a)
// Mid-tone accents are reused as-is in both themes; neutral chrome rides
// Starlight gray/white vars so it flips light/dark. `not-content` (carried by
// DiagramSequence) opts the figure out of Starlight prose styling.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Tone = 'orange' | 'violet' | 'green';

// The five pipeline stages, left -> right. `label` is the short strip glyph
// (\n -> <br>); `tone` is the colour the node takes when it's the active (lit)
// stage. Captions live on each step below.
const STAGES: { label: string; tone: Tone }[] = [
	{ label: 'Click\n“Connect Google”', tone: 'orange' },
	{ label: 'Elevation\ncheck', tone: 'violet' },
	{ label: 'OAuth\nround-trip', tone: 'orange' },
	{ label: 'Insert\naccount row', tone: 'green' },
	{ label: 'Listed in\nsettings', tone: 'green' },
];

// The index of the elevation-check step (the hinge) and the insert step (the row
// appears) — the two steps whose focus zone is a spotlight, not a quiet line.
const ELEVATE_IDX = 1;
const INSERT_IDX = 3;

// The link call, kept as a string so the braces never have to be escaped in JSX.
const LINK_CALL = "authClient.linkSocial({ provider: 'google' })";

// The quiet contextual line shown in the focus zone on the non-spotlight steps,
// so the reserved box never reads empty. Keyed by stage index.
const ZONE_HINTS: Record<number, string> = {
	0: 'Ada is already signed in. From /settings/security/accounts she chooses to add Google — deliberate intent, not a sign-in.',
	2: 'Redirect → Google consent screen → callback. The exact same OAuth machinery as sign-in; only the two ends of this path differ.',
	4: 'Google now appears in her list of sign-in methods. She has two ways in — and a notification email confirms the new one.',
};
---

<DiagramSequence>
	{
		STAGES.map((_, active) => {
			const isElevate = active === ELEVATE_IDX;
			const isInsert = active === INSERT_IDX;
			return (
				<DiagramStep>
					<div class="ls" data-tone={STAGES[active].tone}>
						{/* ── the five-stage pipeline strip ── */}
						<div class="ls-strip">
							{STAGES.map((stage, i) => (
								<Fragment>
									{i > 0 && <span class="ls-arrow" aria-hidden="true">→</span>}
									<div
										class="ls-stage"
										data-state={i < active ? 'done' : i === active ? 'on' : 'todo'}
										data-tone={stage.tone}
									>
										<span class="ls-num">{i + 1}</span>
										<span class="ls-label">
											{stage.label.split('\n').map((line, k) => (
												<>
													{k > 0 && <br />}
													{line}
												</>
											))}
										</span>
									</div>
								</Fragment>
							))}
						</div>

						{/* ── the focus zone: reserved every step, spotlights the two
						     load-bearing moments. All three layers always occupy the same
						     grid cell; only visibility flips, so the stage height is the
						     tallest (the insert cards) on every step and never reflows. */}
						<div
							class="ls-zone"
							data-spotlight={isElevate ? 'elevate' : isInsert ? 'insert' : undefined}
						>
							{/* the ELEVATION-CHECK spotlight (step 2, violet) */}
							<div class="ls-elevate" aria-hidden={isElevate ? undefined : 'true'}>
								<span class="ls-elevate-q">
									is the session <code>fresh</code> enough?
									<span class="ls-elevate-yes">fresh → link</span>
								</span>
								<span class="ls-elevate-not">
									stale → <code>requires-re-authentication</code> — re-prove the
									password, <em>then</em> attach a new way in. No find-or-create:
									the session already says who she is.
								</span>
							</div>

							{/* the INSERTED ROW spotlight (step 4, green): the session feeds
							    its userId straight into the new google account row. */}
							<div class="ls-rows" aria-hidden={isInsert ? undefined : 'true'}>
								<div class="ls-card ls-card--session">
									<div class="ls-card-head">
										<code class="ls-card-name">session</code>
										<span class="ls-card-tag">already signed in</span>
									</div>
									<div class="ls-card-body">
										<span class="ls-field ls-field--link">
											<span class="ls-key">userId</span>
											<span class="ls-val">usr_a1</span>
										</span>
									</div>
								</div>

								<span class="ls-rows-arrow" aria-hidden="true">→</span>

								<div class="ls-card ls-card--violet">
									<div class="ls-card-head">
										<code class="ls-card-name">account</code>
										<span class="ls-card-badge">+ new</span>
									</div>
									<div class="ls-card-body">
										<span class="ls-field">
											<span class="ls-key">providerId</span>
											<span class="ls-val">'google'</span>
										</span>
										<span class="ls-field ls-field--link">
											<span class="ls-key">userId</span>
											<span class="ls-val">usr_a1</span>
										</span>
									</div>
								</div>
							</div>

							{/* the quiet single line for the non-spotlight steps */}
							<p class="ls-hint" aria-hidden={isElevate || isInsert ? 'true' : undefined}>
								{ZONE_HINTS[active]}
							</p>
						</div>
					</div>

					{/* Per-step caption — the "what happens here" sentence. */}
					<Fragment slot="caption">
						{active === 0 && (
							<>
								<strong>Click.</strong> A <strong>signed-in</strong> Ada is on{' '}
								<code>/settings/security/accounts</code>, looking at her sign-in
								methods, and clicks <strong>Connect Google</strong>. The client
								calls <code>{LINK_CALL}</code>. Intent is explicit — she asked for
								this.
							</>
						)}
						{active === 1 && (
							<>
								<strong>The hinge — elevation check.</strong> Attaching a new
								sign-in method changes the account's security posture, so it sits
								behind <strong>elevation</strong>: the session must have proven a
								credential <em>recently</em>. A stale or borrowed session is sent to
								re-prove the password first. This is the mirror of the implicit
								path's hinge — there it was <em>“is the provider trusted?”</em>;
								here it is <em>“is the session fresh?”</em>.
							</>
						)}
						{active === 2 && (
							<>
								<strong>OAuth round-trip.</strong> Redirect to Google, the consent
								screen, the callback — the <strong>same machinery</strong> as a
								normal sign-in. Nothing new in the middle of this path; the whole
								difference lives at its two ends.
							</>
						)}
						{active === 3 && (
							<>
								<strong>Insert.</strong> Because she is already signed in, the
								callback skips find-or-create entirely — it attaches the new{' '}
								<code>account</code> row to <strong>the session's</strong>{' '}
								<code>user</code>. No email branch, <strong>no email match to
								trust</strong>; the session already settled whose account this is.
							</>
						)}
						{active === 4 && (
							<>
								<strong>Listed.</strong> Back on the settings page, Google now
								appears among her sign-in methods. Compared with the implicit path:{' '}
								<strong>intent and consent up front</strong>, and the row attaches to
								the session's user — so there's no find-or-create and no email match
								to trust.
							</>
						)}
					</Fragment>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>

<style>
	.ls {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
		padding: 4px 2px 2px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── the pipeline strip ───────────────────────────────────────── */
	.ls-strip {
		--ls-on: var(--sl-color-gray-3, #64748b);
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 4px;
		margin: 0;
	}
	/* the strip's accent follows the active stage's tone */
	.ls[data-tone='orange'] .ls-strip {
		--ls-on: #ea580c;
	}
	.ls[data-tone='violet'] .ls-strip {
		--ls-on: #7c3aed;
	}
	.ls[data-tone='green'] .ls-strip {
		--ls-on: #16a34a;
	}

	.ls-stage {
		position: relative;
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 5px;
		padding: 8px 4px 7px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			opacity 0.16s,
			transform 0.16s;
	}

	.ls-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		flex: 0 0 auto;
		border-radius: 50%;
		font-size: 0.64rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		transition:
			color 0.16s,
			background-color 0.16s;
	}
	.ls-label {
		font-size: 0.7rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-2, #475569);
		overflow-wrap: anywhere;
		transition: color 0.16s;
	}

	/* the thin connector between stages */
	.ls-arrow {
		flex: 0 0 auto;
		align-self: center;
		font-size: 0.8rem;
		line-height: 1;
		color: var(--sl-color-gray-4, #94a3b8);
	}

	/* not yet reached */
	.ls-stage[data-state='todo'] {
		opacity: 0.5;
	}

	/* already passed: a muted tint in that stage's own tone */
	.ls-stage[data-state='done'][data-tone='orange'] {
		border-color: color-mix(in srgb, #ea580c 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.ls-stage[data-state='done'][data-tone='violet'] {
		border-color: color-mix(in srgb, #7c3aed 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.ls-stage[data-state='done'][data-tone='green'] {
		border-color: color-mix(in srgb, #16a34a 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.ls-stage[data-state='done'] .ls-num {
		color: #fff;
		background: var(--sl-color-gray-4, #94a3b8);
	}
	.ls-stage[data-state='done'][data-tone='orange'] .ls-num {
		background: color-mix(in srgb, #ea580c 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.ls-stage[data-state='done'][data-tone='violet'] .ls-num {
		background: color-mix(in srgb, #7c3aed 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.ls-stage[data-state='done'][data-tone='green'] .ls-num {
		background: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-4, #94a3b8));
	}

	/* the lit stage: full tone, lifted */
	.ls-stage[data-state='on'] {
		border-color: var(--ls-on);
		border-width: 1.5px;
		background: color-mix(in srgb, var(--ls-on) 10%, var(--sl-color-bg, transparent));
		transform: translateY(-2px);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--ls-on) 22%, transparent);
	}
	.ls-stage[data-state='on'] .ls-num {
		color: #fff;
		background: var(--ls-on);
	}
	.ls-stage[data-state='on'] .ls-label {
		color: var(--sl-color-white, #1e293b);
	}

	/* ── the focus zone: the three layers stacked in one grid cell, so the box is
	      always the height of the tallest (the insert cards) and never reflows ── */
	.ls-zone {
		display: grid;
		margin: 0;
		padding: 10px 8px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		transition:
			border-color 0.18s,
			background-color 0.18s;
	}
	/* at the elevation hinge the zone reads violet */
	.ls-zone[data-spotlight='elevate'] {
		border-style: solid;
		border-color: color-mix(in srgb, #7c3aed 40%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #7c3aed 6%, var(--sl-color-bg, transparent));
	}
	/* at the insert step the zone reads green — a new row was written */
	.ls-zone[data-spotlight='insert'] {
		border-style: solid;
		border-color: color-mix(in srgb, #16a34a 40%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #16a34a 6%, var(--sl-color-bg, transparent));
	}
	/* all three children share the one grid cell; inactive ones stay in layout */
	.ls-elevate,
	.ls-rows,
	.ls-hint {
		grid-area: 1 / 1;
	}

	/* ── the elevation-check spotlight ── */
	.ls-elevate {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 8px;
		visibility: hidden;
		text-align: center;
	}
	.ls-zone[data-spotlight='elevate'] .ls-elevate {
		visibility: visible;
	}
	.ls-elevate-q {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
	}
	.ls-elevate-q code {
		font-size: 0.86em;
		font-weight: 700;
		color: #6d28d9;
		background: color-mix(in srgb, #7c3aed 12%, transparent);
		padding: 1px 5px;
		border-radius: 5px;
	}
	.ls-elevate-yes {
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #fff;
		background: #7c3aed;
		padding: 3px 9px;
		border-radius: 999px;
		white-space: nowrap;
	}
	.ls-elevate-not {
		font-size: 0.72rem;
		font-weight: 500;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
		max-width: 32rem;
	}
	.ls-elevate-not code {
		font-size: 0.92em;
		font-weight: 700;
		color: #6d28d9;
		background: color-mix(in srgb, #7c3aed 12%, transparent);
		padding: 1px 4px;
		border-radius: 4px;
	}
	.ls-elevate-not em {
		font-style: normal;
		font-weight: 800;
		color: #6d28d9;
	}

	/* ── the inserted-row spotlight: session card → new google card ── */
	.ls-rows {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		visibility: hidden;
	}
	.ls-zone[data-spotlight='insert'] .ls-rows {
		visibility: visible;
	}
	.ls-rows-arrow {
		flex: 0 0 auto;
		font-size: 1.15rem;
		font-weight: 800;
		line-height: 1;
		color: #16a34a;
	}

	.ls-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		border-radius: 10px;
		overflow: hidden;
		min-width: 0;
		flex: 0 1 13rem;
		margin: 0;
	}
	/* neutral-blue — the session that already identifies her (carries the userId) */
	.ls-card--session {
		flex-basis: 11rem;
		border: 1.5px solid #2563eb;
		background: color-mix(in srgb, #2563eb 7%, var(--sl-color-bg, transparent));
	}
	/* violet — the NEW google row: the hinge made literal */
	.ls-card--violet {
		border: 1.5px solid #7c3aed;
		background: color-mix(in srgb, #7c3aed 8%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 10px rgba(124, 58, 237, 0.22);
	}

	.ls-card-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 5px 10px;
		margin: 0;
	}
	.ls-card--session .ls-card-head {
		border-bottom: 1px solid color-mix(in srgb, #2563eb 32%, transparent);
		background: color-mix(in srgb, #2563eb 12%, transparent);
	}
	.ls-card--violet .ls-card-head {
		border-bottom: 1px solid color-mix(in srgb, #7c3aed 35%, transparent);
		background: color-mix(in srgb, #7c3aed 13%, transparent);
	}
	.ls-card-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.ls-card-tag {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.ls-card-badge {
		font-size: 0.58rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1;
		white-space: nowrap;
		padding: 3px 7px;
		border-radius: 999px;
		color: #fff;
		background: #7c3aed;
		margin: 0;
	}

	.ls-card-body {
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 7px 10px;
		margin: 0;
	}
	.ls-field {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.7rem;
		line-height: 1.3;
		margin: 0;
	}
	.ls-key {
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.ls-val {
		color: var(--sl-color-white, #1e293b);
		text-align: right;
		white-space: nowrap;
		margin: 0;
	}
	/* the shared userId — emphasised so the join reads; blue, matching the user */
	.ls-field--link {
		border-radius: 5px;
		padding: 1px 5px;
		margin: 0 -5px;
		background: color-mix(in srgb, #2563eb 10%, transparent);
	}
	.ls-field--link .ls-key,
	.ls-field--link .ls-val {
		color: #1d4ed8;
		font-weight: 700;
	}

	/* ── the quiet hint line for the non-spotlight steps ── */
	.ls-hint {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		padding: 0 6px;
		font-size: 0.74rem;
		font-weight: 500;
		line-height: 1.45;
		text-align: center;
		color: var(--sl-color-gray-3, #64748b);
	}
	.ls-zone[data-spotlight] .ls-hint {
		visibility: hidden;
	}

	/* ── narrow viewports: wrap the strip into compact left-aligned chips; stack
	      the session/account cards over the arrow. ── */
	@media (max-width: 600px) {
		.ls-stage {
			flex: 1 1 40%;
			min-width: 0;
			flex-direction: row;
			justify-content: flex-start;
			gap: 6px;
			padding: 6px 8px;
			text-align: left;
		}
		.ls-arrow {
			display: none;
		}
		.ls-rows {
			flex-direction: column;
			gap: 6px;
		}
		.ls-rows-arrow {
			transform: rotate(90deg);
		}
		.ls-card {
			flex: 1 1 auto;
			width: 100%;
			max-width: 18rem;
		}
	}
</style>
