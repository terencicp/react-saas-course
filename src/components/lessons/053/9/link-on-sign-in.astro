---
// link-on-sign-in — Chapter 053 Lesson 9, "Account linking".
//
// The implicit / on-sign-in link path, held as one scrubbable sequence. This is
// deliberately the CONTINUATION of L8's oauth-callback-flow figure: same
// DiagramSequence + horizontal pipeline STRIP that only changes which node is
// LIT per step. Where L8's figure fanned the find-or-create lookup into four
// landing states, this figure zooms into the ONE landing state L8 left
// unconfigured — the `link` branch — and walks it end to end. The connective
// tissue is intentional: "this is the node L8 refused with account-not-linked,
// now that a trusted provider is configured."
//
// Two moments in this path are load-bearing and the prose insists they be
// visually unmistakable, so the strip gets a reserved FOCUS ZONE below it that
// spotlights a different thing per step:
//
//   • Step 3 — the TRUST CHECK (the violet hinge). The zone shows the question
//     the library actually asks — "is google in trustedProviders?" — with a
//     struck-through "email_verified?" beside it, because the whole takeover
//     risk hinges on this NOT being an email-verified check. Being on the list
//     IS the trust; there is no email_verified backstop.
//   • Step 4 — the INSERTED ROW (green). The zone renders the schema row-cards
//     from this lesson's sibling figure (accounts-before-after-link): the
//     unchanged neutral `credential` card, and the NEW violet `google` card
//     slotting in beside it — both carrying the SAME `userId: usr_a1`. This is
//     "linking = one more row against the same user" made literal, in motion.
//
// On every other step the zone holds a single quiet contextual line. The zone
// RESERVES its full (tallest: the step-4 row-cards) height on every render via a
// stacked grid cell, so the DiagramSequence stage sizes once at first paint and
// never reflows as the reader scrubs — the same discipline as L8 and the other
// sibling flow figures.
//
// Palette is the chapter's, verbatim from oauth-callback-flow:
//   neutral — request plumbing / the unchanged credential row
//   orange  — library / callback work                (#ea580c)
//   violet  — the hinge: the trust check + new row    (#7c3aed)
//   green   — session / success / the inserted row    (#16a34a)
// Mid-tone accents are reused as-is in both themes; neutral chrome rides
// Starlight gray/white vars so it flips light/dark. `not-content` (carried by
// DiagramSequence) opts the figure out of Starlight prose styling.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Tone = 'orange' | 'violet' | 'green';

// The five pipeline stages, left -> right. `label` is the short strip glyph
// (\n -> <br>); `tone` is the colour the node takes when it's the active (lit)
// stage. Captions live on each step below.
const STAGES: { label: string; tone: Tone }[] = [
	{ label: 'Click\n“Sign in with Google”', tone: 'orange' },
	{ label: 'Callback\nfind-or-create', tone: 'orange' },
	{ label: 'Trust\ncheck', tone: 'violet' },
	{ label: 'Insert\naccount row', tone: 'green' },
	{ label: 'Signed in\n+ notified', tone: 'green' },
];

// The index of the trust-check step (the hinge) and the insert step (the row
// appears) — the two steps whose focus zone is a spotlight, not a quiet line.
const TRUST_IDX = 2;
const INSERT_IDX = 3;

// The quiet contextual line shown in the focus zone on the non-spotlight steps,
// so the reserved box never reads empty. Keyed by stage index.
const ZONE_HINTS: Record<number, string> = {
	0: 'She is an existing credential user — ada@acme.com, signed up with a password back in January.',
	1: 'No (google, accountId) row exists yet, so the lookup falls to the email branch and finds her existing user.',
	4: 'One Google click — no separate “connect your account?” step ever appeared.',
};

// The two account row-cards rendered in the focus zone at the insert step.
// Mirrors the sibling figure's vocabulary: the unchanged neutral `credential`
// card and the NEW violet `google` card, both pointing at the same `userId`.
interface Field {
	key: string;
	val: string;
	link?: boolean;
}
const credentialFields: Field[] = [
	{ key: 'providerId', val: "'credential'" },
	{ key: 'userId', val: 'usr_a1', link: true },
];
const googleFields: Field[] = [
	{ key: 'providerId', val: "'google'" },
	{ key: 'userId', val: 'usr_a1', link: true },
];
---

<DiagramSequence>
	{
		STAGES.map((_, active) => {
			const isTrust = active === TRUST_IDX;
			const isInsert = active === INSERT_IDX;
			return (
				<DiagramStep>
					<div class="li" data-tone={STAGES[active].tone}>
						{/* ── the five-stage pipeline strip ── */}
						<div class="li-strip">
							{STAGES.map((stage, i) => (
								<Fragment>
									{i > 0 && <span class="li-arrow" aria-hidden="true">→</span>}
									<div
										class="li-stage"
										data-state={i < active ? 'done' : i === active ? 'on' : 'todo'}
										data-tone={stage.tone}
									>
										<span class="li-num">{i + 1}</span>
										<span class="li-label">
											{stage.label.split('\n').map((line, k) => (
												<>
													{k > 0 && <br />}
													{line}
												</>
											))}
										</span>
									</div>
								</Fragment>
							))}
						</div>

						{/* ── the focus zone: reserved every step, spotlights the two
						     load-bearing moments. All three layers always occupy the same
						     grid cell; only visibility flips, so the stage height is the
						     tallest (the insert row-cards) on every step and never reflows. */}
						<div
							class="li-zone"
							data-spotlight={isTrust ? 'trust' : isInsert ? 'insert' : undefined}
						>
							{/* the TRUST CHECK spotlight (step 3, violet) */}
							<div class="li-trust" aria-hidden={isTrust ? undefined : 'true'}>
								<span class="li-trust-q">
									is <code>google</code> in <code>trustedProviders</code>?
									<span class="li-trust-yes">yes → link</span>
								</span>
								<span class="li-trust-not">
									not <s>is the email <code>email_verified</code>?</s> — being on
									the list <em>is</em> the trust
								</span>
							</div>

							{/* the INSERTED ROW spotlight (step 4, green): the schema row-cards */}
							<div class="li-rows" aria-hidden={isInsert ? undefined : 'true'}>
								<div class="li-acct li-acct--neutral">
									<div class="li-acct-head">
										<code class="li-acct-name">account</code>
										<span class="li-acct-tag">credential</span>
									</div>
									<div class="li-acct-body">
										{credentialFields.map((f) => (
											<span class={`li-field${f.link ? ' li-field--link' : ''}`}>
												<span class="li-key">{f.key}</span>
												<span class="li-val">{f.val}</span>
											</span>
										))}
									</div>
								</div>

								<span class="li-rows-plus" aria-hidden="true">+</span>

								<div class="li-acct li-acct--violet">
									<div class="li-acct-head">
										<code class="li-acct-name">account</code>
										<span class="li-acct-badge">+ new</span>
									</div>
									<div class="li-acct-body">
										{googleFields.map((f) => (
											<span class={`li-field${f.link ? ' li-field--link' : ''}`}>
												<span class="li-key">{f.key}</span>
												<span class="li-val">{f.val}</span>
											</span>
										))}
									</div>
								</div>
							</div>

							{/* the quiet single line for the non-spotlight steps */}
							<p class="li-hint" aria-hidden={isTrust || isInsert ? 'true' : undefined}>
								{ZONE_HINTS[active]}
							</p>
						</div>
					</div>

					{/* Per-step caption — the "what happens here" sentence. */}
					<Fragment slot="caption">
						{active === 0 && (
							<>
								<strong>Click.</strong> Ada, an existing{' '}
								<code>credential</code> user at <code>ada@acme.com</code>, clicks{' '}
								<strong>Sign in with Google</strong> — same email her Google account
								uses. The same OAuth round-trip as a normal sign-in begins.
							</>
						)}
						{active === 1 && (
							<>
								<strong>Find-or-create.</strong> The callback runs the lookup from the
								last lesson. There's no <code>(google, accountId)</code> row yet, so it
								falls to the <strong>email branch</strong> and finds her existing{' '}
								<code>user</code>.
							</>
						)}
						{active === 2 && (
							<>
								<strong>The hinge — trust check.</strong> The question is{' '}
								<em>“is the provider trusted?”</em>, <strong>not</strong>{' '}
								<em>“is the email verified?”</em>. <code>google</code> is on{' '}
								<code>trustedProviders</code>, so it links. This is the exact node the
								last lesson <strong>refused</strong> with <code>account-not-linked</code>{' '}
								when the list was empty.
							</>
						)}
						{active === 3 && (
							<>
								<strong>Insert.</strong> A second <code>account</code> row appears —{' '}
								<code>providerId: 'google'</code> — against the <strong>same</strong>{' '}
								<code>userId</code>. The <code>user</code> row is untouched; she now has
								two ways in, one human.
							</>
						)}
						{active === 4 && (
							<>
								<strong>Signed in.</strong> Ada lands signed in to her original account,
								and a <strong>“new sign-in method added”</strong> notification email
								fires from the same <code>databaseHooks</code> seam as the welcome
								email. This is the <code>link</code> branch of the last lesson's lookup —
								the node that refused, now that a trusted provider is configured.
							</>
						)}
					</Fragment>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>

<style>
	.li {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
		padding: 4px 2px 2px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── the pipeline strip ───────────────────────────────────────── */
	.li-strip {
		--li-on: var(--sl-color-gray-3, #64748b);
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 4px;
		margin: 0;
	}
	/* the strip's accent follows the active stage's tone */
	.li[data-tone='orange'] .li-strip {
		--li-on: #ea580c;
	}
	.li[data-tone='violet'] .li-strip {
		--li-on: #7c3aed;
	}
	.li[data-tone='green'] .li-strip {
		--li-on: #16a34a;
	}

	.li-stage {
		position: relative;
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 5px;
		padding: 8px 4px 7px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			opacity 0.16s,
			transform 0.16s;
	}

	.li-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		flex: 0 0 auto;
		border-radius: 50%;
		font-size: 0.64rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		transition:
			color 0.16s,
			background-color 0.16s;
	}
	.li-label {
		font-size: 0.7rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-2, #475569);
		overflow-wrap: anywhere;
		transition: color 0.16s;
	}

	/* the thin connector between stages */
	.li-arrow {
		flex: 0 0 auto;
		align-self: center;
		font-size: 0.8rem;
		line-height: 1;
		color: var(--sl-color-gray-4, #94a3b8);
	}

	/* not yet reached */
	.li-stage[data-state='todo'] {
		opacity: 0.5;
	}

	/* already passed: a muted tint in that stage's own tone */
	.li-stage[data-state='done'][data-tone='orange'] {
		border-color: color-mix(in srgb, #ea580c 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.li-stage[data-state='done'][data-tone='violet'] {
		border-color: color-mix(in srgb, #7c3aed 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.li-stage[data-state='done'][data-tone='green'] {
		border-color: color-mix(in srgb, #16a34a 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.li-stage[data-state='done'] .li-num {
		color: #fff;
		background: var(--sl-color-gray-4, #94a3b8);
	}
	.li-stage[data-state='done'][data-tone='orange'] .li-num {
		background: color-mix(in srgb, #ea580c 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.li-stage[data-state='done'][data-tone='violet'] .li-num {
		background: color-mix(in srgb, #7c3aed 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.li-stage[data-state='done'][data-tone='green'] .li-num {
		background: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-4, #94a3b8));
	}

	/* the lit stage: full tone, lifted */
	.li-stage[data-state='on'] {
		border-color: var(--li-on);
		border-width: 1.5px;
		background: color-mix(in srgb, var(--li-on) 10%, var(--sl-color-bg, transparent));
		transform: translateY(-2px);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--li-on) 22%, transparent);
	}
	.li-stage[data-state='on'] .li-num {
		color: #fff;
		background: var(--li-on);
	}
	.li-stage[data-state='on'] .li-label {
		color: var(--sl-color-white, #1e293b);
	}

	/* ── the focus zone: the three layers stacked in one grid cell, so the box is
	      always the height of the tallest (the insert row-cards) and never reflows ── */
	.li-zone {
		display: grid;
		margin: 0;
		padding: 10px 8px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		transition:
			border-color 0.18s,
			background-color 0.18s;
	}
	/* at the trust hinge the zone reads violet */
	.li-zone[data-spotlight='trust'] {
		border-style: solid;
		border-color: color-mix(in srgb, #7c3aed 40%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #7c3aed 6%, var(--sl-color-bg, transparent));
	}
	/* at the insert step the zone reads green — a new row was written */
	.li-zone[data-spotlight='insert'] {
		border-style: solid;
		border-color: color-mix(in srgb, #16a34a 40%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #16a34a 6%, var(--sl-color-bg, transparent));
	}
	/* all three children share the one grid cell; inactive ones stay in layout */
	.li-trust,
	.li-rows,
	.li-hint {
		grid-area: 1 / 1;
	}

	/* ── the trust-check spotlight ── */
	.li-trust {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 8px;
		visibility: hidden;
		text-align: center;
	}
	.li-zone[data-spotlight='trust'] .li-trust {
		visibility: visible;
	}
	.li-trust-q {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
	}
	.li-trust-q code {
		font-size: 0.86em;
		font-weight: 700;
		color: #6d28d9;
		background: color-mix(in srgb, #7c3aed 12%, transparent);
		padding: 1px 5px;
		border-radius: 5px;
	}
	.li-trust-yes {
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #fff;
		background: #7c3aed;
		padding: 3px 9px;
		border-radius: 999px;
		white-space: nowrap;
	}
	.li-trust-not {
		font-size: 0.72rem;
		font-weight: 500;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
		max-width: 30rem;
	}
	.li-trust-not s {
		color: var(--sl-color-gray-3, #64748b);
		text-decoration-thickness: 1.5px;
	}
	.li-trust-not code {
		font-size: 0.92em;
		background: transparent;
		padding: 0;
	}
	.li-trust-not em {
		font-style: normal;
		font-weight: 800;
		color: #6d28d9;
	}

	/* ── the inserted-row spotlight: two account cards + a plus ── */
	.li-rows {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		visibility: hidden;
	}
	.li-zone[data-spotlight='insert'] .li-rows {
		visibility: visible;
	}
	.li-rows-plus {
		flex: 0 0 auto;
		font-size: 1.1rem;
		font-weight: 800;
		line-height: 1;
		color: #16a34a;
	}

	.li-acct {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		border-radius: 10px;
		overflow: hidden;
		min-width: 0;
		flex: 0 1 13rem;
		margin: 0;
	}
	/* neutral — the unchanged credential row */
	.li-acct--neutral {
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 18%, var(--sl-color-bg, transparent));
	}
	/* violet — the NEW google row: the hinge made literal */
	.li-acct--violet {
		border: 1.5px solid #7c3aed;
		background: color-mix(in srgb, #7c3aed 8%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 10px rgba(124, 58, 237, 0.22);
	}

	.li-acct-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 5px 10px;
		margin: 0;
	}
	.li-acct--neutral .li-acct-head {
		border-bottom: 1px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-4, #94a3b8) 13%, transparent);
	}
	.li-acct--violet .li-acct-head {
		border-bottom: 1px solid color-mix(in srgb, #7c3aed 35%, transparent);
		background: color-mix(in srgb, #7c3aed 13%, transparent);
	}
	.li-acct-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.li-acct-tag {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.li-acct-badge {
		font-size: 0.58rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1;
		white-space: nowrap;
		padding: 3px 7px;
		border-radius: 999px;
		color: #fff;
		background: #7c3aed;
		margin: 0;
	}

	.li-acct-body {
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 7px 10px;
		margin: 0;
	}
	.li-field {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.7rem;
		line-height: 1.3;
		margin: 0;
	}
	.li-key {
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.li-val {
		color: var(--sl-color-white, #1e293b);
		text-align: right;
		white-space: nowrap;
		margin: 0;
	}
	/* the shared userId — emphasised so the join reads; blue, matching the user */
	.li-field--link {
		border-radius: 5px;
		padding: 1px 5px;
		margin: 0 -5px;
		background: color-mix(in srgb, #2563eb 10%, transparent);
	}
	.li-field--link .li-key,
	.li-field--link .li-val {
		color: #1d4ed8;
		font-weight: 700;
	}

	/* ── the quiet hint line for the non-spotlight steps ── */
	.li-hint {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		padding: 0 6px;
		font-size: 0.74rem;
		font-weight: 500;
		line-height: 1.45;
		text-align: center;
		color: var(--sl-color-gray-3, #64748b);
	}
	.li-zone[data-spotlight] .li-hint {
		visibility: hidden;
	}

	/* ── narrow viewports: wrap the strip into compact left-aligned chips; stack
	      the two account cards over the plus. ── */
	@media (max-width: 600px) {
		.li-stage {
			flex: 1 1 40%;
			min-width: 0;
			flex-direction: row;
			justify-content: flex-start;
			gap: 6px;
			padding: 6px 8px;
			text-align: left;
		}
		.li-arrow {
			display: none;
		}
		.li-rows {
			flex-direction: column;
			gap: 6px;
		}
		.li-acct {
			flex: 1 1 auto;
			width: 100%;
			max-width: 18rem;
		}
	}
</style>
