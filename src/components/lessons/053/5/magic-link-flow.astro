---
// magic-link-flow — Chapter 053 Lesson 5, "Magic links".
//
// The lesson's named, load-bearing visual: the whole passwordless sign-in held as
// one scrubbable sequence. It is the L5 counterpart to the sibling flow figures
// (signup-flow-strip / signin-flow-strip / verify-flow / reset-flow), but it
// deliberately swaps idiom. Those drew a flat VERB strip (Submit -> Mint -> ...);
// this one draws an ACTOR-LANE view — four fixed lanes (Browser · Better Auth ·
// DB · Inbox) with one directed hop lit per step — because the single point this
// lesson exists to make is STRUCTURAL: *where the session is issued*. A magic link
// issues it a full inbox round-trip after submit (at the click), not the instant
// the form is sent the way password sign-in does. An actor view makes that
// round-trip, and the idle Inbox lane that the request has to travel out to and
// come back from, visible in a way a flat strip cannot.
//
// Composition (plain HTML + CSS — the actor-lane shape the diagrams index routes
// to HTML+CSS): a 4-column grid of actor lanes across the top; the active actor(s)
// for the step light in the step's tone, idle lanes stay muted. Beneath the lanes,
// ONE directed "hop" band per step spans exactly from its source lane to its
// target lane via `grid-column: start / end` — CSS grid does all the positioning
// math, so there is no hand-placed arrow geometry to drift (the failure mode the
// diagrams index warns about). The arrowhead sits at the destination end (dir
// flips it for the leftward redirect hop). A status line under the rail is
// RESERVED on every render and flips from "not authenticated yet" to "signed in"
// exactly at the verify step — the climax, made persistent, so the reader can read
// off the one fact the lesson is about: the click is the moment of auth.
//
// Palette is the chapter's, verbatim from the sibling figures:
//   neutral — request plumbing (idle lanes, the rail)
//   blue    — parse / config / the submit call        (#2563eb)
//   orange  — library / endpoint work                 (#ea580c)
//   green    — session / success                       (#16a34a)
// (violet/red, the hinge/insecure tones, don't appear in this happy path.)
//
// Built as a thin wrapper composing <DiagramSequence> + <DiagramStep> from a step
// array so the five near-identical frames aren't hand-repeated: every step renders
// the SAME four lanes + rail and only the lit actors / hop / status change. The
// geometry is identical every frame (the rail and status row reserve their height
// always), so the DiagramSequence stage sizes once at first paint and never
// reflows as the reader scrubs — same discipline as verify-flow / reset-flow.
// Mid-tone accents are reused as-is in both themes; neutral chrome rides Starlight
// gray/white vars so it flips light/dark. `not-content` (carried by
// DiagramSequence) opts the figure out of Starlight prose styling.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Tone = 'blue' | 'orange' | 'green';
type ActorId = 'browser' | 'auth' | 'db' | 'inbox';

// The four fixed lanes, left -> right. `col` is the 1-based grid column the lane
// occupies, reused to place the hop band that spans between two lanes.
const ACTORS: { id: ActorId; label: string; sub: string; col: number }[] = [
	{ id: 'browser', label: 'Browser', sub: 'the user', col: 1 },
	{ id: 'auth', label: 'Better Auth', sub: '[...all] route', col: 2 },
	{ id: 'db', label: 'DB', sub: 'verification row', col: 3 },
	{ id: 'inbox', label: 'Inbox', sub: 'the credential', col: 4 },
];

// Each step lights one or two actors, draws ONE hop (from -> to lanes), and sets
// whether the user is authenticated yet. `click` flags the Inbox lane with the
// tap cue on the deliver step.
type Step = {
	tone: Tone;
	/** actors lit this step */
	on: ActorId[];
	/** the directed hop: source + target lane ids and its label */
	hop: { from: ActorId; to: ActorId; label: string };
	/** show the "tap" cue on the inbox lane */
	click?: boolean;
	/** the user holds a session from this step on */
	authed: boolean;
};

const STEPS: Step[] = [
	{
		tone: 'blue',
		on: ['browser', 'auth'],
		hop: { from: 'browser', to: 'auth', label: 'signIn.magicLink({ email })' },
		authed: false,
	},
	{
		tone: 'orange',
		on: ['auth', 'db'],
		hop: { from: 'auth', to: 'db', label: 'write magic-link:<email>' },
		authed: false,
	},
	{
		tone: 'orange',
		on: ['auth', 'inbox'],
		hop: { from: 'auth', to: 'inbox', label: 'sendMagicLink → click' },
		click: true,
		authed: false,
	},
	{
		tone: 'green',
		on: ['auth', 'db'],
		hop: { from: 'auth', to: 'db', label: 'consume token · issue session' },
		authed: true,
	},
	{
		tone: 'green',
		on: ['browser', 'auth'],
		hop: { from: 'auth', to: 'browser', label: 'redirect → /dashboard' },
		authed: true,
	},
];

const colOf = (id: ActorId) => ACTORS.find((a) => a.id === id)!.col;

// Inline single-stroke icons per lane (currentColor so they take the lane's ink /
// lit accent). Kept minimal — a glyph, not detailed art — to stay lightweight.
const ICONS: Record<ActorId, string> = {
	// monitor — the browser
	browser:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="3.5" width="19" height="13" rx="2"/><path d="M8.5 20.5h7M12 16.5v4"/></svg>',
	// shield — Better Auth (the [...all] route)
	auth: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5 4.5 5.5v6c0 4.5 3.2 7.6 7.5 9 4.3-1.4 7.5-4.5 7.5-9v-6L12 2.5Z"/></svg>',
	// stacked disks — the database
	db: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5.5" rx="7.5" ry="3"/><path d="M4.5 5.5v13c0 1.66 3.36 3 7.5 3s7.5-1.34 7.5-3v-13M4.5 12c0 1.66 3.36 3 7.5 3s7.5-1.34 7.5-3"/></svg>',
	// envelope — the inbox
	inbox:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="4.5" width="19" height="15" rx="2"/><path d="m3 6 9 6 9-6"/></svg>',
};
---

<DiagramSequence>
	{
		STEPS.map((step) => {
			const fromCol = colOf(step.hop.from);
			const toCol = colOf(step.hop.to);
			// the band spans the lanes it connects, inclusive; grid handles the math
			const start = Math.min(fromCol, toCol);
			const end = Math.max(fromCol, toCol) + 1;
			// arrowhead sits at the destination: right end if the hop runs rightward,
			// left end if it runs leftward (the redirect back to the browser)
			const dir = toCol > fromCol ? 'ltr' : 'rtl';
			return (
				<DiagramStep>
					<div class="ml" data-tone={step.tone}>
						{/* ── the four actor lanes ── */}
						<div class="ml-lanes">
							{ACTORS.map((a) => (
								<div
									class="ml-lane"
									data-on={step.on.includes(a.id) ? '' : undefined}
									style={`grid-column:${a.col}`}
								>
									<span class="ml-ic" aria-hidden="true" set:html={ICONS[a.id]} />
									<span class="ml-name">{a.label}</span>
									<span class="ml-sub">{a.sub}</span>
									{a.id === 'inbox' && step.click && (
										<span class="ml-tap">tap</span>
									)}
								</div>
							))}

							{/* ── the single directed hop, spanning source → target lanes ── */}
							<div
								class="ml-hop"
								data-dir={dir}
								style={`grid-column:${start} / ${end}`}
							>
								<span class="ml-hop-line" aria-hidden="true" />
								<span class="ml-hop-label">{step.hop.label}</span>
							</div>
						</div>

						{/* ── persistent auth-state line: flips at the verify step ── */}
						<div class="ml-state" data-authed={step.authed ? '' : undefined}>
							<span class="ml-dot" aria-hidden="true" />
							<span class="ml-state-text">
								{step.authed
									? 'Session issued — the user is signed in'
									: 'No session yet — the click has not happened'}
							</span>
						</div>
					</div>

					{/* Per-step caption — the "what's true now" sentence. */}
					<Fragment slot="caption">
						{step.tone === 'blue' && (
							<>
								<strong>Submit.</strong> The browser calls{' '}
								<code>authClient.signIn.magicLink(&#123; email, callbackURL &#125;)</code>.
								Nothing is signed in yet — this only asks for a link.
							</>
						)}
						{step.tone === 'orange' && step.hop.to === 'db' && (
							<>
								<strong>Mint.</strong> Better Auth generates a token and writes a{' '}
								<code>verification</code> row under{' '}
								<code>magic-link:&lt;email&gt;</code> — the same one-table,
								many-namespaces pattern as verify and reset.
							</>
						)}
						{step.tone === 'orange' && step.hop.to === 'inbox' && (
							<>
								<strong>Deliver.</strong> Your <code>sendMagicLink</code> callback
								sends the email through Resend; it lands in the inbox and the user
								taps the link. The request has left the system — it now waits in
								the inbox.
							</>
						)}
						{step.tone === 'green' && step.hop.to === 'db' && (
							<>
								<strong>Verify.</strong> The <code>[...all]</code> route consumes
								the token, finds-or-creates the user, and issues the session.{' '}
								<strong>This is the moment of authentication</strong> — a full
								inbox round-trip after submit, where password sign-in would have
								signed in on submit.
							</>
						)}
						{step.tone === 'green' && step.hop.to === 'browser' && (
							<>
								<strong>Land.</strong> The browser is redirected to{' '}
								<code>/dashboard</code>, already signed in. No password was ever
								typed — the click was the credential.
							</>
						)}
					</Fragment>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>

<style>
	.ml {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
		padding: 6px 2px 2px;
		--ml-on: var(--sl-color-gray-3, #64748b);
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}
	/* the step's accent drives the lit lanes + the hop, so they share one hue */
	.ml[data-tone='blue'] {
		--ml-on: #2563eb;
	}
	.ml[data-tone='orange'] {
		--ml-on: #ea580c;
	}
	.ml[data-tone='green'] {
		--ml-on: #16a34a;
	}

	/* ── actor lanes + the hop share one 4-column grid, so the hop band can span
	      exactly from its source lane to its target lane with no hand math ── */
	.ml-lanes {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		/* row 1 = the lanes, row 2 = the hop rail (fixed height, always reserved) */
		grid-template-rows: auto 44px;
		column-gap: 10px;
		align-items: stretch;
		margin: 0;
	}

	.ml-lane {
		grid-row: 1;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 3px;
		padding: 10px 6px 9px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			box-shadow 0.16s,
			transform 0.16s;
	}
	.ml-ic {
		display: inline-flex;
		width: 22px;
		height: 22px;
		color: var(--sl-color-gray-3, #64748b);
		transition: color 0.16s;
	}
	.ml-ic :global(svg) {
		width: 100%;
		height: 100%;
		display: block;
	}
	.ml-name {
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-gray-2, #475569);
		transition: color 0.16s;
	}
	.ml-sub {
		font-size: 0.6rem;
		font-weight: 600;
		line-height: 1.15;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-4, #94a3b8);
		transition: color 0.16s;
	}

	/* a lit lane: full accent border + tint, lifted, icon + name take the ink */
	.ml-lane[data-on] {
		border-color: var(--ml-on);
		border-width: 1.5px;
		background: color-mix(in srgb, var(--ml-on) 10%, var(--sl-color-bg, transparent));
		transform: translateY(-2px);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--ml-on) 22%, transparent);
	}
	.ml-lane[data-on] .ml-ic {
		color: var(--ml-on);
	}
	.ml-lane[data-on] .ml-name {
		color: var(--sl-color-white, #1e293b);
	}
	.ml-lane:not([data-on]) {
		opacity: 0.62;
	}

	/* the "tap" cue on the inbox lane during deliver */
	.ml-tap {
		position: absolute;
		top: -8px;
		right: -6px;
		padding: 1px 6px;
		border-radius: 999px;
		font-size: 0.55rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #fff;
		background: var(--ml-on);
		box-shadow: 0 1px 4px color-mix(in srgb, var(--ml-on) 45%, transparent);
	}

	/* ── the hop band: a labelled connector spanning the two lanes it joins ── */
	.ml-hop {
		grid-row: 2;
		align-self: center;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		margin: 0;
		padding: 0 4px;
		min-width: 0;
	}
	/* the rule the label rides, with an arrowhead at the destination end */
	.ml-hop-line {
		position: relative;
		width: 100%;
		height: 2px;
		border-radius: 2px;
		background: var(--ml-on);
	}
	.ml-hop-line::after {
		content: '';
		position: absolute;
		top: 50%;
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
	}
	/* rightward hop → arrowhead on the right */
	.ml-hop[data-dir='ltr'] .ml-hop-line::after {
		right: 0;
		transform: translateY(-50%);
		border-left: 6px solid var(--ml-on);
	}
	/* leftward hop (the redirect home) → arrowhead on the left */
	.ml-hop[data-dir='rtl'] .ml-hop-line::after {
		left: 0;
		transform: translateY(-50%);
		border-right: 6px solid var(--ml-on);
	}
	.ml-hop-label {
		max-width: 100%;
		padding: 1px 7px;
		border-radius: 6px;
		border: 1px solid color-mix(in srgb, var(--ml-on) 35%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, var(--ml-on) 9%, var(--sl-color-bg, #fff));
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.66rem;
		font-weight: 700;
		line-height: 1.3;
		color: color-mix(in srgb, var(--ml-on) 72%, var(--sl-color-white, #1e293b));
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* ── persistent auth-state line under the rail ── */
	.ml-state {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin: 0;
		padding: 7px 10px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-top: 1px dashed var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		transition:
			border-color 0.18s,
			background-color 0.18s;
	}
	.ml-dot {
		width: 9px;
		height: 9px;
		flex: 0 0 auto;
		border-radius: 50%;
		background: var(--sl-color-gray-4, #94a3b8);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--sl-color-gray-4, #94a3b8) 22%, transparent);
		transition:
			background-color 0.18s,
			box-shadow 0.18s;
	}
	.ml-state-text {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-3, #64748b);
		transition: color 0.18s;
	}
	/* authenticated: the line goes green and the dot lights */
	.ml-state[data-authed] {
		border-color: color-mix(in srgb, #16a34a 45%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #16a34a 8%, var(--sl-color-bg, transparent));
	}
	.ml-state[data-authed] .ml-dot {
		background: #16a34a;
		box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 26%, transparent);
	}
	.ml-state[data-authed] .ml-state-text {
		color: #15803d; /* green-700 */
	}

	/* ── narrow viewports: lanes stay a single row (four columns read fine small),
	      just tighten the chrome and let the hop label wrap instead of truncate ── */
	@media (max-width: 560px) {
		.ml-lanes {
			column-gap: 6px;
			grid-template-rows: auto 52px;
		}
		.ml-lane {
			padding: 8px 3px 7px;
		}
		.ml-name {
			font-size: 0.72rem;
		}
		.ml-sub {
			display: none;
		}
		.ml-hop-label {
			font-size: 0.58rem;
			white-space: normal;
			text-align: center;
		}
		.ml-state-text {
			font-size: 0.66rem;
		}
	}
</style>
