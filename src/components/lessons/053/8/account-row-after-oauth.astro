---
// account-row-after-oauth — Chapter 053 Lesson 8, "Social sign-in with OAuth",
// the payoff of "The button and what lands in `account`".
//
// The spine made literal: after a first-time Google sign-in you get an `account`
// row that is a POINTER + TOKENS and holds NO secret of its own — and that's the
// mirror image of the `'credential'` row a password sign-up writes (a secret, no
// tokens). Two `account` row-cards side by side carry that contrast; a slim `user`
// strip below shows the identity row filled straight from the Google profile.
//
// The contrast is the whole figure, so it's built to be *seen*, not read:
//   • Both account cards are VIOLET — the chapter's credential/`account` accent
//     (from L1's rows-after-signup, where the hash lands). Same colour = same
//     table; the populated-vs-greyed columns carry the difference, not the hue.
//   • Secrets wear a small "secret" tag (the tokens, and the password hash);
//     `accountId` is explicitly the provider's id and is NOT tagged — it's the
//     public-ish pointer, safe to log (the line the prose keeps drawing).
//   • The greyed/struck rows mirror L1's ghosted-`session` treatment: the Google
//     card's `password: —` is emphasised as THE contrast (this row has no secret),
//     its `refreshToken: —` carries the "only if accessType: 'offline'" note, and
//     the credential card greys every token column right back.
//
// Plain HTML + scoped CSS per the diagrams index (annotated-illustration shape;
// deliberately NOT a diagram engine and NOT ArrowDiagram, whose LeaderLines can't
// be relocated into the <Figure> lightbox). Theme-aware Starlight gray/white vars
// flip light/dark; the accents (#7c3aed violet, #2563eb blue) are mid-tones reused
// as-is on both backgrounds. `not-content` + `margin: 0` resets defeat Starlight's
// injected prose styling inside the figure.

import Figure from '../../../figures/Figure.astro';

interface Row {
	key: string;
	val: string;
	/** a populated secret — wears the "secret" tag, value rendered as a live token */
	secret?: boolean;
	/** label on the secret tag (defaults to "secret") */
	secretLabel?: string;
	/** the row is null / absent — greyed and struck, like L1's ghosted session */
	absent?: boolean;
	/** the one row to visually emphasise as the spine contrast (Google's empty password) */
	spine?: boolean;
	/** a short trailing note rendered under the value (e.g. the offline caveat) */
	note?: string;
}

interface AccountCard {
	tag: string;
	/** the one-line takeaway under the card */
	foot: string;
	rows: Row[];
}

// LEFT — the OAuth account row: a pointer + tokens, no password.
const oauth: AccountCard = {
	tag: 'Google sign-in',
	foot: 'A pointer to a Google identity, plus tokens. No secret of its own.',
	rows: [
		{ key: 'providerId', val: "'google'" },
		{ key: 'accountId', val: "'108…74'", note: "the provider's stable id (the OIDC sub) — safe to log" },
		{ key: 'accessToken', val: 'ya29.…', secret: true },
		{ key: 'idToken', val: 'eyJ…', secret: true },
		{ key: 'refreshToken', val: '—', absent: true, note: "only if accessType: 'offline'" },
		{ key: 'scope', val: "'openid email profile'" },
		{ key: 'expiresAt', val: '2026-…' },
		{ key: 'password', val: '—', absent: true, spine: true, note: 'no secret stored here' },
	],
};

// RIGHT — the credential account row, for contrast: a secret, no tokens.
const credential: AccountCard = {
	tag: 'password sign-up',
	foot: 'One secret — the hash. No provider tokens at all.',
	rows: [
		{ key: 'providerId', val: "'credential'" },
		{ key: 'accountId', val: '<userId>' },
		{ key: 'accessToken', val: '—', absent: true },
		{ key: 'idToken', val: '—', absent: true },
		{ key: 'refreshToken', val: '—', absent: true },
		{ key: 'scope', val: '—', absent: true },
		{ key: 'expiresAt', val: '—', absent: true },
		{ key: 'password', val: '$argon2id$…', secret: true, secretLabel: 'secret · hashed' },
	],
};

// The slim `user` strip below — the identity row, filled from the Google profile.
const userRow: { key: string; val: string; from: string }[] = [
	{ key: 'email', val: "'ada@gmail.com'", from: 'from the profile' },
	{ key: 'name', val: "'Ada Lovelace'", from: 'from name' },
	{ key: 'image', val: "'https://…'", from: 'from picture' },
	{ key: 'emailVerified', val: 'true', from: 'from email_verified' },
];

const accounts = [oauth, credential];
---

<Figure caption="The OAuth account row is a pointer plus tokens, no password; the credential row is a secret, no tokens. Same table, opposite contents.">
	<div class="ar not-content">
		{/* ── the two account row-cards, side by side ── */}
		<div class="ar-pair">
			{
				accounts.map((card) => (
					<div class="ar-card">
						<div class="ar-card-head">
							<code class="ar-card-name">account</code>
							<span class="ar-card-tag">{card.tag}</span>
						</div>
						<div class="ar-card-body">
							{card.rows.map((row) => (
								<span
									class="ar-row"
									data-absent={row.absent ? '' : undefined}
									data-spine={row.spine ? '' : undefined}
								>
									<span class="ar-row-main">
										<span class="ar-key">{row.key}</span>
										<span class="ar-val-wrap">
											{row.secret ? (
												<span class="ar-token">{row.val}</span>
											) : (
												<span class="ar-val">{row.val}</span>
											)}
											{row.secret && (
												<span class="ar-secret">{row.secretLabel ?? 'secret'}</span>
											)}
										</span>
									</span>
									{row.note && <span class="ar-note">{row.note}</span>}
								</span>
							))}
						</div>
						<p class="ar-foot">{card.foot}</p>
					</div>
				))
			}
		</div>

		{/* ── the slim `user` strip — the identity row, from the Google profile ── */}
		<div class="ar-user">
			<div class="ar-user-head">
				<code class="ar-user-name">user</code>
				<span class="ar-user-tag">filled from the Google profile</span>
			</div>
			<div class="ar-user-body">
				{
					userRow.map((f) => (
						<span class="ar-user-field">
							<span class="ar-user-pair">
								<span class="ar-key">{f.key}</span>
								<span class="ar-val">{f.val}</span>
							</span>
							<span class="ar-user-from">{f.from}</span>
						</span>
					))
				}
			</div>
		</div>
	</div>
</Figure>

<style>
	.ar {
		display: flex;
		flex-direction: column;
		gap: 16px;
		margin: 0;
		padding: 4px 2px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── the two account cards ── */
	.ar-pair {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		gap: 16px;
		margin: 0;
	}

	.ar-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		flex: 1 1 17rem;
		min-width: 0;
		border-radius: 10px;
		overflow: hidden;
		margin: 0;
		/* violet — the chapter's `account` / credential accent (from L1) */
		border: 1.5px solid #7c3aed;
		background: color-mix(in srgb, #7c3aed 7%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(124, 58, 237, 0.18);
	}

	.ar-card-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 7px 12px;
		margin: 0;
		border-bottom: 1px solid color-mix(in srgb, #7c3aed 35%, transparent);
		background: color-mix(in srgb, #7c3aed 12%, transparent);
	}
	.ar-card-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.9rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.ar-card-tag {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.64rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.ar-card-body {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 9px 12px;
		margin: 0;
	}

	/* ── one `column: value` row ── */
	.ar-row {
		display: flex;
		flex-direction: column;
		gap: 1px;
		border-radius: 6px;
		padding: 2px 6px;
		margin: 0 -6px;
	}
	.ar-row-main {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		margin: 0;
	}
	.ar-key {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.74rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.ar-val-wrap {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		min-width: 0;
		margin: 0;
	}
	.ar-val {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.74rem;
		line-height: 1.3;
		white-space: nowrap;
		text-align: right;
		color: #6d28d9; /* violet-700 — the highlighted value, as in L1 */
		margin: 0;
	}

	/* a populated, truncated token — rendered as a live secret string */
	.ar-token {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1.3;
		white-space: nowrap;
		color: #6d28d9;
		background: color-mix(in srgb, #7c3aed 14%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #7c3aed 42%, transparent);
		border-radius: 5px;
		padding: 1px 5px;
		margin: 0;
	}

	/* the small "secret" tag riding next to a token / hash */
	.ar-secret {
		font-size: 0.56rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1;
		white-space: nowrap;
		padding: 2px 5px;
		border-radius: 999px;
		color: #b91c1c; /* red-700 — "this is a secret, keep it out of logs" */
		background: color-mix(in srgb, #dc2626 12%, transparent);
		border: 1px solid color-mix(in srgb, #dc2626 38%, transparent);
		margin: 0;
	}

	/* a short trailing note under the value (the offline caveat, the sub note) */
	.ar-note {
		align-self: flex-end;
		font-size: 0.6rem;
		font-style: italic;
		line-height: 1.25;
		text-align: right;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── null / absent rows: greyed + struck, mirroring L1's ghosted session ── */
	.ar-row[data-absent] .ar-key {
		color: var(--sl-color-gray-3, #64748b);
		font-weight: 500;
	}
	.ar-row[data-absent] .ar-val {
		color: var(--sl-color-gray-4, #94a3b8);
	}

	/* the spine row: Google's empty `password`, the contrast the figure exists for */
	.ar-row[data-spine] {
		background: color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 24%, transparent);
		box-shadow: inset 0 0 0 1px var(--sl-color-gray-5, #cbd5e1);
	}
	.ar-row[data-spine] .ar-key {
		color: var(--sl-color-white, #1e293b);
		font-weight: 700;
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
		text-decoration-color: var(--sl-color-gray-4, #94a3b8);
	}
	.ar-row[data-spine] .ar-note {
		font-style: normal;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
	}

	.ar-foot {
		padding: 0 12px 10px;
		font-size: 0.66rem;
		line-height: 1.35;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* ── the slim `user` strip below ── */
	.ar-user {
		box-sizing: border-box;
		border-radius: 10px;
		overflow: hidden;
		margin: 0;
		/* blue — the identity row, from L1's rows-after-signup */
		border: 1.5px solid #2563eb;
		background: color-mix(in srgb, #2563eb 6%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(37, 99, 235, 0.15);
	}
	.ar-user-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 6px 12px;
		margin: 0;
		border-bottom: 1px solid color-mix(in srgb, #2563eb 32%, transparent);
		background: color-mix(in srgb, #2563eb 11%, transparent);
	}
	.ar-user-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.ar-user-tag {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	/* the four profile-derived fields flow in a responsive row */
	.ar-user-body {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 22px;
		padding: 9px 12px;
		margin: 0;
	}
	.ar-user-field {
		display: flex;
		flex-direction: column;
		gap: 1px;
		min-width: 0;
		margin: 0;
	}
	.ar-user-pair {
		display: inline-flex;
		align-items: baseline;
		gap: 7px;
		margin: 0;
	}
	.ar-user-pair .ar-val {
		color: #1d4ed8; /* blue-700 — the user row's highlighted value */
		text-align: left;
	}
	.ar-user-from {
		font-size: 0.58rem;
		font-style: italic;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── narrow viewports: the two account cards stack ── */
	@media (max-width: 640px) {
		.ar-card {
			flex: 1 1 100%;
		}
		.ar-user-body {
			gap: 8px 16px;
		}
	}
</style>
