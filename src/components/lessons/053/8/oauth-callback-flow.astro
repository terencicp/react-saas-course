---
// oauth-callback-flow — Chapter 053 Lesson 8, "Social sign-in with OAuth".
//
// The lesson's named, load-bearing visual: the whole social sign-in round-trip
// held as one scrubbable sequence — but built around the ONE step that makes it
// worth drawing. It's a sibling of the chapter's other flow figures
// (signup-flow-strip / signin-flow-strip / verify-flow / reset-flow /
// magic-link-flow): same DiagramSequence + a horizontal pipeline STRIP whose
// only change per step is which node is LIT. What it adds is the BRANCH.
//
// Step 4 — the find-or-create lookup (the violet hinge) — is the centerpiece.
// One button quietly produces four landing states, and the whole point of the
// diagram is to make that fan visible. So under the strip sits a "branch zone"
// that, on step 4, fans the lit lookup node out into four condition -> outcome
// rows (account exists / email + trusted / email + untrusted / no user) ending
// in coloured outcome boxes (three green, one red). On every other step the same
// zone holds a single quiet contextual line. The zone reserves its full (tallest:
// the 4-row fan) height on EVERY render, so the DiagramSequence stage sizes once
// at first paint and never reflows as the reader scrubs — the same discipline as
// the sibling flow figures.
//
// Palette is the chapter's, verbatim from the siblings:
//   neutral — request plumbing                     (the strip rule, idle chrome)
//   blue    — the client call / config             (#2563eb)
//   orange  — library / endpoint / callback work   (#ea580c)
//   violet  — the hinge: the find-or-create lookup  (#7c3aed)
//   green   — session / success outcomes            (#16a34a)
//   red     — the refusal (account-not-linked)      (#dc2626)
//
// Mid-tone accents are reused as-is in both themes; neutral chrome rides
// Starlight gray/white vars so it flips light/dark. `not-content` (carried by
// DiagramSequence) opts the figure out of Starlight prose styling.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Tone = 'blue' | 'orange' | 'violet' | 'green';

// The six pipeline stages, left -> right. `label` is the short strip glyph
// (\n -> <br>); `tone` is the colour the node takes when it's the active (lit)
// stage. Captions live on each step below.
const STAGES: { label: string; tone: Tone }[] = [
	{ label: 'Click\nbutton', tone: 'blue' },
	{ label: 'Google\nconsent', tone: 'orange' },
	{ label: 'Callback\n→ catch-all', tone: 'orange' },
	{ label: 'Find-or-\ncreate', tone: 'violet' },
	{ label: 'Issue\nsession', tone: 'green' },
	{ label: 'Land on\ncallbackURL', tone: 'green' },
];

// The index of the branch step — the only step that fans the branch zone open.
const BRANCH_IDX = STAGES.findIndex((s) => s.tone === 'violet');

// The four landing states off the lookup node. `cond` is the arrow label (what
// the database holds); `outcome` is the destination box; `tone` colours the box
// (green for the three sign-them-in paths, red for the refusal).
const BRANCHES: { cond: string; outcome: string; tone: 'green' | 'red' }[] = [
	{ cond: 'account row exists', outcome: 'Sign in existing user', tone: 'green' },
	{ cond: 'email matches, provider trusted', outcome: 'Link a new account row', tone: 'green' },
	{ cond: 'email matches, provider untrusted', outcome: 'Refuse — account-not-linked', tone: 'red' },
	{ cond: 'no user at all', outcome: 'Create user + account', tone: 'green' },
];

// The quiet contextual line shown in the branch zone on the non-branch steps,
// so the reserved box never reads empty. Keyed by stage index.
const ZONE_HINTS: Record<number, string> = {
	0: 'The library attaches state + the PKCE challenge on the way out.',
	1: "On Google's domain — the user picks an account and approves the scopes.",
	2: 'The library validates state, swaps code for tokens, reads userinfo.',
	4: 'The cookie rides back out through nextCookies.',
	5: 'Validated against your trustedOrigins before the redirect fires.',
};
---

<DiagramSequence>
	{
		STAGES.map((_, active) => {
			const isBranch = active === BRANCH_IDX;
			return (
				<DiagramStep>
					<div class="of" data-tone={STAGES[active].tone}>
						{/* ── the six-stage pipeline strip ── */}
						<div class="of-strip">
							{STAGES.map((stage, i) => (
								<Fragment>
									{i > 0 && <span class="of-arrow" aria-hidden="true">→</span>}
									<div
										class="of-stage"
										data-state={i < active ? 'done' : i === active ? 'on' : 'todo'}
										data-tone={stage.tone}
									>
										<span class="of-num">{i + 1}</span>
										<span class="of-label">
											{stage.label.split('\n').map((line, k) => (
												<>
													{k > 0 && <br />}
													{line}
												</>
											))}
										</span>
									</div>
								</Fragment>
							))}
						</div>

						{/* ── the branch zone: reserved every step, fans open at the hinge ──
						     Both layers always occupy layout; only their visibility flips,
						     so the stage height is the tallest (the open fan) on every step. */}
						<div class="of-zone" data-open={isBranch ? '' : undefined}>
							{/* the open fan — the find-or-create lookup's four landing states */}
							<div class="of-fan" aria-hidden={isBranch ? undefined : 'true'}>
								<span class="of-fan-src">
									<span class="of-fan-src-dot" />
									the lookup asks, in order
								</span>
								<ul class="of-rows">
									{BRANCHES.map((b) => (
										<li class="of-row" data-tone={b.tone}>
											<span class="of-cond">{b.cond}</span>
											<span class="of-rule" aria-hidden="true" />
											<span class="of-outcome">{b.outcome}</span>
										</li>
									))}
								</ul>
							</div>

							{/* the quiet single line for the non-branch steps */}
							<p class="of-hint" aria-hidden={isBranch ? 'true' : undefined}>
								{ZONE_HINTS[active]}
							</p>
						</div>
					</div>

					{/* Per-step caption — the "what happens here" sentence. */}
					<Fragment slot="caption">
						{active === 0 && (
							<>
								<strong>Click.</strong> Your button calls{' '}
								<code>authClient.signIn.social(&#123; provider: 'google' &#125;)</code>,
								and the browser redirects to Google. Nothing is signed in yet.
							</>
						)}
						{active === 1 && (
							<>
								<strong>Consent.</strong> The user picks an account and approves the
								scopes — on <strong>Google's domain, not yours</strong>. The page you
								never see.
							</>
						)}
						{active === 2 && (
							<>
								<strong>Callback.</strong> Google redirects back to{' '}
								<code>…/api/auth/callback/google</code> — straight into the catch-all
								you already mounted. No new route. The library validates{' '}
								<code>state</code>, swaps <code>code</code> for tokens, and reads{' '}
								<code>userinfo</code>.
							</>
						)}
						{active === 3 && (
							<>
								<strong>The hinge — find-or-create.</strong> Now the library decides{' '}
								<em>who this is</em>. One button, four landing states: it tries the
								provider identity, then the email, and only{' '}
								<strong>refuses to auto-merge</strong> on an email match when the
								provider isn't trusted.
							</>
						)}
						{active === 4 && (
							<>
								<strong>Session.</strong> The library issues a session and the cookie
								rides back out through <code>nextCookies</code>. From here on the user
								is signed in.
							</>
						)}
						{active === 5 && (
							<>
								<strong>Land.</strong> The browser is redirected to your{' '}
								<code>callbackURL</code>, already signed in.{' '}
								<strong>No password was stored anywhere.</strong> The provider's vouch
								is the credential — the <code>account</code> row points at a Google
								identity, not a secret you keep.
							</>
						)}
					</Fragment>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>

<style>
	.of {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
		padding: 4px 2px 2px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── the pipeline strip ───────────────────────────────────────── */
	.of-strip {
		--of-on: var(--sl-color-gray-3, #64748b);
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 4px;
		margin: 0;
	}
	/* the strip's accent follows the active stage's tone */
	.of[data-tone='blue'] .of-strip {
		--of-on: #2563eb;
	}
	.of[data-tone='orange'] .of-strip {
		--of-on: #ea580c;
	}
	.of[data-tone='violet'] .of-strip {
		--of-on: #7c3aed;
	}
	.of[data-tone='green'] .of-strip {
		--of-on: #16a34a;
	}

	.of-stage {
		position: relative;
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 5px;
		padding: 8px 4px 7px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			opacity 0.16s,
			transform 0.16s;
	}

	.of-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		flex: 0 0 auto;
		border-radius: 50%;
		font-size: 0.64rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		transition:
			color 0.16s,
			background-color 0.16s;
	}
	.of-label {
		font-size: 0.7rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-2, #475569);
		overflow-wrap: anywhere;
		transition: color 0.16s;
	}

	/* the thin connector between stages */
	.of-arrow {
		flex: 0 0 auto;
		align-self: center;
		font-size: 0.8rem;
		line-height: 1;
		color: var(--sl-color-gray-4, #94a3b8);
	}

	/* not yet reached */
	.of-stage[data-state='todo'] {
		opacity: 0.5;
	}

	/* already passed: a muted tint in that stage's own tone */
	.of-stage[data-state='done'][data-tone='blue'] {
		border-color: color-mix(in srgb, #2563eb 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.of-stage[data-state='done'][data-tone='orange'] {
		border-color: color-mix(in srgb, #ea580c 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.of-stage[data-state='done'][data-tone='violet'] {
		border-color: color-mix(in srgb, #7c3aed 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.of-stage[data-state='done'][data-tone='green'] {
		border-color: color-mix(in srgb, #16a34a 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.of-stage[data-state='done'] .of-num {
		color: #fff;
		background: var(--sl-color-gray-4, #94a3b8);
	}
	.of-stage[data-state='done'][data-tone='blue'] .of-num {
		background: color-mix(in srgb, #2563eb 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.of-stage[data-state='done'][data-tone='orange'] .of-num {
		background: color-mix(in srgb, #ea580c 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.of-stage[data-state='done'][data-tone='violet'] .of-num {
		background: color-mix(in srgb, #7c3aed 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.of-stage[data-state='done'][data-tone='green'] .of-num {
		background: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-4, #94a3b8));
	}

	/* the lit stage: full tone, lifted */
	.of-stage[data-state='on'] {
		border-color: var(--of-on);
		border-width: 1.5px;
		background: color-mix(in srgb, var(--of-on) 10%, var(--sl-color-bg, transparent));
		transform: translateY(-2px);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--of-on) 22%, transparent);
	}
	.of-stage[data-state='on'] .of-num {
		color: #fff;
		background: var(--of-on);
	}
	.of-stage[data-state='on'] .of-label {
		color: var(--sl-color-white, #1e293b);
	}

	/* ── the branch zone: both layers stacked in one grid cell, so the box is
	      always the height of the (taller) open fan and never reflows ── */
	.of-zone {
		display: grid;
		margin: 0;
		padding: 10px 8px 6px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
		border-top-width: 1px;
		background: var(--sl-color-bg, transparent);
		transition:
			border-color 0.18s,
			background-color 0.18s;
	}
	/* at the hinge the zone reads violet — this is the find-or-create moment */
	.of-zone[data-open] {
		border-style: solid;
		border-color: color-mix(in srgb, #7c3aed 40%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #7c3aed 6%, var(--sl-color-bg, transparent));
	}
	/* both children share the one grid cell; the inactive one stays in layout */
	.of-fan,
	.of-hint {
		grid-area: 1 / 1;
	}

	/* the open fan, revealed at the branch step */
	.of-fan {
		display: flex;
		flex-direction: column;
		gap: 7px;
		visibility: hidden;
	}
	/* `inherit`, not `visible`: DiagramSequence stacks every step in one cell and
	   hides the inactive ones with visibility:hidden on the .ds-step wrapper. A
	   descendant set to visibility:visible overrides that ancestor and bleeds
	   through on top of whatever step is active. Inheriting instead makes the fan
	   follow its own step's active state — shown only when the branch step is. */
	.of-zone[data-open] .of-fan {
		visibility: inherit;
	}

	.of-fan-src {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		margin: 0 0 1px;
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: color-mix(in srgb, #7c3aed 78%, var(--sl-color-gray-2, #475569));
	}
	.of-fan-src-dot {
		width: 9px;
		height: 9px;
		flex: 0 0 auto;
		border-radius: 50%;
		background: #7c3aed;
		box-shadow: 0 0 0 3px color-mix(in srgb, #7c3aed 24%, transparent);
	}

	.of-rows {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 6px;
	}
	/* each landing state: condition → rule → outcome box, on one row */
	.of-row {
		--of-out: #16a34a;
		display: grid;
		grid-template-columns: minmax(0, 1fr) 18px minmax(0, 1fr);
		align-items: center;
		gap: 8px;
		margin: 0;
	}
	.of-row[data-tone='red'] {
		--of-out: #dc2626;
	}

	.of-cond {
		justify-self: end;
		max-width: 100%;
		padding: 4px 9px;
		border-radius: 7px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		font-size: 0.68rem;
		font-weight: 600;
		line-height: 1.25;
		text-align: right;
		color: var(--sl-color-gray-2, #475569);
	}
	/* the arrow rule from condition to outcome, arrowhead at the outcome end */
	.of-rule {
		position: relative;
		width: 100%;
		height: 2px;
		border-radius: 2px;
		background: color-mix(in srgb, var(--of-out) 55%, var(--sl-color-gray-5, #cbd5e1));
	}
	.of-rule::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1px;
		transform: translateY(-50%);
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-left: 6px solid color-mix(in srgb, var(--of-out) 70%, var(--sl-color-gray-4, #94a3b8));
	}

	.of-outcome {
		justify-self: start;
		max-width: 100%;
		padding: 5px 10px;
		border-radius: 7px;
		border: 1.5px solid var(--of-out);
		background: color-mix(in srgb, var(--of-out) 11%, var(--sl-color-bg, transparent));
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1.25;
		color: color-mix(in srgb, var(--of-out) 80%, var(--sl-color-white, #1e293b));
	}

	/* the quiet hint line for the non-branch steps */
	.of-hint {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		padding: 0 6px;
		font-size: 0.74rem;
		font-weight: 500;
		line-height: 1.45;
		text-align: center;
		color: var(--sl-color-gray-3, #64748b);
	}
	.of-zone[data-open] .of-hint {
		visibility: hidden;
	}

	/* ── narrow viewports: let the strip wrap into compact left-aligned chips,
	      and stack each branch row so the condition sits over its outcome with a
	      short downward connector. ── */
	@media (max-width: 600px) {
		.of-stage {
			flex: 1 1 40%;
			min-width: 0;
			flex-direction: row;
			justify-content: flex-start;
			gap: 6px;
			padding: 6px 8px;
			text-align: left;
		}
		.of-arrow {
			display: none;
		}

		.of-row {
			grid-template-columns: 1fr;
			gap: 2px;
			justify-items: stretch;
		}
		.of-cond {
			justify-self: stretch;
			text-align: left;
		}
		/* the horizontal rule + arrowhead don't read when stacked — hide it and
		   let the vertical order carry the condition -> outcome direction */
		.of-rule {
			display: none;
		}
		.of-outcome {
			justify-self: stretch;
		}
	}
</style>
