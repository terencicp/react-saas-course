---
// remember-me-cookies — Chapter 053 Lesson 2 ("Password sign-in"), the OPTIONAL
// one-glance figure for the section "What 'remember me' actually controls".
//
// Pedagogical goal: kill the universal misconception that "remember me" extends
// the SERVER-SIDE session. It does not. It changes ONE thing: the cookie's
// Max-Age on the user's machine. The figure's whole job is to show that the two
// checkbox states differ ONLY in the cookie, then visibly CONVERGE onto a single
// `session` row carrying the SAME `expiresAt`. The convergence is the teaching
// point — two different cookies, one identical server-side row — which is hard
// to state in prose but trivial to draw: two cookie chips, two stems, one rail,
// one shared row.
//
// Composition: two cookie "chips" on top (checked vs unchecked), each dropping a
// stem into a shared horizontal rail that feeds a single `session`-row block
// below. Read top-to-bottom: the choice lives in the cookie; the row underneath
// is the same on both sides.
//
// Colour: deliberately NEUTRAL. This lesson's red/violet/green means
// error/continuation/success, and teal/amber (in defense-layers-table) means
// library-vs-you — reusing either here would mislead. The two chips share
// identical chrome on purpose (the point is sameness downstream); a single muted
// slate accent carries the cookie motif, and the one tiny contrast is a "30d"
// vs "—" Max-Age detail, not a colour war between the two states.
//
// Plain HTML + CSS per the diagrams index (annotated-illustration shape; not a
// diagram engine, no LeaderLines, so it survives relocation into the Figure
// lightbox and stays expandable). Astro-scoped <style>. `margin: 0` resets on
// every node + `.not-content` on the root defeat Starlight's injected prose
// margins reaching into the flex/grid children. Theme-aware chrome via Starlight
// gray vars; the lone accent is a 600-range slate that reads on both themes.

import Figure from '../../../figures/Figure.astro';

const ACCENT = '#475569'; // neutral slate — cookie-motif chrome, no classification meaning

type Chip = {
  /** The checkbox state this cookie comes from. */
  state: string;
  /** Is the box checked? drives the little tick glyph. */
  checked: boolean;
  /** The cookie attribute that differs — the hero line. */
  attr: string;
  /** What that attribute means for the cookie's fate. */
  fate: string;
  /** Where the browser keeps it. */
  store: string;
};

const chips: Chip[] = [
  {
    state: 'remember me — checked',
    checked: true,
    attr: 'Max-Age: 30 days',
    fate: 'persists on disk — survives the browser closing',
    store: 'on disk',
  },
  {
    state: 'remember me — unchecked',
    checked: false,
    attr: 'Session',
    fate: 'kept in memory — cleared the moment the browser closes',
    store: 'in memory',
  },
];
---

<Figure>
  <div class="rm not-content" style={`--c:${ACCENT}`}>
    {/* ── two cookie chips: identical chrome, differing only in the cookie's
         lifetime attribute (the hero mono line) ── */}
    <div class="rm-chips">
      {
        chips.map((chip) => (
          <div class="rm-chip">
            <div class="rm-chip-head">
              <svg
                class="rm-cookie"
                viewBox="0 0 24 24"
                aria-hidden="true"
                fill="none"
              >
                <path
                  d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-4-4 4 4 0 0 1-4-4 3 3 0 0 0-2-2Z"
                  fill="color-mix(in srgb, var(--c) 16%, transparent)"
                  stroke="var(--c)"
                  stroke-width="1.5"
                  stroke-linejoin="round"
                />
                <circle cx="9" cy="10" r="1" fill="var(--c)" />
                <circle cx="14" cy="14" r="1" fill="var(--c)" />
                <circle cx="9.5" cy="15" r="0.9" fill="var(--c)" />
                <circle cx="15" cy="9" r="0.9" fill="var(--c)" />
              </svg>
              <span class="rm-state">
                <span
                  class={`rm-box ${chip.checked ? 'rm-box--on' : 'rm-box--off'}`}
                  aria-hidden="true"
                >
                  {chip.checked ? '✓' : ''}
                </span>
                {chip.state}
              </span>
            </div>

            <code class="rm-attr">{chip.attr}</code>
            <span class="rm-fate">{chip.fate}</span>

            {/* stem dropping toward the shared rail below */}
            <span class="rm-stem" aria-hidden="true"></span>
          </div>
        ))
      }
    </div>

    {/* ── the convergence: both stems meet one rail, which feeds ONE row ── */}
    <div class="rm-rail" aria-hidden="true">
      <span class="rm-rail-line"></span>
      <span class="rm-rail-drop"></span>
    </div>

    <div class="rm-row">
      <span class="rm-row-tag">same on both sides</span>
      <code class="rm-row-code"
        >session {'{'} expiresAt: 2026-07-07 {'}'}</code
      >
      <span class="rm-row-note"
        >one server-side row, one identical <code>expiresAt</code></span
      >
    </div>
  </div>

  <Fragment slot="caption">
    Both back a `session` row with the **same** `expiresAt`. The checkbox changes
    the *cookie* on the user's machine, not the server-side session.
  </Fragment>
</Figure>

<style>
  .rm {
    container-type: inline-size;
    container-name: rm;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    width: 100%;
    margin: 0;
    padding-block: 4px;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── the two cookie chips ── */
  .rm-chips {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 18px;
    width: 100%;
    margin: 0;
  }

  .rm-chip {
    position: relative;
    flex: 0 1 17rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 7px;
    min-width: 0;
    margin: 0;
    /* room under the chip for the stem to drop into the rail */
    padding: 12px 14px 26px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    border-radius: 12px;
    background: var(--sl-color-black, transparent);
  }

  .rm-chip-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
  }
  .rm-cookie {
    flex: 0 0 auto;
    width: 22px;
    height: 22px;
    margin: 0;
  }
  .rm-state {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--sl-color-white);
  }

  /* the little checkbox glyph echoing the form control the section is about */
  .rm-box {
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 15px;
    height: 15px;
    margin: 0;
    border-radius: 4px;
    border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
    font-size: 0.7rem;
    font-weight: 800;
    line-height: 1;
    color: #fff;
  }
  .rm-box--on {
    border-color: var(--c);
    background: var(--c);
  }
  .rm-box--off {
    background: transparent;
  }

  /* the hero mono line — the one cookie attribute that actually differs */
  .rm-attr {
    align-self: stretch;
    box-sizing: border-box;
    margin: 0;
    padding: 6px 10px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--c) 38%, transparent);
    background: color-mix(in srgb, var(--c) 12%, transparent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.3;
    white-space: nowrap;
    color: var(--sl-color-white);
  }
  .rm-fate {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.35;
    color: var(--sl-color-gray-2, #475569);
  }

  /* the stem: a short vertical line from the chip's bottom centre toward the
     rail; its tip lands on the rail line that sits just below the chips row */
  .rm-stem {
    position: absolute;
    left: 50%;
    bottom: -1px;
    width: 0;
    height: 18px;
    border-left: 2px solid color-mix(in srgb, var(--c) 55%, var(--sl-color-gray-4, #94a3b8));
    transform: translateX(-50%);
    margin: 0;
  }

  /* ── the convergence rail: a horizontal line tying the two stems together,
        with a single drop feeding the shared row below ── */
  .rm-rail {
    position: relative;
    display: flex;
    justify-content: center;
    width: 100%;
    height: 26px;
    margin: 0;
  }
  /* the horizontal tie — spans the gap between the two chip centres. The chips
     are flex:0 1 17rem with an 18px gap, so their centres sit roughly a quarter
     of the row in from each edge; a 52% centred line reaches both stems with a
     little overhang on each side. */
  .rm-rail-line {
    position: absolute;
    top: 0;
    left: 50%;
    width: min(52%, 19rem);
    height: 0;
    border-top: 2px solid color-mix(in srgb, var(--c) 55%, var(--sl-color-gray-4, #94a3b8));
    transform: translateX(-50%);
    margin: 0;
  }
  /* the single drop from the rail's centre into the row, with an arrowhead */
  .rm-rail-drop {
    position: absolute;
    top: 0;
    left: 50%;
    width: 0;
    height: 100%;
    border-left: 2px solid color-mix(in srgb, var(--c) 55%, var(--sl-color-gray-4, #94a3b8));
    transform: translateX(-50%);
    margin: 0;
  }
  .rm-rail-drop::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -1px;
    transform: translateX(-50%);
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 7px solid color-mix(in srgb, var(--c) 55%, var(--sl-color-gray-4, #94a3b8));
  }

  /* ── the shared session row: ONE block, the same for both cookies ── */
  .rm-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    margin: 0;
    padding: 12px 18px;
    border: 1.5px solid color-mix(in srgb, var(--c) 45%, var(--sl-color-gray-4, #94a3b8));
    border-radius: 12px;
    background: color-mix(in srgb, var(--c) 7%, var(--sl-color-bg, transparent));
    text-align: center;
  }
  .rm-row-tag {
    margin: 0;
    padding: 2px 9px;
    border-radius: 999px;
    background: var(--c);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.2;
    color: #fff;
  }
  .rm-row-code {
    margin: 0;
    padding: 5px 12px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--c) 14%, transparent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.3;
    white-space: nowrap;
    color: var(--sl-color-white);
  }
  .rm-row-note {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.35;
    color: var(--sl-color-gray-2, #475569);
  }
  .rm-row-note code {
    background: transparent;
    padding: 0;
    font-size: 0.72rem;
    color: inherit;
  }

  /* ── narrow figure (sidebar open, or phones): stack the two chips. Once
        stacked, the centred rail no longer ties two side-by-side stems, so drop
        the rail entirely and let the shared row's "same on both sides" tag plus
        the caption carry the convergence. ── */
  @container rm (max-width: 520px) {
    .rm-chips {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
      max-width: 22rem;
    }
    .rm-chip {
      flex: 1 1 auto;
      padding-bottom: 12px;
    }
    /* a centred horizontal rail makes no sense over a single column — hide the
       stems and rail; vertical stacking + the row tag imply the convergence */
    .rm-stem,
    .rm-rail {
      display: none;
    }
    .rm-row {
      margin-top: 10px;
      max-width: 22rem;
    }
    .rm-row-code {
      white-space: normal;
      overflow-wrap: anywhere;
    }
  }
</style>
