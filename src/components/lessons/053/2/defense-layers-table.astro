---
// defense-layers-table — Chapter 053 Lesson 2 ("Password sign-in"), the figure
// for the section "What the library defends, and the defense it leaves you to
// add".
//
// Pedagogical goal: give the HONEST two-layer brute-force picture, where the
// decisive distinction is WHO PROVIDES EACH LAYER. Better Auth ships the per-IP
// rate limit for free; the per-email limit is something the senior ADDS later
// (Ch 074). A student who assumes the library does both ships a real hole, so
// the "who provides it" signal is foregrounded as each card's header badge —
// not buried as one cell in a flat table.
//
// Composition: two side-by-side cards inside <Figure> (the diagrams index lists
// a comparison table / side-by-side cards as a legitimate diagram). The cards
// share an identical three-field structure — Provider badge → Stops → Hole — so
// the reader compares the two layers row-for-row. The "Hole" strip is tinted on
// every card so the eye catches that each layer alone is INCOMPLETE; that sets
// up the caption's interlock point ("each hole the other plugs").
//
// Colour: deliberately NOT the lesson's red/violet/green classification palette
// (that triplet means error/continuation/success elsewhere in this lesson and
// would mislead here). Provider identity instead — teal = the library gives it
// to you, amber = you add it — both 600-range saturated fills that read on both
// themes with white text (per the html-css diagram guide).
//
// Plain HTML + CSS, Astro-scoped <style>. `margin: 0` resets on every node +
// `.not-content` on the root defeat Starlight's injected prose margin-top
// reaching into the flex/grid children. A container query (not a viewport one)
// stacks the two cards when the FIGURE narrows — the docs sidebar shrinks the
// card sharply even on a wide screen.

import Figure from '../../../figures/Figure.astro';

const TEAL = '#0d9488'; // provider: Better Auth (built-in, free)
const AMBER = '#d97706'; // provider: You (added in the rate-limiting chapter)

type Layer = {
  /** Heading of the card. */
  title: string;
  /** Short mono key, the dimension the limit counts on. */
  key: string;
  /** Who ships this layer — the decisive signal. */
  provider: string;
  /** Sub-note under the provider badge. */
  providerNote: string;
  /** Provider colour. */
  color: string;
  /** What this layer actually stops. */
  stops: string;
  /** Where this layer leaks — its hole. */
  hole: string;
};

const layers: Layer[] = [
  {
    title: 'Per-IP rate limit',
    key: 'keyed by IP address',
    provider: 'Better Auth',
    providerNote: 'built-in — on in prod, off in dev',
    color: TEAL,
    stops: 'One IP hammering the endpoint — a credential-stuffing run replayed from a single machine.',
    hole: 'An attacker rotating IPs (a botnet, a proxy pool) sails under it.',
  },
  {
    title: 'Per-email limit',
    key: 'keyed by email address',
    provider: 'You',
    providerNote: 'added in the rate-limiting chapter',
    color: AMBER,
    stops: 'IP-rotation aimed at one known-good account — the guesses pile up wherever they come from.',
    hole: 'One attempt each spread across many accounts stays under it.',
  },
];
---

<Figure>
  <div class="dl not-content">
    {
      layers.map((l) => (
        <article class="dl-card" style={`--c:${l.color}`}>
          <header class="dl-head">
            <span class="dl-title">{l.title}</span>
            <code class="dl-key">{l.key}</code>
          </header>

          <div class="dl-provider">
            <span class="dl-provider-label">Who provides it</span>
            <span class="dl-provider-badge">{l.provider}</span>
            <span class="dl-provider-note">{l.providerNote}</span>
          </div>

          <div class="dl-field dl-field--stops">
            <span class="dl-field-label">Stops</span>
            <span class="dl-field-body">{l.stops}</span>
          </div>

          <div class="dl-field dl-field--hole">
            <span class="dl-field-label">Hole</span>
            <span class="dl-field-body">{l.hole}</span>
          </div>
        </article>
      ))
    }
  </div>

  <Fragment slot="caption">
    Each layer has a hole the other plugs — which is the whole argument for
    running both. The decisive column is *who provides it*: the per-IP limit is
    Better Auth's, the per-email limit is yours to add.
  </Fragment>
</Figure>

<style>
  .dl {
    container-type: inline-size;
    container-name: dl;
    display: flex;
    align-items: stretch;
    gap: 14px;
    width: 100%;
    margin: 0;
    padding-block: 4px;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  .dl-card {
    /* equal-width columns via flex (not grid 1fr) so there is no circular
       sizing against the element's own container size */
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    min-width: 0;
    margin: 0;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    border-top: 4px solid var(--c);
    border-radius: 12px;
    background: var(--sl-color-black, transparent);
    overflow: hidden;
  }

  /* ── header: the limit's name + the dimension it counts on ── */
  .dl-head {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin: 0;
    padding: 12px 14px 10px;
  }
  .dl-title {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--sl-color-white);
  }
  .dl-key {
    align-self: start;
    margin: 0;
    padding: 2px 7px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--c) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 40%, transparent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1.3;
    white-space: nowrap;
    color: var(--sl-color-white);
  }

  /* ── the decisive row: who provides it — a saturated provider band ── */
  .dl-provider {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin: 0;
    padding: 9px 14px 10px;
    background: var(--c);
  }
  .dl-provider-label {
    margin: 0;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.2;
    color: color-mix(in srgb, #fff 78%, var(--c));
  }
  .dl-provider-badge {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 800;
    line-height: 1.15;
    color: #fff;
  }
  .dl-provider-note {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 500;
    line-height: 1.3;
    color: color-mix(in srgb, #fff 86%, var(--c));
  }

  /* ── the two body fields: Stops / Hole, aligned row-for-row across cards ── */
  .dl-field {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin: 0;
    padding: 10px 14px;
  }
  .dl-field--stops {
    flex: 1 1 auto;
  }
  .dl-field--hole {
    border-top: 1px dashed var(--sl-color-gray-5, #cbd5e1);
    /* a faint warning wash so the eye registers "this layer is incomplete" */
    background: color-mix(in srgb, #d97706 9%, transparent);
  }
  .dl-field-label {
    margin: 0;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.2;
    color: var(--sl-color-gray-3, #64748b);
  }
  .dl-field--hole .dl-field-label {
    color: #b45309;
  }
  .dl-field-body {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--sl-color-white);
  }

  /* ── narrow figure (sidebar open, or phones): stack the two cards ── */
  @container dl (max-width: 560px) {
    .dl {
      flex-direction: column;
      max-width: 30rem;
      margin-inline: auto;
    }
  }
</style>
