---
// gauntlet-strip — Chapter 053 Lesson 2 ("Password sign-in"), the figure for
// the section "What the library checks, and the five answers it can give".
//
// Pedagogical goal: draw the sign-in gauntlet so the dual-channel point lands
// VISUALLY — where the request falls out of the strip names the Result, and the
// 2FA outcome forks off the *success* lane, not a failure exit.
//
// The geometry carries two orthogonal signals:
//   - WHERE a branch hangs from encodes CHANNEL.
//       * A drop off the BOTTOM of a GATE = the request "falls out" there as a
//         thrown APIError (rate limit, verify hash, check verified).
//       * The 2FA branch instead hangs off a FORK NODE that sits ON the success
//         lane, downstream of every gate that would already have thrown — "yes"
//         drops to the continuation, "no" carries on to session. So it reads as
//         peeling off the success side, not falling out of a gate.
//   - COLOUR encodes CLASSIFICATION, matched exactly to the outcome-catalog and
//     the Buckets chips so the chapter's figures stay consistent:
//       red = Error, violet = Continuation, green = Success.
// Note that 'email-not-verified' is a thrown failure (straight drop) yet a
// continuation (violet) — colour and geometry deliberately disagree there,
// which is the whole point: thrown ≠ error.
//
// Plain HTML + CSS per the diagrams index (annotated-illustration shape;
// deliberately NOT a diagram engine and NOT ArrowDiagram — no LeaderLines, so
// the figure survives relocation into the Figure lightbox and stays expandable).
// Astro-scoped <style>. `margin: 0` resets on every node + `not-content` on the
// root defeat Starlight's injected prose margins reaching into flex/grid
// children. Theme-aware chrome via Starlight gray vars; the three classification
// hues are 600-range saturated fills with white text, readable on both themes.

import Figure from '../../../figures/Figure.astro';

// Classification palette — identical constants to outcome-catalog.astro.
const RED = '#dc2626'; // Error
const VIOLET = '#7c3aed'; // Continuation
const GREEN = '#16a34a'; // Success

type Gate = {
  /** Gate label on the main lane. */
  label: string;
  /** The outcome this gate emits when the request leaves here. */
  code: string;
  /** Branch colour = classification colour. */
  color: string;
  /** One-word classification, echoed under the chip. */
  klass: 'Error' | 'Continuation' | 'Success';
};

// Gates that drop a branch straight off the bottom (a thrown fall-out). In the
// same order the catalog lists them, so the strip reads left-to-right the way
// the catalog reads top-to-bottom.
const fallOut: Gate[] = [
  { label: 'rate limit', code: 'too-many-attempts', color: RED, klass: 'Error' },
  { label: 'verify hash', code: 'invalid-credentials', color: RED, klass: 'Error' },
  { label: 'check verified', code: 'email-not-verified', color: VIOLET, klass: 'Continuation' },
];
---

<Figure>
  <div class="gs not-content">
    <div class="gs-legend" aria-hidden="true">
      <span class="gs-legend-item"><span class="gs-dot" style={`background:${RED}`}></span>Error</span>
      <span class="gs-legend-item"><span class="gs-dot" style={`background:${VIOLET}`}></span>Continuation</span>
      <span class="gs-legend-item"><span class="gs-dot" style={`background:${GREEN}`}></span>Success</span>
    </div>

    <div class="gs-strip">
      {/* ── The three gates that throw: a straight drop off the bottom.
           Connector chevrons live BETWEEN units (not inside them) so each gate
           and its branch share a centre — the drop falls dead under the gate. */}
      {
        fallOut.map((g) => (
          <>
            <div class="gs-unit" style={`--c:${g.color}`}>
              <div class="gs-gate">{g.label}</div>
              <div class="gs-branch">
                <span class="gs-drop" aria-hidden="true"></span>
                <span class="gs-throws">throws</span>
                <span class="gs-chip">{`'${g.code}'`}</span>
                <span class="gs-klass">{g.klass}</span>
              </div>
            </div>
            <span class="gs-link" aria-hidden="true">›</span>
          </>
        ))
      }

      {/* ── check 2FA: NO fall-out. It clears onto the success lane, which
           THEN reaches a fork — so this gate has no branch of its own. ── */}
      <div class="gs-unit gs-unit--passthru">
        <div class="gs-gate">check 2FA</div>
      </div>
      <span class="gs-link gs-link--ok" aria-hidden="true">›</span>

      {/* ── the fork sits ON the success lane, downstream of every gate that
           would already have thrown. "yes" peels straight DOWN to the
           continuation; "no" carries on right to session. ── */}
      <div class="gs-unit gs-unit--fork" style={`--c:${VIOLET}`}>
        <span class="gs-fork-node">2FA on?</span>
        <div class="gs-branch gs-branch--peel">
          <span class="gs-drop" aria-hidden="true"></span>
          <span class="gs-throws">yes — first factor passed</span>
          <span class="gs-chip">{"'requires-second-factor'"}</span>
          <span class="gs-klass">Continuation</span>
        </div>
      </div>
      <span class="gs-link gs-link--ok gs-link--no" aria-hidden="true">
        ›<span class="gs-no">no</span>
      </span>

      {/* ── session: the success exit ── */}
      <div class="gs-unit gs-unit--end" style={`--c:${GREEN}`}>
        <div class="gs-gate gs-gate--ok">session</div>
        <div class="gs-branch gs-branch--ok">
          <span class="gs-drop gs-drop--ok" aria-hidden="true"></span>
          <span class="gs-throws gs-throws--ok">returns</span>
          <span class="gs-chip gs-chip--ok">'ok'</span>
          <span class="gs-klass">Success</span>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="caption">
    Where the request falls out names the `Result` — and
    `'requires-second-factor'` forks off the *success* exit, not a failure.
  </Fragment>
</Figure>

<style>
  .gs {
    /* container so the layout responds to the FIGURE width, not the viewport —
       the figure card narrows sharply when the docs sidebar is open even on a
       wide screen, which a viewport media query would miss */
    container-type: inline-size;
    container-name: gs;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin: 0;
    padding-block: 4px;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── legend ─────────────────────────────────────────────── */
  .gs-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px 18px;
    margin: 0;
  }
  .gs-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--sl-color-gray-2, #475569);
  }
  .gs-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    margin: 0;
  }

  /* ── the main lane: a single non-wrapping row of gate-units ──
     The left-to-right gauntlet IS the lesson, so the lane must never wrap (a
     gate on its own line reads as broken). Units therefore size to their GATE,
     not their chip — chips below are width-capped and wrap internally instead of
     forcing the column wider. */
  .gs-strip {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    justify-content: center;
    gap: 2px;
    margin: 0;
    width: 100%;
  }

  /* a unit = gate on the lane + its branch below; the gate is CENTRED so the
     chip beneath it shares the same centre and the drop falls dead under it */
  .gs-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 0 1 auto;
    min-width: 0;
    margin: 0;
  }

  /* chevrons are bare flex children of the strip; give them the gate's band
     height and pin them to the top so they centre on the lane, not the row */
  .gs-link {
    align-self: flex-start;
    display: flex;
    align-items: center;
    min-height: 36px;
  }

  /* the fork node lives at the top of its own unit; the same band height puts
     its centre on the lane, level with every gate */
  .gs-fork-node {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
  }

  .gs-gate {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 7px 9px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-4, #94a3b8);
    background: var(--sl-color-bg, transparent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    color: var(--sl-color-white, #1e293b);
    margin: 0;
  }

  /* session — the success exit, the only saturated gate on the lane */
  .gs-gate--ok {
    border: 1.5px solid var(--c);
    background: color-mix(in srgb, var(--c) 14%, var(--sl-color-bg, transparent));
    color: var(--sl-color-white, #14532d);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--c) 30%, transparent);
  }

  /* on-lane chevron between gates — the request flowing right */
  .gs-link {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1;
    color: var(--sl-color-gray-4, #94a3b8);
    margin: 0;
  }
  /* the chevron after the fork is the SUCCESS lane → tint it green */
  .gs-link--ok {
    color: var(--c, #16a34a);
    color: color-mix(in srgb, #16a34a 80%, var(--sl-color-gray-4));
  }

  /* ── a straight drop off the bottom: a thrown fall-out ──── */
  .gs-branch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 2px 0 0;
    margin: 0;
  }

  /* the vertical line + arrowhead, drawn in the branch colour */
  .gs-drop {
    width: 0;
    height: 26px;
    border-left: 2px solid var(--c);
    position: relative;
    margin: 0;
  }
  .gs-drop::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -1px;
    transform: translateX(-50%);
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid var(--c);
  }

  .gs-throws {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.2;
    color: var(--c);
    margin: 0;
  }

  /* the outcome chip — filled in the classification colour, white text. Width
     is capped and the code wraps internally so a long label (e.g.
     'requires-second-factor') never widens the gate column and forces a strip
     wrap. */
  .gs-chip {
    box-sizing: border-box;
    width: 8.5rem;
    padding: 4px 8px;
    border-radius: 10px;
    background: var(--c);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    white-space: normal;
    overflow-wrap: anywhere;
    color: #fff;
    margin: 0;
  }
  /* the success chip is short — let it hug its text instead of the fixed width */
  .gs-chip--ok {
    width: auto;
  }

  .gs-klass {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.2;
    color: var(--c);
    margin: 0;
  }

  /* ── the 2FA fork: peels off the success lane ───────────── */
  .gs-unit--fork {
    margin: 0;
  }

  /* the small fork marker that sits ON the lane, after check 2FA */
  .gs-fork-node {
    box-sizing: border-box;
    padding: 4px 8px;
    border-radius: 999px;
    border: 1px dashed var(--sl-color-gray-3, #64748b);
    font-size: 0.64rem;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    color: var(--sl-color-gray-2, #475569);
    background: var(--sl-color-bg, transparent);
    margin: 0;
  }

  /* the violet continuation branch drops straight DOWN from the fork node — the
     same drop shape as a failure, but it leaves the *success* lane downstream of
     every gate that would already have thrown, so its meaning is carried by
     position + colour + the "yes" label, not by a different arrow. */
  .gs-branch--peel .gs-throws {
    white-space: nowrap;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 600;
  }

  /* the "no" label tucked under the success chevron leaving the fork */
  .gs-link--no {
    flex-direction: column;
    gap: 0;
    line-height: 1;
  }
  .gs-no {
    font-size: 0.56rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, #16a34a 80%, var(--sl-color-gray-3));
    margin: 0;
  }

  /* success branch styling (the 'ok' drop under session) */
  .gs-branch--ok {
    padding: 2px 0 0 0;
  }

  /* ── medium container: keep the single-row lane, trim every element so five
        gates + chips still fit without overlapping ── */
  @container gs (max-width: 760px) {
    .gs-strip {
      gap: 0;
    }
    .gs-chip {
      width: 5.8rem;
      font-size: 0.6rem;
      padding: 3px 5px;
    }
    .gs-gate {
      font-size: 0.68rem;
      padding: 5px 4px;
    }
    .gs-fork-node {
      font-size: 0.56rem;
      padding: 4px 5px;
    }
    .gs-link {
      font-size: 1rem;
    }
    .gs-branch--peel .gs-throws {
      white-space: normal;
    }
  }

  /* ── narrow container (phones, or the article column with the sidebar open):
        the horizontal lane can't hold five columns, so STACK it. Each gate
        becomes a row — gate on the left, its outcome chip on the right — read
        top-to-bottom. The fork nuance is carried by colour + the class label
        (and the catalog above); the chevrons are dropped to avoid rotating
        their composite "yes"/"no" text. ── */
  @container gs (max-width: 560px) {
    .gs-strip {
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: stretch;
      gap: 6px;
      max-width: 22rem;
    }
    /* down-chevrons between rows would need rotating (and the no/yes composite
       breaks), so hide the connectors and let stack order imply the flow */
    .gs-link {
      display: none;
    }
    .gs-unit {
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 10px;
      width: 100%;
      padding: 6px 8px;
      border: 1px solid var(--sl-color-gray-5, #cbd5e1);
      /* each row's left rail is its classification colour (carried on the unit);
         the pass-through gate has no outcome, so it falls back to neutral grey */
      border-left: 4px solid var(--c, var(--sl-color-gray-4, #94a3b8));
      border-radius: 8px;
    }
    .gs-gate,
    .gs-fork-node {
      flex: 0 0 7.5rem;
      min-height: 0;
      justify-content: flex-start;
      border: 0;
      background: transparent;
      box-shadow: none;
      padding: 0;
      font-size: 0.78rem;
    }
    .gs-fork-node {
      border: 0;
    }
    .gs-branch,
    .gs-branch--peel,
    .gs-branch--ok {
      flex-direction: row;
      align-items: center;
      gap: 8px;
      padding: 0;
    }
    /* the vertical drop-arrow makes no sense beside the gate — hide it */
    .gs-drop {
      display: none;
    }
    .gs-throws {
      display: none;
    }
    .gs-chip {
      width: auto;
      max-width: 12rem;
      font-size: 0.72rem;
    }
    .gs-klass {
      margin-left: auto;
    }
  }
</style>
