---
// signin-flow-strip — the single horizontal pipeline strip reused across all six
// steps of the `signin-happy-path` DiagramSequence (Chapter 053 L2, "Password
// sign-in"). The twin of L1's signup-flow-strip: it is the *same* six-node strip
// every frame and only which node is LIT changes (`active`), plus a fixed-height
// status row below that reports the two facts this lesson keeps returning to —
// whether a session exists yet, and whether the session token was rotated. Keeping
// the geometry identical (and reserving the status row on every render) is what
// lets the DiagramSequence stage size once and never reflow as the reader scrubs.
//
// Encoding (left -> right is time, one successful sign-in press):
//   Submit -> Parse -> Verify hash -> Checks pass -> Rotate session -> Redirect
//   - Exactly one node is lit per step; the lit node carries the SECTION's colour
//     so the strip reads as continuous with the rest of the lesson and matches L1:
//       parse        -> BLUE   (the Zod parse / normalize / coerce seam)
//       verify hash  -> ORANGE (the single library call, auth.api.signInEmail)
//       checks pass  -> ORANGE (still inside the library call's gauntlet)
//       rotate / ok  -> GREEN  (a fresh session + the returned ok)
//     Submit and Redirect are neutral slate (no section colour of their own).
//   - Past nodes read as "done" (muted ink); upcoming nodes are faint.
//   - A status row UNDER the strip reserves fixed height every step and reports:
//       • session: "none yet" until Rotate session, then "fresh session issued" —
//         the happy-path payoff, made visible and persistent.
//       • a green "fresh token — pre-auth value is dead" note from the rotate step,
//         the session-fixation defense the surrounding prose names.
//
// Pure HTML + CSS, inline style strings only (sibling-component house style,
// verbatim atoms from signup-flow-strip). color-scheme pinned light so the
// hand-picked accent tints survive dark mode; margin:0 defeats Starlight's
// injected prose margins; box-sizing:border-box throughout.

type Stage = 'submit' | 'parse' | 'verify' | 'checks' | 'rotate' | 'redirect';

interface Props {
	// Which node is lit this step.
	active: Stage;
}

const { active } = Astro.props;

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette — slate ink + the chapter's annotated accents, verbatim from L1's
// flow strip: blue parse, orange the lone library call, green the issued session.
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const INK_FAINT = '#94a3b8'; // slate-400 — upcoming nodes
const SURFACE = '#ffffff';
const GRID = '#e2e8f0'; // slate-200 — soft dividers / idle borders

const BLUE = '#2563eb'; // blue-600 — parse
const ORANGE = '#ea580c'; // orange-600 — library call
const GREEN = '#16a34a'; // green-600 — session / returned ok
const SLATE = '#475569'; // slate-600 — neutral nodes (submit / redirect)

// The six nodes, in order. `key` drives lit/done state; `accent` is the colour the
// node lights to; `gloss` is the one-line "what happens here" under the label.
interface Node {
	key: Stage;
	label: string;
	accent: string;
	gloss: string;
}

const nodes: Node[] = [
	{ key: 'submit', label: 'Submit', accent: SLATE, gloss: 'email · password · remember' },
	{ key: 'parse', label: 'Parse', accent: BLUE, gloss: 'Zod · lowercase · coerce' },
	{ key: 'verify', label: 'Verify hash', accent: ORANGE, gloss: 'scrypt · constant time' },
	{ key: 'checks', label: 'Checks pass', accent: ORANGE, gloss: 'rate · verified · 2FA' },
	{ key: 'rotate', label: 'Rotate session', accent: GREEN, gloss: 'fresh token · cookie set' },
	{ key: 'redirect', label: 'Redirect', accent: SLATE, gloss: 'ok({ redirectTo })' },
];

const activeIdx = nodes.findIndex((n) => n.key === active);

// ---- atoms -----------------------------------------------------------------

const stage = `display: flex; flex-direction: column; align-items: stretch; gap: 0; margin: 0; padding: 6px 2px 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The strip: a flex row of node cells with thin connectors between them.
const strip = `display: flex; align-items: stretch; gap: 0; margin: 0; width: 100%;`;

// A node cell. State drives ink + border + fill:
//   lit      -> accent border, accent wash, accent ink, soft lift
//   done     -> faint border, white fill, muted ink (a step already passed)
//   upcoming -> faint border, white fill, faint ink
const cell = (n: Node, idx: number) => {
	const isLit = idx === activeIdx;
	const isDone = idx < activeIdx;
	const border = isLit ? n.accent : GRID;
	const bg = isLit ? `color-mix(in srgb, ${n.accent} 9%, ${SURFACE})` : SURFACE;
	const lift = isLit ? ` box-shadow: 0 2px 9px color-mix(in srgb, ${n.accent} 24%, transparent);` : '';
	const weight = isLit ? '2px' : '1.5px';
	return (
		`box-sizing: border-box; flex: 1 1 0; min-width: 0; display: flex; flex-direction: column;` +
		` align-items: center; justify-content: center; gap: 2px; margin: 0; padding: 9px 6px;` +
		` border: ${weight} solid ${border}; border-radius: 10px; background: ${bg};` +
		` opacity: ${isDone || isLit ? 1 : 0.72};${lift}`
	);
};

const stepNum = (n: Node, idx: number) => {
	const isLit = idx === activeIdx;
	const isDone = idx < activeIdx;
	const color = isLit ? n.accent : isDone ? INK_SOFT : INK_FAINT;
	return `margin: 0; font-family: ${mono}; font-size: 9px; font-weight: 800; line-height: 1; letter-spacing: 0.04em; color: ${color};`;
};

const nodeLabel = (n: Node, idx: number) => {
	const isLit = idx === activeIdx;
	const isDone = idx < activeIdx;
	const color = isLit ? n.accent : isDone ? INK : INK_FAINT;
	return `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: ${isLit ? 800 : 700}; line-height: 1.2; text-align: center; color: ${color};`;
};

const nodeGloss = (n: Node, idx: number) => {
	const isLit = idx === activeIdx;
	const color = isLit ? `color-mix(in srgb, ${n.accent} 78%, ${INK})` : INK_FAINT;
	return `margin: 0; font-family: ${mono}; font-size: 9px; font-weight: 600; line-height: 1.2; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; color: ${color};`;
};

// Connector between two nodes: a short rule with a chevron. It "fills" (darkens)
// once the step to its LEFT is done, so progress reads left-to-right at a glance.
const connector = (idx: number) => {
	// connector idx sits between node idx and node idx+1
	const passed = idx < activeIdx;
	const color = passed ? INK_SOFT : INK_FAINT;
	const weight = passed ? 700 : 500;
	return `flex: 0 0 16px; display: flex; align-items: center; justify-content: center; margin: 0; font-size: 13px; font-weight: ${weight}; line-height: 1; color: ${color};`;
};

// ---- the status row under the strip ----------------------------------------
// Reserved on EVERY step (fixed height) so the stage never reflows. It carries the
// two facts the lesson keeps naming. Both chips are always present; their emphasis
// changes by step so nothing appears/disappears (which would shift the strip).

// session chip: faint until a real session exists, then a steady positive from the
// rotate step onward — the happy path's payoff.
const sessionLive = activeIdx >= nodes.findIndex((n) => n.key === 'rotate');
// rotation chip: lights from the rotate step onward, where a fresh token replaces
// any pre-auth value (the session-fixation defense).
const rotated = activeIdx >= nodes.findIndex((n) => n.key === 'rotate');

const statusRow = `display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; margin: 0; padding: 9px 4px 3px; min-height: 40px;`;

const chipBase = `box-sizing: border-box; display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 3px 9px; border-radius: 999px; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.3; white-space: nowrap;`;

const sessionChip = sessionLive
	? `${chipBase} border: 1px solid ${GREEN}; background: color-mix(in srgb, ${GREEN} 10%, ${SURFACE}); color: color-mix(in srgb, ${GREEN} 22%, ${INK});`
	: `${chipBase} border: 1px dashed ${INK_FAINT}; background: ${SURFACE}; color: ${INK_FAINT};`;

const rotateChip = rotated
	? `${chipBase} border: 1px solid ${GREEN}; background: color-mix(in srgb, ${GREEN} 10%, ${SURFACE}); color: color-mix(in srgb, ${GREEN} 22%, ${INK});`
	: `${chipBase} border: 1px dashed ${INK_FAINT}; background: ${SURFACE}; color: ${INK_FAINT};`;

const dot = (color: string) =>
	`display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: ${color}; margin: 0; flex: 0 0 auto;`;
---

<div style={stage}>
	{/* ----- THE STRIP: identical geometry every step ----- */}
	<div style={strip}>
		{
			nodes.map((n, idx) => (
				<Fragment>
					{idx > 0 && (
						<span style={connector(idx - 1)} aria-hidden="true">
							&#8250;
						</span>
					)}
					<div style={cell(n, idx)} aria-current={idx === activeIdx ? 'step' : undefined}>
						<span style={stepNum(n, idx)}>{idx + 1}</span>
						<span style={nodeLabel(n, idx)}>{n.label}</span>
						<span style={nodeGloss(n, idx)}>{n.gloss}</span>
					</div>
				</Fragment>
			))
		}
	</div>

	{/* ----- STATUS ROW: reserved every step, reports the two recurring facts ----- */}
	<div style={statusRow}>
		<span style={sessionChip}>
			<span style={dot(sessionLive ? GREEN : INK_FAINT)} aria-hidden="true"></span>
			{sessionLive ? 'fresh session issued' : 'no session yet'}
		</span>
		<span style={rotateChip}>
			<span style={dot(rotated ? GREEN : INK_FAINT)} aria-hidden="true"></span>
			{rotated ? 'fresh token — pre-auth value is dead' : 'token: not minted yet'}
		</span>
	</div>
</div>
