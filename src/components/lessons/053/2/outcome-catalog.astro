---
// outcome-catalog — Chapter 053 Lesson 2 ("Password sign-in"), the figure for
// the section "What the library checks, and the five answers it can give".
//
// Pedagogical goal: present the closed set of five sign-in outcomes as a
// scannable catalog (one row each), so the student reads them as a set of
// *destinations* rather than prose. The load-bearing signal is the
// CLASSIFICATION of each outcome — Error / Continuation / Success — which the
// surrounding lesson turns into the Buckets keystone exercise and the gauntlet
// figure. Each row therefore carries a classification colour twice: a left
// accent rail and a chip in the last column, so the three-way split is legible
// at a glance.
//
// The second non-obvious column is CHANNEL (thrown vs resolved): four outcomes
// arrive as a thrown APIError caught in the action's catch, but
// 'requires-second-factor' arrives on the *resolved* (success) value with no
// throw. The catalog marks that channel explicitly because the dual-channel
// read is the structural point the action is built around.
//
// Plain HTML + CSS per the diagram index's "compact table / color-coded
// segments" row, wrapped in <Figure>. Scoped <style> with a CSS grid so the
// five columns align across rows; `margin: 0` resets defeat Starlight's
// injected prose margin-top reaching into grid children.

import Figure from '../../../figures/Figure.astro';

// Classification palette — saturated 600-range, white text, reads on both
// themes (per the html-css diagram guide). Matches the lesson's stated palette:
// Error = red, Continuation = violet, Success = green. Reused by the gauntlet
// strip and the Buckets chips so the chapter's figures stay consistent.
const RED = '#dc2626'; // Error
const VIOLET = '#7c3aed'; // Continuation
const GREEN = '#16a34a'; // Success

type Outcome = {
  /** The discriminant the action / form reasons about. */
  code: string;
  /** What tripped this gate — terse. */
  tripped: string;
  /** Which channel it arrives on. */
  channel: 'thrown' | 'resolved';
  /** Extra detail under the channel chip (status code, the odd-one-out note). */
  channelNote: string;
  /** What the user is shown. */
  userSees: string;
  /** The senior reframe: error / continuation / success. */
  klass: 'Error' | 'Continuation' | 'Success';
  /** Classification colour. */
  color: string;
};

// Authored top-to-bottom in the gauntlet's fall-out order, so the catalog and
// the gauntlet figure tell the same left-to-right / top-to-bottom story.
const outcomes: Outcome[] = [
  {
    code: 'too-many-attempts',
    tripped: 'Per-IP rate limiter tripped',
    channel: 'thrown',
    channelNote: '429 · retry-after',
    userSees: 'Too many attempts, try again in a moment',
    klass: 'Error',
    color: RED,
  },
  {
    code: 'invalid-credentials',
    tripped: 'Wrong password OR unknown email',
    channel: 'thrown',
    channelNote: 'INVALID_EMAIL_OR_PASSWORD · 401',
    userSees: 'Wrong email or password',
    klass: 'Error',
    color: RED,
  },
  {
    code: 'email-not-verified',
    tripped: 'Correct password, emailVerified still false',
    channel: 'thrown',
    channelNote: 'EMAIL_NOT_VERIFIED · 403',
    userSees: 'The “check your inbox” view',
    klass: 'Continuation',
    color: VIOLET,
  },
  {
    code: 'requires-second-factor',
    tripped: 'Credentials valid, 2FA enabled',
    channel: 'resolved',
    channelNote: 'the odd one out · { twoFactorRedirect: true }',
    userSees: 'The 2FA code prompt',
    klass: 'Continuation',
    color: VIOLET,
  },
  {
    code: 'ok',
    tripped: 'Every gate cleared, no 2FA',
    channel: 'resolved',
    channelNote: 'session row · fresh token · cookie set',
    userSees: 'The dashboard',
    klass: 'Success',
    color: GREEN,
  },
];
---

<Figure>
  <div class="oc">
    <div class="oc-head" aria-hidden="true">
      <span>Outcome</span>
      <span>What tripped it</span>
      <span>Channel</span>
      <span>User sees</span>
      <span class="oc-head-class">Class</span>
    </div>

    <ul class="oc-rows">
      {
        outcomes.map((o) => (
          <li class="oc-row" style={`--accent: ${o.color}`}>
            <span class="oc-code-cell">
              <code class="oc-code">{`'${o.code}'`}</code>
            </span>
            <span class="oc-tripped">{o.tripped}</span>
            <span class="oc-channel-cell">
              <span class={`oc-channel oc-channel--${o.channel}`}>{o.channel}</span>
              <span class="oc-channel-note">{o.channelNote}</span>
            </span>
            <span class="oc-sees">{o.userSees}</span>
            <span class="oc-class-cell">
              <span class="oc-class">{o.klass}</span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <Fragment slot="caption">
    Five outcomes, one row each — and the column that matters most is the last
    one: two of these *look* like failures but are **continuations**, and
    `'requires-second-factor'` is the lone outcome that arrives on the
    *resolved* (success) channel, not a thrown error.
  </Fragment>
</Figure>

<style>
  .oc {
    --col-code: 13.5rem;
    --col-trip: 1.1fr;
    --col-chan: 1.15fr;
    --col-sees: 1fr;
    --col-class: 7.5rem;
    margin: 0;
    width: 100%;
    max-width: 900px;
    margin-inline: auto;
    padding-block: 0.25rem;
  }

  .oc-head {
    display: grid;
    grid-template-columns:
      var(--col-code) var(--col-trip) var(--col-chan) var(--col-sees)
      var(--col-class);
    gap: 0.6rem;
    align-items: end;
    margin: 0;
    padding: 0 0.7rem 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .oc-head > span {
    margin: 0;
  }

  .oc-head-class {
    text-align: center;
  }

  .oc-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .oc-row {
    display: grid;
    grid-template-columns:
      var(--col-code) var(--col-trip) var(--col-chan) var(--col-sees)
      var(--col-class);
    gap: 0.6rem;
    align-items: center;
    margin: 0;
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--sl-color-gray-5);
    border-left: 4px solid var(--accent);
    border-radius: 0.55rem;
    background: var(--sl-color-black);
  }

  .oc-row > span {
    margin: 0;
    min-width: 0;
  }

  .oc-code-cell {
    margin: 0;
  }

  .oc-code {
    display: inline-block;
    margin: 0;
    padding: 0.26rem 0.5rem;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    background: var(--accent);
    border-radius: 0.4rem;
    white-space: nowrap;
  }

  .oc-tripped,
  .oc-sees {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.35;
    color: var(--sl-color-white);
  }

  .oc-channel-cell {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin: 0;
  }

  .oc-channel {
    align-self: start;
    margin: 0;
    padding: 0.14rem 0.45rem;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.2;
    border-radius: 0.35rem;
    white-space: nowrap;
  }

  /* Channel is neutral chrome — it must not compete with the classification
     colour. Thrown = a filled neutral pill; resolved = an outlined pill, so the
     odd-one-out (resolved) reads as visually distinct without stealing a hue. */
  .oc-channel--thrown {
    color: var(--sl-color-gray-1);
    background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    border: 1px solid var(--sl-color-gray-4);
  }

  .oc-channel--resolved {
    color: var(--sl-color-white);
    background: transparent;
    border: 1px dashed var(--sl-color-gray-3);
  }

  .oc-channel-note {
    margin: 0;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.64rem;
    line-height: 1.3;
    color: var(--sl-color-gray-3);
    word-break: break-word;
  }

  .oc-class-cell {
    display: flex;
    justify-content: center;
    margin: 0;
  }

  .oc-class {
    display: inline-block;
    margin: 0;
    padding: 0.26rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.2;
    color: #fff;
    background: var(--accent);
    border-radius: 999px;
    white-space: nowrap;
  }

  /* Stack each row into a labelled card on narrow viewports, where five text
     columns can't coexist. The code pill and the classification chip stay on
     the top line so the outcome and its class read first. */
  @media (max-width: 640px) {
    .oc {
      max-width: 26rem;
    }

    .oc-head {
      display: none;
    }

    .oc-row {
      grid-template-columns: 1fr auto;
      gap: 0.35rem 0.6rem;
      align-items: center;
    }

    .oc-code-cell {
      grid-column: 1;
    }

    .oc-class-cell {
      grid-column: 2;
      justify-content: end;
    }

    .oc-tripped,
    .oc-channel-cell,
    .oc-sees {
      grid-column: 1 / -1;
    }

    .oc-channel-cell {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.4rem;
    }
  }
</style>
