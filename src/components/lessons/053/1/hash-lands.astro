---
// hash-lands — Chapter 053 Lesson 1, "Password sign-up", a one-glance callout
// for the "The library owns the hash" section.
//
// The single idea, made visual: the password hash lands on `account`, NEVER on
// `user`. Two row-cards side by side echo the Ch 052 ER diagram (user = "who you
// are", account = "how you prove it"). The password peels off the sign-up form
// and an arrow carries it PAST the `user` card into `account` — the geometry
// itself says the secret skips the identity row. `user` is deliberately drawn
// neutral with a "no secret here" note; `account` is the saturated accent and
// the only card carrying highlighted rows (`providerId: 'credential'`,
// `password: <scrypt hash>`).
//
// Plain HTML + CSS per the diagrams index (annotated-illustration shape;
// deliberately NOT a diagram engine and NOT ArrowDiagram, whose LeaderLines
// can't be relocated into the Figure lightbox). Astro-scoped <style>, no
// LeaderLines → survives the lightbox, so the wrapping <Figure> stays expandable.
// `margin: 0` resets on every node defeat Starlight's injected prose margins;
// `not-content` on the root does the same. Theme-aware chrome via Starlight gray
// vars (flips light/dark); the `account` accent is violet-600 — the section's
// hinge colour — readable on both backgrounds.
---

<div class="hl not-content">
	{/* ───────── LEFT: the password leaving the form ───────── */}
	<div class="hl-source">
		<span class="hl-source-tag">from the sign-up form</span>
		<code class="hl-source-field">password</code>
	</div>

	{/* connector: the password flows right, past `user`, into `account` */}
	<div class="hl-flow" aria-hidden="true">
		<span class="hl-flow-label">hashed by the library</span>
		<span class="hl-flow-arrow">⟶</span>
	</div>

	{/* ───────── RIGHT: the two rows, side by side ───────── */}
	<div class="hl-rows">
		{/* user — who you are. No secret on it. Neutral, muted. */}
		<div class="hl-card hl-card--user">
			<div class="hl-card-head">
				<code class="hl-card-name">user</code>
				<span class="hl-card-role">who you are</span>
			</div>
			<div class="hl-card-body">
				<span class="hl-row">email</span>
				<span class="hl-row">name</span>
				<span class="hl-row hl-row--empty">no password — no secret here</span>
			</div>
		</div>

		{/* account — how you prove it. The hash lands here. Accent. */}
		<div class="hl-card hl-card--account">
			<div class="hl-card-head">
				<code class="hl-card-name">account</code>
				<span class="hl-card-role">how you prove it</span>
			</div>
			<div class="hl-card-body">
				<span class="hl-row hl-row--mark">
					<span class="hl-key">providerId</span>
					<span class="hl-val">'credential'</span>
				</span>
				<span class="hl-row hl-row--mark">
					<span class="hl-key">password</span>
					<span class="hl-val">&lt;scrypt hash&gt;</span>
				</span>
			</div>
		</div>
	</div>
</div>

<style>
	.hl {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 14px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── LEFT: the password leaving the form ─────────────── */
	.hl-source {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		flex: 0 0 auto;
		padding: 10px 14px;
		border-radius: 9px;
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}
	.hl-source-tag {
		font-size: 0.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.hl-source-field {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.86rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	/* ── connector: the password → account ───────────────── */
	.hl-flow {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		flex: 0 0 auto;
		margin: 0;
	}
	.hl-flow-label {
		font-size: 0.58rem;
		font-weight: 600;
		line-height: 1.2;
		text-align: center;
		color: var(--sl-color-gray-3, #64748b);
		max-width: 6.5rem;
		margin: 0;
	}
	.hl-flow-arrow {
		font-size: 1.5rem;
		font-weight: 700;
		line-height: 1;
		color: #7c3aed; /* violet-600 — the section's hinge colour */
		margin: 0;
	}

	/* ── RIGHT: the two row-cards ────────────────────────── */
	.hl-rows {
		display: flex;
		align-items: stretch;
		gap: 12px;
		flex: 0 1 auto;
		min-width: 0;
		margin: 0;
	}

	.hl-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		flex: 0 1 13rem;
		min-width: 0;
		border-radius: 10px;
		overflow: hidden;
		margin: 0;
	}

	/* user: neutral, recessive — the identity row holds no secret */
	.hl-card--user {
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
	}
	/* account: the accent card — this is where the hash lands */
	.hl-card--account {
		border: 1.5px solid #7c3aed; /* violet-600 */
		background: color-mix(in srgb, #7c3aed 8%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(124, 58, 237, 0.22);
	}

	.hl-card-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 7px 12px;
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.hl-card--account .hl-card-head {
		border-bottom-color: color-mix(in srgb, #7c3aed 35%, transparent);
		background: color-mix(in srgb, #7c3aed 12%, transparent);
	}
	.hl-card-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.hl-card-role {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.hl-card-body {
		display: flex;
		flex-direction: column;
		gap: 5px;
		padding: 9px 12px;
		margin: 0;
	}

	.hl-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.72rem;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	/* the "no secret here" note on user — muted, italic, not monospace */
	.hl-row--empty {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.64rem;
		font-style: italic;
		color: var(--sl-color-gray-3, #64748b);
	}
	/* the two highlighted rows on account — the secret and its discriminator */
	.hl-row--mark {
		color: var(--sl-color-white, #1e293b);
		font-weight: 600;
	}
	.hl-key {
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.hl-val {
		color: #6d28d9; /* violet-700 — the value that lands here */
		white-space: nowrap;
		margin: 0;
	}

	/* ── narrow viewports: stack source over rows, rotate arrow ── */
	@media (max-width: 640px) {
		.hl {
			flex-direction: column;
			align-items: stretch;
			gap: 10px;
		}
		.hl-source {
			align-self: center;
		}
		.hl-flow {
			flex-direction: row;
			gap: 8px;
		}
		.hl-flow-label {
			max-width: none;
		}
		.hl-flow-arrow {
			transform: rotate(90deg);
			display: block;
		}
		.hl-rows {
			width: 100%;
		}
		.hl-card {
			flex: 1 1 0;
		}
	}
</style>
