---
// rows-after-signup — Chapter 053 Lesson 1, "Password sign-up", the closing
// payoff of "The success state: check your inbox".
//
// The single idea, made concrete: the instant the success page renders, exactly
// THREE rows exist in the database — and a session deliberately does NOT. Three
// solid row-cards carry the rows that were written; a fourth, ghosted and
// struck-through, makes the absence of a session visible (the whole point of
// `autoSignIn: false`).
//
// Colour continues the chapter's annotated palette (the same one the Ch 052 ER
// diagram and the sibling `hash-lands` figure speak):
//   • user         → blue   — the identity row.
//   • account      → violet — the credential row (matches `hash-lands`: this is
//                              where the hash lands).
//   • verification → orange — the lone, no-FK table; a distinct accent because
//                              it stands apart from the user, owned by no one.
//   • session      → gray, ghosted — the row that is NOT written.
// Each card carries one or two highlighted columns (the load-bearing values the
// lesson keeps naming) plus a one-line annotation echoing the prose.
//
// Plain HTML + CSS per the diagrams index (annotated-illustration shape;
// deliberately NOT a diagram engine and NOT ArrowDiagram, whose LeaderLines
// can't be relocated into the Figure lightbox). Astro-scoped <style>, no
// LeaderLines → survives the lightbox, so the wrapping <Figure> stays
// expandable. `margin: 0` resets on every node defeat Starlight's injected prose
// margins; `not-content` on the root does the same. Theme-aware chrome via
// Starlight gray vars (flips light/dark); the accents read on both backgrounds.

interface Card {
	name: string;
	role: string;
	accent: 'blue' | 'violet' | 'orange';
	rows: { key: string; val: string }[];
	note: string;
}

const cards: Card[] = [
	{
		name: 'user',
		role: 'who they are',
		accent: 'blue',
		rows: [{ key: 'emailVerified', val: 'false' }],
		note: 'The identity row. Created, but not yet confirmed.',
	},
	{
		name: 'account',
		role: 'how they prove it',
		accent: 'violet',
		rows: [
			{ key: 'providerId', val: "'credential'" },
			{ key: 'password', val: '<scrypt hash>' },
		],
		note: 'The credential row. Password hashed by the library.',
	},
	{
		name: 'verification',
		role: 'pending token',
		accent: 'orange',
		rows: [{ key: 'identifier', val: '<email>' }],
		note: 'The pending email-verification token. Owned by no user yet.',
	},
];
---

<div class="rs not-content">
	<div class="rs-exists">
		{/* the three rows the sign-up actually wrote */}
		<span class="rs-band rs-band--exists">written — 3 rows</span>
		<div class="rs-cards">
			{
				cards.map((card) => (
					<div class={`rs-card rs-card--${card.accent}`}>
						<div class="rs-card-head">
							<code class="rs-card-name">{card.name}</code>
							<span class="rs-card-role">{card.role}</span>
						</div>
						<div class="rs-card-body">
							{card.rows.map((row) => (
								<span class="rs-row">
									<span class="rs-key">{row.key}</span>
									<span class="rs-val">{row.val}</span>
								</span>
							))}
						</div>
						<p class="rs-note">{card.note}</p>
					</div>
				))
			}
		</div>
	</div>

	{/* the row that is deliberately NOT written — the absence made concrete */}
	<div class="rs-absent">
		<span class="rs-band rs-band--absent">not written</span>
		<div class="rs-card rs-card--ghost" aria-label="session row does not exist">
			<div class="rs-card-head">
				<code class="rs-card-name rs-card-name--ghost">session</code>
				<span class="rs-card-role">no login yet</span>
			</div>
			<div class="rs-card-body">
				<span class="rs-row rs-row--ghost">does not exist</span>
			</div>
			<p class="rs-note rs-note--ghost">
				No session is issued at sign-up — <code>autoSignIn</code> is off.
			</p>
		</div>
	</div>
</div>

<style>
	.rs {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 18px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* the two groups: the 3 written rows, and the 1 absent session */
	.rs-exists,
	.rs-absent {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
		min-width: 0;
	}
	.rs-exists {
		flex: 1 1 26rem;
	}
	.rs-absent {
		flex: 0 1 13rem;
	}

	/* the small group label above each cluster */
	.rs-band {
		align-self: flex-start;
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		line-height: 1.2;
		padding: 2px 8px;
		border-radius: 999px;
		margin: 0;
	}
	.rs-band--exists {
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #e2e8f0);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
	}
	.rs-band--absent {
		color: var(--sl-color-gray-3, #64748b);
		background: transparent;
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
	}

	/* the three solid cards sit in a row, wrap on narrow viewports */
	.rs-cards {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		gap: 14px;
		margin: 0;
		min-width: 0;
	}

	.rs-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		flex: 1 1 0;
		min-width: 11rem;
		border-radius: 10px;
		overflow: hidden;
		margin: 0;
	}

	/* ── per-table accents — continue the chapter's annotated palette ── */
	.rs-card--blue {
		border: 1.5px solid #2563eb; /* blue-600 — the identity row */
		background: color-mix(in srgb, #2563eb 7%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(37, 99, 235, 0.16);
	}
	.rs-card--violet {
		border: 1.5px solid #7c3aed; /* violet-600 — the credential row (matches hash-lands) */
		background: color-mix(in srgb, #7c3aed 8%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(124, 58, 237, 0.2);
	}
	.rs-card--orange {
		border: 1.5px solid #ea580c; /* orange-600 — the lone, no-FK token */
		background: color-mix(in srgb, #ea580c 7%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(234, 88, 12, 0.16);
	}

	.rs-card-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 7px 12px;
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.rs-card--blue .rs-card-head {
		border-bottom-color: color-mix(in srgb, #2563eb 32%, transparent);
		background: color-mix(in srgb, #2563eb 11%, transparent);
	}
	.rs-card--violet .rs-card-head {
		border-bottom-color: color-mix(in srgb, #7c3aed 35%, transparent);
		background: color-mix(in srgb, #7c3aed 12%, transparent);
	}
	.rs-card--orange .rs-card-head {
		border-bottom-color: color-mix(in srgb, #ea580c 32%, transparent);
		background: color-mix(in srgb, #ea580c 11%, transparent);
	}

	.rs-card-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.rs-card-role {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.rs-card-body {
		display: flex;
		flex-direction: column;
		gap: 5px;
		padding: 9px 12px;
		margin: 0;
	}

	.rs-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.72rem;
		line-height: 1.3;
		margin: 0;
	}
	.rs-key {
		color: var(--sl-color-white, #1e293b);
		font-weight: 600;
		margin: 0;
	}
	.rs-val {
		white-space: nowrap;
		margin: 0;
	}
	/* the highlighted value picks up each card's accent */
	.rs-card--blue .rs-val {
		color: #1d4ed8; /* blue-700 */
	}
	.rs-card--violet .rs-val {
		color: #6d28d9; /* violet-700 */
	}
	.rs-card--orange .rs-val {
		color: #c2410c; /* orange-700 */
	}

	/* the one-line annotation under each card's columns */
	.rs-note {
		padding: 0 12px 10px;
		font-size: 0.66rem;
		line-height: 1.35;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* ── the ghosted, struck-through session card ── */
	.rs-card--ghost {
		border: 1.5px dashed var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-bg, transparent);
		opacity: 0.72;
		min-width: 11rem;
	}
	.rs-card--ghost .rs-card-head {
		border-bottom: 1px dashed var(--sl-color-gray-5, #cbd5e1);
	}
	.rs-card-name--ghost {
		color: var(--sl-color-gray-3, #64748b);
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
	}
	.rs-row--ghost {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.68rem;
		font-style: italic;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
	}
	.rs-note--ghost {
		color: var(--sl-color-gray-3, #64748b);
	}
	.rs-note--ghost code {
		font-size: 0.92em;
	}

	/* ── narrow viewports: stack the two groups, cards already wrap ── */
	@media (max-width: 720px) {
		.rs {
			flex-direction: column;
			gap: 14px;
		}
		.rs-exists,
		.rs-absent {
			flex: 1 1 auto;
			width: 100%;
		}
		.rs-card {
			flex: 1 1 11rem;
		}
	}
</style>
