---
// twofactor-schema — Chapter 053 Lesson 6, "TOTP and recovery codes",
// "Installing the two-factor plugin". What `@better-auth/cli generate` adds when
// the twoFactor plugin is registered, made into a schema-delta picture.
//
// The single load-bearing idea, the one the prose right under the figure leans
// on: the two facts the plugin lands live in TWO DIFFERENT PLACES. A whole new
// `twoFactor` table (one row per user: secret + hashed backup codes + a
// `verified` flag), AND a single new `twoFactorEnabled` boolean bolted onto the
// EXISTING `user` table. The on/off switch the app reads is `user.twoFactorEnabled`;
// `twoFactor.verified` is the narrower "did the secret finish enrollment" fact —
// not the same flag. The figure has to make "new whole table" vs "one new column
// on a table that already existed" readable at a glance, and put the two
// load-bearing columns (`verified`, `twoFactorEnabled`) under a highlight so the
// "read each from a different place" paragraph has something to point at.
//
// Layout: two row-cards side by side (wrap on narrow). Left = the new `twoFactor`
// table, rendered solid and whole (everything in it is new). Right = the existing
// `user` table, rendered as "…existing columns…" elided to a single ghost line
// with only the one ADDED column shown solid — the geometry says "this table was
// already here; just this row is new". A small "NEW" pill on each added thing.
//
// Plain HTML + CSS per the diagrams index (annotated-illustration shape;
// deliberately NOT a diagram engine and NOT ArrowDiagram, whose LeaderLines can't
// be relocated into the Figure lightbox). Astro-scoped <style>, no LeaderLines →
// survives the lightbox, so the wrapping <Figure> stays expandable. `margin: 0`
// resets on every node defeat Starlight's injected prose margins; `not-content`
// on the root does the same. Theme-aware chrome via Starlight gray vars (flips
// light/dark); the accents read on both backgrounds.
//
// Palette continues the chapter's annotated ER colours (Ch 052 ER diagram +
// sibling `rows-after-signup`):
//   • twoFactor → violet — the credential-bearing row (sibling to `account`, the
//                           other secret-holding table, which is violet here).
//   • user      → blue   — the identity row, blue in Ch 052 and `rows-after-signup`.
// The two highlighted columns (`verified`, `twoFactorEnabled`) carry the figure.

import Figure from '../../../figures/Figure.astro';

interface Col {
	key: string;
	type: string;
	note?: string;
	hi?: boolean; // the load-bearing column the prose points at
}

const twoFactorCols: Col[] = [
	{ key: 'userId', type: 'text', note: 'FK → user.id' },
	{ key: 'secret', type: 'text', note: 'base32 TOTP secret' },
	{ key: 'backupCodes', type: 'text', note: 'recovery codes, hashed' },
	{ key: 'verified', type: 'boolean', note: 'did enrollment finish?', hi: true },
];

const addedUserCol: Col = {
	key: 'twoFactorEnabled',
	type: 'boolean',
	note: 'the on/off switch the app reads',
	hi: true,
};
---

<Figure
	caption="Two things land, in two different places: a whole new twoFactor table (one row per user), and a single twoFactorEnabled column bolted onto the user table you already had."
>
	<div class="tf not-content">
		{/* ───────── NEW TABLE: twoFactor (violet, all of it is new) ───────── */}
		<div class="tf-card tf-card--violet">
			<div class="tf-card-head">
				<code class="tf-card-name">twoFactor</code>
				<span class="tf-pill tf-pill--new">new table</span>
			</div>
			<p class="tf-card-sub">one row per user</p>
			<div class="tf-card-body">
				{
					twoFactorCols.map((col) => (
						<div class={`tf-col${col.hi ? ' tf-col--hi' : ''}`}>
							<code class="tf-col-key">{col.key}</code>
							<code class="tf-col-type">{col.type}</code>
							{col.note && <span class="tf-col-note">{col.note}</span>}
						</div>
					))
				}
			</div>
		</div>

		{/* ──── EXISTING TABLE: user, gaining exactly one column (blue) ──── */}
		<div class="tf-card tf-card--blue">
			<div class="tf-card-head">
				<code class="tf-card-name">user</code>
				<span class="tf-pill tf-pill--exists">existing table</span>
			</div>
			<p class="tf-card-sub">+ one column</p>
			<div class="tf-card-body">
				{/* the columns that were already there, elided to one ghost line */}
				<div class="tf-col tf-col--ghost">
					<span class="tf-col-ellipsis">…existing columns…</span>
				</div>
				{/* the single new column — solid, highlighted, badged */}
				<div class="tf-col tf-col--hi tf-col--added">
					<code class="tf-col-key">{addedUserCol.key}</code>
					<code class="tf-col-type">{addedUserCol.type}</code>
					<span class="tf-pill tf-pill--new tf-pill--inline">new</span>
					<span class="tf-col-note">{addedUserCol.note}</span>
				</div>
			</div>
		</div>
	</div>
</Figure>

<style>
	.tf {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 18px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.tf-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		flex: 1 1 18rem;
		max-width: 24rem;
		min-width: 14rem;
		border-radius: 10px;
		overflow: hidden;
		margin: 0;
	}

	/* ── per-table accents — continue the chapter's annotated ER palette ── */
	.tf-card--violet {
		border: 1.5px solid #7c3aed; /* violet-600 — the secret-bearing table */
		background: color-mix(in srgb, #7c3aed 8%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(124, 58, 237, 0.2);
	}
	.tf-card--blue {
		border: 1.5px solid #2563eb; /* blue-600 — the identity table */
		background: color-mix(in srgb, #2563eb 7%, var(--sl-color-bg, transparent));
		box-shadow: 0 2px 8px rgba(37, 99, 235, 0.16);
	}

	.tf-card-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		padding: 8px 12px 7px;
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.tf-card--violet .tf-card-head {
		border-bottom-color: color-mix(in srgb, #7c3aed 35%, transparent);
		background: color-mix(in srgb, #7c3aed 12%, transparent);
	}
	.tf-card--blue .tf-card-head {
		border-bottom-color: color-mix(in srgb, #2563eb 32%, transparent);
		background: color-mix(in srgb, #2563eb 11%, transparent);
	}

	.tf-card-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	.tf-card-sub {
		padding: 5px 12px 0;
		font-size: 0.64rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── the small "new" / "existing" status pills ── */
	.tf-pill {
		font-size: 0.58rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		line-height: 1.2;
		padding: 2px 7px;
		border-radius: 999px;
		white-space: nowrap;
		margin: 0;
	}
	.tf-pill--new {
		color: #fff;
		background: #7c3aed;
		border: 1px solid #7c3aed;
	}
	/* the user table itself is not new — its pill is quiet */
	.tf-pill--exists {
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
	}
	/* the inline "new" badge on the single added column picks up blue */
	.tf-pill--inline {
		background: #2563eb;
		border-color: #2563eb;
		padding: 1px 6px;
		font-size: 0.54rem;
	}

	.tf-card-body {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 10px 12px 12px;
		margin: 0;
	}

	/* ── one column row: name · type · note ── */
	.tf-col {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 4px 8px;
		padding: 4px 7px;
		border-radius: 6px;
		font-size: 0.72rem;
		line-height: 1.3;
		margin: 0;
	}
	.tf-col-key {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.74rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.tf-col-type {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		font-weight: 500;
		color: var(--sl-color-gray-3, #64748b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.tf-col-note {
		font-size: 0.63rem;
		font-style: italic;
		color: var(--sl-color-gray-2, #475569);
		margin: 0 0 0 auto;
		text-align: right;
	}

	/* the highlighted, load-bearing column — tinted by its card's accent */
	.tf-card--violet .tf-col--hi {
		background: color-mix(in srgb, #7c3aed 14%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #7c3aed 45%, transparent);
	}
	.tf-card--blue .tf-col--hi {
		background: color-mix(in srgb, #2563eb 13%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #2563eb 42%, transparent);
	}
	.tf-card--violet .tf-col--hi .tf-col-type {
		color: #6d28d9; /* violet-700 */
	}
	.tf-card--blue .tf-col--hi .tf-col-type {
		color: #1d4ed8; /* blue-700 */
	}

	/* ── the elided "existing columns" ghost line on user ── */
	.tf-col--ghost {
		opacity: 0.75;
	}
	.tf-col-ellipsis {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		font-style: italic;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.tf-col--added {
		margin-top: 1px;
	}

	/* ── narrow viewports: stack the two cards ── */
	@media (max-width: 640px) {
		.tf {
			flex-direction: column;
			gap: 14px;
		}
		.tf-card {
			flex: 1 1 auto;
			max-width: none;
			width: 100%;
		}
		.tf-col-note {
			margin-left: 0;
			text-align: left;
			flex-basis: 100%;
		}
	}
</style>
