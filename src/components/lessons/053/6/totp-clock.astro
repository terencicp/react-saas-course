---
// totp-clock — Chapter 053 Lesson 6, "TOTP and recovery codes".
//
// The "How TOTP proves possession" mental-model figure. One glance has to carry:
// the shared secret and the clock window are IDENTICAL on both ends and never
// move (a lock sits on the secret), each side runs the SAME computation
// independently, and only the 6-digit RESULT ever crosses the wire.
//
// Layout: a shared header band spanning both tracks (secret box + clock tick,
// with a "same on both sides" note), then two parallel tracks below —
// "Authenticator app" and "Server" — each running HMAC(secret, T) → truncate →
// a large monospace 739 204. A thin connector between the two identical results
// carries the only-the-digits-cross-the-wire point. The geometry says: inputs
// stay put (locked, up top), output travels (connected, at the bottom).
//
// Plain HTML + CSS per the diagrams index (annotated-illustration shape;
// deliberately NOT a diagram engine and NOT ArrowDiagram, whose LeaderLines
// can't be relocated into the Figure lightbox). Astro-scoped <style>, no
// LeaderLines → survives the lightbox, so the wrapping <Figure> stays expandable.
// `margin: 0` resets on every node defeat Starlight's injected prose margins;
// `not-content` on the root does the same. Theme-aware chrome via Starlight gray
// vars (flips light/dark). Chapter palette: blue (#2563eb) = the shared
// config/inputs that stay put; green (#16a34a) = the matched result that travels.

import Figure from '../../../figures/Figure.astro';

const INPUT = '#2563eb'; // blue — the shared secret + clock window (config, stays put)
const RESULT = '#16a34a'; // green — the 6-digit code (the only thing that crosses)
---

<Figure
	caption="Same secret, same clock window, two independent computations — and only the result is ever typed in."
>
	<div class="tc not-content">
		{/* ───────── SHARED HEADER: identical inputs on both ends ───────── */}
		<div class="tc-shared">
			<div class="tc-shared-item tc-secret">
				<span class="tc-lock" aria-hidden="true">🔒</span>
				<div class="tc-shared-text">
					<span class="tc-shared-label">Shared secret</span>
					<code class="tc-shared-val">JBSWY3DPEHPK3PXP</code>
				</div>
			</div>
			<div class="tc-shared-item tc-clock">
				<span class="tc-tick" aria-hidden="true">🕑</span>
				<div class="tc-shared-text">
					<span class="tc-shared-label">Clock window</span>
					<code class="tc-shared-val">T = floor(now / 30s)</code>
				</div>
			</div>
			<span class="tc-shared-note">identical on both sides · never re-sent</span>
		</div>

		{/* ───────── TWO PARALLEL TRACKS ───────── */}
		<div class="tc-tracks">
			{/* LEFT — the authenticator app */}
			<div class="tc-track">
				<div class="tc-track-head">
					<span class="tc-track-glyph" aria-hidden="true">📱</span>
					Authenticator app
				</div>
				<div class="tc-pipe">
					<code class="tc-step">HMAC(secret, T)</code>
					<span class="tc-pipe-arrow" aria-hidden="true">→</span>
					<code class="tc-step">truncate</code>
					<span class="tc-pipe-arrow" aria-hidden="true">→</span>
					<span class="tc-result">739&nbsp;204</span>
				</div>
			</div>

			{/* RIGHT — the server */}
			<div class="tc-track">
				<div class="tc-track-head">
					<span class="tc-track-glyph" aria-hidden="true">🖥️</span>
					Server
				</div>
				<div class="tc-pipe">
					<code class="tc-step">HMAC(secret, T)</code>
					<span class="tc-pipe-arrow" aria-hidden="true">→</span>
					<code class="tc-step">truncate</code>
					<span class="tc-pipe-arrow" aria-hidden="true">→</span>
					<span class="tc-result">739&nbsp;204</span>
				</div>
			</div>

			{/* the only thing that crosses the wire: the 6 digits */}
			<div class="tc-wire" aria-hidden="true">
				<span class="tc-wire-line"></span>
				<span class="tc-wire-label">only the 6 digits cross the wire</span>
				<span class="tc-wire-line"></span>
			</div>
		</div>
	</div>
</Figure>

<style>
	.tc {
		display: flex;
		flex-direction: column;
		gap: 16px;
		margin: 0;
		padding: 6px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── SHARED HEADER ─────────────────────────────────────── */
	.tc-shared {
		box-sizing: border-box;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		column-gap: 16px;
		row-gap: 8px;
		padding: 10px 14px;
		border-radius: 11px;
		border: 1.5px solid color-mix(in srgb, #2563eb 45%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #2563eb 7%, var(--sl-color-bg, transparent));
		margin: 0;
	}

	.tc-shared-item {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 0;
	}

	.tc-lock,
	.tc-tick {
		font-size: 1.05rem;
		line-height: 1;
		margin: 0;
	}

	.tc-shared-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
		margin: 0;
	}

	.tc-shared-label {
		font-size: 0.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1.2;
		color: #2563eb;
		margin: 0;
	}

	.tc-shared-val {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}

	.tc-shared-note {
		flex-basis: 100%;
		text-align: center;
		font-size: 0.66rem;
		font-style: italic;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── TWO TRACKS ────────────────────────────────────────── */
	.tc-tracks {
		display: grid;
		grid-template-columns: 1fr 1fr;
		column-gap: 18px;
		row-gap: 0;
		margin: 0;
	}

	.tc-track {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 9px;
		min-width: 0;
		padding: 11px 13px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}

	.tc-track-head {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 0.78rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.tc-track-glyph {
		font-size: 0.95rem;
		line-height: 1;
		margin: 0;
	}

	.tc-pipe {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 7px;
		margin: 0;
	}

	.tc-step {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		border-radius: 5px;
		padding: 3px 7px;
		margin: 0;
		white-space: nowrap;
	}

	.tc-pipe-arrow {
		font-size: 0.9rem;
		line-height: 1;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	.tc-result {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		line-height: 1.1;
		color: #16a34a;
		background: color-mix(in srgb, #16a34a 13%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #16a34a 45%, transparent);
		border-radius: 6px;
		padding: 2px 9px;
		margin: 0;
		white-space: nowrap;
	}

	/* ── THE WIRE: the connector between the two results ───── */
	.tc-wire {
		grid-column: 1 / -1;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 0 12%;
		margin: 9px 0 0;
	}

	.tc-wire-line {
		flex: 1 1 0;
		height: 0;
		border-top: 2px dashed color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-4, #94a3b8));
		margin: 0;
	}

	.tc-wire-label {
		flex: 0 0 auto;
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.25;
		text-align: center;
		color: #16a34a;
		margin: 0;
		white-space: nowrap;
	}

	/* ── narrow viewports: stack the tracks, drop the wire to vertical ── */
	@media (max-width: 560px) {
		.tc-tracks {
			grid-template-columns: 1fr;
			row-gap: 9px;
		}
		.tc-wire {
			padding: 0;
			margin: 0;
		}
		.tc-wire-label {
			white-space: normal;
		}
	}
</style>
