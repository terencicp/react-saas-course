---
// recovery-codes-card — Chapter 053 Lesson 6, "TOTP and recovery codes",
// end of "Enrolling a device: six steps inside a live session".
//
// A high-fidelity mock of the "save your recovery codes" panel — the single most
// common 2FA-implementation footgun made concrete, so the once-only reveal gets
// RENDERED, not just narrated. The sibling DiagramSequence (twofactor-enrollment)
// keeps its step-6 reveal schematic precisely so this figure can carry the
// full-fidelity screen; this is that screen.
//
// What the panel has to make felt:
//   - 10 monospace recovery codes in a 2-column grid (the artifact to save).
//   - Download + Copy affordances (the ways to capture them off-screen).
//   - A loud warning callout: these will NOT be shown again, store in a password
//     manager, each works once. This is the load-bearing line of the whole flow.
//   - A confirm checkbox ("I've saved my recovery codes") gating a Done button
//     that is DISABLED until it's ticked — the gate that stops a user leaving
//     before they've captured the codes.
//
// This is a static mock: a snapshot of the screen, not a working form. The Done
// button stays disabled and the checkbox unticked on purpose — the disabled state
// IS the teaching point. No JS / no hydration.
//
// Plain HTML + CSS per the diagrams index (annotated-illustration / UI-mock shape;
// deliberately not a diagram engine). Astro-scoped <style>, no LeaderLines → the
// wrapping <Figure> stays expandable. `margin: 0` resets on every node + the
// `not-content` root defeat Starlight's injected prose margins. Theme-aware chrome
// via Starlight gray vars (flips light/dark). Chapter palette, inherited from the
// siblings totp-clock / twofactor-enrollment:
//   violet #7c3aed — THE HINGE: the once-only recovery-code reveal (the warning,
//                    the panel accent, the checkbox).

import Figure from '../../../figures/Figure.astro';

const VIOLET = '#7c3aed'; // the hinge — the once-only reveal

// ten plausible dummy recovery codes, rendered into a 2-column CSS grid
const recoveryCodes = [
	'3f9a-2b71',
	'8c04-9de2',
	'a17e-44c3',
	'd0b9-1f6a',
	'5e82-c7b4',
	'9af3-0d61',
	'71c5-e2a8',
	'2e5f-7a90',
	'b3c1-08dd',
	'6d40-9f12',
];
---

<Figure
	caption="The reveal happens once. After this screen, the codes exist only as hashes in the database — there is no way to show them again."
>
	<div class="rc not-content" style={`--accent: ${VIOLET};`}>
		{/* ── panel header ── */}
		<div class="rc-head">
			<span class="rc-key" aria-hidden="true">🔑</span>
			<div class="rc-head-text">
				<h3 class="rc-title">Save your recovery codes</h3>
				<p class="rc-sub">Use one of these if you ever lose access to your authenticator app.</p>
			</div>
		</div>

		{/* ── the codes: a 2-column monospace grid ── */}
		<div class="rc-codes">
			{recoveryCodes.map((c, i) => (
				<div class="rc-code">
					<span class="rc-code-n">{String(i + 1).padStart(2, '0')}</span>
					<code class="rc-code-val">{c}</code>
				</div>
			))}
		</div>

		{/* ── capture affordances ── */}
		<div class="rc-actions">
			<span class="rc-btn rc-btn--primary">
				<span class="rc-btn-glyph" aria-hidden="true">↓</span>
				Download codes
			</span>
			<span class="rc-btn rc-btn--ghost">
				<span class="rc-btn-glyph" aria-hidden="true">⧉</span>
				Copy
			</span>
		</div>

		{/* ── the load-bearing warning ── */}
		<div class="rc-warn" role="note">
			<span class="rc-warn-icon" aria-hidden="true">⚠</span>
			<p class="rc-warn-text">
				These codes <b>will not be shown again.</b> Store them in a password manager. Each one works
				once if you lose access to your authenticator app.
			</p>
		</div>

		{/* ── the gate: confirm checkbox + disabled Done ── */}
		<div class="rc-gate">
			<label class="rc-confirm">
				<span class="rc-box" aria-hidden="true"></span>
				I've saved my recovery codes
			</label>
			<span class="rc-done" aria-disabled="true">
				Done
				<span class="rc-done-lock" aria-hidden="true">🔒</span>
			</span>
		</div>
	</div>
</Figure>

<style>
	.rc {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 16px;
		max-width: 30rem;
		margin: 0 auto;
		padding: 18px 18px 16px;
		border-radius: 14px;
		border: 1.5px solid color-mix(in srgb, var(--accent) 40%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, var(--accent) 4%, var(--sl-color-bg, transparent));
		font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}
	.rc * {
		box-sizing: border-box;
	}

	/* ── HEADER ─────────────────────────────────────────────── */
	.rc-head {
		display: flex;
		align-items: flex-start;
		gap: 11px;
		margin: 0;
	}
	.rc-key {
		font-size: 1.4rem;
		line-height: 1.1;
		margin: 0;
	}
	.rc-head-text {
		display: flex;
		flex-direction: column;
		gap: 3px;
		margin: 0;
	}
	.rc-title {
		font-size: 1.02rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
		padding: 0;
		border: 0;
	}
	.rc-sub {
		font-size: 0.78rem;
		line-height: 1.35;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* ── THE CODES: a 2-column grid ─────────────────────────── */
	.rc-codes {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 8px 12px;
		padding: 13px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}
	.rc-code {
		display: flex;
		align-items: baseline;
		gap: 8px;
		margin: 0;
	}
	.rc-code-n {
		flex: 0 0 auto;
		font-size: 0.64rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
		user-select: none;
	}
	.rc-code-val {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}

	/* ── CAPTURE AFFORDANCES ────────────────────────────────── */
	.rc-actions {
		display: flex;
		gap: 9px;
		margin: 0;
	}
	.rc-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 0.78rem;
		font-weight: 600;
		line-height: 1.2;
		padding: 7px 13px;
		border-radius: 8px;
		margin: 0;
		white-space: nowrap;
	}
	.rc-btn-glyph {
		font-size: 0.9rem;
		line-height: 1;
		margin: 0;
	}
	.rc-btn--primary {
		color: #fff;
		background: var(--accent);
		box-shadow: 0 1px 2px color-mix(in srgb, var(--accent) 40%, transparent);
	}
	.rc-btn--ghost {
		color: var(--accent);
		background: transparent;
		box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--accent) 45%, transparent);
	}

	/* ── THE WARNING: the load-bearing line ─────────────────── */
	.rc-warn {
		display: flex;
		align-items: flex-start;
		gap: 9px;
		padding: 10px 12px;
		border-radius: 9px;
		border: 1.5px solid color-mix(in srgb, var(--accent) 55%, transparent);
		background: color-mix(in srgb, var(--accent) 11%, transparent);
		margin: 0;
	}
	.rc-warn-icon {
		flex: 0 0 auto;
		font-size: 0.95rem;
		line-height: 1.35;
		color: var(--accent);
		margin: 0;
	}
	.rc-warn-text {
		font-size: 0.76rem;
		line-height: 1.4;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.rc-warn-text b {
		font-weight: 700;
		color: var(--accent);
	}

	/* ── THE GATE: confirm checkbox + disabled Done ─────────── */
	.rc-gate {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
		padding-top: 14px;
		border-top: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.rc-confirm {
		display: flex;
		align-items: center;
		gap: 9px;
		font-size: 0.82rem;
		font-weight: 500;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	/* unticked box — the gate is closed; this is a static mock */
	.rc-box {
		flex: 0 0 auto;
		width: 17px;
		height: 17px;
		border-radius: 5px;
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}
	/* disabled Done — greyed, with a lock; the checkbox above unlocks it */
	.rc-done {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
		padding: 8px 16px;
		border-radius: 8px;
		color: var(--sl-color-gray-3, #64748b);
		background: var(--sl-color-gray-6, #e2e8f0);
		box-shadow: inset 0 0 0 1px var(--sl-color-gray-5, #cbd5e1);
		cursor: not-allowed;
		margin: 0;
	}
	.rc-done-lock {
		font-size: 0.78rem;
		line-height: 1;
		opacity: 0.7;
		margin: 0;
	}

	/* ── narrow viewports: single column of codes, stack the gate ── */
	@media (max-width: 480px) {
		.rc-codes {
			grid-template-columns: 1fr;
		}
		.rc-gate {
			justify-content: stretch;
		}
		.rc-done {
			margin-left: auto;
		}
	}
</style>
