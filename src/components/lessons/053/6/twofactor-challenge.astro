---
// twofactor-challenge — Chapter 053 Lesson 6, "TOTP and recovery codes",
// "The sign-in challenge: composing with the password step". The named,
// load-bearing DiagramSequence for the sign-in second-factor challenge.
//
// It continues the L2 sign-in happy path PAST the 2FA fork, and two facts have to
// survive a scrub through the five steps:
//   1. NO SESSION DURING THE CHALLENGE. The first factor passed but Better Auth
//      did NOT issue a session — only a short-lived first-factor cookie. A
//      persistent `session:` status pill rides every panel so the reader watches
//      it stay `none` across steps 1–3 and only flip to ✓ at step 4 (the commit).
//      That is the visual climax, and the most-misread point of the lesson.
//   2. verifyTotp TAKES NO TOKEN. Step 3 shows the call with an explicit
//      "no factorToken — cookie-carried" annotation: the context travels in the
//      first-factor cookie, not in a function argument.
//
// Deliberately mirrors sibling `twofactor-enrollment.astro` so the two flows read
// as a matched pair across the lesson — same header rail (step counter · stage
// pill · persistent status pill), same centered schematic stage, same two-segment
// foot spine. Here the spine tells the cookie→session story: "first factor ✓
// (cookie)" is done from step 1, "second factor → session" lights at the commit.
//
// Each step is a fixed-frame panel; all steps share chrome/height so
// DiagramSequence's same-cell grid stack never jumps. Schematic, not a pixel mock.
//
// Plain HTML + CSS per the diagrams index. DiagramSequence provides its own outer
// card, so this is NOT wrapped in <Figure>. Astro-scoped <style>; `margin: 0`
// resets + `not-content` defeat Starlight's injected prose margins. Theme-aware
// chrome via Starlight gray vars (flips light/dark). Chapter palette, inherited
// from siblings `totp-clock` / `twofactor-schema` / `twofactor-enrollment`:
//   orange #ea580c  library call / endpoint / the cookie-carried step (1, 3)
//   violet #7c3aed  THE HINGE — the continuation of the sign-in form (step 2)
//   green  #16a34a  session / success / the commit + redirect (steps 4, 5)

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Accent = 'orange' | 'violet' | 'green';

interface Step {
	n: number;
	accent: Accent;
	tag: string; // the stage pill text in the header
	session: boolean; // value of the persistent `session:` status pill
	caption: string;
}

const steps: Step[] = [
	{
		n: 1,
		accent: 'orange',
		tag: 'First factor verified',
		session: false,
		caption:
			'Password accepted — the first factor is verified. Better Auth sets a short-lived first-factor cookie. No session yet.',
	},
	{
		n: 2,
		accent: 'violet',
		tag: 'The sign-in form continues',
		session: false,
		caption:
			"The form reads { status: 'second-factor' } and renders the TOTP prompt instead of redirecting to the dashboard.",
	},
	{
		n: 3,
		accent: 'orange',
		tag: 'Second factor submitted',
		session: false,
		caption:
			'verifyTotp({ code, trustDevice }) — there is no token argument. The call rides the first-factor cookie Better Auth already set.',
	},
	{
		n: 4,
		accent: 'green',
		tag: 'The code matches',
		session: true,
		caption: 'The code matches — only now is a fresh session issued. The session pill flips from none to ✓.',
	},
	{
		n: 5,
		accent: 'green',
		tag: 'Signed in',
		session: true,
		caption: 'Redirect through safeNext, the open-redirect guard reused from the sign-in lesson, to the dashboard.',
	},
];
---

<DiagramSequence>
	{
		steps.map((s) => (
			<DiagramStep caption={s.caption}>
				<div class={`ch ch--${s.accent} not-content`}>
					{/* ── HEADER RAIL: step no · stage pill · persistent session pill ── */}
					<div class="ch-head">
						<span class="ch-step">Step {s.n} / 5</span>
						<span class="ch-stage-pill">{s.tag}</span>
						<span class={`ch-status${s.session ? ' ch-status--on' : ''}`}>
							<code>session</code>
							<b>{s.session ? '✓' : 'none'}</b>
						</span>
					</div>

					{/* ── STAGE: a small schematic, one per step ── */}
					<div class="ch-stage">
						{s.n === 1 && (
							<div class="ch-cookie-wrap">
								<div class="ch-cookie">
									<span class="ch-cookie-icon" aria-hidden="true">
										🍪
									</span>
									<div class="ch-cookie-text">
										<span class="ch-cookie-title">first-factor: verified</span>
										<span class="ch-cookie-sub">short-lived · set by Better Auth</span>
									</div>
								</div>
								<span class="ch-nosess">no session issued — the password is not the finish line</span>
							</div>
						)}

						{s.n === 2 && (
							<div class="ch-card ch-prompt">
								<div class="ch-card-head">Two-factor required</div>
								<div class="ch-prompt-body">
									<div class="ch-otp" aria-hidden="true">
										<span class="ch-otp-box">7</span>
										<span class="ch-otp-box">3</span>
										<span class="ch-otp-box">9</span>
										<span class="ch-otp-box ch-otp-box--caret" />
										<span class="ch-otp-box" />
										<span class="ch-otp-box" />
									</div>
									<label class="ch-trust">
										<span class="ch-checkbox" aria-hidden="true">
											✓
										</span>
										Trust this device for 30 days
									</label>
								</div>
							</div>
						)}

						{s.n === 3 && (
							<div class="ch-call-wrap">
								<code class="ch-call">
									authClient.twoFactor.<b>verifyTotp</b>(&#123;{' '}
									<span class="ch-arg">code</span>, <span class="ch-arg">trustDevice</span> &#125;)
								</code>
								<div class="ch-note">
									<span class="ch-note-strike">no factorToken</span>
									<span class="ch-note-arrow" aria-hidden="true">
										→
									</span>
									<span class="ch-note-carry">context rides the first-factor cookie</span>
								</div>
							</div>
						)}

						{s.n === 4 && (
							<div class="ch-commit-wrap">
								<div class="ch-commit">
									<span class="ch-check" aria-hidden="true">
										✓
									</span>
									<span class="ch-commit-text">code matches — a fresh session is issued</span>
								</div>
								<div class="ch-flip" aria-hidden="true">
									<span class="ch-flip-from">session: none</span>
									<span class="ch-flip-arrow">→</span>
									<span class="ch-flip-to">session: ✓</span>
								</div>
							</div>
						)}

						{s.n === 5 && (
							<div class="ch-redirect">
								<span class="ch-redirect-src">
									<code>safeNext</code>
								</span>
								<span class="ch-redirect-arrow" aria-hidden="true">
									→
								</span>
								<span class="ch-redirect-dest">/dashboard</span>
							</div>
						)}
					</div>

					{/* ── SPINE: first factor (cookie) → second factor → session ── */}
					<div class="ch-spine" aria-hidden="true">
						<span class="ch-seg ch-seg--first is-done">1 · first factor ✓ (cookie)</span>
						<span class="ch-seg-arrow">→</span>
						<span class={`ch-seg ch-seg--second${s.session ? ' is-done' : ' is-here'}`}>
							2 · second factor → session
						</span>
					</div>
				</div>
			</DiagramStep>
		))
	}
</DiagramSequence>

<style>
	.ch {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 12px;
		min-height: 232px;
		margin: 0;
		padding: 4px 2px;
		font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}
	.ch * {
		box-sizing: border-box;
	}

	/* per-step accent, resolved to one custom prop the panel reads */
	.ch--orange {
		--accent: #ea580c;
	}
	.ch--violet {
		--accent: #7c3aed;
	}
	.ch--green {
		--accent: #16a34a;
	}

	/* ── HEADER RAIL ─────────────────────────────────────────── */
	.ch-head {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px 10px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.ch-step {
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.ch-stage-pill {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1.2;
		padding: 2px 8px;
		border-radius: 999px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 42%, transparent);
		margin: 0;
		white-space: nowrap;
	}
	/* the persistent session pill — the element the reader tracks across steps */
	.ch-status {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-left: auto;
		padding: 2px 4px 2px 8px;
		border-radius: 999px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		white-space: nowrap;
	}
	.ch-status code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.64rem;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.ch-status b {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.66rem;
		font-weight: 700;
		line-height: 1.2;
		padding: 1px 8px;
		border-radius: 999px;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
	}
	.ch-status--on {
		border-color: #16a34a;
		background: color-mix(in srgb, #16a34a 9%, transparent);
	}
	.ch-status--on b {
		color: #fff;
		background: #16a34a;
	}

	/* ── STAGE: shared centering frame for the per-step schematic ── */
	.ch-stage {
		flex: 1 1 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 118px;
		margin: 0;
	}

	/* step 1 — the first-factor cookie + the explicit "no session" line */
	.ch-cookie-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		margin: 0;
	}
	.ch-cookie {
		display: flex;
		align-items: center;
		gap: 11px;
		padding: 9px 15px;
		border-radius: 9px;
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		margin: 0;
	}
	.ch-cookie-icon {
		font-size: 1.25rem;
		line-height: 1;
		margin: 0;
	}
	.ch-cookie-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
		margin: 0;
	}
	.ch-cookie-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--accent);
		margin: 0;
	}
	.ch-cookie-sub {
		font-size: 0.64rem;
		font-style: italic;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.ch-nosess {
		font-size: 0.68rem;
		font-weight: 700;
		line-height: 1.25;
		text-align: center;
		color: var(--accent);
		margin: 0;
	}

	/* step 2 — the TOTP prompt card (the continuation of the sign-in form) */
	.ch-card {
		width: 100%;
		max-width: 22rem;
		border-radius: 10px;
		border: 1.5px solid color-mix(in srgb, var(--accent) 45%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, var(--accent) 5%, var(--sl-color-bg, transparent));
		overflow: hidden;
		margin: 0;
	}
	.ch-card-head {
		padding: 6px 12px;
		font-size: 0.68rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
		border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
		margin: 0;
	}
	.ch-prompt-body {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 11px;
		padding: 13px 12px;
		margin: 0;
	}
	.ch-otp {
		display: flex;
		gap: 6px;
		margin: 0;
	}
	.ch-otp-box {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 32px;
		border-radius: 6px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.ch-otp-box--caret {
		border-color: var(--accent);
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 28%, transparent);
	}
	.ch-trust {
		display: flex;
		align-items: center;
		gap: 7px;
		font-size: 0.72rem;
		font-weight: 500;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.ch-checkbox {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 16px;
		height: 16px;
		border-radius: 4px;
		font-size: 0.62rem;
		font-weight: 700;
		color: #fff;
		background: var(--accent);
		margin: 0;
	}

	/* step 3 — the verifyTotp call + the no-token annotation */
	.ch-call-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 11px;
		width: 100%;
		margin: 0;
	}
	.ch-call {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.8rem;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #e2e8f0);
		border-radius: 7px;
		padding: 7px 12px;
		margin: 0;
		text-align: center;
	}
	.ch-call b {
		color: var(--accent);
		font-weight: 700;
	}
	.ch-call .ch-arg {
		color: var(--accent);
		font-weight: 600;
	}
	.ch-note {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
		justify-content: center;
		padding: 7px 13px;
		border-radius: 9px;
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		margin: 0;
	}
	.ch-note-strike {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		font-weight: 700;
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.ch-note-arrow {
		font-size: 0.8rem;
		color: var(--accent);
		margin: 0;
	}
	.ch-note-carry {
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--accent);
		margin: 0;
	}

	/* step 4 — the green commit: code matches → session issued, pill flips */
	.ch-commit-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		margin: 0;
	}
	.ch-commit {
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 7px 13px;
		border-radius: 9px;
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 11%, transparent);
		margin: 0;
	}
	.ch-check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		border-radius: 50%;
		font-size: 0.75rem;
		font-weight: 700;
		color: #fff;
		background: var(--accent);
		margin: 0;
	}
	.ch-commit-text {
		font-size: 0.76rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	/* the explicit none → ✓ flip, echoing the header pill */
	.ch-flip {
		display: flex;
		align-items: center;
		gap: 9px;
		margin: 0;
	}
	.ch-flip-from {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 600;
		padding: 2px 8px;
		border-radius: 999px;
		color: var(--sl-color-gray-3, #64748b);
		background: var(--sl-color-gray-6, #e2e8f0);
		text-decoration: line-through;
		margin: 0;
	}
	.ch-flip-arrow {
		font-size: 0.85rem;
		color: var(--accent);
		margin: 0;
	}
	.ch-flip-to {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.7rem;
		font-weight: 700;
		padding: 2px 9px;
		border-radius: 999px;
		color: #fff;
		background: var(--accent);
		margin: 0;
	}

	/* step 5 — the safeNext redirect to /dashboard */
	.ch-redirect {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-wrap: wrap;
		justify-content: center;
		margin: 0;
	}
	.ch-redirect-src {
		margin: 0;
	}
	.ch-redirect-src code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #e2e8f0);
		border-radius: 6px;
		padding: 4px 10px;
		margin: 0;
	}
	.ch-redirect-arrow {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--accent);
		margin: 0;
	}
	.ch-redirect-dest {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 700;
		color: #fff;
		background: var(--accent);
		border-radius: 6px;
		padding: 4px 12px;
		margin: 0;
	}

	/* ── SPINE: first factor (cookie) → second factor → session ── */
	.ch-spine {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding-top: 10px;
		border-top: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.ch-seg {
		font-size: 0.64rem;
		font-weight: 700;
		line-height: 1.2;
		padding: 3px 10px;
		border-radius: 999px;
		color: var(--sl-color-gray-3, #64748b);
		background: var(--sl-color-gray-6, #e2e8f0);
		box-shadow: inset 0 0 0 1px transparent;
		margin: 0;
		white-space: nowrap;
	}
	.ch-seg-arrow {
		font-size: 0.8rem;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}
	/* the segment matching the current step lights to that step's accent */
	.ch-seg.is-here {
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--accent) 55%, transparent);
	}
	/* a phase already passed reads as quietly done (green tick tint) */
	.ch-seg.is-done {
		color: #16a34a;
		background: color-mix(in srgb, #16a34a 11%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #16a34a 40%, transparent);
	}
	.ch-seg.is-done::before {
		content: '✓ ';
	}

	/* ── narrow viewports ── */
	@media (max-width: 560px) {
		.ch {
			min-height: 256px;
		}
		.ch-status {
			margin-left: 0;
		}
		.ch-redirect,
		.ch-note {
			gap: 8px;
		}
	}
</style>
