---
// twofactor-enrollment — Chapter 053 Lesson 6, "TOTP and recovery codes",
// "Enrolling a device: six steps inside a live session". The named, load-bearing
// DiagramSequence for the enrollment flow.
//
// Two ideas have to survive a scrub through the six steps:
//   1. TWO-PHASE. enable() only GENERATES (phase 1); verifyTotp() COMMITS
//      (phase 2). 2FA is OFF for steps 1–4 and only flips at step 5. A persistent
//      `twoFactorEnabled:` status pill rides every panel so the reader watches it
//      stay `false` and then flip to `true` at the commit — the visual climax. A
//      two-segment phase spine at the foot fills generate → commit alongside it.
//   2. TWO VIOLET BEATS. The elevation gate (step 2, re-prove the password) and
//      the once-only recovery-code reveal (step 6) are the hinges; both wear the
//      chapter's violet so they read as "the two places that carry the flow".
//
// Each step is a fixed-frame panel (header rail + schematic stage). All steps
// share the same chrome/height so DiagramSequence's same-cell grid stack never
// jumps. The stage per step is a small schematic, not a pixel-faithful mock — the
// later `recovery-codes-card` figure carries the high-fidelity reveal screen, so
// step 6 here stays schematic to avoid duplicating it.
//
// Plain HTML + CSS per the diagrams index. DiagramSequence provides its own outer
// card, so this is NOT wrapped in <Figure>. Astro-scoped <style>; `margin: 0`
// resets + `not-content` defeat Starlight's injected prose margins. Theme-aware
// chrome via Starlight gray vars (flips light/dark). Chapter palette, inherited
// from siblings `totp-clock` / `twofactor-schema`:
//   blue   #2563eb  config / parse        (steps 1, 4 — neutral-leaning)
//   orange #ea580c  library call / endpoint / the server response (step 3)
//   green  #16a34a  session / success / the commit (step 5)
//   violet #7c3aed  THE HINGE — elevation + once-only reveal (steps 2, 6)

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Accent = 'blue' | 'orange' | 'green' | 'violet';
type Phase = 'generate' | 'commit' | 'done';

interface Step {
	n: number;
	accent: Accent;
	phase: Phase;
	tag: string; // the phase pill text in the header
	enabled: boolean; // value of the persistent twoFactorEnabled status pill
	caption: string;
}

const steps: Step[] = [
	{
		n: 1,
		accent: 'blue',
		phase: 'generate',
		tag: 'Phase 1 · generate',
		enabled: false,
		caption: 'The user clicks Enable two-factor in security settings — already signed in, so this runs inside a live session.',
	},
	{
		n: 2,
		accent: 'violet',
		phase: 'generate',
		tag: 'Phase 1 · generate',
		enabled: false,
		caption: 'enable({ password }) — the password is the elevation proof. A stale or borrowed session is rejected right here.',
	},
	{
		n: 3,
		accent: 'orange',
		phase: 'generate',
		tag: 'Phase 1 · generate',
		enabled: false,
		caption: 'The server returns the secret as a QR plus the recovery codes — but two-factor is still OFF until the code is verified.',
	},
	{
		n: 4,
		accent: 'blue',
		phase: 'generate',
		tag: 'Phase 1 · generate',
		enabled: false,
		caption: 'The user scans the QR; their authenticator app starts emitting a fresh six-digit code every 30 seconds.',
	},
	{
		n: 5,
		accent: 'green',
		phase: 'commit',
		tag: 'Phase 2 · commit',
		enabled: true,
		caption: 'verifyTotp({ code }) matches — the commit. Now twoFactorEnabled flips to true and the row is marked verified.',
	},
	{
		n: 6,
		accent: 'violet',
		phase: 'done',
		tag: 'Done · save codes',
		enabled: true,
		caption: 'The recovery codes are revealed once, to be saved now — they are stored hashed and never shown again.',
	},
];

// dummy recovery codes for the step-3 chips and the step-6 reveal
const codes = ['3f9a-2b71', '8c04-9de2', 'a17e-44c3', 'd0b9-1f6a'];
---

<DiagramSequence>
	{
		steps.map((s) => (
			<DiagramStep caption={s.caption}>
				<div class={`en en--${s.accent} not-content`} data-phase={s.phase}>
					{/* ── HEADER RAIL: step no · phase pill · persistent status pill ── */}
					<div class="en-head">
						<span class="en-step">Step {s.n} / 6</span>
						<span class="en-phase">{s.tag}</span>
						<span class={`en-status${s.enabled ? ' en-status--on' : ''}`}>
							<code>twoFactorEnabled</code>
							<b>{s.enabled ? 'true' : 'false'}</b>
						</span>
					</div>

					{/* ── STAGE: a small schematic, one per step ── */}
					<div class="en-stage">
						{s.n === 1 && (
							<div class="en-card en-settings">
								<div class="en-card-head">Security settings</div>
								<div class="en-row">
									<span class="en-row-label">Two-factor authentication</span>
									<span class="en-btn en-btn--hot">Enable two-factor</span>
								</div>
							</div>
						)}

						{s.n === 2 && (
							<div class="en-call-wrap">
								<code class="en-call">
									authClient.twoFactor.<b>enable</b>(&#123;{' '}
									<span class="en-arg">password</span> &#125;)
								</code>
								<div class="en-gate">
									<span class="en-gate-icon" aria-hidden="true">
										🔒
									</span>
									<div class="en-gate-text">
										<span class="en-gate-title">Re-prove the password</span>
										<span class="en-gate-sub">elevation · a stale session is rejected</span>
									</div>
								</div>
							</div>
						)}

						{s.n === 3 && (
							<div class="en-response">
								<div class="en-qr" aria-hidden="true">
									<span class="en-qr-glyph">▙▟</span>
									<span class="en-qr-cap">totpURI → QR</span>
								</div>
								<div class="en-response-side">
									<span class="en-mini-label">backupCodes (plaintext, this once)</span>
									<div class="en-codes en-codes--mini">
										{codes.map((c) => (
											<code class="en-code">{c}</code>
										))}
										<code class="en-code en-code--more">+6</code>
									</div>
									<span class="en-stilloff">⚠ two-factor still OFF</span>
								</div>
							</div>
						)}

						{s.n === 4 && (
							<div class="en-phone">
								<div class="en-phone-frame">
									<span class="en-phone-app">Authenticator</span>
									<span class="en-phone-code">739&nbsp;204</span>
									<span class="en-ring" aria-hidden="true" />
								</div>
								<span class="en-phone-note">a fresh code every 30s</span>
							</div>
						)}

						{s.n === 5 && (
							<div class="en-call-wrap">
								<code class="en-call">
									authClient.twoFactor.<b>verifyTotp</b>(&#123;{' '}
									<span class="en-arg">code</span> &#125;)
								</code>
								<div class="en-commit">
									<span class="en-check" aria-hidden="true">
										✓
									</span>
									<span class="en-commit-text">
										match → <code>verified</code>, the flag flips
									</span>
								</div>
							</div>
						)}

						{s.n === 6 && (
							<div class="en-card en-reveal">
								<div class="en-card-head">Save your recovery codes</div>
								<div class="en-codes">
									{codes.map((c) => (
										<code class="en-code">{c}</code>
									))}
									<code class="en-code">2e5f-7a90</code>
									<code class="en-code">b3c1-08dd</code>
								</div>
								<div class="en-warn">You will not see these again — store them somewhere safe.</div>
								<label class="en-confirm">
									<span class="en-checkbox" aria-hidden="true">✓</span>
									I've saved my recovery codes
								</label>
							</div>
						)}
					</div>

					{/* ── PHASE SPINE: generate → commit, fills as you advance ── */}
					<div class="en-spine" aria-hidden="true">
						<span class={`en-seg en-seg--gen${s.phase !== 'generate' ? ' is-done' : ' is-here'}`}>
							1 · generate &amp; show
						</span>
						<span class="en-seg-arrow">→</span>
						<span
							class={`en-seg en-seg--commit${
								s.phase === 'commit' ? ' is-here' : s.phase === 'done' ? ' is-done' : ''
							}`}
						>
							2 · prove &amp; commit
						</span>
					</div>
				</div>
			</DiagramStep>
		))
	}
</DiagramSequence>

<style>
	.en {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 12px;
		min-height: 232px;
		margin: 0;
		padding: 4px 2px;
		font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}
	.en * {
		box-sizing: border-box;
	}

	/* per-step accent, resolved to one custom prop the panel reads */
	.en--blue {
		--accent: #2563eb;
	}
	.en--orange {
		--accent: #ea580c;
	}
	.en--green {
		--accent: #16a34a;
	}
	.en--violet {
		--accent: #7c3aed;
	}

	/* ── HEADER RAIL ─────────────────────────────────────────── */
	.en-head {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px 10px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.en-step {
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.en-phase {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1.2;
		padding: 2px 8px;
		border-radius: 999px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 42%, transparent);
		margin: 0;
		white-space: nowrap;
	}
	/* the persistent status pill — the element the reader tracks across steps */
	.en-status {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-left: auto;
		padding: 2px 4px 2px 8px;
		border-radius: 999px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		white-space: nowrap;
	}
	.en-status code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.64rem;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.en-status b {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.66rem;
		font-weight: 700;
		line-height: 1.2;
		padding: 1px 7px;
		border-radius: 999px;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
	}
	.en-status--on {
		border-color: #16a34a;
		background: color-mix(in srgb, #16a34a 9%, transparent);
	}
	.en-status--on b {
		color: #fff;
		background: #16a34a;
	}

	/* ── STAGE: shared centering frame for the per-step schematic ── */
	.en-stage {
		flex: 1 1 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 118px;
		margin: 0;
	}

	/* generic mini-card used by the settings + reveal steps */
	.en-card {
		width: 100%;
		max-width: 22rem;
		border-radius: 10px;
		border: 1.5px solid color-mix(in srgb, var(--accent) 45%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, var(--accent) 5%, var(--sl-color-bg, transparent));
		overflow: hidden;
		margin: 0;
	}
	.en-card-head {
		padding: 6px 12px;
		font-size: 0.68rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
		border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
		margin: 0;
	}

	/* step 1 — the settings row with the highlighted Enable button */
	.en-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		padding: 12px;
		margin: 0;
	}
	.en-row-label {
		font-size: 0.78rem;
		font-weight: 500;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.en-btn {
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1.2;
		padding: 5px 11px;
		border-radius: 7px;
		white-space: nowrap;
		margin: 0;
	}
	.en-btn--hot {
		color: #fff;
		background: var(--accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 28%, transparent);
	}

	/* steps 2 & 5 — the library call + its consequence box */
	.en-call-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 11px;
		width: 100%;
		margin: 0;
	}
	.en-call {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.8rem;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #e2e8f0);
		border-radius: 7px;
		padding: 7px 12px;
		margin: 0;
		text-align: center;
	}
	.en-call b {
		color: var(--accent);
		font-weight: 700;
	}
	.en-call .en-arg {
		color: var(--accent);
		font-weight: 600;
	}

	/* step 2 — the violet elevation gate */
	.en-gate {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 8px 13px;
		border-radius: 9px;
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		margin: 0;
	}
	.en-gate-icon {
		font-size: 1.1rem;
		line-height: 1;
		margin: 0;
	}
	.en-gate-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
		margin: 0;
	}
	.en-gate-title {
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--accent);
		margin: 0;
	}
	.en-gate-sub {
		font-size: 0.64rem;
		font-style: italic;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* step 5 — the green commit confirmation */
	.en-commit {
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 7px 13px;
		border-radius: 9px;
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 11%, transparent);
		margin: 0;
	}
	.en-check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		border-radius: 50%;
		font-size: 0.75rem;
		font-weight: 700;
		color: #fff;
		background: var(--accent);
		margin: 0;
	}
	.en-commit-text {
		font-size: 0.76rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.en-commit-text code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--accent);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	/* step 3 — the server response: QR + code chips + the STILL OFF marker */
	.en-response {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		flex-wrap: wrap;
		margin: 0;
	}
	.en-qr {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 5px;
		margin: 0;
	}
	.en-qr-glyph {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 64px;
		height: 64px;
		font-size: 1.5rem;
		letter-spacing: -2px;
		color: var(--sl-color-white, #1e293b);
		border: 2px solid var(--sl-color-gray-4, #94a3b8);
		border-radius: 8px;
		background: var(--sl-color-bg, transparent);
		margin: 0;
		overflow: hidden;
	}
	.en-qr-cap {
		font-size: 0.6rem;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.en-response-side {
		display: flex;
		flex-direction: column;
		gap: 5px;
		margin: 0;
	}
	.en-mini-label {
		font-size: 0.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--accent);
		margin: 0;
	}
	.en-codes--mini {
		max-width: 13rem;
	}
	.en-codes {
		display: flex;
		flex-wrap: wrap;
		gap: 5px;
		margin: 0;
	}
	.en-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		border-radius: 5px;
		padding: 2px 6px;
		margin: 0;
		white-space: nowrap;
	}
	.en-code--more {
		color: var(--sl-color-gray-3, #64748b);
		background: transparent;
		box-shadow: inset 0 0 0 1px var(--sl-color-gray-5, #cbd5e1);
	}
	.en-stilloff {
		font-size: 0.68rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--accent);
		margin: 2px 0 0;
	}

	/* step 4 — the phone with a 30s ring */
	.en-phone {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 7px;
		margin: 0;
	}
	.en-phone-frame {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		padding: 12px 26px;
		border-radius: 13px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(in srgb, var(--accent) 5%, var(--sl-color-bg, transparent));
		margin: 0;
	}
	.en-phone-app {
		font-size: 0.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.en-phone-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 1.4rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		line-height: 1.1;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	/* the 30s countdown ring, drawn with a conic gradient */
	.en-ring {
		position: absolute;
		top: 10px;
		right: 9px;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: conic-gradient(var(--accent) 0 252deg, var(--sl-color-gray-5, #cbd5e1) 252deg 360deg);
		margin: 0;
	}
	.en-ring::after {
		content: '';
		position: absolute;
		inset: 3.5px;
		border-radius: 50%;
		background: var(--sl-color-bg, #fff);
	}
	.en-phone-note {
		font-size: 0.64rem;
		font-style: italic;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* step 6 — the recovery reveal (schematic; full screen is its own figure) */
	.en-reveal .en-codes {
		padding: 11px 12px 4px;
	}
	.en-warn {
		display: flex;
		align-items: flex-start;
		gap: 6px;
		padding: 7px 12px 0;
		font-size: 0.68rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--accent);
		margin: 0;
	}
	.en-confirm {
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 9px 12px 11px;
		font-size: 0.72rem;
		font-weight: 500;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.en-checkbox {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 16px;
		height: 16px;
		border-radius: 4px;
		font-size: 0.62rem;
		font-weight: 700;
		color: #fff;
		background: var(--accent);
		margin: 0;
	}

	/* ── PHASE SPINE: generate → commit, fills as the reader advances ── */
	.en-spine {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding-top: 10px;
		border-top: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.en-seg {
		font-size: 0.64rem;
		font-weight: 700;
		line-height: 1.2;
		padding: 3px 10px;
		border-radius: 999px;
		color: var(--sl-color-gray-3, #64748b);
