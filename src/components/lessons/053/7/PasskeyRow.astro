---
// PasskeyRow — Chapter 053 Lesson 7 ("Passkeys and WebAuthn"), section
// "The schema this adds". The single table `passkey()` generates, rendered as one
// labelled ER-style row-card — one row per credential, one card-row per column.
//
// Pedagogical job: make two facts visible at a glance so the prose under the
// figure has something to point at:
//   1. `publicKey` is the only secret-SHAPED column here — and it's public. A
//      full leak of this column authenticates nobody. It gets the violet "secret"
//      highlight (the chapter's enclave/secret accent), but labelled "public" so
//      the irony lands.
//   2. `deviceType` and `backedUp` are the two columns the next section turns
//      into a product decision (synced vs device-bound). They share a blue
//      "decision" highlight so the reader can find them again two sections later.
// Everything else is identity (`id`, `userId`, `credentialID`) or bookkeeping
// (`counter`, `transports`, `name`, `aaguid`, `createdAt`) — rendered plainly.
//
// Plain HTML + scoped CSS per the diagrams index (ER-card / annotated-illustration
// shape — deliberately not a diagram engine and not ArrowDiagram, whose
// LeaderLines can't relocate into the Figure lightbox). This echoes the row-card
// styling of the sibling chapter schema figures (Ch 052 ER diagram, L1
// `rows-after-signup`, L3 `token-two-secrets`, L6 `twofactor-schema`): a header
// strip with the table name + "one row per credential" sub, then a list of
// `name · type · note` rows. `margin: 0` resets + `not-content` on the root defeat
// Starlight's injected prose margins; theme-aware chrome via Starlight gray/white
// vars (flips light/dark); the two accent tints are mid-tones that read on both.
//
// Palette, verbatim from the sibling 053 figures (roles-overview / twofactor-schema):
//   violet #7c3aed — the secret-shaped column (`publicKey`) — the enclave accent.
//   blue   #2563eb — the two product-decision columns (`deviceType`, `backedUp`).

import Figure from '../../../figures/Figure.astro';

const VIOLET = '#7c3aed'; // the secret-shaped column
const BLUE = '#2563eb'; // the product-decision columns

type Hi = 'secret' | 'decision';

interface Col {
	key: string;
	type: string;
	note: string;
	hi?: Hi;
}

// Columns in the order the lesson lists them. `hi` flags the three the prose
// distinguishes; the pill text is the one-word reason it's distinguished.
const cols: Col[] = [
	{ key: 'id', type: 'text', note: 'primary key' },
	{ key: 'userId', type: 'text', note: 'FK → user.id — the one-user-to-many side' },
	{ key: 'credentialID', type: 'text', note: 'public identifier; how a sign-in looks the row up' },
	{
		key: 'publicKey',
		type: 'text',
		note: 'the stored public half — a leak of this column authenticates nobody',
		hi: 'secret',
	},
	{ key: 'counter', type: 'integer', note: 'monotonic signing counter (inert for synced keys)' },
	{
		key: 'deviceType',
		type: "'singleDevice' | 'multiDevice'",
		note: 'pinned to one device, or synced across many',
		hi: 'decision',
	},
	{
		key: 'backedUp',
		type: 'boolean',
		note: 'the sync signal — true when a cloud keychain holds it',
		hi: 'decision',
	},
	{ key: 'transports', type: 'text', note: 'how the authenticator is reached — USB, NFC, internal' },
	{ key: 'name', type: 'text', note: 'user-facing label — "iPhone", "Work laptop"' },
	{ key: 'aaguid', type: 'text', note: 'device-model identifier' },
	{ key: 'createdAt', type: 'timestamp', note: 'when the credential was registered' },
];
---

<Figure
	caption="One row per credential. publicKey is the only secret-shaped thing here, and it's public. deviceType and backedUp are the two columns you'll make a product decision on next."
>
	<div class="pk not-content" style={`--violet: ${VIOLET}; --blue: ${BLUE};`}>
		<div class="pk-card">
			{/* ── header strip: the table name + one-row-per-credential sub ── */}
			<div class="pk-head">
				<code class="pk-name">passkey</code>
				<span class="pk-sub">one row per credential</span>
			</div>

			{/* ── the columns: name · type · note, highlighted ones tinted ── */}
			<div class="pk-body">
				{
					cols.map((col) => (
						<div class={`pk-col${col.hi ? ` pk-col--hi pk-col--${col.hi}` : ''}`}>
							<code class="pk-col-key">{col.key}</code>
							<code class="pk-col-type">{col.type}</code>
							{col.hi === 'secret' && <span class="pk-pill pk-pill--secret">the secret (public)</span>}
							{col.hi === 'decision' && <span class="pk-pill pk-pill--decision">decision</span>}
							<span class="pk-col-note">{col.note}</span>
						</div>
					))
				}
			</div>
		</div>
	</div>
</Figure>

<style>
	.pk {
		display: flex;
		justify-content: center;
		margin: 0;
		padding: 4px 2px;
		font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}
	.pk * {
		box-sizing: border-box;
	}

	.pk-card {
		width: 100%;
		max-width: 38rem;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		overflow: hidden;
		margin: 0;
	}

	/* ── header strip ── */
	.pk-head {
		display: flex;
		align-items: baseline;
		gap: 10px;
		padding: 9px 14px;
		background: var(--sl-color-gray-6, #f1f5f9);
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.pk-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.pk-sub {
		font-size: 0.64rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── one column row: name · type · [pill] · note ── */
	.pk-col {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 3px 9px;
		padding: 7px 14px;
		border-top: 1px solid var(--sl-color-gray-6, #e2e8f0);
		line-height: 1.35;
		margin: 0;
	}
	.pk-col:first-child {
		border-top: none;
	}
	.pk-col-key {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}
	.pk-col-type {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--sl-color-gray-3, #64748b);
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.pk-col-note {
		font-size: 0.68rem;
		font-style: italic;
		color: var(--sl-color-gray-2, #475569);
		margin: 0 0 0 auto;
		text-align: right;
	}

	/* ── highlighted columns ── */
	.pk-col--hi {
		border-radius: 6px;
	}
	.pk-col--secret {
		background: color-mix(in srgb, var(--violet) 11%, transparent);
		box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--violet) 42%, transparent);
	}
	.pk-col--secret .pk-col-type {
		color: color-mix(in srgb, var(--violet) 78%, #1e293b);
	}
	.pk-col--decision {
		background: color-mix(in srgb, var(--blue) 10%, transparent);
		box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--blue) 38%, transparent);
	}
	.pk-col--decision .pk-col-type {
		color: color-mix(in srgb, var(--blue) 80%, #1e293b);
	}

	/* ── inline reason pills on the highlighted rows ── */
	.pk-pill {
		font-size: 0.56rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1.3;
		padding: 1px 7px;
		border-radius: 999px;
		white-space: nowrap;
		margin: 0;
	}
	.pk-pill--secret {
		color: #fff;
		background: var(--violet);
		border: 1px solid var(--violet);
	}
	.pk-pill--decision {
		color: #fff;
		background: var(--blue);
		border: 1px solid var(--blue);
	}

	/* ── narrow viewports: let the note drop to its own full-width line ── */
	@media (max-width: 560px) {
		.pk-col-note {
			margin-left: 0;
			text-align: left;
			flex-basis: 100%;
		}
	}
</style>
