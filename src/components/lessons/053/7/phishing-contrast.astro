---
// phishing-contrast — Chapter 053 Lesson 7 ("Passkeys and WebAuthn"), the
// load-bearing visual of the section "Why a phishing proxy beats TOTP but not a
// passkey". Rendered twice (one per tab of the surrounding TabbedContent), once
// with variant="totp" and once with variant="passkey".
//
// Pedagogical goal: the two attacks side by side so the ONLY thing that changes
// between tabs is whether the credential makes it across the attacker's hop.
//   - variant="totp"   — the 6-digit code flows User -> Phishing -> Real, two
//     completed ORANGE arrows. The code survives one relay and still works.
//   - variant="passkey" — same three boxes in the same positions, plus the
//     User's Authenticator (VIOLET) below them. The look-alike asks the browser
//     to invoke the authenticator; that ONE arrow is struck through and carries a
//     red "origin mismatch" badge. The authenticator never signs; no arrow ever
//     reaches the Real site, so the right side is conspicuously empty.
//
// Why NOT ArrowDiagram here: its arrows are LeaderLines positioned from
// document.body and built once after `load`. Inside a TabbedContent the inactive
// tab is `hidden` (display:none) at build time, so its boxes measure 0x0 and the
// lines draw as garbage, and there is no tab-switch hook to rebuild them. So the
// arrows are authored as plain CSS + one inline SVG instead — they live in the
// normal flow, need no measuring, and render correctly whether the tab is shown
// or hidden. This is the same "no hand-placed geometry to drift" discipline the
// sibling flow strips follow (magic-link-flow et al.): the horizontal arrows are
// grid bands spanning between columns, so CSS does the positioning math.
//
// Palette is the chapter's, verbatim from the sibling 053 figures:
//   slate  — neutral chrome / the User and Real-site boxes
//   red    — the attacker-controlled Phishing box + the origin-mismatch badge
//   orange — the ceremony / relay arrows
//   violet — the Authenticator (the secret that never leaves)
// color-scheme pinned light so the hand-picked accent tints survive dark mode;
// margin:0 resets defeat Starlight's injected prose margins; `not-content` opts
// the figure out of prose styling.

interface Props {
	variant: 'totp' | 'passkey';
}

const { variant } = Astro.props;
const isPasskey = variant === 'passkey';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Chapter palette — same constants the sibling 053 figures use.
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const INK_FAINT = '#94a3b8'; // slate-400 — idle / empty
const SURFACE = '#ffffff';
const GRID = '#e2e8f0'; // slate-200 — soft borders

const RED = '#dc2626'; // attacker-controlled / origin mismatch
const ORANGE = '#ea580c'; // the ceremony / relay arrow
const VIOLET = '#7c3aed'; // the authenticator / the secret

// ---- atoms -----------------------------------------------------------------

const stage = `display: flex; flex-direction: column; align-items: stretch; gap: 0; margin: 0; padding: 8px 2px 4px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The three top boxes + the two arrow bands share one 5-column grid:
//   col 1 = User   col 2 = arrow   col 3 = Phishing   col 4 = arrow   col 5 = Real
// so each arrow band spans exactly the gap between the two boxes it joins, and
// CSS grid does all the positioning — no hand-placed geometry.
const row = `display: grid; grid-template-columns: minmax(0, 1fr) 86px minmax(0, 1fr) 86px minmax(0, 1fr); align-items: center; column-gap: 0; margin: 0;`;

// A box cell. `tone` drives border + wash + ink:
//   neutral -> slate border, white fill
//   red     -> red border, red wash (the attacker-controlled site)
const box = (tone: 'neutral' | 'red', dim = false) => {
	const accent = tone === 'red' ? RED : GRID;
	const bg = tone === 'red' ? `color-mix(in srgb, ${RED} 8%, ${SURFACE})` : SURFACE;
	const weight = tone === 'red' ? '1.5px' : '1.5px';
	const ring =
		tone === 'red'
			? ` box-shadow: inset 0 0 0 1px color-mix(in srgb, ${RED} 55%, transparent);`
			: '';
	return (
		`box-sizing: border-box; grid-row: 1; display: flex; flex-direction: column;` +
		` align-items: center; justify-content: center; gap: 3px; margin: 0; padding: 12px 8px;` +
		` border: ${weight} solid ${accent}; border-radius: 11px; background: ${bg};` +
		` text-align: center; opacity: ${dim ? 0.6 : 1};${ring}`
	);
};

const boxName = (color: string) =>
	`margin: 0; font-family: ${sans}; font-size: 13px; font-weight: 800; line-height: 1.2; color: ${color};`;

const boxAddr = (color: string) =>
	`margin: 0; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.25; color: ${color}; word-break: break-all;`;

const boxRole = (color: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 600; line-height: 1.2; letter-spacing: 0.02em; text-transform: uppercase; color: ${color};`;

// A horizontal arrow band that sits in an arrow column (grid col 2 or 4) and
// spans the gap between two boxes. `blocked` strikes the rule with a red bar and
// drops the arrowhead. The label rides above the rule.
const arrowBand = (gridCol: number) =>
	`grid-row: 1; grid-column: ${gridCol}; position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; margin: 0; padding: 0 2px; min-width: 0;`;

const arrowLabel = (color: string, blocked = false) => {
	const border = blocked ? RED : color;
	const bg = blocked
		? `color-mix(in srgb, ${RED} 12%, ${SURFACE})`
		: `color-mix(in srgb, ${color} 10%, ${SURFACE})`;
	const ink = blocked
		? `color-mix(in srgb, ${RED} 28%, ${INK})`
		: `color-mix(in srgb, ${color} 72%, ${INK})`;
	return (
		`box-sizing: border-box; max-width: 100%; padding: 2px 7px; border-radius: 6px;` +
		` border: 1px solid ${border}; background: ${bg}; font-family: ${mono};` +
		` font-size: 9.5px; font-weight: 800; line-height: 1.25; text-align: center;` +
		` color: ${ink}; white-space: normal;`
	);
};

// The arrow rule itself, with an arrowhead at the right end via ::after (set in
// the scoped <style> by data-state). A struck variant lays a red bar across it.
const arrowRule = (color: string) =>
	`position: relative; width: 100%; height: 2px; border-radius: 2px; background: ${color};`;
---

<div style={stage} class="phc" data-variant={variant}>
	{/* ── the three top boxes + the two horizontal arrow bands ── */}
	<div style={row}>
		{/* User — col 1 */}
		<div style={`${box('neutral')} grid-column: 1;`}>
			<span style={boxRole(INK_FAINT)}>The user</span>
			<span style={boxName(INK)}>You</span>
			<span style={boxAddr(INK_SOFT)}>on the look-alike page</span>
		</div>

		{/* arrow band: User → Phishing (col 2) */}
		<div style={arrowBand(2)}>
			<span style={arrowLabel(ORANGE)}>
				{isPasskey ? 'asks browser to sign in' : 'types the 6-digit code'}
			</span>
			<span style={arrowRule(ORANGE)} class="phc-rule" data-head="right"></span>
		</div>

		{/* Phishing site — col 3 (always the attacker-controlled, red box) */}
		<div style={`${box('red')} grid-column: 3;`}>
			<span style={boxRole(`color-mix(in srgb, ${RED} 45%, ${INK_SOFT})`)}>
				Phishing site
			</span>
			<span style={boxName(`color-mix(in srgb, ${RED} 30%, ${INK})`)}>Attacker</span>
			<span style={boxAddr(RED)}>acme-login.com</span>
		</div>

		{/* arrow band: Phishing → Real (col 4) — relayed for TOTP, absent for passkey */}
		<div style={arrowBand(4)}>
			{!isPasskey && (
				<>
					<span style={arrowLabel(ORANGE)}>relays the code</span>
					<span style={arrowRule(ORANGE)} class="phc-rule" data-head="right" />
				</>
			)}
			{isPasskey && (
				<span class="phc-nothing" style={`color: ${INK_FAINT};`}>nothing to relay</span>
			)}
		</div>

		{/* Real site — col 5 */}
		<div style={`${box('neutral', isPasskey)} grid-column: 5;`}>
			<span style={boxRole(INK_FAINT)}>Real site</span>
			<span style={boxName(INK)}>Acme</span>
			<span style={boxAddr(INK_SOFT)}>acme.com</span>
		</div>
	</div>

	{/* ── passkey only: the User's Authenticator below, and the blocked invoke ── */}
	{
		isPasskey && (
			<div class="phc-auth-wrap">
				{/* the blocked arrow from the Phishing site down to the Authenticator,
				    drawn as one inline SVG so its diagonal path needs no measuring.
				    A red strike bar crosses it; the "origin mismatch" badge labels it. */}
				<div class="phc-block">
					<svg
						class="phc-block-svg"
						viewBox="0 0 200 56"
						preserveAspectRatio="none"
						aria-hidden="true"
					>
						{/* the invoke attempt: from the Phishing box (top-right) down to the
						    Authenticator (bottom-left) */}
						<line
							x1="168"
							y1="4"
							x2="40"
							y2="50"
							stroke={ORANGE}
							stroke-width="2.2"
							stroke-dasharray="5 4"
						/>
						{/* the red strike bar across the path's midpoint */}
						<line
							x1="92"
							y1="14"
							x2="116"
							y2="40"
							stroke={RED}
							stroke-width="3.4"
							stroke-linecap="round"
						/>
					</svg>
					<span class="phc-block-badge">origin mismatch</span>
				</div>

				{/* the Authenticator — the secret that never leaves; it never signs */}
				<div class="phc-auth">
					<span class="phc-auth-ic" aria-hidden="true">
						<svg
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="M12 2.5 4.5 5.5v6c0 4.5 3.2 7.6 7.5 9 4.3-1.4 7.5-4.5 7.5-9v-6L12 2.5Z" />
							<path d="M9.2 12.2l1.9 1.9 3.7-3.9" />
						</svg>
					</span>
					<span class="phc-auth-name">Authenticator</span>
					<span class="phc-auth-sub">passkey for acme.com · never signs</span>
				</div>
			</div>
		)
	}
</div>

<style>
	/* arrowhead at the right end of a horizontal rule */
	.phc-rule[data-head='right']::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1px;
		transform: translateY(-50%);
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-left: 7px solid currentColor;
	}
	/* the orange rules carry an orange head; color comes from the inline background,
	   so mirror it onto currentColor for the ::after head */
	.phc[data-variant] .phc-rule {
		color: #ea580c;
	}

	.phc-nothing {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		text-align: center;
		opacity: 0.8;
	}

	/* ── the authenticator block under the User column ── */
	.phc-auth-wrap {
		display: grid;
		/* line up under the User column (col 1 of the 5-col row above): the User
		   column is 1fr of (1fr 86px 1fr 86px 1fr) = ~ the first third minus gaps.
		   A single centered column under the left third keeps it visually under User. */
		grid-template-columns: minmax(0, 1fr) 86px minmax(0, 2fr);
		align-items: start;
		margin: 2px 0 0;
	}
	.phc-block {
		grid-column: 1 / 3;
		position: relative;
		height: 56px;
		margin: 0;
	}
	.phc-block-svg {
		display: block;
		width: 100%;
		height: 100%;
		overflow: visible;
	}
	.phc-block-badge {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		padding: 2px 8px;
		border-radius: 999px;
		border: 1px solid #dc2626;
		background: color-mix(in srgb, #dc2626 12%, #ffffff);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 9.5px;
		font-weight: 800;
		letter-spacing: 0.01em;
		line-height: 1.2;
		color: #b91c1c; /* red-700 */
		white-space: nowrap;
	}
	.phc-auth {
		grid-column: 1;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		margin: 0;
		padding: 10px 8px;
		border: 1.5px solid #7c3aed;
		border-radius: 11px;
		background: color-mix(in srgb, #7c3aed 8%, #ffffff);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #7c3aed 35%, transparent);
		text-align: center;
	}
	.phc-auth-ic {
		display: inline-flex;
		width: 22px;
		height: 22px;
		color: #7c3aed;
	}
	.phc-auth-ic :global(svg) {
		width: 100%;
		height: 100%;
		display: block;
	}
	.phc-auth-name {
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 12px;
		font-weight: 800;
		line-height: 1.2;
		color: color-mix(in srgb, #7c3aed 35%, #1e293b);
	}
	.phc-auth-sub {
		margin: 0;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 9px;
		font-weight: 600;
		line-height: 1.2;
		color: #64748b;
	}

	/* ── narrow viewports: the relay arrows have little room; let labels wrap and
	      tighten the arrow columns so the three boxes stay readable ── */
	@media (max-width: 560px) {
		.phc > div:first-child {
			grid-template-columns: minmax(0, 1fr) 60px minmax(0, 1fr) 60px minmax(0, 1fr) !important;
		}
	}
</style>
