---
// signin-sequence — Chapter 053 Lesson 7 ("Passkeys and WebAuthn"),
// section "Signing in with a passkey". One frame of the authentication ceremony;
// the surrounding MDX renders five of these (step={1..5}) inside a
// DiagramSequence, so the reader scrubs the round-trip one hop at a time.
//
// Pedagogical job: this is the deliberate MIRROR of registration-sequence.astro —
// SAME four actors on the same strip, SAME chapter palette, SAME CSS-grid arrow
// idiom, so the pair reads as matched. What flips is the DIRECTION OF TRUST: in
// registration the call travelled right into the enclave and a public key came
// back to be stored; here the RP issues a challenge that travels in toward the
// enclave, the enclave signs it, and the signature travels back out to the RP,
// which verifies it and mints a session. Registration ends green on the settings
// page (a credential was stored); sign-in ends green on the user (they are in).
//
// The strip, left -> right, matches the sibling exactly:
//   User · Browser · Authenticator · RP
// with three arrow bands in the gaps. The challenge issued by the RP travels left
// (RP -> Authenticator) to be signed; the signature travels right (Authenticator
// -> RP) to be verified. The Authenticator carries the violet "the secret never
// leaves" accent throughout, intensified on the signing step; the RP turns green
// when it verifies and issues the session, and the user turns green when signed in
// — the chapter's orange=ceremony / green=session-done / violet=enclave coding.
//
// Why a hand-rolled CSS strip and not ArrowDiagram / Mermaid: identical reasoning
// to the sibling registration-sequence / roles-overview figures — LeaderLines /
// Mermaid would re-measure and reflow per step (and can't be re-laid-out on the
// DiagramSequence's visibility toggles), whereas grid bands need no measuring and
// read correctly whether their step is the active (visible) one or an inactive
// (visibility:hidden) sibling. color-scheme pinned light so the accent tints
// survive dark mode; margin:0 resets defeat Starlight's injected prose margins.
//
// Palette, verbatim from the sibling 053 figures (registration-sequence /
// roles-overview / phishing-contrast):
//   slate  — neutral chrome
//   orange — the library call / ceremony hops      (#ea580c)
//   green  — verified-&-signed-in done             (#16a34a)
//   violet — the Authenticator / the secret        (#7c3aed)

interface Props {
	/** Which frame of the 5-step ceremony to render (1-based). */
	step: number;
}

const { step } = Astro.props;

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Chapter palette — same constants the sibling 053 figures use.
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const INK_FAINT = '#94a3b8'; // slate-400 — idle / labels
const SURFACE = '#ffffff';
const GRID = '#e2e8f0'; // slate-200 — soft borders

const ORANGE = '#ea580c'; // the library call / ceremony hop
const GREEN = '#16a34a'; // verified-&-signed-in done
const VIOLET = '#7c3aed'; // the authenticator / the secret

// ---- per-step activation -------------------------------------------------
// For each step, which boxes are "active" (full strength + colored ring) and
// which arrow band is the lit hop. Idle elements stay drawn but dimmed.
type Accent = 'orange' | 'green' | 'violet';

interface Frame {
	// active box index (0=User 1=Browser 2=Authenticator 3=RP) -> its accent
	boxes: Partial<Record<0 | 1 | 2 | 3, Accent>>;
	// active arrow band (0=User↔Browser 1=Browser↔Authenticator 2=Authenticator↔RP)
	band?: { idx: 0 | 1 | 2; accent: Accent; dir: 'right' | 'left' };
}

const frames: Record<number, Frame> = {
	// 1 — neutral: the user taps "Sign in with a passkey" / picks from the
	//     autofill dropdown. The first hop is user -> browser.
	1: { boxes: {}, band: { idx: 0, accent: 'orange', dir: 'right' } },
	// 2 — orange: signIn.passkey() runs; the RP issues a time-bound challenge,
	//     which travels left from the RP toward the enclave to be signed.
	2: { boxes: { 3: 'orange' }, band: { idx: 2, accent: 'orange', dir: 'left' } },
	// 3 — violet: the enclave signs the challenge with the private key, which
	//     never leaves. The lit hop is browser -> authenticator (the signing leg).
	3: { boxes: { 2: 'violet' }, band: { idx: 1, accent: 'violet', dir: 'right' } },
	// 4 — orange -> green: the signature travels back out to the RP, which
	//     verifies it against the stored public key and issues a fresh session.
	4: { boxes: { 3: 'green' }, band: { idx: 2, accent: 'green', dir: 'right' } },
	// 5 — green: signed in. The user is in — no password, no second factor.
	5: { boxes: { 0: 'green' } },
};

const frame = frames[step] ?? frames[1];

const accentHex = (a: Accent) => (a === 'orange' ? ORANGE : a === 'green' ? GREEN : VIOLET);

// ---- the shared 7-column grid --------------------------------------------
// One template drives the strip: four boxes in odd columns, three arrow bands in
// the even gaps, so each band sits exactly between the two boxes it joins.
//   col1 User  col2 →  col3 Browser  col4 →  col5 Authenticator  col6 →  col7 RP
const COLS =
	'grid-template-columns: minmax(0,1fr) 70px minmax(0,1fr) 70px minmax(0,1fr) 70px minmax(0,1fr);';

const stage = `display: grid; ${COLS} align-items: stretch; column-gap: 0; margin: 0; padding: 8px 2px 4px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A role box. Idle boxes keep a slate border + reduced opacity so the lit ones
// pop; an active box gets its accent border, a faint accent wash, and an inset
// ring. The Authenticator always carries a hint of violet even when idle (its
// identity as "the enclave"), matching the sibling registration-sequence.
const box = (gridCol: number, active: Accent | undefined, alwaysViolet = false) => {
	const idle = alwaysViolet ? VIOLET : GRID;
	const accent = active ? accentHex(active) : idle;
	const bg = active
		? `color-mix(in srgb, ${accent} 9%, ${SURFACE})`
		: alwaysViolet
			? `color-mix(in srgb, ${VIOLET} 5%, ${SURFACE})`
			: SURFACE;
	const ring = active
		? ` box-shadow: inset 0 0 0 1px color-mix(in srgb, ${accent} 45%, transparent);`
		: alwaysViolet
			? ` box-shadow: inset 0 0 0 1px color-mix(in srgb, ${VIOLET} 22%, transparent);`
			: '';
	const dim = active || alwaysViolet ? 1 : 0.55;
	return (
		`box-sizing: border-box; grid-row: 1; grid-column: ${gridCol}; display: flex;` +
		` flex-direction: column; align-items: center; justify-content: center; gap: 4px;` +
		` margin: 0; padding: 12px 8px; border: 1.5px solid ${accent}; border-radius: 12px;` +
		` background: ${bg}; text-align: center; opacity: ${dim};${ring}` +
		` transition: opacity .15s, border-color .15s, background-color .15s;`
	);
};

const boxRole = (color: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 700; line-height: 1.2; letter-spacing: 0.04em; text-transform: uppercase; color: ${color};`;

const boxName = (color: string) =>
	`margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 800; line-height: 1.2; color: ${color};`;

const boxNote = (color: string) =>
	`margin: 0; font-family: ${mono}; font-size: 9px; font-weight: 600; line-height: 1.25; color: ${color}; word-break: break-word;`;

// An arrow band in a gap column. The active band lights to its accent with a
// label + arrowhead; idle bands fade to a faint slate rule with no head, so the
// strip's geometry stays put but the eye lands on the lit hop.
const arrowBand = (gridCol: number) =>
	`grid-row: 1; grid-column: ${gridCol}; position: relative; display: flex; flex-direction: column;` +
	` align-items: center; justify-content: center; gap: 5px; margin: 0; padding: 0 2px; min-width: 0;`;

const bandLabel = (color: string) =>
	`box-sizing: border-box; max-width: 100%; padding: 2px 6px; border-radius: 6px; border: 1px solid ${color};` +
	` background: color-mix(in srgb, ${color} 10%, ${SURFACE}); font-family: ${mono}; font-size: 8.5px;` +
	` font-weight: 800; line-height: 1.2; text-align: center; color: color-mix(in srgb, ${color} 70%, ${INK}); white-space: normal;`;

const bandRule = (color: string) =>
	`position: relative; width: 100%; height: 2px; border-radius: 2px; background: ${color};`;

// Per-band content: each gap has a fixed semantic for THIS ceremony. Band 0 is
// the user kicking it off; band 1 is the signing leg (browser hands the
// challenge to the enclave); band 2 carries the challenge out and the signature
// back — its label follows whichever leg is lit (issued challenge left, signed
// assertion right).
const band2Label = frame.band?.idx === 2 && frame.band.dir === 'left' ? 'challenge' : 'signed assertion';
const bandLabels = ['tap / pick passkey', 'signs the challenge', band2Label] as const;
---

<div style={stage} class="sgs" data-step={step}>
	{/* User / sign-in page — col 1 */}
	<div style={box(1, frame.boxes[0])}>
		<span style={boxRole(frame.boxes[0] ? accentHex(frame.boxes[0]) : INK_FAINT)}>
			Sign-in page
		</span>
		<span style={boxName(INK)}>The user</span>
		<span style={boxNote(INK_SOFT)}>
			{step === 5 ? 'signed in — no password' : 'picks "Sign in with a passkey"'}
		</span>
	</div>

	{/* band 0: User ↔ Browser */}
	<div style={arrowBand(2)}>
		{frame.band?.idx === 0 ? (
			<>
				<span style={bandLabel(accentHex(frame.band.accent))}>{bandLabels[0]}</span>
				<span
					style={bandRule(accentHex(frame.band.accent))}
					class="sgs-rule"
					data-head={frame.band.dir}
					data-on
				></span>
			</>
		) : (
			<span style={bandRule(GRID)} class="sgs-rule"></span>
		)}
	</div>

	{/* Browser — col 3 */}
	<div style={box(3, frame.boxes[1])}>
		<span style={boxRole(frame.boxes[1] ? accentHex(frame.boxes[1]) : INK_FAINT)}>
			User agent
		</span>
		<span style={boxName(INK)}>Browser</span>
		<span style={boxNote(INK_SOFT)}>runs signIn.passkey()</span>
	</div>

	{/* band 1: Browser ↔ Authenticator (the signing leg) */}
	<div style={arrowBand(4)}>
		{frame.band?.idx === 1 ? (
			<>
				<span style={bandLabel(accentHex(frame.band.accent))}>{bandLabels[1]}</span>
				<span
					style={bandRule(accentHex(frame.band.accent))}
					class="sgs-rule"
					data-head={frame.band.dir}
					data-on
				></span>
			</>
		) : (
			<span style={bandRule(GRID)} class="sgs-rule"></span>
		)}
	</div>

	{/* Authenticator — col 5, always the violet enclave */}
	<div style={box(5, frame.boxes[2], true)}>
		<span style={boxRole(`color-mix(in srgb, ${VIOLET} 45%, ${INK_SOFT})`)}>Authenticator</span>
		<span style={boxName(`color-mix(in srgb, ${VIOLET} 32%, ${INK})`)}>Secure enclave</span>
		<span style={boxNote(INK_SOFT)}>
			{step === 3 ? 'signs with the private key' : 'private key never leaves'}
		</span>
	</div>

	{/* band 2: Authenticator ↔ RP (challenge out, signature back) */}
	<div style={arrowBand(6)}>
		{frame.band?.idx === 2 ? (
			<>
				<span style={bandLabel(accentHex(frame.band.accent))}>{bandLabels[2]}</span>
				<span
					style={bandRule(accentHex(frame.band.accent))}
					class="sgs-rule"
					data-head={frame.band.dir}
					data-on
				></span>
			</>
		) : (
			<span style={bandRule(GRID)} class="sgs-rule"></span>
		)}
	</div>

	{/* Relying party — col 7 */}
	<div style={box(7, frame.boxes[3])}>
		<span style={boxRole(frame.boxes[3] ? accentHex(frame.boxes[3]) : INK_FAINT)}>
			Relying party
		</span>
		<span style={boxName(INK)}>Your server</span>
		<span style={boxNote(INK_SOFT)}>
			{step >= 4
				? 'verifies, issues a session'
				: step === 2
					? 'issues a challenge'
					: 'holds your public key'}
		</span>
	</div>
</div>

<style>
	/* arrowhead at the active end of a lit rule; idle rules carry no head. */
	.sgs-rule[data-on][data-head='right']::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1px;
		transform: translateY(-50%);
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-left: 7px solid currentColor;
	}
	.sgs-rule[data-on][data-head='left']::after {
		content: '';
		position: absolute;
		top: 50%;
		left: -1px;
		transform: translateY(-50%);
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-right: 7px solid currentColor;
	}
	/* the head inherits the lit rule's color: mirror each step's accent onto
	   currentColor so ::after picks it up. Steps 1-2 orange, 3 violet, 4 green. */
	.sgs[data-step='1'] .sgs-rule[data-on],
	.sgs[data-step='2'] .sgs-rule[data-on] {
		color: #ea580c;
	}
	.sgs[data-step='3'] .sgs-rule[data-on] {
		color: #7c3aed;
	}
	.sgs[data-step='4'] .sgs-rule[data-on] {
		color: #16a34a;
	}

	/* narrow viewports: tighten the gap columns and let the in-gap labels wrap so
	   the four boxes stay readable. */
	@media (max-width: 640px) {
		.sgs {
			grid-template-columns:
				minmax(0, 1fr) 46px minmax(0, 1fr) 46px minmax(0, 1fr) 46px minmax(0, 1fr) !important;
		}
	}
</style>
