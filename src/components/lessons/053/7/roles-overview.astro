---
// roles-overview — Chapter 053 Lesson 7 ("Passkeys and WebAuthn"), the map for
// the section "Three roles and two ceremonies". The overview figure every later
// sequence diagram is a zoom-in of.
//
// Pedagogical goal: one compact picture that NAMES all three WebAuthn roles and
// draws BOTH ceremonies as round-trips between them, so the reader holds "RP /
// browser / authenticator" + "registration vs authentication" before any code.
//
// Layout — the three roles sit on one center row (RP · Browser · Authenticator),
// the two ceremonies bracket them: REGISTRATION above (orange), AUTHENTICATION
// below (green). Each ceremony is a lane with two arrow sub-rows — the request
// travelling RIGHT (RP -> Browser -> Authenticator) and the response travelling
// LEFT back to the RP — so both directions of each round-trip are visible. The
// Authenticator box carries a violet accent to echo "the private key lives here
// and never leaves."
//
// Why NOT ArrowDiagram here: its arrows are LeaderLines, one curve per pair of
// anchors, positioned from document.body after `load`. To draw RP->Browser->
// Authenticator as a round-trip you'd need ~8 short curves through a tight
// horizontal strip with stacked arrowheads and colliding labels — exactly the
// fan-out / shared-endpoint pain the ArrowDiagram doc warns about. So the arrows
// are CSS grid bands instead: each hop is a horizontal rule in the gap column
// between two boxes, positioned by the grid with no measuring. This is the same
// idiom (and the same palette) the sibling phishing-contrast figure uses two
// sections earlier, so the two figures read as a matched set.
//
// Palette is the chapter's, verbatim from the sibling 053 figures:
//   slate  — neutral chrome / the RP and Browser boxes
//   orange — the registration ceremony            (#ea580c)
//   green  — the authentication ceremony          (#16a34a)
//   violet — the Authenticator / the secret       (#7c3aed)
// color-scheme pinned light so the hand-picked accent tints survive dark mode;
// margin:0 resets defeat Starlight's injected prose margins.

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Chapter palette — same constants the sibling 053 figures use.
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const INK_FAINT = '#94a3b8'; // slate-400 — idle / labels
const SURFACE = '#ffffff';
const GRID = '#e2e8f0'; // slate-200 — soft borders

const ORANGE = '#ea580c'; // the registration ceremony
const GREEN = '#16a34a'; // the authentication ceremony
const VIOLET = '#7c3aed'; // the authenticator / the secret

// ---- the shared 5-column grid ----------------------------------------------
// One column template drives the boxes row AND both ceremony lanes, so each
// arrow band sits in exactly the gap between the two boxes it joins:
//   col 1 = RP   col 2 = gap   col 3 = Browser   col 4 = gap   col 5 = Authenticator
const COLS =
	'grid-template-columns: minmax(0, 1fr) 128px minmax(0, 1fr) 128px minmax(0, 1fr);';

const stage = `display: flex; flex-direction: column; align-items: stretch; gap: 4px; margin: 0; padding: 6px 2px 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

const row = `display: grid; ${COLS} align-items: center; column-gap: 0; margin: 0;`;

// A role box. `tone` drives border + wash + ink:
//   neutral -> slate border, white fill
//   violet  -> violet border, violet wash + inset ring (the authenticator)
const box = (tone: 'neutral' | 'violet') => {
	const accent = tone === 'violet' ? VIOLET : GRID;
	const bg = tone === 'violet' ? `color-mix(in srgb, ${VIOLET} 8%, ${SURFACE})` : SURFACE;
	const ring =
		tone === 'violet'
			? ` box-shadow: inset 0 0 0 1px color-mix(in srgb, ${VIOLET} 40%, transparent);`
			: '';
	return (
		`box-sizing: border-box; grid-row: 1; display: flex; flex-direction: column;` +
		` align-items: center; justify-content: center; gap: 4px; margin: 0; padding: 13px 10px;` +
		` border: 1.5px solid ${accent}; border-radius: 12px; background: ${bg};` +
		` text-align: center;${ring}`
	);
};

const boxRole = (color: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; line-height: 1.2; letter-spacing: 0.04em; text-transform: uppercase; color: ${color};`;

const boxName = (color: string) =>
	`margin: 0; font-family: ${sans}; font-size: 14px; font-weight: 800; line-height: 1.2; color: ${color};`;

const boxNote = (color: string) =>
	`margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 500; line-height: 1.25; color: ${color};`;

// ---- ceremony lanes --------------------------------------------------------
// A lane title pill that floats at the left edge of a ceremony's arrow stack.
const laneTag = (color: string) =>
	`display: inline-flex; align-items: center; gap: 5px; align-self: flex-start; margin: 0 0 1px; padding: 2px 9px; border-radius: 999px; border: 1px solid ${color}; background: color-mix(in srgb, ${color} 10%, ${SURFACE}); font-family: ${sans}; font-size: 10px; font-weight: 800; letter-spacing: 0.02em; color: color-mix(in srgb, ${color} 72%, ${INK});`;

const laneSub = (color: string) =>
	`font-family: ${mono}; font-size: 9px; font-weight: 700; text-transform: none; letter-spacing: 0; color: color-mix(in srgb, ${color} 55%, ${INK_SOFT});`;

// An arrow band occupying one gap column (grid col 2 or 4). It stacks a label
// over a horizontal rule. `dir` puts the arrowhead on the correct end.
const arrowBand = (gridCol: number) =>
	`grid-row: 1; grid-column: ${gridCol}; position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; margin: 0; padding: 0 4px; min-width: 0;`;

const arrowLabel = (color: string) =>
	`box-sizing: border-box; max-width: 100%; padding: 2px 8px; border-radius: 6px; border: 1px solid ${color}; background: color-mix(in srgb, ${color} 9%, ${SURFACE}); font-family: ${mono}; font-size: 9.5px; font-weight: 800; line-height: 1.25; text-align: center; color: color-mix(in srgb, ${color} 70%, ${INK}); white-space: nowrap;`;

const arrowRule = (color: string) =>
	`position: relative; width: 100%; height: 2px; border-radius: 2px; background: ${color};`;
---

<div style={stage} class="rov">
	{/* ── REGISTRATION lane (orange): request travels right, response back left ── */}
	<div class="rov-lane">
		<span style={laneTag(ORANGE)}>
			Registration
			<span style={laneSub(ORANGE)}>create()</span>
		</span>

		{/* request leg → */}
		<div style={`${row} margin-top: 1px;`}>
			<div style={arrowBand(2)}>
				<span style={arrowLabel(ORANGE)}>navigator.credentials.create()</span>
				<span style={arrowRule(ORANGE)} class="rov-rule" data-head="right"></span>
			</div>
			<div style={arrowBand(4)}>
				<span style={arrowRule(ORANGE)} class="rov-rule" data-head="right"></span>
			</div>
		</div>

		{/* response leg ← */}
		<div style={row}>
			<div style={arrowBand(2)}>
				<span style={arrowRule(ORANGE)} class="rov-rule" data-head="left"></span>
				<span style={arrowLabel(ORANGE)}>public key + attestation</span>
			</div>
			<div style={arrowBand(4)}>
				<span style={arrowRule(ORANGE)} class="rov-rule" data-head="left"></span>
			</div>
		</div>
	</div>

	{/* ── the three roles ── */}
	<div style={row}>
		{/* Relying party — col 1 */}
		<div style={`${box('neutral')} grid-column: 1;`}>
			<span style={boxRole(INK_FAINT)}>Relying party</span>
			<span style={boxName(INK)}>Your server</span>
			<span style={boxNote(INK_SOFT)}>stores public keys, issues challenges</span>
		</div>

		{/* Browser — col 3 */}
		<div style={`${box('neutral')} grid-column: 3;`}>
			<span style={boxRole(INK_FAINT)}>User agent</span>
			<span style={boxName(INK)}>Browser</span>
			<span style={boxNote(INK_SOFT)}>enforces the origin check</span>
		</div>

		{/* Authenticator — col 5, the violet accent */}
		<div style={`${box('violet')} grid-column: 5;`}>
			<span style={boxRole(`color-mix(in srgb, ${VIOLET} 45%, ${INK_SOFT})`)}>
				Authenticator
			</span>
			<span style={boxName(`color-mix(in srgb, ${VIOLET} 32%, ${INK})`)}>Secure enclave</span>
			<span style={boxNote(INK_SOFT)}>holds the private key — never leaves</span>
		</div>
	</div>

	{/* ── AUTHENTICATION lane (green): request travels right, response back left ── */}
	<div class="rov-lane">
		{/* request leg → */}
		<div style={`${row} margin-top: 1px;`}>
			<div style={arrowBand(2)}>
				<span style={arrowLabel(GREEN)}>navigator.credentials.get()</span>
				<span style={arrowRule(GREEN)} class="rov-rule" data-head="right"></span>
			</div>
			<div style={arrowBand(4)}>
				<span style={arrowLabel(GREEN)}>challenge</span>
				<span style={arrowRule(GREEN)} class="rov-rule" data-head="right"></span>
			</div>
		</div>

		{/* response leg ← */}
		<div style={row}>
			<div style={arrowBand(2)}>
				<span style={arrowRule(GREEN)} class="rov-rule" data-head="left"></span>
				<span style={arrowLabel(GREEN)}>signature</span>
			</div>
			<div style={arrowBand(4)}>
				<span style={arrowRule(GREEN)} class="rov-rule" data-head="left"></span>
			</div>
		</div>

		<span style={`${laneTag(GREEN)} align-self: flex-start; margin-top: 1px;`}>
			Authentication
			<span style={laneSub(GREEN)}>get()</span>
		</span>
	</div>
</div>

<style>
	.rov-lane {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 3px;
		margin: 0;
	}

	/* arrowhead at the right end of a horizontal rule */
	.rov-rule[data-head='right']::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1px;
		transform: translateY(-50%);
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-left: 7px solid currentColor;
	}
	/* arrowhead at the left end */
	.rov-rule[data-head='left']::after {
		content: '';
		position: absolute;
		top: 50%;
		left: -1px;
		transform: translateY(-50%);
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-right: 7px solid currentColor;
	}
	/* the head inherits the rule's own color via currentColor: mirror the inline
	   background onto color so ::after picks it up. Orange rules live in the
	   registration lane, green in the authentication lane. */
	.rov-lane:first-of-type .rov-rule {
		color: #ea580c;
	}
	.rov-lane:last-of-type .rov-rule {
		color: #16a34a;
	}

	/* narrow viewports: tighten the gap columns so the three boxes stay readable
	   and let the in-gap labels wrap rather than overflow. */
	@media (max-width: 620px) {
		.rov [style*='grid-template-columns'] {
			grid-template-columns: minmax(0, 1fr) 92px minmax(0, 1fr) 92px minmax(0, 1fr) !important;
		}
		.rov span[style*='white-space: nowrap'] {
			white-space: normal !important;
		}
	}
</style>
