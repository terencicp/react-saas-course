---
// reset-flow — Chapter 053 Lesson 4, "Password reset".
//
// The lesson's named load-bearing visual: the whole reset, held as one scrubbable
// sequence. It's the L4 counterpart to sign-up's `signup-flow`, sign-in's happy-
// path, and L3's `verify-flow` — same idiom (DiagramSequence + a single strip whose
// only change per step is which node is LIT) plus two things this flow needs that
// the others didn't:
//
//   1. The TWO-LEG, ONE-INBOX-ROUND-TRIP shape. The eight stages are split by an
//      inbox seam into a REQUEST leg (submit -> mint -> email) and, after the user
//      reads their mail, a RESET leg (click -> validate -> hash -> kill -> signed
//      in). The seam is a real node in the strip, not just a gap, and a leg label
//      sits over each group — so the round-trip is structural, not implied.
//
//   2. The session death, made VISIBLE. A persistent cluster of "other device"
//      session chips — Laptop, Phone, Attacker — sits live through the early steps
//      and goes struck-through / greyed at step 7 (Kill all sessions). At step 8 a
//      single fresh Laptop chip lights green while the old keys stay dead. That
//      visible death is the whole point of the lesson, in one frame.
//
// Palette is the chapter's, verbatim from the sibling figures (verify-flow /
// signup-flow-strip):
//   neutral — request plumbing (submit, click, the inbox seam, land)
//   blue    — parse / config knob               (#2563eb)
//   orange  — library / endpoint work           (#ea580c)
//   violet  — the hinge: session invalidation    (#7c3aed)
//   green   — session / success                  (#16a34a)
//   red     — the attacker's still-live session  (#dc2626)
//
// The strip + session cluster keep identical geometry every step (the cluster
// reserves its full height on every render), so the DiagramSequence stage sizes
// once at first paint and never reflows as the reader scrubs — the same discipline
// as verify-flow and signup-flow-strip. Mid-tone accents are reused as-is in both
// themes; neutral chrome rides Starlight gray/white vars so it flips light/dark.
// `not-content` (carried by DiagramSequence) opts the figure out of prose styling.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Phase = 'neutral' | 'blue' | 'orange' | 'violet' | 'green';
type Leg = 'request' | 'reset';

// The fixed pipeline. `label` is the short strip glyph (\n -> <br>); `phase` is the
// colour the node takes when it's the active (lit) stage; `leg` groups it under one
// of the two leg labels. Captions live on each step below.
const STAGES: { label: string; phase: Phase; leg: Leg }[] = [
	{ label: 'Submit\nemail', phase: 'neutral', leg: 'request' },
	{ label: 'Mint +\nhash token', phase: 'orange', leg: 'request' },
	{ label: 'Email\nlink', phase: 'orange', leg: 'request' },
	{ label: 'User\nclicks', phase: 'neutral', leg: 'reset' },
	{ label: 'Validate\ntoken', phase: 'orange', leg: 'reset' },
	{ label: 'Hash new\npassword', phase: 'orange', leg: 'reset' },
	{ label: 'Kill all\nsessions', phase: 'violet', leg: 'reset' },
	{ label: 'Sign in\nfresh', phase: 'green', leg: 'reset' },
];

// The index where the reset leg begins — the inbox round-trip seam is drawn just
// before this node.
const RESET_START = STAGES.findIndex((s) => s.leg === 'reset');
const KILL_IDX = STAGES.findIndex((s) => s.phase === 'violet');

// The persistent session cluster: the user's other live keys before the reset.
// `dead` -> true the moment sessions are killed (step >= KILL_IDX). The attacker
// reads red while live so its survival-or-death is the gut-level fact.
const CHIPS: { label: string; sub: string; attacker?: boolean }[] = [
	{ label: 'Laptop', sub: 'old session' },
	{ label: 'Phone', sub: 'old session' },
	{ label: 'Attacker', sub: 'stolen password', attacker: true },
];
---

<DiagramSequence>
	{
		STAGES.map((_, active) => {
			const killed = active >= KILL_IDX;
			const fresh = active === STAGES.length - 1; // the final "Sign in fresh" step
			return (
				<DiagramStep>
					<div class="rf">
						{/* ── leg labels: one bracket-band over each group ── */}
						<div class="rf-legs" aria-hidden="true">
							<span
								class="rf-leg"
								data-active={STAGES[active].leg === 'request' ? '' : undefined}
							>
								Leg 1 · Request
							</span>
							<span class="rf-leg-gap">↻ inbox</span>
							<span
								class="rf-leg"
								data-active={STAGES[active].leg === 'reset' ? '' : undefined}
							>
								Leg 2 · Reset
							</span>
						</div>

						{/* ── the pipeline strip, broken by the inbox seam ── */}
						<div class="rf-strip" data-phase={STAGES[active].phase}>
							{STAGES.map((stage, i) => (
								<Fragment>
									{i === RESET_START && (
										<span class="rf-seam" aria-hidden="true">
											<span class="rf-seam-glyph">✉</span>
											<span class="rf-seam-note">reads mail</span>
										</span>
									)}
									<div
										class="rf-stage"
										data-state={
											i < active ? 'done' : i === active ? 'on' : 'todo'
										}
										data-phase={stage.phase}
									>
										<span class="rf-num">{i + 1}</span>
										<span class="rf-label">
											{stage.label.split('\n').map((line, k) => (
												<>
													{k > 0 && <br />}
													{line}
												</>
											))}
										</span>
									</div>
								</Fragment>
							))}
						</div>

						{/* ── session cluster: reserved every step, dies at the hinge ── */}
						<div class="rf-sessions" data-killed={killed ? '' : undefined}>
							<span class="rf-sessions-tag">
								{killed
									? 'every old key — dead'
									: 'live sessions on every device'}
							</span>
							<div class="rf-chips">
								{CHIPS.map((chip) => (
									<span
										class="rf-chip"
										data-attacker={chip.attacker ? '' : undefined}
										data-dead={killed ? '' : undefined}
									>
										<span class="rf-chip-name">{chip.label}</span>
										<span class="rf-chip-sub">{chip.sub}</span>
									</span>
								))}
								{/* the one fresh session, present only on the final step */}
								<span class="rf-chip rf-chip--fresh" data-show={fresh ? '' : undefined}>
									<span class="rf-chip-name">Laptop</span>
									<span class="rf-chip-sub">new session</span>
								</span>
							</div>
						</div>
					</div>

					{/* Per-step caption — the "what's true now" sentence. */}
					<Fragment slot="caption">
						{active === 0 && (
							<>
								The user typed their email on <code>/forgot-password</code> and
								pressed send. The request leg begins.
							</>
						)}
						{active === 1 && (
							<>
								Better Auth generated a random token and stored only its{' '}
								<em>hash</em> in a <code>verification</code> row. The raw token
								never touches the database.
							</>
						)}
						{active === 2 && (
							<>
								Your <code>sendResetPassword</code> callback delivered the link
								through Resend. The library is now waiting — nothing happens
								until the user acts.
							</>
						)}
						{active === 3 && (
							<>
								The user opens their inbox and clicks the link. The token rides
								in the URL. The reset leg begins.
							</>
						)}
						{active === 4 && (
							<>
								Better Auth hashed the incoming token, found the matching row,
								and confirmed it hasn't expired. The ten-minute fuse held.
							</>
						)}
						{active === 5 && (
							<>
								The new password was hashed with scrypt and written to{' '}
								<code>account.password</code>. The token row is deleted —
								one-time use, enforced by deletion.
							</>
						)}
						{active === 6 && (
							<>
								<strong>The hinge.</strong> Every session this user had — every
								other browser, every other device, the attacker's stolen one —
								is gone. The new password is the only key now.
							</>
						)}
						{active === 7 && (
							<>
								One fresh session is issued. The user lands signed in with a new
								cookie — the only live key in existence.
							</>
						)}
					</Fragment>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>

<style>
	.rf {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
		padding: 4px 2px 2px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── leg labels ───────────────────────────────────────────────── */
	.rf-legs {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin: 0;
	}
	.rf-leg {
		flex: 1 1 0;
		padding: 3px 8px;
		border-radius: 7px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		text-align: center;
		color: var(--sl-color-gray-3, #64748b);
		transition:
			color 0.16s,
			border-color 0.16s,
			background-color 0.16s;
	}
	/* the active leg darkens its ink + border so the reader sees which leg they're in */
	.rf-leg[data-active] {
		border-color: var(--sl-color-gray-3, #64748b);
		color: var(--sl-color-white, #1e293b);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-5, #cbd5e1) 22%,
			var(--sl-color-bg, transparent)
		);
	}
	.rf-leg-gap {
		flex: 0 0 auto;
		font-size: 0.58rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-4, #94a3b8);
		white-space: nowrap;
	}

	/* ── the pipeline strip ───────────────────────────────────────── */
	.rf-strip {
		--rf-on: var(--sl-color-gray-3, #64748b);
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
		margin: 0;
	}
	/* the strip's accent follows the active stage's phase */
	.rf-strip[data-phase='blue'] {
		--rf-on: #2563eb;
	}
	.rf-strip[data-phase='orange'] {
		--rf-on: #ea580c;
	}
	.rf-strip[data-phase='violet'] {
		--rf-on: #7c3aed;
	}
	.rf-strip[data-phase='green'] {
		--rf-on: #16a34a;
	}

	.rf-stage {
		position: relative;
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 5px;
		padding: 8px 4px 7px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			opacity 0.16s,
			transform 0.16s;
	}

	.rf-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		flex: 0 0 auto;
		border-radius: 50%;
		font-size: 0.64rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		transition:
			color 0.16s,
			background-color 0.16s;
	}
	.rf-label {
		font-size: 0.7rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-2, #475569);
		overflow-wrap: anywhere;
		transition: color 0.16s;
	}

	/* not yet reached */
	.rf-stage[data-state='todo'] {
		opacity: 0.5;
	}

	/* already passed: a muted tint in that stage's own phase colour */
	.rf-stage[data-state='done'][data-phase='orange'] {
		border-color: color-mix(in srgb, #ea580c 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.rf-stage[data-state='done'][data-phase='violet'] {
		border-color: color-mix(in srgb, #7c3aed 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.rf-stage[data-state='done'][data-phase='green'] {
		border-color: color-mix(in srgb, #16a34a 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.rf-stage[data-state='done'] .rf-num {
		color: #fff;
		background: var(--sl-color-gray-4, #94a3b8);
	}
	.rf-stage[data-state='done'][data-phase='orange'] .rf-num {
		background: color-mix(in srgb, #ea580c 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.rf-stage[data-state='done'][data-phase='violet'] .rf-num {
		background: color-mix(in srgb, #7c3aed 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.rf-stage[data-state='done'][data-phase='green'] .rf-num {
		background: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-4, #94a3b8));
	}

	/* the lit stage: full phase colour, lifted */
	.rf-stage[data-state='on'] {
		border-color: var(--rf-on);
		border-width: 1.5px;
		background: color-mix(in srgb, var(--rf-on) 10%, var(--sl-color-bg, transparent));
		transform: translateY(-2px);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--rf-on) 22%, transparent);
	}
	.rf-stage[data-state='on'] .rf-num {
		color: #fff;
		background: var(--rf-on);
	}
	.rf-stage[data-state='on'] .rf-label {
		color: var(--sl-color-white, #1e293b);
	}

	/* ── the inbox seam: splits request leg from reset leg ── */
	.rf-seam {
		flex: 0 0 auto;
		align-self: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1px;
		margin: 0 1px;
		padding: 0 3px;
	}
	.rf-seam-glyph {
		font-size: 0.95rem;
		line-height: 1;
		color: var(--sl-color-gray-3, #64748b);
	}
	.rf-seam-note {
		font-size: 0.5rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-4, #94a3b8);
		white-space: nowrap;
	}

	/* ── the session cluster ──────────────────────────────────────── */
	.rf-sessions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		margin: 0;
		padding: 8px 6px 4px;
		border-top: 1px dashed var(--sl-color-gray-5, #cbd5e1);
	}
	.rf-sessions-tag {
		margin: 0;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		transition: color 0.16s;
	}
	.rf-sessions[data-killed] .rf-sessions-tag {
		color: #b91c1c; /* red-700 — the kill is loud */
	}

	.rf-chips {
		display: flex;
		align-items: stretch;
		justify-content: center;
		flex-wrap: wrap;
		gap: 7px;
		margin: 0;
	}

	/* a session chip echoes the Better Auth session-row styling: a small rounded
	   card with a mono-ish name + a faint sub line. Live = neutral; the attacker
	   reads red while live so its fate is the gut-level fact. */
	.rf-chip {
		box-sizing: border-box;
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0;
		margin: 0;
		padding: 4px 10px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		transition:
			opacity 0.18s,
			border-color 0.18s,
			background-color 0.18s;
	}
	.rf-chip-name {
		font-size: 0.74rem;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		transition: color 0.18s;
	}
	.rf-chip-sub {
		font-size: 0.56rem;
		font-weight: 600;
		line-height: 1.2;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-3, #64748b);
		transition: color 0.18s;
	}

	/* the attacker chip while live: red border + red ink, an alarm that's still on */
	.rf-chip[data-attacker] {
		border-color: color-mix(in srgb, #dc2626 55%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #dc2626 8%, var(--sl-color-bg, transparent));
	}
	.rf-chip[data-attacker] .rf-chip-name {
		color: #b91c1c;
	}
	.rf-chip[data-attacker] .rf-chip-sub {
		color: color-mix(in srgb, #dc2626 60%, var(--sl-color-gray-3, #64748b));
	}

	/* DEAD: struck-through, greyed, flattened — the visible death at the hinge */
	.rf-chip[data-dead] {
		border-color: var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 55%,
			var(--sl-color-bg, transparent)
		);
		opacity: 0.55;
	}
	.rf-chip[data-dead] .rf-chip-name {
		color: var(--sl-color-gray-3, #64748b);
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
	}
	.rf-chip[data-dead] .rf-chip-sub {
		color: var(--sl-color-gray-4, #94a3b8);
		text-decoration: line-through;
	}

	/* the fresh session chip: green, present only on the final step. It always
	   occupies layout (so the cluster height never changes) and just fades in. */
	.rf-chip--fresh {
		border-color: var(--rf-on, #16a34a);
		border-color: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #16a34a 10%, var(--sl-color-bg, transparent));
		visibility: hidden;
		opacity: 0;
		transition:
			opacity 0.18s,
			visibility 0.18s;
	}
	.rf-chip--fresh[data-show] {
		visibility: visible;
		opacity: 1;
	}
	.rf-chip--fresh .rf-chip-name {
		color: #15803d; /* green-700 */
	}
	.rf-chip--fresh .rf-chip-sub {
		color: color-mix(in srgb, #16a34a 65%, var(--sl-color-gray-3, #64748b));
	}

	/* ── narrow viewports: let the strip wrap into compact left-aligned chips,
	      drop the inbox seam (the leg labels still carry the two-leg split). ── */
	@media (max-width: 600px) {
		.rf-stage {
			flex: 1 1 40%;
			min-width: 0;
			flex-direction: row;
			justify-content: flex-start;
			gap: 6px;
			padding: 6px 8px;
			text-align: left;
		}
		.rf-seam {
			flex-basis: 100%;
			flex-direction: row;
			gap: 5px;
			padding: 2px 0;
		}
		.rf-leg {
			font-size: 0.56rem;
		}
	}
</style>
