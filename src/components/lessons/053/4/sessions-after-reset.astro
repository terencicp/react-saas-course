---
// sessions-after-reset — Chapter 053 Lesson 4, "Password reset".
//
// The climax figure: the violet-hinge property made a single-glance fact. Two
// panels show the SAME account the instant after a reset — same three old keys
// (Laptop, Phone, Attacker) plus the one fresh Laptop the reset minted — and the
// ONLY difference between them is whether `revokeSessionsOnPasswordReset` was on.
//
//   Left  ("Without invalidation"): the old keys all stay LIVE. The attacker chip
//          glows red, still valid. A back door that passed every happy-path test.
//   Right ("With invalidation"):    the old keys are DEAD — struck-through, greyed —
//          and only the fresh green Laptop remains. The new password is the one key.
//
// The chip vocabulary is lifted verbatim from this lesson's sibling figure
// reset-flow.astro (same `.rf-chip` shape: live=neutral, attacker=red-while-live,
// dead=struck-through-grey, fresh=green) so the two figures read as one continuous
// visual language, and both echo the Ch 052 session-table row styling.
//
// Chapter palette, same as the siblings:
//   neutral — a plain live session   (Starlight gray vars)
//   red     — the attacker's session (#dc2626)  /  the "back door" verdict (#b91c1c)
//   green   — the one fresh session  (#16a34a)  /  the "real reset" verdict (#15803d)
//
// Plain HTML + CSS, no interactivity — a static annotated illustration, so per the
// diagrams index HTML+CSS is the right engine. Mid-tone accents ride as-is in both
// themes; chrome rides Starlight gray/bg vars so it flips light/dark. The component
// is wrapped in <Figure> at the call site (the caption lives there).

type Chip = {
	label: string;
	sub: string;
	attacker?: boolean;
};

// The three keys the account already had before the reset. Identical in both panels.
const OLD_KEYS: Chip[] = [
	{ label: "Ada's laptop", sub: 'old session' },
	{ label: "Ada's phone", sub: 'old session' },
	{ label: "Attacker's session", sub: 'has the old password', attacker: true },
];
---

<div class="sar">
	{/* ── LEFT: the back door ── */}
	<section class="sar-panel" data-verdict="bad">
		<header class="sar-head">
			<span class="sar-verdict">Without invalidation</span>
			<span class="sar-flag">
				<code>revokeSessionsOnPasswordReset: false</code>
			</span>
		</header>

		<div class="sar-stage">
			<p class="sar-tag">After the reset</p>
			<div class="sar-chips">
				{
					OLD_KEYS.map((chip) => (
						<span class="sar-chip" data-attacker={chip.attacker ? '' : undefined}>
							<span class="sar-chip-name">{chip.label}</span>
							<span class="sar-chip-sub">{chip.sub}</span>
							<span class="sar-chip-state" data-live="">still valid</span>
						</span>
					))
				}
				<span class="sar-chip sar-chip--fresh">
					<span class="sar-chip-name">Ada's laptop</span>
					<span class="sar-chip-sub">new session</span>
					<span class="sar-chip-state" data-live="">just signed in</span>
				</span>
			</div>
		</div>

		<p class="sar-foot">
			The attacker never logged out. The new password changed{' '}
			<strong>nothing</strong> for them.
		</p>
	</section>

	{/* ── RIGHT: a real reset ── */}
	<section class="sar-panel" data-verdict="good">
		<header class="sar-head">
			<span class="sar-verdict">With invalidation</span>
			<span class="sar-flag">
				<code>revokeSessionsOnPasswordReset: true</code>
			</span>
		</header>

		<div class="sar-stage">
			<p class="sar-tag">After the reset</p>
			<div class="sar-chips">
				{
					OLD_KEYS.map((chip) => (
						<span
							class="sar-chip"
							data-attacker={chip.attacker ? '' : undefined}
							data-dead=""
						>
							<span class="sar-chip-name">{chip.label}</span>
							<span class="sar-chip-sub">{chip.sub}</span>
							<span class="sar-chip-state" data-dead="">
								revoked
							</span>
						</span>
					))
				}
				<span class="sar-chip sar-chip--fresh">
					<span class="sar-chip-name">Ada's laptop</span>
					<span class="sar-chip-sub">new session</span>
					<span class="sar-chip-state" data-live="">just signed in</span>
				</span>
			</div>
		</div>

		<p class="sar-foot">
			Every old key is dead. The new password is the{' '}
			<strong>only</strong> way in.
		</p>
	</section>
</div>

<style>
	.sar {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── panel ──────────────────────────────────────────────────────── */
	.sar-panel {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
		padding: 12px 12px 11px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
	}
	/* a hairline of the verdict colour up the left edge of each panel */
	.sar-panel[data-verdict='bad'] {
		border-left: 3px solid color-mix(in srgb, #dc2626 70%, var(--sl-color-gray-5, #cbd5e1));
	}
	.sar-panel[data-verdict='good'] {
		border-left: 3px solid color-mix(in srgb, #16a34a 70%, var(--sl-color-gray-5, #cbd5e1));
	}

	/* ── header: verdict word + the one flag that decides it ── */
	.sar-head {
		display: flex;
		flex-direction: column;
		gap: 5px;
		margin: 0;
	}
	.sar-verdict {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.01em;
		line-height: 1.2;
	}
	.sar-panel[data-verdict='bad'] .sar-verdict {
		color: #b91c1c;
	}
	.sar-panel[data-verdict='good'] .sar-verdict {
		color: #15803d;
	}
	.sar-flag {
		margin: 0;
	}
	.sar-flag code {
		display: inline-block;
		margin: 0;
		padding: 2px 7px;
		border-radius: 6px;
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.3;
		white-space: nowrap;
		max-width: 100%;
		overflow-wrap: anywhere;
		background: var(--sl-color-gray-6, #e2e8f0);
		color: var(--sl-color-gray-2, #475569);
	}

	/* ── the chip stage ─────────────────────────────────────────────── */
	.sar-stage {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
		padding: 9px 8px 10px;
		border-radius: 9px;
		border: 1px dashed var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 28%,
			var(--sl-color-bg, transparent)
		);
	}
	.sar-tag {
		margin: 0;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}

	.sar-chips {
		display: flex;
		flex-direction: column;
		gap: 7px;
		margin: 0;
	}

	/* a session chip echoes the Better Auth session-row styling — and is the exact
	   shape this lesson's reset-flow figure uses, for one continuous vocabulary. */
	.sar-chip {
		box-sizing: border-box;
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-areas:
			'name state'
			'sub  state';
		align-items: center;
		column-gap: 8px;
		row-gap: 0;
		margin: 0;
		padding: 6px 10px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
	}
	.sar-chip-name {
		grid-area: name;
		margin: 0;
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
	}
	.sar-chip-sub {
		grid-area: sub;
		margin: 0;
		font-size: 0.58rem;
		font-weight: 600;
		line-height: 1.2;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* the per-chip state pill: live or revoked */
	.sar-chip-state {
		grid-area: state;
		justify-self: end;
		margin: 0;
		padding: 2px 8px;
		border-radius: 999px;
		font-size: 0.56rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		white-space: nowrap;
	}
	.sar-chip-state[data-live] {
		background: color-mix(in srgb, #16a34a 16%, var(--sl-color-bg, transparent));
		color: #15803d;
		border: 1px solid color-mix(in srgb, #16a34a 35%, transparent);
	}
	.sar-chip-state[data-dead] {
		background: var(--sl-color-gray-6, #e2e8f0);
		color: var(--sl-color-gray-3, #64748b);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
	}

	/* the attacker chip while live: red border + red ink — an alarm that's still on */
	.sar-chip[data-attacker]:not([data-dead]) {
		border-color: color-mix(in srgb, #dc2626 55%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #dc2626 9%, var(--sl-color-bg, transparent));
	}
	.sar-chip[data-attacker]:not([data-dead]) .sar-chip-name {
		color: #b91c1c;
	}
	.sar-chip[data-attacker]:not([data-dead]) .sar-chip-sub {
		color: color-mix(in srgb, #dc2626 60%, var(--sl-color-gray-3, #64748b));
	}
	/* the live attacker's state pill turns red, not green — it's valid, but hostile */
	.sar-chip[data-attacker]:not([data-dead]) .sar-chip-state[data-live] {
		background: color-mix(in srgb, #dc2626 14%, var(--sl-color-bg, transparent));
		color: #b91c1c;
		border-color: color-mix(in srgb, #dc2626 38%, transparent);
	}

	/* DEAD: struck-through, greyed, flattened — the visible death */
	.sar-chip[data-dead] {
		border-color: var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #e2e8f0) 50%,
			var(--sl-color-bg, transparent)
		);
		opacity: 0.6;
	}
	.sar-chip[data-dead] .sar-chip-name {
		color: var(--sl-color-gray-3, #64748b);
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
	}
	.sar-chip[data-dead] .sar-chip-sub {
		color: var(--sl-color-gray-4, #94a3b8);
		text-decoration: line-through;
	}

	/* the one fresh session, present in both panels: green, the reset's new key */
	.sar-chip--fresh {
		border-color: color-mix(in srgb, #16a34a 55%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #16a34a 10%, var(--sl-color-bg, transparent));
	}
	.sar-chip--fresh .sar-chip-name {
		color: #15803d;
	}
	.sar-chip--fresh .sar-chip-sub {
		color: color-mix(in srgb, #16a34a 65%, var(--sl-color-gray-3, #64748b));
	}

	/* ── the panel's one-line verdict ── */
	.sar-foot {
		margin: 0;
		font-size: 0.74rem;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
	}
	.sar-foot strong {
		color: var(--sl-color-white, #1e293b);
		font-weight: 800;
	}

	/* ── narrow viewports: stack the two panels ── */
	@media (max-width: 560px) {
		.sar {
			grid-template-columns: 1fr;
		}
	}
</style>
