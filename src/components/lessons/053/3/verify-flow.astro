---
// verify-flow — Chapter 053 Lesson 3, "Email verification".
//
// The lesson's named load-bearing visual: the click-to-signed-in motion, held
// as one scrubbable sequence. It's the L3 counterpart to sign-up's `signup-flow`
// and sign-in's happy-path diagram.
//
// Shape: a horizontal pipeline strip of seven stages. Scrubbing lights one stage
// at a time; stages already passed go to a muted "done" state so the reader feels
// forward motion, and the per-step caption carries the one-sentence "what's true
// now". The lit stage takes its PHASE colour from the chapter palette:
//
//   neutral  — request plumbing (click, land)
//   orange   — library / endpoint work          (#ea580c)
//   violet   — the hinge: the flag the sign-in lesson was waiting on  (#7c3aed)
//   green     — session / success                (#16a34a)
//
// Built as a thin wrapper that composes <DiagramSequence> + <DiagramStep> from a
// data array so the seven near-identical strips aren't hand-repeated. Each step
// renders the SAME strip with a different active index; the strip styling lives
// once in scoped CSS. The caption is rich (inline <code>), so it goes through the
// DiagramStep `caption` slot.
//
// Colours are mid-tones reused as-is in both themes; the neutral chrome rides
// Starlight gray/white vars so it flips light/dark. `not-content` (carried by
// DiagramSequence) opts the figure out of Starlight prose styling.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

type Phase = 'neutral' | 'orange' | 'violet' | 'green';

// The fixed pipeline. `label` is the short strip glyph; `phase` is the colour the
// node takes when it's the active (lit) stage. Captions live on each step below.
const STAGES: { label: string; phase: Phase }[] = [
	{ label: 'Click link', phase: 'neutral' },
	{ label: 'Hash token', phase: 'orange' },
	{ label: 'Look up\n+ check expiry', phase: 'orange' },
	{ label: 'Flip\nemailVerified', phase: 'violet' },
	{ label: 'Delete row', phase: 'orange' },
	{ label: 'Issue session', phase: 'green' },
	{ label: 'Land in app', phase: 'green' },
];
---

<DiagramSequence>
	{
		STAGES.map((_, active) => (
			<DiagramStep>
				<div class="vf-strip" data-phase={STAGES[active].phase}>
					{STAGES.map((stage, i) => (
						<div
							class="vf-stage"
							data-state={i < active ? 'done' : i === active ? 'on' : 'todo'}
							data-phase={stage.phase}
						>
							<span class="vf-num">{i + 1}</span>
							<span class="vf-label">
								{stage.label.split('\n').map((line, k) => (
									<>
										{k > 0 && <br />}
										{line}
									</>
								))}
							</span>
						</div>
					))}
				</div>

				{/* Per-step caption — the "what's true now" sentence. */}
				<Fragment slot="caption">
					{active === 0 && (
						<>
							The user clicks the link in their inbox. The request hits the{' '}
							<code>[...all]</code> catch-all you mounted when you set up Better
							Auth — no new route.
						</>
					)}
					{active === 1 && (
						<>
							The library hashes the token from the URL. The raw token is never
							looked up directly — only its hash.
						</>
					)}
					{active === 2 && (
						<>
							It finds the <code>verification</code> row by the hashed value and
							checks <code>expiresAt</code>. Missing, expired, or already used →
							the link is dead.
						</>
					)}
					{active === 3 && (
						<>
							<code>user.emailVerified</code> flips from <code>false</code> to{' '}
							<code>true</code>. This is the flag the sign-in lesson was waiting
							on.
						</>
					)}
					{active === 4 && (
						<>
							The <code>verification</code> row is deleted — one-time use,
							enforced by deletion. The same link can never work twice.
						</>
					)}
					{active === 5 && (
						<>
							Because <code>autoSignInAfterVerification</code> is on, a session is
							issued right here — no second trip to the sign-in form.
						</>
					)}
					{active === 6 && (
						<>
							A redirect to <code>callbackURL</code>. The user is verified and
							signed in. The circuit sign-up opened is closed.
						</>
					)}
				</Fragment>
			</DiagramStep>
		))
	}
</DiagramSequence>

<style>
	.vf-strip {
		--vf-on: var(--sl-color-gray-3, #64748b);
		display: flex;
		align-items: stretch;
		justify-content: center;
		flex-wrap: wrap;
		gap: 6px;
		padding: 6px 2px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The strip's accent is set by the active stage's phase, so connectors and the
	   lit node share one hue per step. */
	.vf-strip[data-phase='orange'] {
		--vf-on: #ea580c;
	}
	.vf-strip[data-phase='violet'] {
		--vf-on: #7c3aed;
	}
	.vf-strip[data-phase='green'] {
		--vf-on: #16a34a;
	}

	.vf-stage {
		position: relative;
		flex: 1 1 0;
		min-width: 78px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 6px;
		padding: 9px 5px 8px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			opacity 0.16s,
			transform 0.16s;
	}

	/* Connector tab between stages (drawn on the left edge, skipped on the first). */
	.vf-stage::before {
		content: '';
		position: absolute;
		left: -7px;
		top: 50%;
		width: 7px;
		height: 2px;
		transform: translateY(-50%);
		background: var(--sl-color-gray-5, #cbd5e1);
	}
	.vf-stage:first-child::before {
		display: none;
	}

	.vf-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 19px;
		height: 19px;
		flex: 0 0 auto;
		border-radius: 50%;
		font-size: 0.66rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #e2e8f0);
		transition:
			color 0.16s,
			background-color 0.16s;
	}

	.vf-label {
		font-size: 0.72rem;
		font-weight: 600;
		line-height: 1.22;
		color: var(--sl-color-gray-2, #475569);
		overflow-wrap: anywhere;
		transition: color 0.16s;
	}

	/* ---- not yet reached ---- */
	.vf-stage[data-state='todo'] {
		opacity: 0.5;
	}

	/* ---- already passed: muted tint in that stage's own phase colour ---- */
	.vf-stage[data-state='done'][data-phase='orange'] {
		border-color: color-mix(in srgb, #ea580c 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.vf-stage[data-state='done'][data-phase='violet'] {
		border-color: color-mix(in srgb, #7c3aed 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.vf-stage[data-state='done'][data-phase='green'] {
		border-color: color-mix(in srgb, #16a34a 32%, var(--sl-color-gray-5, #cbd5e1));
	}
	.vf-stage[data-state='done'] .vf-num {
		color: #fff;
		background: var(--sl-color-gray-4, #94a3b8);
	}
	.vf-stage[data-state='done'][data-phase='orange'] .vf-num {
		background: color-mix(in srgb, #ea580c 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.vf-stage[data-state='done'][data-phase='violet'] .vf-num {
		background: color-mix(in srgb, #7c3aed 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.vf-stage[data-state='done'][data-phase='green'] .vf-num {
		background: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-4, #94a3b8));
	}
	.vf-stage[data-state='done']::before {
		background: var(--vf-on);
	}

	/* ---- the lit stage: full phase colour, lifted ---- */
	.vf-stage[data-state='on'] {
		border-color: var(--vf-on);
		border-width: 1.5px;
		background: color-mix(in srgb, var(--vf-on) 10%, var(--sl-color-bg, transparent));
		transform: translateY(-2px);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--vf-on) 22%, transparent);
	}
	.vf-stage[data-state='on'] .vf-num {
		color: #fff;
		background: var(--vf-on);
	}
	.vf-stage[data-state='on'] .vf-label {
		color: var(--sl-color-white, #1e293b);
	}

	/* Mobile: let the strip become two rows of compact chips that read left→right,
	   top→bottom. Connector tabs are hidden once wrapped so they don't dangle. */
	@media (max-width: 560px) {
		.vf-stage {
			flex: 1 1 40%;
			min-width: 0;
			flex-direction: row;
			justify-content: flex-start;
			gap: 7px;
			padding: 7px 8px;
			text-align: left;
		}
		.vf-stage::before {
			display: none;
		}
		.vf-label {
			font-size: 0.7rem;
		}
	}
</style>
