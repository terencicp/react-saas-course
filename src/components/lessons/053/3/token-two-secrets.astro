---
// token-two-secrets — Chapter 053 Lesson 3, "Email verification".
//
// The section's conceptual figure: the verification token in the email and the
// token stored in the `verification` row are NEVER the same string. One glance
// has to carry that. Two panels, side by side, with a one-way transform between:
//
//   [ email link chip ]  ──one-way hash──▶  [ verification row-card ]
//     raw token (orange)    (library does)     hashed value (teal) — a DIFFERENT string
//
// The two highlighted tokens are deliberately different glyphs AND different
// colors, so the "not the same string" point is visual, not just stated. The
// arrow is explicitly one-directional (a struck reverse arrow) to plant that the
// stored value can't be turned back into a working link.
//
// The right panel is styled as a SQL-table card (header strip + column rows) to
// echo the Chapter 052 ER diagram's `verification` table for continuity with the
// sign-up row figures.
//
// Built as plain HTML + scoped CSS (this is the right shape per the diagrams
// index: an annotated illustration of two artifacts). Theme-aware Starlight gray/
// white vars flip light/dark; the two accents (#ea580c orange, #0d9488 teal) are
// mid-tones reused as-is in both themes. `not-content` opts the whole figure out
// of Starlight prose styling.

import Figure from '../../../figures/Figure.astro';

const RAW = '#ea580c'; // the secret as it travels (in the inbox)
const HASH = '#0d9488'; // the one-way transform that sits at rest
---

<Figure caption="The string in the inbox and the string in the database are never the same. A stolen database yields no working links.">
	<div class="tts not-content">
		{/* LEFT — what the user holds, in the email */}
		<div class="tts-col">
			<div class="tts-heading">
				In the email
				<span class="tts-sub">what the user holds</span>
			</div>
			<div class="tts-card tts-card--mail">
				<div class="tts-mail-bar">
					<span class="tts-dot"></span>
					<span class="tts-dot"></span>
					<span class="tts-dot"></span>
					<span class="tts-mail-tag">verify link</span>
				</div>
				<div class="tts-link">
					<span class="tts-link-base">…/verify-email?token=</span><span
						class="tts-token tts-token--raw">ab3f…9d2</span
					>
				</div>
			</div>
			<div class="tts-foot">the raw token, sent over email</div>
		</div>

		{/* CENTER — the one-way transform */}
		<div class="tts-mid">
			<div class="tts-arrow-row">
				<div class="tts-arrow-line"></div>
				<div class="tts-arrow-head"></div>
			</div>
			<div class="tts-arrow-label">one-way hash</div>
			<div class="tts-arrow-note">the library does this</div>
			<div class="tts-arrow-back">
				<span class="tts-back-glyph">⤺</span> can't reverse
			</div>
		</div>

		{/* RIGHT — what you store, in the verification row */}
		<div class="tts-col">
			<div class="tts-heading">
				In the <code>verification</code> row
				<span class="tts-sub">what you store</span>
			</div>
			<div class="tts-card tts-card--row">
				<div class="tts-row-title">verification</div>
				<div class="tts-field">
					<span class="tts-key">identifier</span>
					<span class="tts-val">ada@acme.com</span>
				</div>
				<div class="tts-field tts-field--hl">
					<span class="tts-key">value</span>
					<span class="tts-val"
						><span class="tts-token tts-token--hash">7f1c…e84</span></span
					>
				</div>
				<div class="tts-field">
					<span class="tts-key">expiresAt</span>
					<span class="tts-val">in 1 hour</span>
				</div>
			</div>
			<div class="tts-foot">a hash of the token, never the token</div>
		</div>
	</div>
</Figure>

<style>
	.tts {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		column-gap: 18px;
		row-gap: 22px;
		margin: 0;
		padding: 14px 6px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.tts-col {
		display: flex;
		flex-direction: column;
		gap: 9px;
		min-width: 0;
		margin: 0;
	}

	.tts-heading {
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.tts-heading code {
		font-size: 0.92em;
		background: transparent;
		padding: 0;
	}

	.tts-sub {
		display: block;
		font-size: 0.68rem;
		font-weight: 400;
		color: var(--sl-color-gray-3, #64748b);
		margin: 2px 0 0;
	}

	.tts-card {
		box-sizing: border-box;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		overflow: hidden;
		margin: 0;
	}

	/* ----- left: the email link chip ----- */
	.tts-card--mail {
		border-color: color-mix(in srgb, #ea580c 45%, var(--sl-color-gray-5, #cbd5e1));
	}

	.tts-mail-bar {
		display: flex;
		align-items: center;
		gap: 5px;
		padding: 6px 10px;
		background: color-mix(in srgb, #ea580c 9%, transparent);
		border-bottom: 1px solid
			color-mix(in srgb, #ea580c 28%, var(--sl-color-gray-5, #cbd5e1));
		margin: 0;
	}

	.tts-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	.tts-mail-tag {
		margin: 0 0 0 4px;
		font-size: 0.64rem;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-3, #64748b);
	}

	.tts-link {
		padding: 12px 12px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.78rem;
		line-height: 1.4;
		word-break: break-all;
		margin: 0;
	}

	.tts-link-base {
		color: var(--sl-color-gray-2, #475569);
	}

	/* ----- the two highlighted tokens — visibly different strings + colors ----- */
	.tts-token {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-weight: 700;
		border-radius: 5px;
		padding: 1px 5px;
		margin: 0;
		white-space: nowrap;
	}

	.tts-token--raw {
		color: #ea580c;
		background: color-mix(in srgb, #ea580c 16%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #ea580c 45%, transparent);
	}

	.tts-token--hash {
		color: #0d9488;
		background: color-mix(in srgb, #0d9488 16%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #0d9488 45%, transparent);
	}

	/* ----- center: the one-way transform ----- */
	.tts-mid {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		padding: 0 2px;
		margin: 0;
	}

	.tts-arrow-row {
		display: flex;
		align-items: center;
		margin: 0;
	}

	.tts-arrow-line {
		width: 46px;
		height: 3px;
		border-radius: 2px;
		background: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.tts-arrow-head {
		width: 0;
		height: 0;
		border-top: 6px solid transparent;
		border-bottom: 6px solid transparent;
		border-left: 9px solid var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.tts-arrow-label {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		margin: 4px 0 0;
		text-align: center;
		white-space: nowrap;
	}

	.tts-arrow-note {
		font-size: 0.63rem;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
		text-align: center;
		white-space: nowrap;
	}

	.tts-arrow-back {
		display: flex;
		align-items: center;
		gap: 3px;
		font-size: 0.62rem;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 5px 0 0;
		white-space: nowrap;
	}

	.tts-back-glyph {
		font-size: 0.95rem;
		line-height: 1;
		margin: 0;
	}

	/* ----- right: the verification row-card (echoes the Ch 052 ER table) ----- */
	.tts-card--row {
		border-color: color-mix(in srgb, #0d9488 40%, var(--sl-color-gray-5, #cbd5e1));
	}

	.tts-row-title {
		padding: 6px 12px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.74rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, #0d9488 12%, transparent);
		border-bottom: 1px solid
			color-mix(in srgb, #0d9488 28%, var(--sl-color-gray-5, #cbd5e1));
		margin: 0;
	}

	.tts-field {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		padding: 7px 12px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.74rem;
		line-height: 1.35;
		border-top: 1px solid var(--sl-color-gray-6, #e2e8f0);
		margin: 0;
	}

	.tts-field:first-of-type {
		border-top: none;
	}

	.tts-field--hl {
		background: color-mix(in srgb, #0d9488 7%, transparent);
	}

	.tts-key {
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.tts-val {
		color: var(--sl-color-white, #1e293b);
		text-align: right;
		margin: 0;
	}

	.tts-foot {
		font-size: 0.68rem;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: stack the three cells. The transform arrow rotates to
	   point downward so the email → hash → row reading order is preserved. */
	@media (max-width: 640px) {
		.tts {
			grid-template-columns: 1fr;
			row-gap: 10px;
			justify-items: stretch;
		}
		.tts-mid {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: center;
			gap: 6px 10px;
			padding: 4px 0;
		}
		.tts-arrow-row {
			transform: rotate(90deg);
		}
		.tts-arrow-label {
			margin: 0;
		}
		.tts-arrow-back {
			margin: 0;
		}
	}
</style>
