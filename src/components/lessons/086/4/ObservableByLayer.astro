---
// Diagram: observable-by-layer (Chapter 086, Lesson 4 — "Arrange, act, assert
// one behavior"). A two-column reference TABLE (not a diagram engine): for each
// layer of the app, the observable surface a test should assert against.
//
// The lesson's point is that the rule ("assert what the caller observes") is
// constant up the stack, only the *shape* of "observable" changes. The middle
// three rows — Server Action, route handler, webhook receiver — are explicitly
// called out in the prose as "the integration layer," so they carry a subtle
// tint + a bracket label to make that grouping visible at a glance.
//
// House style follows the chapter-5 reference-table family (TwoRegistersTable):
// a CSS grid acting as a styled table, Starlight theme tokens for chrome,
// color-mix for tints, monospace spans for identifiers (no <code> prose pill,
// which would dominate the cell layout), single-column fallback on narrow
// viewports.

import Figure from '../../../figures/Figure.astro';

// Accent for the integration band (the seam layer L2 centred on). A single
// teal mid-tone, readable on both light and dark backgrounds — deliberately the
// same family L2 used for the integration honeycomb layer.
const SEAM_ACCENT = '#14b8a6'; // teal-500

// A chip in the "observable surface" column. `mono` renders an identifier in
// monospace; otherwise it's plain prose. Parts let one chip mix the two
// (e.g. an RFC 9457 body where "RFC 9457" is prose but the field shape is code).
type Chip = {
	text: string;
	mono?: boolean;
};

type Row = {
	layer: string; // the row's key
	layerMono?: boolean; // render the layer name in monospace
	seam?: boolean; // part of the integration band (tinted)
	later?: boolean; // covered in a later chapter (muted tag)
	chips: Chip[]; // the observable surface, one chip per item
};

const rows: Row[] = [
	{
		layer: 'Pure function',
		chips: [{ text: 'Return value' }, { text: 'Thrown error' }],
	},
	{
		layer: 'Async function',
		chips: [
			{ text: 'Resolved value' },
			{ text: 'Rejected error' },
			{ text: 'Side effects on injected deps' },
		],
	},
	{
		layer: 'Server Action',
		seam: true,
		chips: [
			{ text: 'Result', mono: true },
			{ text: 'Row written to the test DB' },
			{ text: 'Audit-log entry' },
			{ text: 'error.tsx', mono: true },
		],
	},
	{
		layer: 'Route handler',
		seam: true,
		chips: [
			{ text: 'HTTP status' },
			{ text: 'Body (RFC 9457 shape)' },
			{ text: 'Headers' },
		],
	},
	{
		layer: 'Webhook receiver',
		seam: true,
		chips: [
			{ text: 'HTTP status' },
			{ text: 'processed_events', mono: true },
			{ text: 'Side effects on business tables' },
		],
	},
	{
		layer: 'Component',
		later: true,
		chips: [
			{ text: 'Rendered text' },
			{ text: 'Controls present' },
			{ text: 'The effect of a click' },
		],
	},
];
---

<Figure caption="Every layer exposes a surface its caller depends on. Point the assertion there, never at the machinery below it.">
	<div class="obl-root not-content">
		{/* Header row */}
		<div class="obl-row obl-header">
			<div class="obl-key obl-head-cell">Layer</div>
			<div class="obl-cell obl-head-cell">
				What the test asserts <span class="obl-head-sub">— the observable surface</span>
			</div>
		</div>

		{/* Data rows */}
		{
			rows.map((r, i) => (
				<div
					class:list={[
						'obl-row',
						r.seam && 'obl-seam',
						r.seam && rows[i - 1]?.seam !== true && 'obl-seam-first',
						r.seam && rows[i + 1]?.seam !== true && 'obl-seam-last',
					]}
				>
					<div class="obl-key">
						{r.seam && rows[i - 1]?.seam !== true && (
							<span class="obl-band-tag">Integration layer</span>
						)}
						{r.layerMono ? <span class="obl-mono">{r.layer}</span> : <span>{r.layer}</span>}
						{r.later && <span class="obl-later">later</span>}
					</div>
					<div class="obl-cell">
						{r.chips.map((c) => (
							<span class:list={['obl-chip', c.mono && 'obl-chip-mono']}>{c.text}</span>
						))}
					</div>
				</div>
			))
		}
	</div>
</Figure>

<style define:vars={{ SEAM_ACCENT }}>
	.obl-root {
		position: relative;
		display: grid;
		grid-template-columns: minmax(150px, max-content) 1fr;
		row-gap: 1px;
		padding: 14px 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	.obl-row {
		display: contents;
	}

	.obl-key,
	.obl-cell {
		padding: 11px 14px;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-text);
		margin: 0;
		box-sizing: border-box;
	}

	/* Left key column — the layer name. */
	.obl-key {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 4px;
		font-weight: 600;
		font-size: 12.5px;
		color: var(--sl-color-white);
		border-right: 1px solid color-mix(in srgb, currentColor 16%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 8%, transparent);
	}

	/* Right column — chips for each observable item. */
	.obl-cell {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 6px;
		border-bottom: 1px solid color-mix(in srgb, currentColor 8%, transparent);
	}

	.obl-chip {
		display: inline-block;
		font-size: 12px;
		line-height: 1.35;
		padding: 2px 8px;
		border-radius: 5px;
		color: var(--sl-color-gray-1);
		background: color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent);
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 50%, transparent);
		white-space: nowrap;
	}

	.obl-chip-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11.5px;
		color: var(--sl-color-white);
	}

	.obl-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12px;
	}

	/* "covered later" tag on the component row. */
	.obl-later {
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
		font-weight: 600;
		font-size: 9.5px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 1px 6px;
		border-radius: 999px;
		color: var(--sl-color-gray-2);
		background: color-mix(in srgb, var(--sl-color-gray-5) 40%, transparent);
	}

	/* Header row. */
	.obl-head-cell {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3);
		padding-top: 4px;
		padding-bottom: 9px;
		border-bottom: 1px solid color-mix(in srgb, currentColor 22%, transparent);
	}

	.obl-header .obl-key {
		flex-direction: row;
	}

	.obl-head-sub {
		text-transform: none;
		letter-spacing: 0;
		font-weight: 500;
		color: var(--sl-color-gray-3);
	}

	/* Integration band — the three seam rows. A teal tint flags them as the
	   integration layer the prose calls out. */
	.obl-seam .obl-key,
	.obl-seam .obl-cell {
		background: color-mix(in srgb, var(--SEAM_ACCENT) 9%, transparent);
	}

	.obl-seam .obl-key {
		border-left: 2px solid color-mix(in srgb, var(--SEAM_ACCENT) 60%, transparent);
		padding-left: 12px;
	}

	.obl-seam-first .obl-key,
	.obl-seam-first .obl-cell {
		border-top: 1px solid color-mix(in srgb, var(--SEAM_ACCENT) 35%, transparent);
	}

	.obl-seam-last .obl-key,
	.obl-seam-last .obl-cell {
		border-bottom: 1px solid color-mix(in srgb, var(--SEAM_ACCENT) 35%, transparent);
	}

	/* Inline tag naming the integration band, on the first seam row's key. */
	.obl-band-tag {
		align-self: flex-start;
		font-size: 9.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 1px 7px;
		margin-bottom: 2px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--SEAM_ACCENT) 88%, var(--sl-color-text));
		background: color-mix(in srgb, var(--SEAM_ACCENT) 14%, transparent);
		border: 1px solid color-mix(in srgb, var(--SEAM_ACCENT) 32%, transparent);
	}

	@media (max-width: 640px) {
		.obl-root {
			grid-template-columns: 1fr;
		}
		.obl-key {
			border-right: none;
			border-bottom: none;
			padding-bottom: 2px;
			flex-direction: row;
			align-items: center;
		}
		.obl-cell {
			padding-top: 4px;
		}
		.obl-header .obl-cell {
			display: none;
		}
		.obl-seam .obl-key {
			padding-left: 12px;
		}
		.obl-chip {
			white-space: normal;
		}
	}
</style>
