---
// Vitest's worker execution model (Chapter 086 L1). A static conceptual
// illustration — the html-css "annotated illustration" use case — that makes the
// runner's two non-obvious rules read straight off one picture:
//
//   1. FILES RUN IN PARALLEL. Three columns sit side by side, each labelled
//      "Worker N" and holding exactly one file box. A bracket spanning all three
//      columns carries the "files: parallel" idea in the BLUE accent — the
//      between-file dimension where isolation is free.
//   2. TESTS IN A FILE RUN IN ORDER. Inside each file box, a vertical stack of
//      three `it(...)` boxes with a 1 → 2 → 3 cue down the stack reads
//      top-to-bottom. The "tests in a file: sequential" label is in the AMBER
//      accent — the within-file dimension where isolation is the author's job.
//
// Two accents, two ideas, at a glance: blue = parallel across files, amber =
// sequential within a file. Both are saturated mid-tones that read on light and
// dark page backgrounds. Theme-adaptive chrome (Starlight gray vars flip with
// the theme); `margin: 0` on every inner element defeats Starlight's injected
// prose margins. Horizontal, height-capped, no JS.

const PARALLEL = "#2563eb"; // blue-600  — the across-files (parallel) dimension
const SEQ = "#d97706"; // amber-600 — the within-file (sequential) dimension

const reset = "margin: 0";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The three workers, each owning one test file. Different filenames so the
// reader maps "one file → one worker" and recognises the projects from earlier
// in the lesson (a unit file, a mapper file, an integration file).
const workers = [
	{ worker: "Worker 1", file: "money.test.ts" },
	{ worker: "Worker 2", file: "invoice-mapper.test.ts" },
	{ worker: "Worker 3", file: "create-invoice.test.ts" },
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"align-items: stretch",
	"gap: 0",
	"width: 100%",
	"max-width: 760px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// The bracket spanning all three columns — the "files: parallel" header.
const parallelBracket = [
	reset,
	"position: relative",
	"box-sizing: border-box",
	"height: 30px",
	"width: 100%",
	"border: 1.5px solid " + PARALLEL,
	"border-bottom: none",
	"border-radius: 8px 8px 0 0",
	"margin-bottom: 6px",
].join("; ");

const parallelLabel = [
	reset,
	sans,
	"position: absolute",
	"top: 50%",
	"left: 50%",
	"transform: translate(-50%, -50%)",
	"padding: 0 8px",
	"background: var(--sl-color-bg-sidebar)",
	"font-size: 12px",
	"font-weight: 800",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"line-height: 1",
	"color: " + PARALLEL,
	"white-space: nowrap",
].join("; ");

// The row of three worker columns.
const columnsRow = [
	reset,
	"display: flex",
	"align-items: flex-start",
	"justify-content: center",
	"gap: 14px",
	"width: 100%",
].join("; ");

const column = [
	reset,
	"display: flex",
	"flex-direction: column",
	"align-items: stretch",
	"gap: 6px",
	"flex: 1 1 0",
	"min-width: 0",
].join("; ");

// The "Worker N" pill above each file box.
const workerPill = [
	reset,
	sans,
	"box-sizing: border-box",
	"align-self: center",
	"padding: 3px 12px",
	"border-radius: 999px",
	"border: 1.5px solid " + PARALLEL,
	"background: color-mix(in srgb, " + PARALLEL + " 12%, transparent)",
	"font-size: 11.5px",
	"font-weight: 700",
	"letter-spacing: 0.02em",
	"line-height: 1.1",
	"color: color-mix(in srgb, " + PARALLEL + " 78%, var(--sl-color-text))",
].join("; ");

// The rounded file box: a filename header plus the sequential test stack.
const fileBox = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 0",
	"border: 1.5px solid " + PARALLEL,
	"border-radius: 10px",
	"overflow: hidden",
	"background: var(--sl-color-bg)",
].join("; ");

const fileHeader = [
	reset,
	mono,
	"box-sizing: border-box",
	"padding: 6px 9px",
	"background: color-mix(in srgb, " + PARALLEL + " 14%, transparent)",
	"border-bottom: 1.5px solid color-mix(in srgb, " + PARALLEL + " 45%, transparent)",
	"font-size: 11px",
	"font-weight: 700",
	"line-height: 1.2",
	"color: color-mix(in srgb, " + PARALLEL + " 82%, var(--sl-color-text))",
	"overflow: hidden",
	"text-overflow: ellipsis",
	"white-space: nowrap",
].join("; ");

// The vertical stack of it() boxes inside one file. Padding holds the stack;
// the amber "sequential" rail runs down its left edge via the test rows.
const testStack = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 5px",
	"padding: 8px",
].join("; ");

// One it() row: a small ordinal chip in amber, then the it() label.
const testRow = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"gap: 6px",
].join("; ");

const ordinal = [
	reset,
	sans,
	"box-sizing: border-box",
	"flex: 0 0 auto",
	"width: 16px",
	"height: 16px",
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"border-radius: 999px",
	"background: " + SEQ,
	"font-size: 10px",
	"font-weight: 800",
	"line-height: 1",
	"color: #ffffff",
].join("; ");

const testBox = [
	reset,
	mono,
	"box-sizing: border-box",
	"flex: 1 1 0",
	"min-width: 0",
	"padding: 4px 8px",
	"border-radius: 6px",
	"border: 1.5px solid color-mix(in srgb, " + SEQ + " 55%, transparent)",
	"background: color-mix(in srgb, " + SEQ + " 10%, transparent)",
	"font-size: 11px",
	"font-weight: 600",
	"line-height: 1.2",
	"color: color-mix(in srgb, " + SEQ + " 82%, var(--sl-color-text))",
].join("; ");

// The small down-arrow between consecutive it() rows — the "runs in order" cue.
const seqArrow = [
	reset,
	sans,
	"align-self: flex-start",
	"margin-left: 4px",
	"font-size: 11px",
	"font-weight: 800",
	"line-height: 0.6",
	"color: " + SEQ,
].join("; ");

// The per-file "sequential" caption pinned under the stack.
const seqCaption = [
	reset,
	sans,
	"box-sizing: border-box",
	"padding: 5px 9px 8px",
	"font-size: 10px",
	"font-weight: 700",
	"letter-spacing: 0.02em",
	"text-transform: uppercase",
	"line-height: 1.15",
	"color: color-mix(in srgb, " + SEQ + " 80%, var(--sl-color-text))",
].join("; ");
---

<div class="not-content" style={root}>
	{/* ---- header bracket: files run in parallel ---- */}
	<div style={parallelBracket}>
		<span style={parallelLabel}>files: parallel</span>
	</div>

	{/* ---- three worker columns, one file each ---- */}
	<div style={columnsRow}>
		{
			workers.map((w) => (
				<div style={column}>
					<span style={workerPill}>{w.worker}</span>
					<div style={fileBox}>
						<div style={fileHeader} title={w.file}>
							{w.file}
						</div>
						<div style={testStack}>
							{[1, 2, 3].map((n) => (
								<>
									<div style={testRow}>
										<span style={ordinal}>{n}</span>
										<span style={testBox}>{"it( … )"}</span>
									</div>
									{n < 3 && (
										<span style={seqArrow} aria-hidden="true">
											↓
										</span>
									)}
								</>
							))}
						</div>
						<div style={seqCaption}>tests in a file: sequential</div>
					</div>
				</div>
			))
		}
	</div>
</div>
