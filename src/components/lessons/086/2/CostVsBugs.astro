---
// Value-per-test strip (Chapter 086 L2): the secondary figure that turns "shape
// follows the bug" into an optimization. Four rows, one per band, each showing
// two small horizontal bars side by side — "cost per test" (low -> high) and
// "bugs caught here" — so the student SEES that the integration band sits at the
// value/cost sweet spot for this codebase's boundary-heavy bug density.
//
// This is NOT a precise chart; the bar lengths are qualitative. The reading the
// figure is built to produce:
//   Unit         cost very low      bugs modest
//   Integration  cost moderate      bugs TALL      <- the standout
//   Component    cost moderate-high bugs modest
//   E2E          cost VERY HIGH     bugs few (but the few are the expensive ones)
//
// Band colors are LOAD-BEARING — reused verbatim from BugLayersStack.astro and
// PyramidVsHoneycomb.astro so band -> color reads consistently across all three
// figures. The "bugs caught" bar carries the band color (it's the signal); the
// "cost" bar is a neutral gray ramp (cost is the same currency across bands).
//
// The integration row is given a subtle highlighted background so the eye lands
// on the sweet spot without reading the bar lengths first.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// `min-width: 0` on flex children lets labels wrap instead of stealing width.
// Horizontal, height-capped, no JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const E2E = "#ea580c"; // orange-600
const COMPONENT = "#7c3aed"; // violet-600
const INTEGRATION = "#0d9488"; // teal-600
const UNIT = "#2563eb"; // blue-600

// pct values are qualitative fill widths within each mini-bar track (0-100).
const rows = [
	{
		name: "Unit",
		fill: UNIT,
		cost: 18,
		costLabel: "very low",
		bugs: 38,
		bugsLabel: "modest",
		highlight: false,
	},
	{
		name: "Integration",
		fill: INTEGRATION,
		cost: 50,
		costLabel: "moderate",
		bugs: 100,
		bugsLabel: "highest",
		highlight: true,
	},
	{
		name: "Component",
		fill: COMPONENT,
		cost: 68,
		costLabel: "moderate-high",
		bugs: 34,
		bugsLabel: "modest",
		highlight: false,
	},
	{
		name: "E2E",
		fill: E2E,
		cost: 100,
		costLabel: "very high",
		bugs: 22,
		bugsLabel: "few — but costly",
		highlight: false,
	},
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 6px",
	"width: 100%",
	"max-width: 520px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// Column header row aligned with the two bar columns below.
const headerRow = [
	reset,
	"display: flex",
	"align-items: end",
	"gap: 14px",
	"padding: 0 0 2px",
].join("; ");

const headerName = [
	reset,
	sans,
	"flex: 0 0 88px",
	"min-width: 0",
].join("; ");

const headerCol = [
	reset,
	sans,
	"flex: 1 1 0",
	"min-width: 0",
	"font-size: 11px",
	"font-weight: 700",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3, #9ca3af)",
].join("; ");

const dataRow = (highlight: boolean) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"align-items: center",
		"gap: 14px",
		"padding: 7px 8px",
		"border-radius: 8px",
		highlight
			? "background: var(--sl-color-gray-6, rgba(125,125,125,0.10))"
			: "background: transparent",
	].join("; ");

const rowName = (highlight: boolean) =>
	[
		reset,
		sans,
		"flex: 0 0 80px",
		"min-width: 0",
		"font-size: 14px",
		highlight ? "font-weight: 800" : "font-weight: 600",
		"color: var(--sl-color-white, currentColor)",
	].join("; ");

// One mini-bar cell: the track (gray) holds a fill bar plus an inline qualitative
// label to its right. Track + label share the cell via flex.
const cell = [
	reset,
	"flex: 1 1 0",
	"min-width: 0",
	"display: flex",
	"align-items: center",
	"gap: 7px",
].join("; ");

const track = [
	reset,
	"box-sizing: border-box",
	"flex: 1 1 0",
	"min-width: 0",
	"height: 12px",
	"border-radius: 6px",
	"background: var(--sl-color-gray-6, rgba(125,125,125,0.14))",
	"overflow: hidden",
].join("; ");

const fillBar = (pct: number, color: string) =>
	[
		reset,
		"box-sizing: border-box",
		"width: " + pct + "%",
		"height: 100%",
		"border-radius: 6px",
		"background: " + color,
	].join("; ");

const cellLabel = (strong: boolean) =>
	[
		reset,
		sans,
		"flex: 0 0 auto",
		"font-size: 11px",
		strong ? "font-weight: 800" : "font-weight: 500",
		"white-space: nowrap",
		"color: var(--sl-color-gray-2, #6b7280)",
	].join("; ");

// Cost bars share a neutral gray ramp — cost is the same currency across bands,
// so the color shouldn't change row to row; only the length does.
const COST = "var(--sl-color-gray-4, #6b7280)";
---

<div class="not-content" style={root}>
	<div style={headerRow}>
		<div style={headerName}></div>
		<div style={headerCol}>Cost per test</div>
		<div style={headerCol}>Bugs caught here</div>
	</div>

	{
		rows.map((r) => (
			<div style={dataRow(r.highlight)}>
				<div style={rowName(r.highlight)}>{r.name}</div>

				<div style={cell}>
					<div style={track}>
						<div style={fillBar(r.cost, COST)} />
					</div>
					<div style={cellLabel(false)}>{r.costLabel}</div>
				</div>

				<div style={cell}>
					<div style={track}>
						<div style={fillBar(r.bugs, r.fill)} />
					</div>
					<div style={cellLabel(r.highlight)}>{r.bugsLabel}</div>
				</div>
			</div>
		))
	}
</div>
