---
// The four places a bug can live in a Next.js SaaS (Chapter 086 L2). The setup
// figure for the lesson: a stable color vocabulary the rest of the lesson
// reuses. Four horizontal bands of EQUAL height — the sizing meaning (how many
// tests each layer earns) is deliberately withheld until the honeycomb figure.
// Each band is a saturated mid-tone fill (reads on light and dark page
// backgrounds) carrying white text: the layer name in bold on the left, the
// concrete artifacts in a smaller translucent-white callout on the right.
//
// The four colors are LOAD-BEARING — the honeycomb figure later reuses them so
// the student maps band -> color across both figures:
//   orange = E2E money paths
//   violet = components
//   teal   = the seams / integration
//   blue   = pure logic in /lib (unit)
//
// `margin: 0` on every inner element defeats Starlight's injected prose margins;
// `min-width: 0` on flex children lets the long callout text wrap instead of
// stealing width. Horizontal, height-capped, no JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Top-to-bottom, mirroring the order the prose introduces them in reverse
// (the four-layer list builds bottom-up; the stack reads E2E at the crest down
// to pure logic at the base). Each fill is a Tailwind 600-range mid-tone.
const bands = [
	{
		name: "E2E money paths",
		fill: "#ea580c", // orange-600
		callout: "sign-in · Stripe Checkout · invitation accept",
	},
	{
		name: "Components",
		fill: "#7c3aed", // violet-600
		callout: "buttons, forms, the date-range picker",
	},
	{
		name: "The seams",
		fill: "#0d9488", // teal-600
		callout:
			"authedAction · authedRoute · webhook receiver · Drizzle helpers · safeLimit",
	},
	{
		name: "Pure logic in /lib",
		fill: "#2563eb", // blue-600
		callout: "Zod validators · error-code mapper · redactor · Temporal codecs",
	},
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 6px",
	"width: 100%",
	"max-width: 760px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// One band: a flex row whose left side is the bold layer name and right side is
// the artifact callout. Equal height across all four — fixed min-height, no
// flex weighting, so the figure says nothing yet about test counts.
const band = (fill: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"align-items: center",
		"gap: 16px",
		"min-height: 64px",
		"padding: 12px 18px",
		"border-radius: 10px",
		"background: " + fill,
	].join("; ");

const bandName = [
	reset,
	sans,
	"flex: 0 0 33%",
	"min-width: 0",
	"font-size: 16px",
	"font-weight: 800",
	"line-height: 1.2",
	"color: #ffffff",
].join("; ");

const bandCallout = [
	reset,
	sans,
	"flex: 1 1 0",
	"min-width: 0",
	"font-size: 13px",
	"font-weight: 500",
	"line-height: 1.35",
	"color: rgba(255, 255, 255, 0.92)",
].join("; ");
---

<div class="not-content" style={root}>
	{
		bands.map((b) => (
			<div style={band(b.fill)}>
				<div style={bandName}>{b.name}</div>
				<div style={bandCallout}>{b.callout}</div>
			</div>
		))
	}
</div>
