---
// The lesson's anchor figure (Chapter 086 L2): pyramid vs honeycomb, rendered as
// two panels the student flips between inside a <TabbedContent>. The CONTRAST is
// the pedagogy — flipping from the pyramid to the honeycomb, the wide unit base
// shrinks and the integration band swells, exactly where the prose argued the
// bugs live.
//
// One component, two variants, so the four band colors live in one place. They
// are LOAD-BEARING — reused verbatim from BugLayersStack.astro so band -> color
// reads consistently across both figures:
//   orange = E2E money paths      (#ea580c)
//   violet = components           (#7c3aed)
//   teal   = the seams / integration (#0d9488)
//   blue   = pure logic in /lib (unit) (#2563eb)
//
// `variant="pyramid"` draws the classic three-tier triangle silhouette everyone
// recognizes (wide unit base -> tiny E2E cap), using a CSS clip-path so the
// taper is real geometry. The pyramid is the rejected shape, so its tiers are
// the same colors but the visual SIGNAL is the taper, not the widths-as-weight.
//
// `variant="honeycomb"` draws four horizontal bars whose LENGTHS encode weight:
// integration widest (the center of gravity), unit wide-but-shorter, component
// and E2E thin slivers. Horizontal bars respect the laptop vertical-space cap.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// `min-width: 0` on flex children lets long callout text wrap instead of
// stealing width. No JS.

interface Props {
	variant: "pyramid" | "honeycomb";
}
const { variant } = Astro.props;

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const E2E = "#ea580c"; // orange-600
const COMPONENT = "#7c3aed"; // violet-600
const INTEGRATION = "#0d9488"; // teal-600
const UNIT = "#2563eb"; // blue-600

// ---- pyramid (rejected shape) -------------------------------------------
// Top-to-bottom: tiny E2E cap -> integration -> unit base. Each tier is a row
// whose width shrinks toward the top, clipped to a trapezoid so the stacked
// rows read as one triangle. The taper IS the signal here.
const pyramidTiers = [
	{
		name: "E2E",
		fill: E2E,
		width: "26%",
		clip: "polygon(38% 0, 62% 0, 100% 100%, 0 100%)",
	},
	{
		name: "Integration",
		fill: INTEGRATION,
		width: "58%",
		clip: "polygon(22% 0, 78% 0, 100% 100%, 0 100%)",
	},
	{
		name: "Unit",
		fill: UNIT,
		width: "100%",
		clip: "polygon(13% 0, 87% 0, 100% 100%, 0 100%)",
	},
];

// ---- honeycomb (this SaaS) ----------------------------------------------
// Order top-to-bottom mirrors the bug-layers figure (E2E, component,
// integration, unit). Bar WIDTH encodes weight: integration dominates.
const honeycombBands = [
	{
		name: "E2E",
		fill: E2E,
		width: "30%",
		callout: "money paths only",
	},
	{
		name: "Component",
		fill: COMPONENT,
		width: "38%",
		callout: "only when a trigger is met",
	},
	{
		name: "Integration",
		fill: INTEGRATION,
		width: "100%",
		callout:
			"the seams — Server Actions, route handlers, webhooks, Drizzle, rate limiter",
	},
	{
		name: "Unit",
		fill: UNIT,
		width: "72%",
		callout: "everything pure in /lib",
	},
];

// ---- shared styles ------------------------------------------------------
const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"width: 100%",
	"max-width: 720px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// ---- pyramid styles -----------------------------------------------------
const pyramidRoot = [root, "gap: 4px", "align-items: center"].join("; ");

const pyramidTier = (fill: string, width: string, clip: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"align-items: center",
		"justify-content: center",
		"width: " + width,
		"min-height: 56px",
		"background: " + fill,
		"clip-path: " + clip,
	].join("; ");

const pyramidLabel = [
	reset,
	sans,
	"font-size: 15px",
	"font-weight: 800",
	"letter-spacing: 0.02em",
	"color: #ffffff",
	"text-align: center",
].join("; ");

// ---- honeycomb styles ---------------------------------------------------
const honeycombRoot = [root, "gap: 8px"].join("; ");

// A band is a row: the colored bar on the left (length = weight) and the
// callout text on the right of the bar.
const honeycombRow = [
	reset,
	"display: flex",
	"align-items: center",
	"gap: 12px",
	"width: 100%",
].join("; ");

const honeycombBar = (fill: string, width: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"align-items: center",
		"flex: 0 0 " + width,
		"min-width: 0",
		"min-height: 48px",
		"padding: 8px 16px",
		"border-radius: 8px",
		"background: " + fill,
	].join("; ");

const honeycombBarLabel = [
	reset,
	sans,
	"min-width: 0",
	"font-size: 15px",
	"font-weight: 800",
	"color: #ffffff",
	"white-space: nowrap",
].join("; ");

const honeycombCallout = [
	reset,
	sans,
	"flex: 1 1 0",
	"min-width: 0",
	"font-size: 12.5px",
	"font-weight: 500",
	"line-height: 1.3",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");
---

{
	variant === "pyramid" && (
		<div class="not-content" style={pyramidRoot}>
			{pyramidTiers.map((t) => (
				<div style={pyramidTier(t.fill, t.width, t.clip)}>
					<div style={pyramidLabel}>{t.name}</div>
				</div>
			))}
		</div>
	)
}

{
	variant === "honeycomb" && (
		<div class="not-content" style={honeycombRoot}>
			{honeycombBands.map((b) => (
				<div style={honeycombRow}>
					<div style={honeycombBar(b.fill, b.width)}>
						<div style={honeycombBarLabel}>{b.name}</div>
					</div>
					<div style={honeycombCallout}>{b.callout}</div>
				</div>
			))}
		</div>
	)
}
