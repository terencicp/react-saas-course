---
// Branch-vs-line coverage on one guard (Chapter 086 L3, the lesson's most
// important visual). Goal: make "same lines, different branches" physical at a
// glance. The 5-line loadReport guard is rendered as stacked monospace code
// rows with line numbers, flanked by two coverage gutters:
//
//   LEFT  "lines"    — every one of the 5 rows is covered (green tick).
//                      Footer total: 5 / 5 lines — 100%.
//   RIGHT "branches" — only the decision row (the `if`) carries branch markers,
//                      shown as TWO outcome pills: the false branch (admin path
//                      taken) covered/green, the true branch (forbidden(), the
//                      denial) missed/red. Footer total: 1 / 2 branches — 50%.
//
// The whole point is the asymmetry: line coverage says 100%, branch coverage
// says 50%, and the missing branch is the authorization denial.
//
// Palette is LOAD-BEARING and shared with the lesson's second figure
// (fig-report-table): green = covered, red = missed — the project's standard
// covered/missed pair (green-600 / red-600), readable on light and dark page
// backgrounds with white text on swatches.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// no JS, devtools-inspectable, height-capped well under 400px. The `<` in the
// guard's `!==` is plain text (no `<` char), so no MDX escaping is needed here.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

const COVERED = "#16a34a"; // green-600
const MISSED = "#dc2626"; // red-600

// The five source rows of the guard. `decision` flags the only row that has
// branch outcomes; everything else is a plain run-once line.
const lines = [
	{ n: 1, code: "export function loadReport(role: Role) {", decision: false },
	{ n: 2, code: "  if (role !== 'admin') {", decision: true },
	{ n: 3, code: "    return forbidden();", decision: false },
	{ n: 4, code: "  }", decision: false },
	{ n: 5, code: "  return buildReport();", decision: false },
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 12px",
	"width: 100%",
	"max-width: 660px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// Three-column grid: lines gutter | code | branches gutter. Fixed gutter widths
// keep every row's markers in the same coordinate system as the footer totals.
const GUTTER_W = "118px";
const grid = (extra: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: grid",
		"grid-template-columns: " + GUTTER_W + " 1fr " + GUTTER_W,
		"align-items: stretch",
		extra,
	].join("; ");

// Column header strip above the code.
const headerCell = (align: string) =>
	[
		reset,
		sans,
		"box-sizing: border-box",
		"display: flex",
		"align-items: end",
		"justify-content: " + align,
		"padding: 0 4px 4px",
		"font-size: 11px",
		"font-weight: 700",
		"letter-spacing: 0.06em",
		"text-transform: uppercase",
		"color: var(--sl-color-gray-3, #9ca3af)",
	].join("; ");

// One code row: a left gutter cell, the monospace source cell, a right gutter
// cell. Alternating-free, hairline-separated rows for a code-listing feel.
const rowGrid = (last: boolean) =>
	grid(
		[
			"min-height: 30px",
			last ? "" : "border-bottom: 1px solid var(--sl-color-gray-6, rgba(125,125,125,0.18))",
		].join("; "),
	);

// Left gutter cell (lines): a green tick chip, centered.
const lineGutter = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"padding: 0 8px",
	"background: var(--sl-color-gray-7, rgba(125,125,125,0.06))",
	"border-right: 1px solid var(--sl-color-gray-6, rgba(125,125,125,0.18))",
].join("; ");

// Right gutter cell (branches): holds the two outcome pills on the decision
// row, empty otherwise.
const branchGutter = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"gap: 5px",
	"padding: 0 8px",
	"background: var(--sl-color-gray-7, rgba(125,125,125,0.06))",
	"border-left: 1px solid var(--sl-color-gray-6, rgba(125,125,125,0.18))",
].join("; ");

// The code cell: line number + monospace source.
const codeCell = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"gap: 12px",
	"padding: 0 12px",
	"min-width: 0",
].join("; ");

const lineNo = [
	reset,
	mono,
	"flex: 0 0 auto",
	"font-size: 12px",
	"color: var(--sl-color-gray-4, #9ca3af)",
	"user-select: none",
	"text-align: right",
	"width: 12px",
].join("; ");

const codeText = [
	reset,
	mono,
	"flex: 1 1 0",
	"min-width: 0",
	"font-size: 13px",
	"line-height: 1.3",
	"white-space: pre",
	"overflow: hidden",
	"text-overflow: ellipsis",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

// A small "covered" tick chip for the lines gutter.
const tick = [
	reset,
	sans,
	"display: inline-flex",
	"align-items: center",
	"justify-content: center",
	"width: 18px",
	"height: 18px",
	"border-radius: 50%",
	"background: " + COVERED,
	"color: #ffffff",
	"font-size: 11px",
	"font-weight: 800",
	"line-height: 1",
].join("; ");

// A branch outcome pill: label (true/false) on a colored fill.
const pill = (color: string) =>
	[
		reset,
		mono,
		"box-sizing: border-box",
		"display: inline-flex",
		"align-items: center",
		"padding: 2px 6px",
		"border-radius: 5px",
		"background: " + color,
		"color: #ffffff",
		"font-size: 10px",
		"font-weight: 700",
		"line-height: 1",
		"white-space: nowrap",
	].join("; ");

// Footer totals strip, aligned to the gutters.
const totalCell = (color: string, align: string) =>
	[
		reset,
		sans,
		"box-sizing: border-box",
		"display: flex",
		"align-items: center",
		"justify-content: " + align,
		"padding: 6px 4px 0",
		"font-size: 12px",
		"font-weight: 700",
		"color: " + color,
	].join("; ");

// Legend.
const legendRow = [
	reset,
	sans,
	"display: flex",
	"flex-wrap: wrap",
	"justify-content: center",
	"gap: 18px",
	"padding: 2px 0 0",
].join("; ");

const legendItem = [
	reset,
	sans,
	"display: inline-flex",
	"align-items: center",
	"gap: 7px",
	"font-size: 12px",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

const swatch = (color: string) =>
	[
		reset,
		"display: inline-block",
		"width: 12px",
		"height: 12px",
		"border-radius: 3px",
		"background: " + color,
	].join("; ");

// The code listing gets a hairline frame so it reads as one block.
const listing = [
	reset,
	"box-sizing: border-box",
	"border: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))",
	"border-radius: 10px",
	"overflow: hidden",
	"background: var(--sl-color-bg, transparent)",
].join("; ");
---

<div class="not-content" style={root}>
	<div style={listing}>
		<div style={grid("border-bottom: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))")}>
			<div style={headerCell("center")}>lines</div>
			<div style={headerCell("flex-start") + "; padding-left: 12px;"}>loadReport.ts</div>
			<div style={headerCell("center")}>branches</div>
		</div>

		{
			lines.map((l, i) => (
				<div style={rowGrid(i === lines.length - 1)}>
					<div style={lineGutter}>
						<span style={tick}>✓</span>
					</div>

					<div style={codeCell}>
						<span style={lineNo}>{l.n}</span>
						<span style={codeText}>{l.code}</span>
					</div>

					<div style={branchGutter}>
						{l.decision && (
							<>
								<span style={pill(COVERED)}>false ✓</span>
								<span style={pill(MISSED)}>true ✕</span>
							</>
						)}
					</div>
				</div>
			))
		}

		<div style={grid("border-top: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))")}>
			<div style={totalCell(COVERED, "center")}>5 / 5 — 100%</div>
			<div style={headerCell("flex-start") + "; padding: 6px 4px 0 12px; text-transform: none; letter-spacing: 0; font-size: 11px; font-weight: 500; align-items: center;"}>
				one test: loadReport('admin')
			</div>
			<div style={totalCell(MISSED, "center")}>1 / 2 — 50%</div>
		</div>
	</div>

	<div style={legendRow}>
		<span style={legendItem}>
			<span style={swatch(COVERED)} />
			covered
		</span>
		<span style={legendItem}>
			<span style={swatch(MISSED)} />
			missed
		</span>
	</div>
</div>
