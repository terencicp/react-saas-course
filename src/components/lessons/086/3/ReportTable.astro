---
// Reading a coverage report by LOCATION, not by average (Chapter 086 L3, the
// lesson's second figure). Goal: teach *where to look* — the eye should go
// straight to the red rows, and within those rows, to the gap between the line
// and branch columns. It is NOT a lesson in how to read a table.
//
// A stylized per-file coverage table: File · Lines % · Branches % · Uncovered.
// Five rows that tell one story:
//
//   lib/money.ts             100 / 100  — the safe base, fully green.
//   lib/invoice-mapper.ts     96 /  92  — fine, a couple of stray lines.
//   lib/auth/authed-action.ts 100 /  45  — THE TRAP: line-green, branch-red;
//                                          the denial branches never ran.
//   app/api/webhooks/.../route 40 /  30  — the highest-stakes seam, least covered.
//   lib/rate-limit.ts         88 /  52  — fail-open carve-out untested.
//
// The three seam rows (auth, webhook, rate-limit) carry a red left accent bar +
// a faint red row tint so they read as "look here". Two pinned callouts point
// at the auth row (the line-vs-branch trap) and the webhook row (high-stakes,
// low-coverage). Each percentage cell is colored green when high, red when low,
// so a glance reads the shape without parsing the digits.
//
// Palette is LOAD-BEARING and shared with the sibling figure (BranchVsLine):
// green = covered/healthy, red = missed/under-covered — the project's standard
// covered/missed pair (green-600 / red-600), white text on swatches, readable
// on light and dark page backgrounds.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// no JS, devtools-inspectable, height-capped well under 500px.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

const COVERED = "#16a34a"; // green-600 — healthy
const MISSED = "#dc2626"; // red-600 — under-covered

// A faint red wash for the flagged seam rows, and the solid accent bar at their
// left edge. Kept low-alpha so the green cells inside still pop.
const SEAM_TINT = "rgba(220, 38, 38, 0.07)";
const SEAM_BAR = "#dc2626";

// One number is "low" (red) when it falls under this; otherwise green. The
// boundary is illustrative, not the lesson's thresholds — it just drives cell color.
const LOW = 80;

// The five rows. `seam` flags the load-bearing rows that get the red accent.
type Row = {
	file: string;
	lines: number;
	branches: number;
	uncovered: string;
	seam: boolean;
};

const rows: Row[] = [
	{ file: "lib/money.ts", lines: 100, branches: 100, uncovered: "—", seam: false },
	{ file: "lib/invoice-mapper.ts", lines: 96, branches: 92, uncovered: "41, 58", seam: false },
	{ file: "lib/auth/authed-action.ts", lines: 100, branches: 45, uncovered: "22–29", seam: true },
	{ file: "app/api/webhooks/stripe/route.ts", lines: 40, branches: 30, uncovered: "18–52", seam: true },
	{ file: "lib/rate-limit.ts", lines: 88, branches: 52, uncovered: "31–37", seam: true },
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 14px",
	"width: 100%",
	"max-width: 720px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// The table gets a hairline frame so it reads as one block (mirrors the sibling
// figure's code listing).
const listing = [
	reset,
	"box-sizing: border-box",
	"border: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))",
	"border-radius: 10px",
	"overflow: hidden",
	"background: var(--sl-color-bg, transparent)",
].join("; ");

// Four-column grid: File (flexible) | Lines | Branches | Uncovered. The accent
// bar lives as a left border on the row, so a fixed-width first column is not
// needed — File just flexes.
const COL = "1fr 84px 92px 96px";
const grid = (extra: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: grid",
		"grid-template-columns: " + COL,
		"align-items: center",
		extra,
	].join("; ");

const headerCell = (align: string) =>
	[
		reset,
		sans,
		"box-sizing: border-box",
		"display: flex",
		"align-items: end",
		"justify-content: " + align,
		"padding: 9px 12px 8px",
		"font-size: 11px",
		"font-weight: 700",
		"letter-spacing: 0.06em",
		"text-transform: uppercase",
		"color: var(--sl-color-gray-3, #9ca3af)",
	].join("; ");

// A data row. Seam rows get a faint red tint and a solid red left accent bar
// (built as a thick left border so it hugs the frame's rounded corner).
const dataRow = (seam: boolean, last: boolean) =>
	grid(
		[
			"min-height: 38px",
			seam ? "background: " + SEAM_TINT : "",
			seam
				? "border-left: 4px solid " + SEAM_BAR
				: "border-left: 4px solid transparent",
			last
				? ""
				: "border-bottom: 1px solid var(--sl-color-gray-6, rgba(125,125,125,0.18))",
		].join("; "),
	);

const fileCell = [
	reset,
	mono,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"gap: 8px",
	"padding: 0 12px",
	"min-width: 0",
	"font-size: 13px",
	"line-height: 1.25",
	"color: var(--sl-color-white, currentColor)",
	"white-space: nowrap",
	"overflow: hidden",
	"text-overflow: ellipsis",
].join("; ");

// A percentage cell: a centered wrapper holding the colored pill, so the row's
// shape reads at a glance.
const pctCell = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"padding: 0 8px",
].join("; ");

const pctPill = (value: number) =>
	[
		reset,
		mono,
		"box-sizing: border-box",
		"display: inline-flex",
		"align-items: center",
		"justify-content: center",
		"min-width: 52px",
		"padding: 3px 8px",
		"border-radius: 6px",
		"background: " + (value < LOW ? MISSED : COVERED),
		"color: #ffffff",
		"font-size: 12px",
		"font-weight: 800",
		"line-height: 1",
		"white-space: nowrap",
	].join("; ");

const uncoveredCell = [
	reset,
	mono,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"justify-content: flex-end",
	"padding: 0 12px",
	"font-size: 12px",
	"color: var(--sl-color-gray-3, #9ca3af)",
	"white-space: nowrap",
].join("; ");

// The summary strip at the foot: the misleading "headline" average, struck
// through to drive home that it's the one number you must NOT read.
const footStrip = [
	reset,
	sans,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"gap: 8px",
	"padding: 9px 12px",
	"border-top: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))",
	"background: var(--sl-color-gray-7, rgba(125,125,125,0.06))",
	"font-size: 12px",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

const footHeadline = [
	reset,
	mono,
	"font-weight: 700",
	"text-decoration: line-through",
	"text-decoration-color: " + MISSED,
	"color: var(--sl-color-gray-3, #9ca3af)",
].join("; ");

// A pinned annotation callout: a red dot leader + a note. Stacked under the
// table so the diagram stays no-JS and reflows cleanly on narrow viewports.
const callouts = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 8px",
].join("; ");

const callout = [
	reset,
	sans,
	"box-sizing: border-box",
	"display: flex",
	"align-items: flex-start",
	"gap: 9px",
	"padding: 8px 12px",
	"border-left: 4px solid " + SEAM_BAR,
	"background: " + SEAM_TINT,
	"border-radius: 0 7px 7px 0",
	"font-size: 13px",
	"line-height: 1.4",
	"color: var(--sl-color-gray-1, currentColor)",
].join("; ");

const calloutTarget = [
	reset,
	mono,
	"flex: 0 0 auto",
	"font-weight: 700",
	"color: " + MISSED,
].join("; ");

// Legend (matches the sibling figure's chip vocabulary).
const legendRow = [
	reset,
	sans,
	"display: flex",
	"flex-wrap: wrap",
	"justify-content: center",
	"gap: 18px",
	"padding: 2px 0 0",
].join("; ");

const legendItem = [
	reset,
	sans,
	"display: inline-flex",
	"align-items: center",
	"gap: 7px",
	"font-size: 12px",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

const swatch = (color: string) =>
	[
		reset,
		"display: inline-block",
		"width: 12px",
		"height: 12px",
		"border-radius: 3px",
		"background: " + color,
	].join("; ");
---

<div class="not-content" style={root}>
	<div style={listing}>
		<div style={grid("border-bottom: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3)); border-left: 4px solid transparent;")}>
			<div style={headerCell("flex-start")}>File</div>
			<div style={headerCell("center")}>Lines</div>
			<div style={headerCell("center")}>Branches</div>
			<div style={headerCell("flex-end")}>Uncovered</div>
		</div>

		{
			rows.map((r, i) => (
				<div style={dataRow(r.seam, i === rows.length - 1)}>
					<div style={fileCell}>{r.file}</div>
					<div style={pctCell}>
						<span style={pctPill(r.lines)}>{r.lines}%</span>
					</div>
					<div style={pctCell}>
						<span style={pctPill(r.branches)}>{r.branches}%</span>
					</div>
					<div style={uncoveredCell}>{r.uncovered}</div>
				</div>
			))
		}

		<div style={footStrip}>
			<span>headline average</span>
			<span style={footHeadline}>85% lines · 64% branches</span>
			<span>— the one number that tells you nothing</span>
		</div>
	</div>

	<div style={callouts}>
		<div style={callout}>
			<span style={calloutTarget}>authed-action.ts →</span>
			<span>100% lines, 45% branches — the denial branches never ran. The trap line coverage hides.</span>
		</div>
		<div style={callout}>
			<span style={calloutTarget}>stripe/route.ts →</span>
			<span>Your highest-stakes seam, your least-covered file.</span>
		</div>
	</div>

	<div style={legendRow}>
		<span style={legendItem}>
			<span style={swatch(COVERED)} />
			healthy
		</span>
		<span style={legendItem}>
			<span style={swatch(MISSED)} />
			under-covered seam
		</span>
	</div>
</div>
