---
// instant-rollback-tile — Chapter 098 Lesson 7, "Two-layer rollback when prod
// breaks". A faithful HTML/CSS mock of Vercel's production deployment tile with
// its overflow (kebab) menu open and "Instant Rollback" highlighted.
//
// Why a mock, not a Screenshot: the dashboard is an authenticated external screen
// that can't be captured — same chapter-wide convention as L2's DeploymentsList,
// whose chrome vocabulary (Vercel triangle mark, READY green, mono SHA, branch
// chip, theme vars, not-content reset) this component deliberately reuses so the
// student reads the two figures as the same UI.
//
// Teaching point (Layer 1, "flip the alias back"): the fast first move is two
// clicks — open the tile's ⋮ menu and choose Instant Rollback. So the figure
// freezes the menu OPEN with that item visually emphasized; the plausible
// neighbours (Inspect Deployment, Copy URL) keep it honest without competing for
// attention. The card itself carries the BROKEN production build the engineer is
// about to roll back from — the green Production badge, the `main` branch, a Ready
// status, and the same "new pricing page" / v3 commit AliasReaimPointer marks as
// broken, so the two figures tell one continuous story.
//
// Pure HTML + CSS per the diagrams guide; Starlight theme vars keep it native in
// light/dark. The menu is statically open (no JS) — this is a frozen figure of a
// dashboard state, not an interactive control.

import Figure from '../../../figures/Figure.astro';

const READY_GREEN = '#16a34a'; // Vercel "Ready" status green
const PROD_BG = '#16a34a'; // Production badge green

type MenuItem = {
	label: string;
	icon: 'rollback' | 'inspect' | 'copy';
	primary?: boolean; // the teaching point — visually emphasised
};

const deployment = {
	message: 'new pricing page',
	sha: 'a1f9c2e',
	branch: 'main',
	age: '12m ago',
};

const menu: MenuItem[] = [
	{ label: 'Inspect Deployment', icon: 'inspect' },
	{ label: 'Instant Rollback', icon: 'rollback', primary: true },
	{ label: 'Copy URL', icon: 'copy' },
];
---

<Figure
	caption="The production deployment tile with the Instant Rollback action. After a rollback this same control becomes 'Undo Rollback' — the button you press once the fix is verified."
>
	<div
		class="irt not-content"
		role="img"
		aria-label="A Vercel production deployment tile carrying a green Production badge, a commit SHA and message, the main branch, and Ready status. Its overflow menu is open and the Instant Rollback item is highlighted."
	>
		<div class="irt-card">
			{/* ---- Top row: app mark + badge, then the ⋮ trigger ---- */}
			<div class="irt-top">
				<span class="irt-mark" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="16" height="16">
						<polygon points="12,4 22,20 2,20" fill="#fff"></polygon>
					</svg>
				</span>
				<span class="irt-prod-badge">Production</span>
				<span class="irt-spacer"></span>
				<span class="irt-kebab" aria-hidden="true">
					<svg viewBox="0 0 16 16" width="16" height="16">
						<circle cx="8" cy="3" r="1.5" fill="currentColor"></circle>
						<circle cx="8" cy="8" r="1.5" fill="currentColor"></circle>
						<circle cx="8" cy="13" r="1.5" fill="currentColor"></circle>
					</svg>
				</span>
			</div>

			{/* ---- Commit message ---- */}
			<div class="irt-msg">{deployment.message}</div>

			{/* ---- Meta: commit SHA + branch ---- */}
			<div class="irt-meta">
				<span class="irt-commit-ico" aria-hidden="true">
					<svg viewBox="0 0 16 16" width="12" height="12">
						<circle
							cx="8"
							cy="8"
							r="3"
							fill="none"
							stroke="currentColor"
							stroke-width="1.4"></circle>
						<path
							stroke="currentColor"
							stroke-width="1.4"
							stroke-linecap="round"
							d="M8 1.5v3.5M8 11v3.5"></path>
					</svg>
				</span>
				<span class="irt-sha irt-mono">{deployment.sha}</span>
				<span class="irt-branch-ico" aria-hidden="true">
					<svg viewBox="0 0 16 16" width="12" height="12">
						<path
							fill="none"
							stroke="currentColor"
							stroke-width="1.4"
							stroke-linecap="round"
							d="M4.5 2.5v8M4.5 13.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm0-8a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm7 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm0 0c0 4-7 1.5-7 5"
						></path>
					</svg>
				</span>
				<span class="irt-branch irt-mono">{deployment.branch}</span>
			</div>

			{/* ---- Footer: status + age ---- */}
			<div class="irt-foot">
				<span class="irt-status">
					<span class="irt-status-dot" aria-hidden="true"></span>
					Ready
				</span>
				<span class="irt-age">{deployment.age}</span>
			</div>

			{/* ---- Open overflow menu, anchored to the ⋮ ---- */}
			<div class="irt-menu" role="menu">
				{
					menu.map((item) => (
						<div
							class:list={['irt-menu-item', { 'irt-menu-item-primary': item.primary }]}
							role="menuitem"
						>
							<span class="irt-menu-ico" aria-hidden="true">
								{item.icon === 'rollback' && (
									<svg viewBox="0 0 16 16" width="14" height="14">
										<path
											fill="none"
											stroke="currentColor"
											stroke-width="1.5"
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M3.5 4.5v3h3M3.7 7.4A5 5 0 1 1 3 9.2"
										/>
									</svg>
								)}
								{item.icon === 'inspect' && (
									<svg viewBox="0 0 16 16" width="14" height="14">
										<path
											fill="none"
											stroke="currentColor"
											stroke-width="1.5"
											stroke-linecap="round"
											d="M7 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm3.6-1.4L14 14"
										/>
									</svg>
								)}
								{item.icon === 'copy' && (
									<svg viewBox="0 0 16 16" width="14" height="14">
										<rect
											x="5.5"
											y="5.5"
											width="8"
											height="8"
											rx="1.5"
											fill="none"
											stroke="currentColor"
											stroke-width="1.5"
										/>
										<path
											fill="none"
											stroke="currentColor"
											stroke-width="1.5"
											stroke-linecap="round"
											d="M2.5 10.5V3a.5.5 0 0 1 .5-.5h7.5"
										/>
									</svg>
								)}
							</span>
							<span class="irt-menu-label">{item.label}</span>
						</div>
					))
				}
			</div>
		</div>
	</div>
</Figure>

<style define:vars={{ 'irt-ready': READY_GREEN, 'irt-prod-bg': PROD_BG }}>
	.irt {
		margin: 0;
		display: flex;
		justify-content: center;
		padding: 4px 4px 8px;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- The tile ---- */
	.irt-card {
		position: relative;
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		max-width: 340px;
		padding: 15px 16px 14px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 12px;
		background: var(--sl-color-bg-sidebar);
		box-shadow: 0 1px 2px color-mix(in srgb, #000 8%, transparent);
	}

	/* ---- Top row ---- */
	.irt-top {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 9px;
	}
	.irt-mark {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 7px;
		background: #000;
	}
	.irt-prod-badge {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 2px 9px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: #fff;
		background: var(--irt-prod-bg);
	}
	.irt-spacer {
		margin: 0;
		flex: 1;
	}
	.irt-kebab {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 7px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		color: var(--sl-color-white);
	}

	/* ---- Commit message ---- */
	.irt-msg {
		margin: 13px 0 0;
		font-size: 14px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white);
	}

	/* ---- Meta ---- */
	.irt-meta {
		margin: 7px 0 0;
		display: flex;
		align-items: center;
		gap: 6px;
		color: var(--sl-color-gray-3);
	}
	.irt-commit-ico,
	.irt-branch-ico {
		margin: 0;
		flex: none;
		display: inline-flex;
		color: var(--sl-color-gray-3);
	}
	.irt-branch-ico {
		margin-left: 4px;
	}
	.irt-mono {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}
	.irt-sha,
	.irt-branch {
		margin: 0;
		font-size: 12px;
		color: var(--sl-color-gray-2);
	}

	/* ---- Footer ---- */
	.irt-foot {
		margin: 12px 0 0;
		padding-top: 11px;
		border-top: 1px solid var(--sl-color-gray-5);
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.irt-status {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 13px;
		font-weight: 600;
		color: var(--irt-ready);
	}
	.irt-status-dot {
		margin: 0;
		flex: none;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--irt-ready);
	}
	.irt-age {
		margin: 0;
		font-size: 12.5px;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}

	/* ---- Open overflow menu ---- */
	.irt-menu {
		position: absolute;
		top: 44px;
		right: 14px;
		z-index: 2;
		margin: 0;
		min-width: 184px;
		padding: 5px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 10px;
		background: var(--sl-color-bg);
		box-shadow:
			0 8px 22px color-mix(in srgb, #000 22%, transparent),
			0 2px 6px color-mix(in srgb, #000 14%, transparent);
	}
	.irt-menu-item {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 8px 9px;
		border-radius: 7px;
		font-size: 13px;
		font-weight: 500;
		color: var(--sl-color-white);
	}
	.irt-menu-ico {
		margin: 0;
		flex: none;
		display: inline-flex;
		color: var(--sl-color-gray-2);
	}
	.irt-menu-label {
		margin: 0;
	}

	/* The teaching point: Instant Rollback, emphasised as a hovered/active item. */
	.irt-menu-item-primary {
		font-weight: 700;
		color: var(--irt-prod-bg);
		background: color-mix(in srgb, var(--irt-prod-bg) 13%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--irt-prod-bg) 40%, transparent);
	}
	.irt-menu-item-primary .irt-menu-ico {
		color: var(--irt-prod-bg);
	}

	@media (max-width: 420px) {
		.irt-card {
			max-width: 100%;
		}
	}
</style>
