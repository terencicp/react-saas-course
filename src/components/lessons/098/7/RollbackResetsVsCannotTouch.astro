---
// rollback-resets-vs-cannot-touch — the blast-radius figure for Lesson 98.7,
// "Two-layer rollback when prod breaks". It draws the one boundary that produces
// the lesson's most painful surprise: rollback is a CODE pointer flip and nothing
// more, so it snaps back everything frozen into the old build and is powerless
// over everything that lives outside it.
//
// The visual is a two-column classification card with a HARD divider down the
// middle — the boundary IS the teaching point. Left (green/recovery): things that
// snap back with the build. Right (amber/warning): things that survive the
// rollback untouched. The small eyebrow on each column ("frozen into the old
// build" vs "lives outside the build") names WHY the split falls where it does, so
// the student can re-derive it rather than memorise the lists.
//
// Pure HTML + CSS per the diagrams guide (devtools-inspectable). Starlight theme
// vars keep the chrome native in light/dark; the green and amber accents are
// saturated mid-tones that read in both themes. The two columns stack on narrow
// viewports. Every inner element carries margin:0 to defuse Starlight's
// prose-margin injection. A Buckets exercise right after the figure tests this
// same split — the figure teaches, the exercise checks.

import Figure from '../../../figures/Figure.astro';

const RESETS = '#16a34a'; // green-600 — snaps back with the build
const SURVIVES = '#d97706'; // amber-600 — survives the rollback

type Col = {
	side: 'resets' | 'survives';
	heading: string;
	eyebrow: string;
	items: string[];
};

const columns: Col[] = [
	{
		side: 'resets',
		heading: 'Rollback resets',
		eyebrow: 'Frozen into the old build',
		items: [
			'Application code',
			'Server function bundle',
			'Static / pre-rendered HTML',
			'Build-time env values (NEXT_PUBLIC_* inlined into the artifact)',
		],
	},
	{
		side: 'survives',
		heading: "Rollback can't touch",
		eyebrow: 'Lives outside the build',
		items: [
			'Database rows the bad deploy wrote or changed',
			'Emails already sent',
			'Stripe charges already made',
			'Webhooks dispatched / files written to R2',
			"The project's current dashboard env config",
		],
	},
];
---

<Figure
	caption="Rollback flips a code pointer and nothing more. Everything in the right-hand column survives the rollback untouched — which is why 'I rolled back, why is the data still wrong?' is the most common surprise."
>
	<div
		class="rrt not-content"
		role="img"
		aria-label="A two-column card. The green left column 'Rollback resets' lists application code, the server function bundle, static HTML, and build-time inlined env values. The amber right column 'Rollback can't touch' lists database rows the bad deploy wrote, emails sent, Stripe charges made, webhooks dispatched and files written, and the current dashboard env config."
	>
		{
			columns.map((col) => (
				<div class:list={['rrt-col', `rrt-col--${col.side}`]}>
					<div class="rrt-head">
						<span class="rrt-icon" aria-hidden="true">
							{col.side === 'resets' ? (
								<svg viewBox="0 0 16 16" width="15" height="15">
									<path
										fill="none"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M3.5 4.5v3h3M3.7 7.4A5 5 0 1 1 3 9.2"
									/>
								</svg>
							) : (
								<svg viewBox="0 0 16 16" width="15" height="15">
									<path
										fill="none"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"
										d="M3 3l10 10M13 3L3 13"
									/>
								</svg>
							)}
						</span>
						<span class="rrt-title">{col.heading}</span>
					</div>
					<div class="rrt-eyebrow">{col.eyebrow}</div>
					<ul class="rrt-list">
						{col.items.map((item) => (
							<li class="rrt-item">
								<span class="rrt-bullet" aria-hidden="true" />
								<span class="rrt-label">{item}</span>
							</li>
						))}
					</ul>
				</div>
			))
		}
	</div>
</Figure>

<style define:vars={{ 'rrt-resets': RESETS, 'rrt-survives': SURVIVES }}>
	.rrt {
		margin: 0;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
		padding: 4px 2px;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- A column ---- */
	.rrt-col {
		margin: 0;
		box-sizing: border-box;
		padding: 14px 15px 15px;
		border-radius: 12px;
		border: 1.5px solid var(--rrt-tint);
		background: color-mix(in srgb, var(--rrt-tint) 9%, var(--sl-color-bg));
	}
	.rrt-col--resets {
		--rrt-tint: var(--rrt-resets);
	}
	.rrt-col--survives {
		--rrt-tint: var(--rrt-survives);
	}

	/* ---- Column header ---- */
	.rrt-head {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.rrt-icon {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		border-radius: 7px;
		color: #fff;
		background: var(--rrt-tint);
	}
	.rrt-title {
		margin: 0;
		font-size: 15px;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: var(--rrt-tint);
	}
	.rrt-eyebrow {
		margin: 6px 0 0;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--rrt-tint) 75%, var(--sl-color-gray-2));
	}

	/* ---- List ---- */
	.rrt-list {
		margin: 11px 0 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 9px;
	}
	.rrt-item {
		margin: 0;
		display: flex;
		align-items: flex-start;
		gap: 9px;
	}
	.rrt-bullet {
		margin: 6px 0 0;
		flex: none;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--rrt-tint);
	}
	.rrt-label {
		margin: 0;
		font-size: 13.5px;
		line-height: 1.35;
		color: var(--sl-color-white);
	}

	/* Stack on narrow viewports — the boundary becomes a horizontal divide. */
	@media (max-width: 560px) {
		.rrt {
			grid-template-columns: 1fr;
			gap: 12px;
		}
	}
</style>
