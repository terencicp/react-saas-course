---
// alias-reaim-pointer — the recall figure for Lesson 98.7, "Two-layer rollback
// when prod breaks". It deliberately reuses the visual vocabulary of L1's
// AliasPointerSwap (a `production alias` chip with a dropped arrow over a row of
// immutable deployment cards) so the student reads "rollback" as the SAME
// operation they already met — re-aiming the pointer — just pointed backwards.
//
// The single point the picture must make unmistakable: all three deployments
// coexist and stay put. The broken newest build (v3) is the one the alias points
// at RIGHT NOW; the last-known-good (v2) is still right there, addressable, live.
// "Rollback" is sliding the pointer LEFT onto v2 — nothing rebuilds, nothing
// moves. That's why it's instant.
//
// Static HTML + CSS (devtools-inspectable), no LeaderLine: the pointer->card
// connector and the leftward "rollback = slide left" annotation are CSS-drawn,
// so the figure survives the Figure lightbox relocation. Starlight theme vars
// keep chrome native in light/dark; the sky accent reuses L1's "what production
// points at" colour, and a red danger tint marks the broken build.

import Figure from "../../../figures/Figure.astro";

type CardState = "good-dim" | "good" | "broken";

type Card = {
  hash: string;
  message: string;
  state: CardState;
  // small status pill under the hash row
  tag?: string;
};

// Three columns, oldest -> newest (left -> right). The alias points at the
// newest, broken build (index 2). Rollback re-aims it left, onto index 1.
const aliasTarget = 2; // currently aimed at v3 — BROKEN
const rollbackTarget = 1; // last-known-good

const cards: Card[] = [
  { hash: "v1", message: "fix invoice total", state: "good-dim", tag: "older" },
  { hash: "v2", message: "add export button", state: "good", tag: "last-known-good" },
  { hash: "v3", message: "new pricing page", state: "broken", tag: "BROKEN" },
];
---

<Figure caption="Deploys add a box on the right and slide the pointer to it; rollback slides the pointer left. The boxes never move or disappear — every previous deployment stays live on its own URL, which is exactly what makes rollback instant.">
  <div class="arp not-content" style={`--alias-target:${aliasTarget}; --rollback-target:${rollbackTarget}`}>
    {/* Pointer track: the production alias chip sits over the broken build, with
        a dropped arrow connecting it down to that card. */}
    <div class="arp-pointer-row">
      <div class="arp-pointer">
        <span class="arp-pointer-eyebrow">production alias</span>
        <code class="arp-pointer-name">app.example.com</code>
        <span class="arp-pointer-arrow" aria-hidden="true"></span>
      </div>
    </div>

    {/* Card row: three fixed columns, oldest -> newest. */}
    <div class="arp-cards">
      {cards.map((card, ci) => (
        <div
          class={`arp-card arp-card--${card.state} ${ci === aliasTarget ? "is-aliased" : ""} ${ci === rollbackTarget ? "is-rollback" : ""}`}
        >
          <div class="arp-card-head">
            <code class="arp-card-hash">{card.hash}</code>
            {card.tag && (
              <span class={`arp-card-tag arp-card-tag--${card.state}`}>{card.tag}</span>
            )}
          </div>
          <div class="arp-card-msg">{card.message}</div>
          <code class="arp-card-url">{card.hash}-app.vercel.app</code>
        </div>
      ))}
    </div>

    {/* Leftward annotation: a curved arrow from the broken column toward the
        last-known-good one, conveying the move without animating it. */}
    <div class="arp-rollback-row">
      <div class="arp-rollback">
        <span class="arp-rollback-arrow" aria-hidden="true"></span>
        <span class="arp-rollback-label">rollback = slide the pointer left</span>
      </div>
    </div>
  </div>
</Figure>

<style>
  .arp {
    --cols: 3;
    --gap: 16px;
    /* the alias accent — "what production points at" (sky-500, matches L1) */
    --arp-accent: #0ea5e9;
    /* danger tint for the broken build (red-500/600, theme-stable) */
    --arp-danger: #ef4444;
    /* good/recovery tint for the last-known-good build (emerald-500) */
    --arp-good: #10b981;
    margin: 0;
    padding: 8px 4px 4px;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  }

  /* ---- Pointer track -------------------------------------------------- */

  .arp-pointer-row {
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: var(--gap);
    margin: 0 0 10px;
  }

  .arp-pointer {
    /* place the chip over the alias target column (1-based grid lines) */
    grid-column: calc(var(--alias-target) + 1);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    margin: 0;
    padding: 8px 10px 18px;
    border-radius: 10px;
    border: 1.5px solid var(--arp-accent);
    background: color-mix(in srgb, var(--arp-accent) 12%, var(--sl-color-bg, transparent));
  }

  .arp-pointer-eyebrow {
    margin: 0;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--arp-accent);
  }

  .arp-pointer-name {
    margin: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.1;
    color: var(--sl-color-white, #1e293b);
    background: none;
    border: none;
    padding: 0;
  }

  /* The dropped connector: a vertical stem ending in a downward chevron. */
  .arp-pointer-arrow {
    position: absolute;
    left: 50%;
    bottom: -12px;
    width: 2px;
    height: 22px;
    margin: 0;
    background: var(--arp-accent);
    transform: translateX(-50%);
  }
  .arp-pointer-arrow::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -1px;
    width: 9px;
    height: 9px;
    border-right: 2px solid var(--arp-accent);
    border-bottom: 2px solid var(--arp-accent);
    transform: translate(-50%, 0) rotate(45deg);
  }

  /* ---- Card row ------------------------------------------------------- */

  .arp-cards {
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: var(--gap);
    align-items: start;
    margin: 0;
  }

  .arp-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-height: 92px;
    margin: 0;
    padding: 11px 12px;
    border-radius: 10px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
    /* a subtle "frozen" feel — these never change once built */
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 30%, transparent);
  }

  /* good-dim = an older still-live deployment */
  .arp-card--good-dim {
    opacity: 0.55;
  }

  /* the broken newest build — the alias currently points here */
  .arp-card--broken {
    border-color: color-mix(in srgb, var(--arp-danger) 55%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--arp-danger) 8%, var(--sl-color-bg, transparent));
  }

  /* the column the alias currently points at gets a halo in its own colour */
  .arp-card.is-aliased.arp-card--broken {
    border-color: var(--arp-danger);
    box-shadow:
      0 0 0 1px var(--arp-danger),
      0 4px 14px color-mix(in srgb, var(--arp-danger) 22%, transparent);
    opacity: 1;
  }

  /* the rollback target — last-known-good — gets a quiet recovery outline so the
     student's eye lands on "v2 is still right there, ready". */
  .arp-card.is-rollback {
    border-color: color-mix(in srgb, var(--arp-good) 55%, var(--sl-color-gray-5));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--arp-good) 30%, transparent);
    opacity: 1;
  }

  .arp-card-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
  }

  .arp-card-hash {
    margin: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--sl-color-white, #1e293b);
    background: none;
    border: none;
    padding: 0;
  }

  .arp-card-tag {
    margin: 0;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    border-radius: 999px;
    padding: 1px 7px;
    white-space: nowrap;
    color: var(--sl-color-gray-2, #475569);
    background: color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 22%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 45%, transparent);
  }

  .arp-card-tag--good {
    color: var(--arp-good);
    background: color-mix(in srgb, var(--arp-good) 14%, transparent);
    border-color: color-mix(in srgb, var(--arp-good) 35%, transparent);
  }

  .arp-card-tag--broken {
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    background: var(--arp-danger);
    border-color: var(--arp-danger);
  }

  .arp-card-msg {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.25;
    color: var(--sl-color-white, #1e293b);
  }

  .arp-card-url {
    margin: auto 0 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    line-height: 1.2;
    color: var(--sl-color-gray-3, #64748b);
    background: none;
    border: none;
    padding: 0;
    word-break: break-all;
  }

  /* ---- Leftward "rollback" annotation --------------------------------- */

  .arp-rollback-row {
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: var(--gap);
    margin: 12px 0 0;
  }

  /* span the annotation across the good -> broken columns so the leftward arrow
     visually connects the broken build back to the last-known-good one. */
  .arp-rollback {
    grid-column: calc(var(--rollback-target) + 1) / span 2;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0;
    padding: 7px 12px;
    border-radius: 999px;
    border: 1px dashed color-mix(in srgb, var(--arp-good) 55%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--arp-good) 8%, transparent);
  }

  /* a leftward arrow head + shaft drawn in CSS, pointing back toward v2 */
  .arp-rollback-arrow {
    position: relative;
    flex: none;
    width: 26px;
    height: 2px;
    margin: 0;
    background: var(--arp-good);
  }
  .arp-rollback-arrow::before {
    content: "";
    position: absolute;
    left: -1px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-left: 2px solid var(--arp-good);
    border-bottom: 2px solid var(--arp-good);
    transform: translateY(-50%) rotate(45deg);
  }

  .arp-rollback-label {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--arp-good);
    white-space: nowrap;
  }

  /* Narrow viewports: keep three columns but tighten everything so the row
     still reads. */
  @media (max-width: 560px) {
    .arp {
      --gap: 8px;
    }
    .arp-card {
      min-height: 84px;
      padding: 9px 9px;
    }
    .arp-card-url {
      font-size: 0.6rem;
    }
    .arp-pointer {
      padding: 6px 6px 16px;
    }
    .arp-pointer-name {
      font-size: 0.68rem;
    }
    .arp-rollback-label {
      font-size: 0.62rem;
      white-space: normal;
    }
    .arp-rollback-arrow {
      width: 18px;
    }
  }
</style>
