---
// Region match vs. mismatch — make "distance == latency" spatial.
//
// One component, two structurally-identical variants so ONLY the crossing arrow
// (and the database box's region/location) change between the panels:
//
//   variant="mismatch"  User → Function · sfo1 (US West) ══long red arrow══▶ Database · iad1 (US East)
//                        function→DB arrow is LONG, red/orange, labelled "~80 ms each way".
//
//   variant="match"     User → Function · iad1 (US East) ─short green arrow▶ Database · iad1 (US East)
//                        function and database sit right next to each other, the arrow is short and
//                        green, labelled "~1 ms".
//
// The "long vs short" is carried by the flex-grow of the crossing arrow track,
// so the two boxes literally pull apart / snap together between tabs.
//
// Pure HTML + CSS in the house style: `not-content` wrapper, style arrays joined
// with "; ", theme gray variables for chrome, and a `margin: 0` reset on every
// inner element to defeat Starlight's prose-margin selector. Saturated mid-tones
// (red-600 for the tax, teal/green-600 for the win) so the color reads in both
// light and dark mode.

interface Props {
  variant: "mismatch" | "match";
}

const { variant } = Astro.props;
const mismatch = variant === "mismatch";

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const USER = "#64748b"; // slate-500 — the user, neutral
const FUNC = "#0284c7"; // sky-600 — the function, neutral on both panels
const DB = "#7c3aed"; // violet-600 — the database
const TAX = "#dc2626"; // red-600 — the cross-country tax
const WIN = "#0d9488"; // teal-600 — the co-located win

const ARROW = mismatch ? TAX : WIN;
const ARROW_LABEL = mismatch ? "~80 ms each way" : "~1 ms";

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "justify-content: center",
  "gap: 10px",
  "width: 100%",
  "max-width: 860px",
  "box-sizing: border-box",
  sans,
].join("; ");

// A node box (User / Function / Database). `accent` tints its border + title.
// `grow` lets the two halves balance; the matched DB box hugs the function.
const box = (accent: string, grow: string) =>
  [
    reset,
    "flex: " + grow,
    "min-width: 128px",
    "display: flex",
    "flex-direction: column",
    "gap: 5px",
    "padding: 12px 14px",
    "border-radius: 12px",
    "border: 1px solid " +
      `color-mix(in srgb, ${accent} 40%, var(--sl-color-gray-4))`,
    "background: " + `color-mix(in srgb, ${accent} 7%, var(--sl-color-bg))`,
    "box-sizing: border-box",
  ].join("; ");

const boxLabel = (accent: string) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "gap: 6px",
    "font-size: 10px",
    "font-weight: 700",
    "letter-spacing: 0.05em",
    "text-transform: uppercase",
    "line-height: 1",
    "color: " + `color-mix(in srgb, ${accent} 75%, var(--sl-color-gray-2))`,
  ].join("; ");

const boxName = (accent: string) =>
  [
    reset,
    mono,
    "font-size: 15px",
    "font-weight: 700",
    "line-height: 1.2",
    "color: " + `color-mix(in srgb, ${accent} 82%, var(--sl-color-white))`,
  ].join("; ");

const boxRegion = [
  reset,
  mono,
  "font-size: 12px",
  "font-weight: 600",
  "line-height: 1.2",
  "color: var(--sl-color-gray-2)",
].join("; ");

const boxPlace = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// ---- the User→Function hop (always a short, neutral connector) ----------

const shortConn = (accent: string) =>
  [
    reset,
    "flex: 0 0 auto",
    "display: flex",
    "align-items: center",
    "width: 26px",
  ].join("; ") + ";";

const connBar = (accent: string, h = "2px") =>
  [
    reset,
    "flex: 1 1 auto",
    "height: " + h,
    "background: " +
      `color-mix(in srgb, ${accent} 60%, var(--sl-color-gray-4))`,
  ].join("; ");

const connHead = (accent: string) =>
  [
    reset,
    "width: 0",
    "height: 0",
    "border-style: solid",
    "border-width: 5px 0 5px 8px",
    `border-color: transparent transparent transparent ${accent}`,
    "margin-left: -1px",
  ].join("; ");

// ---- the Function→Database crossing arrow (the star of the figure) ------
//
// In the mismatch panel this gets a big flex-grow so the boxes pull far apart;
// in the match panel it shrinks to a hairline gap. The label sits ABOVE the
// bar so it never collides with the boxes.

const crossing = [
  reset,
  "flex: " + (mismatch ? "1 1 120px" : "0 0 54px"),
  "min-width: " + (mismatch ? "110px" : "50px"),
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 6px",
  "box-sizing: border-box",
].join("; ");

const crossLabel = [
  reset,
  sans,
  "display: inline-block",
  "padding: 3px 10px",
  "border-radius: 999px",
  "border: 1px solid " + `color-mix(in srgb, ${ARROW} 50%, transparent)`,
  "background: " + `color-mix(in srgb, ${ARROW} 13%, var(--sl-color-bg))`,
  "color: " + `color-mix(in srgb, ${ARROW} 80%, var(--sl-color-white))`,
  "font-size: " + (mismatch ? "13px" : "12px"),
  "font-weight: 700",
  "line-height: 1.2",
  "white-space: nowrap",
].join("; ");

const crossRow = [
  reset,
  "display: flex",
  "align-items: center",
  "width: 100%",
].join("; ");

const crossBar = [
  reset,
  "flex: 1 1 auto",
  "height: " + (mismatch ? "3px" : "2px"),
  "border-radius: 2px",
  "background: " + ARROW,
].join("; ");

const crossHead = [
  reset,
  "width: 0",
  "height: 0",
  "border-style: solid",
  "border-width: " + (mismatch ? "7px 0 7px 11px" : "5px 0 5px 8px"),
  `border-color: transparent transparent transparent ${ARROW}`,
  "margin-left: -1px",
].join("; ");

// A faint "continent" gap caption that only appears on the mismatch panel.
const gapNote = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "line-height: 1.2",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: " + `color-mix(in srgb, ${TAX} 65%, var(--sl-color-gray-3))`,
].join("; ");
---

<div class="not-content" style={root}>
  {/* USER */}
  <div style={box(USER, "0 0 130px")}>
    <span style={boxLabel(USER)}>User</span>
    <span style={boxName(USER)}>Browser</span>
    <span style={boxPlace}>sends a request</span>
  </div>

  {/* User → Function : always a short neutral hop */}
  <div style={shortConn(USER)}>
    <div style={connBar(USER)}></div>
    <div style={connHead(USER)}></div>
  </div>

  {/* FUNCTION */}
  <div style={box(FUNC, "0 1 178px")}>
    <span style={boxLabel(FUNC)}>Vercel Function</span>
    <span style={boxName(FUNC)}>{mismatch ? "sfo1" : "iad1"}</span>
    <span style={boxPlace}>
      {mismatch ? "San Francisco, US West" : "Washington, D.C., US East"}
    </span>
  </div>

  {/* Function → Database : the crossing arrow */}
  <div style={crossing}>
    <span style={crossLabel}>{ARROW_LABEL}</span>
    <div style={crossRow}>
      <div style={crossBar}></div>
      <div style={crossHead}></div>
    </div>
    {mismatch && <span style={gapNote}>across the country</span>}
  </div>

  {/* DATABASE */}
  <div style={box(DB, "0 1 178px")}>
    <span style={boxLabel(DB)}>Neon Postgres</span>
    <span style={boxName(DB)}>iad1</span>
    <span style={boxPlace}>Washington, D.C., US East</span>
  </div>
</div>
