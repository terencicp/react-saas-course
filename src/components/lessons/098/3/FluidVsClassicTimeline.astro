---
// Fluid Compute vs. classic serverless, made watchable.
//
// One component, three variants, each the body of a <DiagramStep>:
//
//   step="classic"  Three stacked instance lanes (A, B, C). Two carry a
//                   "cold start" badge. Every lane is exec · big shaded
//                   DB-wait · exec — the instance is mostly idle.
//
//   step="fluid"    A SINGLE warm instance lane. A, B, C are interleaved:
//                   while A waits on the DB, the instance runs B in that
//                   gap; while B waits, it runs C. The step-1 gaps are now
//                   FILLED with other requests' work. This is the tallest
//                   step — it sets the stage height.
//
//   step="payoff"   A compact before/after tally: classic (3 instances,
//                   2 cold starts) vs fluid (1 instance, 0-1 cold starts),
//                   plus the one-line payoff.
//
// Pure HTML + CSS in the lesson house style (see RegionLatency.astro):
// `not-content` wrapper, style arrays joined with "; ", theme gray vars for
// chrome, `margin: 0` reset on every inner element to defeat Starlight's
// prose-margin selector, and saturated mid-tones via color-mix so colors
// read in both light and dark mode.

interface Props {
  step: "classic" | "fluid" | "payoff";
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Per-request colors so the overlap reads clearly in the fluid step.
const A = "#0284c7"; // sky-600    — request A
const B = "#7c3aed"; // violet-600 — request B
const C = "#0d9488"; // teal-600   — request C
const COLD = "#dc2626"; // red-600  — cold start
const IDLE = "var(--sl-color-gray-4)"; // the wasted DB-wait window

// ---- shared styles ------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "width: 100%",
  "max-width: 720px",
  "margin: 0 auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// A horizontal lane: a fixed label column + a relatively-positioned track
// the segments are absolutely placed inside (so they can overlap in fluid).
const laneRow = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 12px",
  "width: 100%",
].join("; ");

const laneLabel = (accent: string) =>
  [
    reset,
    sans,
    "flex: 0 0 92px",
    "display: flex",
    "flex-direction: column",
    "gap: 2px",
    "text-align: right",
    "color: " + `color-mix(in srgb, ${accent} 80%, var(--sl-color-white))`,
  ].join("; ");

const laneLabelTitle = (accent: string) =>
  [
    reset,
    mono,
    "font-size: 13px",
    "font-weight: 700",
    "line-height: 1.2",
    "color: " + `color-mix(in srgb, ${accent} 82%, var(--sl-color-white))`,
  ].join("; ");

const laneLabelSub = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The track is the time axis. Height is generous so segments read as bars.
const track = (h = "30px") =>
  [
    reset,
    "position: relative",
    "flex: 1 1 auto",
    "height: " + h,
    "border-radius: 7px",
    "background: " + "color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent)",
    "border: 1px solid var(--sl-color-gray-5)",
    "overflow: hidden",
    "box-sizing: border-box",
  ].join("; ");

// An absolutely-positioned segment on a track. left/width are percentages of
// the shared time axis so lanes line up. `kind` picks exec (solid) vs wait.
const seg = (
  leftPct: number,
  widthPct: number,
  accent: string,
  kind: "exec" | "wait",
  topPct = 0,
  heightPct = 100,
) =>
  [
    reset,
    "position: absolute",
    "left: " + leftPct + "%",
    "width: " + widthPct + "%",
    "top: " + topPct + "%",
    "height: " + heightPct + "%",
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "font-size: 10px",
    "font-weight: 700",
    "line-height: 1",
    "letter-spacing: 0.02em",
    kind === "exec"
      ? "background: " + accent
      : "background: " +
        `repeating-linear-gradient(135deg, color-mix(in srgb, ${accent} 16%, transparent) 0 6px, transparent 6px 12px)`,
    kind === "exec"
      ? "color: #fff"
      : "color: " + `color-mix(in srgb, ${accent} 78%, var(--sl-color-gray-2))`,
    kind === "wait"
      ? "border: 1px dashed " + `color-mix(in srgb, ${accent} 38%, transparent)`
      : "",
  ]
    .filter(Boolean)
    .join("; ");

// "cold start" badge pinned to the start of a classic lane.
const coldBadge = [
  reset,
  sans,
  "position: absolute",
  "left: 3px",
  "top: 50%",
  "transform: translateY(-50%)",
  "z-index: 2",
  "display: inline-flex",
  "align-items: center",
  "gap: 3px",
  "padding: 2px 6px",
  "border-radius: 999px",
  "background: " + `color-mix(in srgb, ${COLD} 90%, black)`,
  "color: #fff",
  "font-size: 9.5px",
  "font-weight: 700",
  "line-height: 1",
  "white-space: nowrap",
  "box-shadow: 0 1px 2px rgba(0,0,0,0.25)",
].join("; ");

// Legend chip for the fluid + classic steps.
const legendRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "justify-content: center",
  "gap: 6px 14px",
  "padding-top: 2px",
].join("; ");

const legendItem = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 6px",
  "font-size: 11px",
  "font-weight: 600",
  "color: var(--sl-color-gray-2)",
].join("; ");

const swatch = (accent: string, dashed = false) =>
  [
    reset,
    "width: 14px",
    "height: 11px",
    "border-radius: 3px",
    dashed
      ? "background: " +
        `repeating-linear-gradient(135deg, color-mix(in srgb, ${accent} 30%, transparent) 0 4px, transparent 4px 8px)`
      : "background: " + accent,
    dashed
      ? "border: 1px dashed " + `color-mix(in srgb, ${accent} 45%, transparent)`
      : "",
  ]
    .filter(Boolean)
    .join("; ");

// time-axis caption under the tracks
const axisNote = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "justify-content: flex-end",
  "gap: 6px",
  "font-size: 10px",
  "font-weight: 600",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
].join("; ");
---

{
  step === "classic" && (
    <div class="not-content" style={root}>
      {/* Lane A — warm (the first request), no cold start */}
      <div style={laneRow}>
        <div style={laneLabel(A)}>
          <span style={laneLabelTitle(A)}>Instance 1</span>
          <span style={laneLabelSub}>request A</span>
        </div>
        <div style={track()}>
          <div style={seg(0, 16, A, "exec")}>exec</div>
          <div style={seg(16, 68, A, "wait")}>waiting on DB</div>
          <div style={seg(84, 16, A, "exec")}>exec</div>
        </div>
      </div>

      {/* Lane B — brand-new instance: cold start */}
      <div style={laneRow}>
        <div style={laneLabel(B)}>
          <span style={laneLabelTitle(B)}>Instance 2</span>
          <span style={laneLabelSub}>request B</span>
        </div>
        <div style={track()}>
          <span style={coldBadge}>cold start</span>
          <div style={seg(0, 16, B, "exec")} />
          <div style={seg(16, 68, B, "wait")}>waiting on DB</div>
          <div style={seg(84, 16, B, "exec")}>exec</div>
        </div>
      </div>

      {/* Lane C — brand-new instance: cold start */}
      <div style={laneRow}>
        <div style={laneLabel(C)}>
          <span style={laneLabelTitle(C)}>Instance 3</span>
          <span style={laneLabelSub}>request C</span>
        </div>
        <div style={track()}>
          <span style={coldBadge}>cold start</span>
          <div style={seg(0, 16, C, "exec")} />
          <div style={seg(16, 68, C, "wait")}>waiting on DB</div>
          <div style={seg(84, 16, C, "exec")}>exec</div>
        </div>
      </div>

      <div style={legendRow}>
        <span style={legendItem}>
          <span style={swatch(A)} /> exec (CPU busy)
        </span>
        <span style={legendItem}>
          <span style={swatch(A, true)} /> waiting on DB (idle)
        </span>
      </div>
      <div style={axisNote}>time &rarr;</div>
    </div>
  )
}

{
  step === "fluid" && (
    <div class="not-content" style={root}>
      {/* ONE warm instance. A, B, C are stacked into thirds of the same track
          and staggered in time, so each request's exec lands inside the
          previous request's DB-wait gap — the idle time is filled. */}
      <div style={laneRow}>
        <div style={laneLabel(A)}>
          <span style={laneLabelTitle(A)}>Instance 1</span>
          <span style={laneLabelSub}>A · B · C</span>
        </div>
        <div style={track("66px")}>
          <span style={coldBadge}>cold start</span>

          {/* Request A — top third */}
          <div style={seg(0, 16, A, "exec", 4, 28)}>A</div>
          <div style={seg(16, 68, A, "wait", 4, 28)} />
          <div style={seg(84, 16, A, "exec", 4, 28)}>A</div>

          {/* Request B — middle third, starts while A is waiting */}
          <div style={seg(20, 16, B, "exec", 36, 28)}>B</div>
          <div style={seg(36, 56, B, "wait", 36, 28)} />
          <div style={seg(92, 8, B, "exec", 36, 28)}>B</div>

          {/* Request C — bottom third, starts while B is waiting */}
          <div style={seg(40, 16, C, "exec", 68, 28)}>C</div>
          <div style={seg(56, 36, C, "wait", 68, 28)} />
          <div style={seg(92, 8, C, "exec", 68, 28)}>C</div>
        </div>
      </div>

      <div style={legendRow}>
        <span style={legendItem}>
          <span style={swatch(A)} /> A exec
        </span>
        <span style={legendItem}>
          <span style={swatch(B)} /> B exec
        </span>
        <span style={legendItem}>
          <span style={swatch(C)} /> C exec
        </span>
        <span style={legendItem}>
          <span style={swatch(A, true)} /> waiting on DB
        </span>
      </div>
      <div style={axisNote}>time &rarr;</div>
    </div>
  )
}

{
  step === "payoff" && (
    <div class="not-content" style={root}>
      <div
        style={[
          reset,
          "display: flex",
          "flex-wrap: wrap",
          "align-items: stretch",
          "justify-content: center",
          "gap: 14px",
          "width: 100%",
        ].join("; ")}
      >
        {/* Before */}
        <div
          style={[
            reset,
            "flex: 1 1 220px",
            "min-width: 200px",
            "display: flex",
            "flex-direction: column",
            "gap: 6px",
            "padding: 14px 16px",
            "border-radius: 12px",
            "border: 1px solid " + `color-mix(in srgb, ${COLD} 35%, var(--sl-color-gray-4))`,
            "background: " + `color-mix(in srgb, ${COLD} 6%, var(--sl-color-bg))`,
            "box-sizing: border-box",
          ].join("; ")}
        >
          <span
            style={[
              reset,
              sans,
              "font-size: 10px",
              "font-weight: 700",
              "letter-spacing: 0.05em",
              "text-transform: uppercase",
              "color: " + `color-mix(in srgb, ${COLD} 75%, var(--sl-color-gray-2))`,
            ].join("; ")}
          >
            Classic serverless
          </span>
          <span
            style={[reset, mono, "font-size: 16px", "font-weight: 700", "color: var(--sl-color-white)"].join(
              "; ",
            )}
          >
            3 instances
          </span>
          <span style={[reset, sans, "font-size: 13px", "color: var(--sl-color-gray-2)"].join("; ")}>
            2 cold starts
          </span>
        </div>

        {/* After */}
        <div
          style={[
            reset,
            "flex: 1 1 220px",
            "min-width: 200px",
            "display: flex",
            "flex-direction: column",
            "gap: 6px",
            "padding: 14px 16px",
            "border-radius: 12px",
            "border: 1px solid " + `color-mix(in srgb, ${C} 45%, var(--sl-color-gray-4))`,
            "background: " + `color-mix(in srgb, ${C} 8%, var(--sl-color-bg))`,
            "box-sizing: border-box",
          ].join("; ")}
        >
          <span
            style={[
              reset,
              sans,
              "font-size: 10px",
              "font-weight: 700",
              "letter-spacing: 0.05em",
              "text-transform: uppercase",
              "color: " + `color-mix(in srgb, ${C} 78%, var(--sl-color-gray-2))`,
            ].join("; ")}
          >
            Fluid Compute
          </span>
          <span
            style={[reset, mono, "font-size: 16px", "font-weight: 700", "color: var(--sl-color-white)"].join(
              "; ",
            )}
          >
            1 instance
          </span>
          <span style={[reset, sans, "font-size: 13px", "color: var(--sl-color-gray-2)"].join("; ")}>
            0&ndash;1 cold starts
          </span>
        </div>
      </div>

      <div
        style={[
          reset,
          sans,
          "text-align: center",
          "font-size: 13.5px",
          "font-weight: 600",
          "line-height: 1.5",
          "color: " + `color-mix(in srgb, ${C} 70%, var(--sl-color-white))`,
        ].join("; ")}
      >
        Fewer instances &middot; fewer cold starts &middot; lower latency &middot; lower bill
        <br />
        <span style={[reset, sans, "font-size: 12px", "font-weight: 600", "color: var(--sl-color-gray-3)"].join("; ")}>
          &mdash; with zero code changes.
        </span>
      </div>
    </div>
  )
}
