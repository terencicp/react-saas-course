---
// vercel-domains-panel — Chapter 098 Lesson 4, "Custom domains and automatic
// SSL", section "The two DNS records, and why apex is the awkward one"
// (right after the Settings → Domains click-flow Steps).
//
// A faithful HTML/CSS mock of Vercel's Settings → Domains panel. The real page is
// an authenticated dashboard that can't be screenshotted, so this is a hand-built
// component, not a Screenshot of a real page (matches L2's mock-not-screenshot
// convention).
//
// The single teaching point is the STATUS PILL: it flips from amber "Invalid
// Configuration" to green "Valid Configuration" on its own once Vercel sees the
// DNS record — no button to press. So the panel shows BOTH states side by side:
//   - example.com (the apex) — still propagating, amber "Invalid Configuration",
//     with the exact record-to-create shown inline (Type / Name / Value), the
//     value rendered as a clearly-labeled placeholder (Vercel issues these
//     per-project and rotates them; never an authoritative string).
//   - www.example.com — green "Valid Configuration", so the reader knows what
//     "done" looks like.
//
// Built as a Vercel-style panel card: a "Domains" heading row with the add-domain
// input + button, then the two domain rows. Pure HTML + CSS per the diagrams
// guide; chrome uses Starlight theme variables so it flips light/dark. The amber
// and green pills are saturated mid-tones with their own text colors that read in
// both themes. `not-content` + margin: 0 resets defeat Starlight's prose-margin
// selector.

import Figure from '../../../figures/Figure.astro';

const AMBER = '#b45309'; // amber-700 — "Invalid Configuration" / still propagating
const AMBER_BG = '#fef3c7'; // amber-100 — pill background (light)
const GREEN = '#15803d'; // green-700 — "Valid Configuration" / done
const GREEN_BG = '#dcfce7'; // green-100 — pill background (light)
---

<Figure>
	<div
		class="vd not-content"
		role="img"
		aria-label="Vercel's Domains settings panel. A row for example.com shows the DNS record to create — an A or ALIAS record on the apex — with an amber 'Invalid Configuration' status pill. A second row for www.example.com shows a green 'Valid Configuration' pill."
	>
		<div class="vd-panel">
			{/* ---- Heading row: title + add-domain control ---- */}
			<div class="vd-head">
				<div class="vd-head-text">
					<span class="vd-title">Domains</span>
					<span class="vd-subtitle">
						Add and manage the domains that point at this project.
					</span>
				</div>
				<div class="vd-add">
					<span class="vd-add-input">example.com</span>
					<span class="vd-add-btn">Add</span>
				</div>
			</div>

			<div class="vd-divider"></div>

			{/* ---- Row 1: apex, INVALID — the record-to-create + amber pill ---- */}
			<div class="vd-row">
				<div class="vd-row-head">
					<span class="vd-domain">example.com</span>
					<span class="vd-pill vd-pill-warn">
						<span class="vd-pill-dot" aria-hidden="true"></span>
						Invalid Configuration
					</span>
				</div>

				<p class="vd-note">
					Set the following record on your DNS provider to continue. Vercel
					will detect it automatically.
				</p>

				{/* ---- Inline DNS-record table for the apex ---- */}
				<div class="vd-rec">
					<div class="vd-rec-row vd-rec-head">
						<span>Type</span>
						<span>Name</span>
						<span>Value</span>
					</div>
					<div class="vd-rec-row">
						<span class="vd-mono">A</span>
						<span class="vd-mono">@</span>
						<span class="vd-mono vd-rec-val">
							76.76.21.NN
							<span class="vd-rec-tag">example — copy yours from this panel</span>
						</span>
					</div>
				</div>
			</div>

			{/* ---- Row 2: www, VALID — what "done" looks like ---- */}
			<div class="vd-row">
				<div class="vd-row-head">
					<span class="vd-domain">www.example.com</span>
					<span class="vd-pill vd-pill-ok">
						<span class="vd-pill-check" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="11" height="11">
								<path
									fill="none"
									stroke="currentColor"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M3.5 8.5 L6.5 11.5 L12.5 4.5"></path>
							</svg>
						</span>
						Valid Configuration
					</span>
				</div>
				<p class="vd-note vd-note-ok">
					Redirects to <span class="vd-mono">example.com</span> · Certificate
					issued automatically.
				</p>
			</div>
		</div>
	</div>
	<Fragment slot="caption">
		Vercel&rsquo;s Settings &rarr; Domains panel. The status pill is the thing you
		watch: it flips from{' '}
		<strong style={`color: ${AMBER};`}>Invalid Configuration</strong> to{' '}
		<strong style={`color: ${GREEN};`}>Valid Configuration</strong> on its own
		once your DNS record is visible. No button to press.
	</Fragment>
</Figure>

<style
	define:vars={{
		'vd-amber': AMBER,
		'vd-amber-bg': AMBER_BG,
		'vd-green': GREEN,
		'vd-green-bg': GREEN_BG,
	}}
>
	.vd {
		margin: 0;
		display: flex;
		justify-content: center;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- The panel card ---- */
	.vd-panel {
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		max-width: 560px;
		padding: 18px 20px 20px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 12px;
		background: var(--sl-color-bg-sidebar);
	}

	/* ---- Heading row ---- */
	.vd-head {
		margin: 0;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 16px;
		flex-wrap: wrap;
	}

	.vd-head-text {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.vd-title {
		margin: 0;
		font-size: 18px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}

	.vd-subtitle {
		margin: 0;
		font-size: 12px;
		line-height: 1.3;
		color: var(--sl-color-gray-3);
	}

	.vd-add {
		margin: 0;
		display: inline-flex;
		align-items: stretch;
		gap: 8px;
		flex: none;
	}

	.vd-add-input {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 6px 11px;
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 7px;
		background: var(--sl-color-bg);
		font-size: 13px;
		color: var(--sl-color-gray-2);
	}

	.vd-add-btn {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 6px 16px;
		border-radius: 7px;
		background: var(--sl-color-white);
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-black);
	}

	.vd-divider {
		margin: 14px 0 0;
		height: 1px;
		background: var(--sl-color-gray-5);
	}

	/* ---- A domain row (boxed card per domain) ---- */
	.vd-row {
		margin: 14px 0 0;
		padding: 13px 14px;
		border: 1.5px solid var(--sl-color-gray-5);
		border-radius: 9px;
		background: var(--sl-color-bg);
	}

	.vd-row-head {
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
	}

	.vd-domain {
		margin: 0;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 15px;
		font-weight: 600;
		color: var(--sl-color-white);
	}

	/* ---- Status pills ---- */
	.vd-pill {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 3px 10px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: 600;
		line-height: 1.4;
		white-space: nowrap;
	}

	.vd-pill-warn {
		color: var(--vd-amber);
		background: var(--vd-amber-bg);
		border: 1px solid color-mix(in srgb, var(--vd-amber) 35%, transparent);
	}

	.vd-pill-dot {
		margin: 0;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--vd-amber);
	}

	.vd-pill-ok {
		color: var(--vd-green);
		background: var(--vd-green-bg);
		border: 1px solid color-mix(in srgb, var(--vd-green) 35%, transparent);
	}

	.vd-pill-check {
		margin: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--vd-green);
	}

	/* ---- Notes under a row ---- */
	.vd-note {
		margin: 9px 0 0;
		font-size: 12px;
		line-height: 1.45;
		color: var(--sl-color-gray-3);
	}

	.vd-note-ok {
		margin: 8px 0 0;
	}

	/* ---- Inline DNS-record table ---- */
	.vd-rec {
		margin: 9px 0 0;
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 7px;
		overflow: hidden;
	}

	.vd-rec-row {
		margin: 0;
		display: grid;
		grid-template-columns: 64px 64px 1fr;
		gap: 12px;
		align-items: center;
		padding: 8px 12px;
	}

	.vd-rec-row + .vd-rec-row {
		border-top: 1px solid var(--sl-color-gray-5);
	}

	.vd-rec-head {
		background: var(--sl-color-bg-sidebar);
	}

	.vd-rec-head span {
		margin: 0;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	.vd-mono {
		margin: 0;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 13px;
		color: var(--sl-color-white);
	}

	.vd-rec-val {
		display: flex;
		align-items: baseline;
		gap: 8px;
		flex-wrap: wrap;
		min-width: 0;
	}

	.vd-rec-tag {
		margin: 0;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
		font-size: 10.5px;
		font-weight: 500;
		font-style: italic;
		color: var(--vd-amber);
		white-space: nowrap;
	}

	@media (max-width: 480px) {
		.vd-panel {
			padding: 16px 14px 16px;
		}
		.vd-head {
			flex-direction: column;
		}
		.vd-add {
			width: 100%;
		}
		.vd-add-input {
			flex: 1 1 auto;
		}
		.vd-rec-row {
			grid-template-columns: 48px 48px 1fr;
			gap: 8px;
		}
	}
</style>
