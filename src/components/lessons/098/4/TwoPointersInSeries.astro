---
// two-pointers-in-series — Chapter 098 Lesson 4, "Custom domains and automatic
// SSL", section "A live domain is a pointer plus a lock".
//
// The section extends L1's already-installed "alias is a pointer" model: a custom
// domain just adds a SECOND pointer, one hop upstream. A single browser request
// travels through both pointers in series:
//
//   app.example.com ──(DNS record)──▶ Vercel edge ──(production alias)──▶ deployment
//                      yours, set once                Vercel's, re-aimed every deploy
//
// The whole teaching point is the "yours vs theirs" split, so the two hops are
// tinted differently: the DNS hop (the student's one-time job) in one color, the
// production alias (Vercel's, automatic) in another. Plain HTML/CSS strip with CSS
// arrows — no LeaderLine — so the Figure stays expandable and a reader can open
// devtools on real flexbox. Horizontal, compact, well under the height cap.
//
// margin: 0 on every inner element per the Starlight prose-margin gotcha.

import Figure from '../../../figures/Figure.astro';

// Mid-tone accents that read on both light and dark page backgrounds.
const YOURS = '#0d9488'; // teal-600 — the DNS pointer, the student's one-time job
const THEIRS = '#7c3aed'; // violet-600 — the production alias, Vercel's automatic hop
---

<Figure>
	<div class="tp not-content">
		<!-- Box 1: the domain -->
		<div class="tp-box">
			<span class="tp-box-title">app.example.com</span>
			<span class="tp-box-sub">your domain</span>
		</div>

		<!-- Hop 1: DNS — yours, set once -->
		<div class="tp-hop" style={`--c: ${YOURS};`}>
			<span class="tp-hop-label">DNS record</span>
			<span class="tp-arrow" aria-hidden="true">
				<span class="tp-arrow-line"></span>
				<span class="tp-arrow-head"></span>
			</span>
			<span class="tp-hop-sub">yours, set once</span>
		</div>

		<!-- Box 2: Vercel's edge -->
		<div class="tp-box">
			<span class="tp-box-title">Vercel edge</span>
			<span class="tp-box-sub">the platform</span>
		</div>

		<!-- Hop 2: production alias — Vercel's, re-aimed every deploy -->
		<div class="tp-hop" style={`--c: ${THEIRS};`}>
			<span class="tp-hop-label">production alias</span>
			<span class="tp-arrow" aria-hidden="true">
				<span class="tp-arrow-line"></span>
				<span class="tp-arrow-head"></span>
			</span>
			<span class="tp-hop-sub">Vercel's, re-aimed on every deploy</span>
		</div>

		<!-- Box 3: the live deployment -->
		<div class="tp-box">
			<span class="tp-box-title">current deployment</span>
			<span class="tp-box-sub">the live build</span>
		</div>
	</div>
	<Fragment slot="caption">
		Two pointers in series. <strong style={`color: ${YOURS};`}>DNS</strong> (yours, set once) points
		the domain at Vercel's edge; the <strong style={`color: ${THEIRS};`}>production alias</strong>{' '}
		(Vercel's, re-aimed on every deploy) points the edge at the current deployment.
	</Fragment>
</Figure>

<style>
	.tp {
		display: flex;
		flex-wrap: nowrap;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
		margin: 0;
		padding: 14px 2px 8px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.tp-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		flex: 0 0 auto;
		padding: 12px 12px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	.tp-box-title {
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.86rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.tp-box-sub {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* A hop is a labeled, colored CSS arrow with a caption under it. */
	.tp-hop {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		flex: 1 1 auto;
		min-width: 96px;
		max-width: 160px;
		margin: 0;
	}

	.tp-hop-label {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--c);
		margin: 0;
	}

	.tp-arrow {
		display: flex;
		align-items: center;
		width: 100%;
		min-width: 80px;
		margin: 0;
	}

	.tp-arrow-line {
		flex: 1 1 auto;
		height: 2px;
		background: var(--c);
		margin: 0;
	}

	.tp-arrow-head {
		flex: 0 0 auto;
		width: 0;
		height: 0;
		border-top: 5px solid transparent;
		border-bottom: 5px solid transparent;
		border-left: 8px solid var(--c);
		margin: 0;
	}

	.tp-hop-sub {
		font-size: 0.66rem;
		line-height: 1.2;
		text-align: center;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: the row wraps. Rotate each hop's arrow to point down so the
	   chain still reads top-to-bottom instead of leaving sideways arrows dangling. */
	@media (max-width: 640px) {
		.tp {
			flex-direction: column;
			align-items: center;
		}
		.tp-box {
			width: min(20rem, 100%);
		}
		.tp-hop {
			width: auto;
		}
		.tp-arrow {
			width: 2px;
			min-width: 0;
			height: 22px;
			flex-direction: column;
		}
		.tp-arrow-line {
			width: 2px;
			height: auto;
		}
		.tp-arrow-head {
			border-left: 5px solid transparent;
			border-right: 5px solid transparent;
			border-top: 8px solid var(--c);
			border-bottom: 0;
		}
	}
</style>
