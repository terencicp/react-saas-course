---
// two-hop-tls-path — Chapter 098 Lesson 4, "Custom domains and automatic SSL",
// section "Putting Cloudflare in front without breaking TLS".
//
// When Cloudflare proxies in front of Vercel there isn't ONE TLS connection with
// one lock — there are TWO independent terminations end to end:
//
//   Browser ──(TLS · Cloudflare edge cert)──▶ Cloudflare edge ──(TLS · Vercel cert)──▶ Vercel edge
//
// The whole pitfall is that beginners model this as a single locked connection,
// when it's really two connections each needing their own lock. So the two arrows
// are drawn visually PARALLEL and EQUAL, each tinted as an encrypted hop and each
// carrying its own padlock glyph + certificate label — the reader should count two
// locks, not one. Both green = the "Full (strict)" state where both hops are
// genuinely encrypted and validated, which the caption names as the only correct mode.
//
// Plain HTML/CSS strip with CSS arrows (no LeaderLine) — mirrors the sibling
// TwoPointersInSeries.astro so the lesson's two figures read as a family, keeps the
// Figure expandable, and stays devtools-inspectable. Horizontal, compact, under cap.
//
// margin: 0 on every inner element per the Starlight prose-margin gotcha.

import Figure from '../../../figures/Figure.astro';

// Single accent reused for both hops: the point is the two locks are EQUAL siblings,
// so they share a color rather than being tinted "yours vs theirs".
const SECURE = '#0d9488'; // teal-600 — an encrypted, validated TLS hop ("Full strict")
---

<Figure>
	<div class="th not-content">
		<!-- Box 1: the browser -->
		<div class="th-box">
			<span class="th-box-title">Browser</span>
			<span class="th-box-sub">the visitor</span>
		</div>

		<!-- Hop 1: browser → Cloudflare, Cloudflare's edge certificate -->
		<div class="th-hop" style={`--c: ${SECURE};`}>
			<span class="th-hop-label">
				<span class="th-lock" aria-hidden="true">🔒</span> TLS
			</span>
			<span class="th-arrow" aria-hidden="true">
				<span class="th-arrow-line"></span>
				<span class="th-arrow-head"></span>
			</span>
			<span class="th-hop-sub">Cloudflare edge cert</span>
		</div>

		<!-- Box 2: the Cloudflare edge -->
		<div class="th-box">
			<span class="th-box-title">Cloudflare edge</span>
			<span class="th-box-sub">the proxy</span>
		</div>

		<!-- Hop 2: Cloudflare → Vercel, Vercel's Let's Encrypt origin certificate -->
		<div class="th-hop" style={`--c: ${SECURE};`}>
			<span class="th-hop-label">
				<span class="th-lock" aria-hidden="true">🔒</span> TLS
			</span>
			<span class="th-arrow" aria-hidden="true">
				<span class="th-arrow-line"></span>
				<span class="th-arrow-head"></span>
			</span>
			<span class="th-hop-sub">Vercel (Let's Encrypt) cert</span>
		</div>

		<!-- Box 3: the Vercel edge -->
		<div class="th-box">
			<span class="th-box-title">Vercel edge</span>
			<span class="th-box-sub">the origin</span>
		</div>
	</div>
	<Fragment slot="caption">
		Two independent TLS terminations, not one. <strong style={`color: ${SECURE};`}
			>Full (strict)</strong
		> is the only Cloudflare mode where <em>both</em> arrows are encrypted and Vercel's
		certificate is validated.
	</Fragment>
</Figure>

<style>
	.th {
		display: flex;
		flex-wrap: nowrap;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
		margin: 0;
		padding: 14px 2px 8px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.th-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		flex: 0 0 auto;
		padding: 12px 12px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	.th-box-title {
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.th-box-sub {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* A hop is a labeled, colored CSS arrow carrying a padlock + a cert caption. */
	.th-hop {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		flex: 1 1 auto;
		min-width: 110px;
		max-width: 180px;
		margin: 0;
	}

	.th-hop-label {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--c);
		margin: 0;
	}

	.th-lock {
		font-size: 0.78rem;
		line-height: 1;
	}

	.th-arrow {
		display: flex;
		align-items: center;
		width: 100%;
		min-width: 90px;
		margin: 0;
	}

	.th-arrow-line {
		flex: 1 1 auto;
		height: 2px;
		background: var(--c);
		margin: 0;
	}

	.th-arrow-head {
		flex: 0 0 auto;
		width: 0;
		height: 0;
		border-top: 5px solid transparent;
		border-bottom: 5px solid transparent;
		border-left: 8px solid var(--c);
		margin: 0;
	}

	.th-hop-sub {
		font-size: 0.66rem;
		line-height: 1.2;
		text-align: center;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: the row wraps. Rotate each hop's arrow to point down so the
	   chain still reads top-to-bottom instead of leaving sideways arrows dangling. */
	@media (max-width: 640px) {
		.th {
			flex-direction: column;
			align-items: center;
		}
		.th-box {
			width: min(20rem, 100%);
		}
		.th-hop {
			width: auto;
			max-width: none;
		}
		.th-hop-sub {
			white-space: normal;
		}
		.th-arrow {
			width: 2px;
			min-width: 0;
			height: 22px;
			flex-direction: column;
		}
		.th-arrow-line {
			width: 2px;
			height: auto;
		}
		.th-arrow-head {
			border-left: 5px solid transparent;
			border-right: 5px solid transparent;
			border-top: 8px solid var(--c);
			border-bottom: 0;
		}
	}
</style>
