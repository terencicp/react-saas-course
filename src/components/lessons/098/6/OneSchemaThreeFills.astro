---
// one-schema-three-fills — Chapter 098 Lesson 6, "Env vars across dev, preview, and prod".
//
// The lesson's spine in one frame: ONE env.ts schema on the left validates THREE
// independent value-sets on the right. The keys are constant down every box; only
// the *fills* change per environment.
//
//   env.ts  ──validated against──▶  Development  (your laptop)
//           ──────────────────────▶  Preview      (every PR)
//           ──────────────────────▶  Production   (main)
//
// Built with <ArrowDiagram> (LeaderLine) because each box is custom HTML — the
// schema box lists field rows; each env box is a key→value mini-table where the
// key column repeats verbatim (driving home "same keys") and the value column is
// the per-env fill. D2/Mermaid can't render those tables verbatim.
//
// Three arrows share one gap. The ArrowDiagram doc warns that three identical
// labels collide, so the relationship is named ONCE on the middle arrow
// ("validated against") and the shared accent color carries "one schema" for the
// other two. The three arrowheads land on three distinct targets (no stacking);
// staggered start gravity fans the curves into separate lanes.
//
// Arrows are positioned from document.body, so the wrapping <Figure> MUST be
// expandable={false}: relocating the body into the lightbox breaks the lines.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark); the accent
// is a single mid-tone blue used as-is in both themes. margin:0 on every node
// defeats Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Single neutral/blue accent — one schema, one relationship.
const C = '#0ea5e9'; // sky-500

// The constant key column, shared verbatim by all three environment boxes.
const KEYS = ['DATABASE_URL', 'STRIPE_SECRET_KEY', 'NEXT_PUBLIC_APP_URL'];

// Each environment's fills, in the same key order.
const ENVS = [
	{
		id: 'env-dev',
		name: 'Development',
		sub: 'your laptop',
		values: ['dev Neon branch', 'sk_test_…', 'http://localhost:3000'],
	},
	{
		id: 'env-preview',
		name: 'Preview',
		sub: 'every PR',
		values: ['per-PR Neon branch', 'sk_test_…', '…-git-branch.vercel.app'],
	},
	{
		id: 'env-prod',
		name: 'Production',
		sub: 'main',
		values: ['main Neon branch', 'sk_live_…', 'your real domain'],
	},
];

// One source box, three targets. Start points coincide (the single schema) but
// land on three distinct env boxes, so arrowheads never stack. Stagger the start
// gravity so the curves fan into separate lanes; only the middle arrow is
// labeled, naming the relationship once.
const arrows = [
	{
		from: 'schema',
		to: 'env-dev',
		color: C,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, -70],
		endSocketGravity: [-70, 0],
	},
	{
		from: 'schema',
		to: 'env-preview',
		color: C,
		label: 'validated against',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [120, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -14],
		labelStyle:
			'background:#0b1220;color:#7dd3fc;border:1px solid #1e3a5f;font-weight:600;',
	},
	{
		from: 'schema',
		to: 'env-prod',
		color: C,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 70],
		endSocketGravity: [-70, 0],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="osf not-content">
			{/* Left — the single schema, one file, validated identically everywhere. */}
			<div class="schema" id="schema" style={`--accent:${C}`}>
				<div class="schema-head">
					<code class="schema-name">env.ts</code>
					<span class="schema-sub">the schema — one file</span>
				</div>
				<ul class="field-list">
					{KEYS.map((k) => <li class="field"><code>{k}</code></li>)}
				</ul>
			</div>

			{/* Right — three environments, same keys, different fills. */}
			<div class="env-col">
				{
					ENVS.map((env) => (
						<div class="env" id={env.id} style={`--accent:${C}`}>
							<div class="env-head">
								<span class="env-name">{env.name}</span>
								<span class="env-sub">{env.sub}</span>
							</div>
							<table class="kv">
								<tbody>
									{KEYS.map((k, i) => (
										<tr>
											<td class="k"><code>{k}</code></td>
											<td class="v"><code>{env.values[i]}</code></td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					))
				}
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		One schema validates three independent sets of values.
	</Fragment>
</Figure>

<style>
	.osf {
		display: grid;
		grid-template-columns: minmax(150px, 0.85fr) 130px minmax(220px, 1.15fr);
		align-items: center;
		margin: 0;
		padding: 10px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The middle grid track is empty — it reserves the gap the three curves and
	   the single label live in. */
	.osf > .schema {
		grid-column: 1;
	}
	.osf > .env-col {
		grid-column: 3;
	}

	/* ---- Left: the schema box ---- */
	.schema {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 12px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-left: 3px solid var(--accent);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}

	.schema-head {
		display: flex;
		flex-direction: column;
		gap: 1px;
		margin: 0;
	}

	.schema-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: none;
		border: none;
		padding: 0;
		margin: 0;
	}

	.schema-sub {
		font-size: 0.66rem;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.field-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 5px;
		margin: 0;
		padding: 0;
	}

	.field {
		margin: 0;
		padding: 0;
	}

	.field code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, var(--accent) 10%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, var(--accent) 26%, transparent);
		border-radius: 5px;
		padding: 2px 6px;
		display: inline-block;
	}

	/* ---- Right: the three environment boxes ---- */
	.env-col {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
	}

	.env {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 9px 11px;
		border-radius: 10px;
		border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--sl-color-gray-5, #cbd5e1));
		border-left: 3px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 7%, var(--sl-color-bg, transparent));
		margin: 0;
	}

	.env-head {
		display: flex;
		align-items: baseline;
		gap: 7px;
		margin: 0;
	}

	.env-name {
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.1;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.env-sub {
		font-size: 0.64rem;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.kv {
		border-collapse: collapse;
		width: 100%;
		margin: 0;
		table-layout: fixed;
	}

	.kv tr {
		margin: 0;
	}

	.kv td {
		padding: 2px 0;
		vertical-align: top;
		border: none;
		margin: 0;
	}

	.kv .k {
		width: 48%;
		padding-right: 8px;
	}

	.kv .k code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.62rem;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		background: none;
		border: none;
		padding: 0;
		word-break: break-all;
	}

	.kv .v code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.64rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--accent-strong, #0369a1);
		background: none;
		border: none;
		padding: 0;
		word-break: break-all;
	}

	/* Brighter value text in dark mode so it reads on the dark card. */
	:global([data-theme='dark']) .kv .v code {
		color: #7dd3fc;
	}

	/* Narrow viewports: the middle gap that holds the arrows collapses, so the
	   right→left sockets would arc awkwardly. Stack the schema above the env
	   column; the arrows degrade to short top→bottom hops — readable, if not the
	   intended straight fan. */
	@media (max-width: 640px) {
		.osf {
			grid-template-columns: 1fr;
			gap: 36px;
			row-gap: 36px;
		}
		.osf > .schema {
			grid-column: 1;
		}
		.osf > .env-col {
			grid-column: 1;
		}
	}
</style>
