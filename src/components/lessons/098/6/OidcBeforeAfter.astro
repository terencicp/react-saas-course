---
// oidc-before-after — Chapter 098 Lesson 6, "Env vars across dev, preview, and
// prod", section "OIDC: short-lived tokens instead of long-lived cloud keys".
//
// The senior diff in one scrubbable figure: the credential's *lifetime* is the
// security property. A standing static key (BEFORE) is unbounded and tagged red;
// the federated token flow (AFTER, three steps: mint -> exchange -> use) is
// ephemeral and tagged green.
//
//   Step 1  BEFORE:  env(R2 secret, lives forever) ──▶ Function → Cloud (R2)
//   Step 2  Mint:    Vercel (IdP) ──▶ VERCEL_OIDC_TOKEN (expires < 1h)
//   Step 3  Exchange: token ──▶ Cloud provider (trusts Vercel) ──▶ temp creds
//   Step 4  Use:     temp creds ──▶ Function → Cloud (R2)  (expires on its own)
//
// Built with <DiagramSequence>/<DiagramStep>: the slider lets the student walk the
// flow one beat at a time, which is exactly the "before, then 3-step after"
// framing the prose uses. Bodies are plain HTML/CSS (per the diagrams guide) — a
// fixed horizontal node→arrow row so every step is the same height and the stage
// never jumps as you scrub.
//
// DiagramSequence provides its own card, so this is NOT wrapped in <Figure>.
//
// Chrome is theme-aware (Starlight gray/white/bg vars flip light/dark). The two
// lifetime tags are the load-bearing color: RED = unbounded standing secret,
// GREEN = ephemeral federated credential. `not-content` + margin:0 resets defeat
// Starlight's injected prose margins inside the figure.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';
---

<DiagramSequence>
	{/* ---- Step 1 — BEFORE: a standing static secret, valid until revoked ---- */}
	<DiagramStep
		caption="Before: a standing secret. The long-lived R2_SECRET_ACCESS_KEY lives in your environment and the function uses it directly. Valid until a human revokes it — so a leak grants full access until someone notices."
	>
		<div class="oba not-content" data-variant="before">
			<div class="node node-store">
				<span class="node-label">Vercel env</span>
				<code class="node-code">R2_SECRET_ACCESS_KEY</code>
				<span class="tag tag-bad">lives forever</span>
			</div>
			<span class="arrow" aria-hidden="true">→</span>
			<div class="node node-fn">
				<span class="node-label">Function</span>
				<span class="node-sub">→ Cloud (R2)</span>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2 — AFTER 1/3: Vercel mints a short-lived signed JWT ---- */}
	<DiagramStep
		caption="After, step 1 of 3 — Mint. On each invocation Vercel mints a short-lived, signed JWT identifying this project and environment. No static cloud key anywhere."
	>
		<div class="oba not-content" data-variant="after">
			<div class="node node-idp">
				<span class="node-label">Vercel</span>
				<span class="node-sub">acts as Identity Provider</span>
			</div>
			<span class="arrow" aria-hidden="true">→</span>
			<div class="chip chip-token">
				<code class="chip-code">VERCEL_OIDC_TOKEN</code>
				<span class="tag tag-good">expires &lt; 1h</span>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3 — AFTER 2/3: the provider trusts Vercel, swaps token for creds ---- */}
	<DiagramStep
		caption="After, step 2 of 3 — Exchange. The function hands that token to the cloud provider, which trusts Vercel's issuer (a one-time trust setup) and swaps it for short-lived cloud credentials."
	>
		<div class="oba not-content" data-variant="after">
			<div class="chip chip-token">
				<code class="chip-code">VERCEL_OIDC_TOKEN</code>
				<span class="tag tag-good">expires &lt; 1h</span>
			</div>
			<span class="arrow" aria-hidden="true">→</span>
			<div class="node node-cloud">
				<span class="node-label">Cloud provider</span>
				<span class="node-sub">trusts Vercel's issuer</span>
			</div>
			<span class="arrow" aria-hidden="true">→</span>
			<div class="chip chip-creds">
				<code class="chip-code">temporary credentials</code>
				<span class="tag tag-good">short-lived</span>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 4 — AFTER 3/3: function calls the cloud with ephemeral creds ---- */}
	<DiagramStep
		caption="After, step 3 of 3 — Use. The function calls the cloud with those temporary credentials, which expire on their own in under an hour. A leaked token is near-worthless — it's already expiring."
	>
		<div class="oba not-content" data-variant="after">
			<div class="chip chip-creds">
				<code class="chip-code">temporary credentials</code>
				<span class="tag tag-good">expires on its own</span>
			</div>
			<span class="arrow" aria-hidden="true">→</span>
			<div class="node node-fn">
				<span class="node-label">Function</span>
				<span class="node-sub">→ Cloud (R2)</span>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>

<style>
	.oba {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 10px;
		margin: 0;
		padding: 18px 8px;
		min-height: 150px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ---- Nodes (boxes) ---- */
	.node {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		min-width: 150px;
		padding: 12px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-top: 3px solid var(--accent, #64748b);
		background: var(--sl-color-bg, transparent);
		margin: 0;
		text-align: center;
	}

	.node-store {
		--accent: #ef4444; /* red-500 — the standing-secret store */
	}
	.node-idp,
	.node-cloud {
		--accent: #0ea5e9; /* sky-500 — Vercel / cloud actors */
	}
	.node-fn {
		--accent: #64748b; /* slate-500 — the function */
	}

	.node-label {
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.node-sub {
		font-size: 0.66rem;
		color: var(--sl-color-gray-3, #64748b);
		line-height: 1.2;
		margin: 0;
	}

	.node-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, var(--accent) 12%, var(--sl-color-bg, transparent));
		border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
		border-radius: 5px;
		padding: 2px 6px;
		margin: 1px 0;
		word-break: break-all;
	}

	/* ---- Token / credential chips (pill-shaped, the thing that flows) ---- */
	.chip {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		padding: 9px 12px;
		border-radius: 999px;
		border: 1px dashed color-mix(in srgb, var(--accent, #22c55e) 50%, transparent);
		background: color-mix(in srgb, var(--accent, #22c55e) 9%, var(--sl-color-bg, transparent));
		margin: 0;
		text-align: center;
	}

	.chip-token,
	.chip-creds {
		--accent: #22c55e; /* green-500 — ephemeral federated credential */
	}

	.chip-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: none;
		border: none;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}

	/* ---- Lifetime tags — the load-bearing color ---- */
	.tag {
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		line-height: 1;
		border-radius: 999px;
		padding: 3px 7px;
		margin: 0;
	}

	.tag-bad {
		color: #b91c1c; /* red-700 */
		background: #fee2e2; /* red-100 */
		border: 1px solid #fca5a5; /* red-300 */
	}

	.tag-good {
		color: #15803d; /* green-700 */
		background: #dcfce7; /* green-100 */
		border: 1px solid #86efac; /* green-300 */
	}

	:global([data-theme='dark']) .tag-bad {
		color: #fca5a5;
		background: color-mix(in srgb, #ef4444 18%, transparent);
		border-color: color-mix(in srgb, #ef4444 45%, transparent);
	}
	:global([data-theme='dark']) .tag-good {
		color: #86efac;
		background: color-mix(in srgb, #22c55e 18%, transparent);
		border-color: color-mix(in srgb, #22c55e 45%, transparent);
	}

	/* ---- Arrows between nodes ---- */
	.arrow {
		font-size: 1.4rem;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-3, #94a3b8);
		margin: 0;
		flex: 0 0 auto;
	}

	/* Narrow viewports: the row wraps; turn the connecting glyphs into down-arrows
	   so the flow still reads top-to-bottom. */
	@media (max-width: 560px) {
		.arrow {
			transform: rotate(90deg);
		}
		.node {
			min-width: 0;
			width: 100%;
		}
	}
</style>
