---
// vercel-env-panel-mock — Chapter 098 Lesson 6, "Env vars across dev, preview,
// and prod", section "Setting variables in the Vercel dashboard" (right after the
// paragraph that introduces the key/value/environment-checkbox triple).
//
// A faithful HTML/CSS mock of Vercel's Settings -> Environment Variables panel.
// The real page is an authenticated dashboard that can't be screenshotted, so this
// is a hand-built component, not a Screenshot of a real page (matches the
// mock-not-screenshot convention from L2-L5, and the VercelDomainsPanel mock in
// L4 whose chrome this deliberately mirrors).
//
// Three teaching points, one per visual element:
//   1. The ADD-VARIABLE row makes the scope concrete: a Key input, a masked Value
//      input, the three environment CHECKBOXES (Production / Preview / Development)
//      that ARE the scope, and a "Sensitive" toggle shown in the ON state.
//   2. STRIPE_SECRET_KEY — scoped to all three — shows a "Sensitive" pill where the
//      value would be: a sensitive var's value is never read back.
//   3. DATABASE_URL (Preview) — locked, "Managed by Neon" pill, greyed/uneditable
//      value: a managed var the integration owns.
//   4. NEXT_PUBLIC_APP_NAME — all three scopes — value shown in plaintext, no pill:
//      a non-sensitive cosmetic string.
//
// Pure HTML + CSS per the diagrams guide. Chrome uses Starlight theme variables so
// it flips light/dark; the accent (sensitive), amber-ish lock, and scope chips are
// saturated mid-tones with their own text colors that read in both themes.
// `not-content` + margin: 0 resets defeat Starlight's prose-margin selector.

import Figure from '../../../figures/Figure.astro';

const VIOLET = '#7c3aed'; // violet-600 — the "Sensitive" accent
const VIOLET_BG = '#f3e8ff'; // violet-100 — sensitive pill background (light)
const SLATE = '#475569'; // slate-600 — the "Managed by Neon" lock accent
const SLATE_BG = '#e2e8f0'; // slate-200 — managed pill background (light)

// The three scope checkboxes shared by the add-variable row.
const SCOPES = ['Production', 'Preview', 'Development'];
---

<Figure>
	<div
		class="ve not-content"
		role="img"
		aria-label="Vercel's Settings, Environment Variables panel. An add-variable row at the top has a Key field showing STRIPE_SECRET_KEY, a masked Value field, three environment checkboxes (Production, Preview, Development) all ticked, and a Sensitive toggle switched on. Below are three saved rows: STRIPE_SECRET_KEY scoped to all three environments with its value hidden behind a Sensitive pill; DATABASE_URL scoped to Preview, locked and labelled Managed by Neon with a greyed value; and NEXT_PUBLIC_APP_NAME scoped to all three environments showing the plaintext value Acme Invoicing."
	>
		<div class="ve-panel">
			{/* ---- Heading ---- */}
			<div class="ve-head">
				<span class="ve-title">Environment Variables</span>
				<span class="ve-subtitle">
					A variable is a key, a value, and the environments it applies to.
				</span>
			</div>

			{/* ---- Add-variable row: key + value + scope checkboxes + sensitive ---- */}
			<div class="ve-add">
				<div class="ve-field">
					<span class="ve-label">Key</span>
					<span class="ve-input ve-input-mono">STRIPE_SECRET_KEY</span>
				</div>
				<div class="ve-field">
					<span class="ve-label">Value</span>
					<span class="ve-input ve-input-mono ve-input-masked">
						&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;
					</span>
				</div>

				<div class="ve-field ve-field-wide">
					<span class="ve-label">Environments</span>
					<div class="ve-checks">
						{
							SCOPES.map((s) => (
								<span class="ve-check">
									<span class="ve-box ve-box-on" aria-hidden="true">
										<svg viewBox="0 0 16 16" width="10" height="10">
											<path
												fill="none"
												stroke="currentColor"
												stroke-width="2.4"
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M3.5 8.5 L6.5 11.5 L12.5 4.5"
											/>
										</svg>
									</span>
									<span class="ve-check-label">{s}</span>
								</span>
							))
						}
					</div>
				</div>

				<div class="ve-field ve-field-toggle">
					<span class="ve-label">Sensitive</span>
					<span class="ve-toggle ve-toggle-on" role="switch" aria-checked="true">
						<span class="ve-toggle-knob" aria-hidden="true"></span>
					</span>
				</div>

				<span class="ve-save-btn">Save</span>
			</div>

			<div class="ve-divider"></div>

			{/* ---- Column header for the saved rows ---- */}
			<div class="ve-list-head">
				<span>Key</span>
				<span>Value</span>
				<span>Environments</span>
			</div>

			{/* ---- Row 1: sensitive — value never shown back ---- */}
			<div class="ve-row">
				<span class="ve-row-key">STRIPE_SECRET_KEY</span>
				<span class="ve-row-val">
					<span class="ve-pill ve-pill-sensitive">
						<svg
							class="ve-pill-ico"
							viewBox="0 0 16 16"
							width="11"
							height="11"
							aria-hidden="true"
						>
							<path
								fill="none"
								stroke="currentColor"
								stroke-width="1.4"
								d="M5 7V4.5a3 3 0 0 1 6 0V7"></path>
							<rect
								x="3.5"
								y="7"
								width="9"
								height="6.5"
								rx="1.2"
								fill="currentColor"></rect>
						</svg>
						Sensitive — value hidden
					</span>
				</span>
				<span class="ve-row-scopes">
					<span class="ve-scope">Production</span>
					<span class="ve-scope">Preview</span>
					<span class="ve-scope">Development</span>
				</span>
			</div>

			{/* ---- Row 2: managed by Neon — locked, greyed, uneditable ---- */}
			<div class="ve-row ve-row-managed">
				<span class="ve-row-key">
					<svg
						class="ve-lock"
						viewBox="0 0 16 16"
						width="12"
						height="12"
						aria-hidden="true"
					>
						<path
							fill="none"
							stroke="currentColor"
							stroke-width="1.4"
							d="M5 7V4.5a3 3 0 0 1 6 0V7"></path>
						<rect
							x="3.5"
							y="7"
							width="9"
							height="6.5"
							rx="1.2"
							fill="currentColor"></rect>
					</svg>
					DATABASE_URL
				</span>
				<span class="ve-row-val ve-row-val-greyed">
					postgres://&hellip;&#8288;neon.tech/&hellip;
				</span>
				<span class="ve-row-scopes">
					<span class="ve-pill ve-pill-managed">Managed by Neon</span>
					<span class="ve-scope ve-scope-single">Preview</span>
				</span>
			</div>

			{/* ---- Row 3: plaintext, non-sensitive cosmetic string ---- */}
			<div class="ve-row">
				<span class="ve-row-key">NEXT_PUBLIC_APP_NAME</span>
				<span class="ve-row-val ve-row-val-plain">Acme Invoicing</span>
				<span class="ve-row-scopes">
					<span class="ve-scope">Production</span>
					<span class="ve-scope">Preview</span>
					<span class="ve-scope">Development</span>
				</span>
			</div>
		</div>
	</div>
	<Fragment slot="caption">
		Vercel&rsquo;s Settings &rarr; Environment Variables panel. Each variable is a
		value plus a scope &mdash; the three checkboxes <em>are</em> the scope. A{' '}
		<strong style={`color: ${VIOLET};`}>Sensitive</strong> variable never shows its
		value back; a <strong style={`color: ${SLATE};`}>managed</strong> variable is
		locked because the Neon integration owns it.
	</Fragment>
</Figure>

<style
	define:vars={{
		've-violet': VIOLET,
		've-violet-bg': VIOLET_BG,
		've-slate': SLATE,
		've-slate-bg': SLATE_BG,
	}}
>
	.ve {
		margin: 0;
		display: flex;
		justify-content: center;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- The panel card ---- */
	.ve-panel {
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		max-width: 620px;
		padding: 18px 20px 20px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 12px;
		background: var(--sl-color-bg-sidebar);
	}

	/* ---- Heading ---- */
	.ve-head {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.ve-title {
		margin: 0;
		font-size: 18px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}

	.ve-subtitle {
		margin: 0;
		font-size: 12px;
		line-height: 1.3;
		color: var(--sl-color-gray-3);
	}

	/* ---- Add-variable row ---- */
	.ve-add {
		margin: 14px 0 0;
		padding: 14px;
		border: 1.5px solid var(--sl-color-gray-5);
		border-radius: 9px;
		background: var(--sl-color-bg);
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		gap: 14px 16px;
	}

	.ve-field {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 5px;
		min-width: 0;
	}

	.ve-field-wide {
		flex: 1 1 auto;
	}

	.ve-label {
		margin: 0;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	.ve-input {
		margin: 0;
		display: inline-flex;
		align-items: center;
		height: 30px;
		padding: 0 11px;
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 7px;
		background: var(--sl-color-bg-sidebar);
		font-size: 13px;
		color: var(--sl-color-white);
	}

	.ve-input-mono {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}

	.ve-input-masked {
		letter-spacing: 1px;
		color: var(--sl-color-gray-3);
		overflow: hidden;
	}

	/* ---- Scope checkboxes ---- */
	.ve-checks {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 6px 14px;
		height: 30px;
		align-items: center;
	}

	.ve-check {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.ve-box {
		margin: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 15px;
		height: 15px;
		border-radius: 4px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg);
	}

	.ve-box-on {
		border-color: var(--sl-color-white);
		background: var(--sl-color-white);
		color: var(--sl-color-black);
	}

	.ve-check-label {
		margin: 0;
		font-size: 12.5px;
		color: var(--sl-color-white);
	}

	/* ---- Sensitive toggle (ON) ---- */
	.ve-field-toggle {
		align-items: flex-start;
	}

	.ve-toggle {
		margin: 0;
		position: relative;
		display: inline-flex;
		align-items: center;
		width: 38px;
		height: 22px;
		border-radius: 999px;
		background: var(--sl-color-gray-5);
		transition: background 0.15s;
	}

	.ve-toggle-on {
		background: var(--ve-violet);
	}

	.ve-toggle-knob {
		margin: 0;
		position: absolute;
		top: 2px;
		left: 2px;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: #fff;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
	}

	.ve-toggle-on .ve-toggle-knob {
		left: 18px;
	}

	.ve-save-btn {
		margin: 0;
		display: inline-flex;
		align-items: center;
		height: 30px;
		padding: 0 16px;
		border-radius: 7px;
		background: var(--sl-color-white);
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-black);
	}

	.ve-divider {
		margin: 16px 0 0;
		height: 1px;
		background: var(--sl-color-gray-5);
	}

	/* ---- Saved-rows list ---- */
	.ve-list-head {
		margin: 14px 0 0;
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.1fr) minmax(0, 1.3fr);
		gap: 14px;
		padding: 0 12px 6px;
	}

	.ve-list-head span {
		margin: 0;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	.ve-row {
		margin: 8px 0 0;
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.1fr) minmax(0, 1.3fr);
		gap: 14px;
		align-items: center;
		padding: 11px 12px;
		border: 1.5px solid var(--sl-color-gray-5);
		border-radius: 9px;
		background: var(--sl-color-bg);
	}

	.ve-row-managed {
		background: color-mix(in srgb, var(--sl-color-gray-5) 35%, var(--sl-color-bg));
	}

	.ve-row-key {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-white);
		word-break: break-all;
	}

	.ve-lock {
		flex: none;
		color: var(--ve-slate);
	}

	:global([data-theme='dark']) .ve-lock {
		color: var(--sl-color-gray-2);
	}

	.ve-row-val {
		margin: 0;
		min-width: 0;
		font-size: 13px;
	}

	.ve-row-val-plain {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		color: var(--sl-color-white);
	}

	.ve-row-val-greyed {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		color: var(--sl-color-gray-3);
		font-style: normal;
		word-break: break-all;
	}

	/* ---- Pills ---- */
	.ve-pill {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 3px 9px;
		border-radius: 999px;
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.4;
		white-space: nowrap;
	}

	.ve-pill-sensitive {
		color: var(--ve-violet);
		background: var(--ve-violet-bg);
		border: 1px solid color-mix(in srgb, var(--ve-violet) 35%, transparent);
	}

	.ve-pill-ico {
		flex: none;
	}

	.ve-pill-managed {
		color: var(--ve-slate);
		background: var(--ve-slate-bg);
		border: 1px solid color-mix(in srgb, var(--ve-slate) 35%, transparent);
	}

	:global([data-theme='dark']) .ve-pill-sensitive {
		color: #d8b4fe;
		background: color-mix(in srgb, var(--ve-violet) 24%, transparent);
	}

	:global([data-theme='dark']) .ve-pill-managed {
		color: var(--sl-color-gray-1);
		background: color-mix(in srgb, var(--sl-color-gray-3) 24%, transparent);
	}

	/* ---- Scope chips on saved rows ---- */
	.ve-row-scopes {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 5px;
		align-items: center;
	}

	.ve-scope {
		margin: 0;
		padding: 2px 8px;
		border-radius: 6px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg-sidebar);
		font-size: 11px;
		font-weight: 500;
		color: var(--sl-color-gray-2);
		white-space: nowrap;
	}

	.ve-scope-single {
		color: var(--sl-color-white);
		border-color: var(--sl-color-gray-3);
	}

	@media (max-width: 540px) {
		.ve-panel {
			padding: 16px 14px;
		}
		.ve-add {
			flex-direction: column;
			align-items: stretch;
		}
		.ve-field {
			width: 100%;
		}
		.ve-save-btn {
			align-self: flex-start;
		}
		.ve-list-head {
			display: none;
		}
		.ve-row {
			grid-template-columns: 1fr;
			gap: 8px;
		}
	}
</style>
