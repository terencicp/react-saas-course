---
// live-vs-defensible — Chapter 098 Lesson 8, "The launch checklist", section
// "Launch is a posture, not a URL".
//
// Makes the subset relation spatial: "live" is a small subset of "defensible".
// Two cards side by side with a "the checklist" arrow between them.
//
//   [ URL is live ]        →        [ URL is defensible ]
//    homepage glyph     the checklist   homepage glyph ringed by
//    "the server answers"               nine verified safety nets
//
// The LEFT card is deliberately sparse — one browser glyph and a single line —
// because the emptiness is the point. The RIGHT card holds the same glyph
// surrounded by the nine nets the rest of the lesson verifies. The nine nets are
// laid out as a wrapped grid of tiny labeled chips beneath the homepage glyph
// (rather than absolute-positioned around a ring, which is brittle and prone to
// label overlap per the HTML/CSS diagram guidance).
//
// Plain HTML/CSS with a scoped <style>; .not-content opts out of Starlight prose
// styling, and margin: 0 on inner elements guards against the prose-margin
// injection gotcha. Horizontal, compact, well under the height cap.

import Figure from '../../../figures/Figure.astro';
import { Icon } from 'astro-icon/components';

const LIVE = '#16a34a'; // green-600 — "the server answers", the whole left story
const DEF = '#0d9488'; // teal-600 — the defensible-side accent

// The nine verified safety nets that fill the gap between live and defensible.
// Order mirrors the nine checklist rows below the diagram in the lesson.
const nets = [
	{ icon: 'lucide:badge-check', label: 'env validation' },
	{ icon: 'lucide:siren', label: 'error monitoring' },
	{ icon: 'lucide:gauge', label: 'rate limits' },
	{ icon: 'lucide:scroll-text', label: 'audit logs' },
	{ icon: 'lucide:shield-check', label: 'security headers' },
	{ icon: 'lucide:database', label: 'pooled DB' },
	{ icon: 'lucide:history', label: 'restore history' },
	{ icon: 'lucide:activity', label: 'uptime monitor' },
	{ icon: 'lucide:book-open', label: 'runbooks' },
];
---

<Figure
	caption="Live is a subset of launched. The left card is everything 'the homepage renders' gives you; the right card adds the nine verified safety nets that make the URL defensible. The checklist is what turns the left into the right."
>
	<div
		class="lvd not-content"
		role="img"
		aria-label="Two side-by-side cards. The left, 'URL is live', holds a single homepage glyph and the words 'the server answers'. The right, 'URL is defensible', shows the same homepage glyph ringed by nine small safety-net glyphs. An arrow labelled 'the checklist' points from the sparse left card to the rich right card."
	>
		<!-- LEFT: URL is live — deliberately sparse -->
		<div class="lvd-card lvd-card--live" style={`--c: ${LIVE};`}>
			<span class="lvd-card-title">URL is live</span>
			<div class="lvd-card-body">
				<span class="lvd-home" aria-hidden="true">
					<Icon name="lucide:globe" size={34} />
				</span>
				<span class="lvd-home-label">the server answers</span>
			</div>
		</div>

		<!-- MIDDLE: the checklist transforms one into the other -->
		<div class="lvd-mid" aria-hidden="true">
			<span class="lvd-mid-label">the checklist</span>
			<span class="lvd-arrow">
				<span class="lvd-arrow-line"></span>
				<span class="lvd-arrow-head"></span>
			</span>
		</div>

		<!-- RIGHT: URL is defensible — same glyph, ringed by nine nets -->
		<div class="lvd-card lvd-card--def" style={`--c: ${DEF};`}>
			<span class="lvd-card-title">URL is defensible</span>
			<div class="lvd-card-body">
				<span class="lvd-home lvd-home--def" aria-hidden="true">
					<Icon name="lucide:globe" size={28} />
				</span>
				<div class="lvd-nets">
					{
						nets.map((net) => (
							<div class="lvd-net">
								<Icon name={net.icon} size={15} class="lvd-net-icon" />
								<span class="lvd-net-label">{net.label}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</Figure>

<style>
	.lvd {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 10px;
		margin: 0;
		padding: 6px 2px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.lvd-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		margin: 0;
		padding: 10px 12px 14px;
		border-radius: 12px;
		border: 1px solid var(--c);
		background: color-mix(in srgb, var(--c) 7%, transparent);
	}

	.lvd-card--live {
		flex: 0 1 200px;
		justify-content: flex-start;
	}

	.lvd-card--def {
		flex: 1 1 320px;
		max-width: 460px;
	}

	.lvd-card-title {
		margin: 0;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--c);
	}

	.lvd-card-body {
		display: flex;
		flex: 1 1 auto;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		margin: 0;
		width: 100%;
	}

	/* The homepage glyph — same shape on both sides. */
	.lvd-home {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		width: 56px;
		height: 56px;
		border-radius: 50%;
		border: 2px solid var(--c);
		background: var(--sl-color-bg, #fff);
		color: var(--c);
	}

	.lvd-home--def {
		width: 48px;
		height: 48px;
	}

	.lvd-home-label {
		margin: 0;
		font-size: 0.74rem;
		font-style: italic;
		line-height: 1.2;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
	}

	/* Middle column: the labeled arrow. */
	.lvd-mid {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 5px;
		margin: 0;
		flex: 0 0 auto;
		min-width: 96px;
	}

	.lvd-mid-label {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		font-style: italic;
		color: var(--sl-color-gray-2, #475569);
	}

	.lvd-arrow {
		display: flex;
		align-items: center;
		margin: 0;
		width: 100%;
		min-width: 80px;
	}

	.lvd-arrow-line {
		flex: 1 1 auto;
		height: 2px;
		margin: 0;
		background: var(--sl-color-gray-4, #94a3b8);
	}

	.lvd-arrow-head {
		flex: 0 0 auto;
		width: 0;
		height: 0;
		margin: 0;
		border-top: 5px solid transparent;
		border-bottom: 5px solid transparent;
		border-left: 8px solid var(--sl-color-gray-4, #94a3b8);
	}

	/* The nine nets, as a wrapped grid of tiny chips beneath the glyph. */
	.lvd-nets {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 6px;
		margin: 0;
		width: 100%;
	}

	.lvd-net {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 5px;
		margin: 0;
		padding: 4px 7px;
		border-radius: 7px;
		border: 1px solid color-mix(in srgb, var(--c) 35%, transparent);
		background: var(--sl-color-bg, transparent);
		min-width: 0;
	}

	.lvd-net-icon {
		flex: 0 0 auto;
		color: var(--c);
	}

	.lvd-net-label {
		margin: 0;
		font-size: 0.66rem;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	/* Narrow viewports: stack the three blocks and point the arrow down. */
	@media (max-width: 620px) {
		.lvd {
			flex-direction: column;
			align-items: center;
		}
		.lvd-card--live,
		.lvd-card--def {
			width: min(22rem, 100%);
			flex: 0 0 auto;
		}
		.lvd-mid {
			flex-direction: row;
			gap: 8px;
		}
		.lvd-arrow {
			width: 2px;
			min-width: 0;
			height: 22px;
			flex-direction: column;
		}
		.lvd-arrow-line {
			width: 2px;
			height: auto;
		}
		.lvd-arrow-head {
			border-left: 5px solid transparent;
			border-right: 5px solid transparent;
			border-top: 8px solid var(--sl-color-gray-4, #94a3b8);
			border-bottom: 0;
		}
		.lvd-nets {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
