---
// git-event-to-deployment-map — Chapter 098 Lesson 1, "The push-is-the-deploy model".
//
// The lesson's opening picture: a clean 3→3 correspondence. Three git
// situations on the left, the deployment kind each one triggers on the right,
// one straight colored arrow per row — no crossings.
//
//   push → main                  ──green──▶  Production deployment
//   push → feature/* (PR open)   ──blue───▶  Preview deployment (*.vercel.app)
//   vercel dev (local)           ──violet─▶  Development
//
// The point: where a commit lands is decided entirely by which branch you
// pushed to and whether a PR is open — three git events, three deployment kinds.
//
// Built with <ArrowDiagram> (LeaderLine) because each box is multi-line custom
// HTML — an eyebrow label ("git event" / "deployment"), a monospace command or
// name, and a short detail line — and the per-row accent coloring carries the
// mapping. The arrows carry DIRECTION (the git event *causes* the deployment),
// which color matching alone wouldn't express, so arrows earn their keep here.
// Each arrow runs right→left across the gap (startSocket 'right', endSocket
// 'left') so the three flow straight across without crossing.
//
// Arrows are positioned from document.body, so the wrapping <Figure> MUST be
// expandable={false}: relocating the body into the lightbox breaks the lines.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark). The accents
// are mid-tones used as-is in both themes. margin:0 on every node defeats
// Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Per-row accents — each names a deployment kind.
const C_PROD = '#16a34a'; // green-600  — production
const C_PREVIEW = '#0ea5e9'; // sky-500    — preview
const C_DEV = '#9333ea'; // violet-600 — development

// Three straight arrows, one per row, left column → right column.
const arrows = [
	{
		from: 'ge-main',
		to: 'dep-prod',
		color: C_PROD,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
	},
	{
		from: 'ge-pr',
		to: 'dep-preview',
		color: C_PREVIEW,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
	},
	{
		from: 'ge-dev',
		to: 'dep-dev',
		color: C_DEV,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="map not-content">
			{/* Left column — the three git events that trigger a deployment. */}
			<div class="col">
				<div class="box box-src" id="ge-main" style={`--accent:${C_PROD}`}>
					<span class="eyebrow">git event</span>
					<code class="cmd">push → main</code>
				</div>
				<div class="box box-src" id="ge-pr" style={`--accent:${C_PREVIEW}`}>
					<span class="eyebrow">git event</span>
					<code class="cmd">push → feature/* (PR open)</code>
				</div>
				<div class="box box-src" id="ge-dev" style={`--accent:${C_DEV}`}>
					<span class="eyebrow">git event</span>
					<code class="cmd">vercel dev (local)</code>
				</div>
			</div>

			{/* Right column — the deployment kind each git event lands in. */}
			<div class="col">
				<div class="box box-tgt" id="dep-prod" style={`--accent:${C_PROD}`}>
					<span class="eyebrow">deployment</span>
					<span class="name">Production deployment</span>
				</div>
				<div class="box box-tgt" id="dep-preview" style={`--accent:${C_PREVIEW}`}>
					<span class="eyebrow">deployment</span>
					<span class="name">Preview deployment</span>
					<code class="detail">*.vercel.app</code>
				</div>
				<div class="box box-tgt" id="dep-dev" style={`--accent:${C_DEV}`}>
					<span class="eyebrow">deployment</span>
					<span class="name">Development</span>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		Each git situation maps to exactly one deployment kind.
	</Fragment>
</Figure>

<style>
	.map {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 110px;
		align-items: stretch;
		margin: 0;
		padding: 12px 6px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.col {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 22px;
		margin: 0;
	}

	.box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 11px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		margin: 0;
		/* A left accent bar ties each box to its row color. */
		border-left: 3px solid var(--accent);
	}

	/* Targets carry a faint accent wash so the deployment side reads as the
	   destination, not just another box. */
	.box-tgt {
		background: color-mix(in srgb, var(--accent) 8%, var(--sl-color-bg, transparent));
		border-color: color-mix(in srgb, var(--accent) 32%, var(--sl-color-gray-5, #cbd5e1));
	}

	.eyebrow {
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0;
	}

	.cmd {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: none;
		border: none;
		padding: 0;
		margin: 0;
	}

	.name {
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.detail {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		background: none;
		border: none;
		padding: 0;
		margin: 0;
	}

	/* Narrow viewports: the gap that holds the arrows collapses, so the right→left
	   sockets would arc awkwardly. Stack the columns and the arrows degrade to
	   short top→bottom-ish hops — readable, if not the intended straight lines. */
	@media (max-width: 560px) {
		.map {
			grid-template-columns: 1fr;
			gap: 40px;
		}
	}
</style>
