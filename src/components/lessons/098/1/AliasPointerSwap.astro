---
// alias-pointer-swap — the keystone visual for Lesson 98.1, "The push-is-the-deploy model".
//
// The single idea the whole chapter hangs on: a deployment is an IMMUTABLE,
// frozen value, and "production" is just a POINTER (the app.example.com alias)
// aimed at one deployment at a time. "Deploying" doesn't rebuild anything — it
// re-aims the pointer. This DiagramSequence lets the student scrub that motion
// into place and SEE the pointer move while the cards stay put:
//
//   Step 1  pointer -> a1b2   (two deployments exist; a1b2 is the latest push)
//   Step 2  pointer -> a1b2   (c3d4 is built & live on its own URL, NOT aliased)
//   Step 3  pointer -> c3d4   (atomic re-alias; a1b2 & 9f0e dimmed but still live)
//
// Layout is fixed across all three steps so the DiagramSequence stage (a grid
// stack that sizes to the tallest step) never reflows. The card row always has
// THREE columns in newest->oldest order (c3d4 | a1b2 | 9f0e). In step 1 the
// c3d4 column is a hidden placeholder that still holds its space, so the two
// real cards never shift. Only per-element STATE changes between steps:
//   - card "new" / "live" / "dim" / "ghost"  -> newest+unaliased / frozen / older / not-built
//   - the pointer chip slides to sit over column `target` and an arrow drops to it
//
// Pure HTML + CSS (devtools-inspectable), no LeaderLine — the pointer->card
// arrow is a CSS-drawn connector inside each static step, so it survives the
// step-swap (unlike ArrowDiagram, which positions from document.body). Starlight
// theme vars keep it native in light and dark; the alias accent (blue) reads as
// "what production points at". `not-content` + margin resets defeat Starlight's
// prose-margin selector inside the figure.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

type CardState = "new" | "live" | "dim" | "ghost";

type Card = {
  hash: string;
  message: string;
  state: CardState;
  // shown on the newest, freshly-built-but-not-yet-aliased card
  badge?: string;
};

type StepDef = {
  // which column index (0 = newest/leftmost) the alias currently points at
  target: number;
  // exactly three columns, newest -> oldest, fixed positions across all steps
  cards: Card[];
};

const steps: StepDef[] = [
  // Step 1 — two deployments exist; the newest column is an empty placeholder so
  // the layout matches steps 2-3. The alias points at a1b2 (the latest push).
  {
    target: 1,
    cards: [
      { hash: "", message: "", state: "ghost" },
      { hash: "a1b2", message: "fix invoice total", state: "live" },
      { hash: "9f0e", message: "add export button", state: "dim" },
    ],
  },

  // Step 2 — a new push to main builds c3d4. It's live on its OWN URL, badged
  // "built · not aliased". The alias has NOT moved — it still points at a1b2.
  {
    target: 1,
    cards: [
      { hash: "c3d4", message: "new pricing page", state: "new", badge: "built · not aliased" },
      { hash: "a1b2", message: "fix invoice total", state: "live" },
      { hash: "9f0e", message: "add export button", state: "dim" },
    ],
  },

  // Step 3 — the atomic re-alias. The pointer swings to c3d4. No rebuild. a1b2
  // and 9f0e are dimmed but still live at their URLs, ready to roll back to.
  {
    target: 0,
    cards: [
      { hash: "c3d4", message: "new pricing page", state: "live" },
      { hash: "a1b2", message: "fix invoice total", state: "dim" },
      { hash: "9f0e", message: "add export button", state: "dim" },
    ],
  },
];

// Captions are rendered via set:html, so inline code is real <code>, not
// markdown backticks (the DiagramStep caption slot takes HTML, not markdown).
const captions = [
  "Two deployments exist. The production domain points at <code>a1b2</code>, the latest push to <code>main</code>.",
  "A new push to <code>main</code> builds <code>c3d4</code>. It's live on its own URL, but the domain hasn't moved.",
  "Vercel re-aliases the domain to <code>c3d4</code>. The swap is atomic — no rebuild. <code>a1b2</code> and the rest stay live at their URLs, ready to roll back to.",
];
---

<DiagramSequence>
  {
    steps.map((step, i) => (
      <DiagramStep>
        <div class="aps not-content" style={`--target:${step.target}`}>
          {/* Pointer track: the alias chip sits over its target column, with a
              dropped arrow connecting it down to that card. */}
          <div class="aps-pointer-row">
            <div class="aps-pointer">
              <span class="aps-pointer-eyebrow">production alias</span>
              <code class="aps-pointer-name">app.example.com</code>
              <span class="aps-pointer-arrow" aria-hidden="true" />
            </div>
          </div>

          {/* Card row: three fixed columns, newest -> oldest. */}
          <div class="aps-cards">
            {step.cards.map((card, ci) => (
              <div
                class={`aps-card aps-card--${card.state} ${ci === step.target ? "is-aliased" : ""}`}
              >
                {card.state === "ghost" ? null : (
                  <>
                    <div class="aps-card-head">
                      <code class="aps-card-hash">{card.hash}</code>
                      {card.badge && <span class="aps-card-badge">{card.badge}</span>}
                      {ci === step.target && <span class="aps-card-pin">production</span>}
                    </div>
                    <div class="aps-card-msg">{card.message}</div>
                    <code class="aps-card-url">{card.hash}-app.vercel.app</code>
                  </>
                )}
              </div>
            ))}
          </div>
        </div>
        <Fragment slot="caption" set:html={captions[i]} />
      </DiagramStep>
    ))
  }
</DiagramSequence>

<style>
  .aps {
    --cols: 3;
    /* width of one card column, shared by the pointer track and the card grid
       so the alias chip lines up dead-center over its target column */
    --gap: 16px;
    /* the alias accent — "what production points at" (sky-500, theme-stable) */
    --aps-accent: #0ea5e9;
    margin: 0;
    padding: 8px 4px 4px;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  }

  /* ---- Pointer track -------------------------------------------------- */

  .aps-pointer-row {
    display: grid;
    /* minmax(0,1fr) keeps every column EXACTLY equal width regardless of its
       content, so the chip's column center always lines up with its card's. */
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: var(--gap);
    margin-bottom: 10px;
  }

  .aps-pointer {
    /* place the chip over the target column (1-based grid lines) */
    grid-column: calc(var(--target) + 1);
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 8px 10px 18px;
    border-radius: 10px;
    border: 1.5px solid var(--aps-accent);
    background: color-mix(in srgb, var(--aps-accent) 12%, var(--sl-color-bg, transparent));
    transition: grid-column 0.2s;
  }

  .aps-pointer-eyebrow {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--aps-accent);
  }

  .aps-pointer-name {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.1;
    color: var(--sl-color-white, #1e293b);
    background: none;
    border: none;
    padding: 0;
  }

  /* The dropped connector: a vertical stem ending in a downward chevron,
     reaching from the chip into the gap above the card row. */
  .aps-pointer-arrow {
    position: absolute;
    left: 50%;
    bottom: -12px;
    width: 2px;
    height: 22px;
    background: var(--aps-accent);
    transform: translateX(-50%);
  }
  .aps-pointer-arrow::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -1px;
    width: 9px;
    height: 9px;
    border-right: 2px solid var(--aps-accent);
    border-bottom: 2px solid var(--aps-accent);
    transform: translate(-50%, 0) rotate(45deg);
  }

  /* ---- Card row ------------------------------------------------------- */

  .aps-cards {
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: var(--gap);
    align-items: start;
  }

  .aps-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-height: 92px;
    padding: 11px 12px;
    border-radius: 10px;
    border: 1px solid var(--sl-color-gray-5, #cbd5e1);
    background: var(--sl-color-bg, transparent);
    /* a subtle "frozen" feel — these never change once built */
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 30%, transparent);
    transition: opacity 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  /* ghost = a column that holds its space but has no deployment yet (step 1) */
  .aps-card--ghost {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 60%, transparent);
    background: transparent;
    box-shadow: none;
    opacity: 0.4;
  }

  /* new = freshly built, not yet aliased */
  .aps-card--new {
    border-color: color-mix(in srgb, var(--aps-accent) 45%, var(--sl-color-gray-5));
  }

  /* dim = older deployment, still live at its URL */
  .aps-card--dim {
    opacity: 0.55;
  }

  /* the column the alias currently points at gets the accent halo */
  .aps-card.is-aliased {
    border-color: var(--aps-accent);
    box-shadow:
      0 0 0 1px var(--aps-accent),
      0 4px 14px color-mix(in srgb, var(--aps-accent) 22%, transparent);
    opacity: 1;
  }

  .aps-card-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  .aps-card-hash {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--sl-color-white, #1e293b);
    background: none;
    border: none;
    padding: 0;
  }

  .aps-card-badge {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--aps-accent);
    background: color-mix(in srgb, var(--aps-accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--aps-accent) 35%, transparent);
    border-radius: 999px;
    padding: 1px 7px;
    white-space: nowrap;
  }

  .aps-card-pin {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: var(--aps-accent);
    border-radius: 999px;
    padding: 1px 8px;
    white-space: nowrap;
  }

  .aps-card-msg {
    font-size: 0.8rem;
    line-height: 1.25;
    color: var(--sl-color-white, #1e293b);
  }

  .aps-card-url {
    margin-top: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    line-height: 1.2;
    color: var(--sl-color-gray-3, #64748b);
    background: none;
    border: none;
    padding: 0;
    word-break: break-all;
  }

  /* Narrow viewports: keep three columns but tighten everything so the row
     still reads. The pointer chip continues to sit over its target column. */
  @media (max-width: 560px) {
    .aps {
      --gap: 8px;
    }
    .aps-card {
      min-height: 84px;
      padding: 9px 9px;
    }
    .aps-card-url {
      font-size: 0.6rem;
    }
    .aps-pointer {
      padding: 6px 6px 16px;
    }
    .aps-pointer-name {
      font-size: 0.68rem;
    }
  }
</style>
