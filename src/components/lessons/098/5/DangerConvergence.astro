---
// danger-convergence — Chapter 098 Lesson 5, "A Neon branch per preview",
// section "Previews are running against production right now".
//
// Anchor visual #1: the danger made literal. Four environments — three open-PR
// previews and production itself — all read and write the SAME production database.
// Every arrow converges on ONE cylinder, tinted red, so the shared-DB hazard is
// impossible to wave away before the fix lands. This figure is a deliberate BOOKEND:
// the lesson's closing figure (three-branch-fanout) is this exact shape inverted,
// fanned safely out to a branch per environment in green.
//
// LeaderLine-based ArrowDiagram because the topology is many-to-one CONVERGENCE with
// curved fan-out — exactly what CSS can't draw. The cylinder is split into two
// anchorable zones (a header strip + a body) so the four arrowheads land apart on it
// instead of stacking at one socket midpoint.
//
// Figure must be expandable={false}: LeaderLine positions from document.body and
// breaks when the figure DOM is relocated into the lightbox.
//
// margin: 0 on inner elements per the Starlight prose-margin gotcha.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const DANGER = '#dc2626'; // red-600 — every write lands in the customers' live rows
---

<Figure expandable={false}>
	<ArrowDiagram
		arrows={[
			// Two arrows aim at the cylinder header strip, two at its body, so the four
			// heads land apart. Gravity X-magnitudes are staggered (40 / 130 / 130 / 40)
			// to bow each curve into its own lane; Y-components pull the outer pair away
			// from the inner pair vertically.
			{ from: 'dc-p41',  to: 'dc-db-top',  color: DANGER, startSocket: 'right', endSocket: 'left', startSocketGravity: [40, 0],   endSocketGravity: [-130, -20] },
			{ from: 'dc-p42',  to: 'dc-db-top',  color: DANGER, startSocket: 'right', endSocket: 'left', startSocketGravity: [120, 0],  endSocketGravity: [-60, 0] },
			{ from: 'dc-p43',  to: 'dc-db-body', color: DANGER, startSocket: 'right', endSocket: 'left', startSocketGravity: [120, 0],  endSocketGravity: [-60, 0] },
			{ from: 'dc-prod', to: 'dc-db-body', color: DANGER, startSocket: 'right', endSocket: 'left', startSocketGravity: [40, 0],   endSocketGravity: [-130, 20] },
		]}
	>
		<div class="dc not-content">
			<!-- Left: the four environments that all point at production today. -->
			<div class="dc-col">
				<div class="dc-env dc-preview" id="dc-p41">
					<span class="dc-kind">Preview</span>
					<span class="dc-name">PR #41</span>
				</div>
				<div class="dc-env dc-preview" id="dc-p42">
					<span class="dc-kind">Preview</span>
					<span class="dc-name">PR #42</span>
				</div>
				<div class="dc-env dc-preview" id="dc-p43">
					<span class="dc-kind">Preview</span>
					<span class="dc-name">PR #43</span>
				</div>
				<div class="dc-env dc-prod" id="dc-prod">
					<span class="dc-kind">Production</span>
					<span class="dc-name">live customers</span>
				</div>
			</div>

			<!-- Right: the single production database. Split into a header strip and a
			     body so the four arrowheads can land on distinct sockets. -->
			<div class="dc-cyl-wrap">
				<div class="dc-cyl">
					<div class="dc-cyl-top" id="dc-db-top">Production database</div>
					<div class="dc-cyl-body" id="dc-db-body">
						<span class="dc-cyl-rows">your customers' rows</span>
					</div>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		One database, every environment. A test signup on a preview, a stray migration,
		a cleanup script — each writes to the same rows your customers live in. The
		previews even collide with each other.
	</Fragment>
</Figure>

<style>
	.dc {
		display: grid;
		grid-template-columns: auto 150px 1fr;
		align-items: center;
		column-gap: 0;
		margin: 0;
		padding: 16px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The middle grid column is empty gap reserved for the converging curves. */
	.dc-col {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
	}

	.dc-env {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1px;
		padding: 9px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		min-width: 150px;
		margin: 0;
	}

	.dc-prod {
		border-color: var(--sl-color-gray-4, #94a3b8);
		border-width: 2px;
	}

	.dc-kind {
		font-size: 0.85rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.dc-name {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Right column: center the cylinder vertically against the box stack. */
	.dc-cyl-wrap {
		display: flex;
		justify-content: center;
		align-items: center;
		margin: 0;
	}

	/* CSS cylinder: a rounded body with an elliptical header strip on top. */
	.dc-cyl {
		display: flex;
		flex-direction: column;
		width: 168px;
		margin: 0;
	}

	.dc-cyl-top {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		height: 40px;
		padding: 0 10px;
		border: 2px solid var(--danger-edge, #dc2626);
		border-radius: 84px / 22px;
		background: color-mix(in srgb, #dc2626 12%, var(--sl-color-bg, #fff));
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.dc-cyl-body {
		box-sizing: border-box;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		text-align: center;
		height: 58px;
		margin-top: -20px;
		padding: 0 10px 8px;
		border: 2px solid var(--danger-edge, #dc2626);
		border-top: none;
		border-radius: 0 0 84px 84px / 0 0 24px 24px;
		background: color-mix(in srgb, #dc2626 7%, var(--sl-color-bg, #fff));
		margin-left: 0;
		margin-right: 0;
	}

	.dc-cyl-rows {
		font-size: 0.66rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	@media (max-width: 640px) {
		.dc {
			grid-template-columns: auto 90px 1fr;
		}
		.dc-env {
			min-width: 130px;
		}
	}
</style>
