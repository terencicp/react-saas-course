---
// three-branch-fanout — Chapter 098 Lesson 5, "A Neon branch per preview",
// section "The three environments, three branches picture".
//
// Anchor visual #3: the fix drawn as the inverse of the opening danger figure.
// Where DangerConvergence had four environments converging on ONE red cylinder,
// this one fans each environment OUT to its OWN Neon branch, tinted green. Same
// shape, inverted outcome — a deliberate bookend.
//
// LeaderLine-based ArrowDiagram so the curves can bow into distinct lanes across
// the gap. Each arrow goes to a distinct target cylinder, so the heads land far
// apart with no socket-splitting needed. The three cylinders are grouped inside a
// single labeled "Neon project" container to show they're branches of one project.
//
// Reuses DangerConvergence's CSS cylinder geometry (elliptical header strip + body),
// retinted green/neutral. Figure must be expandable={false}: LeaderLine positions
// from document.body and breaks when the figure DOM is relocated into the lightbox.
//
// margin: 0 on inner elements per the Starlight prose-margin gotcha.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const SAFE = '#16a34a'; // green-600 — each environment writes to its own isolated branch
---

<Figure expandable={false}>
	<ArrowDiagram
		arrows={[
			// One arrow per environment to its own branch. Staggered gravity bows each
			// curve into its own lane so the three don't pile up in the gap.
			{ from: 'tb-dev',  to: 'tb-br-dev',  color: SAFE, startSocket: 'right', endSocket: 'left', startSocketGravity: [60, 0], endSocketGravity: [-60, 0] },
			{ from: 'tb-prev', to: 'tb-br-prev', color: SAFE, startSocket: 'right', endSocket: 'left', startSocketGravity: [60, 0], endSocketGravity: [-60, 0] },
			{ from: 'tb-prod', to: 'tb-br-prod', color: SAFE, startSocket: 'right', endSocket: 'left', startSocketGravity: [60, 0], endSocketGravity: [-60, 0] },
		]}
	>
		<div class="tb not-content">
			<!-- Left: the three environments, each pointing at its own branch. -->
			<div class="tb-col">
				<div class="tb-env" id="tb-dev">
					<span class="tb-kind">Development</span>
					<span class="tb-name">local</span>
				</div>
				<div class="tb-env" id="tb-prev">
					<span class="tb-kind">Preview</span>
					<span class="tb-name">per PR</span>
				</div>
				<div class="tb-env" id="tb-prod">
					<span class="tb-kind">Production</span>
					<span class="tb-name">live customers</span>
				</div>
			</div>

			<!-- Empty middle column: the gap the fanning curves live in. -->
			<div class="tb-gap" aria-hidden="true"></div>

			<!-- Right: one branch per environment, grouped inside the Neon project. -->
			<div class="tb-proj-wrap">
				<div class="tb-proj">
					<span class="tb-proj-label">Neon project</span>
					<div class="tb-cyls">
						<div class="tb-cyl" id="tb-br-dev">
							<div class="tb-cyl-top">dev branch</div>
							<div class="tb-cyl-body"><span class="tb-cyl-rows">your data</span></div>
						</div>
						<div class="tb-cyl" id="tb-br-prev">
							<div class="tb-cyl-top">preview/&lt;branch&gt;</div>
							<div class="tb-cyl-body"><span class="tb-cyl-rows">a per-PR copy</span></div>
						</div>
						<div class="tb-cyl" id="tb-br-prod">
							<div class="tb-cyl-top">main branch</div>
							<div class="tb-cyl-body"><span class="tb-cyl-rows">customers' rows</span></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		The same shape as the opening figure, inverted. Each environment now writes to
		its own Neon branch — same schema, isolated data. The convergence that was the
		danger is now a clean fan-out.
	</Fragment>
</Figure>

<style>
	.tb {
		display: grid;
		grid-template-columns: max-content 120px max-content;
		justify-content: center;
		align-items: center;
		column-gap: 0;
		margin: 0;
		padding: 16px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* Empty spacer column that reserves horizontal room for the curves. */
	.tb-gap {
		margin: 0;
	}

	/* The middle grid column is empty gap reserved for the fanning curves. */
	.tb-col {
		display: flex;
		flex-direction: column;
		gap: 38px;
		margin: 0;
	}

	.tb-env {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1px;
		padding: 9px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		min-width: 150px;
		margin: 0;
	}

	.tb-kind {
		font-size: 0.85rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.tb-name {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Right column: center the Neon-project container against the box stack. */
	.tb-proj-wrap {
		display: flex;
		justify-content: center;
		align-items: center;
		margin: 0;
	}

	/* The single container that visually groups the three branch cylinders. */
	.tb-proj {
		position: relative;
		box-sizing: border-box;
		padding: 22px 16px 14px;
		border: 1px dashed color-mix(in srgb, #16a34a 45%, var(--sl-color-gray-4, #94a3b8));
		border-radius: 14px;
		background: color-mix(in srgb, #16a34a 4%, var(--sl-color-bg, transparent));
		margin: 0;
	}

	.tb-proj-label {
		position: absolute;
		top: -10px;
		left: 14px;
		padding: 0 8px;
		background: var(--sl-color-bg, #fff);
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: color-mix(in srgb, #16a34a 75%, var(--sl-color-white, #1e293b));
		margin: 0;
	}

	.tb-cyls {
		display: flex;
		flex-direction: column;
		gap: 18px;
		margin: 0;
	}

	/* CSS cylinder: a rounded body with an elliptical header strip on top —
	   the same geometry as DangerConvergence, retinted green. */
	.tb-cyl {
		display: flex;
		flex-direction: column;
		width: 168px;
		margin: 0;
	}

	.tb-cyl-top {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		height: 34px;
		padding: 0 10px;
		border: 2px solid var(--safe-edge, #16a34a);
		border-radius: 84px / 19px;
		background: color-mix(in srgb, #16a34a 12%, var(--sl-color-bg, #fff));
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.tb-cyl-body {
		box-sizing: border-box;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		text-align: center;
		height: 46px;
		margin-top: -16px;
		padding: 0 10px 7px;
		border: 2px solid var(--safe-edge, #16a34a);
		border-top: none;
		border-radius: 0 0 84px 84px / 0 0 20px 20px;
		background: color-mix(in srgb, #16a34a 7%, var(--sl-color-bg, #fff));
		margin-left: 0;
		margin-right: 0;
	}

	.tb-cyl-rows {
		font-size: 0.64rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	@media (max-width: 640px) {
		.tb {
			grid-template-columns: auto 70px 1fr;
		}
		.tb-env {
			min-width: 130px;
		}
	}
</style>
