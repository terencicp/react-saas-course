---
// pr-checks-and-preview — Chapter 098 Lesson 2, "From repo to live URL".
//
// A faithful HTML/CSS mock of a GitHub pull request after a push to a feature
// branch. The real page is an authenticated external screen that can't be
// captured, so this is a hand-built component, not a Screenshot of a real page.
//
// The teaching point is the "deploy and the gate, side by side" beat: after a
// push, the Vercel bot posts a preview deployment, and the merge box shows two
// kinds of checks lined up together — Vercel's own build check plus the CI gate
// (typecheck, lint, test) from the previous chapter — all of which must be green
// before the branch can merge. So the figure renders, top to bottom:
//   1. The Vercel bot comment with its deployment table: a "Visit Preview" link
//      to a per-branch *.vercel.app URL, a "Ready" status, and an updated time.
//   2. The merge box: the four passing checks under a green "All checks have
//      passed" summary and a (disabled-look) "Merge pull request" button.
//
// Pure HTML + CSS per the diagrams guide; chrome uses Starlight theme variables
// so it flips light/dark. GitHub's success green is a saturated mid-tone with
// white glyphs that reads in both themes; the merge CTA uses the same green.
// `not-content` + margin resets defeat Starlight's prose-margin selector.

import Figure from '../../../../figures/Figure.astro';

const GH_GREEN = '#1f883d'; // GitHub success / merge-button green
const GH_GREEN_HI = '#1a7f37';
const LINK = '#4493f8'; // GitHub link blue (dark-mode tuned, reads on both)
const VERCEL_BG = '#000';
---

<Figure caption="A pull request after a push: the Vercel bot's preview link at the top, and the row of status checks — Vercel's build plus the CI gate — that must all be green to merge.">
	<div
		class="pcp not-content"
		role="img"
		aria-label="A GitHub pull request. A comment from the Vercel bot shows a Visit Preview link to a per-branch vercel.app URL marked Ready. Below, the merge box lists four passing checks — the Vercel deployment plus typecheck, lint, and test from CI — under an 'All checks have passed' summary."
	>
		<div class="pcp-thread">
			{/* ---- Vercel bot comment ---- */}
			<div class="pcp-comment">
				<span class="pcp-avatar pcp-avatar-vercel" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="18" height="18">
						<polygon points="12,5 20,19 4,19" fill="#fff"></polygon>
					</svg>
				</span>
				<div class="pcp-bubble">
					<div class="pcp-bubble-head">
						<span class="pcp-author">vercel</span>
						<span class="pcp-bot-tag">bot</span>
						<span class="pcp-meta">commented just now</span>
					</div>
					<div class="pcp-bubble-body">
						<p class="pcp-bot-intro">
							The latest updates on your project. Learn more about
							<span class="pcp-link">Vercel for Git&nbsp;&#8599;</span>
						</p>
						<div class="pcp-table">
							<div class="pcp-table-head">
								<span class="pcp-th pcp-th-name">Name</span>
								<span class="pcp-th pcp-th-status">Status</span>
								<span class="pcp-th pcp-th-preview">Preview</span>
								<span class="pcp-th pcp-th-updated">Updated</span>
							</div>
							<div class="pcp-table-row">
								<span class="pcp-td pcp-td-name">acme-app</span>
								<span class="pcp-td pcp-td-status">
									<span class="pcp-status-dot" aria-hidden="true"></span>
									Ready
								</span>
								<span class="pcp-td pcp-td-preview">
									<span class="pcp-link">Visit Preview</span>
								</span>
								<span class="pcp-td pcp-td-updated">just now</span>
							</div>
						</div>
						<p class="pcp-url-line">
							<span class="pcp-mono pcp-url"
								>your-app-git-feat-pricing-acme.vercel.app</span
							>
						</p>
					</div>
				</div>
			</div>

			{/* ---- Merge box ---- */}
			<div class="pcp-mergebox">
				{/* All checks passed summary */}
				<div class="pcp-summary">
					<span class="pcp-check-ring pcp-check-ring-lg" aria-hidden="true">
						<svg viewBox="0 0 16 16" width="13" height="13">
							<path
								fill="#fff"
								d="M13.78 4.22a.75.75 0 0 1 0 1.06l-6.5 6.5a.75.75 0 0 1-1.06 0l-3.25-3.25a.75.75 0 1 1 1.06-1.06L6.75 10.19l5.97-5.97a.75.75 0 0 1 1.06 0Z"
							></path>
						</svg>
					</span>
					<div class="pcp-summary-text">
						<span class="pcp-summary-title">All checks have passed</span>
						<span class="pcp-summary-sub">4 successful checks</span>
					</div>
				</div>

				<div class="pcp-checks">
					{/* Vercel build check */}
					<div class="pcp-check-row">
						<span class="pcp-check-ring" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="10" height="10">
								<path
									fill="#fff"
									d="M13.78 4.22a.75.75 0 0 1 0 1.06l-6.5 6.5a.75.75 0 0 1-1.06 0l-3.25-3.25a.75.75 0 1 1 1.06-1.06L6.75 10.19l5.97-5.97a.75.75 0 0 1 1.06 0Z"
								></path>
							</svg>
						</span>
						<span class="pcp-check-icon pcp-check-icon-vercel" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="13" height="13">
								<polygon points="12,5 20,19 4,19" fill="#fff"></polygon>
							</svg>
						</span>
						<span class="pcp-check-name">Vercel</span>
						<span class="pcp-check-desc">&mdash; Deployment has completed</span>
						<span class="pcp-check-detail">Details</span>
					</div>

					{/* CI / typecheck */}
					<div class="pcp-check-row">
						<span class="pcp-check-ring" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="10" height="10">
								<path
									fill="#fff"
									d="M13.78 4.22a.75.75 0 0 1 0 1.06l-6.5 6.5a.75.75 0 0 1-1.06 0l-3.25-3.25a.75.75 0 1 1 1.06-1.06L6.75 10.19l5.97-5.97a.75.75 0 0 1 1.06 0Z"
								></path>
							</svg>
						</span>
						<span class="pcp-check-icon pcp-check-icon-ci" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="12" height="12">
								<path
									fill="currentColor"
									d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0ZM1.5 8a6.5 6.5 0 1 1 13 0 6.5 6.5 0 0 1-13 0Zm6.5-4a.75.75 0 0 1 .75.75v3.19l2.03 2.03a.75.75 0 1 1-1.06 1.06L7.47 9.78A.75.75 0 0 1 7.25 9.25V4.75A.75.75 0 0 1 8 4Z"
								></path>
							</svg>
						</span>
						<span class="pcp-check-name pcp-mono">CI / typecheck</span>
						<span class="pcp-check-desc">&mdash; Successful in 38s</span>
						<span class="pcp-check-detail">Details</span>
					</div>

					{/* CI / lint */}
					<div class="pcp-check-row">
						<span class="pcp-check-ring" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="10" height="10">
								<path
									fill="#fff"
									d="M13.78 4.22a.75.75 0 0 1 0 1.06l-6.5 6.5a.75.75 0 0 1-1.06 0l-3.25-3.25a.75.75 0 1 1 1.06-1.06L6.75 10.19l5.97-5.97a.75.75 0 0 1 1.06 0Z"
								></path>
							</svg>
						</span>
						<span class="pcp-check-icon pcp-check-icon-ci" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="12" height="12">
								<path
									fill="currentColor"
									d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0ZM1.5 8a6.5 6.5 0 1 1 13 0 6.5 6.5 0 0 1-13 0Zm6.5-4a.75.75 0 0 1 .75.75v3.19l2.03 2.03a.75.75 0 1 1-1.06 1.06L7.47 9.78A.75.75 0 0 1 7.25 9.25V4.75A.75.75 0 0 1 8 4Z"
								></path>
							</svg>
						</span>
						<span class="pcp-check-name pcp-mono">CI / lint</span>
						<span class="pcp-check-desc">&mdash; Successful in 22s</span>
						<span class="pcp-check-detail">Details</span>
					</div>

					{/* CI / test */}
					<div class="pcp-check-row">
						<span class="pcp-check-ring" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="10" height="10">
								<path
									fill="#fff"
									d="M13.78 4.22a.75.75 0 0 1 0 1.06l-6.5 6.5a.75.75 0 0 1-1.06 0l-3.25-3.25a.75.75 0 1 1 1.06-1.06L6.75 10.19l5.97-5.97a.75.75 0 0 1 1.06 0Z"
								></path>
							</svg>
						</span>
						<span class="pcp-check-icon pcp-check-icon-ci" aria-hidden="true">
							<svg viewBox="0 0 16 16" width="12" height="12">
								<path
									fill="currentColor"
									d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0ZM1.5 8a6.5 6.5 0 1 1 13 0 6.5 6.5 0 0 1-13 0Zm6.5-4a.75.75 0 0 1 .75.75v3.19l2.03 2.03a.75.75 0 1 1-1.06 1.06L7.47 9.78A.75.75 0 0 1 7.25 9.25V4.75A.75.75 0 0 1 8 4Z"
								></path>
							</svg>
						</span>
						<span class="pcp-check-name pcp-mono">CI / test</span>
						<span class="pcp-check-desc">&mdash; Successful in 1m 4s</span>
						<span class="pcp-check-detail">Details</span>
					</div>
				</div>

				{/* Merge CTA */}
				<div class="pcp-merge-cta">
					<span class="pcp-merge-btn">Merge pull request</span>
					<span class="pcp-merge-note">
						This branch has no conflicts with the base branch.
					</span>
				</div>
			</div>
		</div>
	</div>
</Figure>

<style
	define:vars={{
		'pcp-green': GH_GREEN,
		'pcp-green-hi': GH_GREEN_HI,
		'pcp-link': LINK,
		'pcp-vercel-bg': VERCEL_BG,
	}}
>
	.pcp {
		margin: 0;
		display: flex;
		justify-content: center;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	.pcp-thread {
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		max-width: 620px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* ---- Vercel bot comment ---- */
	.pcp-comment {
		margin: 0;
		display: flex;
		gap: 12px;
		align-items: flex-start;
	}
	.pcp-avatar {
		margin: 1px 0 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 50%;
	}
	.pcp-avatar-vercel {
		background: var(--pcp-vercel-bg);
	}

	.pcp-bubble {
		margin: 0;
		flex: 1;
		min-width: 0;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 10px;
		background: var(--sl-color-bg);
		overflow: hidden;
	}
	.pcp-bubble-head {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 9px 14px;
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.pcp-author {
		margin: 0;
		font-size: 13.5px;
		font-weight: 700;
		color: var(--sl-color-white);
	}
	.pcp-bot-tag {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 0 6px;
		height: 17px;
		border-radius: 999px;
		font-size: 10.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2);
		background: color-mix(in srgb, var(--sl-color-gray-3) 16%, transparent);
		border: 1px solid var(--sl-color-gray-5);
	}
	.pcp-meta {
		margin: 0;
		font-size: 12px;
		color: var(--sl-color-gray-3);
	}

	.pcp-bubble-body {
		margin: 0;
		padding: 13px 14px 15px;
	}
	.pcp-bot-intro {
		margin: 0 0 12px;
		font-size: 12.5px;
		line-height: 1.5;
		color: var(--sl-color-gray-2);
	}

	.pcp-link {
		color: var(--pcp-link);
		font-weight: 600;
	}

	/* ---- The deployment table ---- */
	.pcp-table {
		margin: 0;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 8px;
		overflow: hidden;
	}
	.pcp-table-head,
	.pcp-table-row {
		margin: 0;
		display: grid;
		grid-template-columns: 1.1fr 0.9fr 1.2fr 0.9fr;
		align-items: center;
		gap: 8px;
		padding: 9px 13px;
	}
	.pcp-table-head {
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.pcp-th {
		margin: 0;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}
	.pcp-td {
		margin: 0;
		font-size: 12.5px;
		color: var(--sl-color-white);
		min-width: 0;
	}
	.pcp-td-name {
		font-weight: 600;
	}
	.pcp-td-status {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		color: var(--pcp-green);
		font-weight: 600;
	}
	.pcp-status-dot {
		margin: 0;
		flex: none;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--pcp-green);
	}
	.pcp-td-updated {
		color: var(--sl-color-gray-3);
		font-size: 12px;
	}

	.pcp-url-line {
		margin: 9px 0 0;
		font-size: 12px;
		color: var(--sl-color-gray-3);
	}
	.pcp-mono {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}
	.pcp-url {
		color: var(--pcp-link);
		word-break: break-all;
	}

	/* ---- Merge box ---- */
	.pcp-mergebox {
		margin: 0;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 10px;
		background: var(--sl-color-bg);
		overflow: hidden;
	}

	/* Green "all checks passed" summary header */
	.pcp-summary {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 13px 16px;
		background: color-mix(in srgb, var(--pcp-green) 12%, transparent);
		border-bottom: 1px solid color-mix(in srgb, var(--pcp-green) 35%, transparent);
	}
	.pcp-check-ring {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 17px;
		height: 17px;
		border-radius: 50%;
		background: var(--pcp-green);
	}
	.pcp-check-ring-lg {
		width: 22px;
		height: 22px;
	}
	.pcp-summary-text {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.pcp-summary-title {
		margin: 0;
		font-size: 14px;
		font-weight: 700;
		color: var(--sl-color-white);
	}
	.pcp-summary-sub {
		margin: 0;
		font-size: 12px;
		color: var(--sl-color-gray-2);
	}

	/* The check rows */
	.pcp-checks {
		margin: 0;
	}
	.pcp-check-row {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 10px 16px;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.pcp-check-icon {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		border-radius: 4px;
	}
	.pcp-check-icon-vercel {
		background: var(--pcp-vercel-bg);
	}
	.pcp-check-icon-ci {
		color: var(--sl-color-gray-2);
	}
	.pcp-check-name {
		margin: 0;
		flex: none;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.pcp-check-name.pcp-mono {
		font-size: 12.5px;
	}
	.pcp-check-desc {
		margin: 0;
		flex: 1;
		min-width: 0;
		font-size: 12.5px;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.pcp-check-detail {
		margin: 0;
		flex: none;
		font-size: 12.5px;
		font-weight: 600;
		color: var(--pcp-link);
	}

	/* Merge CTA */
	.pcp-merge-cta {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 13px;
		padding: 14px 16px 16px;
		flex-wrap: wrap;
	}
	.pcp-merge-btn {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		padding: 8px 16px;
		border-radius: 7px;
		background: var(--pcp-green);
		border: 1px solid var(--pcp-green-hi);
		font-size: 13.5px;
		font-weight: 600;
		color: #fff;
	}
	.pcp-merge-note {
		margin: 0;
		font-size: 12.5px;
		color: var(--sl-color-gray-3);
	}

	@media (max-width: 560px) {
		.pcp-table-head,
		.pcp-table-row {
			grid-template-columns: 1fr 0.9fr;
			row-gap: 6px;
		}
		.pcp-th-preview,
		.pcp-th-updated,
		.pcp-td-preview,
		.pcp-td-updated {
			grid-column: span 1;
		}
		.pcp-check-desc {
			display: none;
		}
	}
</style>
