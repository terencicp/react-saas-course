---
// github-app-scope-screen — Chapter 098 Lesson 2, "From repo to live URL".
//
// A faithful HTML/CSS mock of GitHub's "Install Vercel" permissions screen.
// (The real page is an authenticated external screen that can't be captured, so
// this is a hand-built component, not a Screenshot of a real page.)
//
// The single teaching point is the selected radio: "Only select repositories"
// is the narrow-scope, reversible choice the prose calls "the one click in this
// flow with asymmetric cost". So that option is rendered SELECTED and visually
// emphasized (filled radio, blue accent ring, the repo picker open beneath it),
// while "All repositories" sits unselected and muted above it.
//
// Built as a small "window" card: a title bar with the GitHub-style Vercel app
// avatar + "Install Vercel" heading, a short "where to install" note, the two
// radio options, the single-repo picker under the selected one, and the green
// "Install" button on the footer. Pure HTML + CSS per the diagrams guide; chrome
// uses Starlight theme variables so it flips light/dark, and the GitHub green CTA
// is a saturated mid-tone with white text that reads in both themes.
// `not-content` + margin resets defeat Starlight's prose-margin selector.

import Figure from '../../../../figures/Figure.astro';

const ACCENT = '#3b82f6'; // selected-option accent
const GH_GREEN = '#1f883d'; // GitHub's primary "Install" button green
const GH_GREEN_HI = '#1a7f37';
---

<Figure caption="The GitHub App install screen. Choosing 'Only select repositories' is the one click in this flow with asymmetric cost.">
	<div
		class="gas not-content"
		role="img"
		aria-label="GitHub's Vercel App installation screen showing two scope options, 'All repositories' and 'Only select repositories'. The 'Only select repositories' option is selected, with a single repository, acme/acme-app, chosen in the picker below it. An Install button sits at the bottom."
	>
		<div class="gas-window">
			{/* ---- Title row: Vercel app avatar + heading ---- */}
			<div class="gas-titlebar">
				<span class="gas-avatar" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="20" height="20">
						<polygon points="12,5 20,19 4,19" fill="#fff" />
					</svg>
				</span>
				<div class="gas-title-text">
					<span class="gas-title">Install Vercel</span>
					<span class="gas-subtitle">for your personal account acme</span>
				</div>
			</div>

			<div class="gas-divider"></div>

			{/* ---- Section label ---- */}
			<div class="gas-section-label">
				Install on <strong>@acme</strong>
			</div>
			<p class="gas-hint">
				This will install the GitHub App and give it access to the
				repositories you choose.
			</p>

			{/* ---- Option 1: All repositories (unselected) ---- */}
			<label class="gas-option">
				<span class="gas-radio" aria-hidden="true"></span>
				<span class="gas-option-body">
					<span class="gas-option-title">All repositories</span>
					<span class="gas-option-desc">
						This applies to all current <em>and future</em> repositories
						owned by the resource owner.
					</span>
				</span>
			</label>

			{/* ---- Option 2: Only select repositories (SELECTED) ---- */}
			<label class="gas-option is-selected">
				<span class="gas-radio is-on" aria-hidden="true">
					<span class="gas-radio-dot"></span>
				</span>
				<span class="gas-option-body">
					<span class="gas-option-title">Only select repositories</span>
					<span class="gas-option-desc">
						Select at least one repository. <em>Future</em> repositories
						won&rsquo;t be accessible unless you add them.
					</span>

					{/* ---- The repo picker, open, with one repo chosen ---- */}
					<span class="gas-picker">
						<span class="gas-picker-row">
							<span class="gas-repo">
								<span class="gas-repo-icon" aria-hidden="true">
									<svg viewBox="0 0 16 16" width="14" height="14">
										<path
											fill="currentColor"
											d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"
										></path>
									</svg>
								</span>
								<span class="gas-repo-name">acme/acme-app</span>
							</span>
							<span class="gas-repo-x" aria-hidden="true">&times;</span>
						</span>
					</span>
				</span>
			</label>

			{/* ---- Footer: green Install button ---- */}
			<div class="gas-footer">
				<span class="gas-install-btn">Install</span>
			</div>
		</div>
	</div>
</Figure>

<style define:vars={{ 'gas-accent': ACCENT, 'gas-green': GH_GREEN, 'gas-green-hi': GH_GREEN_HI }}>
	.gas {
		margin: 0;
		display: flex;
		justify-content: center;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- The window card ---- */
	.gas-window {
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		max-width: 480px;
		padding: 18px 20px 0;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 12px;
		background: var(--sl-color-bg-sidebar);
	}

	/* ---- Title bar ---- */
	.gas-titlebar {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.gas-avatar {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 8px;
		background: #000;
	}

	.gas-title-text {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1px;
	}

	.gas-title {
		margin: 0;
		font-size: 17px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}

	.gas-subtitle {
		margin: 0;
		font-size: 12px;
		line-height: 1.2;
		color: var(--sl-color-gray-3);
	}

	.gas-divider {
		margin: 14px 0 0;
		height: 1px;
		background: var(--sl-color-gray-5);
	}

	/* ---- Section label + hint ---- */
	.gas-section-label {
		margin: 14px 0 0;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}
	.gas-section-label strong {
		color: var(--sl-color-white);
	}

	.gas-hint {
		margin: 4px 0 0;
		font-size: 12px;
		line-height: 1.45;
		color: var(--sl-color-gray-3);
	}

	/* ---- Radio options ---- */
	.gas-option {
		margin: 12px 0 0;
		display: flex;
		gap: 11px;
		align-items: flex-start;
		padding: 12px 13px;
		border: 1.5px solid var(--sl-color-gray-5);
		border-radius: 9px;
		background: transparent;
	}

	/* The selected option carries the teaching emphasis. */
	.gas-option.is-selected {
		border-color: var(--gas-accent);
		background: color-mix(in srgb, var(--gas-accent) 9%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--gas-accent) 14%, transparent);
	}

	.gas-radio {
		margin: 1px 0 0;
		flex: none;
		box-sizing: border-box;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		border: 2px solid var(--sl-color-gray-4);
		background: transparent;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}
	.gas-radio.is-on {
		border-color: var(--gas-accent);
	}
	.gas-radio-dot {
		margin: 0;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--gas-accent);
	}

	.gas-option-body {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.gas-option-title {
		margin: 0;
		font-size: 14px;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-white);
	}

	.gas-option-desc {
		margin: 0;
		font-size: 12px;
		line-height: 1.45;
		color: var(--sl-color-gray-3);
	}

	/* ---- The open repo picker ---- */
	.gas-picker {
		margin: 10px 0 0;
		display: block;
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 7px;
		background: var(--sl-color-bg);
		overflow: hidden;
	}

	.gas-picker-row {
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		padding: 8px 11px;
	}

	.gas-repo {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		min-width: 0;
	}

	.gas-repo-icon {
		margin: 0;
		flex: none;
		display: inline-flex;
		color: var(--sl-color-gray-3);
	}

	.gas-repo-name {
		margin: 0;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-white);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.gas-repo-x {
		margin: 0;
		flex: none;
		font-size: 15px;
		line-height: 1;
		color: var(--sl-color-gray-3);
	}

	/* ---- Footer with the green Install button ---- */
	.gas-footer {
		margin: 16px 0 0;
		padding: 14px 0 18px;
		border-top: 1px solid var(--sl-color-gray-5);
		display: flex;
		justify-content: flex-end;
	}

	.gas-install-btn {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 7px 18px;
		border-radius: 7px;
		background: var(--gas-green);
		border: 1px solid var(--gas-green-hi);
		font-size: 14px;
		font-weight: 600;
		color: #fff;
	}

	@media (max-width: 460px) {
		.gas-window {
			padding: 16px 14px 0;
		}
	}
</style>
