---
// configure-project-screen — Chapter 098 Lesson 2, "From repo to live URL".
//
// A faithful HTML/CSS mock of Vercel's "Configure Project" screen, shown after
// importing a repo. The real page is an authenticated external screen that can't
// be captured, so this is a hand-built component, not a Screenshot of a real page.
//
// The teaching point is the lesson's spine: "accept four defaults, slow down on
// two." So the four auto-detected fields (Framework Preset, Build Command, Output
// Directory, Install Command) carry a quiet "Auto-detected" chip, while the two
// look-twice fields (Project Name, Root Directory) get an understated amber accent
// on their label so the eye lands on the pair that costs you later if wrong.
// Environment Variables is rendered deliberately empty (the "skip on first deploy"
// step), and the green Deploy button sits at the footer.
//
// Pure HTML + CSS per the diagrams guide; chrome uses Starlight theme variables so
// it flips light/dark, and the Vercel-black Deploy button uses white text that
// reads in both themes. `not-content` + margin resets defeat Starlight's
// prose-margin selector.

import Figure from '../../../../figures/Figure.astro';

const ACCENT = '#d97706'; // amber accent for the "look twice" pair
const DEPLOY_BG = '#171717'; // Vercel's near-black primary button
const DEPLOY_BORDER = '#3f3f46';
---

<Figure caption="Vercel's Configure Project screen. Four fields are auto-detected and correct; Project name and Root Directory are the two that cost you later if they're wrong; Environment Variables is left empty on purpose.">
	<div
		class="cps not-content"
		role="img"
		aria-label="Vercel's Configure Project screen. Project Name is set to acme-app, Framework Preset to Next.js, Root Directory to ./, and the Build and Output Settings show next build, .next, and pnpm install. The Environment Variables section is empty. A Deploy button is at the bottom."
	>
		<div class="cps-window">
			{/* ---- Header ---- */}
			<div class="cps-header">
				<span class="cps-mark" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="22" height="22">
						<polygon points="12,4 22,20 2,20" fill="#fff" />
					</svg>
				</span>
				<span class="cps-heading">Configure Project</span>
			</div>

			<div class="cps-divider"></div>

			{/* ---- Project Name (look twice) ---- */}
			<div class="cps-field">
				<div class="cps-label-row">
					<span class="cps-label cps-label-watch">Project Name</span>
					<span class="cps-tag cps-tag-watch">Look twice</span>
				</div>
				<div class="cps-input">
					<span class="cps-input-value">acme-app</span>
				</div>
				<span class="cps-hint">
					Becomes your deployment subdomain:
					<span class="cps-mono">acme-app.vercel.app</span>
				</span>
			</div>

			{/* ---- Framework Preset (auto) ---- */}
			<div class="cps-field">
				<div class="cps-label-row">
					<span class="cps-label">Framework Preset</span>
					<span class="cps-tag">Auto-detected</span>
				</div>
				<div class="cps-select">
					<span class="cps-select-icon" aria-hidden="true">
						<svg viewBox="0 0 180 180" width="15" height="15">
							<mask id="cps-next-mask" maskUnits="userSpaceOnUse" x="0" y="0" width="180" height="180">
								<circle cx="90" cy="90" r="90" fill="#fff"></circle>
							</mask>
							<g mask="url(#cps-next-mask)">
								<circle cx="90" cy="90" r="90" fill="currentColor"></circle>
								<path d="M149.5 157.6 69.1 54H54v71.9h12.1V69.4l73.9 95.8a90.4 90.4 0 0 0 9.5-7.6Z" fill="var(--sl-color-bg)"></path>
								<rect x="115" y="54" width="12" height="72" fill="var(--sl-color-bg)"></rect>
							</g>
						</svg>
					</span>
					<span class="cps-select-value">Next.js</span>
					<span class="cps-chevron" aria-hidden="true">
						<svg viewBox="0 0 16 16" width="13" height="13">
							<path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"></path>
						</svg>
					</span>
				</div>
			</div>

			{/* ---- Root Directory (look twice) ---- */}
			<div class="cps-field">
				<div class="cps-label-row">
					<span class="cps-label cps-label-watch">Root Directory</span>
					<span class="cps-tag cps-tag-watch">Look twice</span>
				</div>
				<div class="cps-input cps-input-with-btn">
					<span class="cps-input-value cps-mono">./</span>
					<span class="cps-edit-btn">Edit</span>
				</div>
			</div>

			{/* ---- Build and Output Settings (expandable, open) ---- */}
			<div class="cps-group">
				<div class="cps-group-head">
					<span class="cps-chevron cps-chevron-open" aria-hidden="true">
						<svg viewBox="0 0 16 16" width="13" height="13">
							<path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"></path>
						</svg>
					</span>
					<span class="cps-group-title">Build and Output Settings</span>
					<span class="cps-tag">Auto-detected</span>
				</div>

				<div class="cps-group-body">
					<div class="cps-sub">
						<span class="cps-sub-label">Build Command</span>
						<div class="cps-input cps-input-sm">
							<span class="cps-input-value cps-mono">next build</span>
						</div>
					</div>
					<div class="cps-sub">
						<span class="cps-sub-label">Output Directory</span>
						<div class="cps-input cps-input-sm">
							<span class="cps-input-value cps-mono">.next</span>
						</div>
					</div>
					<div class="cps-sub">
						<span class="cps-sub-label">Install Command</span>
						<div class="cps-input cps-input-sm">
							<span class="cps-input-value cps-mono">pnpm install</span>
						</div>
					</div>
				</div>
			</div>

			{/* ---- Environment Variables (deliberately empty) ---- */}
			<div class="cps-group">
				<div class="cps-group-head">
					<span class="cps-chevron cps-chevron-open" aria-hidden="true">
						<svg viewBox="0 0 16 16" width="13" height="13">
							<path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M4 6l4 4 4-4"></path>
						</svg>
					</span>
					<span class="cps-group-title">Environment Variables</span>
					<span class="cps-tag cps-tag-empty">Empty &mdash; on purpose</span>
				</div>

				<div class="cps-group-body">
					<div class="cps-env-empty">
						<div class="cps-env-row">
							<span class="cps-env-input">Add a variable&hellip;</span>
							<span class="cps-env-input">value</span>
							<span class="cps-env-add">Add</span>
						</div>
						<span class="cps-hint">No variables added for this deploy.</span>
					</div>
				</div>
			</div>

			{/* ---- Footer: Deploy button ---- */}
			<div class="cps-footer">
				<span class="cps-deploy-btn">Deploy</span>
			</div>
		</div>
	</div>
</Figure>

<style define:vars={{ 'cps-accent': ACCENT, 'cps-deploy-bg': DEPLOY_BG, 'cps-deploy-border': DEPLOY_BORDER }}>
	.cps {
		margin: 0;
		display: flex;
		justify-content: center;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- The window card ---- */
	.cps-window {
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		max-width: 520px;
		padding: 18px 20px 0;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 12px;
		background: var(--sl-color-bg-sidebar);
	}

	/* ---- Header ---- */
	.cps-header {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 11px;
	}
	.cps-mark {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 8px;
		background: #000;
	}
	.cps-heading {
		margin: 0;
		font-size: 17px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.cps-divider {
		margin: 13px 0 0;
		height: 1px;
		background: var(--sl-color-gray-5);
	}

	/* ---- Fields ---- */
	.cps-field {
		margin: 13px 0 0;
		display: flex;
		flex-direction: column;
		gap: 5px;
	}
	.cps-label-row {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 9px;
	}
	.cps-label {
		margin: 0;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-white);
	}
	/* The look-twice pair gets a quiet amber accent on its label. */
	.cps-label-watch {
		color: var(--cps-accent);
	}

	/* ---- Tags ---- */
	.cps-tag {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 1px 7px;
		border-radius: 999px;
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-2);
		background: color-mix(in srgb, var(--sl-color-gray-3) 16%, transparent);
		border: 1px solid var(--sl-color-gray-5);
	}
	.cps-tag-watch {
		color: var(--cps-accent);
		background: color-mix(in srgb, var(--cps-accent) 13%, transparent);
		border-color: color-mix(in srgb, var(--cps-accent) 40%, transparent);
	}
	.cps-tag-empty {
		color: var(--sl-color-gray-2);
	}

	/* ---- Inputs ---- */
	.cps-input {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		min-height: 36px;
		padding: 0 12px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 8px;
		background: var(--sl-color-bg);
	}
	.cps-input-sm {
		min-height: 32px;
	}
	.cps-input-value {
		margin: 0;
		font-size: 13.5px;
		color: var(--sl-color-white);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.cps-mono {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 13px;
	}
	.cps-edit-btn {
		margin: 0;
		flex: none;
		padding: 3px 11px;
		border-radius: 6px;
		font-size: 12px;
		font-weight: 600;
		color: var(--sl-color-gray-2);
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg-sidebar);
	}
	.cps-hint {
		margin: 0;
		font-size: 11.5px;
		line-height: 1.4;
		color: var(--sl-color-gray-3);
	}
	.cps-hint .cps-mono {
		color: var(--sl-color-gray-2);
	}

	/* ---- Select ---- */
	.cps-select {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 9px;
		min-height: 36px;
		padding: 0 12px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 8px;
		background: var(--sl-color-bg);
	}
	.cps-select-icon {
		margin: 0;
		flex: none;
		display: inline-flex;
		color: var(--sl-color-white);
	}
	.cps-select-value {
		margin: 0;
		flex: 1;
		font-size: 13.5px;
		color: var(--sl-color-white);
	}
	.cps-chevron {
		margin: 0;
		flex: none;
		display: inline-flex;
		color: var(--sl-color-gray-3);
	}

	/* ---- Expandable groups ---- */
	.cps-group {
		margin: 13px 0 0;
		border: 1.5px solid var(--sl-color-gray-5);
		border-radius: 9px;
		background: color-mix(in srgb, var(--sl-color-gray-6, var(--sl-color-gray-5)) 30%, transparent);
		overflow: hidden;
	}
	.cps-group-head {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 10px 13px;
	}
	.cps-chevron-open {
		color: var(--sl-color-gray-2);
	}
	.cps-group-title {
		margin: 0;
		flex: 1;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.cps-group-body {
		margin: 0;
		padding: 0 13px 12px;
		display: flex;
		flex-direction: column;
		gap: 9px;
	}

	.cps-sub {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.cps-sub-label {
		margin: 0;
		font-size: 12px;
		font-weight: 500;
		color: var(--sl-color-gray-2);
	}

	/* ---- Empty env section ---- */
	.cps-env-empty {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 7px;
	}
	.cps-env-row {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.cps-env-input {
		margin: 0;
		box-sizing: border-box;
		flex: 1;
		min-width: 0;
		min-height: 32px;
		display: flex;
		align-items: center;
		padding: 0 11px;
		border: 1.5px dashed var(--sl-color-gray-4);
		border-radius: 7px;
		background: var(--sl-color-bg);
		font-size: 13px;
		color: var(--sl-color-gray-3);
	}
	.cps-env-add {
		margin: 0;
		flex: none;
		padding: 6px 14px;
		border-radius: 7px;
		font-size: 12.5px;
		font-weight: 600;
		color: var(--sl-color-gray-3);
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg-sidebar);
	}

	/* ---- Footer: Deploy button ---- */
	.cps-footer {
		margin: 14px 0 0;
		padding: 13px 0 16px;
		border-top: 1px solid var(--sl-color-gray-5);
		display: flex;
		justify-content: flex-end;
	}
	.cps-deploy-btn {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 8px 26px;
		border-radius: 8px;
		background: var(--cps-deploy-bg);
		border: 1px solid var(--cps-deploy-border);
		font-size: 14px;
		font-weight: 600;
		color: #fff;
	}

	@media (max-width: 500px) {
		.cps-window {
			padding: 16px 14px 0;
		}
		.cps-env-row {
			flex-wrap: wrap;
			row-gap: 7px;
		}
	}
</style>
