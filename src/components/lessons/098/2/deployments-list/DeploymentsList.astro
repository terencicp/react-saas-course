---
// deployments-list — Chapter 098 Lesson 2, "From repo to live URL".
//
// A faithful HTML/CSS mock of Vercel's "Deployments" tab. The real page is an
// authenticated external screen that can't be captured, so this is a hand-built
// component, not a Screenshot of a real page.
//
// The teaching point: this list is the first place you look when prod looks
// wrong, and exactly one row carries the green "Production" badge — the build the
// alias currently points at. So the figure renders the Deployments tab as a list
// of rows, newest first. Each row shows a status icon (Ready), the commit message
// with its short SHA and branch chip, an environment badge, and a relative age.
// The top row (a merge to main) carries a green "Production" badge and a subtle
// highlight so the eye lands on the live build; the rest are "Preview" rows on
// feature branches.
//
// Pure HTML + CSS per the diagrams guide; chrome uses Starlight theme variables
// so it flips light/dark. Vercel's success green is a saturated mid-tone that
// reads in both themes. `not-content` + margin resets defeat Starlight's
// prose-margin selector.

import Figure from '../../../../figures/Figure.astro';

const READY_GREEN = '#16a34a'; // Vercel "Ready" status green
const PROD_BG = '#16a34a'; // Production badge green

type Row = {
	message: string;
	sha: string;
	branch: string;
	env: 'Production' | 'Preview';
	age: string;
	production?: boolean;
};

const rows: Row[] = [
	{
		message: 'Add invoices route and pricing page',
		sha: 'a1f9c2e',
		branch: 'main',
		env: 'Production',
		age: '2m ago',
		production: true,
	},
	{
		message: 'Tighten dashboard empty state',
		sha: '7d4b018',
		branch: 'feat/dashboard-empty',
		env: 'Preview',
		age: '40m ago',
	},
	{
		message: 'Wire pricing copy from CMS',
		sha: 'c0e1a5d',
		branch: 'feat/pricing-copy',
		env: 'Preview',
		age: '3h ago',
	},
	{
		message: 'Initial import',
		sha: 'b2998fa',
		branch: 'main',
		env: 'Production',
		age: '1d ago',
	},
];
---

<Figure caption="The Deployments list. The row carrying the Production badge is the build currently serving live traffic.">
	<div
		class="dpl not-content"
		role="img"
		aria-label="Vercel's Deployments list as a table of four rows, each showing a commit SHA, message, branch, Ready status, environment, and age. The most recent row on the main branch carries a green Production badge and is highlighted; the others are preview deployments on feature branches."
	>
		<div class="dpl-window">
			{/* ---- Header / tab ---- */}
			<div class="dpl-header">
				<span class="dpl-mark" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="18" height="18">
						<polygon points="12,4 22,20 2,20" fill="#fff"></polygon>
					</svg>
				</span>
				<span class="dpl-title">Deployments</span>
				<span class="dpl-search" aria-hidden="true">
					<svg viewBox="0 0 16 16" width="13" height="13">
						<path
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							d="M7 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm3.6-1.4L14 14"></path>
					</svg>
					<span class="dpl-search-text">Search deployments&hellip;</span>
				</span>
			</div>

			{/* ---- Column header ---- */}
			<div class="dpl-colhead">
				<span class="dpl-ch dpl-ch-deploy">Deployment</span>
				<span class="dpl-ch dpl-ch-status">Status</span>
				<span class="dpl-ch dpl-ch-env">Environment</span>
				<span class="dpl-ch dpl-ch-age">Created</span>
			</div>

			{/* ---- Rows ---- */}
			<div class="dpl-rows">
				{
					rows.map((row) => (
						<div class:list={['dpl-row', { 'dpl-row-prod': row.production }]}>
							{/* Deployment: message + meta */}
							<div class="dpl-deploy">
								<span class="dpl-msg-line">
									<span class="dpl-msg">{row.message}</span>
									{row.production && <span class="dpl-prod-badge">Production</span>}
								</span>
								<span class="dpl-meta">
									<span class="dpl-commit-ico" aria-hidden="true">
										<svg viewBox="0 0 16 16" width="12" height="12">
											<circle
												cx="8"
												cy="8"
												r="3"
												fill="none"
												stroke="currentColor"
												stroke-width="1.4"
											/>
											<path
												stroke="currentColor"
												stroke-width="1.4"
												stroke-linecap="round"
												d="M8 1.5v3.5M8 11v3.5"
											/>
										</svg>
									</span>
									<span class="dpl-sha dpl-mono">{row.sha}</span>
									<span class="dpl-branch-ico" aria-hidden="true">
										<svg viewBox="0 0 16 16" width="12" height="12">
											<path
												fill="none"
												stroke="currentColor"
												stroke-width="1.4"
												stroke-linecap="round"
												d="M4.5 2.5v8M4.5 13.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm0-8a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm7 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm0 0c0 4-7 1.5-7 5"
											/>
										</svg>
									</span>
									<span class="dpl-branch dpl-mono">{row.branch}</span>
								</span>
							</div>

							{/* Status */}
							<span class="dpl-status">
								<span class="dpl-status-dot" aria-hidden="true" />
								Ready
							</span>

							{/* Environment */}
							<span class="dpl-env">
								<span
									class:list={[
										'dpl-env-badge',
										row.env === 'Production' ? 'dpl-env-prod' : 'dpl-env-preview',
									]}
								>
									{row.env}
								</span>
							</span>

							{/* Age */}
							<span class="dpl-age">{row.age}</span>
						</div>
					))
				}
			</div>
		</div>
	</div>
</Figure>

<style define:vars={{ 'dpl-ready': READY_GREEN, 'dpl-prod-bg': PROD_BG }}>
	.dpl {
		margin: 0;
		display: flex;
		justify-content: center;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- The window card ---- */
	.dpl-window {
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		max-width: 680px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 12px;
		background: var(--sl-color-bg-sidebar);
		overflow: hidden;
	}

	/* ---- Header ---- */
	.dpl-header {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 13px 16px;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.dpl-mark {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 7px;
		background: #000;
	}
	.dpl-title {
		margin: 0;
		flex: 1;
		font-size: 15px;
		font-weight: 700;
		color: var(--sl-color-white);
	}
	.dpl-search {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 7px;
		padding: 6px 11px;
		border: 1.5px solid var(--sl-color-gray-4);
		border-radius: 7px;
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-3);
	}
	.dpl-search-text {
		margin: 0;
		font-size: 12px;
		color: var(--sl-color-gray-3);
	}

	/* ---- Column header ---- */
	.dpl-colhead {
		margin: 0;
		display: grid;
		grid-template-columns: 1fr 0.65fr 0.75fr 0.6fr;
		align-items: center;
		gap: 12px;
		padding: 8px 16px;
		background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent);
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.dpl-ch {
		margin: 0;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	/* ---- Rows ---- */
	.dpl-rows {
		margin: 0;
	}
	.dpl-row {
		margin: 0;
		display: grid;
		grid-template-columns: 1fr 0.65fr 0.75fr 0.6fr;
		align-items: center;
		gap: 12px;
		padding: 13px 16px;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.dpl-row:last-child {
		border-bottom: none;
	}
	/* The currently-aliased production row gets a subtle green wash + left rail. */
	.dpl-row-prod {
		background: color-mix(in srgb, var(--dpl-prod-bg) 9%, transparent);
		box-shadow: inset 3px 0 0 var(--dpl-prod-bg);
	}

	/* Deployment cell */
	.dpl-deploy {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 5px;
		min-width: 0;
	}
	.dpl-msg-line {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 9px;
		min-width: 0;
	}
	.dpl-msg {
		margin: 0;
		font-size: 13.5px;
		font-weight: 600;
		color: var(--sl-color-white);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.dpl-prod-badge {
		margin: 0;
		flex: none;
		display: inline-flex;
		align-items: center;
		padding: 1px 8px;
		border-radius: 999px;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: #fff;
		background: var(--dpl-prod-bg);
	}
	.dpl-meta {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 6px;
		min-width: 0;
		color: var(--sl-color-gray-3);
	}
	.dpl-commit-ico,
	.dpl-branch-ico {
		margin: 0;
		flex: none;
		display: inline-flex;
		color: var(--sl-color-gray-3);
	}
	.dpl-branch-ico {
		margin-left: 4px;
	}
	.dpl-mono {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}
	.dpl-sha {
		margin: 0;
		font-size: 12px;
		color: var(--sl-color-gray-2);
	}
	.dpl-branch {
		margin: 0;
		font-size: 12px;
		color: var(--sl-color-gray-2);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* Status cell */
	.dpl-status {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 13px;
		font-weight: 600;
		color: var(--dpl-ready);
	}
	.dpl-status-dot {
		margin: 0;
		flex: none;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--dpl-ready);
	}

	/* Environment cell */
	.dpl-env {
		margin: 0;
	}
	.dpl-env-badge {
		margin: 0;
		display: inline-flex;
		align-items: center;
		padding: 2px 9px;
		border-radius: 999px;
		font-size: 11.5px;
		font-weight: 600;
		border: 1px solid var(--sl-color-gray-5);
	}
	.dpl-env-prod {
		color: var(--dpl-prod-bg);
		background: color-mix(in srgb, var(--dpl-prod-bg) 12%, transparent);
		border-color: color-mix(in srgb, var(--dpl-prod-bg) 38%, transparent);
	}
	.dpl-env-preview {
		color: var(--sl-color-gray-2);
		background: color-mix(in srgb, var(--sl-color-gray-3) 14%, transparent);
	}

	/* Age cell */
	.dpl-age {
		margin: 0;
		font-size: 12.5px;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}

	@media (max-width: 560px) {
		.dpl-colhead {
			display: none;
		}
		.dpl-row {
			grid-template-columns: 1fr auto;
			row-gap: 9px;
		}
		.dpl-status {
			justify-self: end;
		}
		.dpl-env {
			grid-column: 1;
		}
		.dpl-age {
			grid-column: 2;
			justify-self: end;
		}
	}
</style>
