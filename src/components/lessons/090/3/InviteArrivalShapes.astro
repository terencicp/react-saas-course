---
// invite-arrival-shapes — Chapter 090 Lesson 3, "The four-path catalog"
// (Money path 3 — invitation acceptance with seat grant).
//
// Situates the ONE arrival shape the E2E spec drives within the four shapes the
// app's invitation feature actually supports, so the student doesn't mistake a
// single spec for coverage of the whole feature. The picture is the same every
// frame: four arrival-situation boxes on the left, all funneling through one
// signed "Accept route" box in the middle, which leads to a single outcome box
// on the right ("Seat granted + scoped to org"). The geometry is FIXED across
// all five steps — only the highlight/dim state of the boxes changes — so the
// DiagramSequence grid stack sizes once to the tallest step and never reflows
// as the reader scrubs.
//
// State machine per box, per step:
//   is-on  — highlighted (the shape(s) this caption is about)
//   is-dim — faded back (an arrival the caption is currently NOT about)
//   (neutral) — shown at full weight but not accented (step 1, everything equal)
//
// The five steps mirror the lesson outline:
//   1. all four arrivals equal → one accept route
//   2. highlight "signed in, same email"      (one-click accept)
//   3. highlight the two re-auth shapes        (signed-in-diff + signed-out-acct)
//   4. highlight ONLY "signed out, no account" (the shape the spec drives)
//   5. spotlight the shared outcome box        (seat granted + scoped to org)
//
// Pure HTML + CSS per the diagrams guide (a small fixed graph with per-step
// emphasis, no leader lines — ArrowDiagram's body-positioned lines break inside
// DiagramSequence's visibility:hidden grid stack). Colour language matches the
// chapter family: blue #3b82f6 as the active accent, green #16a34a reserved for
// the terminal outcome (the seat grant — the thing that actually mattered).
// DiagramSequence supplies the outer card, so there is NO <Figure> wrapper.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// The four arrival situations, top → bottom. `auth` / `acct` are the two-axis
// under-labels (signed-in state × account state) that distinguish the shapes.
const arrivals = [
	{ id: 'same', label: 'Signed in, same email', sub: 'one-click accept' },
	{ id: 'diff', label: 'Signed in, different email', sub: 're-auth first' },
	{ id: 'acct', label: 'Signed out, has an account', sub: 'sign in first' },
	{ id: 'none', label: 'Signed out, no account', sub: 'sign up first' },
];

// Per step: which arrival ids are highlighted, which are dimmed, and whether the
// terminal outcome box is spotlit. Anything not named stays neutral.
type Frame = { on: string[]; dim: string[]; outcome: boolean };
const frames: Frame[] = [
	{ on: [], dim: [], outcome: false }, // 1 — all equal
	{ on: ['same'], dim: ['diff', 'acct', 'none'], outcome: false }, // 2
	{ on: ['diff', 'acct'], dim: ['same', 'none'], outcome: false }, // 3
	{ on: ['none'], dim: ['same', 'diff', 'acct'], outcome: false }, // 4 — spec's shape
	{ on: [], dim: ['same', 'diff', 'acct', 'none'], outcome: true }, // 5 — outcome
];

const captions = [
	'Four ways an invite can arrive — all four hit the same signed accept URL.',
	'Already signed in with the invited email? Accept in one click, no new credentials.',
	'Signed in as someone else, or signed out with an existing account? Re-auth, then accept.',
	'Signed out with no account — the shape our spec drives: sign up, then accept.',
	'Whichever way they arrive, the outcome is the same: a seat granted, scoped to this org and no other.',
];

const BLUE = '#3b82f6';
const GREEN = '#16a34a';

const cls = (id: string, f: Frame) =>
	['ias-arrival', f.on.includes(id) && 'is-on', f.dim.includes(id) && 'is-dim']
		.filter(Boolean)
		.join(' ');
---

<DiagramSequence>
	{
		frames.map((f, i) => (
			<DiagramStep caption={captions[i]}>
				<div class="ias not-content" data-step={i + 1}>
					{/* Left column — the four arrival situations. */}
					<div class="ias-arrivals">
						{arrivals.map((a) => (
							<div class={cls(a.id, f)}>
								<span class="ias-arrival-label">{a.label}</span>
								<span class="ias-arrival-sub">{a.sub}</span>
							</div>
						))}
					</div>

					{/* Funnel — four lines converging on one route. */}
					<div class="ias-funnel" aria-hidden="true">
						<svg viewBox="0 0 56 200" preserveAspectRatio="none" fill="none">
							<path d="M2 25 H30 Q44 25 44 60 V96" />
							<path d="M2 75 H37 Q44 75 44 90 V96" />
							<path d="M2 125 H37 Q44 125 44 110 V104" />
							<path d="M2 175 H30 Q44 175 44 140 V104" />
							<polyline points="40 96 44 102 48 96" />
							<polyline points="40 104 44 98 48 104" />
						</svg>
					</div>

					{/* Center — the single signed accept route. */}
					<div class="ias-route">
						<span class="ias-route-tag">one route</span>
						<span class="ias-route-label">Accept route</span>
						<span class="ias-route-sub">signed token URL</span>
					</div>

					{/* Connector → outcome. */}
					<div class="ias-link" aria-hidden="true">
						<svg viewBox="0 0 44 14" fill="none" stroke="currentColor">
							<line x1="2" y1="7" x2="34" y2="7" />
							<polyline points="29 2.5 35.5 7 29 11.5" />
						</svg>
					</div>

					{/* Right — the shared terminal outcome. */}
					<div class={['ias-outcome', f.outcome && 'is-on'].filter(Boolean).join(' ')}>
						<span class="ias-outcome-label">Seat granted</span>
						<span class="ias-outcome-sub">scoped to org — no other</span>
					</div>
				</div>
			</DiagramStep>
		))
	}
</DiagramSequence>

<style define:vars={{ 'ias-blue': BLUE, 'ias-green': GREEN }}>
	.ias {
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		flex-wrap: nowrap;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── Left column: the four arrival situations ───────────────────────────── */
	.ias-arrivals {
		display: flex;
		flex-direction: column;
		gap: 8px;
		flex: 0 1 auto;
	}
	.ias-arrival {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 9px 12px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		min-width: 178px;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			color 0.16s,
			opacity 0.16s,
			box-shadow 0.16s;
	}
	.ias-arrival.is-on {
		border: 1.5px solid var(--ias-blue);
		background: color-mix(in srgb, var(--ias-blue) 13%, transparent);
		color: color-mix(in srgb, var(--ias-blue) 82%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--ias-blue) 13%, transparent);
	}
	.ias-arrival.is-dim {
		opacity: 0.4;
	}
	.ias-arrival-label {
		font-size: 0.8rem;
		font-weight: 700;
		line-height: 1.2;
		white-space: nowrap;
	}
	.ias-arrival-sub {
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.2;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		opacity: 0.8;
		white-space: nowrap;
	}

	/* ── Funnel: four converging lines ──────────────────────────────────────── */
	.ias-funnel {
		flex: 0 0 auto;
		width: 48px;
		align-self: stretch;
		display: flex;
		align-items: center;
	}
	.ias-funnel svg {
		width: 100%;
		height: 100%;
		stroke: var(--sl-color-gray-3);
		stroke-width: 1.5;
		stroke-linecap: round;
		stroke-linejoin: round;
		vector-effect: non-scaling-stroke;
	}

	/* ── Center: the single signed accept route ─────────────────────────────── */
	.ias-route {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		flex: 0 0 auto;
		padding: 12px 16px;
		border-radius: 11px;
		border: 1.5px solid color-mix(in srgb, var(--ias-blue) 55%, var(--sl-color-gray-4));
		background: var(--sl-color-bg);
		text-align: center;
	}
	.ias-route-tag {
		font-size: 0.6rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 2px 8px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--ias-blue) 84%, var(--sl-color-text));
		background: color-mix(in srgb, var(--ias-blue) 12%, transparent);
		margin-bottom: 2px;
	}
	.ias-route-label {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
		white-space: nowrap;
	}
	.ias-route-sub {
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}

	/* ── Connector → outcome ────────────────────────────────────────────────── */
	.ias-link {
		flex: 0 0 auto;
		width: 40px;
		display: inline-flex;
		align-items: center;
		color: var(--sl-color-gray-3);
	}
	.ias-link svg {
		width: 100%;
		height: 14px;
		stroke-width: 1.6;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	/* ── Right: the shared terminal outcome ─────────────────────────────────── */
	.ias-outcome {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 3px;
		flex: 0 1 auto;
		padding: 11px 14px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		min-width: 142px;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			color 0.16s,
			box-shadow 0.16s;
	}
	.ias-outcome.is-on {
		border: 1.5px solid var(--ias-green);
		background: color-mix(in srgb, var(--ias-green) 13%, transparent);
		color: color-mix(in srgb, var(--ias-green) 80%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--ias-green) 13%, transparent);
	}
	.ias-outcome-label {
		font-size: 0.86rem;
		font-weight: 700;
		line-height: 1.2;
		white-space: nowrap;
	}
	.ias-outcome-sub {
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
	}

	/* ── Narrow viewports: stack vertically, rotate the connectors ──────────── */
	@media (max-width: 720px) {
		.ias {
			flex-direction: column;
			gap: 4px;
		}
		.ias-arrivals {
			width: 100%;
		}
		.ias-arrival {
			min-width: 0;
			width: 100%;
		}
		.ias-funnel {
			width: 100%;
			height: 26px;
			align-self: auto;
			transform: rotate(90deg);
		}
		.ias-funnel svg {
			height: 26px;
		}
		.ias-route,
		.ias-outcome {
			width: 100%;
			min-width: 0;
		}
		.ias-link {
			width: 14px;
			height: 30px;
			transform: rotate(90deg);
		}
	}
</style>
