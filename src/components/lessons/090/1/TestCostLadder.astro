---
// TestCostLadder — Chapter 090 Lesson 1 ("The money-path filter").
//
// Four horizontal bars, one per test tier, stacked top-to-bottom from cheapest
// to most expensive. The pedagogical point is the *asymmetry*: an E2E test costs
// three orders of magnitude more than a unit test. A literal pixel-proportional
// log axis is unreadable for beginners and a literal linear axis would make the
// first three bars invisible slivers — so the bars use a compressed (root) scale
// for shape, the runtime number is printed on every bar as the ground truth, and
// the caption (supplied by the MDX <Figure>) names it "not to scale".
//
//   Unit (/lib) ............ 5 ms          [tiny bar,   muted]
//   Integration + rollback . 20–80 ms      [small bar,  muted]
//   Component (jsdom) ...... 100–300 ms     [mid bar,    mid]
//   Playwright (E2E) ....... 2–10 s         [LONG bar,   ACCENT]   ≈ 1000× the unit
//
// The eye should land on the long accented Playwright bar and read it as the
// outlier the whole lesson is about. The "≈1000× the unit test" annotation on
// that bar is the takeaway in three characters.
//
// Pure HTML+CSS per the diagrams guide. `not-content` + margin:0 on every node
// defeats Starlight's injected prose margins. Goes inside <Figure>, which the
// MDX supplies along with the caption.
//
// Colour: the three cheap tiers lean on Starlight greys so they recede; the
// Playwright tier uses the course's amber/orange accent (#d97706) so it pops in
// both themes. Tints via color-mix so they track the page background.

const ACCENT = '#d97706'; // the expensive tier — the one bar that stands out

type Tier = {
	label: string;
	scope: string;
	runtime: string;
	// Bar fill as a percentage of the track. Hand-tuned on a compressed scale so
	// the cheap tiers are visible at all while the E2E bar still dominates.
	fill: number;
	tone: 'muted' | 'mid' | 'accent';
	note?: string; // optional annotation printed after the runtime
};

const tiers: Tier[] = [
	{
		label: 'Unit',
		scope: 'a /lib helper',
		runtime: '~5 ms',
		fill: 4,
		tone: 'muted',
	},
	{
		label: 'Integration',
		scope: 'real Postgres, rolled back',
		runtime: '20–80 ms',
		fill: 11,
		tone: 'muted',
	},
	{
		label: 'Component',
		scope: 'rendered in jsdom',
		runtime: '100–300 ms',
		fill: 22,
		tone: 'mid',
	},
	{
		label: 'End-to-end',
		scope: 'a real browser, via Playwright',
		runtime: '2–10 s',
		fill: 100,
		tone: 'accent',
		note: '≈1000× the unit test',
	},
];
---

<div class="tcl not-content" style={`--tcl-accent:${ACCENT};`}>
	{
		tiers.map((tier) => (
			<div class:list={['tcl-row', `tcl-row--${tier.tone}`]}>
				<div class="tcl-head">
					<span class="tcl-label">{tier.label}</span>
					<span class="tcl-scope">{tier.scope}</span>
				</div>
				<div class="tcl-track">
					<div class="tcl-bar" style={`width: ${tier.fill}%;`} />
					<span class="tcl-runtime">
						{tier.runtime}
						{tier.note && <span class="tcl-note">{tier.note}</span>}
					</span>
				</div>
			</div>
		))
	}
</div>

<style>
	.tcl {
		display: flex;
		flex-direction: column;
		gap: 18px;
		padding: 6px 4px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* One tier: a label/scope head over a full-width bar track. */
	.tcl-row {
		display: grid;
		grid-template-columns: minmax(140px, 1fr) minmax(0, 3fr);
		align-items: center;
		gap: 14px;
		margin: 0;
	}

	.tcl-head {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
		margin: 0;
		text-align: right;
	}

	.tcl-label {
		font-size: 14px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.tcl-row--accent .tcl-label {
		color: color-mix(in srgb, var(--tcl-accent) 82%, var(--sl-color-white));
	}

	.tcl-scope {
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The full-width lane the bar grows inside. A faint baseline so a tiny bar
	   still reads as "a fraction of the lane", not a floating chip. */
	.tcl-track {
		position: relative;
		display: flex;
		align-items: center;
		gap: 10px;
		min-width: 0;
		min-height: 30px;
		margin: 0;
		border-radius: 8px;
		background: color-mix(in srgb, var(--sl-color-gray-6) 45%, transparent);
	}

	.tcl-bar {
		height: 30px;
		min-width: 6px;
		border-radius: 8px;
		flex: none;
		margin: 0;
	}

	.tcl-row--muted .tcl-bar {
		background: color-mix(in srgb, var(--sl-color-gray-4) 70%, transparent);
	}

	.tcl-row--mid .tcl-bar {
		background: color-mix(in srgb, var(--sl-color-gray-2) 70%, transparent);
	}

	.tcl-row--accent .tcl-bar {
		background: var(--tcl-accent);
	}

	.tcl-runtime {
		display: flex;
		align-items: baseline;
		gap: 8px;
		flex: none;
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		font-variant-numeric: tabular-nums;
		margin: 0;
		white-space: nowrap;
	}

	.tcl-row--accent .tcl-runtime {
		color: color-mix(in srgb, var(--tcl-accent) 82%, var(--sl-color-white));
	}

	/* The "≈1000×" payoff annotation rides next to the E2E runtime. */
	.tcl-note {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: color-mix(in srgb, var(--tcl-accent) 88%, var(--sl-color-text));
		margin: 0;
	}

	/* Narrow viewports: stack the head above the bar so the label keeps its size
	   and the bar still gets the full card width. */
	@media (max-width: 540px) {
		.tcl-row {
			grid-template-columns: 1fr;
			gap: 6px;
		}
		.tcl-head {
			text-align: left;
		}
	}
</style>
