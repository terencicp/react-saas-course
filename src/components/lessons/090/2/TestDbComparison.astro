---
// test-db-comparison — Chapter 090 Lesson 2,
// "Config, storageState, and the trace viewer", section
// "The Playwright-owned test database and its seed".
//
// Pedagogical goal: stop the single most common conflation in this chapter —
// "there's one test database." There are TWO, with TWO different isolation
// seams, and the difference is forced by a process boundary. The integration
// suite (ch088) keys a DB per Vitest worker and rolls each test back inside the
// SAME process; Playwright drives a separate server process, so a per-test
// rollback is impossible and the seam becomes a full reset between RUNS.
//
// Composition: a literal HTML <table> — three uniform columns (Layer, Database,
// Isolation seam) read across, two rows compared down. A table is the right
// shape here (vs side-by-side cards) because the three dimensions are the SAME
// attribute for both layers; the reader scans the Layer column to find a row,
// then reads its two facts across. The decisive column is the last one
// (Isolation seam) — that's where the two layers actually diverge — so it gets
// the strongest emphasis.
//
// Colour: a left accent rail per row carries identity, not value — BLUE = the
// integration layer the student already owns (ch088), GREEN = the E2E layer
// this chapter adds. Both are mid-tone accents reused verbatim in light + dark,
// matching the sibling SetupStorageStateFlow figure's blue/green vocabulary so
// the lesson reads as one palette.
//
// Plain HTML + CSS, Astro-scoped <style>. `.not-content` on the root plus
// margin/border resets defeat Starlight's injected prose table styling (zebra
// stripes, full borders) so the figure controls its own look. A container query
// stacks each row into a label/value list when the figure narrows (sidebar open
// or phone), keeping the three facts legible without a horizontal scroll.

import Figure from '../../../figures/Figure.astro';

const INTEGRATION_BLUE = '#0ea5e9'; // the layer the student already owns (ch088)
const E2E_GREEN = '#16a34a'; // the layer this chapter adds

type Row = {
	/** Test layer name. */
	layer: string;
	/** The chapter it was established in. */
	source: string;
	/** Which database it talks to, with the keying mechanism. */
	db: string;
	/** Mono token naming the database / key. */
	dbToken: string;
	/** How writes get cleaned up — the column where the two diverge. */
	seam: string;
	/** Mono token naming the seam mechanism. */
	seamToken: string;
	/** Cadence of the seam: per test vs per run. */
	seamCadence: string;
	/** Row accent. */
	color: string;
};

const rows: Row[] = [
	{
		layer: 'Integration',
		source: 'Integration tests at the seams',
		db: 'a fresh database per worker',
		dbToken: 'keyed by VITEST_POOL_ID',
		seam: 'a transaction rolled back after each test',
		seamToken: 'withRollback(tx)',
		seamCadence: 'per test',
		color: INTEGRATION_BLUE,
	},
	{
		layer: 'E2E',
		source: 'this chapter',
		db: 'one shared database',
		dbToken: 'saas_e2e',
		seam: 'a deterministic full reset between runs',
		seamToken: 'db:e2e:reset',
		seamCadence: 'per run',
		color: E2E_GREEN,
	},
];
---

<Figure>
	<div class="tdb not-content">
		<table class="tdb-table">
			<thead>
				<tr>
					<th scope="col" class="tdb-th tdb-th--layer">Layer</th>
					<th scope="col" class="tdb-th">Database</th>
					<th scope="col" class="tdb-th tdb-th--seam">Isolation seam</th>
				</tr>
			</thead>
			<tbody>
				{
					rows.map((r) => (
						<tr class="tdb-row" style={`--c:${r.color}`}>
							<th scope="row" class="tdb-cell tdb-cell--layer" data-label="Layer">
								<span class="tdb-layer">{r.layer}</span>
								<span class="tdb-source">{r.source}</span>
							</th>
							<td class="tdb-cell" data-label="Database">
								<span class="tdb-text">{r.db}</span>
								<code class="tdb-token">{r.dbToken}</code>
							</td>
							<td class="tdb-cell tdb-cell--seam" data-label="Isolation seam">
								<span class="tdb-text">{r.seam}</span>
								<span class="tdb-seam-line">
									<code class="tdb-token">{r.seamToken}</code>
									<span class="tdb-cadence">{r.seamCadence}</span>
								</span>
							</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>

	<Fragment slot="caption">
		Two test databases, two isolation seams. The integration suite rolls back
		inside one process; Playwright's server is a separate process, so it resets
		the whole database between runs instead.
	</Fragment>
</Figure>

<style>
	.tdb {
		container-type: inline-size;
		container-name: tdb;
		width: 100%;
		margin: 0;
		padding-block: 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.tdb-table {
		width: 100%;
		margin: 0;
		border-collapse: separate;
		border-spacing: 0 8px;
		table-layout: fixed;
	}

	/* ── header ── */
	.tdb-th {
		margin: 0;
		padding: 0 14px 6px;
		text-align: left;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		background: transparent;
		border: 0;
		width: 30%;
	}
	.tdb-th--layer {
		width: 22%;
		padding-left: 18px;
	}
	.tdb-th--seam {
		width: 48%;
		color: var(--sl-color-white, #1e293b);
	}

	/* ── rows: each a banded card with a left accent rail ── */
	.tdb-row {
		background: var(--sl-color-black, transparent);
	}
	.tdb-cell {
		margin: 0;
		padding: 12px 14px;
		vertical-align: top;
		text-align: left;
		background: color-mix(in srgb, var(--c) 7%, transparent);
		border-top: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		font-weight: 400;
	}
	.tdb-cell--layer {
		border-left: 4px solid var(--c);
		border-top-left-radius: 10px;
		border-bottom-left-radius: 10px;
		padding-left: 14px;
	}
	.tdb-cell--seam {
		border-right: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-top-right-radius: 10px;
		border-bottom-right-radius: 10px;
	}

	/* ── layer cell: name + the chapter it came from ── */
	.tdb-layer {
		display: block;
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
	}
	.tdb-source {
		display: block;
		margin-top: 3px;
		font-size: 0.68rem;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── value cells ── */
	.tdb-text {
		display: block;
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.4;
		color: var(--sl-color-white, #1e293b);
	}
	.tdb-token {
		display: inline-block;
		margin-top: 6px;
		padding: 2px 7px;
		border-radius: 6px;
		background: color-mix(in srgb, var(--c) 15%, transparent);
		border: 1px solid color-mix(in srgb, var(--c) 38%, transparent);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.7rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
	}

	/* ── seam cell: the decisive column — token + a cadence pill ── */
	.tdb-seam-line {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
		margin-top: 6px;
	}
	.tdb-seam-line .tdb-token {
		margin-top: 0;
	}
	.tdb-cadence {
		display: inline-block;
		padding: 2px 8px;
		border-radius: 999px;
		background: var(--c);
		font-size: 0.64rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		line-height: 1.3;
		color: #fff;
	}

	/* ── narrow figure (sidebar open or phones): each row becomes a stacked
	   label/value list; the column headers are replaced by per-cell data-labels
	   so the three facts stay legible without a horizontal scroll. ── */
	@container tdb (max-width: 560px) {
		.tdb-table {
			table-layout: auto;
		}
		.tdb-th {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0 0 0 0);
			white-space: nowrap;
		}
		.tdb-row {
			display: block;
			margin-bottom: 14px;
		}
		.tdb-cell {
			display: block;
			width: 100%;
			border: 1px solid var(--sl-color-gray-5, #cbd5e1);
			border-left: 4px solid var(--c);
			border-bottom: 0;
		}
		.tdb-cell--layer {
			border-top-left-radius: 10px;
			border-top-right-radius: 10px;
			border-bottom-left-radius: 0;
		}
		.tdb-cell--seam {
			border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
			border-bottom-left-radius: 10px;
			border-bottom-right-radius: 10px;
			border-top-right-radius: 0;
		}
		.tdb-cell:not(.tdb-cell--layer)::before {
			content: attr(data-label);
			display: block;
			margin-bottom: 4px;
			font-size: 0.6rem;
			font-weight: 700;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			color: var(--sl-color-gray-3, #64748b);
		}
	}
</style>
