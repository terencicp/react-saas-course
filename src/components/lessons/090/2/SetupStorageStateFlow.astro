---
// setup-storagestate-flow — Chapter 090 Lesson 2,
// "Config, storageState, and the trace viewer".
//
// Makes the otherwise-invisible "how does my test get logged in?" data flow
// concrete. The config alone hides it: a `setup` project writes a file, the
// `chromium` project loads it via `use.storageState`, and the `dependencies`
// key orders the two. This figure traces that artifact left→right across four
// boxes:
//
//   setup project ──[writes]──▶ .auth/owner.json ──[loads]──▶ chromium project
//     ──[applies to]──▶ every spec
//
// The single GREEN arrow is the write — it echoes the produces-the-artifact
// idea (the setup project's whole job is to create the file). The other two
// arrows are BLUE: the file being consumed and the session being applied.
//
// Built with <ArrowDiagram> (LeaderLine) because each box is two-line custom
// HTML (a monospace title + a muted under-label) and the per-arrow semantic
// coloring is the point. The arrows are positioned from document.body, so the
// wrapping <Figure> MUST be expandable={false}: relocating the body into the
// lightbox breaks the leader lines.
//
// Sockets are right→left between adjacent boxes in one horizontal row; the
// three labels sit in the gaps, lifted above the wire with labelOffset so they
// don't land on the arrow body. Chrome is theme-aware (Starlight gray/white
// vars flip light/dark); the two accents (#16a34a green, #0ea5e9 blue) are
// used as-is in both themes — mid-tones that read on either background.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// The four boxes, left → right. `id` matches the arrow descriptors; `under` is
// the small muted label beneath each box title.
const boxes = [
	{ id: 'ad-setup', title: 'setup project', under: 'runs auth.setup.ts' },
	{ id: 'ad-statefile', title: '.auth/owner.json', under: 'session cookies on disk' },
	{ id: 'ad-chromium', title: 'chromium project', under: 'loads storageState' },
	{ id: 'ad-specs', title: 'every spec', under: 'starts already signed in' },
];

// Mid-tone accents reused verbatim in light + dark.
const WRITE_GREEN = '#16a34a'; // produces the artifact
const FLOW_BLUE = '#0ea5e9'; // consumes / applies the artifact

const arrows = [
	// The write — the setup project's whole job is to produce this file.
	{
		from: 'ad-setup',
		to: 'ad-statefile',
		label: 'writes',
		color: WRITE_GREEN,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
		labelOffset: [0, -28],
	},
	// The file gets loaded into the chromium project.
	{
		from: 'ad-statefile',
		to: 'ad-chromium',
		label: 'loads',
		color: FLOW_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
		labelOffset: [0, -28],
	},
	// The loaded session applies to every spec the project runs.
	{
		from: 'ad-chromium',
		to: 'ad-specs',
		label: 'applies to',
		color: FLOW_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
		labelOffset: [0, -28],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="ssf not-content">
			{
				boxes.map((box) => (
					<div class="ssf-box" id={box.id}>
						<span class="ssf-title">{box.title}</span>
						<span class="ssf-under">{box.under}</span>
					</div>
				))
			}
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		The setup project signs in once and serializes the session to disk; every
		chromium spec loads that file and starts authenticated. The `dependencies`
		key is what orders the two.
	</Fragment>
</Figure>

<style>
	.ssf {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: space-between;
		gap: 86px;
		margin: 0;
		padding: 18px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.ssf-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		flex: 0 1 auto;
		padding: 11px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	.ssf-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.86rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.ssf-under {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: stack the four boxes; the right→left sockets degrade to
	   vertical arcs between stacked boxes — readable, and the labels still float
	   in the gaps. */
	@media (max-width: 760px) {
		.ssf {
			flex-direction: column;
			gap: 50px;
		}
		.ssf-box {
			width: min(18rem, 100%);
		}
	}
</style>
