---
// handlesubmit-flow — Chapter 045 Lesson 2, "The five RHF primitives".
//
// The SUBMIT concern, made scrubbable. `handleSubmit` returns a real DOM submit
// handler that runs a small fixed flow before any of the student's code sees the
// data: intercept -> validate -> BRANCH -> hand off (valid) / populate errors
// (invalid). The whole job of this figure is to replace any lingering
// action-prop or `fetch + preventDefault` mental model with RHF's
// intercept-then-handoff flow, and to make the BRANCH the visible centerpiece.
//
// Every step shows the SAME horizontal flow graph so the DiagramSequence grid
// stack sizes to the tallest step once and never reflows as the reader scrubs.
// Only the lit nodes/edges change beat to beat:
//
//   [ Submit ] --> [ Validate ] --<fork>== (valid) ==> [ onSubmit(values) ]
//                                      \== (invalid) ==> [ formState.errors ]
//
//   1  Submit clicked. The node lights; a "preventDefault()" pill marks that the
//      browser POST was intercepted — nothing leaves the page.
//   2  Validate. RHF runs the resolver (the same Zod schema the action uses).
//   3  Branch. The fork + both lane labels light; RHF is about to pick a lane.
//   4  Valid lane lights through to onSubmit(values) (green) — the typed values
//      reach the student's code, which calls the Server Action.
//   5  Invalid lane lights through to formState.errors (red); onSubmit is shown
//      explicitly SKIPPED so the "RHF skips onSubmit entirely" caption lands.
//
// House style follows this chapter-arc's SubmitLifecycleTimeline /
// EffectLifecycleSequence: fixed slate ink, color-scheme pinned light so the
// hand-picked blue/amber/green/red tints survive dark mode, `margin: 0` on every
// inner element to defeat Starlight's injected prose margins. A color-coded phase
// banner heads each step so scanning the banners alone tells the flow. Per the
// diagram index a temporal sequence the reader scrubs is a DiagramSequence, and
// the panels are plain HTML + CSS. This component renders its own card — it is
// NOT wrapped in <Figure>.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary / dim edge (slate-300)
const DIM_BG = '#f8fafc'; // an inert / not-yet-reached node wash (slate-50)
const DIM_INK = '#94a3b8'; // dim node ink (slate-400)
const WIRE = '#cbd5e1'; // an inert connector (slate-300)

const BLUE = '#2563eb'; // blue-600 — the active node in the flow
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const AMBER = '#d97706'; // amber-600 — validate / handleSubmit's own beat
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const GREEN = '#16a34a'; // green-600 — the valid branch -> onSubmit
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const RED = '#dc2626'; // red-600 — the invalid branch -> errors
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// A node's visual state: `on` = lit/active for this beat, `done` = already
// passed (settled), `off` = not yet reached / not taken, `skip` = explicitly
// skipped (the invalid beat's onSubmit). Each maps to an accent triad.
type NodeState = 'on' | 'done' | 'off' | 'skip';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all five steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 13px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// --- the phase banner (top of every step) ------------------------------------
// A full-width strip naming the current stage. Its accent run is the story:
// blue intercept, amber validate, slate branch, green valid, red invalid.
const banner = (edge: string, bg: string, ink: string) =>
	`display: flex; align-items: center; gap: 9px; margin: 0; padding: 8px 12px; width: 100%; max-width: 600px; box-sizing: border-box; border: 1px solid ${edge}; border-left-width: 4px; border-radius: 8px; background: ${bg}; color: ${ink}; font-size: 12.5px; font-weight: 600; line-height: 1.3;`;
const bannerEyebrow = (ink: string) =>
	`flex: 0 0 auto; margin: 0; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: ${ink};`;
const monoTag = `font-family: ${mono}; font-weight: 700;`;

// --- the flow graph ----------------------------------------------------------
// One horizontal row: left rail [Submit -> Validate], a fork, then two stacked
// lanes on the right. A fixed min-height holds the row constant across steps.
const graph = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0; margin: 0; width: 100%; max-width: 600px; min-height: 132px;`;

// A flow node. The triad is keyed off NodeState; `done` reads as a settled blue,
// `off` is the inert slate wash, `skip` is a dashed greyed box.
const nodeTriad = (state: NodeState, accent: 'blue' | 'amber' | 'green' | 'red'): [string, string, string] => {
	if (state === 'off') return [BORDER, DIM_BG, DIM_INK];
	if (state === 'skip') return [BORDER, DIM_BG, DIM_INK];
	if (state === 'done') return [BLUE, '#eff6ff', BLUE_INK];
	// state === 'on' — paint with the node's own accent
	if (accent === 'amber') return [AMBER, AMBER_BG, AMBER_INK];
	if (accent === 'green') return [GREEN, GREEN_BG, GREEN_INK];
	if (accent === 'red') return [RED, RED_BG, RED_INK];
	return [BLUE, BLUE_BG, BLUE_INK];
};
const node = (state: NodeState, accent: 'blue' | 'amber' | 'green' | 'red') => {
	const [edge, bg, ink] = nodeTriad(state, accent);
	const dashed = state === 'skip' ? 'border-style: dashed;' : '';
	const lift = state === 'on' ? `box-shadow: 0 2px 6px color-mix(in srgb, ${edge} 30%, transparent);` : '';
	const fade = state === 'off' || state === 'skip' ? 'opacity: 0.78;' : '';
	return (
		`box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 0 0 auto; margin: 0; padding: 9px 11px; min-width: 96px; border: 1.5px solid ${edge}; ${dashed} border-radius: 10px; background: ${bg}; color: ${ink}; text-align: center; ${lift} ${fade}`
	);
};
const nodeEyebrow = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${ink};`;
const nodeName = `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.15;`;

// A small status pill that rides under a node (e.g. preventDefault, skipped).
const nodePill = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; margin: 1px 0 0; padding: 1px 7px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${mono}; font-size: 9px; font-weight: 700; line-height: 1.4; white-space: nowrap;`;

// A horizontal connector between Submit and Validate. `lit` paints it blue.
const arrowH = (lit: boolean) => {
	const c = lit ? BLUE : WIRE;
	return `display: flex; align-items: center; flex: 0 0 auto; margin: 0 2px; color: ${c};`;
};
const arrowLine = (lit: boolean) => {
	const c = lit ? BLUE : WIRE;
	return `width: 22px; height: 2.5px; margin: 0; border-radius: 2px; background: ${c};`;
};
const arrowHead = (lit: boolean) => {
	const c = lit ? BLUE : WIRE;
	return `width: 0; height: 0; margin: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent; border-left: 7px solid ${c};`;
};

// The fork: a short stem out of Validate that splits into two lanes. Built as a
// 3-row grid so the upper lane label/arrow and lower lane label/arrow align to
// their terminal nodes. The connecting bracket is a bordered box on the left.
const fork = `display: grid; grid-template-rows: 1fr 1fr; align-items: center; flex: 0 0 auto; margin: 0 0 0 4px;`;
const lane = `display: flex; align-items: center; gap: 6px; margin: 0;`;
// The little "valid"/"invalid" label sitting on a lane's arrow.
const laneTag = (lit: boolean, tone: 'green' | 'red') => {
	const [edge, bg, ink] = lit
		? tone === 'green'
			? [GREEN, GREEN_BG, GREEN_INK]
			: [RED, RED_BG, RED_INK]
		: [BORDER, '#ffffff', DIM_INK];
	return `display: inline-flex; align-items: center; margin: 0; padding: 1px 7px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.4; white-space: nowrap;`;
};
const laneArrowLine = (lit: boolean, tone: 'green' | 'red') => {
	const c = lit ? (tone === 'green' ? GREEN : RED) : WIRE;
	return `width: 18px; height: 2.5px; margin: 0; border-radius: 2px; background: ${c};`;
};
const laneArrowHead = (lit: boolean, tone: 'green' | 'red') => {
	const c = lit ? (tone === 'green' ? GREEN : RED) : WIRE;
	return `width: 0; height: 0; margin: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent; border-left: 7px solid ${c};`;
};
// The vertical bracket that joins the two lanes back to the Validate stem.
const forkBracket = (lit: boolean) => {
	const c = lit ? AMBER : WIRE;
	return `flex: 0 0 auto; width: 2.5px; height: 64px; margin: 0 4px 0 0; border-radius: 2px; background: ${c};`;
};
const forkStem = (lit: boolean) => {
	const c = lit ? AMBER : WIRE;
	return `flex: 0 0 auto; width: 12px; height: 2.5px; margin: 0; border-radius: 2px; background: ${c};`;
};
const forkWrap = `display: flex; align-items: center; flex: 0 0 auto; margin: 0 2px 0 4px;`;

// A column wrapper so a terminal node can carry a tiny caption pill under it.
const termCol = `display: flex; flex-direction: column; align-items: center; gap: 4px; margin: 0;`;

// The one-line verdict under the graph. Fixed min-height for a stable footprint.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.4; color: ${tone}; max-width: 560px; text-align: center; min-height: 16px;`;
const codeInline = `font-family: ${mono}; font-weight: 700;`;
---

<DiagramSequence>
	{/* ---- Step 1: Submit clicked — handleSubmit intercepts (preventDefault) ---- */}
	<DiagramStep
		caption="The user clicks submit. The browser would normally POST the form — but handleSubmit intercepted it (it called preventDefault for you), so nothing leaves the page yet."
	>
		<div style={stage}>
			<div style={banner(BLUE, BLUE_BG, BLUE_INK)}>
				<span style={bannerEyebrow(BLUE_INK)}>intercept</span>
				<span>Submit clicked &mdash; <code style={monoTag}>handleSubmit</code> intercepts the native POST</span>
			</div>
			<div style={graph}>
				<div style={termCol}>
					<div style={node('on', 'blue')}>
						<span style={nodeEyebrow(BLUE_INK)}>user</span>
						<span style={nodeName}>Submit</span>
					</div>
					<span style={nodePill(BLUE, BLUE_BG, BLUE_INK)}>preventDefault()</span>
				</div>
				<span style={arrowH(false)}><span style={arrowLine(false)}></span><span style={arrowHead(false)}></span></span>
				<div style={node('off', 'amber')}>
					<span style={nodeEyebrow(DIM_INK)}>RHF</span>
					<span style={nodeName}>Validate</span>
				</div>
				<span style={forkWrap}>
					<span style={forkStem(false)}></span>
					<span style={forkBracket(false)}></span>
				</span>
				<div style={fork}>
					<div style={lane}>
						<span style={laneTag(false, 'green')}>valid</span>
						<span style={laneArrowLine(false, 'green')}></span><span style={laneArrowHead(false, 'green')}></span>
						<div style={node('off', 'green')}>
							<span style={nodeEyebrow(DIM_INK)}>your code</span>
							<span style={nodeName}>onSubmit(values)</span>
						</div>
					</div>
					<div style={lane}>
						<span style={laneTag(false, 'red')}>invalid</span>
						<span style={laneArrowLine(false, 'red')}></span><span style={laneArrowHead(false, 'red')}></span>
						<div style={node('off', 'red')}>
							<span style={nodeEyebrow(DIM_INK)}>RHF</span>
							<span style={nodeName}>formState.errors</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(BLUE_INK)}>
				The submit is caught in JS &mdash; <code style={codeInline}>preventDefault</code> already fired, so no request has left the page.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Validate — RHF runs the resolver ---- */}
	<DiagramStep
		caption="RHF runs client-side validation against the resolver — the same Zod schema the action uses. This is the check that drives the inline error UX."
	>
		<div style={stage}>
			<div style={banner(AMBER, AMBER_BG, AMBER_INK)}>
				<span style={bannerEyebrow(AMBER_INK)}>validate</span>
				<span>RHF runs the <code style={monoTag}>resolver</code> &mdash; the same Zod schema the action parses with</span>
			</div>
			<div style={graph}>
				<div style={termCol}>
					<div style={node('done', 'blue')}>
						<span style={nodeEyebrow(BLUE_INK)}>user</span>
						<span style={nodeName}>Submit</span>
					</div>
					<span style={nodePill(BORDER, '#ffffff', INK_SOFT)}>intercepted</span>
				</div>
				<span style={arrowH(true)}><span style={arrowLine(true)}></span><span style={arrowHead(true)}></span></span>
				<div style={node('on', 'amber')}>
					<span style={nodeEyebrow(AMBER_INK)}>RHF</span>
					<span style={nodeName}>Validate</span>
				</div>
				<span style={forkWrap}>
					<span style={forkStem(false)}></span>
					<span style={forkBracket(false)}></span>
				</span>
				<div style={fork}>
					<div style={lane}>
						<span style={laneTag(false, 'green')}>valid</span>
						<span style={laneArrowLine(false, 'green')}></span><span style={laneArrowHead(false, 'green')}></span>
						<div style={node('off', 'green')}>
							<span style={nodeEyebrow(DIM_INK)}>your code</span>
							<span style={nodeName}>onSubmit(values)</span>
						</div>
					</div>
					<div style={lane}>
						<span style={laneTag(false, 'red')}>invalid</span>
						<span style={laneArrowLine(false, 'red')}></span><span style={laneArrowHead(false, 'red')}></span>
						<div style={node('off', 'red')}>
							<span style={nodeEyebrow(DIM_INK)}>RHF</span>
							<span style={nodeName}>formState.errors</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(AMBER_INK)}>
				Before your code runs, RHF validates the values against the resolver &mdash; the client-side mirror of the action's <code style={codeInline}>safeParse</code>.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: Branch — RHF picks a lane based on the result ---- */}
	<DiagramStep
		caption="The flow branches on the result. Valid one way, invalid the other — RHF picks which of your callbacks runs."
	>
		<div style={stage}>
			<div style={banner(INK_SOFT, '#f1f5f9', INK)}>
				<span style={bannerEyebrow(INK_SOFT)}>branch</span>
				<span>Validation done &mdash; RHF picks a lane on the result</span>
			</div>
			<div style={graph}>
				<div style={termCol}>
					<div style={node('done', 'blue')}>
						<span style={nodeEyebrow(BLUE_INK)}>user</span>
						<span style={nodeName}>Submit</span>
					</div>
					<span style={nodePill(BORDER, '#ffffff', INK_SOFT)}>intercepted</span>
				</div>
				<span style={arrowH(true)}><span style={arrowLine(true)}></span><span style={arrowHead(true)}></span></span>
				<div style={node('done', 'amber')}>
					<span style={nodeEyebrow(BLUE_INK)}>RHF</span>
					<span style={nodeName}>Validate</span>
				</div>
				<span style={forkWrap}>
					<span style={forkStem(true)}></span>
					<span style={forkBracket(true)}></span>
				</span>
				<div style={fork}>
					<div style={lane}>
						<span style={laneTag(true, 'green')}>valid</span>
						<span style={laneArrowLine(true, 'green')}></span><span style={laneArrowHead(true, 'green')}></span>
						<div style={node('off', 'green')}>
							<span style={nodeEyebrow(GREEN_INK)}>your code</span>
							<span style={nodeName}>onSubmit(values)</span>
						</div>
					</div>
					<div style={lane}>
						<span style={laneTag(true, 'red')}>invalid</span>
						<span style={laneArrowLine(true, 'red')}></span><span style={laneArrowHead(true, 'red')}></span>
						<div style={node('off', 'red')}>
							<span style={nodeEyebrow(RED_INK)}>RHF</span>
							<span style={nodeName}>formState.errors</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(INK)}>
				One check, two exits: exactly one lane is taken &mdash; RHF decides which of your callbacks gets to run.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Valid — onSubmit(values) runs with the typed values ---- */}
	<DiagramStep
		caption="On valid: RHF calls onSubmit(values) with the typed values — already parsed and shaped to InvoiceInput. This is where your code finally runs and calls the Server Action."
	>
		<div style={stage}>
			<div style={banner(GREEN, GREEN_BG, GREEN_INK)}>
				<span style={bannerEyebrow(GREEN_INK)}>valid path</span>
				<span><code style={monoTag}>onSubmit(values)</code> runs with the typed <code style={monoTag}>InvoiceInput</code></span>
			</div>
			<div style={graph}>
				<div style={termCol}>
					<div style={node('done', 'blue')}>
						<span style={nodeEyebrow(BLUE_INK)}>user</span>
						<span style={nodeName}>Submit</span>
					</div>
					<span style={nodePill(BORDER, '#ffffff', INK_SOFT)}>intercepted</span>
				</div>
				<span style={arrowH(true)}><span style={arrowLine(true)}></span><span style={arrowHead(true)}></span></span>
				<div style={node('done', 'amber')}>
					<span style={nodeEyebrow(BLUE_INK)}>RHF</span>
					<span style={nodeName}>Validate</span>
				</div>
				<span style={forkWrap}>
					<span style={forkStem(true)}></span>
					<span style={forkBracket(true)}></span>
				</span>
				<div style={fork}>
					<div style={lane}>
						<span style={laneTag(true, 'green')}>valid</span>
						<span style={laneArrowLine(true, 'green')}></span><span style={laneArrowHead(true, 'green')}></span>
						<div style={node('on', 'green')}>
							<span style={nodeEyebrow(GREEN_INK)}>your code</span>
							<span style={nodeName}>onSubmit(values)</span>
						</div>
					</div>
					<div style={lane}>
						<span style={laneTag(false, 'red')}>invalid</span>
						<span style={laneArrowLine(false, 'red')}></span><span style={laneArrowHead(false, 'red')}></span>
						<div style={node('off', 'red')}>
							<span style={nodeEyebrow(DIM_INK)}>RHF</span>
							<span style={nodeName}>formState.errors</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>
				Valid: <code style={codeInline}>onSubmit</code> receives clean, typed <code style={codeInline}>values</code> &mdash; your code runs and calls <code style={codeInline}>createInvoice</code>.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 5: Invalid — onSubmit skipped, formState.errors populated ---- */}
	<DiagramStep
		caption="On invalid: RHF skips onSubmit entirely and populates formState.errors instead, so each field can render its message. An optional second argument, handleSubmit(onSubmit, onInvalid), lets you also run code on the invalid branch."
	>
		<div style={stage}>
			<div style={banner(RED, RED_BG, RED_INK)}>
				<span style={bannerEyebrow(RED_INK)}>invalid path</span>
				<span><code style={monoTag}>onSubmit</code> is skipped &mdash; <code style={monoTag}>formState.errors</code> is populated instead</span>
			</div>
			<div style={graph}>
				<div style={termCol}>
					<div style={node('done', 'blue')}>
						<span style={nodeEyebrow(BLUE_INK)}>user</span>
						<span style={nodeName}>Submit</span>
					</div>
					<span style={nodePill(BORDER, '#ffffff', INK_SOFT)}>intercepted</span>
				</div>
				<span style={arrowH(true)}><span style={arrowLine(true)}></span><span style={arrowHead(true)}></span></span>
				<div style={node('done', 'amber')}>
					<span style={nodeEyebrow(BLUE_INK)}>RHF</span>
					<span style={nodeName}>Validate</span>
				</div>
				<span style={forkWrap}>
					<span style={forkStem(true)}></span>
					<span style={forkBracket(true)}></span>
				</span>
				<div style={fork}>
					<div style={lane}>
						<span style={laneTag(false, 'green')}>valid</span>
						<span style={laneArrowLine(false, 'green')}></span><span style={laneArrowHead(false, 'green')}></span>
						<div style={node('skip', 'green')}>
							<span style={nodeEyebrow(DIM_INK)}>skipped</span>
							<span style={nodeName}>onSubmit(values)</span>
						</div>
					</div>
					<div style={lane}>
						<span style={laneTag(true, 'red')}>invalid</span>
						<span style={laneArrowLine(true, 'red')}></span><span style={laneArrowHead(true, 'red')}></span>
						<div style={node('on', 'red')}>
							<span style={nodeEyebrow(RED_INK)}>RHF</span>
							<span style={nodeName}>formState.errors</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(RED_INK)}>
				Invalid: <code style={codeInline}>onSubmit</code> never runs; RHF fills <code style={codeInline}>formState.errors</code> so each field shows its message.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
