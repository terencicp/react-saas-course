---
// primitive-map — Chapter 045 Lesson 2, "The five RHF primitives".
//
// The lesson's spine, made spatial: a form has exactly THREE CONCERNS, and
// every RHF primitive answers one of them. The whole job of this figure is to
// fix, at a glance, which primitive owns which job — so every later section in
// the lesson slots into a known place.
//
//   [ Get values in & track ]  [ Submit ]  [ Read state out ]
//        register / Controller    handleSubmit   formState / watch
//   ────────────────────────────────────────────────────────────────
//   [           useForm  — the container, produces everything above        ]
//
// Three concern columns across the top, each with a tinted header and the
// primitive name(s) under it as monospace "chips" with a quiet sub-label.
// Beneath them, spanning the full width as a base/foundation row, a single wide
// `useForm` chip — visually the root the three columns sit on. No arrows: the
// spatial grouping (columns over a shared base) carries the meaning.
//
// Plain HTML + CSS, inline styles only, devtools-inspectable — matches the
// house style of the chapter's other figures (NameThreePlaces / SameSiteMatrix
// / ReactRightsPanel): a `not-content` wrapper, `margin: 0` on every inner node
// to defeat Starlight's injected prose margins, `box-sizing: border-box`
// throughout, and theme-aware Starlight gray variables for chrome. The three
// concern accents are hue-only (sky / amber / violet) applied as a translucent
// `color-mix` fill + a same-hue border and header text, so they read in both
// light and dark theme without pinning a color scheme. The `useForm` base row
// is deliberately the most saturated element on the card so it reads as the
// root. Wrapped in <Figure> from the MDX (caption lives there).

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Three concern accents — hue only. color-mix against the card background keeps
// the fill quiet in both themes; the same hue paints the header text + border.
const SKY = "#0ea5e9"; // concern 1 — get values in & track
const AMBER = "#f59e0b"; // concern 2 — submit
const VIOLET = "#8b5cf6"; // concern 3 — read state out

// The three concerns, left -> right. `chips` are the primitives that answer it;
// each chip carries a monospace `name` and a short `sub` clarifier.
const concerns = [
  {
    n: 1,
    accent: SKY,
    title: "Get values in & track",
    chips: [
      { name: "register", sub: "native inputs" },
      { name: "Controller / useController", sub: "UI-library inputs" },
    ],
  },
  {
    n: 2,
    accent: AMBER,
    title: "Submit",
    chips: [{ name: "handleSubmit", sub: "intercept · validate · hand off" }],
  },
  {
    n: 3,
    accent: VIOLET,
    title: "Read state out",
    chips: [
      { name: "formState", sub: "errors, submitting, dirty" },
      { name: "watch / useWatch", sub: "live values" },
    ],
  },
];

// ---- styles --------------------------------------------------------------

const root = [
  reset,
  sans,
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// The three concern columns. A fixed 3-track grid so the columns always read
// side by side as "the three concerns"; equal tracks keep them visually peer.
const columns = [
  reset,
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  "gap: 12px",
  "align-items: stretch",
  "box-sizing: border-box",
].join("; ");

// One concern column: a tinted header pill, then a stack of primitive chips.
const column = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "min-width: 0",
  "box-sizing: border-box",
].join("; ");

// Concern header — a small index badge + the concern name, tinted by accent.
const colHead = (accent: string) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "gap: 8px",
    "padding: 8px 10px",
    "border-radius: 9px",
    `border: 1px solid color-mix(in srgb, ${accent} 55%, transparent)`,
    `background: color-mix(in srgb, ${accent} 14%, var(--sl-color-bg-sidebar))`,
    "box-sizing: border-box",
  ].join("; ");

const headBadge = (accent: string) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "flex: none",
    "width: 20px",
    "height: 20px",
    "border-radius: 999px",
    `background: ${accent}`,
    "color: #ffffff",
    "font-size: 11px",
    "font-weight: 800",
    "line-height: 1",
  ].join("; ");

const headText = (accent: string) =>
  [
    reset,
    sans,
    "font-size: 12.5px",
    "font-weight: 700",
    "letter-spacing: 0.01em",
    "line-height: 1.15",
    `color: color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
    "min-width: 0",
  ].join("; ");

// A primitive chip: monospace name + quiet sub-label. Neutral chrome so the
// concern accent (the header) stays the grouping signal, not the chip color.
const chip = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 3px",
  "flex: 1 1 auto",
  "padding: 9px 11px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.03))",
  "box-sizing: border-box",
  "min-width: 0",
].join("; ");

const chipName = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
  "overflow-wrap: anywhere",
].join("; ");

const chipSub = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 400",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The base / foundation row: useForm. Saturated emerald so it reads as the
// root the three columns sit on; spans the full width under them.
const FORM = "#059669"; // emerald-600 — reads on white and near-black

const baseRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: baseline",
  "column-gap: 12px",
  "row-gap: 4px",
  "padding: 11px 14px",
  "border-radius: 10px",
  `background: ${FORM}`,
  `box-shadow: 0 1px 0 color-mix(in srgb, ${FORM} 60%, #000)`,
  "box-sizing: border-box",
].join("; ");

const baseTag = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 800",
  "letter-spacing: 0.08em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: rgba(255, 255, 255, 0.82)",
  "flex: none",
].join("; ");

const baseName = [
  reset,
  mono,
  "font-size: 15px",
  "font-weight: 800",
  "line-height: 1.15",
  "color: #ffffff",
  "flex: none",
].join("; ");

const baseSub = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: rgba(255, 255, 255, 0.9)",
  "min-width: 0",
].join("; ");
---

<div class="not-content" style={root}>
  {/* The three concern columns */}
  <div style={columns}>
    {
      concerns.map((c) => (
        <div style={column}>
          <div style={colHead(c.accent)}>
            <span style={headBadge(c.accent)}>{c.n}</span>
            <span style={headText(c.accent)}>{c.title}</span>
          </div>
          {c.chips.map((chipItem) => (
            <div style={chip}>
              <span style={chipName}>{chipItem.name}</span>
              <span style={chipSub}>{chipItem.sub}</span>
            </div>
          ))}
        </div>
      ))
    }
  </div>

  {/* The base / foundation row — useForm is the root the columns sit on */}
  <div style={baseRow}>
    <span style={baseTag}>the container</span>
    <span style={baseName}>useForm</span>
    <span style={baseSub}>called once — produces every primitive above</span>
  </div>
</div>
