---
// Diagram: wizard context vs prop-drilling (diagram id:
// wizard-context-vs-prop-drilling, Chapter 045 Lesson 5 — "Multi-step wizards
// with FormProvider"). The *why* of FormProvider, shown as a side-by-side
// contrast of two layouts of the SAME 3-step invoice wizard:
//
//   PANEL A — "Without a shared context (prop-drilling)". A `Root (holds form)`
//   box on top, the three step boxes (CustomerStep / LineItemsStep /
//   ReviewStep) stacked below it. Three arrows fan from the Root down to each
//   step, EVERY one carrying the same `register / control / errors` payload.
//   Tinted muted orange. The goal is NOISE: the same payload hand-delivered
//   three times, curves fanning across the panel.
//
//   PANEL B — "With FormProvider". The same `Root (holds form)` box on top, but
//   now the three steps live INSIDE an enclosing tinted region labelled
//   "FormProvider context", together with a small shared `form` node. Three
//   short arrows connect that one shared node to each step — no labels, no
//   payload threaded. Tinted calm teal. The goal is CALM: one shared source
//   nested with the steps, short hops, nothing hand-delivered.
//
// The contrast carries the whole lesson point — the left panel's arrows are
// heavy (props) and travel from an OUTSIDE root; the right panel's arrows are
// bare and stay INSIDE the provider region. The step number is deliberately
// absent from both form boxes: the form holds field data, navigation lives
// elsewhere (the lesson's spine).
//
// Two independent ArrowDiagram stages (arrows are looked up per-stage by
// getElementById, so the two panels' IDs never cross-wire) laid out in a
// 2-column grid. House style mirrors the chapter's other arrow figures
// (DerivationFanout / FormContextBroadcast): pinned `color-scheme: light` so
// the hand-picked tints survive dark mode, inline style strings with
// `box-sizing: border-box` + `margin: 0` throughout to defeat Starlight's
// injected prose margins. ArrowDiagram uses leader-line positioned from
// document.body, so the wrapping <Figure> sets `expandable={false}`.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text / chrome
const SURFACE = '#ffffff';
const PANEL_BORDER = '#e2e8f0'; // slate-200 — neutral chrome
const PANEL_BG = '#f8fafc'; // slate-50 — step wash

const ORANGE = '#ea580c'; // prop-drilling pain — muted orange
const TEAL = '#0d9488'; // shared-context calm — teal-600

// ---- layout --------------------------------------------------------------
// two equal panels side by side; collapses to one column on narrow screens
// (the within-panel arrows are vertical-ish, so a stack degrades gracefully).
const grid = [
  'box-sizing: border-box',
  'margin: 0',
  'display: grid',
  'grid-template-columns: repeat(auto-fit, minmax(260px, 1fr))',
  'gap: 22px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
  'padding: 6px 4px',
].join('; ');

// `padRight` reserves a right-hand lane inside Panel A for its loop-back curves
// (sockets on the right, curves bow into the margin); Panel B doesn't need it.
const panel = (accent: string, padRight = 14) =>
  [
    'box-sizing: border-box',
    'margin: 0',
    'display: flex',
    'flex-direction: column',
    'gap: 6px',
    'min-width: 0',
    `padding: 12px ${padRight}px 16px 14px`,
    'border-radius: 14px',
    `border: 1px solid ${PANEL_BORDER}`,
    `background: ${SURFACE}`,
  ].join('; ');

const panelHead = (accent: string) =>
  [
    'box-sizing: border-box',
    'margin: 0 0 4px',
    'display: flex',
    'align-items: center',
    'gap: 8px',
    'padding: 6px 10px',
    'border-radius: 9px',
    `border: 1px solid color-mix(in srgb, ${accent} 45%, transparent)`,
    `background: color-mix(in srgb, ${accent} 11%, ${SURFACE})`,
  ].join('; ');

const panelDot = (accent: string) =>
  [
    'flex: 0 0 auto',
    'width: 7px',
    'height: 7px',
    'border-radius: 999px',
    `background: ${accent}`,
    'margin: 0',
  ].join('; ');

const panelTitle = (accent: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 11.5px',
    'font-weight: 800',
    'letter-spacing: 0.01em',
    'line-height: 1.25',
    `color: color-mix(in srgb, ${accent} 72%, ${INK})`,
  ].join('; ');

// ---- the Root (holds form) box, shared shape across both panels -----------
const rootBox = (accent: string) =>
  [
    'box-sizing: border-box',
    'align-self: center',
    'display: inline-flex',
    'align-items: baseline',
    'gap: 8px',
    'margin: 0',
    'padding: 8px 13px',
    'border-radius: 10px',
    `border: 1.5px solid ${accent}`,
    `background: color-mix(in srgb, ${accent} 10%, ${SURFACE})`,
  ].join('; ');

const rootName = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 13px',
  'font-weight: 800',
  `color: ${INK}`,
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

const rootTag = (accent: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 9.5px',
    'font-weight: 800',
    'letter-spacing: 0.04em',
    'text-transform: uppercase',
    `color: color-mix(in srgb, ${accent} 70%, ${INK_SOFT})`,
    'line-height: 1',
    'white-space: nowrap',
  ].join('; ');

// ---- step boxes (Panel A) -------------------------------------------------
// Left-aligned, content-width: leaves a right-hand lane the prop-drilling
// curves bow into (sockets on the right). Bigger row gap so three curves +
// labels fit between the stacked boxes.
const stepCol = [
  'box-sizing: border-box',
  'margin: 0',
  'display: flex',
  'flex-direction: column',
  'align-items: flex-start',
  'gap: 16px',
].join('; ');

const stepBox = [
  'box-sizing: border-box',
  'margin: 0',
  'padding: 7px 13px',
  'border-radius: 9px',
  `border: 1.5px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
  `font-family: ${mono}`,
  'font-size: 12px',
  'font-weight: 700',
  `color: ${INK}`,
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

// ---- the FormProvider region (panel B only) -------------------------------
const providerRegion = [
  'box-sizing: border-box',
  'margin: 0',
  'display: flex',
  'flex-direction: column',
  'gap: 12px',
  'padding: 12px 14px 14px',
  'border-radius: 13px',
  `border: 1.5px dashed ${TEAL}`,
  `background: color-mix(in srgb, ${TEAL} 6%, ${SURFACE})`,
].join('; ');

const providerLabel = [
  'box-sizing: border-box',
  'align-self: flex-start',
  'display: inline-flex',
  'align-items: center',
  'gap: 6px',
  'margin: 0',
  'padding: 3px 9px',
  'border-radius: 999px',
  `border: 1px solid color-mix(in srgb, ${TEAL} 45%, transparent)`,
  `background: color-mix(in srgb, ${TEAL} 13%, ${SURFACE})`,
  `font-family: ${mono}`,
  'font-size: 10px',
  'font-weight: 800',
  'letter-spacing: 0.02em',
  `color: ${TEAL}`,
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

// the small shared `form` node — the one instance every step reaches.
const sharedNode = [
  'box-sizing: border-box',
  'align-self: center',
  'display: inline-flex',
  'flex-direction: column',
  'align-items: center',
  'gap: 1px',
  'margin: 0',
  'padding: 6px 14px',
  'border-radius: 999px',
  `border: 1.5px solid ${TEAL}`,
  `background: color-mix(in srgb, ${TEAL} 14%, ${SURFACE})`,
].join('; ');

const sharedName = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 13px',
  'font-weight: 800',
  `color: color-mix(in srgb, ${TEAL} 82%, ${INK})`,
  'line-height: 1.15',
].join('; ');

const sharedSub = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9px',
  'font-weight: 700',
  'letter-spacing: 0.03em',
  'text-transform: uppercase',
  `color: ${INK_SOFT}`,
  'line-height: 1.15',
].join('; ');

const stepRow = [
  'box-sizing: border-box',
  'margin: 0',
  'display: grid',
  'grid-template-columns: repeat(3, 1fr)',
  'gap: 9px',
].join('; ');

const stepChip = [
  'box-sizing: border-box',
  'margin: 0',
  'padding: 6px 4px',
  'border-radius: 9px',
  `border: 1.5px solid color-mix(in srgb, ${TEAL} 35%, ${PANEL_BORDER})`,
  `background: ${SURFACE}`,
  `font-family: ${mono}`,
  'font-size: 10.5px',
  'font-weight: 700',
  `color: ${INK}`,
  'line-height: 1.2',
  'text-align: center',
  'white-space: nowrap',
].join('; ');

const steps = [
  { idA: 'wcd-a-customer', idB: 'wcd-b-customer', label: 'CustomerStep' },
  { idA: 'wcd-a-lineitems', idB: 'wcd-b-lineitems', label: 'LineItemsStep' },
  { idA: 'wcd-a-review', idB: 'wcd-b-review', label: 'ReviewStep' },
] as const;

// ---- arrows ---------------------------------------------------------------
// One stage, all six arrows. Two ArrowDiagram instances on one page each emit
// their own inline build script and each rebuilds EVERY stage, double-drawing
// the lines — so both panels share a single ArrowDiagram. Arrows are looked up
// by id within the one stage, and the two panels sit far apart, so Panel A's
// orange fan stays in the left column and Panel B's teal fan in the right.
//
// Panel A: Root -> each step, every arrow carrying the same prop payload. The
// root and the steps both expose their RIGHT socket, so the three curves swing
// out into the reserved right lane (never crossing a box face) and drop to each
// step. Staggered gravity fans them into distinct lanes; the (deliberately
// identical) payload label repeats three times — that repetition IS the noise.
const PROPS = 'register / control / errors';
const arrows = [
  {
    from: 'wcd-a-root',
    to: 'wcd-a-customer',
    label: PROPS,
    color: ORANGE,
    startSocket: 'right' as const,
    endSocket: 'right' as const,
    startSocketGravity: [44, 6] as [number, number],
    endSocketGravity: [60, 0] as [number, number],
    labelOffset: [4, -16] as [number, number],
  },
  {
    from: 'wcd-a-root',
    to: 'wcd-a-lineitems',
    label: PROPS,
    color: ORANGE,
    startSocket: 'right' as const,
    endSocket: 'right' as const,
    startSocketGravity: [82, 0] as [number, number],
    endSocketGravity: [82, 0] as [number, number],
    labelOffset: [10, 0] as [number, number],
  },
  {
    from: 'wcd-a-root',
    to: 'wcd-a-review',
    label: PROPS,
    color: ORANGE,
    startSocket: 'right' as const,
    endSocket: 'right' as const,
    startSocketGravity: [120, -6] as [number, number],
    endSocketGravity: [60, 0] as [number, number],
    labelOffset: [4, 16] as [number, number],
  },

  // Panel B: the one shared `form` node -> each step. Short, bare (no labels),
  // fanned just enough to separate the curves. The heads land on three distinct
  // step chips, so nothing stacks.
  {
    from: 'wcd-b-form',
    to: 'wcd-b-customer',
    color: TEAL,
    startSocket: 'bottom' as const,
    endSocket: 'top' as const,
    startSocketGravity: [-34, 26] as [number, number],
    endSocketGravity: [0, -26] as [number, number],
  },
  {
    from: 'wcd-b-form',
    to: 'wcd-b-lineitems',
    color: TEAL,
    startSocket: 'bottom' as const,
    endSocket: 'top' as const,
    startSocketGravity: [0, 30] as [number, number],
    endSocketGravity: [0, -30] as [number, number],
  },
  {
    from: 'wcd-b-form',
    to: 'wcd-b-review',
    color: TEAL,
    startSocket: 'bottom' as const,
    endSocket: 'top' as const,
    startSocketGravity: [34, 26] as [number, number],
    endSocketGravity: [0, -26] as [number, number],
  },
];
---

<Figure expandable={false}>
  <ArrowDiagram arrows={arrows}>
    <div class="not-content" style={grid}>
      {/* ============ PANEL A — prop-drilling ============ */}
      {/* extra right padding reserves the lane the loop-back curves bow into */}
      <div style={panel(ORANGE, 150)}>
        <div style={panelHead(ORANGE)}>
          <span style={panelDot(ORANGE)}></span>
          <span style={panelTitle(ORANGE)}>Without a shared context (prop-drilling)</span>
        </div>
        <div style={rootBox(ORANGE)} id="wcd-a-root">
          <span style={rootName}>Root</span>
          <span style={rootTag(ORANGE)}>holds form</span>
        </div>
        {/* spacer so the fanning arrows have vertical room below the root */}
        <div style="height: 14px; margin: 0;"></div>
        <div style={stepCol}>
          {
            steps.map((s) => (
              <div style={stepBox} id={s.idA}>
                {s.label}
              </div>
            ))
          }
        </div>
      </div>

      {/* ============ PANEL B — FormProvider ============ */}
      <div style={panel(TEAL)}>
        <div style={panelHead(TEAL)}>
          <span style={panelDot(TEAL)}></span>
          <span style={panelTitle(TEAL)}>With FormProvider</span>
        </div>
        <div style={rootBox(TEAL)} id="wcd-b-root">
          <span style={rootName}>Root</span>
          <span style={rootTag(TEAL)}>holds form</span>
        </div>
        <div style="height: 6px; margin: 0;"></div>
        <div style={providerRegion}>
          <span style={providerLabel}>FormProvider context</span>
          <div style={sharedNode} id="wcd-b-form">
            <span style={sharedName}>form</span>
            <span style={sharedSub}>shared instance</span>
          </div>
          <div style={stepRow}>
            {
              steps.map((s) => (
                <div style={stepChip} id={s.idB}>
                  {s.label}
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </ArrowDiagram>
  <Fragment slot="caption">
    The same wizard, two ways to share one form. Without a context the root
    hand-delivers the form to every step; <code>FormProvider</code> publishes it
    once and each step reaches it directly.
  </Fragment>
</Figure>
