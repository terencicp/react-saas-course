---
// Validation scope: per-step `trigger` vs final `handleSubmit` (diagram id:
// validation-scope-next-vs-submit, Chapter 045 Lesson 5 — "Multi-step wizards
// with FormProvider"). A four-step scrubbable DiagramSequence that makes the
// lesson's hardest distinction concrete: which fields the resolver runs against,
// and which API drove it.
//
// The persistent layout — identical in shape across ALL four steps so the grid
// stack never reflows — is a horizontal row of three "step group" cards:
//
//   Step 1 group: two field cells (`customer`, `email`).
//   Step 2 group: two array cells (`lineItems[0]`, `lineItems[1]`) + a thin
//                 full-width bar `lineItems (min 1)` for the array-level rule.
//   Step 3 group: one cell `review` + a full-width bar `total > 0` for the
//                 cross-step refinement.
//
//   Step A  trigger(['customer','email'])  — only Step 1's two cells pass (green);
//                                             Steps 2 & 3 dimmed/neutral.
//   Step B  trigger('lineItems')           — only Step 2's cells + the min-1 bar
//                                             pass; Steps 1 & 3 dimmed/neutral.
//   Step C  handleSubmit()                 — EVERY cell across all three groups
//                                             passes at once (the whole schema).
//   Step D  handleSubmit() (rule fails)    — same whole-schema gate, but the
//                                             cross-step `total > 0` bar fails
//                                             (red) while the field cells stay
//                                             green: a rule no single field could
//                                             check, failing only at the final gate.
//
// Each tick is data-driven from `stepConfig`: a per-step record of which groups
// are "active" (the resolver ran against them — bright accent ring + an API
// badge) and the state of each cell/bar (`neutral` | `pass` | `fail`). The
// markup is one shared render loop, so the three cards keep identical geometry
// and only their state classes swap between ticks.
//
// House style mirrors this chapter's other figures (WizardContextVsPropDrilling,
// and PositionMatchSequence's DiagramSequence): pinned `color-scheme: light` so
// the hand-picked tints survive dark mode, slate ink, inline style strings with
// `box-sizing: border-box` + `margin: 0` throughout to defeat Starlight's
// injected prose margins. DiagramSequence supplies its own card — NOT wrapped in
// <Figure>.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text / chrome
const SURFACE = '#ffffff';
const BORDER = '#e2e8f0'; // slate-200 — neutral chrome

const ACCENT = '#4f46e5'; // indigo-600 — the "active / validating now" accent
const GREEN = '#16a34a'; // green-600 — validated and passing
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#15803d'; // green-700
const RED = '#dc2626'; // red-600 — validated and failing
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#b91c1c'; // red-700

// ---- stage: three group cards in a row, identical shape every step --------
const stage = [
  'box-sizing: border-box',
  'margin: 0',
  'display: grid',
  'grid-template-columns: repeat(3, 1fr)',
  'gap: 12px',
  'align-items: start',
  'padding: 4px 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// A group card. `active` brightens it (accent ring + lifted surface); inactive
// groups dim back so the eye lands on what the resolver is checking this tick.
const groupCard = (active: boolean) =>
  [
    'box-sizing: border-box',
    'margin: 0',
    'display: flex',
    'flex-direction: column',
    'gap: 8px',
    'min-width: 0',
    'padding: 10px 10px 12px',
    'border-radius: 12px',
    `border: 1.5px solid ${active ? ACCENT : BORDER}`,
    `background: ${active ? `color-mix(in srgb, ${ACCENT} 5%, ${SURFACE})` : SURFACE}`,
    active
      ? `box-shadow: 0 0 0 3px color-mix(in srgb, ${ACCENT} 14%, transparent)`
      : 'box-shadow: none',
    `opacity: ${active ? '1' : '0.5'}`,
    'transition: opacity 0.15s, border-color 0.15s, box-shadow 0.15s',
  ].join('; ');

// Card header: the step label on the left, the driving-API badge on the right.
const groupHead = [
  'box-sizing: border-box',
  'margin: 0',
  'display: flex',
  'align-items: center',
  'justify-content: space-between',
  'gap: 6px',
  'min-height: 22px',
].join('; ');

const groupLabel = (active: boolean) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 11px',
    'font-weight: 800',
    'letter-spacing: 0.04em',
    'text-transform: uppercase',
    `color: ${active ? ACCENT : INK_SOFT}`,
    'line-height: 1',
    'white-space: nowrap',
  ].join('; ');

// The API badge: only shown on an active group; its text is the driving call.
const apiBadge = [
  'box-sizing: border-box',
  'margin: 0',
  'padding: 2px 7px',
  'border-radius: 6px',
  `border: 1px solid color-mix(in srgb, ${ACCENT} 40%, transparent)`,
  `background: color-mix(in srgb, ${ACCENT} 12%, ${SURFACE})`,
  `font-family: ${mono}`,
  'font-size: 9.5px',
  'font-weight: 700',
  'letter-spacing: 0',
  `color: ${ACCENT}`,
  'line-height: 1.3',
  'white-space: nowrap',
].join('; ');

// A field cell. Three visual states keyed by `state`.
const cellBase = [
  'box-sizing: border-box',
  'margin: 0',
  'display: flex',
  'align-items: center',
  'gap: 6px',
  'padding: 6px 9px',
  'border-radius: 8px',
  `font-family: ${mono}`,
  'font-size: 11.5px',
  'font-weight: 700',
  'line-height: 1.25',
  'white-space: nowrap',
  'transition: background-color 0.15s, border-color 0.15s, color 0.15s',
];

type CellState = 'neutral' | 'pass' | 'fail';

const cell = (state: CellState) => {
  if (state === 'pass')
    return [...cellBase, `color: ${GREEN_INK}`, `background: ${GREEN_BG}`, `border: 1.5px solid ${GREEN}`].join('; ');
  if (state === 'fail')
    return [...cellBase, `color: ${RED_INK}`, `background: ${RED_BG}`, `border: 1.5px solid ${RED}`].join('; ');
  return [...cellBase, `color: ${INK_SOFT}`, `background: ${SURFACE}`, `border: 1.5px solid ${BORDER}`].join('; ');
};

// Status glyph that rides inside a cell/bar: check on pass, cross on fail, dot otherwise.
const glyph = (state: CellState) =>
  [
    'flex: 0 0 auto',
    'display: inline-flex',
    'align-items: center',
    'justify-content: center',
    'width: 13px',
    'height: 13px',
    'border-radius: 999px',
    'margin: 0',
    'font-size: 9px',
    'font-weight: 900',
    'line-height: 1',
    state === 'pass'
      ? `background: ${GREEN}; color: #fff`
      : state === 'fail'
        ? `background: ${RED}; color: #fff`
        : `background: color-mix(in srgb, ${INK_SOFT} 22%, transparent); color: ${INK_SOFT}`,
  ].join('; ');

const glyphChar = (state: CellState) => (state === 'pass' ? '✓' : state === 'fail' ? '✕' : '·');

// The full-width rule bar (array min-1, cross-step total>0). Same states, but
// spans the card and reads as a rule rather than a field.
const ruleBar = (state: CellState) => {
  const accent = state === 'pass' ? GREEN : state === 'fail' ? RED : INK_SOFT;
  const wash =
    state === 'pass'
      ? GREEN_BG
      : state === 'fail'
        ? RED_BG
        : `color-mix(in srgb, ${INK_SOFT} 7%, ${SURFACE})`;
  const ink = state === 'pass' ? GREEN_INK : state === 'fail' ? RED_INK : INK_SOFT;
  return [
    'box-sizing: border-box',
    'margin: 2px 0 0',
    'display: flex',
    'align-items: center',
    'gap: 6px',
    'padding: 5px 9px',
    'border-radius: 8px',
    `border: 1.5px dashed ${accent}`,
    `background: ${wash}`,
    `font-family: ${mono}`,
    'font-size: 10px',
    'font-weight: 700',
    `color: ${ink}`,
    'line-height: 1.2',
    'white-space: nowrap',
    'transition: background-color 0.15s, border-color 0.15s, color 0.15s',
  ].join('; ');
};

const ruleTag = (state: CellState) =>
  [
    'flex: 0 0 auto',
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 8px',
    'font-weight: 800',
    'letter-spacing: 0.04em',
    'text-transform: uppercase',
    'padding: 1px 5px',
    'border-radius: 4px',
    'color: #fff',
    `background: ${state === 'pass' ? GREEN : state === 'fail' ? RED : INK_SOFT}`,
    'line-height: 1.3',
  ].join('; ');

// ---- the three groups (constant geometry) and per-step state --------------
// `cells` / `rule` are keyed slots; each step below supplies their CellState.
const groups = [
  {
    key: 'one',
    label: 'Step 1',
    cells: [
      { id: 'customer', text: 'customer' },
      { id: 'email', text: 'email' },
    ],
    rule: null as null | { id: string; tag: string; text: string },
  },
  {
    key: 'two',
    label: 'Step 2',
    cells: [
      { id: 'li0', text: 'lineItems[0]' },
      { id: 'li1', text: 'lineItems[1]' },
    ],
    rule: { id: 'liMin', tag: 'array rule', text: 'lineItems (min 1)' },
  },
  {
    key: 'three',
    label: 'Step 3',
    cells: [{ id: 'review', text: 'review' }],
    rule: { id: 'total', tag: 'cross-step', text: 'total > 0' },
  },
] as const;

type StepTick = {
  active: Record<string, string | undefined>; // group.key -> API badge text (present => active)
  states: Record<string, CellState>; // cell/rule id -> state (missing => neutral)
};

const stTrigger1 = "trigger(['customer', 'email'])";
const stTrigger2 = "trigger('lineItems')";
const stSubmit = 'handleSubmit()';

const ticks: StepTick[] = [
  // A — Next on step 1
  {
    active: { one: stTrigger1 },
    states: { customer: 'pass', email: 'pass' },
  },
  // B — Next on step 2
  {
    active: { two: stTrigger2 },
    states: { li0: 'pass', li1: 'pass', liMin: 'pass' },
  },
  // C — final submit, whole schema passes
  {
    active: { one: stSubmit, two: stSubmit, three: stSubmit },
    states: {
      customer: 'pass',
      email: 'pass',
      li0: 'pass',
      li1: 'pass',
      liMin: 'pass',
      review: 'pass',
      total: 'pass',
    },
  },
  // D — final submit, cross-step rule fails
  {
    active: { one: stSubmit, two: stSubmit, three: stSubmit },
    states: {
      customer: 'pass',
      email: 'pass',
      li0: 'pass',
      li1: 'pass',
      liMin: 'pass',
      review: 'pass',
      total: 'fail',
    },
  },
];

const state = (tick: StepTick, id: string): CellState => tick.states[id] ?? 'neutral';
---

<DiagramSequence>
  <DiagramStep caption="trigger(['customer', 'email']) — Next on step 1 runs the resolver against these two fields only. Steps 2 and 3 are untouched.">
    <div style={stage}>
      {
        groups.map((g) => {
          const tick = ticks[0];
          const badge = tick.active[g.key];
          const active = Boolean(badge);
          return (
            <div style={groupCard(active)}>
              <div style={groupHead}>
                <span style={groupLabel(active)}>{g.label}</span>
                {badge && <span style={apiBadge}>{badge}</span>}
              </div>
              {g.cells.map((c) => {
                const s = state(tick, c.id);
                return (
                  <span style={cell(s)}>
                    <span style={glyph(s)} aria-hidden="true">
                      {glyphChar(s)}
                    </span>
                    {c.text}
                  </span>
                );
              })}
              {g.rule && (
                <span style={ruleBar(state(tick, g.rule.id))}>
                  <span style={ruleTag(state(tick, g.rule.id))}>{g.rule.tag}</span>
                  {g.rule.text}
                </span>
              )}
            </div>
          );
        })
      }
    </div>
  </DiagramStep>

  <DiagramStep caption="Each step gates on its own fields. Next on step 2 validates the line items and the array's min-1 rule — nothing else.">
    <div style={stage}>
      {
        groups.map((g) => {
          const tick = ticks[1];
          const badge = tick.active[g.key];
          const active = Boolean(badge);
          return (
            <div style={groupCard(active)}>
              <div style={groupHead}>
                <span style={groupLabel(active)}>{g.label}</span>
                {badge && <span style={apiBadge}>{badge}</span>}
              </div>
              {g.cells.map((c) => {
                const s = state(tick, c.id);
                return (
                  <span style={cell(s)}>
                    <span style={glyph(s)} aria-hidden="true">
                      {glyphChar(s)}
                    </span>
                    {c.text}
                  </span>
                );
              })}
              {g.rule && (
                <span style={ruleBar(state(tick, g.rule.id))}>
                  <span style={ruleTag(state(tick, g.rule.id))}>{g.rule.tag}</span>
                  {g.rule.text}
                </span>
              )}
            </div>
          );
        })
      }
    </div>
  </DiagramStep>

  <DiagramStep caption="handleSubmit on the final step runs the resolver against the whole schema — every field, all at once. This is the final gate.">
    <div style={stage}>
      {
        groups.map((g) => {
          const tick = ticks[2];
          const badge = tick.active[g.key];
          const active = Boolean(badge);
          return (
            <div style={groupCard(active)}>
              <div style={groupHead}>
                <span style={groupLabel(active)}>{g.label}</span>
                {badge && <span style={apiBadge}>{badge}</span>}
              </div>
              {g.cells.map((c) => {
                const s = state(tick, c.id);
                return (
                  <span style={cell(s)}>
                    <span style={glyph(s)} aria-hidden="true">
                      {glyphChar(s)}
                    </span>
                    {c.text}
                  </span>
                );
              })}
              {g.rule && (
                <span style={ruleBar(state(tick, g.rule.id))}>
                  <span style={ruleTag(state(tick, g.rule.id))}>{g.rule.tag}</span>
                  {g.rule.text}
                </span>
              )}
            </div>
          );
        })
      }
    </div>
  </DiagramStep>

  <DiagramStep caption="The whole-schema gate is also where cross-step rules fire — total > 0, which no single field could check alone, fails here even though every field passes.">
    <div style={stage}>
      {
        groups.map((g) => {
          const tick = ticks[3];
          const badge = tick.active[g.key];
          const active = Boolean(badge);
          return (
            <div style={groupCard(active)}>
              <div style={groupHead}>
                <span style={groupLabel(active)}>{g.label}</span>
                {badge && <span style={apiBadge}>{badge}</span>}
              </div>
              {g.cells.map((c) => {
                const s = state(tick, c.id);
                return (
                  <span style={cell(s)}>
                    <span style={glyph(s)} aria-hidden="true">
                      {glyphChar(s)}
                    </span>
                    {c.text}
                  </span>
                );
              })}
              {g.rule && (
                <span style={ruleBar(state(tick, g.rule.id))}>
                  <span style={ruleTag(state(tick, g.rule.id))}>{g.rule.tag}</span>
                  {g.rule.text}
                </span>
              )}
            </div>
          );
        })
      }
    </div>
  </DiagramStep>
</DiagramSequence>
