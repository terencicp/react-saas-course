---
// key-bug-scrub — Chapter 045 Lesson 4, "useFieldArray: dynamic lists".
//
// The index-vs-id keying bug, made viscerally visible. This is the highest-value
// correctness point in the lesson and the one prose cannot prove: with
// key={index}, removing a NON-LAST row makes React reuse DOM nodes by position,
// so the focused input + half-typed text silently teleport to the wrong row.
// With key={field.id} the node follows the row's identity and nothing jumps.
//
// Each step is a side-by-side comparison: the SAME three-row list rendered two
// ways — left column keyed by array index, right column keyed by field.id. A
// focus ring + the half-typed value "Desig…" + a caret mark row C the whole way
// through; the reader watches where it lands as row B is removed.
//
//   1  Three rows A/B/C. C is focused, "Desig…" half-typed. Both columns look
//      identical — the bug is invisible until a remove happens.
//   2  Remove clicked on row B. B drops from the array; A and C remain, and C is
//      now at position 1 (it was 2). Both columns shift the same way.
//   3  key={index}: React matched nodes by position, so position-1's node (which
//      held B) is reused for C's data — but focus + "Desig…" stayed with the
//      physical node, landing on the WRONG row (red). key={field.id}: the node
//      moved with C's identity, ring + text still on C (green).
//   4  Verdict — id tracks identity, so the whole node (value, focus, dirty)
//      moved up with the row. One character's difference, opposite outcomes.
//
// House style follows this chapter's HandleSubmitFlow / the arc's
// KeyChangeRemountSequence: fixed slate ink, color-scheme pinned light so the
// hand-picked blue/amber/green/red tints survive dark mode, `margin: 0` on every
// inner element to defeat Starlight's injected prose margins. Per the diagram
// index a temporal sequence the reader scrubs is a DiagramSequence, panels are
// plain HTML + CSS. This component renders its own card — NOT wrapped in <Figure>.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary input surface
const BORDER = '#cbd5e1'; // ordinary input edge (slate-300)
const COL_BG = '#f8fafc'; // column wash (slate-50)
const COL_BORDER = '#e2e8f0'; // column edge (slate-200)
const LABEL_INK = '#475569'; // field label ink (slate-600)

const BLUE = '#2563eb'; // blue-600 — the live focus ring + caret
const BLUE_BG = '#eff6ff'; // blue-50 — focused-input wash
const BLUE_INK = '#1e40af'; // blue-800

const AMBER = '#d97706'; // amber-600 — the row removed mid-edit
const AMBER_INK = '#92400e'; // amber-800

const RED = '#dc2626'; // red-600 — focus landed on the WRONG row
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800
const GREEN = '#16a34a'; // green-600 — focus stayed on the RIGHT row
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, the two columns in
// a row so all four steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;
const cols = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 18px; margin: 0; width: 100%;`;

// One column: a labeled card holding a vertical stack of row boxes. `accent`
// tints the header chip so the index vs id sides read at a glance.
const column = `display: flex; flex-direction: column; gap: 10px; margin: 0; padding: 12px; border: 1px solid ${COL_BORDER}; border-radius: 12px; background: ${COL_BG}; width: 230px; box-sizing: border-box;`;
const colHead = (accent: string) =>
	`display: inline-flex; align-self: flex-start; align-items: center; margin: 0; padding: 4px 9px; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.3; color: #ffffff; background: ${accent}; border-radius: 7px; white-space: nowrap;`;
const rowStack = `display: flex; flex-direction: column; gap: 8px; margin: 0;`;

// A row = an index chip + a faux "Description" input. `tone` tints the input
// to flag where focus/text landed:
//   plain  — neutral input, no focus
//   focus  — blue ring, the live focused input carrying the typed text
//   wrong  — red ring, focus/text landed on a row that ISN'T the one being typed
//   right  — green ring, focus/text correctly stayed with its row
type Tone = 'plain' | 'focus' | 'wrong' | 'right';
const TONE: Record<Tone, { edge: string; ring: string; bg: string; ink: string }> = {
	plain: { edge: BORDER, ring: 'transparent', bg: SURFACE, ink: INK },
	focus: { edge: BLUE, ring: BLUE, bg: BLUE_BG, ink: BLUE_INK },
	wrong: { edge: RED, ring: RED, bg: RED_BG, ink: RED_INK },
	right: { edge: GREEN, ring: GREEN, bg: GREEN_BG, ink: GREEN_INK },
};

const row = `display: flex; align-items: center; gap: 8px; margin: 0;`;
const idxChip = `display: inline-flex; flex: 0 0 auto; align-items: center; justify-content: center; min-width: 26px; height: 26px; margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; color: ${INK_SOFT}; background: #e2e8f0; border-radius: 6px;`;

// The faux input. A wrapper carries the field label above an input-like box.
const field = `display: flex; flex-direction: column; gap: 3px; margin: 0; flex: 1 1 auto; min-width: 0;`;
const fieldLabel = `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: ${LABEL_INK};`;
const inputBox = (t: Tone) => {
	const c = TONE[t];
	const focused = t !== 'plain';
	return `display: flex; align-items: center; gap: 1px; margin: 0; padding: 6px 9px; min-height: 30px; box-sizing: border-box; border: 1.5px solid ${c.edge}; border-radius: 7px; background: ${c.bg}; font-family: ${sans}; font-size: 13px; font-weight: 500; color: ${c.ink};${focused ? ` outline: 2px solid ${c.ring}; outline-offset: 1px;` : ''}`;
};
const caret = (t: Tone) => `display: inline-block; width: 1.5px; height: 15px; margin: 0; background: ${TONE[t].ring}; border-radius: 1px;`;
const placeholder = `margin: 0; font-style: italic; color: ${INK_SOFT}; opacity: 0.7;`;

// The removed row, shown struck + faded so the stack height stays constant
// across all four steps (no reflow as the reader scrubs).
const removedRow = `display: flex; align-items: center; gap: 8px; margin: 0; opacity: 0.55;`;
const removedField = `display: flex; flex-direction: column; gap: 3px; margin: 0; flex: 1 1 auto; min-width: 0;`;
const removedBox = `display: flex; align-items: center; gap: 6px; margin: 0; padding: 6px 9px; min-height: 30px; box-sizing: border-box; border: 1.5px dashed ${BORDER}; border-radius: 7px; background: transparent; font-family: ${sans}; font-size: 13px; color: ${INK_SOFT}; text-decoration: line-through;`;
const removedTag = `display: inline-block; flex: 0 0 auto; margin: 0; padding: 1px 6px; font-family: ${sans}; font-size: 9px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; text-decoration: none; color: ${AMBER_INK}; background: color-mix(in srgb, ${AMBER} 16%, transparent); border-radius: 4px;`;

// A small phase / status pill heading the stage.
const phase = (bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 7px; margin: 0; padding: 4px 11px; font-family: ${sans}; font-size: 12px; font-weight: 600; line-height: 1.3; color: ${ink}; background: ${bg}; border-radius: 999px; white-space: nowrap;`;
const verdict = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 600; line-height: 1.4; color: ${INK_SOFT}; max-width: 480px; text-align: center;`;
---

<DiagramSequence>
	{/* ---- Step 1: three rows, C focused mid-type, both columns identical ---- */}
	<DiagramStep caption="Three rows. The user is mid-type in row C — focus ring on it, “Desig…” half-entered. Both columns look identical so far.">
		<div style={stage}>
			<span style={phase(BLUE_BG, BLUE_INK)}>Editing row C</span>
			<div style={cols}>
				<div style={column}>
					<span style={colHead(INK_SOFT)}>key=&#123;index&#125;</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('plain')}>Hosting</div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>B · Description</span>
								<div style={inputBox('plain')}>Domain</div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>2</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('focus')}>Desig<span style={caret('focus')}></span></div>
							</div>
						</div>
					</div>
				</div>

				<div style={column}>
					<span style={colHead(BLUE)}>key=&#123;field.id&#125;</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('plain')}>Hosting</div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>B · Description</span>
								<div style={inputBox('plain')}>Domain</div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>2</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('focus')}>Desig<span style={caret('focus')}></span></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Remove B. A and C remain; C moved up to position 1 ---- */}
	<DiagramStep caption="The user clicks Remove on row B. RHF drops B from the array; rows A and C remain, and C is now at position 1 (it used to be 2).">
		<div style={stage}>
			<span style={phase('color-mix(in srgb, #d97706 14%, #ffffff)', AMBER_INK)}>Removed row B</span>
			<div style={cols}>
				<div style={column}>
					<span style={colHead(INK_SOFT)}>key=&#123;index&#125;</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('plain')}>Hosting</div>
							</div>
						</div>
						<div style={removedRow}>
							<span style={idxChip}>—</span>
							<div style={removedField}>
								<span style={fieldLabel}>B · Description</span>
								<div style={removedBox}>Domain<span style={removedTag}>removed</span></div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('focus')}>Desig<span style={caret('focus')}></span></div>
							</div>
						</div>
					</div>
				</div>

				<div style={column}>
					<span style={colHead(BLUE)}>key=&#123;field.id&#125;</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('plain')}>Hosting</div>
							</div>
						</div>
						<div style={removedRow}>
							<span style={idxChip}>—</span>
							<div style={removedField}>
								<span style={fieldLabel}>B · Description</span>
								<div style={removedBox}>Domain<span style={removedTag}>removed</span></div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('focus')}>Desig<span style={caret('focus')}></span></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: index reuses position-1's node -> wrong row; id stays on C ---- */}
	<DiagramStep caption="key={index}: React matched nodes by position. Position 1’s node — the one that held B — is reused for C’s data, but the focus and the typed text stayed with the physical node. The ring and “Desig…” are now on the wrong row. key={field.id}: React tracked C by identity — the ring and text are still on C.">
		<div style={stage}>
			<span style={phase(RED_BG, RED_INK)}>Same remove · opposite outcomes</span>
			<div style={cols}>
				<div style={column}>
					<span style={colHead(RED)}>key=&#123;index&#125; — bug</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('plain')}>Hosting</div>
							</div>
						</div>
						<div style={removedRow}>
							<span style={idxChip}>—</span>
							<div style={removedField}>
								<span style={fieldLabel}>B · Description</span>
								<div style={removedBox}>Domain<span style={removedTag}>removed</span></div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('wrong')}>Desig<span style={caret('wrong')}></span></div>
							</div>
						</div>
					</div>
				</div>

				<div style={column}>
					<span style={colHead(GREEN)}>key=&#123;field.id&#125; — correct</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('plain')}>Hosting</div>
							</div>
						</div>
						<div style={removedRow}>
							<span style={idxChip}>—</span>
							<div style={removedField}>
								<span style={fieldLabel}>B · Description</span>
								<div style={removedBox}>Domain<span style={removedTag}>removed</span></div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('right')}>Desig<span style={caret('right')}></span></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 4: verdict — id moved the whole node up; nothing jumped ---- */}
	<DiagramStep caption="key={field.id}: React tracked C’s node by its identity, so it moved the whole node — value, focus, dirty state — up with the row. Nothing jumped. That is the entire difference.">
		<div style={stage}>
			<span style={phase(GREEN_BG, GREEN_INK)}>field.id moved the whole node</span>
			<div style={cols}>
				<div style={column}>
					<span style={colHead(RED)}>key=&#123;index&#125; — bug</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('wrong')}>Desig<span style={caret('wrong')}></span></div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('plain')}><span style={placeholder}>(empty)</span></div>
							</div>
						</div>
						<div style={removedRow}>
							<span style={idxChip}>&nbsp;</span>
							<div style={removedField}>
								<span style={fieldLabel}>&nbsp;</span>
								<div style="margin: 0; min-height: 30px; border: 1.5px solid transparent;"></div>
							</div>
						</div>
					</div>
				</div>

				<div style={column}>
					<span style={colHead(GREEN)}>key=&#123;field.id&#125; — correct</span>
					<div style={rowStack}>
						<div style={row}>
							<span style={idxChip}>0</span>
							<div style={field}>
								<span style={fieldLabel}>A · Description</span>
								<div style={inputBox('plain')}>Hosting</div>
							</div>
						</div>
						<div style={row}>
							<span style={idxChip}>1</span>
							<div style={field}>
								<span style={fieldLabel}>C · Description</span>
								<div style={inputBox('right')}>Desig<span style={caret('right')}></span></div>
							</div>
						</div>
						<div style={removedRow}>
							<span style={idxChip}>&nbsp;</span>
							<div style={removedField}>
								<span style={fieldLabel}>&nbsp;</span>
								<div style="margin: 0; min-height: 30px; border: 1.5px solid transparent;"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict}>One character&rsquo;s difference — <span style={`color: ${RED_INK}; font-weight: 700;`}>index</span> teleports the cursor and the half-typed text onto the wrong line; <span style={`color: ${GREEN_INK}; font-weight: 700;`}>field.id</span> moves the whole node with the row.</p>
		</div>
	</DiagramStep>
</DiagramSequence>
