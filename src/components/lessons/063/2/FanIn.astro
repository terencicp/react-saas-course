---
// Fan-in figure — Chapter 063 L2, "At-least-once is the contract" section.
//
// The whole problem in one picture: ONE event arrives at the handler MANY times
// (three retry stories), and all of those arrivals must converge on ONE effect.
// Plural input, singular desired effect — the gap the lesson closes.
//
// Layout: three stacked source boxes on the left (one per arrival reason), a
// single center gate ("Process exactly once?"), and one effect box on the right
// ("customer provisioned once"). The boxes are authored here as real HTML; the
// arrows are drawn by <ArrowDiagram> in the MDX over these ids:
//   src-slow / src-lost / src-crash  -> three convergence arrows into the gate
//   gate                             -> one arrow out to the effect
//
// The gate's LEFT edge is split into three stacked anchor strips
// (gate-in-1/2/3) so the three converging arrowheads land tens of px apart
// instead of stacking on one point (see ArrowDiagram guide: "splitting an
// endpoint"). gate-out is the right edge, the single exit anchor.
//
// Pure HTML + CSS. `margin: 0` reset on every element defeats Starlight's
// prose-margin selector; color-mix mid-tones read on both themes.

const reset = "margin: 0";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Accents — saturated mid-tones that read on both themes.
const orange = "#ea580c"; // arrivals + the open-question gate (neutral/unresolved)
const green = "#16a34a"; // the resolved single effect

// Three-column flow: arrivals | gate | effect. Generous gaps absorb the curves
// and the arrow labels (the left gap fans three arrows in).
const flow = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: minmax(0, 1.05fr) 110px minmax(0, 0.95fr) 90px minmax(0, 0.85fr)",
  "align-items: center",
  "max-width: 880px",
  "margin: 0 auto",
  sans,
].join("; ");

// The stack of three arrival boxes.
const arrivals = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 14px",
].join("; ");

// A single arrival box: the same event, arriving again for a different reason.
const arrivalBox = [
  reset,
  "box-sizing: border-box",
  "padding: 10px 12px",
  "border-radius: 10px",
  "line-height: 1.35",
  `border: 1px solid color-mix(in srgb, ${orange} 45%, transparent)`,
  `background: color-mix(in srgb, ${orange} 12%, var(--sl-color-bg))`,
].join("; ");

const arrivalLabel = [
  reset,
  "display: block",
  "font-size: 13px",
  "font-weight: 600",
  `color: color-mix(in srgb, ${orange} 80%, var(--sl-color-text))`,
].join("; ");

const arrivalSub = [
  reset,
  "display: block",
  "margin-top: 2px",
  "font-size: 11.5px",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The center gate — the open question, styled as unresolved (orange ring,
// dashed to read as "not yet decided").
const gate = [
  reset,
  "box-sizing: border-box",
  "position: relative",
  "padding: 18px 14px",
  "border-radius: 12px",
  "text-align: center",
  `border: 2px dashed color-mix(in srgb, ${orange} 60%, transparent)`,
  `background: color-mix(in srgb, ${orange} 8%, var(--sl-color-bg))`,
].join("; ");

const gateTitle = [
  reset,
  "display: block",
  "font-size: 15px",
  "font-weight: 700",
  `color: color-mix(in srgb, ${orange} 82%, var(--sl-color-text))`,
].join("; ");

const gateSub = [
  reset,
  "display: block",
  "margin-top: 4px",
  "font-size: 11.5px",
  "color: var(--sl-color-gray-2)",
].join("; ");

// Invisible anchor strips on the gate's left edge so the three converging
// arrowheads land apart instead of stacking. Absolutely positioned, zero
// visual footprint.
const gateAnchor = (topPct: number) =>
  [
    reset,
    "position: absolute",
    "left: -1px",
    `top: ${topPct}%`,
    "width: 1px",
    "height: 1px",
  ].join("; ");

const gateOut = [
  reset,
  "position: absolute",
  "right: -1px",
  "top: 50%",
  "width: 1px",
  "height: 1px",
].join("; ");

// The single resolved effect.
const effectBox = [
  reset,
  "box-sizing: border-box",
  "padding: 16px 14px",
  "border-radius: 12px",
  "text-align: center",
  `border: 1px solid color-mix(in srgb, ${green} 55%, transparent)`,
  `background: color-mix(in srgb, ${green} 14%, var(--sl-color-bg))`,
].join("; ");

const effectTitle = [
  reset,
  "display: block",
  "font-size: 15px",
  "font-weight: 700",
  `color: color-mix(in srgb, ${green} 78%, var(--sl-color-text))`,
].join("; ");

const effectSub = [
  reset,
  "display: block",
  "margin-top: 4px",
  "font-size: 11.5px",
  "color: var(--sl-color-gray-2)",
].join("; ");

// Spacer cells (the grid gaps) hold the arrow curves.
const spacer = reset;
---

<div class="not-content fan-in-flow" style={flow}>
  {/* LEFT — three arrivals of the SAME event */}
  <div style={arrivals}>
    <div style={arrivalBox} id="src-slow">
      <span style={arrivalLabel}>Retry</span>
      <span style={arrivalSub}>handler was slow, Stripe timed out</span>
    </div>
    <div style={arrivalBox} id="src-lost">
      <span style={arrivalLabel}>Retry</span>
      <span style={arrivalSub}>the 200 was lost in transit</span>
    </div>
    <div style={arrivalBox} id="src-crash">
      <span style={arrivalLabel}>Retry</span>
      <span style={arrivalSub}>handler crashed mid-work</span>
    </div>
  </div>

  <div style={spacer}></div>

  {/* CENTER — the open question every arrival hits */}
  <div style={gate} id="gate">
    <span style={gateAnchor(22)} id="gate-in-1"></span>
    <span style={gateAnchor(50)} id="gate-in-2"></span>
    <span style={gateAnchor(78)} id="gate-in-3"></span>
    <span style={gateOut} id="gate-out"></span>
    <span style={gateTitle}>Process exactly once?</span>
    <span style={gateSub}>same event.id, every time</span>
  </div>

  <div style={spacer}></div>

  {/* RIGHT — the single desired effect */}
  <div style={effectBox} id="effect">
    <span style={effectTitle}>One effect</span>
    <span style={effectSub}>customer provisioned once</span>
  </div>
</div>

<style>
  /* Side-by-side fan-in needs horizontal room for the curves. Below ~720px the
     three columns get too cramped for the arrows to read; stack them and the
     arrows degrade to short vertical arcs that still convey "many in, one out". */
  @media (max-width: 720px) {
    .fan-in-flow {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
      max-width: 360px !important;
    }
  }
</style>
