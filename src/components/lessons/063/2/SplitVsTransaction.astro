---
// Split-vs-transaction figure — Chapter 063 L2, "The claim and the work are one
// transaction".
//
// One crash, two architectures. Both panels trace the SAME failure: a crash
// strikes after the claim INSERT but before the business effect has committed.
// The only difference is WHERE THE COMMIT BOUNDARY SITS — and that difference
// is the entire correctness argument.
//
//   variant="split"        the claim commits on its OWN boundary, the effect
//                          fails after, the retry sees the orphaned receipt and
//                          skips forever. End state: permanently wrong (red).
//   variant="transaction"  one boundary wraps the claim AND the effect; the
//                          crash rolls both back, the retry re-claims cleanly
//                          and heals. End state: correct (green).
//
// Each panel is a horizontal strip of step chips connected by chevrons, with a
// bracket above the steps marking the commit boundary, then a colored end-state
// banner. The bracket is the load-bearing visual: in "split" it hugs only the
// claim (an early, fatal commit); in "transaction" it spans the claim + work.
//
// Pure HTML + CSS so it inspects in devtools and themes for free. `margin: 0`
// reset defeats Starlight's prose-margin selector; color-mix mid-tones read on
// both light and dark themes. Rendered inside <TabbedContent> tabs in the MDX.

interface Props {
  // Which architecture this panel shows.
  variant: "split" | "transaction";
}

const { variant } = Astro.props;
const isSplit = variant === "split";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono = "font-family: var(--__sl-font-mono, ui-monospace, monospace)";

const green = "#16a34a"; // committed / correct
const red = "#dc2626"; // crash / corrupted end state
const slate = "#64748b"; // neutral, post-failure follow-up steps
const blue = "#2563eb"; // the retry that heals (transaction panel)

type Tone = "ok" | "bad" | "neutral" | "heal";

// One step in the horizontal sequence.
interface Step {
  // Monospace headline — the operation.
  op: string;
  // Plain-language gloss under it.
  sub: string;
  tone: Tone;
}

// The two timelines. They share the first beat (the claim) and the crash beat,
// then diverge: split orphans the receipt, transaction rolls it back.
const splitSteps: Step[] = [
  { op: "claim INSERT", sub: "commits on its own", tone: "ok" },
  { op: "business work", sub: "fails / crashes", tone: "bad" },
  { op: "Stripe retries", sub: "non-2xx, resend", tone: "neutral" },
  { op: "claim row found", sub: '"already done", skip', tone: "neutral" },
];

const txSteps: Step[] = [
  { op: "claim + work", sub: "in one tx", tone: "ok" },
  { op: "crash", sub: "before commit", tone: "bad" },
  { op: "rollback", sub: "no claim row left", tone: "neutral" },
  { op: "Stripe retries", sub: "re-claim, commit", tone: "heal" },
];

const steps = isSplit ? splitSteps : txSteps;

const endTone = isSplit ? red : green;
const endText = isSplit
  ? "Effect never applied. Data permanently wrong."
  : "Recorded and applied together. Correct.";

// Commit-boundary bracket span (1-based, inclusive step indices).
//   split:       boundary closes around step 1 only — the claim commits alone.
//   transaction: boundary spans steps 1–2 — claim + work share one commit.
const boundaryStart = 1;
const boundaryEnd = isSplit ? 1 : 2;
const boundaryLabel = isSplit
  ? "commit boundary (claim only)"
  : "one commit boundary (claim + work)";

const accentFor = (tone: Tone) =>
  tone === "ok"
    ? green
    : tone === "bad"
      ? red
      : tone === "heal"
        ? blue
        : slate;

// ---- styles -------------------------------------------------------------

const frame = [
  reset,
  "box-sizing: border-box",
  "max-width: 720px",
  "margin: 0 auto",
  sans,
].join("; ");

// The strip: bracket row sits above, steps row below, sharing the same columns
// so the bracket lines up exactly over its steps.
const stripGridCols = `grid-template-columns: ${steps
  .map(() => "minmax(0, 1fr)")
  .join(" 18px ")};`;

const strip = [
  reset,
  "display: grid",
  stripGridCols,
  "grid-template-rows: 26px auto",
  "align-items: stretch",
  "column-gap: 0",
].join("; ");

// Bracket: an underlined span over the boundary steps. Grid columns are
// 1-based; step N lives in grid column (2N-1), chevrons in the even columns.
const bracketColStart = boundaryStart * 2 - 1;
const bracketColEnd = boundaryEnd * 2 - 1;
const bracket = [
  reset,
  "position: relative",
  `grid-column: ${bracketColStart} / ${bracketColEnd + 1}`,
  "grid-row: 1",
  "align-self: end",
  "height: 16px",
  `border: 2px solid color-mix(in srgb, ${green} 70%, transparent)`,
  "border-bottom: none",
  "border-top-left-radius: 7px",
  "border-top-right-radius: 7px",
].join("; ");

const bracketTag = [
  reset,
  "position: absolute",
  "left: 50%",
  "top: -3px",
  "transform: translate(-50%, -100%)",
  "padding: 1px 8px",
  "border-radius: 999px",
  "white-space: nowrap",
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  `color: color-mix(in srgb, ${green} 82%, var(--sl-color-text))`,
  `background: color-mix(in srgb, ${green} 13%, var(--sl-color-bg))`,
  `border: 1px solid color-mix(in srgb, ${green} 40%, transparent)`,
].join("; ");

const stepBox = (tone: Tone) => {
  const a = accentFor(tone);
  return [
    reset,
    "box-sizing: border-box",
    "grid-row: 2",
    "padding: 10px 10px",
    "border-radius: 10px",
    "text-align: center",
    "line-height: 1.3",
    `border: ${tone === "bad" ? "2px" : "1px"} solid color-mix(in srgb, ${a} ${
      tone === "bad" ? "70%" : "45%"
    }, transparent)`,
    `background: color-mix(in srgb, ${a} ${tone === "bad" ? "15%" : "10%"}, var(--sl-color-bg))`,
  ].join("; ");
};

const stepOp = (tone: Tone) =>
  [
    reset,
    mono,
    "display: block",
    "font-size: 12.5px",
    "font-weight: 700",
    `color: color-mix(in srgb, ${accentFor(tone)} 85%, var(--sl-color-text))`,
  ].join("; ");

const stepSub = [
  reset,
  "display: block",
  "margin-top: 3px",
  "font-size: 11px",
  "color: var(--sl-color-gray-2)",
].join("; ");

const chevron = [
  reset,
  "grid-row: 2",
  "align-self: center",
  "justify-self: center",
  "font-size: 15px",
  "line-height: 1",
  "color: var(--sl-color-gray-4)",
].join("; ");

const endState = [
  reset,
  "box-sizing: border-box",
  "margin-top: 16px",
  "padding: 11px 14px",
  "border-radius: 10px",
  "text-align: center",
  "font-size: 13.5px",
  "font-weight: 700",
  `color: ${endTone}`,
  `border: 2px solid ${endTone}`,
  `background: color-mix(in srgb, ${endTone} 12%, var(--sl-color-bg))`,
].join("; ");
---

<div class="not-content split-vs-tx" style={frame}>
  <div class="svt-strip" style={strip}>
    {/* Commit-boundary bracket over its step(s) */}
    <div style={bracket}>
      <span style={bracketTag}>{boundaryLabel}</span>
    </div>

    {/* Steps + chevrons */}
    {
      steps.map((s, i) => (
        <>
          <div style={stepBox(s.tone)}>
            <span style={stepOp(s.tone)}>{s.op}</span>
            <span style={stepSub}>{s.sub}</span>
          </div>
          {i < steps.length - 1 && <span style={chevron}>&rarr;</span>}
        </>
      ))
    }
  </div>

  <div style={endState}>{endText}</div>
</div>

<style>
  /* The four-step strip is too tight to read side-by-side on phones. Stack the
     steps vertically; turn the connectors into down-arrows. The commit bracket
     is a horizontal affordance, so hide it on the stacked layout and lean on
     the per-step colors + end-state banner to carry the contrast. */
  @media (max-width: 560px) {
    .split-vs-tx .svt-strip {
      display: flex !important;
      flex-direction: column !important;
      gap: 8px !important;
    }
    .split-vs-tx .svt-strip > div:first-child {
      display: none !important; /* the commit bracket */
    }
    .split-vs-tx .svt-strip span:not([style*="display: block"]) {
      transform: rotate(90deg);
    }
  }
</style>
