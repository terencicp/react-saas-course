---
// Diagram id: four-surfaces-grid-full (Chapter 063, Lesson 4 "One pattern,
// four surfaces"). The climactic reprise of the centerpiece comparison: the
// SAME hand-coded grid as four-surfaces-grid-partial, now with every row
// filled in. Per the diagrams guide this is a "color-coded segments / compare"
// shape, so a hand-coded HTML+CSS grid — not a graph engine.
//
// Styling is kept deliberately identical to the partial version so the two
// visuals read as the same artifact at two stages. The one departure: the
// bottom-right cell (Public route / On replay) carries a subtle highlight,
// because it is the single behavior that genuinely differs across the four
// surfaces — the public route replays a stored response, the rest only
// confirm "already done."
//
// Pure HTML + CSS, devtools-inspectable grid. `margin: 0` reset defeats
// Starlight's injected prose-margin selector. Accent fills are saturated
// mid-tones mixed toward the page bg so they read in both light and dark themes.

import Figure from '../../../figures/Figure.astro';

type Surface = {
  name: string;
  accent: string; // saturated mid-tone, the column's identity color
};

const surfaces: Surface[] = [
  { name: 'Webhook', accent: '#635bff' }, // stripe violet
  { name: 'Server Action', accent: '#2563eb' }, // blue-600
  { name: 'Background job', accent: '#d97706' }, // amber-600
  { name: 'Public route', accent: '#0d9488' }, // teal-600
];

type Cell = { text: string; code?: boolean; emphasis?: boolean };

type Row = {
  label: string;
  // one cell per surface, in the same order as `surfaces`; `code: true` renders
  // the value in a mono pill.
  cells: Cell[];
};

const rows: Row[] = [
  {
    label: 'Who owns the attempt',
    cells: [
      { text: 'the sender (Stripe)' },
      { text: 'the form render' },
      { text: 'the job runtime' },
      { text: 'the calling client' },
    ],
  },
  {
    label: 'Where the key is generated',
    cells: [
      { text: 'provider' },
      { text: 'Client Component, once per render' },
      { text: 'runtime, per run' },
      { text: 'client, per request' },
    ],
  },
  {
    label: 'The key',
    cells: [
      { text: 'event.id', code: true },
      { text: 'a UUID in a hidden input' },
      { text: 'runId', code: true },
      { text: 'Idempotency-Key header', code: true },
    ],
  },
  {
    label: 'What triggers a replay',
    cells: [
      { text: 'retry / out-of-order redelivery' },
      { text: 'double-click / browser retry' },
      { text: 'runtime retry after failure' },
      { text: 'client retry on timeout' },
    ],
  },
  {
    label: 'The constraint (scoped)',
    cells: [
      { text: '(provider, eventId)', code: true },
      { text: '(orgId, idempotencyKey)', code: true },
      { text: '(runId)', code: true },
      { text: '(clientId, idempotencyKey)', code: true },
    ],
  },
  {
    label: 'On replay',
    cells: [
      { text: 'claim conflicts → 200' },
      { text: 'conflict → return success' },
      { text: 'conflict → no-op' },
      { text: 'return cached response', emphasis: true },
    ],
  },
];

const reset = 'margin: 0; box-sizing: border-box';

// Header cell for one surface lane — colored top strip.
const headerStyle = (accent: string) =>
  [
    reset,
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'text-align: center',
    'padding: 10px 10px',
    'border-radius: 10px',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 13.5px',
    'font-weight: 700',
    'line-height: 1.15',
    'color: #ffffff',
    `background: ${accent}`,
    `box-shadow: 0 0 0 1px color-mix(in srgb, ${accent} 55%, transparent)`,
  ].join('; ');

const rowLabelStyle =
  [
    reset,
    'display: flex',
    'align-items: center',
    'padding: 10px 12px 10px 0',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 12.5px',
    'font-weight: 600',
    'line-height: 1.25',
    'color: var(--sl-color-white)',
  ].join('; ');

const cellStyle = (accent: string, emphasis: boolean) =>
  [
    reset,
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'text-align: center',
    'padding: 10px 9px',
    'border-radius: 9px',
    'min-height: 44px',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 12.5px',
    'line-height: 1.3',
    emphasis ? 'font-weight: 700' : 'font-weight: 500',
    `color: ${emphasis ? `color-mix(in srgb, ${accent} 30%, var(--sl-color-white))` : 'var(--sl-color-white)'}`,
    `background: color-mix(in srgb, ${accent} ${emphasis ? '26%' : '13%'}, var(--sl-color-bg))`,
    `border: 1px solid color-mix(in srgb, ${accent} ${emphasis ? '62%' : '35%'}, transparent)`,
    emphasis ? `box-shadow: 0 0 0 1px color-mix(in srgb, ${accent} 40%, transparent)` : '',
  ]
    .filter(Boolean)
    .join('; ');

const monoPill = (accent: string) =>
  [
    reset,
    'display: inline-block',
    'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
    'font-size: 12px',
    'font-weight: 600',
    'padding: 2px 7px',
    'border-radius: 6px',
    'white-space: nowrap',
    `color: color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
    `background: color-mix(in srgb, ${accent} 16%, transparent)`,
  ].join('; ');
---

<Figure caption="One discipline, four surfaces. Read down for a surface's full story; read across for the one shape underneath all of them. The bottom-right cell is the only behavior that genuinely differs — the public route replays a stored response, the rest just confirm 'already done.'">
  <div
    class="not-content fsg-root"
    style={`${reset}; width: 100%; max-width: 920px; margin: 0 auto`}
  >
    <div
      class="fsg-grid"
      style={`${reset}; display: grid; grid-template-columns: minmax(120px, 0.9fr) repeat(4, minmax(0, 1fr)); column-gap: 8px; row-gap: 7px; align-items: stretch`}
    >
      {/* Header row: empty corner + four surface lane headers. */}
      <div style={reset}></div>
      {
        surfaces.map((s) => (
          <div style={headerStyle(s.accent)}>{s.name}</div>
        ))
      }

      {/* Data rows. */}
      {
        rows.map((row) => (
          <Fragment>
            <div style={rowLabelStyle}>{row.label}</div>
            {surfaces.map((s, i) => {
              const cell = row.cells[i];
              return (
                <div style={cellStyle(s.accent, Boolean(cell.emphasis))}>
                  {cell.code ? (
                    <span style={monoPill(s.accent)}>{cell.text}</span>
                  ) : (
                    cell.text
                  )}
                </div>
              );
            })}
          </Fragment>
        ))
      }
    </div>
  </div>
</Figure>
