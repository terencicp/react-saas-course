---
// Diagram id: four-surfaces-grid-partial (Chapter 063, Lesson 4 "One pattern,
// four surfaces"). The centerpiece comparison: ONE idempotency discipline, four
// surfaces side by side as parallel lanes. Per the diagrams guide this is a
// "color-coded segments / compare" shape, so a hand-coded HTML+CSS grid — not a
// graph engine.
//
// Layout: a CSS grid. A left label column names each row; four accent-tinted
// surface columns (Webhook / Server Action / Background job / Public route) read
// as distinct lanes. Six rows down the side.
//
// THIS partial version fills only the first three rows (the lesson's through-line:
// who owns the attempt, where the key is born, what the key is). The last three
// rows render as muted "—" placeholders so the reader sees the slots exist and
// will be filled in as each surface is taught; the completed grid reprises at the
// end of the lesson (diagram id four-surfaces-grid-full).
//
// Pure HTML + CSS, devtools-inspectable grid. `margin: 0` reset defeats
// Starlight's injected prose-margin selector. Accent fills are saturated
// mid-tones mixed toward the page bg so they read in both light and dark themes.

import Figure from '../../../figures/Figure.astro';

type Surface = {
  name: string;
  accent: string; // saturated mid-tone, the column's identity color
};

const surfaces: Surface[] = [
  { name: 'Webhook', accent: '#635bff' }, // stripe violet
  { name: 'Server Action', accent: '#2563eb' }, // blue-600
  { name: 'Background job', accent: '#d97706' }, // amber-600
  { name: 'Public route', accent: '#0d9488' }, // teal-600
];

type Row = {
  label: string;
  // one cell per surface, in the same order as `surfaces`; `code: true` renders
  // the value in a mono pill. `filled: false` rows render as muted placeholders.
  cells: { text: string; code?: boolean }[];
  filled: boolean;
};

const rows: Row[] = [
  {
    label: 'Who owns the attempt',
    filled: true,
    cells: [
      { text: 'the sender (Stripe)' },
      { text: 'the form render' },
      { text: 'the job runtime' },
      { text: 'the calling client' },
    ],
  },
  {
    label: 'Where the key is generated',
    filled: true,
    cells: [
      { text: 'provider' },
      { text: 'Client Component, once per render' },
      { text: 'runtime, per run' },
      { text: 'client, per request' },
    ],
  },
  {
    label: 'The key',
    filled: true,
    cells: [
      { text: 'event.id', code: true },
      { text: 'a UUID in a hidden input' },
      { text: 'runId', code: true },
      { text: 'Idempotency-Key header', code: true },
    ],
  },
  { label: 'What triggers a replay', filled: false, cells: [] },
  { label: 'The constraint (scoped)', filled: false, cells: [] },
  { label: 'On replay', filled: false, cells: [] },
];

const reset = 'margin: 0; box-sizing: border-box';

// Header cell for one surface lane — colored top strip.
const headerStyle = (accent: string) =>
  [
    reset,
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'text-align: center',
    'padding: 10px 10px',
    'border-radius: 10px',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 13.5px',
    'font-weight: 700',
    'line-height: 1.15',
    'color: #ffffff',
    `background: ${accent}`,
    `box-shadow: 0 0 0 1px color-mix(in srgb, ${accent} 55%, transparent)`,
  ].join('; ');

const rowLabelStyle = (filled: boolean) =>
  [
    reset,
    'display: flex',
    'align-items: center',
    'padding: 10px 12px 10px 0',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 12.5px',
    'font-weight: 600',
    'line-height: 1.25',
    `color: ${filled ? 'var(--sl-color-white)' : 'var(--sl-color-gray-3)'}`,
  ].join('; ');

const cellStyle = (accent: string, filled: boolean) =>
  [
    reset,
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'text-align: center',
    'padding: 10px 9px',
    'border-radius: 9px',
    'min-height: 44px',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 12.5px',
    'line-height: 1.3',
    filled ? 'font-weight: 500' : 'font-weight: 600',
    `color: ${filled ? 'var(--sl-color-white)' : `color-mix(in srgb, ${accent} 55%, var(--sl-color-gray-3))`}`,
    `background: color-mix(in srgb, ${accent} ${filled ? '13%' : '5%'}, var(--sl-color-bg))`,
    `border: 1px solid color-mix(in srgb, ${accent} ${filled ? '35%' : '18%'}, transparent)`,
    filled ? 'border-style: solid' : 'border-style: dashed',
  ].join('; ');

const monoPill = (accent: string) =>
  [
    reset,
    'display: inline-block',
    'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
    'font-size: 12px',
    'font-weight: 600',
    'padding: 2px 7px',
    'border-radius: 6px',
    'white-space: nowrap',
    `color: color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
    `background: color-mix(in srgb, ${accent} 16%, transparent)`,
  ].join('; ');
---

<Figure caption="Same three moves in every column. Only the key's origin and the replay trigger change.">
  <div
    class="not-content fsg-root"
    style={`${reset}; width: 100%; max-width: 920px; margin: 0 auto`}
  >
    <div
      class="fsg-grid"
      style={`${reset}; display: grid; grid-template-columns: minmax(120px, 0.9fr) repeat(4, minmax(0, 1fr)); column-gap: 8px; row-gap: 7px; align-items: stretch`}
    >
      {/* Header row: empty corner + four surface lane headers. */}
      <div style={reset}></div>
      {
        surfaces.map((s) => (
          <div style={headerStyle(s.accent)}>{s.name}</div>
        ))
      }

      {/* Data rows. */}
      {
        rows.map((row) => (
          <Fragment>
            <div style={rowLabelStyle(row.filled)}>{row.label}</div>
            {surfaces.map((s, i) => {
              const cell = row.filled ? row.cells[i] : undefined;
              return (
                <div style={cellStyle(s.accent, row.filled)}>
                  {row.filled && cell ? (
                    cell.code ? (
                      <span style={monoPill(s.accent)}>{cell.text}</span>
                    ) : (
                      cell.text
                    )
                  ) : (
                    <span aria-hidden="true">&#8212;</span>
                  )}
                </div>
              );
            })}
          </Fragment>
        ))
      }
    </div>
  </div>
</Figure>
