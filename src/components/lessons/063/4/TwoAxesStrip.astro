---
// Diagram id: two-axes-strip (Chapter 063, Lesson 4 "One pattern, four
// surfaces"). The orthogonality beat: an incoming request raises TWO independent
// questions, and idempotency answers only one. Per the diagrams guide this is a
// compact "color-coded segments" strip, so a hand-coded HTML+CSS layout — not a
// graph engine.
//
// Layout: two horizontal rows, each reading left-to-right as a flow:
//   axis name  →  the question it answers  →  the mechanism(s) that answer it.
// Each row carries its own accent color so the two axes read as distinct,
// parallel concerns. Kept small and horizontal per the vertical-space cap.
//
// Pure HTML + CSS, devtools-inspectable. `margin: 0` reset defeats Starlight's
// injected prose-margin selector. Accent fills are saturated mid-tones mixed
// toward the page bg so they read in both light and dark themes.

import Figure from '../../../figures/Figure.astro';

type Mechanism = { text: string; tag?: string };

type Axis = {
  name: string;
  question: string;
  accent: string; // saturated mid-tone, the row's identity color
  mechanisms: Mechanism[];
};

const axes: Axis[] = [
  {
    name: 'Provenance',
    question: 'Who is this from?',
    accent: '#2563eb', // blue-600
    mechanisms: [
      { text: 'signature', tag: 'webhook' },
      { text: 'auth', tag: 'public route' },
    ],
  },
  {
    name: 'Attempt identity',
    question: 'Is this the same attempt as before?',
    accent: '#0d9488', // teal-600
    mechanisms: [{ text: 'idempotency key' }],
  },
];

const reset = 'margin: 0; box-sizing: border-box';

const labelMap = {
  axis: 'the axis',
  question: 'the question it answers',
  mechanism: 'the mechanism that answers it',
};

const captionStripStyle = [
  reset,
  'display: grid',
  'grid-template-columns: minmax(140px, 0.85fr) auto minmax(0, 1.7fr) auto minmax(0, 1.6fr)',
  'align-items: center',
  'column-gap: 10px',
  'padding: 0 2px 10px',
  'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
  'font-size: 10.5px',
  'font-weight: 700',
  'letter-spacing: 0.06em',
  'text-transform: uppercase',
  'color: var(--sl-color-gray-3)',
].join('; ');

const rowStyle = (accent: string) =>
  [
    reset,
    'display: grid',
    'grid-template-columns: minmax(140px, 0.85fr) auto minmax(0, 1.7fr) auto minmax(0, 1.6fr)',
    'align-items: center',
    'column-gap: 10px',
    'padding: 12px 14px',
    'border-radius: 12px',
    `background: color-mix(in srgb, ${accent} 9%, var(--sl-color-bg))`,
    `border: 1px solid color-mix(in srgb, ${accent} 32%, transparent)`,
  ].join('; ');

const axisStyle = (accent: string) =>
  [
    reset,
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'text-align: center',
    'padding: 9px 12px',
    'border-radius: 9px',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 14px',
    'font-weight: 700',
    'line-height: 1.15',
    'color: #ffffff',
    `background: ${accent}`,
    `box-shadow: 0 0 0 1px color-mix(in srgb, ${accent} 55%, transparent)`,
  ].join('; ');

const questionStyle = [
  reset,
  'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
  'font-size: 14px',
  'font-style: italic',
  'font-weight: 500',
  'line-height: 1.3',
  'color: var(--sl-color-white)',
].join('; ');

const arrowStyle = (accent: string) =>
  [
    reset,
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 18px',
    'font-weight: 700',
    'line-height: 1',
    `color: color-mix(in srgb, ${accent} 70%, var(--sl-color-gray-3))`,
  ].join('; ');

const mechRowStyle = [
  reset,
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'gap: 7px',
].join('; ');

const chipStyle = (accent: string) =>
  [
    reset,
    'display: inline-flex',
    'align-items: baseline',
    'gap: 6px',
    'padding: 5px 10px',
    'border-radius: 8px',
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 13px',
    'font-weight: 600',
    'line-height: 1.2',
    `color: color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
    `background: color-mix(in srgb, ${accent} 16%, transparent)`,
    `border: 1px solid color-mix(in srgb, ${accent} 35%, transparent)`,
  ].join('; ');

const tagStyle = (accent: string) =>
  [
    reset,
    'font-size: 10.5px',
    'font-weight: 600',
    'font-style: italic',
    `color: color-mix(in srgb, ${accent} 55%, var(--sl-color-gray-2))`,
  ].join('; ');
---

<Figure>
  <div
    class="not-content tas-root"
    style={`${reset}; width: 100%; max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 10px`}
  >
    {/* Column-label strip naming the three segments of each row. */}
    <div style={captionStripStyle}>
      <span style={reset}>{labelMap.axis}</span>
      <span style={reset} aria-hidden="true"></span>
      <span style={reset}>{labelMap.question}</span>
      <span style={reset} aria-hidden="true"></span>
      <span style={reset}>{labelMap.mechanism}</span>
    </div>

    {
      axes.map((axis) => (
        <div style={rowStyle(axis.accent)}>
          <div style={axisStyle(axis.accent)}>{axis.name}</div>
          <span style={arrowStyle(axis.accent)} aria-hidden="true">
            &#8594;
          </span>
          <span style={questionStyle}>&#8220;{axis.question}&#8221;</span>
          <span style={arrowStyle(axis.accent)} aria-hidden="true">
            &#8594;
          </span>
          <div style={mechRowStyle}>
            {axis.mechanisms.map((m) => (
              <span style={chipStyle(axis.accent)}>
                {m.text}
                {m.tag ? <span style={tagStyle(axis.accent)}>{m.tag}</span> : null}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
  <Fragment slot="caption">
    Two independent axes. A real webhook answers both — the signature proves it&#8217;s
    Stripe, the <code>event.id</code> proves it&#8217;s not a duplicate. A public route
    answers both too — auth proves the client, the header proves sameness.
  </Fragment>
</Figure>
