---
// Diagram id: emitted-vs-arrived (Chapter 063, Lesson 3 "Newer wins, single
// writer"). A compact two-lane HTML+CSS strip that separates *emission order*
// from *arrival order* in the reader's head.
//
//   Top lane  — "Emitted by Stripe (created order)": active(100) -> past_due(160),
//               left-to-right. Green / calm: this is the order Stripe intended.
//   Bottom    — "Arrived at your handler": past_due(160) -> active(100). Red /
//               alarmed: this is what the network actually delivered.
//
// The load-bearing visual: the SAME two created values (100 and 160) appear in
// both lanes, but their left-to-right positions SWAP. A small SVG between the
// lanes draws two crossing connectors — active's chip slides from top-left to
// bottom-right, past_due's from top-right to bottom-left — so the reordering
// reads as literally crossed. The crossing lines are the only SVG; everything
// else is real, devtools-inspectable flexbox/grid.
//
// Pure HTML + CSS otherwise. `margin: 0` reset on every inner element to defeat
// Starlight's injected prose-margin selector. Saturated mid-tone fills with
// white text read in both light and dark themes; the lane *frames* use
// theme-aware Starlight variables tinted toward green/red.

import Figure from '../../../figures/Figure.astro';

const reset = 'margin: 0';

// Theme-aware palette ---------------------------------------------------------
const calmBg = 'color-mix(in srgb, #16a34a 12%, var(--sl-color-bg))';
const calmBorder = 'color-mix(in srgb, #16a34a 45%, transparent)';
const calmInk = 'color-mix(in srgb, #16a34a 70%, var(--sl-color-white))';

const alarmBg = 'color-mix(in srgb, #dc2626 12%, var(--sl-color-bg))';
const alarmBorder = 'color-mix(in srgb, #dc2626 45%, transparent)';
const alarmInk = 'color-mix(in srgb, #dc2626 75%, var(--sl-color-white))';

const laneBase = (bg: string, border: string) =>
  [
    reset,
    'box-sizing: border-box',
    'display: grid',
    'grid-template-columns: minmax(0, 1fr) 36px minmax(0, 1fr)',
    'align-items: center',
    'gap: 0',
    `background: ${bg}`,
    `border: 1px solid ${border}`,
    'border-radius: 12px',
    'padding: 14px 16px',
  ].join('; ');

const laneLabel = (ink: string) =>
  [
    reset,
    'box-sizing: border-box',
    'display: flex',
    'align-items: baseline',
    'gap: 8px',
    'flex-wrap: wrap',
    `color: ${ink}`,
    'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
    'font-size: 13px',
    'font-weight: 700',
    'line-height: 1.2',
    'padding: 0 0 2px',
  ].join('; ');

const laneLabelHint = [
  reset,
  'font-size: 11.5px',
  'font-weight: 500',
  'opacity: 0.85',
].join('; ');

const chip = (fill: string) =>
  [
    reset,
    'box-sizing: border-box',
    'display: flex',
    'flex-direction: column',
    'align-items: center',
    'gap: 2px',
    'min-width: 0',
    `background: ${fill}`,
    'border-radius: 9px',
    'padding: 9px 6px 8px',
    'color: #ffffff',
    'text-align: center',
  ].join('; ');

const chipName = [
  reset,
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
  'font-size: 14px',
  'font-weight: 700',
  'line-height: 1.1',
  'letter-spacing: -0.01em',
].join('; ');

const chipMeta = [
  reset,
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
  'font-size: 11px',
  'font-weight: 500',
  'line-height: 1.1',
  'opacity: 0.92',
  'white-space: nowrap',
].join('; ');

const arrowCell = [
  reset,
  'display: flex',
  'align-items: center',
  'justify-content: center',
].join('; ');

const arrow = (ink: string) =>
  [
    reset,
    `color: ${ink}`,
    'font-size: 22px',
    'font-weight: 700',
    'line-height: 1',
  ].join('; ');

// active = blue-ish identity, past_due = amber identity, kept consistent across
// lanes so the eye tracks each event as it changes position.
const activeFill = '#2563eb'; // blue-600
const pastDueFill = '#d97706'; // amber-600
---

<Figure
  caption="Stripe emits in order and stamps each event with created. The network delivers in whatever order it likes. created is how you recover the order Stripe intended."
>
  <div
    class="not-content eva-root"
    style={`${reset}; box-sizing: border-box; display: flex; flex-direction: column; gap: 0; width: 100%; max-width: 620px; margin: 0 auto;`}
  >
    {/* Top label — emitted order */}
    <div
      style={`${reset}; display: flex; align-items: center; gap: 8px; padding: 0 4px 6px;`}
    >
      <span style={laneLabel(calmInk)}>
        Emitted by Stripe
        <span style={laneLabelHint}>(created order)</span>
      </span>
    </div>

    {/* Top lane — emitted in order */}
    <div style={laneBase(calmBg, calmBorder)}>
      <div style={chip(activeFill)}>
        <span style={chipName}>active</span>
        <span style={chipMeta}>created=100</span>
      </div>
      <div style={arrowCell}>
        <span style={arrow(calmInk)}>&#8594;</span>
      </div>
      <div style={chip(pastDueFill)}>
        <span style={chipName}>past_due</span>
        <span style={chipMeta}>created=160</span>
      </div>
    </div>

    {/* Crossing connectors — the only SVG. active slides left->right, past_due
        slides right->left, so the lines read as swapped. */}
    <svg
      class="eva-cross"
      viewBox="0 0 620 48"
      preserveAspectRatio="none"
      width="100%"
      height="48"
      role="presentation"
      aria-hidden="true"
      style={`${reset}; display: block; overflow: visible;`}
    >
      {/* active: top-left column center (~110) down to bottom-right (~510) */}
      <line
        x1="110"
        y1="2"
        x2="510"
        y2="46"
        stroke={activeFill}
        stroke-width="2.5"
        stroke-dasharray="6 5"
        stroke-linecap="round"
      ></line>
      {/* past_due: top-right (~510) down to bottom-left (~110) */}
      <line
        x1="510"
        y1="2"
        x2="110"
        y2="46"
        stroke={pastDueFill}
        stroke-width="2.5"
        stroke-dasharray="6 5"
        stroke-linecap="round"
      ></line>
    </svg>

    {/* Bottom label — arrival order */}
    <div
      style={`${reset}; display: flex; align-items: center; gap: 8px; padding: 6px 4px 6px;`}
    >
      <span style={laneLabel(alarmInk)}>
        Arrived at your handler
        <span style={laneLabelHint}>(network order)</span>
      </span>
    </div>

    {/* Bottom lane — arrived reversed */}
    <div style={laneBase(alarmBg, alarmBorder)}>
      <div style={chip(pastDueFill)}>
        <span style={chipName}>past_due</span>
        <span style={chipMeta}>created=160</span>
      </div>
      <div style={arrowCell}>
        <span style={arrow(alarmInk)}>&#8594;</span>
      </div>
      <div style={chip(activeFill)}>
        <span style={chipName}>active</span>
        <span style={chipMeta}>created=100</span>
      </div>
    </div>
  </div>
</Figure>
