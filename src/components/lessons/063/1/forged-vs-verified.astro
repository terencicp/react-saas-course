---
import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Two stacked horizontal flows contrasting the same forged request.
//   Top row    — unverified handler: the forgery sails straight through to a
//                free entitlement (the whole path is "danger" red).
//   Bottom row — verifying handler: Stripe and the attacker both POST into a
//                single verify gate (the chokepoint); legitimate traffic flows
//                out green, forgery dies red at the gate.
const DANGER = '#dc2626'; // red-600 — forgery / refusal
const NEUTRAL = '#64748b'; // slate-500 — inbound request, sender-agnostic
const SAFE = '#16a34a'; // green-600 — verified, processed
---

<Figure expandable={false}>
  <ArrowDiagram
    arrows={[
      {
        from: 'fv-attacker-top',
        to: 'fv-handler',
        label: 'POST forged JSON',
        color: DANGER,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [60, 0],
        endSocketGravity: [-60, 0],
        labelOffset: [0, -16],
      },
      {
        from: 'fv-handler',
        to: 'fv-free',
        label: 'trusts body',
        color: DANGER,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [60, 0],
        endSocketGravity: [-60, 0],
        labelOffset: [0, -16],
      },
      {
        from: 'fv-stripe',
        to: 'fv-gate-in',
        label: 'POST + valid signature',
        color: NEUTRAL,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [70, 0],
        endSocketGravity: [-70, -18],
        labelOffset: [4, -16],
      },
      {
        from: 'fv-attacker-bot',
        to: 'fv-gate-in',
        label: 'POST forged, no valid signature',
        color: NEUTRAL,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [70, 0],
        endSocketGravity: [-70, 18],
        labelOffset: [4, 16],
      },
      {
        from: 'fv-gate-out',
        to: 'fv-process',
        label: 'match → process',
        color: SAFE,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [70, -18],
        endSocketGravity: [-70, 0],
        labelOffset: [-4, -16],
      },
      {
        from: 'fv-gate-out',
        to: 'fv-reject',
        label: 'no match → 400',
        color: DANGER,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [70, 18],
        endSocketGravity: [-70, 0],
        labelOffset: [-4, 16],
      },
    ]}
  >
    <div class="fv">
      <section class="fv-row">
        <div class="fv-row-tag fv-row-tag--bad">No verification</div>
        <div class="fv-line">
          <div class="fv-box fv-box--attacker" id="fv-attacker-top">
            <span class="fv-box-title">Attacker</span>
          </div>
          <div class="fv-box fv-box--neutral" id="fv-handler">
            <span class="fv-box-title">Handler</span>
            <span class="fv-box-sub">no verify</span>
          </div>
          <div class="fv-box fv-box--danger" id="fv-free">
            <span class="fv-box-title">Free pro plan granted</span>
          </div>
        </div>
      </section>

      <div class="fv-divider"></div>

      <section class="fv-row">
        <div class="fv-row-tag fv-row-tag--good">Verify at the boundary</div>
        <div class="fv-line fv-line--gate">
          <div class="fv-col">
            <div class="fv-box fv-box--stripe" id="fv-stripe">
              <span class="fv-box-title">Stripe</span>
            </div>
            <div class="fv-box fv-box--attacker" id="fv-attacker-bot">
              <span class="fv-box-title">Attacker</span>
            </div>
          </div>

          <div class="fv-gate">
            <span class="fv-gate-title" id="fv-gate-in">Verify signature</span>
            <span class="fv-gate-sub" id="fv-gate-out">the only chokepoint</span>
          </div>

          <div class="fv-col">
            <div class="fv-box fv-box--safe" id="fv-process">
              <span class="fv-box-title">Process event</span>
            </div>
            <div class="fv-box fv-box--danger" id="fv-reject">
              <span class="fv-box-title">400, silence</span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </ArrowDiagram>
  <Fragment slot="caption">
    The same forged request, with and without verification at the boundary.
    Unverified, it grants a free plan; behind the verify gate, legitimate
    traffic flows through and forgery dies at the chokepoint.
  </Fragment>
</Figure>

<style>
  .fv {
    max-width: 860px;
    margin-inline: auto;
    padding-block: 0.5rem;
  }

  .fv-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fv-row-tag {
    align-self: flex-start;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.15rem 0.55rem;
    border-radius: 0.4rem;
  }

  .fv-row-tag--bad {
    color: color-mix(in srgb, #dc2626 75%, var(--sl-color-white));
    background: color-mix(in srgb, #dc2626 14%, transparent);
    border: 1px solid color-mix(in srgb, #dc2626 35%, transparent);
  }

  .fv-row-tag--good {
    color: color-mix(in srgb, #16a34a 75%, var(--sl-color-white));
    background: color-mix(in srgb, #16a34a 14%, transparent);
    border: 1px solid color-mix(in srgb, #16a34a 35%, transparent);
  }

  .fv-divider {
    height: 1px;
    margin: 1.5rem 0;
    background: var(--sl-color-gray-5);
  }

  /* Top row: simple left-to-right line. */
  .fv-line {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 120px;
    align-items: center;
  }

  /* Bottom row: senders | gate | outcomes, gate vertically centered. */
  .fv-line--gate {
    gap: 150px;
  }

  .fv-col {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .fv-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.1rem;
    padding: 0.7rem 0.85rem;
    border-radius: 0.6rem;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-black);
    min-height: 3.2rem;
  }

  .fv-box-title {
    font-weight: 600;
    font-size: 0.92rem;
    line-height: 1.25;
    color: var(--sl-color-white);
  }

  .fv-box-sub {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
  }

  .fv-box--attacker {
    border-color: color-mix(in srgb, #dc2626 40%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #dc2626 7%, var(--sl-color-black));
  }

  .fv-box--stripe {
    border-color: color-mix(in srgb, #635bff 50%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #635bff 10%, var(--sl-color-black));
  }

  .fv-box--safe {
    border-color: color-mix(in srgb, #16a34a 55%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #16a34a 9%, var(--sl-color-black));
  }

  .fv-box--safe .fv-box-title {
    color: var(--sl-color-green-high, #4ade80);
  }

  .fv-box--danger {
    border-color: color-mix(in srgb, #dc2626 60%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #dc2626 12%, var(--sl-color-black));
  }

  .fv-box--danger .fv-box-title {
    color: var(--sl-color-red-high, #f87171);
  }

  /* The verify gate — the visual hero, a diamond-ish prominent block. */
  .fv-gate {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.15rem;
    padding: 1rem 1rem;
    border-radius: 0.7rem;
    border: 2px solid color-mix(in srgb, #635bff 65%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #635bff 12%, var(--sl-color-black));
    box-shadow: 0 0 0 4px color-mix(in srgb, #635bff 8%, transparent);
  }

  .fv-gate-title {
    font-weight: 700;
    font-size: 0.98rem;
    color: var(--sl-color-white);
  }

  .fv-gate-sub {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
  }

  @media (max-width: 720px) {
    .fv-line,
    .fv-line--gate {
      grid-template-columns: 1fr;
      gap: 56px;
      justify-items: center;
    }

    .fv-col {
      flex-direction: row;
      gap: 1.5rem;
    }
  }
</style>
