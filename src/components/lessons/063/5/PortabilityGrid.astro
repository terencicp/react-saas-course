---
// Portability grid — Chapter 063 L5, "One more provider is one more file".
//
// The lesson's closing thesis, banked in one glance: the webhook handler's
// SPINE is invariant across providers, only its EDGES move. The grid lays three
// provider columns (Stripe / Resend / next) over six rows, split into two
// bands:
//
//   top three rows    — the parts that VARY per provider (verify SDK, claim key
//                        source, event switch). Tinted amber/neutral so the eye
//                        reads "these change".
//   bottom three rows — the parts that are CONSTANT (the claim against
//                       processed_events, the single transaction, the
//                       200/400/500 status surface). Tinted green and visually
//                       fused into one block so the invariant spine reads as a
//                       unit.
//
// Pure HTML + CSS so it inspects in devtools and themes for free. Inline styles
// built as joined arrays (chapter convention); `margin: 0` reset everywhere
// defeats Starlight's prose-margin selector; color-mix mid-tones read on both
// light and dark. The Stripe/Resend cells in the constant band say "same" to
// hammer that nothing structural is reinvented.

import { Icon } from "astro-icon/components";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono = "font-family: var(--__sl-font-mono, ui-monospace, monospace)";

const amber = "#d97706"; // amber-600 — the varying edges
const green = "#16a34a"; // green-600 — the constant spine

type Band = "varies" | "constant";

interface Row {
  label: string; // the part of the handler
  stripe: string; // Stripe's value
  resend: string; // Resend's value
  next: string; // a hypothetical third provider's value
  band: Band;
}

// Three rows vary, three are constant. Order: varying edges on top, constant
// spine below — so the spine reads as a fused block at the foot of the grid.
const rows: Row[] = [
  {
    label: "Verify SDK",
    stripe: "stripe.webhooks\n.constructEvent",
    resend: "resend.webhooks\n.verify",
    next: "its own SDK call",
    band: "varies",
  },
  {
    label: "Claim key source",
    stripe: "event.id",
    resend: "svix-id header",
    next: "its message id",
    band: "varies",
  },
  {
    label: "Event switch",
    stripe: "checkout.*, invoice.*",
    resend: "email.bounced,\nemail.complained",
    next: "its event types",
    band: "varies",
  },
  {
    label: "Claim",
    stripe: "processed_events\n(provider, id)",
    resend: "same",
    next: "same",
    band: "constant",
  },
  {
    label: "Transaction",
    stripe: "one db.transaction",
    resend: "same",
    next: "same",
    band: "constant",
  },
  {
    label: "Status surface",
    stripe: "200 / 400 / 500",
    resend: "same",
    next: "same",
    band: "constant",
  },
];

const providers = [
  { name: "Stripe", icon: "simple-icons:stripe", key: "stripe" as const },
  { name: "Resend", icon: "simple-icons:resend", key: "resend" as const },
  { name: "Next provider", icon: "lucide:plus", key: "next" as const },
];

const toneFor = (band: Band) => (band === "varies" ? amber : green);

// ---- styles -------------------------------------------------------------

const frame = [
  reset,
  "box-sizing: border-box",
  "max-width: 760px",
  "margin: 0 auto",
  sans,
  "display: grid",
  // row-label column + three equal provider columns.
  "grid-template-columns: minmax(96px, 0.9fr) repeat(3, minmax(0, 1fr))",
  "gap: 6px",
].join("; ");

const cornerCell = [reset, "box-sizing: border-box"].join("; ");

const headCell = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "gap: 6px",
  "padding: 8px 6px",
  "border-radius: 8px",
  "font-size: 13px",
  "font-weight: 700",
  "color: var(--sl-color-white)",
  "background: color-mix(in srgb, var(--sl-color-gray-5) 55%, var(--sl-color-bg))",
  "border: 1px solid var(--sl-color-gray-5)",
].join("; ");

const rowLabel = (band: Band) => {
  const a = toneFor(band);
  return [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "padding: 8px 10px",
    "border-radius: 8px",
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.2",
    `color: color-mix(in srgb, ${a} 80%, var(--sl-color-text))`,
    `background: color-mix(in srgb, ${a} 12%, var(--sl-color-bg))`,
    `border: 1px solid color-mix(in srgb, ${a} 38%, transparent)`,
  ].join("; ");
};

const cell = (band: Band, same: boolean) => {
  const a = toneFor(band);
  return [
    reset,
    mono,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "text-align: center",
    "padding: 8px 6px",
    "border-radius: 8px",
    "font-size: 11.5px",
    "line-height: 1.25",
    "white-space: pre-line",
    same ? "font-weight: 700" : "font-weight: 500",
    same
      ? `color: ${a}`
      : `color: color-mix(in srgb, ${a} 78%, var(--sl-color-text))`,
    `background: color-mix(in srgb, ${a} ${same ? "16%" : "8%"}, var(--sl-color-bg))`,
    `border: 1px solid color-mix(in srgb, ${a} ${same ? "42%" : "28%"}, transparent)`,
  ].join("; ");
};

// The two band tags that bracket each group on the left edge.
const bandTag = (band: Band) => {
  const a = toneFor(band);
  return [
    reset,
    "grid-column: 1 / -1",
    "display: flex",
    "align-items: center",
    "gap: 8px",
    "margin: 4px 0 0",
    "font-size: 11px",
    "font-weight: 800",
    "letter-spacing: 0.08em",
    "text-transform: uppercase",
    `color: color-mix(in srgb, ${a} 75%, var(--sl-color-text))`,
  ].join("; ");
};

const bandRule = (band: Band) =>
  [
    reset,
    "flex: 1",
    "height: 1px",
    `background: color-mix(in srgb, ${toneFor(band)} 40%, transparent)`,
  ].join("; ");

const iconStyle = "width: 15px; height: 15px;";

const variesRows = rows.filter((r) => r.band === "varies");
const constantRows = rows.filter((r) => r.band === "constant");
---

<div class="not-content portability-grid" style={frame}>
  {/* header row: blank corner + three provider columns */}
  <div style={cornerCell}></div>
  {
    providers.map((p) => (
      <div style={headCell}>
        <Icon name={p.icon} style={iconStyle} aria-hidden="true" />
        <span style={reset}>{p.name}</span>
      </div>
    ))
  }

  {/* VARIES band */}
  <div style={bandTag("varies")}>
    <span style={reset}>Varies per provider — the edges</span>
    <span style={bandRule("varies")}></span>
  </div>
  {
    variesRows.map((r) => (
      <>
        <div style={rowLabel(r.band)}>{r.label}</div>
        <div style={cell(r.band, false)}>{r.stripe}</div>
        <div style={cell(r.band, false)}>{r.resend}</div>
        <div style={cell(r.band, false)}>{r.next}</div>
      </>
    ))
  }

  {/* CONSTANT band */}
  <div style={bandTag("constant")}>
    <span style={reset}>Constant across providers — the spine</span>
    <span style={bandRule("constant")}></span>
  </div>
  {
    constantRows.map((r) => (
      <>
        <div style={rowLabel(r.band)}>{r.label}</div>
        <div style={cell(r.band, false)}>{r.stripe}</div>
        <div style={cell(r.band, r.resend === "same")}>{r.resend}</div>
        <div style={cell(r.band, r.next === "same")}>{r.next}</div>
      </>
    ))
  }
</div>

<style>
  /* On phones the three monospace columns are too tight to read. Collapse to a
     single column: each row becomes a stacked label + the three provider values
     prefixed by their short name. The band tags still segment the two groups. */
  @media (max-width: 560px) {
    .portability-grid {
      grid-template-columns: 1fr !important;
    }
    /* hide the header provider row — values carry their own prefix below */
    .portability-grid > div:nth-child(2),
    .portability-grid > div:nth-child(3),
    .portability-grid > div:nth-child(4),
    .portability-grid > div:nth-child(1) {
      display: none !important;
    }
  }
</style>
