---
// A stylized Sentry-style waterfall trace for the dashboard request, hand-built
// in HTML + CSS. Deliberately mirrors the bar vocabulary of
// WaterfallTimingTransformation (same slate dependency bars, same 80ms ticks,
// same monospace read names) so the abstract timing diagram and the concrete
// trace artifact read as the same picture.
//
// Layout:
//   - A root span row spanning the full width: `GET /dashboard — 320ms`.
//   - Four indented child spans drawn as offset bars on a shared 0–320ms axis,
//     each starting where the last ended, forming a descending staircase:
//       getUser          0–80ms
//       getOrg          80–160ms
//       listInvoices   160–240ms
//       listTeamMembers 240–320ms
//   - A callout following the diagonal of the staircase: "each bar starts where
//     the last ended — sequential".
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

const reset = "margin: 0";
const codeFont =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;";
const uiFont =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);";

// --- Axis -----------------------------------------------------------------
const AXIS_MAX = 320;
const pct = (ms: number) => (ms / AXIS_MAX) * 100;

// --- Colours --------------------------------------------------------------
const ROOT = "#334155"; // slate-700 — the root request span
const DEP = "#475569"; // slate-600 — the auth/org dependency chain
const NEUTRAL = "#64748b"; // slate-500 — the (needlessly serial) reads
const ACCENT = "#0d9488"; // teal-600 — the callout, matches the sibling colour

// --- Spans ----------------------------------------------------------------
// Each child span: name, [start, end] in ms, and bar colour.
const spans = [
  { name: "getUser", start: 0, end: 80, color: DEP },
  { name: "getOrg", start: 80, end: 160, color: DEP },
  { name: "listInvoices", start: 160, end: 240, color: NEUTRAL },
  { name: "listTeamMembers", start: 240, end: 320, color: NEUTRAL },
];

// --- Geometry -------------------------------------------------------------
const LABEL_W = 130; // px gutter for the span name (indented child rows)
const ROW_H = 28; // px per span row
const BAR_H = 15; // px bar thickness

const wrap = [
  reset,
  uiFont,
  "width: 100%",
  "max-width: 660px",
  "margin-left: auto",
  "margin-right: auto",
].join("; ");

const rowGrid = [
  reset,
  "display: grid",
  `grid-template-columns: ${LABEL_W}px 1fr`,
  "align-items: center",
  `height: ${ROW_H}px`,
].join("; ");

// Child span names sit slightly indented and right-aligned against the track.
const labelStyle = [
  reset,
  codeFont,
  "font-size: 12px",
  "font-weight: 600",
  "color: var(--sl-color-white)",
  "text-align: right",
  "padding-right: 10px",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");

const trackStyle = [reset, "position: relative", `height: ${ROW_H}px`].join(
  "; ",
);

const barStyle = (startMs: number, endMs: number, color: string) =>
  [
    reset,
    "position: absolute",
    `top: ${(ROW_H - BAR_H) / 2}px`,
    `height: ${BAR_H}px`,
    `left: ${pct(startMs)}%`,
    `width: ${pct(endMs - startMs)}%`,
    `background: ${color}`,
    "border-radius: 3px",
    "box-sizing: border-box",
  ].join("; ");

// The duration label rides just to the right of each bar's end.
const durStyle = (endMs: number) =>
  [
    reset,
    "position: absolute",
    `top: ${(ROW_H - BAR_H) / 2 + 1}px`,
    `left: calc(${pct(endMs)}% + 6px)`,
    codeFont,
    "font-size: 10px",
    "font-weight: 600",
    "color: var(--sl-color-gray-3)",
    "white-space: nowrap",
  ].join("; ");

// Faint gridlines at each 80ms tick so the staircase reads against an axis.
const ticks = [80, 160, 240];

const tickLine = (ms: number) =>
  [
    reset,
    "position: absolute",
    "top: 0",
    "bottom: 0",
    `left: ${pct(ms)}%`,
    "width: 1px",
    "background: color-mix(in srgb, currentColor 12%, transparent)",
  ].join("; ");
---

<div style={wrap}>
  {/* Root span: the whole request, spanning the full axis. */}
  <div style={`${reset}; display: grid; grid-template-columns: ${LABEL_W}px 1fr;`}>
    <div
      style={`${reset}; ${codeFont} font-size: 12px; font-weight: 700; color: var(--sl-color-white); text-align: right; padding-right: 10px; white-space: nowrap; align-self: center;`}
    >
      GET /dashboard
    </div>
    <div style={`${reset}; position: relative; height: ${ROW_H}px;`}>
      <div
        style={`${barStyle(0, AXIS_MAX, ROOT)}; display: flex; align-items: center; justify-content: flex-end; padding-right: 8px;`}
      >
        <span
          style={`${reset}; ${uiFont} font-size: 10px; font-weight: 700; color: #fff; opacity: 0.85; letter-spacing: 0.02em;`}
        >320ms</span>
      </div>
    </div>
  </div>

  {/* Child spans, with gridlines behind them, forming the staircase. */}
  <div style={`${reset}; display: grid; grid-template-columns: ${LABEL_W}px 1fr; margin-top: 4px;`}>
    <div style={reset}></div>
    <div style={`${reset}; position: relative;`}>
      {/* vertical 80ms gridlines spanning the four child rows */}
      <div style={`${reset}; position: absolute; inset: 0; pointer-events: none;`}>
        {ticks.map((ms) => <div style={tickLine(ms)}></div>)}
      </div>
    </div>
  </div>

  {spans.map((s) => (
    <div style={rowGrid}>
      <div style={labelStyle}>{s.name}</div>
      <div style={trackStyle}>
        <div style={barStyle(s.start, s.end, s.color)}></div>
        <div style={durStyle(s.end)}>{s.end - s.start}ms</div>
      </div>
    </div>
  ))}

  {/* Callout following the diagonal edge of the staircase. */}
  <div style={`${reset}; display: grid; grid-template-columns: ${LABEL_W}px 1fr; margin-top: 6px;`}>
    <div style={reset}></div>
    <div style={`${reset}; position: relative; height: 22px;`}>
      {/* a diagonal line tracing the step ends, with a tag underneath */}
      <div
        style={`${reset}; position: absolute; top: 0; left: ${pct(80)}%; width: ${pct(320 - 80)}%; border-top: 1.5px dashed color-mix(in srgb, ${ACCENT} 60%, transparent); transform-origin: left top; height: 0;`}
      ></div>
      <div
        style={`${reset}; position: absolute; top: 6px; left: ${pct(200)}%; transform: translateX(-50%); ${uiFont} font-size: 10.5px; font-weight: 600; color: ${ACCENT}; white-space: nowrap;`}
      >
        each bar starts where the last ended — sequential
      </div>
    </div>
  </div>

  {/* Axis endpoints. */}
  <div style={`${reset}; display: grid; grid-template-columns: ${LABEL_W}px 1fr; margin-top: 2px;`}>
    <div style={reset}></div>
    <div style={`${reset}; position: relative; height: 14px;`}>
      <div style={`${reset}; position: absolute; top: 0; left: 0; ${codeFont} font-size: 10px; color: var(--sl-color-gray-3);`}>0</div>
      <div style={`${reset}; position: absolute; top: 0; right: 0; ${codeFont} font-size: 10px; color: var(--sl-color-gray-3);`}>320ms</div>
    </div>
  </div>
</div>
