---
// One frame of the waterfall timing-transformation Gantt, used inside
// <DiagramSequence>. Four reads — user, org, invoices, team — each ~80ms,
// laid on a shared 0–340ms axis as horizontal bars.
//
//   Step 1 — the waterfall: four bars stacked into a descending staircase,
//            each starting where the last ended. Total ~320ms.
//   Step 2 — find the independents: invoices + team highlighted as siblings
//            off org, with a brace noting "same dependency, independent".
//   Step 3 — overlap the siblings: invoices + team now start at the same x
//            (right after org). Total shrinks to ~240ms; the 240–320ms span
//            is shaded green as the "saved" region.
//
// The axis is fixed across all three frames so bars never reflow as the
// reader scrubs — only their offsets and highlights change. Pure HTML + CSS.
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

interface Props {
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const reset = "margin: 0";
const codeFont =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;";
const uiFont =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);";

// --- Axis -----------------------------------------------------------------
// Domain runs 0..AXIS_MAX ms; each read is DUR ms wide.
const AXIS_MAX = 340;
const DUR = 80;
const pct = (ms: number) => (ms / AXIS_MAX) * 100;

// Each read's start offset (ms) depends on the step.
// user -> org are always sequential (real dependencies).
// invoices/team stack after org in steps 1–2, overlap in step 3.
const USER_START = 0;
const ORG_START = 80;
const SEQ_INV_START = 160; // invoices in the staircase
const SEQ_TEAM_START = 240; // team in the staircase
const PAR_START = 160; // invoices + team together after org

const invStart = step === 3 ? PAR_START : SEQ_INV_START;
const teamStart = step === 3 ? PAR_START : SEQ_TEAM_START;

// Totals: staircase ends at 320; overlapped ends at max(inv, team) = 240.
const totalMs = step === 3 ? 240 : 320;

// --- Colours --------------------------------------------------------------
const NEUTRAL = "#64748b"; // slate-500 — plain bars
const DEP = "#475569"; // slate-600 — user/org (the real dependency chain)
const SIBLING = "#0d9488"; // teal-600 — the independent pair (highlighted)
const SAVED = "#16a34a"; // green-600 — the time saved in step 3

// In steps 2 and 3 the sibling pair is highlighted; otherwise neutral.
const siblingHighlighted = step >= 2;
const invColor = siblingHighlighted ? SIBLING : NEUTRAL;
const teamColor = siblingHighlighted ? SIBLING : NEUTRAL;

// --- Geometry -------------------------------------------------------------
const LABEL_W = 78; // px gutter for the read name
const ROW_H = 30; // px per row
const BAR_H = 16; // px bar thickness

const wrap = [
  reset,
  uiFont,
  "width: 100%",
  "max-width: 640px",
  "margin-left: auto",
  "margin-right: auto",
].join("; ");

const rowGrid = [
  reset,
  "display: grid",
  `grid-template-columns: ${LABEL_W}px 1fr`,
  "align-items: center",
  `height: ${ROW_H}px`,
].join("; ");

const labelStyle = [
  reset,
  codeFont,
  "font-size: 12.5px",
  "font-weight: 600",
  "color: var(--sl-color-white)",
  "text-align: right",
  "padding-right: 10px",
  "white-space: nowrap",
].join("; ");

// The track each bar floats inside (one row's worth of the axis).
const trackStyle = [
  reset,
  "position: relative",
  `height: ${ROW_H}px`,
].join("; ");

const barStyle = (startMs: number, color: string) =>
  [
    reset,
    "position: absolute",
    `top: ${(ROW_H - BAR_H) / 2}px`,
    `height: ${BAR_H}px`,
    `left: ${pct(startMs)}%`,
    `width: ${pct(DUR)}%`,
    `background: ${color}`,
    "border-radius: 3px",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "box-sizing: border-box",
  ].join("; ");

const barLabel = [
  reset,
  uiFont,
  "font-size: 10px",
  "font-weight: 600",
  "color: #fff",
  "opacity: 0.9",
  "letter-spacing: 0.02em",
].join("; ");

// Faint gridlines at each 80ms tick so the staircase reads against an axis.
const ticks = [80, 160, 240, 320];

const tickLine = (ms: number) =>
  [
    reset,
    "position: absolute",
    "top: 0",
    "bottom: 0",
    `left: ${pct(ms)}%`,
    "width: 1px",
    "background: color-mix(in srgb, currentColor 12%, transparent)",
  ].join("; ");

// The "now" total bracket sits under the bars.
const bracketColor = step === 3 ? SAVED : "var(--sl-color-gray-3)";
---

<div style={wrap}>
  {/* Plot area: gridlines span all rows, bars + an axis live on top. */}
  <div style={`${reset}; display: grid; grid-template-columns: ${LABEL_W}px 1fr;`}>
    {/* spacer above the gutter */}
    <div style={reset}></div>
    {/* the bars region, with gridlines behind every row */}
    <div style={`${reset}; position: relative;`}>
      {/* vertical 80ms gridlines spanning the four rows */}
      <div style={`${reset}; position: absolute; inset: 0; pointer-events: none;`}>
        {ticks.map((ms) => <div style={tickLine(ms)}></div>)}
      </div>

      {/* Step 3 only: shaded "saved" region from 240ms to 320ms. */}
      {step === 3 && (
        <div
          style={`${reset}; position: absolute; top: 0; bottom: 0; left: ${pct(240)}%; width: ${pct(320 - 240)}%; background: color-mix(in srgb, ${SAVED} 14%, transparent); border-left: 1px dashed color-mix(in srgb, ${SAVED} 55%, transparent); border-right: 1px dashed color-mix(in srgb, ${SAVED} 55%, transparent);`}
        >
          <div
            style={`${reset}; position: absolute; top: 2px; left: 50%; transform: translateX(-50%); ${uiFont} font-size: 9.5px; font-weight: 700; color: ${SAVED}; letter-spacing: 0.03em; white-space: nowrap;`}
          >
            saved
          </div>
        </div>
      )}
    </div>
  </div>

  {/* Row: user (always first, real dependency root) */}
  <div style={rowGrid}>
    <div style={labelStyle}>user</div>
    <div style={trackStyle}>
      <div style={barStyle(USER_START, DEP)}><span style={barLabel}>80ms</span></div>
    </div>
  </div>

  {/* Row: org (depends on user) */}
  <div style={rowGrid}>
    <div style={labelStyle}>org</div>
    <div style={trackStyle}>
      <div style={barStyle(ORG_START, DEP)}><span style={barLabel}>80ms</span></div>
    </div>
  </div>

  {/* Row: invoices (sibling off org) */}
  <div style={rowGrid}>
    <div style={labelStyle}>invoices</div>
    <div style={trackStyle}>
      <div style={barStyle(invStart, invColor)}><span style={barLabel}>80ms</span></div>
    </div>
  </div>

  {/* Row: team (sibling off org) */}
  <div style={rowGrid}>
    <div style={labelStyle}>team</div>
    <div style={trackStyle}>
      <div style={barStyle(teamStart, teamColor)}><span style={barLabel}>80ms</span></div>
    </div>
  </div>

  {/* Step 2 only: brace + note joining the two sibling rows. */}
  {step === 2 && (
    <div style={`${reset}; display: grid; grid-template-columns: ${LABEL_W}px 1fr;`}>
      <div style={reset}></div>
      <div style={`${reset}; position: relative; height: 26px;`}>
        {/* the brace sits under the staircase tail (160–320ms) */}
        <div
          style={`${reset}; position: absolute; top: 6px; left: ${pct(SEQ_INV_START)}%; width: ${pct(SEQ_TEAM_START + DUR - SEQ_INV_START)}%; height: 8px; border: 1.5px solid ${SIBLING}; border-top: none; border-radius: 0 0 6px 6px;`}
        ></div>
        <div
          style={`${reset}; position: absolute; top: 15px; left: ${pct(SEQ_INV_START)}%; width: ${pct(SEQ_TEAM_START + DUR - SEQ_INV_START)}%; ${uiFont} font-size: 10.5px; font-weight: 600; color: ${SIBLING}; text-align: center; white-space: nowrap;`}
        >
          same dependency (<span style={codeFont}>org</span>), independent of each other
        </div>
      </div>
    </div>
  )}

  {/* Total bracket + axis labels under everything. */}
  <div style={`${reset}; margin-top: ${step === 2 ? 4 : 12}px; display: grid; grid-template-columns: ${LABEL_W}px 1fr;`}>
    <div style={reset}></div>
    <div style={`${reset}; position: relative; height: 34px;`}>
      {/* total-duration span from 0 to totalMs */}
      <div
        style={`${reset}; position: absolute; top: 0; left: 0; width: ${pct(totalMs)}%; height: 7px; border: 1.5px solid ${bracketColor}; border-bottom: none; border-radius: 6px 6px 0 0; transition: width 240ms ease;`}
      ></div>
      <div
        style={`${reset}; position: absolute; top: 9px; left: 0; width: ${pct(totalMs)}%; ${uiFont} font-size: 12px; font-weight: 700; color: ${bracketColor}; text-align: center; white-space: nowrap; transition: width 240ms ease, color 240ms ease;`}
      >
        ~{totalMs}ms
      </div>
      {/* axis end tick */}
      <div
        style={`${reset}; position: absolute; top: 24px; left: 0; ${codeFont} font-size: 10px; color: var(--sl-color-gray-3);`}
      >0</div>
      <div
        style={`${reset}; position: absolute; top: 24px; right: 0; ${codeFont} font-size: 10px; color: var(--sl-color-gray-3);`}
      >340ms</div>
    </div>
  </div>
</div>
