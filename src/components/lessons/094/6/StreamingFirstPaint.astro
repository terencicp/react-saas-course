---
// One frame of the "block-on-all vs stream-the-slow-one" first-paint contrast,
// used inside <DiagramSequence>. Reuses the bar vocabulary of the lesson's
// first diagram (WaterfallTimingTransformation): horizontal bars on a shared
// ms axis, code-font row labels, faint gridlines.
//
// Two reads, already running in parallel from t=0:
//   profile   ~50ms  (fast)
//   analytics ~800ms (slow)
//
//   Step 1 — Block on all (Promise.all): the page can't paint until the slow
//            read finishes, so the "first paint" line sits at the END of the
//            analytics bar (~800ms). The user sees nothing until then.
//   Step 2 — Stream the slow one: the fast content paints immediately, so the
//            "first paint" line jumps left to the end of the profile bar
//            (~50ms). A skeleton placeholder holds the analytics row until the
//            (unchanged) slow bar resolves and swaps in.
//
// The crucial reading: the analytics bar is IDENTICAL in both frames — the slow
// fetch is exactly as slow. Only the first-paint line moved. Pure HTML + CSS;
// the fixed axis keeps the bars from reflowing as the reader scrubs.
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

interface Props {
  step: 1 | 2;
}

const { step } = Astro.props;

const reset = "margin: 0";
const codeFont =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;";
const uiFont =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);";

// --- Axis -----------------------------------------------------------------
// Domain runs 0..AXIS_MAX ms. The analytics bar dominates the scale.
const AXIS_MAX = 900;
const pct = (ms: number) => (ms / AXIS_MAX) * 100;

const PROFILE_DUR = 50;
const ANALYTICS_DUR = 800;

// First paint: end of the slow bar when blocking, end of the fast bar when
// streaming. This is the only value that changes between the two frames.
const firstPaintMs = step === 1 ? ANALYTICS_DUR : PROFILE_DUR;

const streaming = step === 2;

// --- Colours --------------------------------------------------------------
const FAST = "#0d9488"; // teal-600 — the fast read (paints first)
const SLOW = "#475569"; // slate-600 — the slow read
const SKELETON = "#94a3b8"; // slate-400 — the streaming skeleton placeholder
const PAINT = "#16a34a"; // green-600 — the first-paint marker

// --- Geometry -------------------------------------------------------------
const LABEL_W = 78; // px gutter for the read name
const ROW_H = 30; // px per row
const BAR_H = 16; // px bar thickness

const wrap = [
  reset,
  uiFont,
  "width: 100%",
  "max-width: 640px",
  "margin-left: auto",
  "margin-right: auto",
].join("; ");

const labelStyle = [
  reset,
  codeFont,
  "font-size: 12.5px",
  "font-weight: 600",
  "color: var(--sl-color-white)",
  "text-align: right",
  "padding-right: 10px",
  "white-space: nowrap",
].join("; ");

const rowGrid = [
  reset,
  "display: grid",
  `grid-template-columns: ${LABEL_W}px 1fr`,
  "align-items: center",
  `height: ${ROW_H}px`,
].join("; ");

const trackStyle = [reset, "position: relative", `height: ${ROW_H}px`].join(
  "; ",
);

const barStyle = (startMs: number, durMs: number, color: string) =>
  [
    reset,
    "position: absolute",
    `top: ${(ROW_H - BAR_H) / 2}px`,
    `height: ${BAR_H}px`,
    `left: ${pct(startMs)}%`,
    `width: ${pct(durMs)}%`,
    `background: ${color}`,
    "border-radius: 3px",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "box-sizing: border-box",
  ].join("; ");

// A dashed skeleton placeholder occupying the slow row until it streams in.
const skeletonStyle = (startMs: number, durMs: number) =>
  [
    reset,
    "position: absolute",
    `top: ${(ROW_H - BAR_H) / 2}px`,
    `height: ${BAR_H}px`,
    `left: ${pct(startMs)}%`,
    `width: ${pct(durMs)}%`,
    "border-radius: 3px",
    `border: 1.5px dashed ${SKELETON}`,
    `background: repeating-linear-gradient(45deg, color-mix(in srgb, ${SKELETON} 18%, transparent) 0 6px, transparent 6px 12px)`,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "justify-content: center",
  ].join("; ");

const barLabel = [
  reset,
  uiFont,
  "font-size: 10px",
  "font-weight: 600",
  "color: #fff",
  "opacity: 0.9",
  "letter-spacing: 0.02em",
].join("; ");

const skeletonLabel = [
  reset,
  uiFont,
  "font-size: 9.5px",
  "font-weight: 700",
  `color: ${SKELETON}`,
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
].join("; ");

// Faint gridlines at every 200ms tick so the bars read against an axis.
const ticks = [200, 400, 600, 800];

const tickLine = (ms: number) =>
  [
    reset,
    "position: absolute",
    "top: 0",
    "bottom: 0",
    `left: ${pct(ms)}%`,
    "width: 1px",
    "background: color-mix(in srgb, currentColor 12%, transparent)",
  ].join("; ");
---

<div style={wrap}>
  {/* Plot area: gridlines + the first-paint marker span both rows. */}
  <div style={`${reset}; display: grid; grid-template-columns: ${LABEL_W}px 1fr;`}>
    <div style={reset}></div>
    <div style={`${reset}; position: relative;`}>
      {/* vertical 200ms gridlines spanning the two rows */}
      <div style={`${reset}; position: absolute; inset: 0; pointer-events: none;`}>
        {ticks.map((ms) => <div style={tickLine(ms)}></div>)}
      </div>

      {/* The first-paint marker: a full-height vertical line that slides from
          ~800ms (block) to ~50ms (stream) as the reader scrubs. */}
      <div
        style={`${reset}; position: absolute; top: -4px; bottom: -4px; left: ${pct(firstPaintMs)}%; width: 2px; background: ${PAINT}; transition: left 320ms ease; z-index: 2;`}
      >
        <div
          style={`${reset}; position: absolute; top: -16px; left: 50%; transform: translateX(-50%); ${uiFont} font-size: 9.5px; font-weight: 700; color: ${PAINT}; white-space: nowrap; letter-spacing: 0.02em;`}
        >
          first paint ~{firstPaintMs}ms
        </div>
      </div>
    </div>
  </div>

  {/* Spacer so the first-paint label above the marker has room. */}
  <div style={`${reset}; height: 14px;`}></div>

  {/* Row: profile (fast — paints first) */}
  <div style={rowGrid}>
    <div style={labelStyle}>profile</div>
    <div style={trackStyle}>
      <div style={barStyle(0, PROFILE_DUR, FAST)}></div>
      <div
        style={`${reset}; position: absolute; top: ${(ROW_H - BAR_H) / 2}px; height: ${BAR_H}px; left: ${pct(PROFILE_DUR)}%; display: flex; align-items: center; padding-left: 6px; ${barLabel} color: ${FAST};`}
      >50ms</div>
    </div>
  </div>

  {/* Row: analytics (slow — IDENTICAL bar in both steps) */}
  <div style={rowGrid}>
    <div style={labelStyle}>analytics</div>
    <div style={trackStyle}>
      {streaming ? (
        <div style={skeletonStyle(0, ANALYTICS_DUR)}>
          <span style={skeletonLabel}>skeleton — streaming in…</span>
        </div>
      ) : (
        <div style={barStyle(0, ANALYTICS_DUR, SLOW)}>
          <span style={barLabel}>800ms</span>
        </div>
      )}
    </div>
  </div>

  {/* Footnote axis ticks. */}
  <div style={`${reset}; margin-top: 8px; display: grid; grid-template-columns: ${LABEL_W}px 1fr;`}>
    <div style={reset}></div>
    <div style={`${reset}; position: relative; height: 14px;`}>
      <div
        style={`${reset}; position: absolute; top: 0; left: 0; ${codeFont} font-size: 10px; color: var(--sl-color-gray-3);`}
      >0</div>
      <div
        style={`${reset}; position: absolute; top: 0; right: 0; ${codeFont} font-size: 10px; color: var(--sl-color-gray-3);`}
      >900ms</div>
    </div>
  </div>
</div>
