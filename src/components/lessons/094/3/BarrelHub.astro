---
// barrel-hub-diagram — Chapter 094 Lesson 3, "The barrel-export trap".
//
// The lesson's conceptual spine, made spatial. Two tabs, same import line:
//
//   Tab 1 "Barrel import":
//     import { Pencil } ──resolves to──▶ lucide-react/index.ts ──┬──▶ pencil.js
//     from 'lucide-react'                (the barrel hub)        ├──▶ trash.js
//                                                                ├──▶ camera.js
//                                                                ├──▶ user.js
//                                                                └──▶ …1500 modules
//
//   Tab 2 "Rewritten import":
//     import { Pencil } ──rewritten at build──▶ pencil.js   (one module, directly)
//     from 'lucide-react'   (green)            hub + the other modules sit greyed,
//                                              with NO arrows touching them.
//
// The visual point: one tiny, innocent-looking import line ends up wired to the
// WHOLE library through the barrel hub (left tab); the optimized build rewrites
// the exact same line to reach a single module directly, bypassing the hub
// (right tab). Same source, two bundle outcomes.
//
// Built with <ArrowDiagram> (LeaderLine) because the nodes are custom HTML — a
// code-styled two-line import box, a hub box with a sub-label, and a vertical
// stack of monospace module chips — and the per-arrow semantics matter (the green
// "good shape" arrow in tab 2). Plain-label D2/Mermaid boxes wouldn't carry the
// code styling or the greyed-out bypass state.
//
// Arrows are positioned from document.body, so each wrapping <Figure> MUST be
// expandable={false}: relocating the body into the lightbox breaks the lines.
// TabbedContent provides its own outer card, so it is NOT wrapped in <Figure>;
// each tab's Figure is the per-state card.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark). The green
// accent (#16a34a) is a mid-tone used as-is in both themes. A margin:0 reset on
// every node defeats Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';
import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

const GOOD_GREEN = '#16a34a'; // green-600 — the "this is the good shape" arrow

// The representative module stack, shared by both tabs. The first four are real
// icon files; the last stands in for the rest of the library.
const modules = [
	{ id: 'pencil', label: 'pencil.js', isTarget: true },
	{ id: 'trash', label: 'trash.js', isTarget: false },
	{ id: 'camera', label: 'camera.js', isTarget: false },
	{ id: 'user', label: 'user.js', isTarget: false },
	{ id: 'rest', label: '…1500 modules', isTarget: false },
];

// Tab 1 — the barrel import: one arrow into the hub, then the hub fans out to
// every module box. Stagger the fan-out gravity so the five curves spread into
// distinct lanes instead of stacking.
const barrelArrows = [
	{
		from: 'b-import',
		to: 'b-hub',
		label: 'resolves to',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -24],
	},
	{
		from: 'b-hub',
		to: 'b-mod-pencil',
		label: 'pulls all',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [90, -70],
		endSocketGravity: [-50, 0],
		labelOffset: [6, -18],
	},
	{
		from: 'b-hub',
		to: 'b-mod-trash',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, -35],
		endSocketGravity: [-45, 0],
	},
	{
		from: 'b-hub',
		to: 'b-mod-camera',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [55, 0],
		endSocketGravity: [-45, 0],
	},
	{
		from: 'b-hub',
		to: 'b-mod-user',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 35],
		endSocketGravity: [-45, 0],
	},
	{
		from: 'b-hub',
		to: 'b-mod-rest',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [90, 70],
		endSocketGravity: [-50, 0],
	},
];

// Tab 2 — the rewritten import: a single green arrow straight from the import
// site to pencil.js, leaping over the dimmed hub entirely. No other arrows.
const rewrittenArrows = [
	{
		from: 'r-import',
		to: 'r-mod-pencil',
		label: 'rewritten at build → per-export path',
		color: GOOD_GREEN,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [140, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -26],
	},
];
---

<TabbedContent>
	<TabbedItem label="Barrel import">
		<Figure expandable={false}>
			<ArrowDiagram arrows={barrelArrows}>
				<div class="bh not-content">
					{/* Column 1: the innocent-looking import line. */}
					<div class="bh-col bh-col-import">
						<div class="bh-box bh-box-import" id="b-import">
							<code class="bh-code"
								>import &#123; Pencil &#125; from <span class="bh-str"
									>'lucide-react'</span
								>;</code
							>
							<span class="bh-under">the import site</span>
						</div>
					</div>

					{/* Column 2: the barrel hub — the re-export-everything chokepoint. */}
					<div class="bh-col bh-col-hub">
						<div class="bh-box bh-box-hub" id="b-hub">
							<span class="bh-hub-title">lucide-react/index.ts</span>
							<span class="bh-under">barrel — re-exports everything</span>
						</div>
					</div>

					{/* Column 3: the whole library, fanned out from the hub. */}
					<div class="bh-col bh-col-mods">
						{
							modules.map((m) => (
								<div class="bh-mod" id={`b-mod-${m.id}`}>
									{m.label}
								</div>
							))
						}
					</div>
				</div>
			</ArrowDiagram>
			<Fragment slot="caption">
				One named import points at the barrel, and now the bundler has the
				<strong>whole library</strong> on the table — it has to prove each of the
				other ~1500 modules is safe to drop.
			</Fragment>
		</Figure>
	</TabbedItem>

	<TabbedItem label="Rewritten import">
		<Figure expandable={false}>
			<ArrowDiagram arrows={rewrittenArrows}>
				<div class="bh not-content">
					{/* Same import line as the other tab — the contrast is the point. */}
					<div class="bh-col bh-col-import">
						<div class="bh-box bh-box-import" id="r-import">
							<code class="bh-code"
								>import &#123; Pencil &#125; from <span class="bh-str"
									>'lucide-react'</span
								>;</code
							>
							<span class="bh-under">the import site</span>
						</div>
					</div>

					{/* The hub is bypassed — dimmed, with no arrows touching it. */}
					<div class="bh-col bh-col-hub">
						<div class="bh-box bh-box-hub bh-dim" id="r-hub" aria-hidden="true">
							<span class="bh-hub-title">lucide-react/index.ts</span>
							<span class="bh-under">barrel — bypassed</span>
						</div>
					</div>

					{/* Only pencil.js is reached; the rest stay greyed with no arrows. */}
					<div class="bh-col bh-col-mods">
						{
							modules.map((m) => (
								<div
									class:list={['bh-mod', { 'bh-mod-target': m.isTarget, 'bh-dim': !m.isTarget }]}
									id={`r-mod-${m.id}`}
									aria-hidden={m.isTarget ? undefined : 'true'}
								>
									{m.label}
								</div>
							))
						}
					</div>
				</div>
			</ArrowDiagram>
			<Fragment slot="caption">
				The same import line, but the build has rewritten it to a per-export deep
				path — it reaches <strong>one module</strong> directly and the barrel hub is
				bypassed.
			</Fragment>
		</Figure>
	</TabbedItem>
</TabbedContent>

<style>
	.bh {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: space-between;
		gap: 110px;
		margin: 0;
		padding: 18px 6px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.bh-col {
		display: flex;
		flex-direction: column;
		margin: 0;
		flex: 0 1 auto;
	}

	.bh-col-import,
	.bh-col-hub {
		align-self: center;
	}

	/* Column 3: the module stack, evenly spaced so the fan-out arrows separate. */
	.bh-col-mods {
		gap: 10px;
		align-self: center;
	}

	.bh-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		padding: 11px 16px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	/* The import site reads as a small code card. */
	.bh-box-import {
		border-color: var(--sl-color-gray-4, #94a3b8);
		align-items: flex-start;
		text-align: left;
	}

	.bh-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.8rem;
		line-height: 1.3;
		white-space: nowrap;
		background: none;
		border: none;
		padding: 0;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.bh-str {
		color: #c2410c; /* amber-700 — the package path, the thing that points at the barrel */
	}

	/* The hub is the focal box in tab 1 — a touch heavier border. */
	.bh-box-hub {
		border-color: var(--sl-color-gray-4, #94a3b8);
		border-width: 2px;
	}

	.bh-hub-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.bh-under {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Each module is a compact monospace chip. */
	.bh-mod {
		box-sizing: border-box;
		padding: 6px 12px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.74rem;
		line-height: 1.3;
		white-space: nowrap;
		text-align: center;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	/* The one module the rewritten import actually reaches — green, alive. */
	.bh-mod-target {
		border-color: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-5, #cbd5e1));
		color: #16a34a;
		font-weight: 600;
	}

	/* Bypassed / unused nodes in tab 2: greyed back so the eye ignores them. */
	.bh-dim {
		opacity: 0.4;
	}

	/* Narrow viewports: stack the three columns. The right→left sockets degrade to
	   vertical arcs between stacked boxes — readable, and labels still float in the
	   gaps. The fan-out is wide; tighten the gap so the height stays in budget. */
	@media (max-width: 760px) {
		.bh {
			flex-direction: column;
			align-items: center;
			gap: 48px;
		}
		.bh-col {
			width: 100%;
			align-items: center;
		}
		.bh-col-mods {
			align-items: center;
		}
		.bh-code {
			white-space: normal;
		}
	}
</style>
