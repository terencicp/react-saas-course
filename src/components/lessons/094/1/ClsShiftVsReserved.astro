---
// ClsShiftVsReserved — Chapter 094 Lesson 1 ("The Core Web Vitals").
//
// Makes "reserve the space" visceral by showing the exact same image load two
// ways, on a loop, in real (devtools-inspectable) CSS. Authored as two near-
// identical content columns — a headline, an image area, a button — that differ
// in ONE thing: whether the image's box is pre-sized.
//
//   • Unreserved: the image container starts at height:0 (bytes not in yet) and
//     animates up to its real height when the image "arrives", shoving the
//     headline and button DOWN. A red marker rides that downward jump.
//   • Reserved: the image lives in a box that is already its final height, so
//     the image just fades in inside it and NOTHING around it moves. A green
//     marker sits still next to the stable button.
//
// The animation loops so the contrast keeps replaying. Both columns share the
// same keyframe clock, so the unreserved jump and the reserved no-op happen at
// the same instant — the eye reads them as the same load, two outcomes.
//
// Each column is rendered by this single component, switched by the `variant`
// prop, so the two TabbedContent tabs stay structurally identical and only the
// reservation differs. Pure HTML+CSS per the diagrams guide; margin:0 on every
// node defeats Starlight's injected prose margins, min-width:0 guards the flex
// children. Honours prefers-reduced-motion by pinning to the loaded state.

interface Props {
	/** Which side of the comparison to render. */
	variant: 'unreserved' | 'reserved';
}

const { variant } = Astro.props;

const SHIFT = '#dc2626'; // red — the unexpected jump
const STABLE = '#16a34a'; // green — nothing moves
const accent = variant === 'unreserved' ? SHIFT : STABLE;
const markerText =
	variant === 'unreserved'
		? 'headline + button jump down'
		: 'box reserved — nothing moves';
---

<div class:list={['cls not-content', `cls--${variant}`]} style={`--accent:${accent};`}>
	{/* A mocked content column inside a small browser viewport */}
	<div class="cls-frame">
		{/* Headline line — page furniture that gets shoved (or not) */}
		<div class="cls-headline"></div>

		{/* The image area. In "reserved" this wrapper is already sized; in
		    "unreserved" it collapses to nothing until the bytes "arrive". */}
		<div class="cls-imgbox">
			<div class="cls-img">
				<svg viewBox="0 0 24 24" width="30" height="30" aria-hidden="true">
					<rect
						x="2"
						y="3"
						width="20"
						height="18"
						rx="2"
						fill="none"
						stroke="currentColor"
						stroke-width="1.6"></rect>
					<circle cx="8" cy="9" r="2" fill="currentColor"></circle>
					<path
						d="M3 18l5-5 4 4 3-3 6 6"
						fill="none"
						stroke="currentColor"
						stroke-width="1.6"
						stroke-linejoin="round"
						stroke-linecap="round"></path>
				</svg>
			</div>
		</div>

		{/* The button + its marker. The marker rides the button so its motion
		    (or stillness) is unmistakable. */}
		<div class="cls-buttonrow">
			<span class="cls-button">Buy now</span>
			<span class="cls-marker">{markerText}</span>
		</div>
	</div>
</div>

<style>
	.cls {
		margin: 0;
		display: flex;
		justify-content: center;
		padding: 8px 2px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* The mocked viewport. Fixed total height so the column has somewhere to
	   jump *into* — the reserved space below the button is what stays empty
	   in the unreserved case while the image is still missing. */
	.cls-frame {
		box-sizing: border-box;
		width: 100%;
		max-width: 360px;
		min-height: 230px;
		margin: 0;
		padding: 18px;
		display: flex;
		flex-direction: column;
		gap: 14px;
		border-radius: 12px;
		background: var(--sl-color-bg, #fff);
		border: 1.5px solid color-mix(in srgb, var(--sl-color-gray-4) 70%, transparent);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.14);
	}

	/* Headline — neutral page furniture. */
	.cls-headline {
		width: 70%;
		height: 16px;
		margin: 0;
		border-radius: 5px;
		background: color-mix(in srgb, var(--sl-color-gray-4) 75%, transparent);
	}

	/* The image's outer box. This is the ONLY structural difference between the
	   two variants — see the per-variant overrides below. */
	.cls-imgbox {
		margin: 0;
		min-width: 0;
		overflow: hidden;
	}

	.cls-img {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: center;
		height: 96px;
		margin: 0;
		border-radius: 8px;
		background: color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent);
		border: 1.5px dashed color-mix(in srgb, var(--sl-color-gray-3) 55%, transparent);
		color: color-mix(in srgb, var(--sl-color-gray-2) 80%, transparent);
	}

	/* Button row — the button plus its annotation marker. */
	.cls-buttonrow {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 0;
		min-width: 0;
		flex-wrap: wrap;
	}

	.cls-button {
		margin: 0;
		padding: 8px 16px;
		border-radius: 7px;
		font-size: 13px;
		font-weight: 700;
		color: #fff;
		background: var(--sl-color-accent, #4f46e5);
		white-space: nowrap;
	}

	.cls-marker {
		margin: 0;
		padding: 4px 10px;
		border-radius: 6px;
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.25;
		color: #fff;
		background: var(--accent);
		min-width: 0;
	}

	/* ----- UNRESERVED: the box has no height until the bytes "arrive" ----- */
	/* It animates 0 → 96px, pushing the button (and its red marker) down. */
	.cls--unreserved .cls-imgbox {
		height: 0;
		animation: cls-grow 3.4s ease-in-out infinite;
	}

	@keyframes cls-grow {
		0%,
		25% {
			height: 0;
		}
		45%,
		90% {
			height: 96px;
		}
		100% {
			height: 0;
		}
	}

	/* The image fades in as its box opens. */
	.cls--unreserved .cls-img {
		opacity: 0;
		animation: cls-fade 3.4s ease-in-out infinite;
	}

	/* ----- RESERVED: the box is pre-sized to the image's final height ----- */
	/* Layout never changes; only the image's own opacity animates inside it. */
	.cls--reserved .cls-imgbox {
		height: 96px;
	}

	.cls--reserved .cls-img {
		opacity: 0;
		animation: cls-fade 3.4s ease-in-out infinite;
	}

	@keyframes cls-fade {
		0%,
		25% {
			opacity: 0;
		}
		45%,
		90% {
			opacity: 1;
		}
		100% {
			opacity: 0;
		}
	}

	/* Respect reduced-motion: hold the loaded state, no looping jump. */
	@media (prefers-reduced-motion: reduce) {
		.cls--unreserved .cls-imgbox,
		.cls--reserved .cls-imgbox {
			height: 96px;
			animation: none;
		}

		.cls--unreserved .cls-img,
		.cls--reserved .cls-img {
			opacity: 1;
			animation: none;
		}
	}
</style>
