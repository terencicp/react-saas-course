---
// LcpOneElement — Chapter 094 Lesson 1 ("The Core Web Vitals").
//
// A small mocked browser viewport that kills one misconception: LCP is not a
// whole-page or "fully loaded" metric — it is the paint time of ONE element.
// Everything in the mock is drawn faint and unremarkable EXCEPT the hero image
// block, which is outlined in a saturated blue and tagged with a single callout
// reading "this element's paint time IS your LCP". The contrast does the
// teaching: every other line is just page furniture; the LCP is the one box the
// browser is being timed on.
//
// Pure HTML+CSS per the diagrams guide ("Annotated illustration" → HTML+CSS):
// a rounded rectangle with a chrome bar (traffic-light dots + a fake address
// pill) standing in for a browser, a flex/grid page layout inside, and an
// absolutely-positioned callout anchored to the hero. `not-content` + margin:0
// on every node defeats Starlight's injected prose margins. Goes inside
// <Figure>, supplied by the MDX (no caption — the prose frames it).
//
// Colour: page furniture leans on Starlight greys so it recedes; only the hero
// outline + callout use the LCP blue (#2563eb), so the eye lands there in both
// light and dark themes. This is a clarifier, not a centrepiece — height stays
// modest.

const LCP = '#2563eb'; // the one element being timed
---

<div class="lcp not-content" style={`--lcp:${LCP};`}>
	{/* The browser viewport */}
	<div class="lcp-browser">
		{/* Chrome bar: traffic lights + a fake address pill */}
		<div class="lcp-chrome">
			<span class="lcp-dot"></span>
			<span class="lcp-dot"></span>
			<span class="lcp-dot"></span>
			<span class="lcp-url"></span>
		</div>

		{/* The mocked page */}
		<div class="lcp-page">
			{/* Top: logo left, nav right */}
			<div class="lcp-topbar">
				<span class="lcp-logo"></span>
				<span class="lcp-nav">
					<span class="lcp-navline"></span>
					<span class="lcp-navline"></span>
					<span class="lcp-navline"></span>
				</span>
			</div>

			{/* The hero image — the LCP candidate. Outlined + labelled. */}
			<div class="lcp-hero">
				<span class="lcp-hero-glyph">
					<svg viewBox="0 0 24 24" width="34" height="34" aria-hidden="true">
						<rect
							x="2"
							y="3"
							width="20"
							height="18"
							rx="2"
							fill="none"
							stroke="currentColor"
							stroke-width="1.6"></rect>
						<circle cx="8" cy="9" r="2" fill="currentColor"></circle>
						<path
							d="M3 18l5-5 4 4 3-3 6 6"
							fill="none"
							stroke="currentColor"
							stroke-width="1.6"
							stroke-linejoin="round"
							stroke-linecap="round"></path>
					</svg>
				</span>
				{/* Callout anchored to the hero */}
				<div class="lcp-callout">
					<span class="lcp-callout-text">
						this element&rsquo;s paint time <strong>is</strong> your LCP
					</span>
				</div>
			</div>

			{/* Headline line under the hero */}
			<div class="lcp-headline"></div>

			{/* Faint paragraph lines */}
			<div class="lcp-para">
				<span class="lcp-pline"></span>
				<span class="lcp-pline"></span>
				<span class="lcp-pline lcp-pline--short"></span>
			</div>
		</div>
	</div>
</div>

<style>
	.lcp {
		margin: 0;
		display: flex;
		justify-content: center;
		padding: 6px 2px 4px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* The browser window. */
	.lcp-browser {
		box-sizing: border-box;
		width: 100%;
		max-width: 480px;
		margin: 0;
		border-radius: 12px;
		overflow: visible;
		background: var(--sl-color-bg, #fff);
		border: 1.5px solid color-mix(in srgb, var(--sl-color-gray-4) 70%, transparent);
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.16);
	}

	/* Chrome bar. */
	.lcp-chrome {
		display: flex;
		align-items: center;
		gap: 6px;
		margin: 0;
		padding: 9px 12px;
		border-bottom: 1.5px solid
			color-mix(in srgb, var(--sl-color-gray-5) 80%, transparent);
		border-radius: 12px 12px 0 0;
		background: color-mix(in srgb, var(--sl-color-gray-6) 70%, transparent);
	}

	.lcp-dot {
		width: 9px;
		height: 9px;
		margin: 0;
		border-radius: 50%;
		background: color-mix(in srgb, var(--sl-color-gray-3) 55%, transparent);
	}

	.lcp-url {
		flex: 1;
		height: 12px;
		margin: 0 0 0 10px;
		border-radius: 6px;
		background: color-mix(in srgb, var(--sl-color-gray-5) 90%, transparent);
	}

	/* The page canvas. */
	.lcp-page {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
		padding: 16px 18px 20px;
	}

	.lcp-topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin: 0;
		min-width: 0;
	}

	.lcp-logo {
		width: 44px;
		height: 14px;
		margin: 0;
		border-radius: 4px;
		background: color-mix(in srgb, var(--sl-color-gray-4) 75%, transparent);
	}

	.lcp-nav {
		display: flex;
		gap: 8px;
		margin: 0;
	}

	.lcp-navline {
		width: 26px;
		height: 8px;
		margin: 0;
		border-radius: 4px;
		background: color-mix(in srgb, var(--sl-color-gray-5) 90%, transparent);
	}

	/* The hero image block — the LCP candidate. The one element that pops. */
	.lcp-hero {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		height: 116px;
		margin: 0;
		border-radius: 8px;
		background: color-mix(in srgb, var(--lcp) 9%, transparent);
		border: 2.5px solid var(--lcp);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--lcp) 16%, transparent);
		color: color-mix(in srgb, var(--lcp) 70%, var(--sl-color-gray-2));
	}

	.lcp-hero-glyph {
		display: flex;
		margin: 0;
		opacity: 0.85;
	}

	/* The callout, anchored to the top-right of the hero. */
	.lcp-callout {
		position: absolute;
		top: -14px;
		right: 10px;
		margin: 0;
		padding: 5px 10px;
		border-radius: 7px;
		background: var(--lcp);
		box-shadow: 0 3px 8px color-mix(in srgb, var(--lcp) 45%, transparent);
	}

	/* Little pointer notch under the callout, aimed at the hero. */
	.lcp-callout::after {
		content: '';
		position: absolute;
		left: 22px;
		bottom: -5px;
		width: 10px;
		height: 10px;
		margin: 0;
		background: var(--lcp);
		transform: rotate(45deg);
		border-radius: 1px;
	}

	.lcp-callout-text {
		display: block;
		margin: 0;
		font-size: 12px;
		font-weight: 600;
		line-height: 1.2;
		color: #fff;
		white-space: nowrap;
	}

	.lcp-callout-text strong {
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	/* Headline line under the hero — page furniture, recedes. */
	.lcp-headline {
		width: 62%;
		height: 16px;
		margin: 2px 0 0;
		border-radius: 5px;
		background: color-mix(in srgb, var(--sl-color-gray-4) 70%, transparent);
	}

	.lcp-para {
		display: flex;
		flex-direction: column;
		gap: 7px;
		margin: 0;
	}

	.lcp-pline {
		height: 8px;
		margin: 0;
		border-radius: 4px;
		background: color-mix(in srgb, var(--sl-color-gray-5) 85%, transparent);
	}

	.lcp-pline--short {
		width: 70%;
	}

	/* On very narrow cards, let the callout wrap rather than overflow. */
	@media (max-width: 420px) {
		.lcp-callout-text {
			white-space: normal;
			max-width: 150px;
		}
	}
</style>
