---
// LoadTimeline — Chapter 094 Lesson 1 ("The Core Web Vitals").
//
// A single left-to-right page-load timeline that puts TTFB, FCP, and LCP on the
// SAME axis, so the lesson's claim — "a slow TTFB drags LCP along behind it" —
// is visually obvious: every marker downstream of a slow gap is shoved right.
//
// Four markers along one axis, in order:
//   request (t=0) → TTFB (first byte) → FCP (first paint) → LCP (main element).
// Only LCP is drawn as a Vital (filled, saturated); request/TTFB/FCP are plain
// upstream tells. Under each of the three gaps sits the chapter lesson that owns
// that stretch of time:
//   request → TTFB : server time (waterfalls; DB queries)
//   TTFB → FCP     : render start (render-blocking resources)
//   FCP → LCP      : the LCP element itself (image priority)
//
// Pure HTML+CSS per the diagrams guide ("sequential phase strip" → HTML+CSS).
// The axis is one relatively-positioned track; markers and gap cards are pinned
// by percentage so they always agree (no two-grid alignment to drift). The
// percentages come from each gap's relative weight, computed below — so widths
// read as elapsed time. `not-content` + margin:0 on every node defeats
// Starlight's injected prose margins.
//
// Colour: the three upstream segments use a muted grey ramp so they read as
// "lead-up"; LCP alone takes the blue (#2563eb) shared with the LCP illustration
// in this lesson, so the eye lands on the metric that actually gets scored.

const LCP = '#2563eb'; // the Vital the upstream tells lead to

interface Gap {
	span: string; // which two markers it connects
	owns: string; // what this stretch of time is
	lesson: string; // the chapter lesson that fixes it
	weight: number; // relative width on the axis
}

const gaps: Gap[] = [
	{
		span: 'request → TTFB',
		owns: 'server time',
		lesson: 'covered later — waterfalls; DB queries',
		weight: 5,
	},
	{
		span: 'TTFB → FCP',
		owns: 'render start',
		lesson: 'render-blocking resources',
		weight: 3,
	},
	{
		span: 'FCP → LCP',
		owns: 'the LCP element itself',
		lesson: 'image priority — next lesson',
		weight: 4,
	},
];

interface Marker {
	label: string;
	sub: string;
	pos: number; // left position, percent of the track
	vital?: boolean;
}

const total = gaps.reduce((sum, g) => sum + g.weight, 0);

// Cumulative boundary positions (0% … 100%) give the four marker offsets.
const bounds: number[] = [0];
for (const g of gaps) bounds.push(bounds[bounds.length - 1] + g.weight);
const pct = (w: number) => (w / total) * 100;

const markers: Marker[] = [
	{ label: 'request', sub: 't = 0', pos: pct(bounds[0]) },
	{ label: 'TTFB', sub: 'first byte', pos: pct(bounds[1]) },
	{ label: 'FCP', sub: 'first paint', pos: pct(bounds[2]) },
	{ label: 'LCP', sub: 'main element', pos: pct(bounds[3]), vital: true },
];

// Each gap card spans from one boundary to the next, with a small inset so the
// cards don't visually touch.
const gapBoxes = gaps.map((g, i) => ({
	...g,
	left: pct(bounds[i]),
	width: pct(g.weight),
}));
---

<div class="lt not-content" style={`--lcp:${LCP};`}>
	<div class="lt-inner">
		{/* Marker labels, pinned above each axis boundary. */}
		<div class="lt-labels">
			{
				markers.map((m, i) => (
					<div
						class:list={[
							'lt-label',
							{
								'lt-label--vital': m.vital,
								'lt-label--first': i === 0,
								'lt-label--last': i === markers.length - 1,
							},
						]}
						style={`left: ${m.pos}%;`}
					>
						<span class="lt-name">{m.label}</span>
						<span class="lt-sub">{m.sub}</span>
					</div>
				))
			}
		</div>

		{/* The axis: a baseline rule with proportional segments + pinned dots. */}
		<div class="lt-axis">
			{/* The full-width rule under the segments. */}
			<div class="lt-rule"></div>

			{/* Coloured segments fill each gap so width reads as elapsed time. */}
			{
				gapBoxes.map((g, i) => (
					<div
						class:list={['lt-seg', { 'lt-seg--final': i === gaps.length - 1 }]}
						style={`left: ${g.left}%; width: ${g.width}%; --tint: ${i};`}
					/>
				))
			}

			{/* Markers — dots pinned to the boundary positions. */}
			{
				markers.map((m, i) => (
					<span
						class:list={[
							'lt-dot',
							{
								'lt-dot--vital': m.vital,
								'lt-dot--first': i === 0,
								'lt-dot--last': i === markers.length - 1,
							},
						]}
						style={`left: ${m.pos}%;`}
					/>
				))
			}
		</div>

		{/* Gap cards: each sits under its segment, naming the owning lesson. */}
		<div class="lt-gaps">
			{
				gapBoxes.map((g) => (
					<div
						class="lt-gap"
						style={`left: ${g.left}%; --w: ${g.width}%;`}
					>
						<span class="lt-gap-span">{g.span}</span>
						<span class="lt-gap-owns">{g.owns}</span>
						<span class="lt-gap-lesson">{g.lesson}</span>
					</div>
				))
			}
		</div>
	</div>
</div>

<style>
	.lt {
		margin: 0;
		display: flex;
		justify-content: center;
		padding: 8px 2px 4px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	.lt-inner {
		box-sizing: border-box;
		width: 100%;
		max-width: 720px;
		margin: 0;
		display: flex;
		flex-direction: column;
	}

	/* ---- Marker labels (above the axis) ---- */
	.lt-labels {
		position: relative;
		height: 34px;
		margin: 0 0 6px;
	}

	.lt-label {
		position: absolute;
		bottom: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1px;
		margin: 0;
		/* Centre each label on its boundary position. */
		transform: translateX(-50%);
		text-align: center;
		white-space: nowrap;
	}

	/* Edge labels can't half-overhang the track, so anchor them to the edges. */
	.lt-label--first {
		align-items: flex-start;
		transform: none;
		text-align: left;
	}

	.lt-label--last {
		align-items: flex-end;
		transform: translateX(-100%);
		text-align: right;
	}

	.lt-name {
		margin: 0;
		font-size: 0.85rem;
		font-weight: 700;
		line-height: 1.1;
		color: var(--sl-color-gray-2);
	}

	.lt-label--vital .lt-name {
		font-size: 0.98rem;
		font-weight: 800;
		color: var(--lcp);
	}

	.lt-sub {
		margin: 0;
		font-size: 0.7rem;
		font-weight: 500;
		line-height: 1.1;
		color: var(--sl-color-gray-3);
	}

	/* ---- The axis ---- */
	.lt-axis {
		position: relative;
		height: 18px;
		margin: 0;
	}

	.lt-rule {
		position: absolute;
		left: 0;
		right: 0;
		top: 50%;
		height: 4px;
		margin: 0;
		transform: translateY(-50%);
		border-radius: 4px;
		background: color-mix(in srgb, var(--sl-color-gray-4) 60%, transparent);
	}

	/* Each segment overlays the rule on its span with a graded fill, so a wider
	   gap reads as more elapsed time. */
	.lt-seg {
		position: absolute;
		top: 50%;
		height: 4px;
		margin: 0;
		transform: translateY(-50%);
		border-radius: 4px;
		background: color-mix(in srgb, var(--sl-color-gray-3) 55%, transparent);
	}

	/* Final segment ramps into the LCP blue, pointing the eye at the endpoint. */
	.lt-seg--final {
		background: linear-gradient(
			to right,
			color-mix(in srgb, var(--sl-color-gray-3) 65%, transparent),
			color-mix(in srgb, var(--lcp) 75%, transparent)
		);
	}

	/* Markers: dots centred on their boundary position. */
	.lt-dot {
		position: absolute;
		top: 50%;
		width: 13px;
		height: 13px;
		margin: 0;
		transform: translate(-50%, -50%);
		border-radius: 50%;
		background: var(--sl-color-bg, #fff);
		border: 3px solid
			color-mix(in srgb, var(--sl-color-gray-2) 70%, transparent);
		z-index: 1;
	}

	/* Keep the two edge dots fully inside the track rather than half-overhanging. */
	.lt-dot--first {
		transform: translate(0, -50%);
	}

	.lt-dot--last {
		transform: translate(-100%, -50%);
	}

	/* The LCP dot is the endpoint everything else leads to — make it pop. */
	.lt-dot--vital {
		width: 17px;
		height: 17px;
		border-color: var(--lcp);
		background: var(--lcp);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--lcp) 20%, transparent);
	}

	/* ---- Gap cards (below the axis) ---- */
	.lt-gaps {
		position: relative;
		height: 84px;
		margin: 12px 0 0;
	}

	.lt-gap {
		box-sizing: border-box;
		position: absolute;
		top: 0;
		bottom: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 3px;
		/* Inset so neighbouring cards read as separate. */
		margin: 0 5px;
		padding: 8px 10px;
		border-radius: 9px;
		text-align: center;
		background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent);
		/* width is set inline; subtract the inset margins from it. */
		width: calc(var(--w, 33%) - 10px);
	}

	.lt-gap-span {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-2);
	}

	.lt-gap-owns {
		margin: 0;
		font-size: 0.84rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}

	.lt-gap-lesson {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 500;
		line-height: 1.25;
		color: var(--sl-color-gray-3);
	}

	/* Narrow cards: percentage-pinned cards get too cramped, so stack them into a
	   normal flow column and let the axis ride above as a simple legend strip. */
	@media (max-width: 560px) {
		.lt-gaps {
			height: auto;
			display: flex;
			flex-direction: column;
			gap: 8px;
		}

		.lt-gap {
			position: static;
			width: auto !important;
			margin: 0;
		}
	}
</style>
