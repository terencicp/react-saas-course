---
// ChapterMap — Chapter 094 Lesson 1 ("The Core Web Vitals").
//
// The lesson's one-glance summary card and the artifact the student scrolls
// back to: every row ties a metric → its primary cause → the structural fix →
// the lesson in this chapter that owns that fix. This is the "trigger before
// tool" map for the whole chapter — read it once here, return to it whenever a
// later lesson needs placing.
//
// Four columns: Vital | Primary cause | Structural fix | Where in this chapter.
// Laid out as a CSS grid (not an HTML <table>) so the four columns align
// cleanly and Starlight's prose styling can't reach the cells. Rows are grouped
// by Vital and tinted with a saturated left accent — green for LCP, amber for
// INP, red for CLS — matching the threshold-chart colours earlier in the
// lesson, so the eye can find a Vital's rows at a glance. LCP carries three rows
// (it sits where network, fonts, and server timing meet) and a final spanning
// row names the Lighthouse lab gate that guards all three before deploy.
//
// Pure HTML+CSS per the diagrams guide. `not-content` + margin:0 on every node
// defeats Starlight's injected prose margins. Rows kept compact so total height
// stays well under 800px.

const LCP = '#16a34a'; // green — matches the threshold chart's "good" band
const INP = '#d97706'; // amber
const CLS = '#dc2626'; // red
const ALL = '#0d9488'; // teal — the lab gate that guards all three

interface Row {
	vital: string;
	cause: string;
	fix: string;
	where: string;
	accent: string;
	// First row of a Vital group draws the coloured Vital label; later rows in
	// the same group leave it blank but keep the accent rail.
	groupStart: boolean;
}

const rows: Row[] = [
	{
		vital: 'LCP',
		cause: 'Hero image discovered late, a blocking font, or a slow server',
		fix: 'Mark the LCP image as priority',
		where: 'Next lesson — priority on the LCP element',
		accent: LCP,
		groupStart: true,
	},
	{
		vital: 'LCP',
		cause: 'Sequential awaits in a Server Component',
		fix: 'Parallelize the independent fetches',
		where: 'The RSC-waterfalls lesson',
		accent: LCP,
		groupStart: false,
	},
	{
		vital: 'LCP',
		cause: 'A missing index or an N+1 at the database',
		fix: 'Composite indexes, batch the queries',
		where: 'The indexes-and-N+1 lesson',
		accent: LCP,
		groupStart: false,
	},
	{
		vital: 'INP',
		cause: 'Too much main-thread JavaScript',
		fix: 'Ship less client JS — let the server do the work',
		where: 'The bundle lessons — barrel-export trap, then the treemap',
		accent: INP,
		groupStart: true,
	},
	{
		vital: 'CLS',
		cause: 'Unsized media and late-injected content',
		fix: 'Reserve space for everything dynamic',
		where: 'No dedicated lesson — set the defaults from this one',
		accent: CLS,
		groupStart: true,
	},
];
---

<div class="cmap not-content">
	<div class="cmap-grid" role="table" aria-label="Vital, cause, fix, and lesson">
		{/* Header row */}
		<div class="cmap-head" role="columnheader">Vital</div>
		<div class="cmap-head" role="columnheader">Primary cause</div>
		<div class="cmap-head" role="columnheader">Structural fix</div>
		<div class="cmap-head" role="columnheader">Where in this chapter</div>

		{
			rows.map((row) => (
				<>
					<div
						class="cmap-vital"
						role="cell"
						style={`--accent:${row.accent};`}
					>
						{row.groupStart ? <span class="cmap-pill">{row.vital}</span> : null}
					</div>
					<div class="cmap-cell" role="cell" style={`--accent:${row.accent};`}>
						{row.cause}
					</div>
					<div class="cmap-cell" role="cell" style={`--accent:${row.accent};`}>
						{row.fix}
					</div>
					<div class="cmap-cell cmap-where" role="cell" style={`--accent:${row.accent};`}>
						{row.where}
					</div>
				</>
			))
		}

		{/* Spanning footer: the lab gate guards all three before deploy. */}
		<div class="cmap-allgate" role="cell" style={`--accent:${ALL};`}>
			<span class="cmap-allpill">All three</span>
			<span class="cmap-alltext">
				A regression slips through before deploy — add a lab gate that runs
				before shipping. <strong>The Lighthouse lesson</strong> guards LCP, INP,
				and CLS in one pass.
			</span>
		</div>
	</div>
</div>

<style>
	.cmap {
		margin: 0;
		display: flex;
		justify-content: center;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	.cmap-grid {
		box-sizing: border-box;
		width: 100%;
		margin: 0;
		display: grid;
		grid-template-columns: 84px 1.5fr 1.4fr 1.6fr;
		column-gap: 8px;
		row-gap: 6px;
		align-items: stretch;
	}

	.cmap-head {
		box-sizing: border-box;
		margin: 0;
		padding: 8px 12px;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-3);
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	/* Vital column: a left accent rail + the coloured pill on the group's first
	   row; later rows in the group keep the rail so the group reads as one block. */
	.cmap-vital {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		margin: 0;
		padding: 10px 4px 10px 12px;
		border-left: 4px solid var(--accent);
		border-radius: 6px 0 0 6px;
		background: color-mix(in srgb, var(--accent) 9%, transparent);
	}

	.cmap-pill {
		box-sizing: border-box;
		margin: 0;
		padding: 3px 10px;
		border-radius: 999px;
		font-size: 0.86rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		color: #fff;
		background: var(--accent);
	}

	.cmap-cell {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		margin: 0;
		padding: 10px 12px;
		font-size: 0.85rem;
		font-weight: 500;
		line-height: 1.35;
		color: var(--sl-color-white);
		border-radius: 6px;
		background: color-mix(in srgb, var(--accent) 9%, transparent);
	}

	.cmap-where {
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}

	/* Footer spanning all four columns: the lab gate that guards every Vital. */
	.cmap-allgate {
		box-sizing: border-box;
		grid-column: 1 / -1;
		display: flex;
		align-items: center;
		gap: 12px;
		margin: 4px 0 0;
		padding: 12px 14px;
		border-radius: 8px;
		border: 1px dashed color-mix(in srgb, var(--accent) 55%, transparent);
		background: color-mix(in srgb, var(--accent) 11%, transparent);
		font-size: 0.85rem;
		line-height: 1.4;
		color: var(--sl-color-white);
	}

	.cmap-allpill {
		flex: 0 0 auto;
		margin: 0;
		padding: 4px 12px;
		border-radius: 999px;
		font-size: 0.84rem;
		font-weight: 800;
		color: #fff;
		background: var(--accent);
	}

	.cmap-alltext {
		margin: 0;
	}

	.cmap-alltext strong {
		color: var(--sl-color-white);
		font-weight: 700;
	}

	/* Narrow viewports: collapse the rigid grid into stacked card rows so each
	   cell stays readable. Each Vital group becomes one card; the header row and
	   the accent-rail Vital column fold away. */
	@media (max-width: 640px) {
		.cmap-grid {
			grid-template-columns: 1fr;
			row-gap: 10px;
		}

		.cmap-head {
			display: none;
		}

		.cmap-vital {
			border-radius: 6px 6px 0 0;
			border-left-width: 5px;
			padding: 8px 12px;
		}

		.cmap-vital:empty {
			display: none;
		}

		.cmap-cell {
			border-radius: 0;
		}
	}
</style>
