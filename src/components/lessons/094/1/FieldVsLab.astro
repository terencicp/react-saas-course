---
// FieldVsLab — Chapter 094 Lesson 1 ("The Core Web Vitals").
//
// A durable side-by-side the student can recall whenever a later lesson says
// "field" or "lab". Two columns visible at once (deliberately not tabs — the
// whole point is the contrast, so both sides stay on screen):
//
//   • Field — Speed Insights: the VERDICT. Real users, real devices; continuous
//     but lags ~28 days; this is what Google Search actually scores.
//   • Lab — Lighthouse: the REGRESSION CATCHER. One synthetic run; instant and
//     pre-deploy; reproducible, not the verdict.
//
// Three contrast rows — Source / Timing / Job — laid out on a CSS grid so the
// rows line up exactly across the two columns (a shared left rail names each
// row). The eye can scan a row across to compare, or a column down to read one
// surface. Each column carries one role badge ("the verdict" / "the regression
// catcher") so the takeaway survives even a glance.
//
// Pure HTML+CSS per the diagrams guide ("two-column comparison card"). The grid
// guarantees row alignment without fixed pixel widths. `not-content` + margin:0
// on every node defeats Starlight's injected prose margins. Colour carries the
// signal — indigo for Field (the authoritative verdict), teal for Lab (the
// pre-deploy tool) — both read in light and dark themes.

const FIELD = '#4f46e5'; // indigo — the verdict
const LAB = '#0d9488'; // teal — the regression catcher

interface Row {
	label: string;
	field: string;
	lab: string;
}

const rows: Row[] = [
	{
		label: 'Source',
		field: 'Real users, real devices, real networks',
		lab: 'One synthetic run — simulated slow network + mid-tier mobile CPU',
	},
	{
		label: 'Timing',
		field: 'Continuous, lags ~28 days',
		lab: 'Instant, on demand, pre-deploy',
	},
	{
		label: 'Job',
		field: 'The verdict — what Google Search scores',
		lab: 'The regression catcher — before you ship',
	},
];
---

<div class="fvl not-content" style={`--field:${FIELD}; --lab:${LAB};`}>
	<div class="fvl-grid">
		{/* Header row: empty rail cell, then a titled card head per column. */}
		<div class="fvl-railhead"></div>

		<div class="fvl-head fvl-head--field">
			<span class="fvl-name">Field</span>
			<span class="fvl-tool">Speed Insights</span>
			<span class="fvl-role">the verdict</span>
		</div>

		<div class="fvl-head fvl-head--lab">
			<span class="fvl-name">Lab</span>
			<span class="fvl-tool">Lighthouse</span>
			<span class="fvl-role">the regression catcher</span>
		</div>

		{/* Three aligned contrast rows. */}
		{
			rows.map((row) => (
				<>
					<div class="fvl-rail">{row.label}</div>
					<div class="fvl-cell fvl-cell--field">{row.field}</div>
					<div class="fvl-cell fvl-cell--lab">{row.lab}</div>
				</>
			))
		}
	</div>
</div>

<style>
	.fvl {
		margin: 0;
		display: flex;
		justify-content: center;
		padding: 4px 2px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* Rail + two equal columns; rows align because every cell shares the grid. */
	.fvl-grid {
		box-sizing: border-box;
		width: 100%;
		max-width: 760px;
		margin: 0;
		display: grid;
		grid-template-columns: minmax(72px, auto) 1fr 1fr;
		column-gap: 12px;
		row-gap: 10px;
		align-items: stretch;
	}

	/* The empty top-left cell above the row-label rail. */
	.fvl-railhead {
		margin: 0;
	}

	/* Column heads — coloured banners that name the surface, its tool, and role. */
	.fvl-head {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		margin: 0;
		padding: 12px 14px;
		border-radius: 10px 10px 0 0;
		color: #fff;
	}

	.fvl-head--field {
		background: var(--field);
	}

	.fvl-head--lab {
		background: var(--lab);
	}

	.fvl-name {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.1;
	}

	.fvl-tool {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 600;
		opacity: 0.92;
	}

	.fvl-role {
		margin: 4px 0 0;
		align-self: flex-start;
		padding: 2px 9px;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		background: rgba(255, 255, 255, 0.22);
		color: #fff;
	}

	/* Left rail: the row label shared across both columns. */
	.fvl-rail {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		margin: 0;
		padding: 0 2px;
		text-align: right;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		color: var(--sl-color-gray-3);
	}

	/* Body cells — one per surface per row. Tinted by the column's colour so the
	   eye keeps tracking which side it's reading even mid-row. */
	.fvl-cell {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		margin: 0;
		padding: 11px 14px;
		border-radius: 8px;
		font-size: 0.88rem;
		font-weight: 500;
		line-height: 1.35;
		color: var(--sl-color-white);
		border: 1px solid transparent;
	}

	.fvl-cell--field {
		background: color-mix(in srgb, var(--field) 12%, transparent);
		border-color: color-mix(in srgb, var(--field) 32%, transparent);
	}

	.fvl-cell--lab {
		background: color-mix(in srgb, var(--lab) 12%, transparent);
		border-color: color-mix(in srgb, var(--lab) 34%, transparent);
	}

	/* Narrow cards: drop the rail, stack the two surfaces, and inline each row's
	   label so the contrast still reads when columns can't sit side by side. */
	@media (max-width: 560px) {
		.fvl-grid {
			grid-template-columns: 1fr;
		}

		.fvl-railhead,
		.fvl-rail {
			display: none;
		}

		.fvl-head {
			border-radius: 10px 10px 0 0;
		}

		.fvl-head--lab {
			margin-top: 8px;
		}
	}
</style>
