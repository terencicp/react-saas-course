---
// Cadence comparison card — one posture per call (Chapter 094 L5).
//
// The lesson's closing synthesis: the same tool (Lighthouse) used in two
// cadences. This component renders ONE posture's comparison card, selected by
// the `posture` prop, so each drops into its own TabbedItem tab:
//   "oneoff"    — the pre-launch deep pass (PageSpeed Insights, run once)
//   "recurring" — the CI regression gate (@lhci/cli, run forever)
//
// Each card lays out the five fields the outline calls for — Trigger, Tool,
// Surfaces, Can, Can't — as a labeled stack, with the Can / Can't pair shown
// side by side so the posture's reach and its limit read as one contrast.
//
// Palette ties back to the sibling figures: the one-off pass takes AMBER (the
// exploratory "find every opportunity once" energy of the Opportunities pane),
// the recurring gate takes TEAL/GREEN (the same "this is the gate" green used on
// the assertion block in the lighthouserc walkthrough). The Can/Can't glyphs use
// a steady green check and a muted red cross. `margin: 0` on descendants defeats
// Starlight's injected prose margins. No JS.

interface Props {
	posture: "oneoff" | "recurring";
}

const { posture } = Astro.props;

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, monospace)";

const AMBER = "#d97706"; // one-off deep pass — exploratory, run once
const TEAL = "#0d9488"; // recurring gate — the structural floor (the "gate" green)
const CHECK = "#0d9488"; // "can" — green
const CROSS = "#dc2626"; // "can't" — muted red

type Field = { label: string; body: string; code?: boolean };

type Card = {
	accent: string;
	icon: string; // emoji glyph kept tiny + neutral
	kicker: string;
	title: string;
	tagline: string;
	trigger: string;
	tool: Field;
	surfaces: string;
	can: string;
	cant: string;
};

const cards: Record<Props["posture"], Card> = {
	oneoff: {
		accent: AMBER,
		icon: "1",
		kicker: "One-off",
		title: "Pre-launch deep pass",
		tagline: "Find every problem once, before ship.",
		trigger: "The weeks before ship.",
		tool: {
			label: "Tool",
			body: "PageSpeed Insights — plus DevTools for spot checks.",
		},
		surfaces:
			"Marketing + dashboard, plus 2–3 critical screens (signup, primary task, settings).",
		can: "Find every problem on the pages that matter and drive them to the cheat-sheet targets.",
		cant: "See field data — there's no traffic yet, so lab is all you have. And it's a snapshot, not a guard.",
	},
	recurring: {
		accent: TEAL,
		icon: "∞",
		kicker: "Recurring",
		title: "The CI gate",
		tagline: "Keep the problems from coming back.",
		trigger: "Every pull request that touches UI or dependencies.",
		tool: {
			label: "Tool",
			body: "@lhci/cli via lighthouserc.json.",
			code: true,
		},
		surfaces: "The two regimes — marketing + one authenticated screen.",
		can: "Stop a regression from merging by failing the build on a busted budget.",
		cant: "Make the app fast — it only holds the floor. And it doesn't replace the field-data verdict from Speed Insights.",
	},
};

const c = cards[posture];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 14px",
	"width: 100%",
	"box-sizing: border-box",
	sans,
].join("; ");

const header = [
	reset,
	"display: flex",
	"align-items: center",
	"gap: 12px",
	"padding: 10px 14px",
	"border-radius: 10px",
	"border-left: 4px solid " + c.accent,
	"background: color-mix(in srgb, " + c.accent + " 10%, var(--sl-color-bg))",
].join("; ");

const badge = [
	reset,
	"flex: 0 0 auto",
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"width: 34px",
	"height: 34px",
	"border-radius: 50%",
	"font-size: 18px",
	"font-weight: 800",
	"line-height: 1",
	"color: #fff",
	"background: " + c.accent,
].join("; ");

const headText = [reset, "display: flex", "flex-direction: column", "gap: 1px", "min-width: 0"].join(
	"; ",
);

const kicker = [
	reset,
	"font-size: 10px",
	"font-weight: 700",
	"letter-spacing: 0.08em",
	"text-transform: uppercase",
	"color: color-mix(in srgb, " + c.accent + " 70%, var(--sl-color-text))",
].join("; ");

const titleText = [
	reset,
	"font-size: 16px",
	"font-weight: 800",
	"line-height: 1.15",
	"color: var(--sl-color-text)",
].join("; ");

const tagline = [
	reset,
	"font-size: 12px",
	"font-weight: 500",
	"line-height: 1.2",
	"color: var(--sl-color-gray-3, #9aa2b1)",
].join("; ");

// Field rows -------------------------------------------------------------

const fieldRow = [
	reset,
	"display: grid",
	"grid-template-columns: 96px 1fr",
	"gap: 12px",
	"align-items: baseline",
	"padding: 0 4px",
].join("; ");

const fieldLabel = [
	reset,
	"font-size: 11px",
	"font-weight: 700",
	"letter-spacing: 0.05em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3, #9aa2b1)",
].join("; ");

const fieldBody = [
	reset,
	"font-size: 13.5px",
	"line-height: 1.4",
	"color: var(--sl-color-text)",
].join("; ");

const codeSpan = [
	reset,
	mono,
	"font-size: 12.5px",
	"font-weight: 600",
	"padding: 1px 5px",
	"border-radius: 5px",
	"background: var(--sl-color-gray-6, rgba(255,255,255,0.05))",
].join("; ");

// Can / Can't pair -------------------------------------------------------

const verdicts = [reset, "display: grid", "grid-template-columns: 1fr 1fr", "gap: 10px"].join("; ");

const verdictCell = (color: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"gap: 6px",
		"padding: 11px 12px",
		"border-radius: 9px",
		"background: color-mix(in srgb, " + color + " 7%, var(--sl-color-bg))",
		"border: 1px solid color-mix(in srgb, " + color + " 28%, transparent)",
	].join("; ");

const verdictHead = (color: string) =>
	[
		reset,
		"display: flex",
		"align-items: center",
		"gap: 6px",
		"font-size: 11px",
		"font-weight: 700",
		"letter-spacing: 0.05em",
		"text-transform: uppercase",
		"color: " + color,
	].join("; ");

const glyph = (color: string) =>
	[
		reset,
		"flex: 0 0 auto",
		"display: flex",
		"align-items: center",
		"justify-content: center",
		"width: 16px",
		"height: 16px",
		"border-radius: 50%",
		"font-size: 11px",
		"font-weight: 900",
		"line-height: 1",
		"color: #fff",
		"background: " + color,
	].join("; ");

const verdictBody = [
	reset,
	"font-size: 12.5px",
	"line-height: 1.4",
	"color: var(--sl-color-text)",
].join("; ");
---

<div class="not-content" style={root}>
	<div style={header}>
		<span style={badge}>{c.icon}</span>
		<span style={headText}>
			<span style={kicker}>{c.kicker}</span>
			<span style={titleText}>{c.title}</span>
			<span style={tagline}>{c.tagline}</span>
		</span>
	</div>

	<div style={fieldRow}>
		<span style={fieldLabel}>Trigger</span>
		<span style={fieldBody}>{c.trigger}</span>
	</div>

	<div style={fieldRow}>
		<span style={fieldLabel}>Tool</span>
		<span style={fieldBody}>
			{
				c.tool.code ? (
					<>
						<span style={codeSpan}>@lhci/cli</span> via{" "}
						<span style={codeSpan}>lighthouserc.json</span>.
					</>
				) : (
					c.tool.body
				)
			}
		</span>
	</div>

	<div style={fieldRow}>
		<span style={fieldLabel}>Surfaces</span>
		<span style={fieldBody}>{c.surfaces}</span>
	</div>

	<div style={verdicts}>
		<div style={verdictCell(CHECK)}>
			<span style={verdictHead(CHECK)}>
				<span style={glyph(CHECK)}>✓</span>Can
			</span>
			<span style={verdictBody}>{c.can}</span>
		</div>
		<div style={verdictCell(CROSS)}>
			<span style={verdictHead(CROSS)}>
				<span style={glyph(CROSS)}>✕</span>Can't
			</span>
			<span style={verdictBody}>{c.cant}</span>
		</div>
	</div>
</div>
