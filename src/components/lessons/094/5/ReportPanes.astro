---
// Lighthouse report panes — recognition mock (Chapter 094 L5).
//
// No real Lighthouse run is available, so this is a faithful hand-authored mock
// of the four panes a student scans top-to-bottom in a real report: Score,
// Metrics, Opportunities, Diagnostics. The component renders ONE pane per call,
// selected by the `pane` prop, so the lesson can drop each into its own
// TabbedItem tab. The goal is pure recognition — "this is what that pane looks
// like" — so the reading order and cross-tool routing live in the prose, not here.
//
// Lighthouse's own color language is reused so the mock reads as authentic:
//   green  = good        (score 90-100 / metric in band)
//   orange = needs work  (score 50-89  / metric over band)
//   red    = poor        (score 0-49   / metric well over band)
// The sample report scores 78 (orange dial) with LCP the one red metric — the
// canonical "image too heavy" story this chapter teaches.
//
// Palette echoes the sibling figures (MetricWeights, ThresholdCheatSheet) so all
// three read as one family. `margin: 0` on every descendant defeats Starlight's
// injected prose margins. No JS — the dial arc is a static conic-gradient.

interface Props {
	pane: "score" | "metrics" | "opportunities" | "diagnostics";
}

const { pane } = Astro.props;

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, monospace)";

// Lighthouse status colors (saturated mid-tones — readable on both themes).
const GREEN = "#0d9488"; // teal-600 — "good"
const ORANGE = "#d97706"; // amber-600 — "needs improvement"
const RED = "#dc2626"; // red-600  — "poor"

// ---- shared shells ------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 12px",
	"width: 100%",
	"box-sizing: border-box",
	sans,
].join("; ");

const paneTitle = [
	reset,
	"font-size: 11px",
	"font-weight: 700",
	"letter-spacing: 0.05em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3, #9aa2b1)",
].join("; ");

// ---- 1 · Score ----------------------------------------------------------

const SCORE = 78; // orange band — the sample report
const scoreColor = ORANGE;

const scoreWrap = [
	reset,
	"display: flex",
	"flex-direction: column",
	"align-items: center",
	"gap: 12px",
	"padding: 8px 0",
].join("; ");

// The dial: a conic-gradient ring filled to SCORE%, with a punched-out center
// that carries the page background so the arc reads as a ring.
const dial = [
	reset,
	"position: relative",
	"width: 132px",
	"height: 132px",
	"border-radius: 50%",
	`background: conic-gradient(${scoreColor} ${SCORE * 3.6}deg, color-mix(in srgb, ${scoreColor} 22%, var(--sl-color-bg)) ${SCORE * 3.6}deg)`,
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"box-sizing: border-box",
].join("; ");

const dialHole = [
	reset,
	"position: absolute",
	"inset: 12px",
	"border-radius: 50%",
	"background: var(--sl-color-bg-sidebar, var(--sl-color-bg))",
	"display: flex",
	"align-items: center",
	"justify-content: center",
].join("; ");

const dialNumber = [
	reset,
	"font-size: 44px",
	"font-weight: 800",
	"line-height: 1",
	"color: " + scoreColor,
].join("; ");

const dialLabel = [
	reset,
	"font-size: 14px",
	"font-weight: 700",
	"letter-spacing: 0.02em",
	"color: var(--sl-color-text)",
].join("; ");

// Legend — the three bands so the dial's color is legible.
const legendRow = [reset, "display: flex", "gap: 14px", "flex-wrap: wrap", "justify-content: center"].join(
	"; ",
);

const legendItem = [
	reset,
	"display: flex",
	"align-items: center",
	"gap: 5px",
	"font-size: 11px",
	"color: var(--sl-color-gray-2, #c2c7d0)",
].join("; ");

const dot = (color: string) =>
	[reset, "width: 9px", "height: 9px", "border-radius: 50%", "background: " + color].join("; ");

// ---- 2 · Metrics --------------------------------------------------------

type Metric = { name: string; value: string; status: "good" | "warn" | "poor" };
const metrics: Metric[] = [
	{ name: "First Contentful Paint", value: "1.4 s", status: "good" },
	{ name: "Speed Index", value: "2.1 s", status: "good" },
	{ name: "Largest Contentful Paint", value: "4.1 s", status: "poor" },
	{ name: "Total Blocking Time", value: "210 ms", status: "warn" },
	{ name: "Cumulative Layout Shift", value: "0.04", status: "good" },
];

const statusColor: Record<Metric["status"], string> = {
	good: GREEN,
	warn: ORANGE,
	poor: RED,
};

const metricRow = [
	reset,
	"display: flex",
	"align-items: center",
	"gap: 10px",
	"padding: 9px 12px",
	"border-radius: 8px",
	"background: var(--sl-color-gray-7, rgba(255,255,255,0.03))",
	"border: 1px solid var(--sl-color-gray-5, rgba(255,255,255,0.08))",
].join("; ");

const metricSquare = (color: string) =>
	[reset, "flex: 0 0 auto", "width: 12px", "height: 12px", "border-radius: 3px", "background: " + color].join(
		"; ",
	);

const metricName = [
	reset,
	"flex: 1 1 auto",
	"min-width: 0",
	"font-size: 13px",
	"color: var(--sl-color-text)",
].join("; ");

const metricValue = [
	reset,
	mono,
	"flex: 0 0 auto",
	"font-size: 13px",
	"font-weight: 700",
	"white-space: nowrap",
].join("; ");

// ---- 3 · Opportunities --------------------------------------------------

type Opp = { title: string; saving: string };
const opportunities: Opp[] = [
	{ title: "Properly size images", saving: "−1.6 s" },
	{ title: "Reduce unused JavaScript", saving: "−0.9 s" },
	{ title: "Eliminate render-blocking resources", saving: "−0.4 s" },
];

const oppRow = [
	reset,
	"display: flex",
	"align-items: center",
	"gap: 12px",
	"padding: 11px 12px",
	"border-radius: 8px",
	"background: var(--sl-color-gray-7, rgba(255,255,255,0.03))",
	"border: 1px solid var(--sl-color-gray-5, rgba(255,255,255,0.08))",
	"border-left: 3px solid " + ORANGE,
].join("; ");

const oppTitle = [
	reset,
	"flex: 1 1 auto",
	"min-width: 0",
	"font-size: 13px",
	"color: var(--sl-color-text)",
].join("; ");

const oppSaving = [
	reset,
	mono,
	"flex: 0 0 auto",
	"font-size: 13px",
	"font-weight: 700",
	"white-space: nowrap",
	"color: " + ORANGE,
].join("; ");

// ---- 4 · Diagnostics ----------------------------------------------------

const diagnostics: string[] = [
	"Avoid an excessive DOM size — 1,240 elements",
	"Minimize main-thread work — 3.2 s",
	"Browser errors were logged to the console",
];

const diagRow = [
	reset,
	"display: flex",
	"align-items: center",
	"gap: 10px",
	"padding: 11px 12px",
	"border-radius: 8px",
	"background: var(--sl-color-gray-7, rgba(255,255,255,0.03))",
	"border: 1px solid var(--sl-color-gray-5, rgba(255,255,255,0.08))",
].join("; ");

const diagDot = [
	reset,
	"flex: 0 0 auto",
	"width: 12px",
	"height: 12px",
	"border-radius: 3px",
	"background: var(--sl-color-gray-4, #6b7280)",
].join("; ");

const diagText = [
	reset,
	"flex: 1 1 auto",
	"min-width: 0",
	"font-size: 13px",
	"color: var(--sl-color-text)",
].join("; ");
---

<div class="not-content" style={root}>
	{
		pane === "score" && (
			<>
				<div style={paneTitle}>Performance</div>
				<div style={scoreWrap}>
					<div style={dial}>
						<div style={dialHole}>
							<span style={dialNumber}>{SCORE}</span>
						</div>
					</div>
					<span style={dialLabel}>Performance score</span>
					<div style={legendRow}>
						<span style={legendItem}>
							<span style={dot(RED)} />0–49
						</span>
						<span style={legendItem}>
							<span style={dot(ORANGE)} />50–89
						</span>
						<span style={legendItem}>
							<span style={dot(GREEN)} />90–100
						</span>
					</div>
				</div>
			</>
		)
	}

	{
		pane === "metrics" && (
			<>
				<div style={paneTitle}>Metrics</div>
				{metrics.map((m) => (
					<div style={metricRow}>
						<span style={metricSquare(statusColor[m.status])} />
						<span style={metricName}>{m.name}</span>
						<span style={[metricValue, "color: " + statusColor[m.status]].join("; ")}>
							{m.value}
						</span>
					</div>
				))}
			</>
		)
	}

	{
		pane === "opportunities" && (
			<>
				<div style={paneTitle}>Opportunities · est. savings</div>
				{opportunities.map((o) => (
					<div style={oppRow}>
						<span style={oppTitle}>{o.title}</span>
						<span style={oppSaving}>{o.saving}</span>
					</div>
				))}
			</>
		)
	}

	{
		pane === "diagnostics" && (
			<>
				<div style={paneTitle}>Diagnostics · no time estimate</div>
				{diagnostics.map((d) => (
					<div style={diagRow}>
						<span style={diagDot} />
						<span style={diagText}>{d}</span>
					</div>
				))}
			</>
		)
	}
</div>
