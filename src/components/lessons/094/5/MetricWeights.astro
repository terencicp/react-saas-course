---
// Lighthouse 12 Performance-score weight bar (Chapter 094 L5).
//
// One full-width horizontal stacked bar split into five segments whose widths
// are proportional to each lab metric's weight in the Performance score
// (FCP 10, Speed Index 10, LCP 25, TBT 30, CLS 25). The point the student must
// walk away with: TBT is the single widest segment (30%) AND it is Lighthouse's
// stand-in for INP. So the TBT segment carries a distinct accent fill + a heavier
// ring, and a callout line under the bar names it as the INP proxy.
//
// The weights drive `flex-grow` directly, so the bar's geometry IS the data — a
// reader opening devtools sees real flex ratios, not hand-placed widths.
//
// A labels row sits beneath the bar, sharing the exact same flex ratios so each
// full metric name lines up under its segment. The thin 10% segments can't hold
// a long name inside the bar, so inside the bar we only print the abbreviation +
// weight (always fits); the full name lives in the aligned labels row below.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// `min-width: 0` on every flex child lets proportional widths hold instead of a
// long label forcing its segment wider than its weight asks for. No JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Saturated mid-tones read on both themes (white text on each). The two minor
// metrics (10% each) get a muted slate so attention lands on the three that
// matter; TBT gets the warm accent because it is the lesson's pivot.
const SLATE = "#64748b"; // slate-500 — the two minor 10% metrics
const INDIGO = "#4f46e5"; // indigo-600 — LCP
const AMBER = "#d97706"; // amber-600 — TBT (the pivot)
const TEAL = "#0d9488"; // teal-600 — CLS

const metrics = [
	{ name: "First Contentful Paint", abbr: "FCP", weight: 10, color: SLATE },
	{ name: "Speed Index", abbr: "SI", weight: 10, color: SLATE },
	{ name: "Largest Contentful Paint", abbr: "LCP", weight: 25, color: INDIGO },
	{
		name: "Total Blocking Time",
		abbr: "TBT",
		weight: 30,
		color: AMBER,
		pivot: true,
	},
	{ name: "Cumulative Layout Shift", abbr: "CLS", weight: 25, color: TEAL },
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 14px",
	"width: 100%",
	"box-sizing: border-box",
	sans,
].join("; ");

const title = [
	reset,
	"font-size: 13px",
	"font-weight: 700",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-2, #c2c7d0)",
	"text-align: center",
].join("; ");

// The bar itself: one row, segments share the same coordinate system as the
// labels row below because both use weight-as-flex-grow.
const bar = [
	reset,
	"display: flex",
	"width: 100%",
	"height: 60px",
	"box-sizing: border-box",
	"border-radius: 10px",
	"overflow: hidden",
	"gap: 2px",
	"background: var(--sl-color-bg)",
].join("; ");

const segment = (color: string, weight: number, pivot: boolean) =>
	[
		reset,
		"box-sizing: border-box",
		`flex: ${weight} 1 0`,
		"min-width: 0",
		"display: flex",
		"flex-direction: column",
		"align-items: center",
		"justify-content: center",
		"gap: 1px",
		"padding: 4px 2px",
		"background: " + color,
		// The pivot gets an inset white ring so it pops as the widest, hottest
		// segment even at a glance.
		pivot
			? "box-shadow: inset 0 0 0 2px rgba(255,255,255,0.9)"
			: "box-shadow: none",
	].join("; ");

const segAbbr = [
	reset,
	"font-size: 15px",
	"font-weight: 800",
	"letter-spacing: 0.01em",
	"color: #ffffff",
	"line-height: 1.1",
].join("; ");

const segPct = [
	reset,
	"font-size: 12px",
	"font-weight: 600",
	"color: rgba(255,255,255,0.92)",
	"line-height: 1.1",
].join("; ");

// Labels row: same flex ratios as the bar so each name centers under its band.
const labelsRow = [
	reset,
	"display: flex",
	"width: 100%",
	"gap: 2px",
].join("; ");

const labelCell = (weight: number) =>
	[
		reset,
		`flex: ${weight} 1 0`,
		"min-width: 0",
		"text-align: center",
		"font-size: 11px",
		"line-height: 1.25",
		"color: var(--sl-color-gray-2, #c2c7d0)",
		"padding: 0 2px",
	].join("; ");

const labelStrong = (pivot: boolean) =>
	[
		reset,
		"display: inline",
		"font-weight: " + (pivot ? "700" : "500"),
		"color: " +
			(pivot
				? "color-mix(in srgb, " + AMBER + " 75%, var(--sl-color-text))"
				: "var(--sl-color-gray-2, #c2c7d0)"),
	].join("; ");

// Callout line under the bar — the take-home, set apart with an accent left rule.
const callout = [
	reset,
	"box-sizing: border-box",
	"width: 100%",
	"padding: 10px 14px",
	"border-radius: 8px",
	"border-left: 3px solid " + AMBER,
	"background: color-mix(in srgb, " + AMBER + " 10%, var(--sl-color-bg))",
	"font-size: 13.5px",
	"line-height: 1.5",
	"color: var(--sl-color-text)",
].join("; ");

const calloutStrong = [
	reset,
	"font-weight: 700",
	"color: color-mix(in srgb, " + AMBER + " 70%, var(--sl-color-text))",
].join("; ");
---

<div class="not-content" style={root}>
	<div style={title}>The Lighthouse 12 Performance score</div>

	<div style={bar}>
		{
			metrics.map((m) => (
				<div style={segment(m.color, m.weight, Boolean(m.pivot))}>
					<span style={segAbbr}>{m.abbr}</span>
					<span style={segPct}>{m.weight}%</span>
				</div>
			))
		}
	</div>

	<div style={labelsRow}>
		{
			metrics.map((m) => (
				<div style={labelCell(m.weight)}>
					<span style={labelStrong(Boolean(m.pivot))}>{m.name}</span>
				</div>
			))
		}
	</div>

	<div style={callout}>
		<span style={calloutStrong}>TBT is the heaviest single lever</span> — and
		it is Lighthouse's stand-in for INP. Lighthouse never reports an INP number.
	</div>
</div>
