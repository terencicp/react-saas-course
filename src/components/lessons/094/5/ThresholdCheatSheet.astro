---
// The 2026-SaaS Lighthouse threshold cheat sheet (Chapter 094 L5).
//
// A reference card, not prose: two surface rows (Marketing page, Authenticated
// dashboard) scored across the five budgets the CI gate later asserts —
// Performance, LCP, CLS, TBT, Total JS. The numbers here are canonical:
// downstream lessons and the chapter quiz cite them, so they must match the
// lesson's table exactly.
//
// Shape rationale: a real two-axis table (surfaces × budgets) reads as the
// look-up card it is. The metric columns reuse the accent palette established
// by the sibling MetricWeights bar (LCP indigo, TBT amber, CLS teal) so the two
// figures in this lesson read as one family — the budgets are visually tied to
// the weights that justify them. The two surface rows carry a left accent rule
// (sky for the static marketing regime, violet for the JS-heavy app regime) that
// mirrors the two buckets in the sort exercise that follows.
//
// CSS grid drives the layout: one header row plus two data rows share a single
// six-column track, so every cell aligns without hand-placed widths. `margin: 0`
// on descendants defeats Starlight's injected prose margins. No JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, monospace)";

// Column accents — shared with MetricWeights.astro so weight ↔ budget read as
// one visual system. The two non-metric columns stay neutral.
const NEUTRAL = "var(--sl-color-gray-3, #9aa2b1)";
const INDIGO = "#4f46e5"; // LCP
const AMBER = "#d97706"; // TBT
const TEAL = "#0d9488"; // CLS

// Surface accents — match the two buckets in the sort drill below the figure.
const SKY = "#0284c7"; // marketing — static, public
const VIOLET = "#7c3aed"; // authenticated dashboard — behind login, JS-heavy

type Col = { key: string; label: string; sub: string; accent: string };

const columns: Col[] = [
	{ key: "perf", label: "Performance", sub: "score", accent: NEUTRAL },
	{ key: "lcp", label: "LCP", sub: "lab", accent: INDIGO },
	{ key: "cls", label: "CLS", sub: "shift", accent: TEAL },
	{ key: "tbt", label: "TBT", sub: "lab", accent: AMBER },
	{ key: "js", label: "Total JS", sub: "gzip", accent: NEUTRAL },
];

type Row = {
	surface: string;
	regime: string;
	accent: string;
	cells: Record<string, string>;
};

const rows: Row[] = [
	{
		surface: "Marketing page",
		regime: "static · public · SEO-sensitive",
		accent: SKY,
		cells: {
			perf: "≥ 90",
			lcp: "≤ 2.5 s",
			cls: "≤ 0.1",
			tbt: "≤ 200 ms",
			js: "≤ 200 KB",
		},
	},
	{
		surface: "Authenticated dashboard",
		regime: "behind login · JS-heavy",
		accent: VIOLET,
		cells: {
			perf: "≥ 85",
			lcp: "≤ 3.0 s",
			cls: "≤ 0.1",
			tbt: "≤ 300 ms",
			js: "≤ 350 KB",
		},
	},
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 12px",
	"width: 100%",
	"box-sizing: border-box",
	sans,
].join("; ");

const title = [
	reset,
	"font-size: 13px",
	"font-weight: 700",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-2, #c2c7d0)",
	"text-align: center",
].join("; ");

// One shared grid for header + rows: first column is the surface label, then
// one track per budget. `minmax(0, …)` lets the budget tracks compress evenly.
const grid = [
	reset,
	"display: grid",
	"grid-template-columns: minmax(150px, 1.6fr) repeat(5, minmax(0, 1fr))",
	"gap: 6px",
	"width: 100%",
	"box-sizing: border-box",
].join("; ");

// Header cells -----------------------------------------------------------

const headSurface = [
	reset,
	"display: flex",
	"align-items: flex-end",
	"padding: 4px 8px",
	"font-size: 11px",
	"font-weight: 600",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3, #9aa2b1)",
].join("; ");

const headMetric = (accent: string) =>
	[
		reset,
		"display: flex",
		"flex-direction: column",
		"align-items: center",
		"justify-content: flex-end",
		"gap: 1px",
		"padding: 6px 4px 8px",
		"border-bottom: 2px solid " + accent,
	].join("; ");

const headMetricLabel = (accent: string) =>
	[
		reset,
		"font-size: 13px",
		"font-weight: 800",
		"letter-spacing: 0.01em",
		"line-height: 1.1",
		"text-align: center",
		"color: " +
			(accent === NEUTRAL
				? "var(--sl-color-text)"
				: "color-mix(in srgb, " + accent + " 70%, var(--sl-color-text))"),
	].join("; ");

const headMetricSub = [
	reset,
	"font-size: 10px",
	"font-weight: 500",
	"line-height: 1.1",
	"color: var(--sl-color-gray-3, #9aa2b1)",
].join("; ");

// Data cells -------------------------------------------------------------

const surfaceCell = (accent: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"justify-content: center",
		"gap: 2px",
		"padding: 10px 8px 10px 12px",
		"border-left: 4px solid " + accent,
		"border-radius: 0 8px 8px 0",
		"background: color-mix(in srgb, " + accent + " 9%, var(--sl-color-bg))",
	].join("; ");

const surfaceName = [
	reset,
	"font-size: 14px",
	"font-weight: 700",
	"line-height: 1.2",
	"color: var(--sl-color-text)",
].join("; ");

const surfaceRegime = [
	reset,
	"font-size: 10.5px",
	"font-weight: 500",
	"line-height: 1.25",
	"color: var(--sl-color-gray-3, #9aa2b1)",
].join("; ");

const valueCell = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"justify-content: center",
	"padding: 10px 4px",
	"border-radius: 8px",
	"background: var(--sl-color-gray-7, rgba(255,255,255,0.03))",
	"border: 1px solid var(--sl-color-gray-5, rgba(255,255,255,0.08))",
].join("; ");

const valueText = [
	reset,
	mono,
	"font-size: 13px",
	"font-weight: 600",
	"line-height: 1.1",
	"text-align: center",
	"color: var(--sl-color-text)",
	"white-space: nowrap",
].join("; ");
---

<div class="not-content" style={root}>
	<div style={title}>2026 SaaS audit budgets</div>

	<div style={grid}>
		{/* header row */}
		<div style={headSurface}>Surface</div>
		{
			columns.map((c) => (
				<div style={headMetric(c.accent)}>
					<span style={headMetricLabel(c.accent)}>{c.label}</span>
					<span style={headMetricSub}>{c.sub}</span>
				</div>
			))
		}

		{/* data rows */}
		{
			rows.map((r) => (
				<>
					<div style={surfaceCell(r.accent)}>
						<span style={surfaceName}>{r.surface}</span>
						<span style={surfaceRegime}>{r.regime}</span>
					</div>
					{columns.map((c) => (
						<div style={valueCell}>
							<span style={valueText}>{r.cells[c.key]}</span>
						</div>
					))}
				</>
			))
		}
	</div>
</div>
