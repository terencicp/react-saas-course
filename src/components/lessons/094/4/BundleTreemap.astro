---
// Bundle treemap (Chapter 094 L4): ONE representative client-bundle treemap,
// rendered once as nested, AREA-proportional HTML+CSS rectangles, reused across
// every DiagramSequence step. The `highlight` prop names which tile glows while
// the rest sit muted, so the same picture teaches a different reading on each
// pass. Area = bytes is the whole reading primitive — the tiles are sized so the
// rendered rectangle area tracks the gzip label.
//
// Layout is honest slice-and-dice over flex tracks (no absolute positioning):
//   - Two columns split horizontally by their total bytes.
//   - LEFT  (190 KB): framework runtime stacked over the shared chunk.
//   - RIGHT (286 KB): recharts on top; a bottom band split into the /dashboard
//                     chunk and a pair of equal date-fns tiles (the duplicate).
// Sizes below are the byte weights; flex-grow values are those same weights, so
// each track's share of its parent is exactly its share of the bytes.
//
// Colors are theme-portable saturated mid-tones with white labels (read in both
// light and dark). The floor is neutral gray; each call-out tile owns a hue.
// `margin: 0` on every descendant defeats Starlight's injected prose margins.
// Height is capped; no JS.

interface Props {
	// Which tile to spotlight. "none" mutes everything (not used by the lesson
	// but keeps the base picture available).
	highlight?:
		| "none"
		| "framework"
		| "route"
		| "surprise"
		| "duplicate"
		| "shared";
}

const { highlight = "none" } = Astro.props;

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--sl-font-system-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

// Tile hues. Floor is neutral; each call-out owns one saturated mid-tone.
const C = {
	framework: "#475569", // slate-600 — the floor, deliberately muted-neutral
	route: "#d97706", // amber-600 — per-route chunk
	surprise: "#dc2626", // red-600 — the surprise barrel import
	duplicate: "#7c3aed", // violet-600 — the duplicate dependency
	shared: "#0d9488", // teal-600 — the every-route chunk
};

// A tile is lit when it is the highlighted one. Lit tiles keep their saturated
// fill + a bright ring; everything else desaturates toward the page background.
const isLit = (key: keyof typeof C) => highlight === key;

const tile = (key: keyof typeof C) => {
	const color = C[key];
	const lit = isLit(key);
	return [
		reset,
		"box-sizing: border-box",
		"position: relative",
		"display: flex",
		"flex-direction: column",
		"justify-content: flex-end",
		"overflow: hidden",
		"border-radius: 6px",
		"padding: 8px 9px",
		"transition: background 160ms, box-shadow 160ms, opacity 160ms",
		lit
			? "background: " + color
			: "background: color-mix(in srgb, " + color + " 22%, var(--sl-color-bg))",
		lit
			? "box-shadow: 0 0 0 2px var(--sl-color-bg), 0 0 0 4px " +
				color +
				", 0 0 16px color-mix(in srgb, " +
				color +
				" 70%, transparent)"
			: "box-shadow: inset 0 0 0 1px color-mix(in srgb, " +
				color +
				" 38%, transparent)",
		lit ? "opacity: 1" : "opacity: 0.78",
		lit ? "z-index: 1" : "z-index: 0",
	].join("; ");
};

const tileName = (key: keyof typeof C) =>
	[
		reset,
		mono,
		"font-size: 13px",
		"font-weight: 700",
		"line-height: 1.2",
		"white-space: nowrap",
		"overflow: hidden",
		"text-overflow: ellipsis",
		isLit(key)
			? "color: #fff"
			: "color: color-mix(in srgb, " + C[key] + " 70%, var(--sl-color-text))",
	].join("; ");

const tileSize = (key: keyof typeof C) =>
	[
		reset,
		sans,
		"font-size: 11px",
		"font-weight: 600",
		"line-height: 1.2",
		"margin-top: 2px",
		"white-space: nowrap",
		isLit(key)
			? "color: rgba(255,255,255,0.88)"
			: "color: var(--sl-color-gray-3, #9ca3af)",
	].join("; ");

// ---- containers ---------------------------------------------------------

// Outer card labelled as the whole client bundle. Height is fixed so the
// flex-grow ratios resolve to honest pixel areas.
const canvas = [
	reset,
	"box-sizing: border-box",
	"width: 100%",
	"height: 360px",
	"display: flex",
	"gap: 6px",
	"padding: 6px",
	"border-radius: 10px",
	"border: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.25))",
	"background: var(--sl-color-gray-6, rgba(125,125,125,0.08))",
	sans,
].join("; ");

// A flex track that splits its space by byte weight (flex-grow = bytes).
const track = (
	weight: number,
	dir: "row" | "column",
) =>
	[
		reset,
		"box-sizing: border-box",
		"flex: " + weight + " 1 0",
		"min-width: 0",
		"min-height: 0",
		"display: flex",
		"flex-direction: " + dir,
		"gap: 6px",
	].join("; ");

// LEFT column = framework (142) over shared (48) → weight 190.
// RIGHT column = recharts (178) over [ /dashboard (64) | date-fns ×2 (44) ] → 286.
const COL_LEFT = 190;
const COL_RIGHT = 286;

const caption = [
	reset,
	sans,
	"font-size: 11px",
	"font-weight: 600",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3, #9ca3af)",
	"margin-bottom: 6px",
].join("; ");
---

<div class="not-content" style={reset}>
	<div style={caption}>client bundle &mdash; area is bytes</div>

	<div style={canvas}>
		{/* LEFT column: the floor + the shared chunk */}
		<div style={track(COL_LEFT, "column")}>
			<div style={[track(142, "column"), tile("framework")].join("; ")}>
				<div style={tileName("framework")}>react-dom + next runtime</div>
				<div style={tileSize("framework")}>~142 KB &middot; the floor</div>
			</div>
			<div style={[track(48, "column"), tile("shared")].join("; ")}>
				<div style={tileName("shared")}>shared chunk</div>
				<div style={tileSize("shared")}>~48 KB &middot; every route</div>
			</div>
		</div>

		{/* RIGHT column: surprise barrel on top, route + duplicate beneath */}
		<div style={track(COL_RIGHT, "column")}>
			<div style={[track(178, "column"), tile("surprise")].join("; ")}>
				<div style={tileName("surprise")}>recharts</div>
				<div style={tileSize("surprise")}>~178 KB &middot; whole package</div>
			</div>

			<div style={track(108, "row")}>
				<div style={[track(64, "column"), tile("route")].join("; ")}>
					<div style={tileName("route")}>/dashboard chunk</div>
					<div style={tileSize("route")}>~64 KB</div>
				</div>

				{/* The duplicate: two equal tiles, same name, different versions */}
				<div style={track(44, "column")}>
					<div style={[track(22, "column"), tile("duplicate")].join("; ")}>
						<div style={tileName("duplicate")}>date-fns</div>
						<div style={tileSize("duplicate")}>~22 KB &middot; v3</div>
					</div>
					<div style={[track(22, "column"), tile("duplicate")].join("; ")}>
						<div style={tileName("duplicate")}>date-fns</div>
						<div style={tileSize("duplicate")}>~22 KB &middot; v2</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
