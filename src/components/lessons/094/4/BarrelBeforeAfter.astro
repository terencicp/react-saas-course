---
// Barrel before/after bar (Chapter 094 L4): two horizontal bars sharing ONE
// left origin and ONE px-per-KB scale, so the shrink after
// `optimizePackageImports` is honest by geometry, not by hand-placed widths.
//
// This cashes L3's debt: the icon-library tile you'd watch collapse from a full
// barrel import (~600 KB) to the per-export shape (~30 KB) once the package is
// listed in `experimental.optimizePackageImports`. Numbers are an illustrative
// shape, not a measured readout — the caption says so.
//
// Each row = a fixed-width left text label ("Before" / "After") + a track that
// is the full byte scale (its 100% === 600 KB). The bar inside each track gets
// width = kb / SCALE_KB, so both bars resolve against the same coordinate
// system. The wide BEFORE bar holds its label inside (white on red); the tiny
// AFTER bar is too narrow for an inside label, so its label sits just to the
// right of the bar in green.
//
// Colors are saturated mid-tones (the same red/green used by the L4 treemap and
// L3 stakes bar) so they read white-on-fill in both themes. `margin: 0` on every
// descendant defeats Starlight's injected prose margins; `box-sizing: border-box`
// keeps the width math exact. No JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const RED = "#dc2626"; // red-600 — the full barrel import
const GREEN = "#16a34a"; // green-600 — the per-export shape

const SCALE_KB = 600; // the track's full width === this many KB

const rows = [
	{
		side: "Before",
		note: "full barrel import",
		kb: 600,
		label: "~600 KB",
		color: RED,
		inside: true,
	},
	{
		side: "After",
		note: "optimizePackageImports",
		kb: 30,
		label: "~30 KB",
		color: GREEN,
		inside: false,
	},
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"box-sizing: border-box",
	"width: 100%",
	"display: flex",
	"flex-direction: column",
	"gap: 22px",
	sans,
].join("; ");

const row = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"gap: 14px",
	"width: 100%",
].join("; ");

// Fixed-width label column so both bars share the exact same left origin.
const sideCol = [
	reset,
	"box-sizing: border-box",
	"flex: 0 0 88px",
	"text-align: right",
	"line-height: 1.25",
].join("; ");

const sideName = [
	reset,
	"font-size: 14px",
	"font-weight: 700",
	"color: var(--sl-color-text)",
].join("; ");

const sideNote = [
	reset,
	"font-size: 11px",
	"font-weight: 500",
	"margin-top: 2px",
	"color: var(--sl-color-gray-3, #9ca3af)",
].join("; ");

// The track IS the byte scale: full width === SCALE_KB. Both rows use it, so a
// given KB count lands at the same pixel offset in both.
const track = [
	reset,
	"box-sizing: border-box",
	"flex: 1 1 0",
	"min-width: 0",
	"display: flex",
	"align-items: center",
	"gap: 8px",
	"height: 38px",
].join("; ");

const barBase = (color: string, pct: number) =>
	[
		reset,
		"box-sizing: border-box",
		"flex: 0 0 " + pct + "%",
		"min-width: 0",
		"height: 100%",
		"display: flex",
		"align-items: center",
		"padding: 0 10px",
		"border-radius: 6px",
		"background: " + color,
		"box-shadow: inset 0 0 0 1px rgba(255,255,255,0.14)",
	].join("; ");

const insideLabel = [
	reset,
	"font-size: 13px",
	"font-weight: 700",
	"color: #ffffff",
	"white-space: nowrap",
].join("; ");

const outsideLabel = (color: string) =>
	[
		reset,
		"font-size: 13px",
		"font-weight: 700",
		"white-space: nowrap",
		"color: color-mix(in srgb, " + color + " 78%, var(--sl-color-text))",
	].join("; ");
---

<div class="not-content" style={root}>
	{
		rows.map((r) => {
			const pct = (r.kb / SCALE_KB) * 100;
			return (
				<div style={row}>
					<div style={sideCol}>
						<div style={sideName}>{r.side}</div>
						<div style={sideNote}>{r.note}</div>
					</div>
					<div style={track}>
						<div style={barBase(r.color, pct)}>
							{r.inside && <span style={insideLabel}>{r.label}</span>}
						</div>
						{!r.inside && <span style={outsideLabel(r.color)}>{r.label}</span>}
					</div>
				</div>
			);
		})
	}
</div>
