---
// LCP discovery timeline (diagram id: lcp-discovery-timeline, Chapter 094 L2,
// "Priority on the LCP element"). A three-step scrubbable DiagramSequence that
// makes the discovery-timing story felt: a hero <Image> in the body is
// *discovered* late, so its bytes start late; `preload` moves discovery into
// <head>-parse time so the hero downloads alongside the CSS/JS; preloading
// everything splits the fixed high-priority budget so nothing wins.
//
// Every step shows the SAME stage so the grid stack never reflows: a short
// horizontal time axis (left = navigation start, right = later) with three
// stacked resource lanes drawn as CSS bars — HTML, CSS / JS bundle, hero image.
// Bars are absolutely positioned inside a relative track whose full width is the
// time window; `left`/`width` are percentages of that window, so a bar that
// starts later literally sits further right. A red LCP marker line drops at the
// end of the hero bar; it visibly jumps left between step 1 and step 2.
//
//   Step 1  Default: the hero bar starts well to the right, after a "discovered
//           during layout" tick. LCP marker sits late.
//   Step 2  preload added: a <link rel="preload"> chip rides in the HTML lane;
//           the hero bar slides left to start alongside CSS/JS; LCP jumps left
//           with a "~200-600 ms saved" bracket.
//   Step 3  Over-preloading: three hero-sized bars (hero, product shot, banner)
//           all start at the left, all high-priority, all the same width, and
//           none finishes earlier than the single hero did in step 2 (a touch
//           later) — the budget split three ways.
//
// Why DiagramSequence + HTML/CSS (per diagrams INDEX "sequential phase strip"):
// the teaching IS the before/after shift of one bar's start time, which the
// scrubber makes felt; real CSS bars are devtools-inspectable. color-scheme is
// pinned light so the hand-picked tints survive dark mode; `margin: 0` on every
// inner element defeats Starlight's injected prose margins. The component owns
// its DiagramSequence + steps so the MDX stays a single import.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const AXIS = '#94a3b8'; // the time axis + ticks (slate-400)
const LANE_BG = '#f1f5f9'; // the empty lane track (slate-100)
const DIM_INK = '#94a3b8'; // muted ink (slate-400)

const SLATE = '#475569'; // slate-600 — the HTML stream bar
const TEAL = '#0d9488'; // teal-600 — the CSS / JS bundle bar
const BLUE = '#2563eb'; // blue-600 — the hero image bar (the star)
const BLUE_SOFT = '#93c5fd'; // blue-300 — the contended hero bars in step 3
const BLUE_INK = '#1e40af'; // blue-800 — dark text on the pastel step-3 bars
const RED = '#dc2626'; // red-600 — the LCP marker + "trap" accent
const AMBER_INK = '#92400e'; // amber-800 — the saved/trap annotation ink
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER = '#d97706'; // amber-600
const GREEN_INK = '#166534'; // green-800 — the "saved" annotation ink
const GREEN_BG = '#dcfce7'; // green-100
const GREEN = '#16a34a'; // green-600

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, centered column so all three
// steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; gap: 12px; margin: 0; padding: 4px 0; color-scheme: light; font-family: ${sans}; color: ${INK}; max-width: 560px; margin-inline: auto;`;

// The "navigation start ... later" eyebrow above the lanes.
const axisLabels = `display: flex; align-items: baseline; justify-content: space-between; margin: 0; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT};`;

// The lane grid: a fixed label column on the left, the time track on the right,
// three explicit rows (one per lane). Explicit placement on every child keeps
// the marker overlay (which spans all rows) from reordering the auto-flow.
// Extra top padding leaves room for the LCP flag that sits above the first lane.
const grid = `display: grid; grid-template-columns: 92px minmax(0, 1fr); grid-template-rows: repeat(3, 24px); column-gap: 10px; row-gap: 9px; align-items: center; margin: 0; padding-top: 16px;`;

// A lane's left-hand label (column 1, explicit row).
const laneName = (row: number) =>
	`grid-column: 1; grid-row: ${row}; margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${INK}; text-align: right;`;

// The time track each lane's bars live in (column 2, explicit row; bars by %).
const track = (row: number) =>
	`grid-column: 2; grid-row: ${row}; position: relative; width: 100%; height: 24px; margin: 0; border-radius: 6px; background: ${LANE_BG}; min-width: 0;`;

// A bar inside a track. start/end are percentages of the time window.
const bar = (color: string, start: number, end: number, opts: { soft?: boolean } = {}) =>
	`position: absolute; top: 3px; bottom: 3px; left: ${start}%; width: ${end - start}%; margin: 0; border-radius: 5px; background: ${color}; display: flex; align-items: center; justify-content: center; box-sizing: border-box; overflow: hidden; ${opts.soft ? `border: 1px solid ${BLUE};` : ''}`;

// The text inside a bar. White on the saturated fills; dark-blue ink on the
// pastel (contended) bars in step 3, where white would wash out.
const barText = `margin: 0; padding: 0 6px; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1; color: #ffffff; white-space: nowrap;`;
const barTextSoft = `margin: 0; padding: 0 6px; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1; color: ${BLUE_INK}; white-space: nowrap;`;

// A small chip that rides on the HTML lane (e.g. the <link rel="preload"> hint).
const headChip = (at: number) =>
	`position: absolute; top: 50%; left: ${at}%; transform: translate(-50%, -50%); margin: 0; padding: 2px 6px; font-family: ${mono}; font-size: 9.5px; font-weight: 700; line-height: 1.2; color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN}; border-radius: 999px; white-space: nowrap; z-index: 2;`;

// A small "discovered during layout" tick that sits on the hero track (step 1).
const discoverTick = (at: number) =>
	`position: absolute; top: 50%; left: ${at}%; transform: translate(-50%, -50%); margin: 0; padding: 2px 6px; font-family: ${sans}; font-size: 9.5px; font-weight: 700; line-height: 1.2; color: ${INK_SOFT}; background: #ffffff; border: 1px dashed ${AXIS}; border-radius: 6px; white-space: nowrap; z-index: 2;`;

// The LCP marker: a grid item placed in the track column (column 2) spanning
// every lane row, so its `left: X%` shares the exact coordinate system the bars
// use. A vertical red line drops at the end of the hero bar with a flag on top.
const markerCol = `grid-column: 2; grid-row: 1 / 4; align-self: stretch; position: relative; margin: 0; pointer-events: none;`;
const markerLine = (at: number) =>
	`position: absolute; top: 14px; bottom: 0; left: ${at}%; width: 2px; margin: 0; background: ${RED}; z-index: 3;`;
const markerFlag = (at: number) =>
	`position: absolute; top: -3px; left: ${at}%; transform: translateX(-50%); margin: 0; padding: 1px 7px; font-family: ${sans}; font-size: 9.5px; font-weight: 800; letter-spacing: 0.03em; line-height: 1.3; color: #ffffff; background: ${RED}; border-radius: 5px; white-space: nowrap; z-index: 4;`;

// A faint reference marker (step 3): where step 2's single preload landed, so
// the reader sees the contended bars finish *later* than the lone hero would.
const refLine = (at: number) =>
	`position: absolute; top: 14px; bottom: 0; left: ${at}%; width: 0; margin: 0; border-left: 2px dashed ${INK_SOFT}; z-index: 2;`;
const refFlag = (at: number) =>
	`position: absolute; top: -3px; left: ${at}%; transform: translateX(-100%); margin: 0; padding: 1px 6px; font-family: ${sans}; font-size: 8.5px; font-weight: 700; line-height: 1.3; color: ${INK_SOFT}; background: #ffffff; border: 1px dashed ${INK_SOFT}; border-radius: 5px; white-space: nowrap; z-index: 2;`;

// The annotation pill under the lanes (saved / trap).
const note = (kind: 'saved' | 'trap') => {
	const base =
		'display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 3px 10px; font-family: ' +
		sans +
		'; font-size: 10.5px; font-weight: 700; line-height: 1.3; border-radius: 999px; white-space: nowrap;';
	return kind === 'saved'
		? base + ` color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN};`
		: base + ` color: ${AMBER_INK}; background: ${AMBER_BG}; border: 1px solid ${AMBER};`;
};
const noteRow = `display: flex; justify-content: center; margin: 0; min-height: 22px;`;

// Title eyebrow shared by all three steps.
const titleRow = `display: flex; align-items: center; justify-content: center; gap: 8px; margin: 0; font-size: 12px; font-weight: 800; color: ${INK};`;
const stepTag = (color: string) =>
	`display: inline-flex; align-items: center; margin: 0; padding: 1px 8px; font-size: 10px; font-weight: 800; letter-spacing: 0.03em; line-height: 1.4; border-radius: 999px; color: #ffffff; background: ${color};`;
---

<DiagramSequence>
	{/* ---- Step 1: Default — the late start ---- */}
	<DiagramStep caption="The hero waits until the browser trips over it in the body during layout, then waits again because the default is lazy-loading. The bytes only start late — so LCP lands late.">
		<div style={stage}>
			<div style={titleRow}>
				<span style={stepTag(SLATE)}>Step 1</span>
				<span>Default: the late start</span>
			</div>
			<div style={axisLabels}>
				<span style="margin: 0;">&larr; navigation start</span>
				<span style="margin: 0;">later &rarr;</span>
			</div>
			<div style={grid}>
				<span style={laneName(1)}>HTML</span>
				<div style={track(1)}>
					<div style={bar(SLATE, 0, 30)}><span style={barText}>HTML stream</span></div>
				</div>

				<span style={laneName(2)}>CSS / JS bundle</span>
				<div style={track(2)}>
					<div style={bar(TEAL, 6, 40)}><span style={barText}>CSS / JS</span></div>
				</div>

				<span style={laneName(3)}>hero image</span>
				<div style={track(3)}>
					<div style={discoverTick(46)} aria-hidden="true">discovered during layout</div>
					<div style={bar(BLUE, 52, 82)}><span style={barText}>hero</span></div>
				</div>

				<div style={markerCol} aria-hidden="true">
					<div style={markerFlag(82)}>LCP</div>
					<div style={markerLine(82)}></div>
				</div>
			</div>
			<div style={noteRow}>
				<span style={note('trap')}>Discovered late, then lazy-loaded &mdash; doubly delayed</span>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: preload added ---- */}
	<DiagramStep caption="preload moves the hero's discovery into the <head>, so its bytes download alongside the CSS and JS instead of queuing behind them. The LCP marker jumps left by the discovery gap.">
		<div style={stage}>
			<div style={titleRow}>
				<span style={stepTag(BLUE)}>Step 2</span>
				<span>preload added</span>
			</div>
			<div style={axisLabels}>
				<span style="margin: 0;">&larr; navigation start</span>
				<span style="margin: 0;">later &rarr;</span>
			</div>
			<div style={grid}>
				<span style={laneName(1)}>HTML</span>
				<div style={track(1)}>
					<div style={bar(SLATE, 0, 30)}><span style={barText}>HTML stream</span></div>
					<div style={headChip(15)} aria-hidden="true">&lt;link rel="preload"&gt;</div>
				</div>

				<span style={laneName(2)}>CSS / JS bundle</span>
				<div style={track(2)}>
					<div style={bar(TEAL, 6, 40)}><span style={barText}>CSS / JS</span></div>
				</div>

				<span style={laneName(3)}>hero image</span>
				<div style={track(3)}>
					<div style={bar(BLUE, 8, 38)}><span style={barText}>hero</span></div>
				</div>

				<div style={markerCol} aria-hidden="true">
					<div style={markerFlag(38)}>LCP</div>
					<div style={markerLine(38)}></div>
				</div>
			</div>
			<div style={noteRow}>
				<span style={note('saved')}>&#9889; ~200&ndash;600 ms saved &mdash; hero starts with the bundle</span>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: Over-preloading — the trap ---- */}
	<DiagramStep caption="The high-priority lane is a fixed budget, not a free upgrade. Preload everything and you've preloaded nothing — the bandwidth just splits three ways, and none lands sooner than the single hero did.">
		<div style={stage}>
			<div style={titleRow}>
				<span style={stepTag(RED)}>Step 3</span>
				<span>Over-preloading: the trap</span>
			</div>
			<div style={axisLabels}>
				<span style="margin: 0;">&larr; navigation start</span>
				<span style="margin: 0;">later &rarr;</span>
			</div>
			<div style={grid}>
				<span style={laneName(1)}>hero image</span>
				<div style={track(1)}>
					<div style={bar(BLUE_SOFT, 8, 46, { soft: true })}><span style={barTextSoft}>hero</span></div>
				</div>

				<span style={laneName(2)}>product shot</span>
				<div style={track(2)}>
					<div style={bar(BLUE_SOFT, 8, 46, { soft: true })}><span style={barTextSoft}>product shot</span></div>
				</div>

				<span style={laneName(3)}>banner</span>
				<div style={track(3)}>
					<div style={bar(BLUE_SOFT, 8, 46, { soft: true })}><span style={barTextSoft}>banner</span></div>
				</div>

				<div style={markerCol} aria-hidden="true">
					<div style={refFlag(38)}>step 2 hero</div>
					<div style={refLine(38)}></div>
					<div style={markerFlag(46)}>LCP</div>
					<div style={markerLine(46)}></div>
				</div>
			</div>
			<div style={noteRow}>
				<span style={note('trap')}>3 images, all high-priority &mdash; the budget splits, none wins</span>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
