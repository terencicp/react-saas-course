---
// Diagram: a stylized Sentry-style server trace on a shared left-to-right
// millisecond axis. Used by the "two-signatures" TabbedContent to draw the two
// production SQL-slowness shapes side by side:
//   - Missing index  -> ONE fat span filling almost the whole axis.
//   - N+1            -> a STAIRCASE of many thin spans, each starting where the
//                       previous ended.
//
// Pure HTML + CSS (inline styles only, devtools-inspectable). Bar widths and
// offsets are proportional to a shared `axisMs` so the "fat vs thin" contrast is
// honest. Bars are absolutely positioned inside a relative track; a tick axis at
// the bottom anchors the milliseconds. No <Figure> wrapper — the parent
// TabbedItem provides the card.

interface Span {
	// Bar label (rendered inside the bar when it fits, else above it).
	label: string;
	// Start offset in ms along the shared axis.
	start: number;
	// Duration in ms (bar width along the shared axis).
	ms: number;
}

interface Props {
	// Root span row drawn full width at the top (e.g. "GET /invoices — 280ms").
	root: string;
	// Child spans drawn below the root.
	spans: Span[];
	// Axis upper bound in ms; every width/offset is a fraction of this.
	axisMs: number;
	// Tick positions in ms for the bottom axis.
	ticks: number[];
	// Saturated fill for the bars (reads on light + dark).
	color: string;
	// Whether a span's label sits inside the bar (fat span) or above it (thin
	// spans, where the bar is too narrow to hold text).
	labelInside?: boolean;
}

const { root, spans, axisMs, ticks, color, labelInside = false } = Astro.props;

const pct = (ms: number) => `${(ms / axisMs) * 100}%`;

// Each child span gets its own row so a staircase reads as distinct stacked
// bars. Rows are taller when labels live above the bar.
const rowHeight = labelInside ? 30 : 34;
const rowGap = 6;
const tracksHeight = spans.length * rowHeight + (spans.length - 1) * rowGap;

const rootLabelStyle = [
	'margin: 0',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 12px',
	'font-weight: 600',
	'color: #ffffff',
	'white-space: nowrap',
	'overflow: hidden',
	'text-overflow: ellipsis',
].join('; ');

const barLabelInsideStyle = [
	'margin: 0',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 11.5px',
	'font-weight: 600',
	'color: #ffffff',
	'white-space: nowrap',
	'overflow: hidden',
	'text-overflow: ellipsis',
].join('; ');

const barLabelAboveStyle = [
	'margin: 0',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 11px',
	'color: var(--sl-color-gray-1)',
	'white-space: nowrap',
].join('; ');

const durPillStyle = [
	'margin: 0',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 11px',
	'font-weight: 600',
	'color: var(--sl-color-gray-2)',
	'white-space: nowrap',
].join('; ');

const tickLabelStyle = [
	'margin: 0',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 11px',
	'color: var(--sl-color-gray-3)',
].join('; ');
---

<div class="tsig" style="margin: 0;">
	{/* Root span: full-width bar at the top */}
	<div class="tsig-root-track" style="margin: 0;">
		<div class="tsig-root-bar" style={`background: ${color}; margin: 0;`}>
			<span style={rootLabelStyle}>{root}</span>
		</div>
	</div>

	{/* Child spans */}
	<div class="tsig-tracks" style={`height: ${tracksHeight}px; margin: 0;`}>
		{spans.map((span, i) => (
			<div
				class="tsig-row"
				style={`top: ${i * (rowHeight + rowGap)}px; height: ${rowHeight}px; margin: 0;`}
			>
				{labelInside ? (
					<div
						class="tsig-bar"
						style={`left: ${pct(span.start)}; width: ${pct(span.ms)}; background: ${color}; margin: 0;`}
					>
						<span style={barLabelInsideStyle}>{span.label}</span>
						<span style={`${durPillStyle}; color: #ffffff; margin-left: 8px;`}>
							{span.ms}ms
						</span>
					</div>
				) : (
					<>
						<div
							class="tsig-bar-label-above"
							style={`left: ${pct(span.start)}; margin: 0;`}
						>
							<span style={barLabelAboveStyle}>{span.label}</span>
						</div>
						<div
							class="tsig-bar tsig-bar--thin"
							style={`left: ${pct(span.start)}; width: ${pct(span.ms)}; background: ${color}; margin: 0;`}
						>
						</div>
						<div
							class="tsig-dur-above"
							style={`left: calc(${pct(span.start)} + ${pct(span.ms)} + 6px); margin: 0;`}
						>
							<span style={durPillStyle}>{span.ms}ms</span>
						</div>
					</>
				)}
			</div>
		))}
	</div>

	{/* Shared time axis */}
	<div class="tsig-axis" style="margin: 0;">
		<div class="tsig-axis-line" style="margin: 0;"></div>
		{ticks.map((t) => (
			<div class="tsig-tick" style={`left: ${pct(t)}; margin: 0;`}>
				<div class="tsig-tick-mark" style="margin: 0;"></div>
				<div style={tickLabelStyle}>{t}ms</div>
			</div>
		))}
	</div>
</div>

<style>
	.tsig {
		width: 100%;
	}

	.tsig-root-track {
		position: relative;
		width: 100%;
		margin-bottom: 10px;
	}

	.tsig-root-bar {
		width: 100%;
		height: 26px;
		border-radius: 5px;
		display: flex;
		align-items: center;
		padding: 0 10px;
		box-sizing: border-box;
		opacity: 0.55;
	}

	.tsig-tracks {
		position: relative;
		width: 100%;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-radius: 6px;
		overflow: visible;
	}

	.tsig-row {
		position: absolute;
		left: 0;
		right: 0;
	}

	.tsig-bar {
		position: absolute;
		top: 4px;
		bottom: 4px;
		border-radius: 4px;
		display: flex;
		align-items: center;
		padding: 0 10px;
		box-sizing: border-box;
		min-width: 0;
	}

	.tsig-bar--thin {
		top: 14px;
		bottom: 6px;
		min-width: 4px;
		padding: 0;
	}

	.tsig-bar-label-above {
		position: absolute;
		top: 0;
		transform: none;
	}

	.tsig-dur-above {
		position: absolute;
		top: 14px;
	}

	.tsig-axis {
		position: relative;
		height: 30px;
		margin-top: 6px;
	}

	.tsig-axis-line {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		border-top: 1px solid color-mix(in srgb, currentColor 30%, transparent);
	}

	.tsig-tick {
		position: absolute;
		top: 0;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.tsig-tick-mark {
		width: 1px;
		height: 6px;
		background: color-mix(in srgb, currentColor 40%, transparent);
	}
</style>
