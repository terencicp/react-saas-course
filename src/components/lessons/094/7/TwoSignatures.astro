---
// Diagram "two-signatures": the two production SQL-slowness shapes, side by side
// in a TabbedContent. One tab per failure class so the visual signatures are
// directly comparable.
//   Tab 1 — Missing index: ONE fat span (~280ms) filling the whole axis.
//   Tab 2 — N+1: a STAIRCASE of ~6 thin spans (~2ms each), descending.
// Both share the same 300ms axis so "fat" and "thin" are honest, not relative.

import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';
import TraceSignature from './TraceSignature.astro';

// Shared axis so both tabs read on the same coordinate system.
const axisMs = 300;
const ticks = [0, 100, 200, 300];

// Tab 1: one fat span. Almost the full axis, one query, scanning the table.
const fatSpan = [
	{
		label: 'select … from invoices where organization_id = $1 order by created_at desc limit 20',
		start: 4,
		ms: 280,
	},
];

// Tab 2: a staircase. One parent query, then one child query per row, each
// starting roughly where the previous ended — and each only ~2ms wide.
const staircase = [
	{ label: 'select … from audit_logs where organization_id = $1', start: 1, ms: 3 },
	{ label: 'select … from users where id = $2', start: 5, ms: 2 },
	{ label: 'select … from users where id = $3', start: 8, ms: 2 },
	{ label: 'select … from users where id = $4', start: 11, ms: 2 },
	{ label: 'select … from users where id = $5', start: 14, ms: 2 },
	{ label: 'select … from users where id = $6', start: 17, ms: 2 },
];

// blue-600 / teal-600 — saturated mid-tones that read on light and dark.
const fatColor = '#2563eb';
const staircaseColor = '#0d9488';
---

<TabbedContent syncKey="two-signatures">
	<TabbedItem label="Missing index — one fat span">
		<TraceSignature
			root="GET /invoices — 285ms"
			spans={fatSpan}
			axisMs={axisMs}
			ticks={ticks}
			color={fatColor}
			labelInside={true}
		/>
		<Fragment slot="caption">
			One query — but it scans 50,000 rows to return 20. It is{' '}
			<strong>one bar, and it is fat</strong>: the slowness is all in this single span.
		</Fragment>
	</TabbedItem>

	<TabbedItem label="N+1 — a staircase">
		<TraceSignature
			root="GET /audit-log — 64ms"
			spans={staircase}
			axisMs={axisMs}
			ticks={ticks}
			color={staircaseColor}
		/>
		<Fragment slot="caption">
			One parent query plus N child queries — each row its own round trip. Every bar is{' '}
			<strong>thin, but there are many</strong>: the slowness is in the count, not any one span.
		</Fragment>
	</TabbedItem>
</TabbedContent>
