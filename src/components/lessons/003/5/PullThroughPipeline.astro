---
import Figure from '../../../figures/Figure.astro';

// Layout constants for the four-box horizontal pipeline.
const BOX_W = 160;
const BOX_H = 50;
const GAP = 120;
const PAD_X = 20;
const Y_TOP = 45;
const Y_BOTTOM = Y_TOP + BOX_H; // 95
const Y_CENTER = (Y_TOP + Y_BOTTOM) / 2; // 70
const Y_ARROW_TOP = Y_CENTER - 10; // 60
const Y_ARROW_BOTTOM = Y_CENTER + 10; // 80
const Y_LABEL_TOP = 50; // above the top arrow
const Y_LABEL_BOTTOM = 92; // below the bottom arrow
const Y_SUBTITLE = Y_BOTTOM + 17; // 112

const boxes = [
	{ label: 'invoiceEvents()', subtitle: 'generator source', kind: 'source' as const },
	{ label: '.filter(isCritical)', subtitle: 'lazy', kind: 'stage' as const },
	{ label: '.take(10)', subtitle: 'lazy', kind: 'stage' as const },
	{ label: '.toArray()', subtitle: 'terminal', kind: 'terminal' as const },
];

const boxXs = boxes.map((_, i) => PAD_X + i * (BOX_W + GAP));
const viewW = PAD_X * 2 + boxes.length * BOX_W + (boxes.length - 1) * GAP;
const viewH = Y_SUBTITLE + 8;

const gaps = boxXs.slice(0, -1).map((x, i) => ({
	xEnd: x + BOX_W, // right edge of left box
	xStart: boxXs[i + 1], // left edge of right box
	midX: (x + BOX_W + boxXs[i + 1]) / 2,
}));
---

<Figure caption="Each terminal call pulls one value through the chain at a time — the source yields only what the terminal needs.">
	<div style="overflow-x: auto;">
		<svg
			viewBox={`0 0 ${viewW} ${viewH}`}
			role="img"
			aria-label="A pull-through iterator pipeline: invoiceEvents() feeds into .filter(isCritical), which feeds into .take(10), which feeds into the terminal .toArray(). Each gap shows a leftward 'pull (next)' arrow above a rightward 'value' arrow, indicating that the terminal pulls one value at a time and the source yields exactly what's needed."
			xmlns="http://www.w3.org/2000/svg"
			style={`width: 100%; min-width: ${viewW}px; height: auto; display: block;`}
		>
			<defs>
				<marker
					id="ptp-arrow-end"
					viewBox="0 0 10 10"
					refX="9"
					refY="5"
					markerWidth="7"
					markerHeight="7"
					orient="auto-start-reverse"
				>
					<path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
				</marker>
			</defs>

			{/* Boxes */}
			{boxes.map((box, i) => {
				const x = boxXs[i];
				const isTerminal = box.kind === 'terminal';
				const isSource = box.kind === 'source';
				const fill = isTerminal
					? 'var(--sl-color-accent-low, #dce8f5)'
					: 'var(--sl-color-bg-sidebar, transparent)';
				const stroke = isTerminal
					? 'var(--sl-color-accent, #3178c6)'
					: isSource
						? 'currentColor'
						: '#9ca3af';
				const textFill = 'currentColor';
				return (
					<g>
						<rect
							x={x}
							y={Y_TOP}
							width={BOX_W}
							height={BOX_H}
							rx="6"
							ry="6"
							fill={fill}
							stroke={stroke}
							stroke-width={isTerminal ? '2' : isSource ? '1.5' : '1.25'}
						/>
						<text
							x={x + BOX_W / 2}
							y={Y_CENTER}
							font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
							font-size="13"
							fill={textFill}
							text-anchor="middle"
							dominant-baseline="central"
						>
							{box.label}
						</text>
						<text
							x={x + BOX_W / 2}
							y={Y_SUBTITLE}
							font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
							font-size="11"
							fill="#9ca3af"
							text-anchor="middle"
						>
							{box.subtitle}
						</text>
					</g>
				);
			})}

			{/* Arrows in each gap: top (pull, leftward) + bottom (value, rightward) */}
			{gaps.map((gap) => (
				<g>
					{/* Top arrow: right-to-left, "pull (next)" */}
					<line
						x1={gap.xStart - 2}
						y1={Y_ARROW_TOP}
						x2={gap.xEnd + 2}
						y2={Y_ARROW_TOP}
						stroke="currentColor"
						stroke-width="1.25"
						marker-end="url(#ptp-arrow-end)"
					/>
					<text
						x={gap.midX}
						y={Y_LABEL_TOP}
						font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
						font-size="11"
						fill="currentColor"
						text-anchor="middle"
					>
						pull (next)
					</text>

					{/* Bottom arrow: left-to-right, "value" */}
					<line
						x1={gap.xEnd + 2}
						y1={Y_ARROW_BOTTOM}
						x2={gap.xStart - 2}
						y2={Y_ARROW_BOTTOM}
						stroke="currentColor"
						stroke-width="1.25"
						marker-end="url(#ptp-arrow-end)"
					/>
					<text
						x={gap.midX}
						y={Y_LABEL_BOTTOM}
						font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
						font-size="11"
						fill="currentColor"
						text-anchor="middle"
					>
						value
					</text>
				</g>
			))}
		</svg>
	</div>
</Figure>
