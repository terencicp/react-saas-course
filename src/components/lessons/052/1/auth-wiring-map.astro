---
// auth-wiring-map — Chapter 052 Lesson 1, "Wiring the auth instance".
//
// The lesson's single load-bearing visual. It shows the TWO ways into the one
// shared server `auth` instance, split by where the caller runs:
//
//   Server code  ──(auth.api.* · in-process, no HTTP)──▶ lib/auth.ts (instance)
//                   ↑ VIOLET: server-direct — same process, no network
//
//   Browser code ──(authClient.* · HTTP POST/GET)──▶ [...all] route ──(dispatches)──▶ instance
//                   ↑ ORANGE: browser-over-HTTP — the catch-all route only sits on this path
//
// Topology, not a straight line: server code reaches the instance DIRECTLY, so a
// single horizontal row would force the server arrow to leap over the route box.
// Instead a 3-column grid — sources (left, two stacked) | route (middle, on the
// browser row only) | instance (right, spans both rows). The server arrow flies
// straight across the top lane in clear space; the browser arrow goes left→route,
// then route→instance. That keeps every curve in empty gap, never crossing text.
//
// Built with <ArrowDiagram> (LeaderLine) because each box is two-line custom HTML
// (a monospace title + a muted under-label) and the per-path semantic coloring is
// the whole point — plain-label D2/Mermaid boxes wouldn't carry it. LeaderLine
// positions arrows from document.body, so the wrapping <Figure> MUST be
// expandable={false}: relocating the body into the lightbox breaks the lines.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark). The two path
// accents (#7c3aed violet, #ea580c orange) are used as-is in both themes —
// mid-tones that read on either background. margin:0 resets defeat Starlight's
// injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Mid-tone accents reused verbatim in light + dark.
const SERVER_VIOLET = '#7c3aed'; // server-direct, in-process
const BROWSER_ORANGE = '#ea580c'; // browser-over-HTTP

const arrows = [
	// Server code calls the instance DIRECTLY — same process, no network hop.
	// Top lane: a strong rightward pull keeps the long curve clear of the route
	// box sitting below it.
	{
		from: 'awm-server',
		to: 'awm-instance',
		label: 'auth.api.* — in-process call, no HTTP',
		color: SERVER_VIOLET,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [150, 0],
		endSocketGravity: [-150, -40],
		labelOffset: [0, -20],
	},
	// Browser code can't reach the instance — it POSTs to the catch-all route.
	{
		from: 'awm-browser',
		to: 'awm-route',
		label: 'authClient.* — HTTP POST/GET',
		color: BROWSER_ORANGE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, 30],
	},
	// The route forwards to the same instance.
	{
		from: 'awm-route',
		to: 'awm-instance',
		label: 'dispatches',
		color: BROWSER_ORANGE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 40],
		labelOffset: [0, 30],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="awm not-content">
			<div class="awm-sources">
				<div class="awm-box awm-box--server" id="awm-server">
					<span class="awm-title">Server code</span>
					<span class="awm-under"
						>Server Components, Server Actions, route handlers, <code
							>proxy.ts</code
						></span
					>
				</div>
				<div class="awm-box awm-box--browser" id="awm-browser">
					<span class="awm-title">Browser code</span>
					<span class="awm-under">Client Components (forms, session UI)</span>
				</div>
			</div>

			<div class="awm-route-cell">
				<div class="awm-box awm-box--route" id="awm-route">
					<span class="awm-title">app/api/auth/[...all]/route.ts</span>
					<span class="awm-under">the catch-all endpoint</span>
				</div>
			</div>

			<div class="awm-instance-cell">
				<div class="awm-box awm-box--instance" id="awm-instance">
					<span class="awm-title">lib/auth.ts</span>
					<span class="awm-under">the server <code>auth</code> instance</span>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		Two ways into one instance. Server code calls it in-process; browser code
		reaches it over HTTP through the catch-all route. Both end at the same
		<code>auth</code> object.
	</Fragment>
</Figure>

<style>
	.awm {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.15fr) minmax(0, 0.95fr);
		align-items: center;
		column-gap: 120px;
		row-gap: 28px;
		margin: 0;
		padding: 16px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* Column 1: the two source boxes, stacked. */
	.awm-sources {
		grid-column: 1;
		display: flex;
		flex-direction: column;
		gap: 28px;
		margin: 0;
	}

	/* Column 2: the route box, on the browser (bottom) row only. The top half of
	   this column is intentionally empty so the server arrow's top lane is clear. */
	.awm-route-cell {
		grid-column: 2;
		align-self: end;
		margin: 0;
	}

	/* Column 3: the instance, vertically centered so both paths land on it. */
	.awm-instance-cell {
		grid-column: 3;
		margin: 0;
	}

	.awm-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 11px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	.awm-box--server {
		border-color: color-mix(in srgb, #7c3aed 50%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #7c3aed 7%, transparent);
	}

	.awm-box--browser,
	.awm-box--route {
		border-color: color-mix(in srgb, #ea580c 50%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #ea580c 7%, transparent);
	}

	.awm-box--instance {
		border-color: var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-6, #1e293b) 55%, transparent);
	}

	.awm-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.awm-under {
		font-size: 0.68rem;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.awm-under code,
	.awm-title code {
		font-size: 0.95em;
		background: transparent;
		padding: 0;
	}

	/* Narrow viewports: collapse to a single column. The right→left sockets
	   degrade to vertical arcs between stacked boxes — readable, labels still
	   float in the gaps. Source order (server, browser, route, instance) keeps
	   the reading order sensible top-to-bottom. */
	@media (max-width: 760px) {
		.awm {
			grid-template-columns: 1fr;
			row-gap: 52px;
		}
		.awm-sources {
			grid-column: 1;
			gap: 52px;
		}
		.awm-route-cell,
		.awm-instance-cell {
			grid-column: 1;
			align-self: stretch;
			justify-self: center;
		}
		.awm-box {
			width: min(22rem, 100%);
		}
	}
</style>
