---
// three-clocks-timeline — the centerpiece visual of Ch 052 L3 and the killer of
// the "one timeout" trap. The whole job of the figure is to make the reader SEE
// that the three session clocks are different sizes and anchored differently on
// ONE shared time axis that runs from sign-in (createdAt) at the origin to the
// expiresIn wall at the right edge.
//
//   sign-in (createdAt) ........................................ the wall
//   |freshAge|  | updateAge tick → slides the wall right          |
//   [============ expiresIn — 30 days =============================]
//
// Layout: a single horizontal axis region, positioned children read off it as
// percentages of 0..30 days.
//   • expiresIn  (blue)   — a long bar spanning the full axis; its right edge is
//                           the hard wall. A green slide-arrow extends past the
//                           wall to show updateAge pushing it further right.
//   • freshAge   (violet) — a thin band hugging the origin. 10 min is ~1/4320 of
//                           30 days, so it's drawn at a minimum visible width and
//                           labelled honestly as a sliver ("tiny by design").
//   • updateAge  (green)  — a tick partway in (1 day ≈ 1/30 of the axis), with a
//                           right-pointing arrow off the wall: an active request
//                           past this tick slides the wall right.
// Callouts sit above and below the bar so no two labels share pixels.
//
// Pure HTML + CSS, scoped <style>. `not-content` wrapper + margin:0 on every
// node defeat Starlight's prose-margin selector. Violet/blue/green follow the
// outline's colour suggestion (freshAge violet, expiresIn blue, slide green) and
// read on both themes as saturated mid-tones with white text. Height is capped
// for laptop viewports; the layout collapses to a stacked legend on narrow ones.

import Figure from "../../../figures/Figure.astro";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

// Geometry, as percentages along the 0..30-day axis.
// updateAge is 1 day = 1/30 ≈ 3.3%; nudged out to 6% so the tick + its label
// clear the freshAge band and read as small-but-deliberate rather than glued to
// the origin. freshAge (10 min) is far smaller still — drawn as a sliver from
// the origin to ~3%, comfortably narrower than the updateAge tick so the size
// ordering freshAge ≪ updateAge ≪ expiresIn is unmistakable.
const FRESH_END = 3; // %
const UPDATE_AT = 6; // %
---

<Figure
  caption="Three clocks on one session row: a tiny `freshAge` window (10 min) for sensitive actions near sign-in, a 30-day `expiresIn` wall, and a 1-day `updateAge` tick that slides the wall right while you stay active. The bands share one time axis — note how small freshness is next to the session's whole life."
>
  <div class="tc not-content" style={sans}>
    {/* freshAge callout — above the bar, anchored at the origin end of the axis. */}
    <div class="tc-top">
      <div
        class="tc-callout tc-callout--fresh"
        style={`left: ${FRESH_END}%;`}
      >
        <span class="tc-callout-title" style={mono}>freshAge — 10 min</span>
        <span class="tc-callout-sub" style={sans}
          >high-stakes actions proceed without re-auth</span
        >
      </div>
    </div>

    {/* The axis region — every absolutely-positioned child reads off this box. */}
    <div class="tc-axis">
      {/* expiresIn: the long outer bar. Its right edge (100%) is the wall. */}
      <div class="tc-bar" aria-hidden="true">
        <span class="tc-bar-label" style={mono}>expiresIn — 30 days</span>
      </div>

      {/* The hard wall at the bar's right edge. */}
      <div class="tc-wall" aria-hidden="true"></div>

      {/* Slide arrow off the wall — updateAge pushing expiresAt further right. */}
      <div class="tc-slide" aria-hidden="true">
        <span class="tc-slide-line"></span>
        <span class="tc-slide-head"></span>
      </div>

      {/* freshAge: the sliver hugging the origin, the elevation-allowed zone. */}
      <div
        class="tc-fresh"
        style={`width: ${FRESH_END}%;`}
        aria-hidden="true"
      ></div>

      {/* updateAge tick line. */}
      <div
        class="tc-tick"
        style={`left: ${UPDATE_AT}%;`}
        aria-hidden="true"
      ></div>

      {/* Origin marker: where the session was created. */}
      <div class="tc-origin" aria-hidden="true"></div>
    </div>

    {/* updateAge callout below the bar — kept on the opposite side of the axis
       from the freshAge callout so the two never share pixels at their close
       anchor points. Its connector points up to the tick. */}
    <div class="tc-under">
      <div class="tc-ucallout" style={`left: ${UPDATE_AT}%;`}>
        <span class="tc-callout-title" style={mono}>updateAge — 1 day</span>
        <span class="tc-callout-sub" style={sans}
          >an active request past this tick slides the wall right →</span
        >
      </div>
    </div>

    {/* Bottom axis labels — origin on the left, wall on the right. */}
    <div class="tc-bottom">
      <span class="tc-anchor tc-anchor--origin" style={sans}>
        sign-in <span class="tc-anchor-code" style={mono}>(createdAt)</span>
      </span>
      <span class="tc-anchor tc-anchor--wall" style={sans}>
        the wall <span class="tc-anchor-code" style={mono}>(expiresAt)</span>
      </span>
    </div>

    {/* Accessible summary for screen readers — the bars above are aria-hidden. */}
    <p class="tc-sr">
      One time axis from sign-in to a 30-day expiresIn wall. A 10-minute freshAge
      band sits at sign-in for high-stakes actions; a 1-day updateAge tick partway
      in slides the wall further right whenever an active request arrives.
    </p>
  </div>
</Figure>

<style>
  .tc {
    margin: 0;
    /* Left/right gutters keep the freshAge sliver off the card edge and leave
       room for the slide-arrow that overshoots the wall on the right. */
    padding: 4px 64px 0 8px;
  }

  /* Shared callout typography (used above and below the bar). */
  .tc-callout-title {
    margin: 0;
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
  }
  .tc-callout-sub {
    margin: 0;
    font-size: 10.5px;
    line-height: 1.3;
    color: var(--sl-color-gray-2);
  }

  /* ---- Top callout (freshAge) ----------------------------------------- */

  .tc-top {
    position: relative;
    height: 56px;
    margin: 0;
  }

  /* freshAge (violet) hangs above the bar from a connector that drops to the
     origin end of the axis. left is the % anchor; text flows right. */
  .tc-callout {
    position: absolute;
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    max-width: 280px;
    padding-bottom: 11px;
    margin: 0;
  }
  .tc-callout::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 1.5px;
    height: 11px;
    background: #7c3aed; /* violet-600 */
    margin: 0;
  }
  .tc-callout--fresh .tc-callout-title {
    color: #8b5cf6; /* violet-500 — reads on both themes */
  }

  /* ---- Axis region ----------------------------------------------------- */

  .tc-axis {
    position: relative;
    height: 56px;
    margin: 0;
  }

  /* expiresIn: the outer bar, full axis width. Blue is the session's whole life. */
  .tc-bar {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: color-mix(in srgb, #2563eb 16%, var(--sl-color-bg)); /* blue-600 tint */
    border: 1.5px solid color-mix(in srgb, #2563eb 55%, transparent);
    box-sizing: border-box;
    margin: 0;
  }
  .tc-bar-label {
    margin: 0;
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, #3b82f6 75%, var(--sl-color-white)); /* blue-500 */
  }

  /* The hard wall: a thick solid edge on the bar's right side. */
  .tc-wall {
    position: absolute;
    top: -5px;
    bottom: -5px;
    right: 0;
    width: 4px;
    border-radius: 2px;
    background: #2563eb; /* blue-600 */
    margin: 0;
  }

  /* Slide arrow: starts at the wall, points right — the wall moving on activity. */
  .tc-slide {
    position: absolute;
    top: 50%;
    right: -52px;
    width: 48px;
    height: 0;
    transform: translateY(-50%);
    margin: 0;
  }
  .tc-slide-line {
    position: absolute;
    left: 0;
    top: 50%;
    width: 100%;
    height: 2.5px;
    background: #16a34a; /* green-600 */
    transform: translateY(-50%);
    margin: 0;
  }
  .tc-slide-head {
    position: absolute;
    right: 0;
    top: 50%;
    width: 0;
    height: 0;
    transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 8px solid #16a34a; /* green-600 */
    margin: 0;
  }

  /* freshAge: the violet sliver at the origin. width set inline. */
  .tc-fresh {
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 0;
    border-radius: 6px 4px 4px 6px;
    background: #7c3aed; /* violet-600 */
    border: 1px solid color-mix(in srgb, #7c3aed 60%, #ffffff);
    box-shadow: 0 0 0 3px color-mix(in srgb, #7c3aed 22%, transparent);
    box-sizing: border-box;
    margin: 0;
  }

  /* updateAge tick: a vertical green line crossing the bar. left set inline. */
  .tc-tick {
    position: absolute;
    top: -5px;
    bottom: -5px;
    width: 2.5px;
    border-radius: 2px;
    background: #16a34a; /* green-600 */
    margin: 0;
  }

  /* Origin marker: a short upright at x=0 anchoring "sign-in". */
  .tc-origin {
    position: absolute;
    top: -8px;
    bottom: -8px;
    left: 0;
    width: 2.5px;
    border-radius: 2px;
    background: var(--sl-color-gray-2);
    margin: 0;
  }

  /* ---- Under-bar callout (updateAge) ---------------------------------- */

  .tc-under {
    position: relative;
    height: 50px;
    margin: 0;
  }

  /* updateAge (green) hangs below the bar from a connector that rises to the
     tick. left is the % anchor; text flows right. */
  .tc-ucallout {
    position: absolute;
    top: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    max-width: 320px;
    padding-top: 11px;
    margin: 0;
  }
  .tc-ucallout::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 1.5px;
    height: 11px;
    background: #16a34a; /* green-600 */
    margin: 0;
  }
  .tc-ucallout .tc-callout-title {
    color: #22c55e; /* green-500 */
  }

  /* ---- Bottom anchor labels -------------------------------------------- */

  .tc-bottom {
    position: relative;
    height: 30px;
    margin: 8px 0 0;
  }
  .tc-anchor {
    position: absolute;
    top: 0;
    font-size: 11.5px;
    font-weight: 700;
    color: var(--sl-color-text);
    margin: 0;
    white-space: nowrap;
  }
  .tc-anchor-code {
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }
  .tc-anchor--origin {
    left: 0;
  }
  .tc-anchor--wall {
    right: 0;
    text-align: right;
  }

  .tc-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---- Narrow viewports ------------------------------------------------ */
  /* The proportional read survives down to fairly small widths, but below this
     the callout text starts to crowd, so give the bar more headroom and shrink
     the right gutter / slide overshoot. */
  @media (max-width: 640px) {
    .tc {
      padding: 4px 40px 0 6px;
    }
    .tc-top {
      height: 70px;
    }
    .tc-under {
      height: 62px;
    }
    .tc-callout {
      max-width: 200px;
    }
    .tc-ucallout {
      max-width: 220px;
    }
    .tc-callout-sub {
      font-size: 10px;
    }
    .tc-slide {
      right: -32px;
      width: 28px;
    }
  }
</style>
