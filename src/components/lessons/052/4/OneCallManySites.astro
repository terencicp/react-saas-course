---
// OneCallManySites — Chapter 052 Lesson 4, "Reading the session everywhere
// with one call shape", the framing figure for the "Five surfaces" section.
//
// The single load-bearing idea of the lesson, made visual BEFORE the code makes
// it concrete: ONE call answers "who is this user?" and the call sites differ
// only in what they do with a `null` result. The hero is the center node —
// `auth.api.getSession({ headers })` — drawn bigger and bordered. The incoming
// request flows in from the left; four surfaces fan out to the right, each a
// small pill carrying its distinct `null` tail.
//
// The proxy is the deliberate exception, and the GEOMETRY says so: it peels off
// the request line BEFORE the call (dashed, set apart, muted), labelled
// "never this call". Every other surface sits AFTER the hero. So the picture
// itself encodes "the proxy doesn't make this call" — not just a colour.
//
// Plain HTML + CSS per the diagrams index (annotated-illustration / colour-coded
// strip shape; deliberately NOT a diagram engine and NOT ArrowDiagram, whose
// LeaderLines can't be relocated into the Figure lightbox). Astro-scoped <style>,
// no LeaderLines → survives the lightbox, so the wrapping <Figure> stays
// `expandable`. A `margin: 0` reset on every node defeats Starlight's injected
// prose margins; `not-content` on the root does the same.
//
// Theme-aware chrome via Starlight gray vars (flips light/dark). The hero is the
// one saturated accent (blue-600, white text — reads on both backgrounds) since
// that node IS the lesson. The four tails carry the lesson's reusable surface
// hues; the proxy stays muted/dashed to read as "set apart".

// The four surfaces that DO make the call, in the order the lesson walks them.
// `tail` is the one thing each does with a `null` result — the variable the
// whole section turns on.
const surfaces = [
	{
		site: 'layout / Server Component',
		tail: 'redirect',
	},
	{
		site: 'Server Action',
		tail: 'unauthorized Result',
	},
	{
		site: 'route handler',
		tail: '401',
	},
	{
		site: 'client (via a prop)',
		tail: 'gets the user, never asks',
	},
];
---

<div class="ocms not-content">
	{/* ───────── LEFT: the incoming request ───────── */}
	<div class="ocms-source">
		<div class="ocms-req">
			<span class="ocms-req-label">the incoming request</span>
			<span class="ocms-req-sub">carries the session cookie — or not</span>
		</div>

		{/* The proxy peels off BEFORE the call: dashed, set apart, muted. The
		    fork point is the whole point — this surface never reaches getSession. */}
		<div class="ocms-branch" aria-hidden="true">
			<span class="ocms-branch-arrow">⤷</span>
		</div>
		<div class="ocms-proxy">
			<span class="ocms-proxy-name">proxy</span>
			<span class="ocms-proxy-note">cookie-presence only · never this call</span>
		</div>
	</div>

	{/* connector: request → the call */}
	<div class="ocms-flow" aria-hidden="true">
		<span class="ocms-flow-arrow">⟶</span>
	</div>

	{/* ───────── CENTER: the one call (the hero) ───────── */}
	<div class="ocms-hero">
		<span class="ocms-hero-tag">one call</span>
		<code class="ocms-hero-code">auth.api.getSession({'{'} headers {'}'})</code>
		<span class="ocms-hero-shape">→ {'{'} user, session {'}'} | null</span>
	</div>

	{/* connector: the call → the surfaces */}
	<div class="ocms-flow" aria-hidden="true">
		<span class="ocms-flow-arrow">⟶</span>
	</div>

	{/* ───────── RIGHT: the four surfaces fan out ───────── */}
	<div class="ocms-fan">
		<span class="ocms-fan-tag">on <code>null</code>, each site differs</span>
		{
			surfaces.map((s) => (
				<div class="ocms-lane">
					<span class="ocms-lane-site">{s.site}</span>
					<span class="ocms-lane-tail">{s.tail}</span>
				</div>
			))
		}
	</div>
</div>

<style>
	.ocms {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── LEFT: request + the proxy fork ──────────────────── */
	.ocms-source {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		flex: 0 1 11rem;
		min-width: 0;
		margin: 0;
	}

	.ocms-req {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 9px 12px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}
	.ocms-req-label {
		font-size: 0.8rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.ocms-req-sub {
		font-size: 0.62rem;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* the fork arrow down-and-right into the proxy */
	.ocms-branch {
		display: flex;
		align-items: center;
		padding-left: 14px;
		margin: 0;
	}
	.ocms-branch-arrow {
		font-size: 1.1rem;
		line-height: 1;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	/* the proxy: deliberately set apart — dashed, muted, smaller */
	.ocms-proxy {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 1px;
		align-self: flex-start;
		margin: 1px 0 0 18px;
		padding: 5px 10px;
		border-radius: 8px;
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
		background: color-mix(
			in srgb,
			var(--sl-color-gray-6, #f1f5f9) 70%,
			transparent
		);
	}
	.ocms-proxy-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.74rem;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.ocms-proxy-note {
		font-size: 0.58rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── connectors ──────────────────────────────────────── */
	.ocms-flow {
		display: flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		margin: 0;
	}
	.ocms-flow-arrow {
		font-size: 1.5rem;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── CENTER: the hero call ───────────────────────────── */
	.ocms-hero {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		flex: 0 0 auto;
		padding: 13px 16px;
		border-radius: 11px;
		border: 1.5px solid #1d4ed8; /* blue-700 */
		background: #2563eb; /* blue-600 — reads on light and dark */
		box-shadow: 0 2px 8px rgba(37, 99, 235, 0.38);
		margin: 0;
	}
	.ocms-hero-tag {
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(255, 255, 255, 0.85);
		margin: 0;
	}
	.ocms-hero-code {
		box-sizing: border-box;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.2;
		color: #ffffff;
		background: transparent;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}
	.ocms-hero-shape {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		line-height: 1.2;
		color: rgba(255, 255, 255, 0.9);
		margin: 0;
		white-space: nowrap;
	}

	/* ── RIGHT: the fan of surfaces ──────────────────────── */
	.ocms-fan {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 6px;
		flex: 0 1 13rem;
		min-width: 0;
		margin: 0;
	}
	.ocms-fan-tag {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0 0 1px;
	}
	.ocms-fan-tag code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.62rem;
		background: transparent;
		padding: 0;
		color: var(--sl-color-gray-2, #475569);
	}

	.ocms-lane {
		box-sizing: border-box;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 6px 11px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}
	.ocms-lane-site {
		font-size: 0.74rem;
		font-weight: 600;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.ocms-lane-tail {
		font-size: 0.6rem;
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: 0.01em;
		color: #1d4ed8; /* blue-700 — ties each tail back to the one call */
		white-space: nowrap;
		margin: 0;
	}

	/* ── narrow viewports: stack the three columns, rotate arrows ── */
	@media (max-width: 720px) {
		.ocms {
			flex-direction: column;
			align-items: stretch;
			gap: 8px;
		}
		.ocms-source,
		.ocms-fan {
			flex: 0 0 auto;
			width: 100%;
		}
		.ocms-hero {
			align-self: center;
		}
		.ocms-flow-arrow {
			transform: rotate(90deg);
			display: block;
		}
		.ocms-hero-code {
			white-space: normal;
			text-align: center;
		}
	}
</style>
