---
// SharedFixtureCollision — Chapter 087 Lesson 2, "Factories over shared
// fixtures".
//
// Makes run-order coupling a PICTURE, not a sentence. One shared mutable
// fixture sits in the center; two `it` blocks both point at it. The admin test
// WRITES to the shared object (orange); the member test READS that poisoned
// value and fails (red). The takeaway is purely spatial: both tests aim at the
// SAME object, so one test's write leaks into the other's read.
//
//        it('lists a member')            const baseUser            it('grants admin access')
//        ┌────────────────┐  reads      ┌──────────────┐  mutates  ┌────────────────────┐
//        │ canSeeBilling  │ ◀── poison ─│ role:'member'│ ◀── .role │ baseUser.role='admin'│
//        │   → fails(red) │             │  (shared!)   │   (orange)│                    │
//        └────────────────┘             └──────────────┘           └────────────────────┘
//
// Built with <ArrowDiagram> (LeaderLine): boxes are mixed custom HTML — a label
// strip plus monospace code lines with one token tinted (the mutated `.role`).
// D2/Mermaid plain labels couldn't carry that. Arrows are positioned from
// document.body, so the wrapping <Figure> MUST be expandable={false}.
//
// Two arrows land on the center fixture from opposite sides so their arrowheads
// never stack: the orange WRITE arrives on the fixture's RIGHT, the red READ on
// its LEFT. Mid-tone hexes (#ea580c orange-600, #dc2626 red-600) used as-is in
// both themes. margin:0 resets defeat Starlight's injected prose margins.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const WRITE_ORANGE = '#ea580c'; // orange-600 — the admin test mutates .role
const READ_RED = '#dc2626'; // red-600    — the member test reads the poison and fails

// Pin label badges to a light card so they survive dark mode (the body-appended
// badge defaults derive from the page bg).
const labelBase =
	'background: #ffffff; border: 1px solid #cbd5e1; color: #334155; font-weight: 600;';
const labelOrange = `${labelBase} border-color: #fdba74; color: #c2410c;`;
const labelRed = `${labelBase} border-color: #fca5a5; color: #b91c1c;`;

const arrows = [
	// The admin test writes into the shared object — arrives on the fixture's right.
	{
		from: 'sfc-admin',
		to: 'sfc-fixture',
		label: "mutates .role → 'admin'",
		color: WRITE_ORANGE,
		startSocket: 'left',
		endSocket: 'right',
		startSocketGravity: [-80, 0],
		endSocketGravity: [80, 0],
		labelOffset: [0, -24],
		labelStyle: labelOrange,
	},
	// The member test reads the poisoned value — arrives on the fixture's left.
	{
		from: 'sfc-member',
		to: 'sfc-fixture',
		label: 'reads mutated value → fails',
		color: READ_RED,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [80, 0],
		endSocketGravity: [-80, 0],
		labelOffset: [0, -24],
		labelStyle: labelRed,
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="sfc not-content">
			<div class="sfc-row">
				{/* Left — the member test, the victim. It only reads. */}
				<div class="sfc-node sfc-node-fail" id="sfc-member">
					<span class="sfc-cap sfc-cap-red">it('lists a member')</span>
					<code class="sfc-line">canSeeBilling(baseUser)</code>
					<span class="sfc-verdict sfc-verdict-fail">expects false → FAILS</span>
				</div>

				{/* Center — the one shared mutable object both tests aim at. */}
				<div class="sfc-node sfc-node-hub" id="sfc-fixture">
					<span class="sfc-cap">const baseUser</span>
					<span class="sfc-shared">one shared object</span>
					<code class="sfc-line"
						>role: <span class="sfc-role">'member'</span></code
					>
				</div>

				{/* Right — the admin test, the culprit. It writes. */}
				<div class="sfc-node sfc-node-write" id="sfc-admin">
					<span class="sfc-cap sfc-cap-orange">it('grants admin access')</span>
					<code class="sfc-line"
						>baseUser.role = <span class="sfc-role-admin">'admin'</span></code
					>
					<span class="sfc-verdict sfc-verdict-pass">expects true → passes</span>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		Both tests point at the one shared object. The
		<strong style="color:#c2410c;">admin test writes</strong> to
		<code>.role</code>; the
		<strong style="color:#b91c1c;">member test reads</strong> that mutated
		value and fails — even though it never touched <code>baseUser</code>. The
		failure depends on which test ran first: that is run-order coupling.
	</Fragment>
</Figure>

<style>
	.sfc {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin: 0;
		padding: 30px 8px 18px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* Three boxes in a row, generously spaced so the labeled curves have room. */
	.sfc-row {
		display: flex;
		flex-wrap: nowrap;
		align-items: stretch;
		justify-content: center;
		gap: 132px;
		margin: 0;
	}

	.sfc-node {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 6px;
		min-width: 11rem;
		max-width: 15rem;
		padding: 12px 16px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
		margin: 0;
	}

	/* The fixture is the hub both arrows touch — heavier border reads it as the
	   shared center of the bug. */
	.sfc-node-hub {
		border-color: var(--sl-color-gray-4, #94a3b8);
		border-width: 2px;
	}

	/* Tint the two test boxes by their role in the bug. */
	.sfc-node-fail {
		border-color: #fca5a5;
		background: color-mix(in srgb, #dc2626 7%, var(--sl-color-bg, #fff));
	}
	.sfc-node-write {
		border-color: #fdba74;
		background: color-mix(in srgb, #ea580c 7%, var(--sl-color-bg, #fff));
	}

	/* Caption strip at the top of each box: the test name / fixture name. */
	.sfc-cap {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.sfc-cap-red {
		color: #b91c1c;
	}
	.sfc-cap-orange {
		color: #c2410c;
	}

	/* The "one shared object" note — the crux of the picture. */
	.sfc-shared {
		font-size: 0.66rem;
		font-style: italic;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Monospace payload line inside the boxes. */
	.sfc-line {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.76rem;
		line-height: 1.4;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #f1f5f9);
		border-radius: 6px;
		padding: 5px 8px;
		margin: 0;
	}

	/* The fixture starts as 'member' — neutral. */
	.sfc-role {
		color: var(--sl-color-gray-2, #475569);
		font-weight: 600;
	}

	/* The value the admin test writes in — orange, the source of the poison. */
	.sfc-role-admin {
		color: #c2410c;
		font-weight: 700;
		background: color-mix(in srgb, #ea580c 16%, transparent);
		border-radius: 3px;
		padding: 0 2px;
	}

	.sfc-verdict {
		font-size: 0.66rem;
		font-weight: 700;
		line-height: 1.2;
		margin: 0;
	}
	.sfc-verdict-fail {
		color: #b91c1c;
	}
	.sfc-verdict-pass {
		color: var(--sl-color-gray-3, #64748b);
	}

	/* Narrow viewports: stack the three boxes. Side sockets degrade to vertical
	   arcs between stacked boxes — readable, labels still float in the gaps. */
	@media (max-width: 800px) {
		.sfc-row {
			flex-direction: column;
			align-items: center;
			gap: 60px;
		}
		.sfc-node {
			width: min(18rem, 100%);
			max-width: none;
		}
	}
</style>
