---
// FactoryFixtureSeedTable — Chapter 087 Lesson 2, "Factories over shared
// fixtures".
//
// The three-noun decision matrix the back half of the lesson turns on:
// factory / fixture / seed get used interchangeably on real teams and they are
// not interchangeable. A side-by-side table is the fastest way to fix the
// distinction — three columns (the nouns), three rows (the axes a reader
// actually decides on): what it is, where it lives, when you reach for it.
//
//                  Factory            Fixture            Seed
//   What it is      fn → fresh         static data,       code that fills
//                   instance           used verbatim      a database
//   Lives where     src/test/          src/test/          scripts/seed.ts
//                   factories/         fixtures/
//   Reach for it    per-test domain    external payload   populated dev DB /
//   when            entity             you can't          integration baseline
//                                      paraphrase
//
// Built as a plain HTML <table> inside <Figure> so it reads as one glance — no
// engine needed, no leader lines, survives the expand lightbox. Each column is
// anchored to one accent (green = factory, the lesson's hero; blue = fixture;
// violet = seed) carried only on the header cells, so the body stays calm and
// scannable. Accents are mid-tone hexes via color-mix so they hold in both
// themes. not-content opts the table out of Starlight's prose table styling so
// our layout wins. `code`/`path` spans set monospace inline.

import Figure from '../../../figures/Figure.astro';

const FACTORY = '#16a34a'; // green-600  — the per-test factory (this lesson's hero)
const FIXTURE = '#2563eb'; // blue-600   — the static captured fixture
const SEED = '#7c3aed'; // violet-600 — the database seeder
---

<Figure>
	<div class="ffs not-content">
		<table class="ffs-table">
			<thead>
				<tr>
					<th class="ffs-axis" scope="col"></th>
					<th class="ffs-head ffs-head-factory" scope="col">
						<span class="ffs-noun">Factory</span>
						<span class="ffs-tag">a function</span>
					</th>
					<th class="ffs-head ffs-head-fixture" scope="col">
						<span class="ffs-noun">Fixture</span>
						<span class="ffs-tag">static data</span>
					</th>
					<th class="ffs-head ffs-head-seed" scope="col">
						<span class="ffs-noun">Seed</span>
						<span class="ffs-tag">a script</span>
					</th>
				</tr>
			</thead>
			<tbody>
				<tr>
					<th class="ffs-axis" scope="row">What it is</th>
					<td>
						Returns a <strong>fresh in-memory instance</strong> with overrides.
					</td>
					<td>
						<strong>Static data</strong>, usually a JSON file, used verbatim.
					</td>
					<td>
						Code that <strong>populates a database</strong> with realistic volume
						and distribution.
					</td>
				</tr>
				<tr>
					<th class="ffs-axis" scope="row">Lives where</th>
					<td><span class="ffs-path">src/test/factories/</span></td>
					<td><span class="ffs-path">src/test/fixtures/</span></td>
					<td><span class="ffs-path">scripts/seed.ts</span></td>
				</tr>
				<tr>
					<th class="ffs-axis" scope="row">Reach for it when</th>
					<td>You need a <strong>per-test domain entity</strong>.</td>
					<td>
						You need an <strong>external payload</strong> whose exact shape you
						don't author and can't safely paraphrase.
					</td>
					<td>
						You need a <strong>populated dev database</strong> or an
						integration-test baseline.
					</td>
				</tr>
			</tbody>
		</table>
	</div>
</Figure>

<style define:vars={{ factory: FACTORY, fixture: FIXTURE, seed: SEED }}>
	.ffs {
		margin: 0;
		overflow-x: auto;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.ffs-table {
		width: 100%;
		min-width: 36rem;
		border-collapse: separate;
		border-spacing: 0;
		margin: 0;
		font-size: 0.86rem;
		line-height: 1.45;
	}

	.ffs-table th,
	.ffs-table td {
		padding: 11px 14px;
		text-align: left;
		vertical-align: top;
		border: none;
		background: transparent;
	}

	/* Column header cells — each noun anchored to its accent. */
	.ffs-head {
		border-bottom: 2px solid var(--sl-color-gray-5, #cbd5e1);
	}
	.ffs-noun {
		display: block;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.2;
	}
	.ffs-tag {
		display: block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		opacity: 0.7;
		margin-top: 2px;
	}
	.ffs-head-factory {
		color: color-mix(in srgb, var(--factory) 78%, var(--sl-color-white, #0f172a));
		border-bottom-color: var(--factory);
		background: color-mix(in srgb, var(--factory) 8%, transparent);
	}
	.ffs-head-fixture {
		color: color-mix(in srgb, var(--fixture) 78%, var(--sl-color-white, #0f172a));
		border-bottom-color: var(--fixture);
		background: color-mix(in srgb, var(--fixture) 8%, transparent);
	}
	.ffs-head-seed {
		color: color-mix(in srgb, var(--seed) 78%, var(--sl-color-white, #0f172a));
		border-bottom-color: var(--seed);
		background: color-mix(in srgb, var(--seed) 8%, transparent);
	}

	/* Row-axis labels down the left edge — the question each row answers. */
	.ffs-axis {
		width: 9.5rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--sl-color-gray-2, #475569);
	}

	/* Zebra the body rows so the three axes stay visually separable. */
	.ffs-table tbody tr td,
	.ffs-table tbody tr th {
		border-top: 1px solid var(--sl-color-gray-6, #e2e8f0);
	}
	.ffs-table tbody tr:nth-child(even) td {
		background: color-mix(in srgb, var(--sl-color-gray-6, #f1f5f9) 55%, transparent);
	}

	.ffs-table strong {
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}

	.ffs-path {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.8rem;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #f1f5f9);
		border-radius: 5px;
		padding: 2px 6px;
		white-space: nowrap;
	}

	/* Narrow viewports: shrink the axis column and let the table scroll if the
	   three content columns still can't fit. */
	@media (max-width: 640px) {
		.ffs-axis {
			width: 6.5rem;
		}
		.ffs-table {
			font-size: 0.8rem;
		}
	}
</style>
