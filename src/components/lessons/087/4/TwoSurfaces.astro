---
// TwoSurfaces — Chapter 087 Lesson 4 ("Type-level tests with expectTypeOf"),
// the lesson's anchor figure.
//
// Pedagogical goal: install a spatial, durable picture of the one idea before
// any matcher API appears — there are TWO checkers over the same colocated
// suite. Runtime tests assert values (run by the Vitest runner); type tests
// assert types (checked by tsc). Neither checker sees the other's surface.
//
// Shape: a short, horizontal two-column split. Each column is a labeled panel
// holding the SAME three-row vertical flow — input chip -> engine -> result —
// so the parallel structure reads at a glance and the only differences (the
// chip, the engine, "values" vs "types") carry the lesson. A footer bar
// spanning both columns names what's shared: same file tree, same describe/it
// reflex, different engine.
//
// Accessibility: the two engines are tinted differently (left neutral slate,
// right blue) to reinforce "two engines", but the column HEADINGS carry the
// meaning — the diagram is readable in greyscale. Code-ish chips are monospace;
// the engine/result rows and labels are sans.
//
// Plain HTML + flexbox inside <Figure> per the diagram index's annotated-split
// guidance. Inline style strings on every primitive so a reader can copy the
// source. `margin: 0` on every element (via `reset`) defeats Starlight's
// injected prose margins; `not-content` on the root defeats article resets.
// Height-capped well under 800px, no JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

// Per-column accent. Left runtime surface = neutral slate; right type surface =
// blue. Both read on light and dark page backgrounds. Headings carry meaning so
// the color is reinforcement, not the only signal.
const RUNTIME = "#475569"; // slate-600
const TYPE = "#2563eb"; // blue-600

type Surface = {
	/** Column heading. */
	heading: string;
	/** Accent color for the heading + engine row. */
	accent: string;
	/** The monospace input chip (top of the flow). */
	chip: string;
	/** The engine that runs it (middle row). */
	engine: string;
	/** Whether the engine name is code-ish (monospace). */
	engineMono: boolean;
	/** The result row text; the bold word is split out for emphasis. */
	resultLead: string;
	resultBold: string;
};

const surfaces: Surface[] = [
	{
		heading: "Runtime surface",
		accent: RUNTIME,
		chip: "expect(value)",
		engine: "Vitest runner",
		engineMono: false,
		resultLead: "pass / fail on ",
		resultBold: "values",
	},
	{
		heading: "Type surface",
		accent: TYPE,
		chip: "expectTypeOf<T>()",
		engine: "tsc --noEmit",
		engineMono: true,
		resultLead: "pass / fail on ",
		resultBold: "types",
	},
];

// ---- styles --------------------------------------------------------------

const root = [
	reset,
	sans,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 14px",
	"width: 100%",
	"max-width: 760px",
	"margin-left: auto",
	"margin-right: auto",
].join("; ");

// The two panels sit side by side; wrap on narrow viewports so neither column
// is clipped.
const columns = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-wrap: wrap",
	"gap: 16px",
	"align-items: stretch",
].join("; ");

const panel = (accent: string) =>
	[
		reset,
		"box-sizing: border-box",
		"flex: 1 1 240px",
		"min-width: 0",
		"display: flex",
		"flex-direction: column",
		"align-items: center",
		"gap: 8px",
		"padding: 16px 14px 18px",
		"border: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))",
		"border-top: 3px solid " + accent,
		"border-radius: 10px",
		"background: var(--sl-color-bg, transparent)",
	].join("; ");

const heading = (accent: string) =>
	[
		reset,
		sans,
		"box-sizing: border-box",
		"margin-bottom: 4px",
		"font-size: 13px",
		"font-weight: 800",
		"letter-spacing: 0.04em",
		"text-transform: uppercase",
		"color: " + accent,
	].join("; ");

// Top row: the monospace input chip.
const chip = (accent: string) =>
	[
		reset,
		mono,
		"box-sizing: border-box",
		"display: inline-block",
		"padding: 6px 12px",
		"border-radius: 7px",
		"background: " + accent,
		"color: #ffffff",
		"font-size: 13px",
		"font-weight: 700",
		"line-height: 1.2",
		"white-space: nowrap",
		"max-width: 100%",
	].join("; ");

const chevron = [
	reset,
	"box-sizing: border-box",
	"font-size: 14px",
	"line-height: 1",
	"color: var(--sl-color-gray-4, #9ca3af)",
].join("; ");

// Middle row: the engine. Hairline-bordered card so it reads as a distinct
// stage, not just text.
const engineCard = (accent: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: inline-block",
		"padding: 6px 14px",
		"border: 1px solid " + accent,
		"border-radius: 7px",
		"background: var(--sl-color-bg-sidebar, transparent)",
		"max-width: 100%",
	].join("; ");

const engineText = (isMono: boolean, accent: string) =>
	[
		reset,
		isMono ? mono : sans,
		"font-size: 13px",
		"font-weight: 700",
		"line-height: 1.2",
		"white-space: nowrap",
		"color: " + accent,
	].join("; ");

// Bottom row: the result.
const result = [
	reset,
	sans,
	"box-sizing: border-box",
	"font-size: 13px",
	"line-height: 1.3",
	"text-align: center",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

const resultBold = [
	reset,
	sans,
	"font-weight: 800",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

// Footer bar spanning both columns: what's shared across the two engines.
const footer = [
	reset,
	sans,
	"box-sizing: border-box",
	"display: flex",
	"flex-wrap: wrap",
	"justify-content: center",
	"align-items: center",
	"gap: 6px 10px",
	"padding: 9px 14px",
	"border: 1px dashed var(--sl-color-gray-4, rgba(125,125,125,0.45))",
	"border-radius: 8px",
	"font-size: 12px",
	"line-height: 1.3",
	"text-align: center",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

const footerStrong = [
	reset,
	sans,
	"font-weight: 700",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

const footerDot = [reset, "color: var(--sl-color-gray-4, #9ca3af)"].join("; ");
---

<div class="not-content" style={root}>
	<div style={columns}>
		{
			surfaces.map((s) => (
				<div style={panel(s.accent)}>
					<div style={heading(s.accent)}>{s.heading}</div>
					<span style={chip(s.accent)}>{s.chip}</span>
					<div style={chevron}>&darr;</div>
					<div style={engineCard(s.accent)}>
						<span style={engineText(s.engineMono, s.accent)}>
							{s.engine}
						</span>
					</div>
					<div style={chevron}>&darr;</div>
					<div style={result}>
						{s.resultLead}
						<span style={resultBold}>{s.resultBold}</span>
					</div>
				</div>
			))
		}
	</div>

	<div style={footer}>
		<span style={footerStrong}>same file tree</span>
		<span style={footerDot}>&middot;</span>
		<span style={footerStrong}>same describe / it reflex</span>
		<span style={footerDot}>&middot;</span>
		<span>different engine</span>
	</div>
</div>
