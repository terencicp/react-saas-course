---
// The seam-wiring illustration (Chapter 087 L3) — the lesson's thesis image.
// Goal: cement that the UNIT is unchanged and only the WIRING behind the seam
// differs. One call site (computeDueAt) calls the seam (clock.now()), and the
// seam fans out to two implementations: production reads the real wall clock,
// the test reads a frozen instant. Reused mentally in the IDs and randomness
// sections, so it has to read at a glance.
//
// Three columns left-to-right:
//   1. the unit       — neutral, the caller, never changes
//   2. the seam        — accent border, the pivot (src/lib/clock.ts)
//   3. two wirings     — Production (green tint) above, Test (blue tint) below
//
// Connectors are arrow glyphs, not drawn lines: the seam column ends in a
// `→` that points up to production and down to the test (a small CSS branch
// with two diagonal-ish arrow rows). Pure CSS arrow glyphs are robust and
// devtools-inspectable; true SVG/leader lines are fragile here per the
// diagrams guide.
//
// Color signal: green = production / real, blue = test / frozen — saturated
// 600-range tints readable on both themes. The seam's accent border uses the
// Starlight accent so the pivot pops.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins.
// Height-capped well under 800px, width well under 800px. No JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

const PROD = "#16a34a"; // green-600 — real wall clock
const TEST = "#2563eb"; // blue-600 — frozen instant

const root = [
	reset,
	"display: flex",
	"flex-wrap: wrap",
	"align-items: center",
	"justify-content: center",
	"column-gap: 8px",
	"row-gap: 16px",
	"width: 100%",
	"max-width: 760px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// A generic box: title (monospace) + muted subtitle. Boxes never shrink below
// their content (`flex: 0 0 auto`) so the row keeps its three-column read.
const box = (border: string, bg: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"gap: 4px",
		"padding: 12px 14px",
		"border-radius: 10px",
		"border: 1px solid " + border,
		"background: " + bg,
		"flex: 0 0 auto",
	].join("; ");

const unitBox = box(
	"var(--sl-color-gray-5, rgba(125,125,125,0.3))",
	"var(--sl-color-gray-7, rgba(125,125,125,0.06))",
);

// The seam is the pivot — thicker accent border, accent-tinted background.
const seamBox = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 4px",
	"padding: 12px 16px",
	"border-radius: 10px",
	"border: 2px solid var(--sl-color-accent, #7c3aed)",
	"background: var(--sl-color-accent-low, rgba(124,58,237,0.12))",
	"flex: 0 0 auto",
].join("; ");

// Wiring boxes cap their width so the long frozen-instant literal wraps inside
// the box instead of stretching the whole row past the figure.
const wireBox = (color: string) =>
	[
		box(color, "transparent"),
		"max-width: 300px",
	].join("; ");

const title = [
	reset,
	mono,
	"font-size: 14px",
	"font-weight: 700",
	"line-height: 1.25",
	"white-space: nowrap",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

// The Test box's literal is long — let it wrap inside the capped box instead of
// forcing the row wider.
const titleWrap = [
	reset,
	mono,
	"font-size: 13px",
	"font-weight: 700",
	"line-height: 1.3",
	"overflow-wrap: anywhere",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

const subtitle = [
	reset,
	sans,
	"font-size: 11.5px",
	"line-height: 1.3",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

const subtitleMono = [
	reset,
	mono,
	"font-size: 11px",
	"line-height: 1.3",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

// A small label pill that sits above a wiring box (PRODUCTION / TEST).
const tagPill = (color: string) =>
	[
		reset,
		sans,
		"display: inline-block",
		"width: fit-content",
		"padding: 2px 8px",
		"border-radius: 999px",
		"background: " + color,
		"color: #ffffff",
		"font-size: 10px",
		"font-weight: 800",
		"letter-spacing: 0.07em",
		"text-transform: uppercase",
		"line-height: 1.4",
	].join("; ");

// Plain arrow glyph between the unit and the seam.
const arrow = [
	reset,
	sans,
	"font-size: 22px",
	"line-height: 1",
	"color: var(--sl-color-gray-3, #9ca3af)",
	"flex: 0 0 auto",
].join("; ");

// The branch column: a single arrow that splits up to production and down to
// the test. Two rows, each an arrow glyph aligned to its wiring box.
const branch = [
	reset,
	"display: flex",
	"flex-direction: column",
	"justify-content: center",
	"gap: 34px",
	"flex: 0 0 auto",
].join("; ");

const branchArrow = (color: string) =>
	[
		reset,
		sans,
		"font-size: 18px",
		"font-weight: 700",
		"line-height: 1",
		"color: " + color,
	].join("; ");

// The right-hand stack of the two wiring boxes.
const wireStack = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 12px",
	"flex: 0 0 auto",
].join("; ");
---

<div class="not-content" style={root}>
	<div style={unitBox}>
		<span style={title}>computeDueAt()</span>
		<span style={subtitle}>calls <code style="background: transparent; padding: 0; font-size: 11px;">clock.now()</code></span>
	</div>

	<span style={arrow} aria-hidden="true">→</span>

	<div style={seamBox}>
		<span style={title}>clock.now()</span>
		<span style={subtitleMono}>src/lib/clock.ts</span>
	</div>

	<div style={branch} aria-hidden="true">
		<span style={branchArrow(PROD)}>↗</span>
		<span style={branchArrow(TEST)}>↘</span>
	</div>

	<div style={wireStack}>
		<div style={wireBox(PROD)}>
			<span style={tagPill(PROD)}>Production</span>
			<span style={title}>Temporal.Now.instant()</span>
			<span style={subtitle}>the real wall clock</span>
		</div>

		<div style={wireBox(TEST)}>
			<span style={tagPill(TEST)}>Test</span>
			<span style={titleWrap}>{"Temporal.Instant.from('2026-01-15T12:00:00Z')"}</span>
			<span style={subtitle}>a frozen instant</span>
		</div>
	</div>
</div>
