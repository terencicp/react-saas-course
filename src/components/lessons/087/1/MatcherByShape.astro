---
// MatcherByShape — Chapter 087 Lesson 1 ("Pure-function tests, the daily
// shape"), the lesson's single figure.
//
// Pedagogical goal: install a reflex, not a reference. This is NOT a system
// diagram — it's a compact lookup card the student internalises: "shape of the
// value under test → matcher to reach for". The whole skill of the section is
// reading down the left column to find the row whose shape matches the value,
// then reaching for the matcher named on the right. So the layout is a strict
// two-column read: value SHAPE on the left, MATCHER (in a monospace code pill)
// on the right, with a one-phrase reason under the pill.
//
// The matcher pill carries the signal — it's the thing the eye should land on
// and the thing the student copies — so it gets a saturated indigo fill with
// white monospace text that reads on both light and dark page backgrounds. The
// left "shape" column stays muted so the pill pops. Seven rows, in the order
// the prose walks them (primitive first, throw last — the throw row is dimmed
// because it gets its own lesson later in the chapter, signalled by a "later"
// tag).
//
// Plain HTML + grid inside <Figure> per the diagram index's lookup-card
// guidance. Inline style strings on every primitive so a reader can copy the
// source and see exactly what styled it. `margin: 0` on every element (via
// `reset`) defeats Starlight's injected prose margins; `not-content` on the
// root defeats the article-level resets. Height-capped well under 800px, no JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

// The matcher pill's signal colour — saturated indigo, white text, reads on
// both themes. The "deferred" throw row uses a muted slate instead so it reads
// as "not yet".
const MATCHER = "#4f46e5"; // indigo-600
const DEFERRED = "#64748b"; // slate-500

type Row = {
	/** The shape of the value you're asserting on (left column). */
	shape: string;
	/** Optional monospace type hint shown under the shape label. */
	hint?: string;
	/** The matcher to reach for (the code pill, right column). */
	matcher: string;
	/** One-phrase reason, shown under the matcher pill. */
	reason: string;
	/** A second matcher for the either/or rows (e.g. toContainEqual / toContain). */
	altMatcher?: string;
	/** Reason for the alternative matcher. */
	altReason?: string;
	/** Dimmed + tagged "later in the chapter" — the throw row. */
	deferred?: boolean;
};

// In the order the prose walks them. Primitive → whole object → partial object
// → array membership → float → instance → throws.
const rows: Row[] = [
	{
		shape: "Primitive",
		hint: "string · number · boolean · bigint",
		matcher: "toBe",
		reason: "SameValue identity",
	},
	{
		shape: "Object or array, comparing the whole thing",
		matcher: "toEqual",
		reason: "deep, field by field",
	},
	{
		shape: "Object, asserting only some fields",
		matcher: "toMatchObject",
		reason: "partial match",
	},
	{
		shape: "Array contains an element",
		matcher: "toContainEqual",
		reason: "deep",
		altMatcher: "toContain",
		altReason: "primitive or same reference",
	},
	{
		shape: "Float with rounding error",
		matcher: "toBeCloseTo",
		reason: "within a tolerance",
	},
	{
		shape: "Instance of a class",
		matcher: "toBeInstanceOf",
		reason: "constructor check",
	},
	{
		shape: "Function throws",
		matcher: "toThrow",
		reason: "message or class",
		deferred: true,
	},
];

// ---- styles --------------------------------------------------------------

const root = [
	reset,
	sans,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 8px",
	"width: 100%",
	"max-width: 760px",
	"margin-left: auto",
	"margin-right: auto",
].join("; ");

// Column header strip — labels the two-column read once at the top.
const COL = "minmax(0, 1fr) minmax(220px, 300px)";
const headerRow = [
	reset,
	"box-sizing: border-box",
	"display: grid",
	"grid-template-columns: " + COL,
	"gap: 10px",
	"padding: 0 12px 2px",
].join("; ");

const headerCell = (align: string) =>
	[
		reset,
		sans,
		"box-sizing: border-box",
		"font-size: 11px",
		"font-weight: 700",
		"letter-spacing: 0.07em",
		"text-transform: uppercase",
		"color: var(--sl-color-gray-3, #9ca3af)",
		"text-align: " + align,
	].join("; ");

// One lookup row: a hairline-framed card holding the shape (left) and the
// matcher pill + reason (right). The arrow between the two columns reinforces
// the "shape → matcher" read.
const rowCard = (deferred: boolean) =>
	[
		reset,
		"box-sizing: border-box",
		"display: grid",
		"grid-template-columns: " + COL,
		"align-items: center",
		"gap: 10px",
		"padding: 10px 12px",
		"border: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))",
		"border-radius: 9px",
		"background: var(--sl-color-bg, transparent)",
		deferred ? "opacity: 0.72" : "",
	].join("; ");

const shapeCell = [
	reset,
	"box-sizing: border-box",
	"min-width: 0",
	"display: flex",
	"flex-direction: column",
	"gap: 3px",
].join("; ");

const shapeLabel = [
	reset,
	sans,
	"font-size: 14px",
	"font-weight: 600",
	"line-height: 1.3",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

const shapeHint = [
	reset,
	mono,
	"font-size: 11.5px",
	"line-height: 1.3",
	"color: var(--sl-color-gray-3, #9ca3af)",
].join("; ");

// The right column: an arrow leader + the matcher pill stack.
const matcherCell = [
	reset,
	"box-sizing: border-box",
	"min-width: 0",
	"display: flex",
	"align-items: center",
	"gap: 8px",
].join("; ");

const arrow = [
	reset,
	mono,
	"flex: 0 0 auto",
	"font-size: 15px",
	"color: var(--sl-color-gray-4, #9ca3af)",
].join("; ");

const pillStack = [
	reset,
	"box-sizing: border-box",
	"min-width: 0",
	"display: flex",
	"flex-direction: column",
	"gap: 4px",
].join("; ");

// A matcher pill row: the code pill itself, then its one-phrase reason inline.
const pillRow = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-wrap: wrap",
	"align-items: baseline",
	"gap: 7px",
].join("; ");

const pill = (deferred: boolean) =>
	[
		reset,
		mono,
		"box-sizing: border-box",
		"display: inline-block",
		"padding: 3px 9px",
		"border-radius: 6px",
		"background: " + (deferred ? DEFERRED : MATCHER),
		"color: #ffffff",
		"font-size: 12.5px",
		"font-weight: 700",
		"line-height: 1.2",
		"white-space: nowrap",
	].join("; ");

const reasonText = [
	reset,
	sans,
	"font-size: 11.5px",
	"line-height: 1.3",
	"color: var(--sl-color-gray-2, #6b7280)",
].join("; ");

// The "later in the chapter" tag on the deferred throw row.
const laterTag = [
	reset,
	sans,
	"box-sizing: border-box",
	"display: inline-block",
	"padding: 1px 7px",
	"border: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.4))",
	"border-radius: 999px",
	"font-size: 10px",
	"font-weight: 700",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3, #9ca3af)",
].join("; ");
---

<div class="not-content" style={root}>
	<div style={headerRow}>
		<div style={headerCell("left")}>Shape of the value</div>
		<div style={headerCell("left")}>Matcher to reach for</div>
	</div>

	{
		rows.map((r) => (
			<div style={rowCard(!!r.deferred)}>
				<div style={shapeCell}>
					<span style={shapeLabel}>{r.shape}</span>
					{r.hint && <span style={shapeHint}>{r.hint}</span>}
				</div>
				<div style={matcherCell}>
					<span style={arrow}>&rarr;</span>
					<div style={pillStack}>
						<div style={pillRow}>
							<span style={pill(!!r.deferred)}>{r.matcher}</span>
							<span style={reasonText}>{r.reason}</span>
							{r.deferred && <span style={laterTag}>later</span>}
						</div>
						{r.altMatcher && (
							<div style={pillRow}>
								<span style={pill(false)}>{r.altMatcher}</span>
								<span style={reasonText}>{r.altReason}</span>
							</div>
						)}
					</div>
				</div>
			</div>
		))
	}
</div>
