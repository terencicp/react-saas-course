---
// microtask-macrotask-trace — Ch087 L5 "Async tests without the forgotten-await
// trap", the figure for the "When fake timers meet promises" section.
//
// The conceptual heart of the lesson: a setTimeout callback (a MACROTASK) firing
// and the promise continuation it schedules (a MICROTASK) are one tick apart. The
// synchronous timer API (advanceTimersByTime) stops after the macrotask; the
// *Async variant keeps going until the microtask queue has drained too. That gap
// is why the sync version's assertion runs a tick too early and the test fails.
//
//   Step 1 — the setTimeout callback fires (macrotask leaves its lane and runs),
//     resolving sleep's promise. Resolving only QUEUES the continuation as a
//     microtask; it does not run it. doWork has NOT run.  chip: no.
//   Step 2 — advanceTimersByTime is synchronous, so the assertion runs NOW, with
//     the continuation still parked in the microtask lane. The assertion sees the
//     world one tick early. This is the failure.  chip: no (failed).
//   Step 3 — swap in `await advanceTimersByTimeAsync`. The await yields to the
//     event loop, draining the microtask lane: the continuation runs and doWork
//     executes BEFORE the assertion.  chip: yes.
//   Step 4 — recap: a 5-stage horizontal flow naming the whole chain, with the
//     sync API covering only the first stage and the *Async variant covering all.
//
// Colour convention (lesson spec): BLUE pill = timer callback (macrotask),
// VIOLET pill = promise continuation (microtask), GREEN chip = doWork ran (yes),
// neutral grey chip = not yet (no), RED tint on the chip = the failed assertion.
// Built on Starlight CSS variables + color-mix so it adapts to dark mode. The
// DiagramSequence supplies the outer card + per-step captions — NOT wrapped in
// <Figure>.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';
---

<DiagramSequence>
	{/* ===== Step 1 — the timer callback fires, queues the continuation ===== */}
	<DiagramStep caption="advanceTimersByTime(5000) fires the setTimeout callback. That callback resolves sleep's promise — but resolving a promise only queues its continuation as a microtask; it doesn't run it. doWork has not run.">
		<div class="mmt-stage">
			<div class="mmt-cur">
				<span class="mmt-cur-label">Now running</span>
				<code class="mmt-cur-code">setTimeout callback &rarr; resolves sleep</code>
			</div>
			<div class="mmt-lanes">
				<div class="mmt-lane mmt-lane--macro">
					<span class="mmt-lane-name">Macrotask queue</span>
					<div class="mmt-lane-track">
						<span class="mmt-empty">empty &mdash; the timer callback just ran</span>
					</div>
				</div>
				<div class="mmt-lane mmt-lane--micro mmt-lane--active">
					<span class="mmt-lane-name">Microtask queue</span>
					<div class="mmt-lane-track">
						<span class="mmt-pill mmt-pill--micro">withRetry continuation &rarr; doWork</span>
					</div>
				</div>
			</div>
			<div class="mmt-chip mmt-chip--no">
				<span class="mmt-chip-q"><code>doWork</code> ran?</span>
				<span class="mmt-chip-v">no</span>
			</div>
		</div>
	</DiagramStep>

	{/* ===== Step 2 — the assertion runs a tick too early: the failure ===== */}
	<DiagramStep caption="advanceTimersByTime is synchronous, so the test's next line — the assertion — runs now, before the microtask queue is drained. It sees the world one tick too early. This is the failure.">
		<div class="mmt-stage">
			<div class="mmt-cur">
				<span class="mmt-cur-label">Now running</span>
				<code class="mmt-cur-code">expect(doWork).toHaveBeenCalled()</code>
			</div>
			<div class="mmt-lanes">
				<div class="mmt-lane mmt-lane--macro">
					<span class="mmt-lane-name">Macrotask queue</span>
					<div class="mmt-lane-track">
						<span class="mmt-empty">empty</span>
					</div>
				</div>
				<div class="mmt-lane mmt-lane--micro mmt-lane--stuck">
					<span class="mmt-lane-name">Microtask queue</span>
					<div class="mmt-lane-track">
						<span class="mmt-pill mmt-pill--micro mmt-pill--stuck">withRetry continuation &rarr; doWork</span>
						<span class="mmt-stuck-note">still parked &mdash; never drained</span>
					</div>
				</div>
			</div>
			<div class="mmt-chip mmt-chip--fail">
				<span class="mmt-chip-q"><code>doWork</code> ran?</span>
				<span class="mmt-chip-v">no &mdash; assertion fails</span>
			</div>
		</div>
	</DiagramStep>

	{/* ===== Step 3 — the *Async variant drains the microtask first ===== */}
	<DiagramStep caption="Swap in await advanceTimersByTimeAsync. The await yields to the event loop between firing the timer and returning, which drains the microtask queue. The continuation runs, and doWork executes — before the assertion.">
		<div class="mmt-stage">
			<div class="mmt-cur">
				<span class="mmt-cur-label">Now running</span>
				<code class="mmt-cur-code">await advanceTimersByTimeAsync(5000)</code>
			</div>
			<div class="mmt-lanes">
				<div class="mmt-lane mmt-lane--macro">
					<span class="mmt-lane-name">Macrotask queue</span>
					<div class="mmt-lane-track">
						<span class="mmt-empty">empty</span>
					</div>
				</div>
				<div class="mmt-lane mmt-lane--micro mmt-lane--active">
					<span class="mmt-lane-name">Microtask queue</span>
					<div class="mmt-lane-track">
						<span class="mmt-empty mmt-empty--drained">drained &mdash; continuation ran <code>doWork()</code></span>
					</div>
				</div>
			</div>
			<div class="mmt-chip mmt-chip--yes">
				<span class="mmt-chip-q"><code>doWork</code> ran?</span>
				<span class="mmt-chip-v">yes</span>
			</div>
		</div>
	</DiagramStep>

	{/* ===== Step 4 — recap: the whole chain, sync vs *Async coverage ===== */}
	<DiagramStep caption="The whole chain: timer fires (macrotask) → promise resolves → continuation queued (microtask) → microtasks drain → doWork runs → assertion sees the result. The sync timer APIs do only the macrotask step. The *Async variants do the macrotask step and drain the microtasks.">
		<div class="mmt-stage">
			<div class="mmt-flow">
				<span class="mmt-flow-box mmt-flow-box--macro">
					timer fires
					<span class="mmt-flow-tag">macrotask</span>
				</span>
				<span class="mmt-flow-arrow">&rarr;</span>
				<span class="mmt-flow-box mmt-flow-box--micro">
					promise resolves
					<span class="mmt-flow-tag">microtask</span>
				</span>
				<span class="mmt-flow-arrow">&rarr;</span>
				<span class="mmt-flow-box mmt-flow-box--micro">continuation queued</span>
				<span class="mmt-flow-arrow">&rarr;</span>
				<span class="mmt-flow-box mmt-flow-box--micro">microtasks drain</span>
				<span class="mmt-flow-arrow">&rarr;</span>
				<span class="mmt-flow-box mmt-flow-box--done">doWork runs</span>
			</div>
			<div class="mmt-coverage">
				<div class="mmt-cover-row">
					<code class="mmt-cover-api mmt-cover-api--sync">advanceTimersByTime</code>
					<span class="mmt-cover-span mmt-cover-span--sync">stops after the macrotask</span>
				</div>
				<div class="mmt-cover-row">
					<code class="mmt-cover-api mmt-cover-api--async">advanceTimersByTimeAsync</code>
					<span class="mmt-cover-span mmt-cover-span--async">macrotask + drains the microtasks</span>
				</div>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>

<style define:vars={{ blue: '#2563eb', violet: '#7c3aed', green: '#16a34a' }}>
	.mmt-stage {
		box-sizing: border-box;
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		justify-content: center;
		gap: 14px;
		min-height: 230px;
		padding: 6px 4px;
	}
	.mmt-stage *,
	.mmt-stage *::before,
	.mmt-stage *::after {
		box-sizing: border-box;
	}

	/* ---- "Now running" current-line pointer ---- */
	.mmt-cur {
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
		justify-content: center;
	}
	.mmt-cur-label {
		flex: 0 0 auto;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--sl-color-gray-2);
	}
	.mmt-cur-code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12.5px;
		font-weight: 600;
		line-height: 1.4;
		padding: 4px 10px;
		border-radius: 7px;
		border: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-text);
		white-space: nowrap;
		max-width: 100%;
		overflow-x: auto;
	}

	/* ---- the two stacked queue lanes ---- */
	.mmt-lanes {
		display: flex;
		flex-direction: column;
		gap: 8px;
		width: 100%;
		max-width: 460px;
		margin: 0 auto;
	}
	.mmt-lane {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 9px 12px;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		transition: none;
	}
	.mmt-lane-name {
		flex: 0 0 116px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-2);
		line-height: 1.3;
	}
	.mmt-lane-track {
		flex: 1 1 auto;
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
		min-height: 26px;
	}
	/* The active lane (where the current tick's work lives) gets a brighter
	   border so the eye lands on the queue that matters this step. */
	.mmt-lane--macro.mmt-lane--active {
		border-color: color-mix(in srgb, var(--blue) 60%, transparent);
		background: color-mix(in srgb, var(--blue) 8%, var(--sl-color-bg));
	}
	.mmt-lane--micro.mmt-lane--active {
		border-color: color-mix(in srgb, var(--violet) 60%, transparent);
		background: color-mix(in srgb, var(--violet) 8%, var(--sl-color-bg));
	}
	.mmt-lane--micro.mmt-lane--stuck {
		border-color: color-mix(in srgb, var(--violet) 55%, transparent);
		border-style: dashed;
		background: color-mix(in srgb, var(--violet) 6%, var(--sl-color-bg));
	}

	/* ---- queue pills ---- */
	.mmt-pill {
		display: inline-flex;
		align-items: center;
		padding: 3px 11px;
		border-radius: 999px;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 11px;
		font-weight: 700;
		line-height: 1.4;
		white-space: nowrap;
	}
	.mmt-pill--micro {
		border: 1.5px solid color-mix(in srgb, var(--violet) 55%, transparent);
		background: color-mix(in srgb, var(--violet) 16%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--violet) 80%, var(--sl-color-text));
	}
	.mmt-pill--stuck {
		animation: none;
	}
	.mmt-empty {
		font-size: 11px;
		font-style: italic;
		font-weight: 500;
		color: var(--sl-color-gray-3);
	}
	.mmt-empty--drained {
		color: color-mix(in srgb, var(--green) 70%, var(--sl-color-text));
		font-style: normal;
		font-weight: 600;
	}
	.mmt-empty--drained code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 10.5px;
		font-style: normal;
	}
	.mmt-stuck-note {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--violet) 70%, var(--sl-color-text));
	}

	/* ---- status chip ---- */
	.mmt-chip {
		margin: 0 auto;
		display: inline-flex;
		align-items: center;
		gap: 9px;
		padding: 5px 14px;
		border-radius: 999px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		font-size: 12px;
	}
	.mmt-chip-q {
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}
	.mmt-chip-q code,
	.mmt-chip-v code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 11px;
	}
	.mmt-chip-v {
		font-weight: 800;
		letter-spacing: 0.02em;
	}
	.mmt-chip--no .mmt-chip-v {
		color: var(--sl-color-gray-2);
	}
	.mmt-chip--fail {
		border-color: color-mix(in srgb, #dc2626 55%, transparent);
		background: color-mix(in srgb, #dc2626 12%, var(--sl-color-bg));
	}
	.mmt-chip--fail .mmt-chip-v {
		color: color-mix(in srgb, #dc2626 78%, var(--sl-color-text));
	}
	.mmt-chip--yes {
		border-color: color-mix(in srgb, var(--green) 55%, transparent);
		background: color-mix(in srgb, var(--green) 12%, var(--sl-color-bg));
	}
	.mmt-chip--yes .mmt-chip-v {
		color: color-mix(in srgb, var(--green) 72%, var(--sl-color-text));
	}

	/* ---- step 4: recap flow ---- */
	.mmt-flow {
		display: flex;
		align-items: stretch;
		justify-content: center;
		flex-wrap: wrap;
		gap: 6px;
		margin: 0 auto;
	}
	.mmt-flow-box {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		padding: 9px 11px;
		border-radius: 9px;
		border: 1.5px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-6);
		font-size: 11.5px;
		font-weight: 700;
		line-height: 1.25;
		text-align: center;
		color: var(--sl-color-text);
	}
	.mmt-flow-box--macro {
		border-color: color-mix(in srgb, var(--blue) 55%, transparent);
		background: color-mix(in srgb, var(--blue) 10%, var(--sl-color-bg));
	}
	.mmt-flow-box--micro {
		border-color: color-mix(in srgb, var(--violet) 50%, transparent);
		background: color-mix(in srgb, var(--violet) 9%, var(--sl-color-bg));
	}
	.mmt-flow-box--done {
		border-color: color-mix(in srgb, var(--green) 55%, transparent);
		background: color-mix(in srgb, var(--green) 11%, var(--sl-color-bg));
	}
	.mmt-flow-tag {
		font-size: 8.5px;
		font-weight: 800;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 1px 7px;
		border-radius: 999px;
	}
	.mmt-flow-box--macro .mmt-flow-tag {
		background: color-mix(in srgb, var(--blue) 22%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--blue) 80%, var(--sl-color-text));
	}
	.mmt-flow-box--micro .mmt-flow-tag {
		background: color-mix(in srgb, var(--violet) 22%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--violet) 80%, var(--sl-color-text));
	}
	.mmt-flow-arrow {
		display: flex;
		align-items: center;
		font-size: 16px;
		font-weight: 900;
		color: var(--sl-color-gray-3);
	}

	/* ---- step 4: which API covers which part of the chain ---- */
	.mmt-coverage {
		display: flex;
		flex-direction: column;
		gap: 7px;
		max-width: 480px;
		margin: 4px auto 0;
		width: 100%;
	}
	.mmt-cover-row {
		display: flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
	}
	.mmt-cover-api {
		flex: 0 0 auto;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 11.5px;
		font-weight: 700;
		padding: 2px 9px;
		border-radius: 6px;
	}
	.mmt-cover-api--sync {
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
	}
	.mmt-cover-api--async {
		border: 1px solid color-mix(in srgb, var(--green) 50%, transparent);
		background: color-mix(in srgb, var(--green) 12%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--green) 75%, var(--sl-color-text));
	}
	.mmt-cover-span {
		font-size: 12px;
		font-weight: 600;
		color: var(--sl-color-text);
	}
	.mmt-cover-span--sync {
		color: var(--sl-color-gray-2);
	}
</style>
