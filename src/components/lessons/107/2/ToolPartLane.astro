---
// Two-lane (Server / Client) figure for the tool-part lifecycle DiagramSequence.
// The layout is identical across every step — only the part-state pill, the
// tints, and the node labels change — so the stage never reflows as the reader
// scrubs. Each lane has a fixed label column on the left and a single node box
// on the right; pass `serverTone` / `clientTone` to tint the active node.

type Tone = 'idle' | 'orange' | 'green' | 'red';

interface Props {
	/** The current part.state, shown as a pill above the lanes. */
	state: string;
	/** Server-lane node label. */
	serverNode: string;
	/** Client-lane node label. */
	clientNode: string;
	/** Active tint for the server node (idle = faint, no fill). */
	serverTone?: Tone;
	/** Active tint for the client node (idle = faint, no fill). */
	clientTone?: Tone;
}

const {
	state,
	serverNode,
	clientNode,
	serverTone = 'idle',
	clientTone = 'idle',
} = Astro.props;

const tones: Record<Tone, { fill: string; border: string; text: string }> = {
	idle: {
		fill: 'var(--sl-color-bg)',
		border: 'var(--sl-color-hairline)',
		text: 'var(--sl-color-gray-3)',
	},
	orange: { fill: '#ea580c', border: '#ea580c', text: '#fff' },
	green: { fill: '#16a34a', border: '#16a34a', text: '#fff' },
	red: { fill: '#dc2626', border: '#dc2626', text: '#fff' },
};

const stateTone: Tone =
	clientTone !== 'idle' ? clientTone : serverTone !== 'idle' ? serverTone : 'idle';
const pill = tones[stateTone];

const lane = (tone: Tone) => tones[tone];
const s = lane(serverTone);
const c = lane(clientTone);

const nodeStyle = (t: { fill: string; border: string; text: string }) =>
	`flex: 1; min-width: 0; box-sizing: border-box; margin: 0; padding: 10px 12px;` +
	`border: 1.5px solid ${t.border}; border-radius: 8px; background: ${t.fill};` +
	`color: ${t.text}; font-size: 13.5px; font-weight: 600; line-height: 1.35;` +
	`font-family: ui-monospace, SFMono-Regular, Menlo, monospace; text-align: center;`;
---

<div style="display: flex; flex-direction: column; gap: 12px; margin: 0; width: 100%;">
	{/* part.state pill */}
	<div style="display: flex; align-items: center; gap: 8px; margin: 0;">
		<span
			style="margin: 0; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--sl-color-gray-3);"
			>part.state</span
		>
		<span
			style={`margin: 0; padding: 3px 10px; border-radius: 999px; font-size: 13px; font-weight: 700;` +
				`font-family: ui-monospace, SFMono-Regular, Menlo, monospace;` +
				(stateTone === 'idle'
					? `background: var(--sl-color-bg); border: 1.5px solid var(--sl-color-hairline); color: var(--sl-color-gray-2);`
					: `background: ${pill.fill}; border: 1.5px solid ${pill.border}; color: ${pill.text};`)}
			>{state}</span
		>
	</div>

	{/* Server lane */}
	<div style="display: flex; align-items: stretch; gap: 12px; margin: 0;">
		<div
			style="flex: 0 0 78px; box-sizing: border-box; margin: 0; display: flex; align-items: center; justify-content: flex-start; padding: 0 4px; font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--sl-color-gray-2);"
		>
			Server
		</div>
		<div style={nodeStyle(s)}>{serverNode}</div>
	</div>

	{/* Boundary line */}
	<div style="display: flex; align-items: center; gap: 12px; margin: 0;">
		<div style="flex: 0 0 78px; margin: 0;"></div>
		<div
			style="flex: 1; min-width: 0; margin: 0; border-top: 1px dashed var(--sl-color-gray-4); position: relative; height: 0;"
		>
			<span
				style="position: absolute; top: -9px; left: 0; margin: 0; padding: 0 8px; font-size: 11px; color: var(--sl-color-gray-3); background: var(--sl-color-bg-sidebar);"
				>network boundary</span
			>
		</div>
	</div>

	{/* Client lane */}
	<div style="display: flex; align-items: stretch; gap: 12px; margin: 0;">
		<div
			style="flex: 0 0 78px; box-sizing: border-box; margin: 0; display: flex; align-items: center; justify-content: flex-start; padding: 0 4px; font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--sl-color-gray-2);"
		>
			Client
		</div>
		<div style={nodeStyle(c)}>{clientNode}</div>
	</div>
</div>
