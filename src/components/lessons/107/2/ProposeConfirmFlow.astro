---
// The propose/confirm gate as a box-and-arrow flow. The boxes are authored as
// real HTML (the confirmation card shows live-looking Send / Cancel buttons),
// so this uses <ArrowDiagram> rather than a label-only engine. The card is the
// fork: one arrow leaves the Send button (the write path, amber), one leaves
// the Cancel button (the terminating path, grey) — splitting the source across
// the two button zones keeps the arrowheads from stacking.
//
// Wrapped in <Figure expandable={false}> because ArrowDiagram's leader lines
// are positioned from document.body and break when the figure is relocated
// into the expand lightbox.
//
// Tints reuse the lesson's lifecycle palette: blue for the model's decision,
// amber for the committed write, grey for the no-op branch.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const blue = '#2563eb';
const amber = '#d97706';
const grey = '#6b7280';

// Shared box chrome.
const boxBase =
	'box-sizing: border-box; margin: 0; padding: 11px 14px; border-radius: 10px;' +
	'border: 1.5px solid var(--sl-color-hairline); background: var(--sl-color-bg);' +
	'font-size: 13.5px; line-height: 1.4; color: var(--sl-color-white);';

const toolName =
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-weight: 700;';

const subLabel =
	'margin: 3px 0 0; font-size: 12px; color: var(--sl-color-gray-3); line-height: 1.35;';

const arrows = [
	{
		from: 'pc-model',
		to: 'pc-propose',
		label: 'proposes',
		color: blue,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [50, 0],
		endSocketGravity: [-50, 0],
		labelOffset: [0, -14],
	},
	{
		from: 'pc-propose',
		to: 'pc-card',
		label: 'renders',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 60],
		endSocketGravity: [0, -60],
		labelOffset: [0, 0],
	},
	{
		from: 'pc-send',
		to: 'pc-confirm',
		label: 'user clicks Send',
		color: amber,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -16],
		labelStyle: `background: ${amber}; color: #fff; border-color: ${amber};`,
	},
	{
		from: 'pc-cancel',
		to: 'pc-stop',
		label: 'user clicks Cancel',
		color: grey,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, 16],
		labelStyle: `background: ${grey}; color: #fff; border-color: ${grey};`,
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="pc-grid">
			{/* Column 1 — the model's decision */}
			<div class="pc-col pc-col-model">
				<div
					id="pc-model"
					style={boxBase +
						`border-color: ${blue}; box-shadow: inset 0 0 0 1px ${blue};`}
				>
					<div style="font-weight: 700;">Model decides to send</div>
					<div style={subLabel}>It picks the action — but can't pull the trigger.</div>
				</div>
			</div>

			{/* Column 2 — propose (read-only) on top, confirmation card below */}
			<div class="pc-col pc-col-mid">
				<div id="pc-propose" style={boxBase}>
					<div><span style={toolName}>proposeInvoiceSend</span></div>
					<div style={subLabel}>Read-only · returns a preview shape</div>
				</div>

				{/* The confirmation card — the human-click gate */}
				<div id="pc-card" class="pc-card">
					<div class="pc-card-head">Confirmation card</div>
					<div class="pc-card-preview">
						<div class="pc-prev-row"><span>To</span><span>Northwind Trading Co.</span></div>
						<div class="pc-prev-row"><span>Total</span><span>$4,820.00</span></div>
						<div class="pc-prev-row"><span>Due</span><span>Jun 30, 2026</span></div>
					</div>
					<div class="pc-card-buttons">
						<div id="pc-send" class="pc-btn pc-btn-send">Send</div>
						<div id="pc-cancel" class="pc-btn pc-btn-cancel">Cancel</div>
					</div>
				</div>
			</div>

			{/* Column 3 — the two outcomes, vertically aligned to the two buttons */}
			<div class="pc-col pc-col-out">
				<div
					id="pc-confirm"
					style={boxBase +
						`border-color: ${amber}; box-shadow: inset 0 0 0 1px ${amber};`}
				>
					<div><span style={toolName}>confirmInvoiceSend</span></div>
					<div style={subLabel}>The write · sends the invoice → result</div>
				</div>

				<div
					id="pc-stop"
					style={boxBase +
						`border-style: dashed; color: var(--sl-color-gray-2);`}
				>
					<div style="font-weight: 700;">Nothing happens</div>
					<div style={subLabel}>The loop ends — no write fires.</div>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		The propose/confirm gate. The model can only reach the write through a human
		click &mdash; `confirmInvoiceSend` never fires on the model&rsquo;s decision alone.
	</Fragment>
</Figure>

<style>
	.pc-grid {
		display: grid;
		grid-template-columns: minmax(150px, 1fr) minmax(180px, 1.15fr) minmax(170px, 1fr);
		gap: 90px;
		align-items: center;
		padding: 8px 4px;
	}

	.pc-col {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	/* The middle column stacks propose above the card with a small gap. */
	.pc-col-mid {
		gap: 18px;
	}

	/* The outcomes column spreads its two boxes to roughly meet the two buttons. */
	.pc-col-out {
		gap: 40px;
	}

	.pc-card {
		box-sizing: border-box;
		margin: 0;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-hairline);
		background: var(--sl-color-bg-sidebar);
		overflow: hidden;
	}

	.pc-card-head {
		padding: 7px 12px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
		border-bottom: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg);
	}

	.pc-card-preview {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 10px 12px;
	}

	.pc-prev-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 12px;
		font-size: 12.5px;
	}

	.pc-prev-row > span:first-child {
		color: var(--sl-color-gray-3);
	}

	.pc-prev-row > span:last-child {
		font-weight: 600;
		color: var(--sl-color-white);
	}

	.pc-card-buttons {
		display: flex;
		gap: 8px;
		padding: 0 12px 12px;
	}

	.pc-btn {
		flex: 1;
		text-align: center;
		padding: 7px 10px;
		border-radius: 8px;
		font-size: 13px;
		font-weight: 700;
	}

	.pc-btn-send {
		background: #d97706;
		color: #fff;
		border: 1.5px solid #d97706;
	}

	.pc-btn-cancel {
		background: transparent;
		color: var(--sl-color-gray-2);
		border: 1.5px solid var(--sl-color-hairline);
	}

	/* Stacked layout for narrow viewports: arrows degrade but the boxes stay
	   readable, and the button fork still reads top-to-bottom. */
	@media (max-width: 640px) {
		.pc-grid {
			grid-template-columns: 1fr;
			gap: 36px;
		}
		.pc-col-out {
			gap: 18px;
		}
	}
</style>
