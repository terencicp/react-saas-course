---
// Static, hand-authored mock of a single assistant chat bubble whose `parts`
// array interleaves text and tool renders in order: text -> invoice card ->
// text -> a second (compact) tool render. No live AI render is possible
// in-browser, so this is styled divs only — it exists to show the *shape* of
// interleaving, not to run. Each block carries a faint "part" tag so the reader
// can map what they see back to the entries in `parts`.
//
// Colors lean on Starlight's CSS custom properties so the mock tracks the
// light/dark theme; the "Overdue" status badge reuses the same red the
// lifecycle figure uses for its error tone for visual continuity.

const partTagStyle =
	'display: inline-block; margin: 0 0 6px; padding: 1px 7px; border-radius: 999px;' +
	'font-size: 10.5px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase;' +
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace;';

const textTag =
	partTagStyle +
	'background: var(--sl-color-gray-6); border: 1px solid var(--sl-color-hairline); color: var(--sl-color-gray-2);';
const toolTag =
	partTagStyle +
	'background: rgba(37, 99, 235, 0.12); border: 1px solid rgba(37, 99, 235, 0.4); color: var(--sl-color-blue, #2563eb);';

const assistantText =
	'margin: 0; font-size: 14.5px; line-height: 1.5; color: var(--sl-color-white);';
---

<div
	style="margin: 0; display: flex; align-items: flex-start; gap: 10px; max-width: 560px;"
>
	{/* Assistant avatar */}
	<div
		style="flex: 0 0 30px; width: 30px; height: 30px; margin: 0; border-radius: 999px; background: var(--sl-color-gray-5); border: 1px solid var(--sl-color-hairline); display: flex; align-items: center; justify-content: center; font-size: 14px;"
		aria-hidden="true"
	>
		🤖
	</div>

	{/* The single assistant bubble — everything below is ONE message's parts */}
	<div
		style="flex: 1; min-width: 0; margin: 0; padding: 14px 16px; border-radius: 4px 14px 14px 14px; background: var(--sl-color-bg-sidebar); border: 1px solid var(--sl-color-hairline); display: flex; flex-direction: column; gap: 12px;"
	>
		{/* part 0 — text */}
		<div style="margin: 0;">
			<span style={textTag}>text part</span>
			<p style={assistantText}>Here&rsquo;s the invoice you asked about:</p>
		</div>

		{/* part 1 — tool-getInvoiceById -> InvoiceCard */}
		<div style="margin: 0;">
			<span style={toolTag}>tool-getInvoiceById</span>
			<div
				style="margin: 0; padding: 13px 14px; border-radius: 10px; background: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); box-shadow: 0 1px 2px rgba(0,0,0,0.05);"
			>
				<div
					style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin: 0 0 10px;"
				>
					<div style="margin: 0; min-width: 0;">
						<div
							style="margin: 0; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--sl-color-gray-3);"
						>
							Invoice INV-2041
						</div>
						<div
							style="margin: 2px 0 0; font-size: 16px; font-weight: 700; color: var(--sl-color-white);"
						>
							Northwind Trading Co.
						</div>
					</div>
					<span
						style="flex: 0 0 auto; margin: 2px 0 0; padding: 3px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; background: rgba(220, 38, 38, 0.12); border: 1px solid rgba(220, 38, 38, 0.45); color: #dc2626;"
					>
						Overdue
					</span>
				</div>

				<div
					style="display: flex; align-items: baseline; gap: 18px; margin: 0 0 12px;"
				>
					<div style="margin: 0;">
						<div
							style="margin: 0; font-size: 11px; color: var(--sl-color-gray-3);"
						>
							Total
						</div>
						<div
							style="margin: 1px 0 0; font-size: 18px; font-weight: 700; color: var(--sl-color-white);"
						>
							$4,820.00
						</div>
					</div>
					<div style="margin: 0;">
						<div
							style="margin: 0; font-size: 11px; color: var(--sl-color-gray-3);"
						>
							Due
						</div>
						<div
							style="margin: 1px 0 0; font-size: 14px; font-weight: 600; color: var(--sl-color-gray-2);"
						>
							Jun 10, 2026
						</div>
					</div>
				</div>

				<div
					style="margin: 0; padding: 7px 14px; border-radius: 8px; background: var(--sl-color-accent); color: var(--sl-color-accent-low, #fff); font-size: 13px; font-weight: 600; text-align: center; display: inline-block;"
				>
					Send reminder
				</div>
			</div>
		</div>

		{/* part 2 — text */}
		<div style="margin: 0;">
			<span style={textTag}>text part</span>
			<p style={assistantText}>
				It&rsquo;s 4 days overdue &mdash; want me to send a reminder?
			</p>
		</div>

		{/* part 3 — a second, compact tool render */}
		<div style="margin: 0;">
			<span style={toolTag}>tool-getPaymentHistory</span>
			<div
				style="margin: 0; padding: 11px 13px; border-radius: 10px; background: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline);"
			>
				<div
					style="margin: 0 0 8px; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--sl-color-gray-3);"
				>
					Payment history
				</div>
				<div style="display: flex; flex-direction: column; gap: 5px; margin: 0;">
					<div
						style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin: 0; font-size: 13px;"
					>
						<span style="margin: 0; color: var(--sl-color-gray-2);"
							>Apr 2026 &middot; INV-1980</span
						>
						<span style="margin: 0; font-weight: 600; color: #16a34a;"
							>Paid</span
						>
					</div>
					<div
						style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin: 0; font-size: 13px;"
					>
						<span style="margin: 0; color: var(--sl-color-gray-2);"
							>Mar 2026 &middot; INV-1944</span
						>
						<span style="margin: 0; font-weight: 600; color: #16a34a;"
							>Paid</span
						>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
