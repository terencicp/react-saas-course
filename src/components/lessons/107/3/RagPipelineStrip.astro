---
// One reusable RAG-pipeline node-strip, re-skinned per panel of a
// DiagramSequence (Chapter 107 L3, "the two-phase pipeline"). The point is to
// make the two phases — index (offline) and query (per-request) — read as two
// separate strips that meet at exactly one shared artifact, the
// `documentChunks` table (the seam).
//
//   steps 1-3 → strip A (index, offline): Document → Chunker → embedMany → documentChunks
//   steps 4-6 → strip B (query, per-request): Question → embed → documentChunks → system prompt → streamText → Answer
//
// Each step highlights one or more nodes with the accent ring + fill; the
// shared `documentChunks` node carries a fixed violet "seam" treatment in both
// strips so the eye recognises it as the same table written by A and read by B.
//
// A phase banner above the strip labels and tints the current phase (blue for
// index/offline, green for query/per-request) so the offline/online seam is
// obvious. Theme-adaptive chrome via Starlight gray vars; semantic tints are
// fixed mid-tones so colour survives the light/dark flip. `not-content` +
// `margin: 0` defeat Starlight's prose styles.

interface Props {
	step: 1 | 2 | 3 | 4 | 5 | 6;
}

const { step } = Astro.props;

const phase: 'index' | 'query' = step <= 3 ? 'index' : 'query';

// Which node ids light up on this step.
const lit: Record<number, string[]> = {
	1: ['document', 'chunker'],
	2: ['embedmany'],
	3: ['chunks'],
	4: ['question', 'embed'],
	5: ['chunks'],
	6: ['system', 'streamtext', 'answer'],
};
const active = new Set(lit[step]);

type Node = { id: string; label: string; seam?: boolean };

const indexNodes: Node[] = [
	{ id: 'document', label: 'Document' },
	{ id: 'chunker', label: 'Chunker' },
	{ id: 'embedmany', label: 'embedMany' },
	{ id: 'chunks', label: 'documentChunks', seam: true },
];

const queryNodes: Node[] = [
	{ id: 'question', label: 'Question' },
	{ id: 'embed', label: 'embed' },
	{ id: 'chunks', label: 'documentChunks', seam: true },
	{ id: 'system', label: 'system prompt' },
	{ id: 'streamtext', label: 'streamText' },
	{ id: 'answer', label: 'Answer' },
];

const nodes = phase === 'index' ? indexNodes : queryNodes;
---

<div class="rp not-content" data-phase={phase}>
	<div class="rp-banner">
		<span class="rp-dot"></span>
		{phase === 'index' ? 'Index — offline' : 'Query — per request'}
	</div>

	<div class="rp-strip">
		{
			nodes.map((node, i) => (
				<>
					<div
						class:list={[
							'rp-node',
							{ 'is-on': active.has(node.id), 'is-seam': node.seam },
						]}
					>
						{node.label}
					</div>
					{i < nodes.length - 1 && (
						<span class="rp-arrow" aria-hidden="true">
							›
						</span>
					)}
				</>
			))
		}
	</div>
</div>

<style>
	.rp {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
		margin: 0;
		padding: 8px 0 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* --- phase banner: blue tint for index/offline, green for query/online --- */
	.rp-banner {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		line-height: 1;
		padding: 5px 12px;
		border-radius: 999px;
		margin: 0;
	}
	.rp-dot {
		width: 8px;
		height: 8px;
		border-radius: 999px;
		margin: 0;
	}
	.rp[data-phase='index'] .rp-banner {
		color: #1d4ed8; /* blue 700 */
		background: rgba(37, 99, 235, 0.13);
		border: 1px solid rgba(37, 99, 235, 0.4);
	}
	.rp[data-phase='index'] .rp-dot {
		background: #2563eb; /* blue 600 */
	}
	.rp[data-phase='query'] .rp-banner {
		color: #15803d; /* green 700 */
		background: rgba(22, 163, 74, 0.13);
		border: 1px solid rgba(22, 163, 74, 0.4);
	}
	.rp[data-phase='query'] .rp-dot {
		background: #16a34a; /* green 600 */
	}

	/* --- the node strip --- */
	.rp-strip {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		column-gap: 5px;
		row-gap: 18px;
		margin: 0;
	}

	.rp-node {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		min-height: 2.9rem;
		padding: 9px 11px;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-gray-6, #f1f5f9);
		color: var(--sl-color-white, #1e293b);
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1.1;
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			box-shadow 0.16s,
			opacity 0.16s;
	}

	.rp-arrow {
		flex: 0 0 auto;
		font-size: 1.2rem;
		line-height: 1;
		font-weight: 700;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	/* The shared documentChunks table — a fixed violet "seam" treatment so it
	   reads as the same artifact in the index strip and the query strip. */
	.rp-node.is-seam {
		border-color: #7c3aed; /* violet 600 */
		border-style: dashed;
		background: rgba(124, 58, 237, 0.1);
		color: var(--sl-color-white, #5b21b6);
	}

	/* The node(s) this step is about: accent ring + fill, matched to the phase. */
	.rp[data-phase='index'] .rp-node.is-on {
		border-color: #2563eb; /* blue 600 */
		border-style: solid;
		background: rgba(37, 99, 235, 0.18);
		box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.18);
	}
	.rp[data-phase='query'] .rp-node.is-on {
		border-color: #16a34a; /* green 600 */
		border-style: solid;
		background: rgba(22, 163, 74, 0.18);
		box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.18);
	}

	/* The seam node, when it is the lit node, keeps its violet identity but
	   gains the active ring so it still reads as "this step's focus". */
	.rp .rp-node.is-seam.is-on {
		border-color: #7c3aed; /* violet 600 */
		border-style: solid;
		background: rgba(124, 58, 237, 0.2);
		box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.2);
	}

	@media (max-width: 520px) {
		.rp-node {
			min-height: 2.6rem;
			padding: 8px 10px;
			font-size: 0.75rem;
		}
		.rp-arrow {
			font-size: 1.1rem;
		}
	}
</style>
