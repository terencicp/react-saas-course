---
// A hand-authored 2D scatter "cartoon" of an embedding space. Static intuition
// aid for "similar meaning = nearby vectors". Corpus points are muted; the
// query point uses the accent colour and a ring so the eye separates "stored
// text" from "the question". Two short lines connect the query to its two
// nearest neighbours. Positions are percentages inside a square plot box, so
// the whole thing scales fluidly and survives the Figure lightbox relocation.

const accent = '#7c3aed'; // query point + its connectors
const corpus = 'var(--sl-color-gray-2)';

// Plot positions as { x, y } percentages from the top-left of the plot area.
// The invoice / bill / receipt cluster sits centre-left; refund policy hangs
// just outside it; office cat is exiled to the top-right corner; the query
// lands inside the cluster.
const points: {
	label: string;
	x: number;
	y: number;
	kind: 'corpus' | 'query';
	// label placement relative to the dot
	place?: 'above' | 'below' | 'right' | 'left';
}[] = [
	{ label: 'invoice', x: 24, y: 52, kind: 'corpus', place: 'left' },
	{ label: 'bill', x: 37, y: 44, kind: 'corpus', place: 'above' },
	{ label: 'receipt', x: 33, y: 64, kind: 'corpus', place: 'below' },
	{ label: 'refund policy', x: 52, y: 70, kind: 'corpus', place: 'right' },
	{ label: 'office cat', x: 84, y: 16, kind: 'corpus', place: 'left' },
	{ label: 'unpaid invoices', x: 31, y: 53, kind: 'query', place: 'below' },
];

const query = points.find((p) => p.kind === 'query')!;
// The two nearest neighbours the query "retrieves".
const neighbours = ['invoice', 'bill'].map(
	(name) => points.find((p) => p.label === name)!,
);

const labelOffsets: Record<string, string> = {
	above: 'bottom: 132%; left: 50%; transform: translateX(-50%);',
	below: 'top: 132%; left: 50%; transform: translateX(-50%);',
	right: 'left: 150%; top: 50%; transform: translateY(-50%);',
	left: 'right: 150%; top: 50%; transform: translateY(-50%);',
};
---

<div style="margin: 0; width: 100%; max-width: 460px; margin-inline: auto;">
	<div
		style="margin: 0 0 8px; text-align: center; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--sl-color-gray-3);"
	>
		A 2D cartoon of a 1536-dimensional space
	</div>

	{/* Square plot area */}
	<div
		style="position: relative; width: 100%; aspect-ratio: 1 / 1; box-sizing: border-box; margin: 0; border: 1.5px solid var(--sl-color-hairline); border-radius: 10px; background: var(--sl-color-bg);"
	>
		{/* Connector lines from query to its nearest neighbours */}
		<svg
			viewBox="0 0 100 100"
			preserveAspectRatio="none"
			style="position: absolute; inset: 0; width: 100%; height: 100%; margin: 0; overflow: visible; pointer-events: none;"
		>
			{
				neighbours.map((n) => (
					<line
						x1={query.x}
						y1={query.y}
						x2={n.x}
						y2={n.y}
						stroke={accent}
						stroke-width="0.5"
						stroke-dasharray="1.6 1.4"
						vector-effect="non-scaling-stroke"
						opacity="0.7"
					/>
				))
			}
		</svg>

		{/* Points */}
		{
			points.map((p) => {
				const isQuery = p.kind === 'query';
				const dot = isQuery
					? `width: 14px; height: 14px; background: ${accent}; box-shadow: 0 0 0 4px color-mix(in srgb, ${accent} 22%, transparent);`
					: `width: 11px; height: 11px; background: ${corpus};`;
				const labelColor = isQuery ? accent : 'var(--sl-color-white)';
				const labelWeight = isQuery ? 700 : 600;
				return (
					<div
						style={`position: absolute; left: ${p.x}%; top: ${p.y}%; transform: translate(-50%, -50%); margin: 0;`}
					>
						<div style="position: relative; margin: 0;">
							<span
								style={`display: block; ${dot} border-radius: 999px; margin: 0;`}
							/>
							<span
								style={`position: absolute; ${labelOffsets[p.place ?? 'below']} margin: 0; white-space: nowrap; font-size: 12.5px; font-weight: ${labelWeight}; color: ${labelColor}; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;`}
							>
								{p.label}
							</span>
						</div>
					</div>
				);
			})
		}
	</div>

	{/* Legend */}
	<div
		style="display: flex; justify-content: center; gap: 18px; margin: 12px 0 0; font-size: 12px; color: var(--sl-color-gray-2);"
	>
		<span style="display: inline-flex; align-items: center; gap: 6px; margin: 0;">
			<span
				style={`width: 11px; height: 11px; border-radius: 999px; background: ${corpus}; margin: 0;`}
			></span>
			stored text
		</span>
		<span style="display: inline-flex; align-items: center; gap: 6px; margin: 0;">
			<span
				style={`width: 12px; height: 12px; border-radius: 999px; background: ${accent}; box-shadow: 0 0 0 3px color-mix(in srgb, ${accent} 22%, transparent); margin: 0;`}
			></span>
			the question
		</span>
	</div>
</div>
