---
// Retry-collapse step diagram. Renders one of three temporal variants
// of the same client-server pair, used inside three <DiagramStep>
// slots in the lesson.
//
// Step 1 — first attempt, response packet is dropped.
// Step 2 — client retries with the same Idempotency-Key.
// Step 3 — server looks the key up and replays the cached response.
//
// Layout: a two-column grid (Client | Server) with sticky actor
// headers at top and time-ordered rows below. Each row is itself a
// two-column grid so messages and server-work boxes share the same
// coordinate system across steps — the slider doesn't visually jump
// between steps because every variant sizes to the same column grid
// and the stage sizes to the tallest variant.
//
// The literal `Idempotency-Key: ab12c3d4...` value is rendered in a
// consistent orange accent across all three steps so it visually
// anchors as "the same key is used every time."
//
// Pure HTML + CSS, no script. Theme-adaptive via Starlight CSS
// variables for chrome; saturated mid-tones for the colored chips
// (orange for the key, green for the success body, red for the drop).

interface Props {
  step?: 1 | 2 | 3;
}

const { step = 1 } = Astro.props;

const reset = "margin: 0";

// Accent for the Idempotency-Key — orange, matching the AnnotatedCode
// step that highlights the header in the same lesson.
const keyAccent = "#ea580c"; // orange-600

const root = [
  reset,
  "display: grid",
  "grid-template-columns: 1fr 1fr",
  "gap: 14px",
  "width: 100%",
  "max-width: 620px",
  "margin-left: auto",
  "margin-right: auto",
  "padding: 4px 0 0",
  "row-gap: 16px",
  "column-gap: 24px",
].join("; ");

const actorHeader = [
  reset,
  "padding: 6px 10px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-hairline)",
  "background: var(--sl-color-bg-sidebar)",
  "color: var(--sl-color-text)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 13px",
  "font-weight: 700",
  "text-align: center",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
].join("; ");

// Each row spans both actor columns and lays out content inside its own
// two-column grid so an arrow can run all the way from one actor to the
// other.
const row = [
  reset,
  "grid-column: 1 / -1",
  "display: grid",
  "grid-template-columns: 1fr 1fr",
  "gap: 24px",
  "align-items: center",
  "min-height: 0",
].join("; ");

// A small "work" box that sits in one of the columns of the row.
const workBoxBase = [
  reset,
  "padding: 8px 10px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-hairline)",
  "background: var(--sl-color-bg)",
  "color: var(--sl-color-text)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 12px",
  "line-height: 1.4",
  "text-align: center",
  "box-shadow: inset 0 0 0 1px rgba(127, 127, 127, 0.05)",
].join("; ");

// Server-work box — green-tinted left border to flag "server did work".
const workBoxServer = `${workBoxBase}; border-left: 3px solid #16a34a;`;
// Server-replay box — blue-tinted left border to flag "server looked up,
// did not re-run".
const workBoxReplay = `${workBoxBase}; border-left: 3px solid #0ea5e9;`;

// Inline-grid arrow lane: label on top, arrow on bottom (or strikethrough
// arrow + "dropped" tag for step 1's response).
const arrowLane = [
  reset,
  "grid-column: 1 / -1",
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 4px",
].join("; ");

const arrowLabelLine = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 2px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 12px",
  "line-height: 1.3",
  "color: var(--sl-color-text)",
  "text-align: center",
].join("; ");

const methodLabel = [
  reset,
  "font-weight: 700",
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 13px",
  "letter-spacing: 0.02em",
].join("; ");

const statusLabel = [
  reset,
  "font-weight: 700",
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 13px",
  "color: #16a34a",
  "letter-spacing: 0.02em",
].join("; ");

const keyLabel = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 11px",
  `color: ${keyAccent}`,
  "font-weight: 600",
  "letter-spacing: 0.01em",
].join("; ");

// The arrow itself — a horizontal line with an arrowhead at one end.
const arrowWrap = [
  reset,
  "position: relative",
  "display: flex",
  "align-items: center",
  "width: 100%",
  "height: 14px",
].join("; ");

const arrowLineRight = [
  reset,
  "flex: 1",
  "height: 2px",
  "background: var(--sl-color-text)",
  "opacity: 0.7",
].join("; ");

const arrowHeadRight = [
  reset,
  "width: 0",
  "height: 0",
  "border-top: 6px solid transparent",
  "border-bottom: 6px solid transparent",
  "border-left: 9px solid var(--sl-color-text)",
  "opacity: 0.7",
  "flex: none",
].join("; ");

const arrowHeadLeft = [
  reset,
  "width: 0",
  "height: 0",
  "border-top: 6px solid transparent",
  "border-bottom: 6px solid transparent",
  "border-right: 9px solid var(--sl-color-text)",
  "opacity: 0.7",
  "flex: none",
].join("; ");

// Dropped arrow — strikethrough overlay and a red "dropped" tag.
const arrowDropOverlay = [
  reset,
  "position: absolute",
  "top: 50%",
  "left: 50%",
  "transform: translate(-50%, -50%) rotate(-12deg)",
  "width: 60%",
  "height: 3px",
  "background: #dc2626",
  "border-radius: 2px",
  "pointer-events: none",
].join("; ");

const droppedTag = [
  reset,
  "display: inline-block",
  "padding: 1px 6px",
  "border-radius: 4px",
  "background: #dc2626",
  "color: #fff",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1.2",
  "margin-top: 2px",
].join("; ");

// A short annotation that sits under one column, in muted text.
const annotation = [
  reset,
  "padding: 6px 10px",
  "border-radius: 8px",
  "background: var(--sl-color-bg-sidebar)",
  "border: 1px dashed var(--sl-color-hairline)",
  "color: var(--sl-color-gray-3)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 11px",
  "line-height: 1.4",
  "text-align: center",
  "font-style: italic",
].join("; ");

// Spacer cell — keeps the opposite column reserved so the grid columns
// stay aligned vertically across rows.
const spacer = `${reset}; min-height: 1px`;
---

<div class="not-content rs-root" style={root} data-step={step}>
  <div style={actorHeader}>Client</div>
  <div style={actorHeader}>Server</div>

  {step === 1 && (
    <>
      {/* Row 1: Client -> Server, POST with key */}
      <div style={row}>
        <div style={arrowLane}>
          <div style={arrowLabelLine}>
            <span style={methodLabel}>POST /charge</span>
            <span style={keyLabel}>Idempotency-Key: ab12c3d4...</span>
          </div>
          <div style={arrowWrap} aria-hidden="true">
            <div style={arrowLineRight}></div>
            <div style={arrowHeadRight}></div>
          </div>
        </div>
      </div>

      {/* Row 2: Server-side work box */}
      <div style={row}>
        <div style={spacer}></div>
        <div style={workBoxServer}>
          Process charge.<br />Store (ab12, resp).
        </div>
      </div>

      {/* Row 3: Server -> Client, 200 OK, dropped */}
      <div style={row}>
        <div style={arrowLane}>
          <div style={arrowLabelLine}>
            <span style={statusLabel}>200 OK</span>
          </div>
          <div style={arrowWrap} aria-hidden="true">
            <div style={arrowHeadLeft}></div>
            <div style={arrowLineRight}></div>
            <div style={arrowDropOverlay}></div>
          </div>
          <div style={arrowLabelLine}>
            <span style={droppedTag}>dropped</span>
          </div>
        </div>
      </div>
    </>
  )}

  {step === 2 && (
    <>
      {/* Row 1: Client -> Server, POST with the SAME key */}
      <div style={row}>
        <div style={arrowLane}>
          <div style={arrowLabelLine}>
            <span style={methodLabel}>POST /charge</span>
            <span style={keyLabel}>Idempotency-Key: ab12c3d4...</span>
          </div>
          <div style={arrowWrap} aria-hidden="true">
            <div style={arrowLineRight}></div>
            <div style={arrowHeadRight}></div>
          </div>
        </div>
      </div>

      {/* Row 2: Annotation on the Client side */}
      <div style={row}>
        <div style={annotation}>Same key. No new UUID.</div>
        <div style={spacer}></div>
      </div>

      {/* Reserve row to keep height parity with step 1 */}
      <div style={row}>
        <div style={spacer}></div>
        <div style={spacer}></div>
      </div>
    </>
  )}

  {step === 3 && (
    <>
      {/* Row 1: Server-side lookup box */}
      <div style={row}>
        <div style={spacer}></div>
        <div style={workBoxReplay}>
          Look up ab12.<br />Found cached response.
        </div>
      </div>

      {/* Row 2: Server -> Client, 200 OK, intact */}
      <div style={row}>
        <div style={arrowLane}>
          <div style={arrowLabelLine}>
            <span style={statusLabel}>200 OK</span>
          </div>
          <div style={arrowWrap} aria-hidden="true">
            <div style={arrowHeadLeft}></div>
            <div style={arrowLineRight}></div>
          </div>
        </div>
      </div>

      {/* Row 3: Annotation under the arrow */}
      <div style={row}>
        <div style={spacer}></div>
        <div style={annotation}>
          No charge re-run.<br />Card charged exactly once.
        </div>
      </div>
    </>
  )}
</div>

<style>
  /* Mobile: tighten gaps and let the columns breathe a touch. */
  @media (max-width: 560px) {
    .rs-root {
      column-gap: 14px !important;
      row-gap: 12px !important;
    }
  }
</style>
