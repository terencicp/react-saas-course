---
// 2x2 method-property grid: rows = Safe / Unsafe, cols = Idempotent /
// Not idempotent. The five methods drop into the cells their properties
// pick out. The top-right cell is intentionally empty (no use case for
// a "safe but non-idempotent" method); the bottom-right cell is the
// POST cell, tinted more prominently because it's the one the
// Idempotency-Key section addresses.
//
// Layout: a 3-column / 3-row CSS grid. The first row and first column
// hold the axis headers; the inner 2x2 holds the four cells. On narrow
// viewports the grid collapses to a single column with per-cell
// inline labels.
//
// Pure HTML + CSS. `margin: 0` on every inner element to defeat the
// Starlight prose margin selector. Text on tinted backgrounds uses a
// dark color baked in (the tints stay light enough for dark text in
// both themes thanks to a low-alpha saturated overlay over white).

const reset = "margin: 0";

const root = [
  reset,
  "display: grid",
  "grid-template-columns: minmax(64px, 96px) 1fr 1fr",
  "grid-template-rows: auto 1fr 1fr",
  "gap: 10px",
  "width: 100%",
  "max-width: 680px",
  "margin-left: auto",
  "margin-right: auto",
  "padding: 0",
].join("; ");

const colHeader = [
  reset,
  "padding: 6px 4px 8px",
  "font-size: 13px",
  "font-weight: 600",
  "text-align: center",
  "color: var(--sl-color-text)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "letter-spacing: 0.01em",
].join("; ");

const rowHeader = [
  reset,
  "padding: 4px 6px",
  "font-size: 13px",
  "font-weight: 600",
  "color: var(--sl-color-text)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "letter-spacing: 0.01em",
  "writing-mode: vertical-rl",
  "transform: rotate(180deg)",
  "text-align: center",
  "align-self: stretch",
  "justify-self: center",
  "display: flex",
  "align-items: center",
  "justify-content: center",
].join("; ");

const cellBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 8px",
  "padding: 16px 14px",
  "border-radius: 12px",
  "border: 1px solid var(--sl-color-hairline)",
  "min-height: 130px",
  "box-sizing: border-box",
  "text-align: center",
].join("; ");

// Saturated mid-tone fills with white text — readable in both themes.
const cellSafeIdem = `${cellBase}; background: #16a34a;`; // green-600
const cellSafeNon = `${cellBase}; background: var(--sl-color-bg); border-style: dashed; color: var(--sl-color-gray-3);`;
const cellUnsafeIdem = `${cellBase}; background: #d97706;`; // amber-600
const cellUnsafeNon = `${cellBase}; background: #dc2626; box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.25);`; // red-600 + glow

const chipBase = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "padding: 4px 12px",
  "border-radius: 6px",
  "font-weight: 700",
  "font-size: 14px",
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "letter-spacing: 0.02em",
  "background: rgba(255, 255, 255, 0.2)",
  "color: #fff",
  "border: 1px solid rgba(255, 255, 255, 0.35)",
  "line-height: 1.2",
].join("; ");

const chipBig = `${chipBase}; padding: 6px 16px; font-size: 16px;`;

const chipRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "gap: 6px",
  "justify-content: center",
].join("; ");

const exampleText = [
  reset,
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "color: #fff",
  "line-height: 1.35",
  "opacity: 0.92",
  "max-width: 220px",
].join("; ");

const emptyMark = [
  reset,
  "font-size: 28px",
  "color: var(--sl-color-gray-4)",
  "font-weight: 300",
  "line-height: 1",
].join("; ");

const emptyLabel = [
  reset,
  "font-size: 11px",
  "color: var(--sl-color-gray-4)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
].join("; ");

const mobileTag = [
  reset,
  "display: none",
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "opacity: 0.85",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
].join("; ");
---

<div class="not-content mpg-root" style={root}>
  <div style={`${reset}`} aria-hidden="true"></div>
  <div style={colHeader}>Idempotent</div>
  <div style={colHeader}>Not idempotent</div>

  <div style={rowHeader} class="mpg-rowhead">Safe</div>

  {/* Safe + Idempotent */}
  <div style={cellSafeIdem} class="mpg-cell">
    <span style={mobileTag} class="mpg-mobile-tag">Safe / Idempotent</span>
    <span style={chipBig}>GET</span>
    <p style={exampleText}>Load an invoice.</p>
  </div>

  {/* Safe + Not idempotent — intentionally empty */}
  <div style={cellSafeNon} class="mpg-cell mpg-cell-empty">
    <span style={mobileTag} class="mpg-mobile-tag">Safe / Not idempotent</span>
    <span style={emptyMark}>&mdash;</span>
    <span style={emptyLabel}>no occupants</span>
  </div>

  <div style={rowHeader} class="mpg-rowhead">Unsafe</div>

  {/* Unsafe + Idempotent */}
  <div style={cellUnsafeIdem} class="mpg-cell">
    <span style={mobileTag} class="mpg-mobile-tag">Unsafe / Idempotent</span>
    <div style={chipRow}>
      <span style={chipBase}>PUT</span>
      <span style={chipBase}>PATCH</span>
      <span style={chipBase}>DELETE</span>
    </div>
    <p style={exampleText}>Replace, set status to &lsquo;paid&rsquo;, delete the invoice.</p>
  </div>

  {/* Unsafe + Not idempotent — the POST cell */}
  <div style={cellUnsafeNon} class="mpg-cell">
    <span style={mobileTag} class="mpg-mobile-tag">Unsafe / Not idempotent</span>
    <span style={chipBig}>POST</span>
    <p style={exampleText}>Charge a card.</p>
  </div>
</div>

<style>
  /* Mobile: drop the axis headers, stack the four cells in one column,
     and reveal an inline "Safe / Idempotent" tag inside each cell so
     the property pairing stays visible without the grid. */
  @media (max-width: 560px) {
    .mpg-root {
      grid-template-columns: 1fr !important;
      grid-template-rows: repeat(4, auto) !important;
      gap: 12px !important;
    }
    .mpg-root > div[aria-hidden="true"],
    .mpg-root > div:nth-child(2),
    .mpg-root > div:nth-child(3),
    .mpg-rowhead {
      display: none !important;
    }
    .mpg-mobile-tag {
      display: inline-flex !important;
    }
    .mpg-cell {
      min-height: 110px !important;
    }
  }
</style>
