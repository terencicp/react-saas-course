---
// Two-row reference card for the lesson's two anchor properties.
//
// Layout: a single card containing two stacked rows. Each row pairs a
// large label pill on the left (Safety / Idempotency) with the
// definition + test text on the right.
//
// Pure HTML + CSS. No script needed. Theme-adaptive via Starlight CSS
// variables; the pill colors are saturated mid-tones that read well on
// both light and dark backgrounds.
//
// `margin: 0` on every inner element to defeat the Starlight prose
// margin selector that injects ~16px on every block-level descendant.

const reset = "margin: 0";

const card = [
  reset,
  "display: grid",
  "grid-template-rows: 1fr 1fr",
  "gap: 12px",
  "width: 100%",
  "max-width: 640px",
  "margin-left: auto",
  "margin-right: auto",
  "padding: 0",
].join("; ");

const row = [
  reset,
  "display: grid",
  "grid-template-columns: minmax(120px, 160px) 1fr",
  "gap: 16px",
  "align-items: center",
  "padding: 14px 16px",
  "background: var(--sl-color-bg)",
  "border: 1px solid var(--sl-color-hairline)",
  "border-radius: 10px",
].join("; ");

const pillBase = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "padding: 8px 14px",
  "border-radius: 999px",
  "font-weight: 700",
  "font-size: 14px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "letter-spacing: 0.01em",
  "color: #fff",
  "width: fit-content",
].join("; ");

// Saturated mid-tones — teal for the "no side effect" property,
// indigo for the "converges to one state" property.
const pillSafety = `${pillBase}; background: #0d9488;`;
const pillIdempotency = `${pillBase}; background: #4f46e5;`;

const body = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 6px",
  "min-width: 0",
].join("; ");

const definition = [
  reset,
  "font-size: 15px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "color: var(--sl-color-text)",
  "line-height: 1.4",
].join("; ");

const test = [
  reset,
  "font-size: 13px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "color: var(--sl-color-gray-3)",
  "line-height: 1.4",
].join("; ");

const testLabel = [
  reset,
  "font-weight: 600",
  "text-transform: uppercase",
  "letter-spacing: 0.05em",
  "font-size: 11px",
  "color: var(--sl-color-gray-3)",
  "margin-right: 6px",
].join("; ");
---

<div class="not-content sic-root" style={card}>
  <div style={row} class="sic-row">
    <span style={pillSafety}>Safety</span>
    <div style={body}>
      <p style={definition}>No observable change to server state.</p>
      <p style={test}>
        <span style={testLabel}>Test</span>
        Any observable server-state change? No &rarr; safe.
      </p>
    </div>
  </div>

  <div style={row} class="sic-row">
    <span style={pillIdempotency}>Idempotency</span>
    <div style={body}>
      <p style={definition}>Same final state after N calls as after one.</p>
      <p style={test}>
        <span style={testLabel}>Test</span>
        Same final state after N calls as after one? Yes &rarr; idempotent.
      </p>
    </div>
  </div>
</div>

<style>
  /* On narrow viewports collapse to a single column so the pill sits
     above the definition + test rather than crowding it sideways. */
  @media (max-width: 520px) {
    .sic-root .sic-row {
      grid-template-columns: 1fr !important;
      gap: 8px !important;
    }
  }
</style>
