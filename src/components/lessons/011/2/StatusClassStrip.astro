---
// Compact reference strip for the five HTTP status classes (1xx-5xx).
// Each swatch stacks: the class range (e.g. "1xx"), the one-word
// semantic label, and a short "who reads this" hint. Five swatches in a
// flex row of equal flex-basis; allowed to wrap on narrow viewports so
// no swatch ever ends up clipped.
//
// Pure HTML + CSS. `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector. Saturated mid-tone fills with
// white text — readable in both light and dark theme. 1xx uses a
// neutral slate so the "informational, no team owns it" semantic reads
// at a glance.

const reset = "margin: 0";

const root = [
  reset,
  "display: grid",
  "grid-template-columns: repeat(5, minmax(0, 1fr))",
  "column-gap: 8px",
  "row-gap: 8px",
  "width: 100%",
  "padding: 0",
  "box-sizing: border-box",
].join("; ");

const cellBase = [
  reset,
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 6px",
  "padding: 14px 8px",
  "border-radius: 10px",
  "color: #ffffff",
  "box-sizing: border-box",
  "text-align: center",
  "min-height: 120px",
].join("; ");

const rangeStyle = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 13px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "opacity: 0.85",
  "line-height: 1",
].join("; ");

const labelStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 16px",
  "font-weight: 700",
  "line-height: 1.15",
  "letter-spacing: 0.01em",
].join("; ");

const hintStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.3",
  "opacity: 0.92",
  "max-width: 16ch",
].join("; ");

// Saturated mid-tone fills (Tailwind ~600 range) — white text reads in
// both themes. 1xx is a muted slate so it visually de-emphasises
// (junior never sends one) compared to the loud 4xx/5xx.
const classes = [
  { range: "1xx", label: "Informational", hint: "Niche, rarely sent", bg: "#475569" }, // slate-600
  { range: "2xx", label: "Success", hint: "Happy path, every read", bg: "#16a34a" }, // green-600
  { range: "3xx", label: "Redirection", hint: "Browser follows Location", bg: "#2563eb" }, // blue-600
  { range: "4xx", label: "Client error", hint: "Doesn't page on-call", bg: "#ea580c" }, // orange-600
  { range: "5xx", label: "Server error", hint: "Pages on-call", bg: "#dc2626" }, // red-600
];
---

<div class="not-content scs-root" style={root}>
  {classes.map((c) => (
    <div style={`${cellBase}; background: ${c.bg};`}>
      <span style={rangeStyle}>{c.range}</span>
      <span style={labelStyle}>{c.label}</span>
      <span style={hintStyle}>{c.hint}</span>
    </div>
  ))}
</div>

<style>
  /* On narrow viewports, drop the strict 5-column grid for a 2x2 grid
     with the 5th cell spanning both columns at the bottom — no orphan
     row, no labels squeezed into ~50px-wide cells. */
  @media (max-width: 520px) {
    .scs-root {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
    .scs-root > div:nth-child(5) {
      grid-column: 1 / -1 !important;
    }
  }
</style>
