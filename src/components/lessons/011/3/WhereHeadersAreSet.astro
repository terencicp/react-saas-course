---
// Closing-payoff strip mapping each header-setter to the Next.js file it
// lives in. Three columns left-to-right: build-time `next.config.ts`,
// per-request `proxy.ts`, per-response `route.ts` / Server Action. Each
// column stacks: a monospaced filename pill, the trigger one-liner that
// answers "why this file?", and the chip list of example header names.
//
// Pure HTML + CSS. `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector. Same saturated mid-tone palette as
// HeaderAudienceStrip so the lesson's two reference strips read as a
// family — the audience colour at the top of the lesson is the same
// colour at the bottom where each audience's setter lives.

const reset = "margin: 0";

const root = [
  reset,
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  "column-gap: 8px",
  "row-gap: 8px",
  "width: 100%",
  "padding: 0",
  "box-sizing: border-box",
].join("; ");

const cellBase = [
  reset,
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 10px",
  "padding: 14px 14px 12px",
  "border-radius: 10px",
  "color: #ffffff",
  "box-sizing: border-box",
].join("; ");

const filenameStyle = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "letter-spacing: -0.01em",
  "padding: 6px 8px",
  "border-radius: 6px",
  "background: rgba(0, 0, 0, 0.22)",
  "color: #ffffff",
  "word-break: break-word",
].join("; ");

const triggerStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.35",
  "opacity: 0.92",
].join("; ");

const listStyle = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
  "padding: 0",
  "list-style: none",
].join("; ");

const chipStyle = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 11.5px",
  "font-weight: 500",
  "letter-spacing: -0.01em",
  "line-height: 1.25",
  "padding: 4px 6px",
  "border-radius: 6px",
  "background: rgba(255, 255, 255, 0.18)",
  "border: 1px solid rgba(255, 255, 255, 0.28)",
  "color: #ffffff",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");

// Same saturated mid-tone palette as HeaderAudienceStrip — blue for the
// browser-baseline setter, orange for the infrastructure-touching
// per-request setter, green for the application-response setter. The
// colour family is the visual reinforcement of audience → setter.
const setters = [
  {
    filename: "next.config.ts headers()",
    trigger: "Static across requests.",
    headers: [
      "Strict-Transport-Security",
      "X-Content-Type-Options",
      "Referrer-Policy",
      "Permissions-Policy",
    ],
    bg: "#2563eb", // blue-600
  },
  {
    filename: "proxy.ts",
    trigger: "Per-request data (CSP nonce, request-id).",
    headers: [
      "Content-Security-Policy",
      "X-Request-Id",
      "RateLimit",
    ],
    bg: "#ea580c", // orange-600
  },
  {
    filename: "route.ts / Server Action",
    trigger: "Per-response (per-route cache, per-resource ETag).",
    headers: [
      "Cache-Control",
      "ETag",
      "WWW-Authenticate",
      "Content-Type",
    ],
    bg: "#16a34a", // green-600
  },
];
---

<div class="not-content whs-root" style={root}>
  {
    setters.map((s) => (
      <div style={`${cellBase}; background: ${s.bg};`}>
        <span style={filenameStyle}>{s.filename}</span>
        <span style={triggerStyle}>{s.trigger}</span>
        <ul style={listStyle}>
          {s.headers.map((h) => (
            <li style={chipStyle}>{h}</li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<style>
  /* Drop to a single column on narrow viewports — only three cells, so
     no orphan-row situation can arise; each cell keeps its full chip
     list intact. */
  @media (max-width: 560px) {
    .whs-root {
      grid-template-columns: 1fr !important;
    }
  }
</style>
