---
// Compact reference strip for the three audiences a header can be
// addressed to (browser, infrastructure, application). Each column
// stacks: the uppercase audience name, the one-line "who reads it"
// semantic, and a small list of example header names in monospace.
// Three columns of equal flex-basis; collapses to one column on narrow
// viewports so no chip ever ends up clipped.
//
// Pure HTML + CSS. `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector. Saturated mid-tone fills with
// white text — matches the StatusClassStrip palette so the chapter's
// reference strips read as a family.

const reset = "margin: 0";

const root = [
  reset,
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  "column-gap: 8px",
  "row-gap: 8px",
  "width: 100%",
  "padding: 0",
  "box-sizing: border-box",
].join("; ");

const cellBase = [
  reset,
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 10px",
  "padding: 14px 14px 12px",
  "border-radius: 10px",
  "color: #ffffff",
  "box-sizing: border-box",
].join("; ");

const audienceStyle = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 13px",
  "font-weight: 700",
  "letter-spacing: 0.08em",
  "text-transform: uppercase",
  "line-height: 1",
].join("; ");

const hintStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.35",
  "opacity: 0.92",
].join("; ");

const listStyle = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
  "padding: 0",
  "list-style: none",
].join("; ");

const chipStyle = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 11.5px",
  "font-weight: 500",
  "letter-spacing: -0.01em",
  "line-height: 1.25",
  "padding: 4px 6px",
  "border-radius: 6px",
  "background: rgba(255, 255, 255, 0.18)",
  "border: 1px solid rgba(255, 255, 255, 0.28)",
  "color: #ffffff",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");

// Saturated mid-tone fills (Tailwind ~600 range) — white text reads in
// both themes. Same palette family as StatusClassStrip.
const audiences = [
  {
    name: "Browser",
    hint: "The browser enforces this header.",
    headers: [
      "Set-Cookie",
      "Strict-Transport-Security",
      "Content-Security-Policy",
      "Permissions-Policy",
    ],
    bg: "#2563eb", // blue-600
  },
  {
    name: "Infrastructure",
    hint: "CDNs and proxies act on this header.",
    headers: ["Cache-Control", "Vary", "Content-Encoding", "Retry-After"],
    bg: "#ea580c", // orange-600
  },
  {
    name: "Application",
    hint: "Your application code reads this header.",
    headers: [
      "Authorization",
      "Idempotency-Key",
      "If-None-Match",
      "Content-Type",
    ],
    bg: "#16a34a", // green-600
  },
];
---

<div class="not-content has-root" style={root}>
  {
    audiences.map((a) => (
      <div style={`${cellBase}; background: ${a.bg};`}>
        <span style={audienceStyle}>{a.name}</span>
        <span style={hintStyle}>{a.hint}</span>
        <ul style={listStyle}>
          {a.headers.map((h) => (
            <li style={chipStyle}>{h}</li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<style>
  /* Drop to a single column on narrow viewports — only three cells, so
     no orphan-row situation can arise; each cell keeps its full chip
     list intact. */
  @media (max-width: 560px) {
    .has-root {
      grid-template-columns: 1fr !important;
    }
  }
</style>
