---
// TokenAtRest — Chapter 058 Lesson 1, "Why the token is hashed at rest".
//
// The one takeaway: the raw invitation token and the value the database stores
// are in TWO DIFFERENT TRUST ZONES, and the database is the weaker one. The same
// secret forks to two destinations:
//
//   raw token ──► in the email URL ──► reaches Bob   (only live copy, sensitive)
//             └─► sha256(...) ──► invitation.tokenHash ──► the database  (safe at rest)
//
// A read of the invitation table sees ONLY the hash, and SHA-256 is one-way —
// you can go token → hash, never hash → token — so that read can't reconstruct a
// working accept URL. That's the whole payoff, made visual.
//
// Colour language: amber = the live secret, handle with care (the raw token and
// its email path); green = safe at rest (the hash and the database). The fork
// reads as "one secret, two zones".
//
// Engine: plain HTML + CSS — the diagrams index's pick for a colour-coded,
// callout-annotated illustration, and the grammar this chapter's sibling figure
// (InvitationHandoff) and Ch049's TwoBodySplit share: nodes + chevrons, a
// saturated accent per zone, theme-aware via Starlight CSS variables + color-mix
// so it reads on both the light and dark Figure card. `.not-content` drops
// Starlight prose styling; a `margin: 0` reset on every node defeats the
// prose-margin injection. On a wide Figure it's a source card above two
// destination lanes; below ~620px the lanes stack. <Figure> + caption come from
// the MDX, not here.

// Saturated mid-tones (Tailwind 600-range) that read white-on-fill in both
// themes. AMBER = the live raw secret; GREEN = safe-at-rest hash.
const AMBER = "#d97706";
const GREEN = "#16a34a";

const ALT =
	"The raw invitation token forks to two destinations: along the amber path it goes into the emailed URL and reaches Bob, the only live copy of the secret; along the green path it is run through SHA-256 and only the resulting hash is stored in the invitation.tokenHash column in the database. A read of that database column sees only the hash, and because SHA-256 is one-way it cannot be turned back into the token, so the read cannot rebuild a working accept URL.";
---

<div class="tar not-content" role="img" aria-label={ALT} style={`--amber:${AMBER};--green:${GREEN}`}>
	{/* ── The single source: one secret, in server memory ─────────────────── */}
	<div class="tar-source">
		<span class="tar-source-eyebrow">in server memory</span>
		<span class="tar-source-title tar-mono">raw invitation token</span>
		<span class="tar-source-sub">32 random bytes · the secret</span>
	</div>

	{/* The fork: one secret splits toward two trust zones. The grid mirrors
	    .tar-lanes (same columns + gap) so each cell's centre sits over its lane. */}
	<div class="tar-fork" aria-hidden="true">
		<span class="tar-fork-stem"></span>
		<span class="tar-fork-cell">
			<span class="tar-fork-rail tar-fork-rail-r"></span>
			<span class="tar-fork-drop tar-fork-drop-l"></span>
		</span>
		<span class="tar-fork-cell">
			<span class="tar-fork-rail tar-fork-rail-l"></span>
			<span class="tar-fork-drop tar-fork-drop-r"></span>
		</span>
	</div>

	{/* ── Two destinations, side by side — two different trust zones ───────── */}
	<div class="tar-lanes">
		{/* Lane A · the live secret leaves in the email URL. */}
		<div class="tar-lane tar-lane-amber">
			<span class="tar-edge tar-mono">in the email URL</span>
			<div class="tar-dest tar-dest-amber">
				<span class="tar-dest-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
						<rect x="2" y="5" width="20" height="14" rx="2"></rect>
						<path d="m3 7 9 6 9-6"></path>
					</svg>
				</span>
				<span class="tar-dest-title">reaches Bob</span>
				<span class="tar-dest-sub">his inbox · the link</span>
			</div>
			<span class="tar-note tar-note-amber">
				the <strong>only</strong> live copy of the raw secret outside server memory
			</span>
		</div>

		{/* Lane B · only the hash is written to the database. */}
		<div class="tar-lane tar-lane-green">
			<span class="tar-hash tar-mono">sha256(token)</span>
			<span class="tar-edge tar-mono">→ invitation.tokenHash</span>
			<div class="tar-dest tar-dest-green">
				<span class="tar-dest-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
						<ellipse cx="12" cy="5" rx="8" ry="3"></ellipse>
						<path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5"></path>
						<path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6"></path>
					</svg>
				</span>
				<span class="tar-dest-title">the database</span>
				<span class="tar-dest-sub">stores the hash, never the token</span>
			</div>
			<span class="tar-note tar-note-green tar-note-loud">
				a read sees <strong>only this hash</strong> — it can&rsquo;t rebuild a working accept URL
			</span>
		</div>
	</div>

	{/* The one-way law that makes the green zone safe. */}
	<div class="tar-oneway">
		<span class="tar-oneway-icon" aria-hidden="true">
			<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 12h14"></path>
				<path d="m13 6 6 6-6 6"></path>
			</svg>
		</span>
		<span><strong>SHA-256 is one-way:</strong> token <span class="tar-mono">→</span> hash, never hash <span class="tar-mono">→</span> token</span>
	</div>
</div>

<style>
	.tar {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
		width: 100%;
		max-width: 600px;
		margin-inline: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.tar * {
		box-sizing: border-box;
		margin: 0;
	}
	.tar-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
	}

	/* ── Source: the one secret, neutral chrome (it belongs to no zone yet) ── */
	.tar-source {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		padding: 10px 18px;
		text-align: center;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-gray-4, #b0b7c3);
		background: color-mix(in srgb, var(--sl-color-gray-5, #94a3b8) 12%, var(--sl-color-bg, #fff));
	}
	.tar-source-eyebrow {
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.tar-source-title {
		font-size: 15px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
	}
	.tar-source-sub {
		font-size: 11px;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── The fork: stem down from the source, split, drop into each lane ─────
	   The grid mirrors .tar-lanes (same columns + gap), so each cell's centre
	   coincides with the lane box centre below it at any width. Per cell: a
	   half-rail from the cell centre to the inner edge plus half the gap (so the
	   two halves meet over the gap's midpoint = the stem), and a vertical drop. */
	.tar-fork {
		position: relative;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
		width: 100%;
		height: 26px;
	}
	.tar-fork-stem {
		position: absolute;
		top: 0;
		left: 50%;
		width: 2px;
		height: 13px;
		background: var(--sl-color-gray-4, #b0b7c3);
		transform: translateX(-50%);
		z-index: 1;
	}
	.tar-fork-cell {
		position: relative;
	}
	.tar-fork-rail {
		position: absolute;
		top: 12px;
		height: 2px;
		background: var(--sl-color-gray-4, #b0b7c3);
	}
	/* left cell extends right toward the gap midpoint; right cell extends left */
	.tar-fork-rail-r {
		left: 50%;
		right: -8px;
	}
	.tar-fork-rail-l {
		right: 50%;
		left: -8px;
	}
	.tar-fork-drop {
		position: absolute;
		top: 12px;
		left: 50%;
		width: 2px;
		height: 14px;
		transform: translateX(-50%);
	}
	.tar-fork-drop-l {
		background: color-mix(in srgb, var(--amber) 70%, var(--sl-color-gray-4, #b0b7c3));
	}
	.tar-fork-drop-r {
		background: color-mix(in srgb, var(--green) 70%, var(--sl-color-gray-4, #b0b7c3));
	}

	/* ── The two lanes ─────────────────────────────────────────────────────── */
	.tar-lanes {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
		width: 100%;
		align-items: start;
	}
	.tar-lane {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 7px;
		padding: 12px 12px 11px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.tar-lane-amber {
		border-color: color-mix(in srgb, var(--amber) 40%, transparent);
		background: color-mix(in srgb, var(--amber) 7%, var(--sl-color-bg, #fff));
	}
	.tar-lane-green {
		border-color: color-mix(in srgb, var(--green) 40%, transparent);
		background: color-mix(in srgb, var(--green) 7%, var(--sl-color-bg, #fff));
	}

	/* The labelled edge between source and destination. */
	.tar-edge {
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.3;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
	}

	/* The hash transform pill (green lane only). */
	.tar-hash {
		padding: 3px 10px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: 700;
		line-height: 1.3;
		white-space: nowrap;
		color: color-mix(in srgb, var(--green) 82%, var(--sl-color-white, #14532d));
		background: color-mix(in srgb, var(--green) 16%, transparent);
		border: 1px solid color-mix(in srgb, var(--green) 45%, transparent);
	}

	/* Destination card — mailbox / database. */
	.tar-dest {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		width: 100%;
		padding: 9px 8px;
		text-align: center;
		border-radius: 10px;
		border: 1.5px solid transparent;
	}
	.tar-dest-amber {
		color: color-mix(in srgb, var(--amber) 78%, var(--sl-color-white, #1e293b));
		border-color: color-mix(in srgb, var(--amber) 55%, transparent);
		background: color-mix(in srgb, var(--amber) 14%, var(--sl-color-bg, #fff));
	}
	.tar-dest-green {
		color: color-mix(in srgb, var(--green) 78%, var(--sl-color-white, #1e293b));
		border-color: color-mix(in srgb, var(--green) 55%, transparent);
		background: color-mix(in srgb, var(--green) 14%, var(--sl-color-bg, #fff));
	}
	.tar-dest-icon {
		display: inline-flex;
		line-height: 0;
	}
	.tar-dest-title {
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
	}
	.tar-dest-sub {
		font-size: 10.5px;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* Per-lane note beneath the destination. */
	.tar-note {
		font-size: 11px;
		line-height: 1.35;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
	}
	.tar-note strong {
		font-weight: 700;
	}
	.tar-note-amber strong {
		color: color-mix(in srgb, var(--amber) 70%, var(--sl-color-text));
	}
	/* The loud, highlighted DB-read callout — the figure's punchline. */
	.tar-note-loud {
		padding: 6px 9px;
		border-radius: 8px;
		font-weight: 500;
		color: color-mix(in srgb, var(--green) 30%, var(--sl-color-text));
		background: color-mix(in srgb, var(--green) 14%, transparent);
		border: 1px solid color-mix(in srgb, var(--green) 35%, transparent);
	}
	.tar-note-loud strong {
		color: color-mix(in srgb, var(--green) 72%, var(--sl-color-text));
	}

	/* ── The one-way law band ──────────────────────────────────────────────── */
	.tar-oneway {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 7px;
		margin-top: 14px;
		padding: 7px 14px;
		border-radius: 999px;
		font-size: 12px;
		line-height: 1.3;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}
	.tar-oneway strong {
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}
	.tar-oneway .tar-mono {
		font-weight: 700;
	}
	.tar-oneway-icon {
		display: inline-flex;
		flex: 0 0 auto;
		line-height: 0;
		color: var(--sl-color-gray-3, #94a3b8);
	}

	/* ── Narrow Figure: stack the lanes; the fork becomes a single spine ───── */
	@media (max-width: 620px) {
		.tar-lanes {
			grid-template-columns: 1fr;
			gap: 12px;
			max-width: 320px;
		}
		.tar-fork {
			grid-template-columns: 1fr;
			height: 16px;
			max-width: 320px;
		}
		.tar-fork-rail,
		.tar-fork-drop {
			display: none;
		}
		.tar-fork-stem {
			height: 16px;
		}
		.tar-oneway {
			margin-top: 12px;
		}
	}
</style>
