---
// InvitationHandoff — Chapter 058 Lesson 1, "the invitation and the member are
// sequential, not joined".
//
// The one takeaway: on accept, TWO rows are written — the invitation flips to
// 'accepted' (acceptedAt set) and a NEW member row is inserted with
// role = invitation.role — but the two tables are NOT foreign-keyed to each
// other. The normalization instinct is to add a memberId FK on invitation; this
// figure kills that instinct. The boxes sit side by side with the FK that does
// NOT exist drawn as a SEVERED connector in the gap (crossed out, "no foreign
// key"). The real, historical linkage lives one level down: the audit log's
// 'invitation.accepted' event carries the new memberId in its payload.
//
//   [ invitation → accepted ]   ✕no FK✕   [ member (new) ]
//             └────────── dashed ──────────┘
//              audit log · invitation.accepted { memberId }
//
// Engine: plain HTML + CSS — the diagrams index's pick for a colour-coded,
// callout-annotated illustration, and the grammar this lesson's sibling figure
// (TokenAtRest) shares: nodes + connectors, a saturated accent per role,
// theme-aware via Starlight CSS variables + color-mix so it reads on both the
// light and dark Figure card. An <ArrowDiagram> is the wrong tool here: the whole
// point is the ABSENCE of an arrow between the two boxes, plus a dashed bracket
// down to a third element — easier and sturdier in hand-laid CSS than in
// leader-line. `.not-content` drops Starlight prose styling; a `margin: 0` reset
// on every node defeats the prose-margin injection. On a wide Figure the two row
// cards sit side by side over one audit card; below ~560px they stack and the
// severed-FK band turns into a stacked "still no FK" note. <Figure> + caption
// come from the MDX, not here.

// Saturated mid-tones (Tailwind 600-range) that read on both themes. BLUE = the
// invitation row (the offer, now resolved); VIOLET = the member row (the new
// fact); SLATE = the audit log (the neutral system-of-record).
const BLUE = "#2563eb";
const VIOLET = "#7c3aed";

const ALT =
	"When an invitation is accepted, two rows are written: the invitation row flips to status accepted with acceptedAt set, and a brand-new member row is inserted with role equal to the invitation's role. The two boxes sit side by side and are deliberately not connected by a foreign key — the connector between them is shown severed and labelled no foreign key. Instead, both rows link down to a single audit-log entry, the invitation.accepted event, whose payload carries the new memberId. The audit trail, not a cross-table foreign key, records which invitation produced which membership.";
---

<div
	class="ih not-content"
	role="img"
	aria-label={ALT}
	style={`--blue:${BLUE};--violet:${VIOLET}`}
>
	{/* ── The two rows written at accept time, side by side ─────────────────── */}
	<div class="ih-rows">
		{/* Left row · the invitation, resolving to its terminal state. */}
		<div class="ih-card ih-card-blue">
			<span class="ih-eyebrow ih-eyebrow-blue">existing row · updated</span>
			<span class="ih-table ih-mono">invitation</span>
			<span class="ih-field">
				<span class="ih-key ih-mono">status</span>
				<span class="ih-arrow" aria-hidden="true">→</span>
				<span class="ih-val ih-val-blue ih-mono">accepted</span>
			</span>
			<span class="ih-field">
				<span class="ih-key ih-mono">acceptedAt</span>
				<span class="ih-arrow" aria-hidden="true">→</span>
				<span class="ih-val ih-mono">now()</span>
			</span>
		</div>

		{/* The gap · the foreign key that does NOT exist. */}
		<div class="ih-sever" aria-hidden="true">
			<span class="ih-sever-line ih-sever-line-l"></span>
			<span class="ih-sever-x">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
					<path d="M6 6l12 12M18 6 6 18"></path>
				</svg>
			</span>
			<span class="ih-sever-line ih-sever-line-r"></span>
			<span class="ih-sever-label">no foreign key</span>
		</div>

		{/* Right row · the brand-new membership. */}
		<div class="ih-card ih-card-violet">
			<span class="ih-eyebrow ih-eyebrow-violet">new row · inserted</span>
			<span class="ih-table ih-mono">member</span>
			<span class="ih-field">
				<span class="ih-key ih-mono">role</span>
				<span class="ih-arrow" aria-hidden="true">←</span>
				<span class="ih-val ih-val-violet ih-mono">invitation.role</span>
			</span>
			<span class="ih-field">
				<span class="ih-key ih-mono">userId</span>
				<span class="ih-arrow" aria-hidden="true">←</span>
				<span class="ih-val ih-mono">the accepter</span>
			</span>
		</div>
	</div>

	{/* The dashed bracket: both rows descend into the one thing that DOES link
	    them — the audit log. Mirrors .ih-rows columns so each leg lands under its
	    card; the centre stem drops into the audit card below. */}
	<div class="ih-bracket" aria-hidden="true">
		<span class="ih-bracket-leg ih-bracket-leg-l"></span>
		<span class="ih-bracket-top"></span>
		<span class="ih-bracket-leg ih-bracket-leg-r"></span>
		<span class="ih-bracket-stem"></span>
	</div>

	{/* ── The real linkage: one audit-log entry carrying the new memberId ───── */}
	<div class="ih-audit">
		<span class="ih-audit-icon" aria-hidden="true">
			<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
				<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
				<path d="M14 2v6h6"></path>
				<path d="M8 13h8M8 17h6"></path>
			</svg>
		</span>
		<span class="ih-audit-text">
			<span class="ih-audit-title">audit log</span>
			<span class="ih-audit-event ih-mono">
				invitation.accepted
				<span class="ih-audit-payload">&#123; memberId &#125;</span>
			</span>
		</span>
		<span class="ih-audit-note">the handoff is recorded <strong>here</strong>, not by a column</span>
	</div>
</div>

<style>
	.ih {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
		width: 100%;
		max-width: 640px;
		margin-inline: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.ih * {
		box-sizing: border-box;
		margin: 0;
	}
	.ih-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
	}

	/* ── The two side-by-side row cards (and the severed FK between them) ───── */
	.ih-rows {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 12px;
		width: 100%;
	}
	.ih-card {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 5px;
		padding: 12px 14px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.ih-card-blue {
		border-color: color-mix(in srgb, var(--blue) 42%, transparent);
		background: color-mix(in srgb, var(--blue) 7%, var(--sl-color-bg, #fff));
	}
	.ih-card-violet {
		border-color: color-mix(in srgb, var(--violet) 42%, transparent);
		background: color-mix(in srgb, var(--violet) 7%, var(--sl-color-bg, #fff));
	}
	.ih-eyebrow {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 2px 7px;
		border-radius: 999px;
	}
	.ih-eyebrow-blue {
		color: color-mix(in srgb, var(--blue) 82%, var(--sl-color-white, #1e3a8a));
		background: color-mix(in srgb, var(--blue) 14%, transparent);
	}
	.ih-eyebrow-violet {
		color: color-mix(in srgb, var(--violet) 82%, var(--sl-color-white, #4c1d95));
		background: color-mix(in srgb, var(--violet) 14%, transparent);
	}
	.ih-table {
		font-size: 15px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
	}
	.ih-field {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		line-height: 1.3;
	}
	.ih-key {
		color: var(--sl-color-gray-2, #475569);
	}
	.ih-arrow {
		color: var(--sl-color-gray-3, #94a3b8);
		font-weight: 700;
	}
	.ih-val {
		font-weight: 700;
		color: var(--sl-color-gray-1, #334155);
	}
	.ih-val-blue {
		color: color-mix(in srgb, var(--blue) 78%, var(--sl-color-white, #1e293b));
	}
	.ih-val-violet {
		color: color-mix(in srgb, var(--violet) 78%, var(--sl-color-white, #1e293b));
	}

	/* ── The severed foreign key: two stubs that DON'T meet, an ✕, a label ─── */
	.ih-sever {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		padding: 0 2px;
	}
	.ih-sever-line {
		position: absolute;
		top: calc(50% - 9px);
		width: 16px;
		height: 0;
		border-top: 2px dashed var(--sl-color-gray-4, #b0b7c3);
	}
	.ih-sever-line-l {
		right: 100%;
		margin-right: 1px;
	}
	.ih-sever-line-r {
		left: 100%;
		margin-left: 1px;
	}
	.ih-sever-x {
		display: inline-flex;
		line-height: 0;
		color: var(--sl-color-red, #dc2626);
	}
	.ih-sever-label {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.02em;
		white-space: nowrap;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--sl-color-red, #dc2626) 78%, var(--sl-color-text));
	}

	/* ── The dashed bracket from both cards down into the audit card ───────── */
	.ih-bracket {
		position: relative;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: 12px;
		width: 100%;
		height: 26px;
	}
	.ih-bracket-leg {
		position: absolute;
		top: 0;
		width: 0;
		height: 13px;
		border-left: 2px dashed color-mix(in srgb, var(--sl-color-gray-4, #b0b7c3) 80%, transparent);
	}
	/* legs drop from roughly the centre of each card column */
	.ih-bracket-leg-l {
		left: 25%;
	}
	.ih-bracket-leg-r {
		right: 25%;
	}
	.ih-bracket-top {
		position: absolute;
		top: 13px;
		left: 25%;
		right: 25%;
		height: 0;
		border-top: 2px dashed color-mix(in srgb, var(--sl-color-gray-4, #b0b7c3) 80%, transparent);
	}
	.ih-bracket-stem {
		position: absolute;
		top: 13px;
		left: 50%;
		width: 0;
		height: 13px;
		border-left: 2px dashed color-mix(in srgb, var(--sl-color-gray-4, #b0b7c3) 80%, transparent);
		transform: translateX(-50%);
	}

	/* ── The audit-log entry: the one place the linkage actually lives ─────── */
	.ih-audit {
		display: flex;
		align-items: center;
		gap: 11px;
		width: 100%;
		max-width: 460px;
		padding: 11px 15px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-4, #b0b7c3);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
	}
	.ih-audit-icon {
		display: inline-flex;
		flex: 0 0 auto;
		line-height: 0;
		color: var(--sl-color-gray-2, #475569);
	}
	.ih-audit-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		flex: 1 1 auto;
		min-width: 0;
	}
	.ih-audit-title {
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.ih-audit-event {
		display: inline-flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 6px;
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
	}
	.ih-audit-payload {
		font-size: 11.5px;
		font-weight: 600;
		padding: 1px 7px;
		border-radius: 6px;
		color: color-mix(in srgb, var(--violet) 72%, var(--sl-color-text));
		background: color-mix(in srgb, var(--violet) 13%, transparent);
		border: 1px solid color-mix(in srgb, var(--violet) 32%, transparent);
	}
	.ih-audit-note {
		flex: 0 0 auto;
		max-width: 130px;
		font-size: 10.5px;
		line-height: 1.3;
		text-align: right;
		color: var(--sl-color-gray-3, #64748b);
	}
	.ih-audit-note strong {
		font-weight: 700;
		color: var(--sl-color-gray-2, #475569);
	}

	/* ── Narrow Figure: stack the two cards; collapse the geometry ─────────── */
	@media (max-width: 560px) {
		.ih-rows {
			grid-template-columns: 1fr;
			gap: 0;
			max-width: 340px;
		}
		.ih-card {
			align-items: center;
			text-align: center;
		}
		/* The severed FK becomes a stacked between-cards note. */
		.ih-sever {
			flex-direction: row;
			gap: 6px;
			padding: 9px 0;
		}
		.ih-sever-line {
			position: static;
			width: 18px;
			margin: 0;
		}
		.ih-sever-label {
			font-size: 9.5px;
		}
		/* Single centred spine into the audit card. */
		.ih-bracket {
			grid-template-columns: 1fr;
			height: 16px;
			max-width: 340px;
		}
		.ih-bracket-leg,
		.ih-bracket-top {
			display: none;
		}
		.ih-bracket-stem {
			top: 0;
			height: 16px;
		}
		.ih-audit {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 6px;
			max-width: 340px;
		}
		.ih-audit-event {
			justify-content: center;
		}
		.ih-audit-note {
			max-width: none;
			text-align: center;
		}
	}
</style>
