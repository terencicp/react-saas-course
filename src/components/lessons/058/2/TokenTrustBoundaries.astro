---
// TokenTrustBoundaries — Chapter 058 Lesson 2 ("Minting the signed accept link").
//
// Makes "the raw token is allowed in exactly ONE of three places" a single
// glanceable picture. Three side-by-side cards, each a place the secret could
// surface outside server memory, with a check-or-cross verdict on each:
//
//   Database row   ─✗  raw token never stored — only sha256(token)
//   Server logs    ─✗  redacted at the logger (token=[redacted], sig=[redacted])
//   Email body     ─✓  the one place it belongs — its destination
//
// The first two cards read as "kept out": muted chrome, a red verdict, and the
// raw token shown struck-through / redacted. The third reads as "delivered": a
// green verdict and the real token present and highlighted inside the accept
// URL. Reading left → right, the asymmetry IS the lesson — one secret, three
// boundaries, one legitimate exit.
//
// Pure HTML+CSS per the diagrams guide (an annotated illustration with
// colour-coded verdicts, not a graph engine), modeled on this chapter family's
// 057/5 ThreeLayerDefense. `not-content` + a margin:0 reset on every node
// defeats Starlight's injected prose margins. Goes inside <Figure>, which the
// MDX supplies along with the caption.
//
// Colour language: red (#dc2626) = the secret kept out; green (#16a34a) = the
// secret delivered to where it belongs. Saturated mid-tones reused verbatim in
// light + dark since the colour itself is the signal; tints derived with
// color-mix so they track the page background. Card chrome stays neutral grey.

const xIcon = `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>`;
const checkIcon = `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
---

<div class="ttb not-content">
	{/* ── Card 1 — Database row: only the hash lands, never the raw token ── */}
	<div class="ttb-card ttb-card--out">
		<div class="ttb-head">
			<span class="ttb-head-title">Database row</span>
			<span class="ttb-head-sub">invitation table</span>
		</div>

		<div class="ttb-body">
			<div class="ttb-rows">
				<div class="ttb-row">
					<span class="ttb-key">email</span>
					<span class="ttb-val">bob@acme.com</span>
				</div>
				<div class="ttb-row">
					<span class="ttb-key">tokenHash</span>
					<span class="ttb-val ttb-val--hash">3af9c2…</span>
				</div>
				<div class="ttb-row ttb-row--struck">
					<span class="ttb-key">token</span>
					<span class="ttb-val ttb-val--gone">Yk3f…</span>
				</div>
			</div>
		</div>

		<div class="ttb-verdict ttb-verdict--out">
			<span class="ttb-mark ttb-mark--x">
				<Fragment set:html={xIcon} />
			</span>
			<span class="ttb-verdict-text">
				raw token never stored — only <code>sha256(token)</code>
			</span>
		</div>
	</div>

	{/* ── Card 2 — Server logs / Sentry: query params redacted at the logger ── */}
	<div class="ttb-card ttb-card--out">
		<div class="ttb-head">
			<span class="ttb-head-title">Server logs / Sentry</span>
			<span class="ttb-head-sub">every breadcrumb</span>
		</div>

		<div class="ttb-body">
			<div class="ttb-log">
				<span class="ttb-log-meta">POST /actions/sendInvitation</span>
				<span class="ttb-log-url"
					>…/accept-invite?id=018f…<wbr />&amp;token=<span
						class="ttb-redacted">[redacted]</span
					><wbr />&amp;sig=<span class="ttb-redacted">[redacted]</span
					></span
				>
			</div>
		</div>

		<div class="ttb-verdict ttb-verdict--out">
			<span class="ttb-mark ttb-mark--x">
				<Fragment set:html={xIcon} />
			</span>
			<span class="ttb-verdict-text">
				redacted at the logger before any line is written
			</span>
		</div>
	</div>

	{/* ── Card 3 — Email body: the one legitimate exit, token present & live ── */}
	<div class="ttb-card ttb-card--in">
		<div class="ttb-head">
			<span class="ttb-head-title">Email body</span>
			<span class="ttb-head-sub">Bob&rsquo;s inbox</span>
		</div>

		<div class="ttb-body">
			<div class="ttb-email">
				<span class="ttb-email-subject">You&rsquo;re invited to Acme</span>
				<span class="ttb-email-btn">Accept invite</span>
				<span class="ttb-email-url"
					>…?token=<span class="ttb-token">Yk3f…</span></span
				>
			</div>
		</div>

		<div class="ttb-verdict ttb-verdict--in">
			<span class="ttb-mark ttb-mark--check">
				<Fragment set:html={checkIcon} />
			</span>
			<span class="ttb-verdict-text">
				the one place it belongs — its destination
			</span>
		</div>
	</div>
</div>

<style>
	.ttb {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		align-items: stretch;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		/* Saturated mid-tones — the colour is the signal, identical in both themes. */
		--ttb-red: #dc2626;
		--ttb-green: #16a34a;
	}

	/* ── Card shell ─────────────────────────────────────────────────────── */
	.ttb-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		min-width: 0;
		border-radius: 12px;
		overflow: hidden;
		margin: 0;
	}

	/* Cards 1 & 2 — "kept out": muted neutral chrome, red verdict. */
	.ttb-card--out {
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 22%, transparent);
	}

	/* Card 3 — "delivered": green chrome, lifted so it reads as the exception. */
	.ttb-card--in {
		border: 1.5px solid color-mix(in srgb, var(--ttb-green) 55%, transparent);
		background: color-mix(in srgb, var(--ttb-green) 8%, transparent);
	}

	/* ── Card header ────────────────────────────────────────────────────── */
	.ttb-head {
		display: flex;
		flex-direction: column;
		gap: 1px;
		padding: 9px 12px;
		border-bottom: 1px solid
			color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent);
		margin: 0;
	}
	.ttb-card--in .ttb-head {
		border-bottom-color: color-mix(in srgb, var(--ttb-green) 35%, transparent);
	}

	.ttb-head-title {
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.ttb-head-sub {
		font-size: 11px;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── Card body (the representation of each place) ───────────────────── */
	.ttb-body {
		flex: 1 1 auto;
		display: flex;
		padding: 11px 12px;
		margin: 0;
	}

	/* Card 1 — a mini row stack mimicking the table row. */
	.ttb-rows {
		display: flex;
		flex-direction: column;
		gap: 5px;
		width: 100%;
		margin: 0;
	}
	.ttb-row {
		display: flex;
		align-items: baseline;
		gap: 8px;
		min-width: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		margin: 0;
	}
	.ttb-key {
		flex: 0 0 auto;
		width: 70px;
		font-size: 11px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.ttb-val {
		min-width: 0;
		font-size: 12px;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		margin: 0;
	}
	.ttb-val--hash {
		color: color-mix(in srgb, var(--ttb-green) 70%, var(--sl-color-text));
	}
	/* The raw-token row is struck out — it never reaches the table. */
	.ttb-row--struck {
		opacity: 0.62;
	}
	.ttb-val--gone {
		color: color-mix(in srgb, var(--ttb-red) 78%, var(--sl-color-text));
		text-decoration: line-through;
		text-decoration-color: color-mix(
			in srgb,
			var(--ttb-red) 80%,
			transparent
		);
		text-decoration-thickness: 1.5px;
	}

	/* Card 2 — a log line with the secret params redacted. */
	.ttb-log {
		display: flex;
		flex-direction: column;
		gap: 5px;
		width: 100%;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		margin: 0;
	}
	.ttb-log-meta {
		font-size: 11px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.ttb-log-url {
		font-size: 11.5px;
		line-height: 1.45;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		overflow-wrap: anywhere;
		word-break: break-word;
		margin: 0;
	}
	/* The redacted placeholders — struck-through, muted: the secret was withheld. */
	.ttb-redacted {
		display: inline;
		color: color-mix(in srgb, var(--ttb-red) 80%, var(--sl-color-text));
		text-decoration: line-through;
		text-decoration-color: color-mix(
			in srgb,
			var(--ttb-red) 70%,
			transparent
		);
		text-decoration-thickness: 1.5px;
		margin: 0;
	}

	/* Card 3 — a mini email card; the accept URL carries the live token. */
	.ttb-email {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 8px;
		width: 100%;
		margin: 0;
	}
	.ttb-email-subject {
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.ttb-email-btn {
		display: inline-flex;
		align-items: center;
		padding: 5px 12px;
		border-radius: 7px;
		font-size: 11.5px;
		font-weight: 700;
		color: #ffffff;
		background: var(--ttb-green);
		margin: 0;
	}
	.ttb-email-url {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11.5px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 100%;
		margin: 0;
	}
	/* The real token — present and highlighted; this is its legitimate exit. */
	.ttb-token {
		color: color-mix(in srgb, var(--ttb-green) 82%, var(--sl-color-text));
		background: color-mix(in srgb, var(--ttb-green) 16%, transparent);
		border-radius: 4px;
		padding: 0 3px;
		font-weight: 800;
		margin: 0;
	}

	/* ── Verdict strip (one per card, bottom edge) ──────────────────────── */
	.ttb-verdict {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 9px 12px;
		border-top: 1px solid transparent;
		margin: 0;
	}
	.ttb-verdict--out {
		background: color-mix(in srgb, var(--ttb-red) 9%, transparent);
		border-top-color: color-mix(in srgb, var(--ttb-red) 28%, transparent);
	}
	.ttb-verdict--in {
		background: color-mix(in srgb, var(--ttb-green) 13%, transparent);
		border-top-color: color-mix(in srgb, var(--ttb-green) 40%, transparent);
	}

	.ttb-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		flex: 0 0 auto;
		border-radius: 999px;
		margin: 0;
	}
	.ttb-mark--x {
		background: var(--ttb-red);
		color: #ffffff;
	}
	.ttb-mark--check {
		background: var(--ttb-green);
		color: #ffffff;
	}

	.ttb-verdict-text {
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	/* The inline sha256(token) code in card 1's verdict — clean label, no pill. */
	.ttb-verdict-text code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11px;
		font-weight: 700;
		color: color-mix(in srgb, var(--ttb-green) 72%, var(--sl-color-text));
		background: transparent;
		border: 0;
		padding: 0;
		margin: 0;
	}

	/* Narrow viewports: three side-by-side cards crush. Stack to one column. */
	@media (max-width: 620px) {
		.ttb {
			grid-template-columns: 1fr;
			gap: 11px;
		}
	}
</style>
