---
// SignedUrlAnatomy — Chapter 058 Lesson 2 ("Minting the signed accept link").
//
// Makes the two-layer auth model SPATIAL: the token is "the credential", the
// sig is "the doorman". Two panels side by side (stacking on narrow viewports):
//
//   Panel A — Anatomy. The accept URL laid out as four joined segments, each
//   tinted and captioned underneath:
//       base   (neutral) — from NEXT_PUBLIC_APP_URL, never the request host
//       id     (neutral) — which invitation row; a public key, not a secret
//       token  (green)   — THE CREDENTIAL, verified by hash lookup
//       sig    (blue)    — THE DOORMAN, rejects forgeries before the DB
//   Under the bar, the canonical signing formula.
//
//   Panel B — Verify side (built next lesson). A short vertical flow:
//       1. recompute the HMAC from id + token under the same secret
//       2. constant-time compare against the sig in the URL
//       3. mismatch → reject, BEFORE any DB lookup  ← the gate
//   Step 3 is the gate; the DB-side lookup sits visibly behind it.
//
// Colour language carries the whole idea: green (#16a34a) = the credential
// (matches 058/2 TokenTrustBoundaries, where the token's home is green); blue
// (#2563eb) = the doorman / structural pre-check (the AnnotatedCode "blue"
// default in this chapter family). base + id stay neutral grey — public, not
// secret. Saturated mid-tones reused verbatim in light + dark since the colour
// itself is the signal; tints derived with color-mix so they track the page
// background.
//
// Pure HTML+CSS per the diagrams guide (an annotated illustration with
// colour-coded segments + callouts, not a graph engine), modeled on this
// chapter family's 057/5 ThreeLayerDefense and 058/2 TokenTrustBoundaries.
// `not-content` + a margin:0 reset on every node defeats Starlight's injected
// prose margins. Goes inside <Figure>, which the MDX supplies with the caption.

// The four URL segments, left → right in the order they appear in the string.
// `kind` selects the tint; `lead` is the joining punctuation shown muted.
const segments = [
	{
		kind: 'base',
		key: 'base',
		lead: '',
		value: 'https://app.acme.com/accept-invite',
		role: 'public path',
		note: 'from NEXT_PUBLIC_APP_URL — never the request host',
	},
	{
		kind: 'id',
		key: 'id',
		lead: '?',
		value: 'id=018f…',
		role: 'public key',
		note: 'which invitation row — not a secret',
	},
	{
		kind: 'token',
		key: 'token',
		lead: '&',
		value: 'token=Yk3f…',
		role: 'the credential',
		note: 'the actual secret — verified by hash lookup',
	},
	{
		kind: 'sig',
		key: 'sig',
		lead: '&',
		value: 'sig=9b1c…',
		role: 'the doorman',
		note: 'HMAC of id + token — rejects forgeries before the DB',
	},
];

// Verify-side steps. Step 3 is the gate (`gate: true`).
const verifySteps = [
	{
		n: '1',
		text: 'Recompute the HMAC from id + token, same secret',
	},
	{
		n: '2',
		text: 'Constant-time compare against the sig in the URL',
	},
	{
		n: '3',
		text: 'Mismatch → reject immediately',
		gate: true,
	},
];

const xIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>`;
const lockIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><rect x="5" y="11" width="14" height="9" rx="2"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3"></path></svg>`;
---

<div class="sua not-content">
	{/* ── Panel A — Anatomy of the accept URL ──────────────────────────── */}
	<section class="sua-panel sua-panel--anatomy">
		<div class="sua-panel-tag">Anatomy of the accept URL</div>

		{/* The URL bar — four joined, tinted segments read as one string. */}
		<div class="sua-url">
			{
				segments.map((seg) => (
					<div class={`sua-seg sua-seg--${seg.kind}`}>
						{seg.lead && <span class="sua-lead">{seg.lead}</span>}
						<span class="sua-seg-val">{seg.value}</span>
					</div>
				))
			}
		</div>

		{/* One caption card per segment — a 2×2 grid, tint links each to its
		    segment above. */}
		<div class="sua-notes">
			{
				segments.map((seg) => (
					<div class={`sua-note sua-note--${seg.kind}`}>
						<span class="sua-note-head">
							<span class="sua-note-key">{seg.key}</span>
							<span class="sua-note-role">{seg.role}</span>
						</span>
						<span class="sua-note-text">{seg.note}</span>
					</div>
				))
			}
		</div>

		{/* The canonical signing payload, stated once. */}
		<div class="sua-formula">
			<span class="sua-formula-lhs">sig</span>
			<span class="sua-formula-eq">=</span>
			<span class="sua-formula-rhs"
				>base64url(HMAC-SHA256(<span class="sua-tok-secret">secret</span>,{' '}
				<span class="sua-tok-id">id</span> + <span class="sua-tok-dot"
					>'.'</span
				> + <span class="sua-tok-token">token</span>))</span
			>
		</div>
	</section>

	{/* ── Panel B — Verify side (built next lesson) ────────────────────── */}
	<section class="sua-panel sua-panel--verify">
		<div class="sua-panel-tag">
			Verify side <span class="sua-panel-tag-sub">— next lesson</span>
		</div>

		<div class="sua-flow">
			{
				verifySteps.map((step) => (
					<div class={`sua-step${step.gate ? ' sua-step--gate' : ''}`}>
						<span class="sua-step-n">
							{step.gate ? (
								<Fragment set:html={xIcon} />
							) : (
								step.n
							)}
						</span>
						<span class="sua-step-text">{step.text}</span>
					</div>
				))
			}

			{/* Everything DB-side sits BEHIND the gate. */}
			<div class="sua-gate-rail">
				<span class="sua-gate-rail-label">only valid sig gets past</span>
			</div>

			<div class="sua-behind">
				<span class="sua-behind-mark">
					<Fragment set:html={lockIcon} />
				</span>
				<span class="sua-behind-text">
					look up the row by <code>tokenHash</code>
				</span>
			</div>
		</div>
	</section>
</div>

<style>
	.sua {
		display: grid;
		/* Anatomy panel is wider; verify flow is a narrow column. */
		grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
		gap: 16px;
		align-items: stretch;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		/* Saturated mid-tones — the colour is the signal, identical in both themes. */
		--sua-green: #16a34a; /* the credential (the token) */
		--sua-blue: #2563eb; /* the doorman (the signature) */
	}

	/* ── Panel shell ────────────────────────────────────────────────────── */
	.sua-panel {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		min-width: 0;
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		border-radius: 12px;
		background: color-mix(in srgb, var(--sl-color-gray-5) 18%, transparent);
		padding: 13px 14px 14px;
		margin: 0;
	}

	.sua-panel-tag {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-2, #475569);
		margin: 0 0 11px;
	}
	.sua-panel-tag-sub {
		font-weight: 600;
		text-transform: none;
		letter-spacing: 0;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── Panel A: the URL bar ───────────────────────────────────────────── */
	.sua-url {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		gap: 5px;
		margin: 0;
	}

	.sua-seg {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 1px;
		min-width: 0;
		padding: 7px 9px;
		border-radius: 8px;
		border: 1.5px solid transparent;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.1;
		margin: 0;
	}
	.sua-lead {
		font-weight: 700;
		opacity: 0.55;
		margin: 0;
	}
	.sua-seg-val {
		min-width: 0;
		margin: 0;
	}

	/* base + id — public, neutral grey. */
	.sua-seg--base,
	.sua-seg--id {
		border-color: var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 40%, transparent);
		color: var(--sl-color-gray-1, #334155);
	}
	/* token — THE CREDENTIAL, green. */
	.sua-seg--token {
		border-color: color-mix(in srgb, var(--sua-green) 60%, transparent);
		background: color-mix(in srgb, var(--sua-green) 15%, transparent);
		color: color-mix(in srgb, var(--sua-green) 82%, var(--sl-color-text));
	}
	/* sig — THE DOORMAN, blue. */
	.sua-seg--sig {
		border-color: color-mix(in srgb, var(--sua-blue) 60%, transparent);
		background: color-mix(in srgb, var(--sua-blue) 15%, transparent);
		color: color-mix(in srgb, var(--sua-blue) 84%, var(--sl-color-text));
	}

	/* ── Panel A: caption cards under the bar (a 2×2 grid) ──────────────── */
	.sua-notes {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 7px;
		margin: 9px 0 0;
	}

	.sua-note {
		box-sizing: border-box;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 7px 9px;
		border-radius: 8px;
		border-left: 3px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 16%, transparent);
		margin: 0;
	}
	.sua-note-head {
		display: flex;
		align-items: baseline;
		gap: 7px;
		min-width: 0;
		margin: 0;
	}
	.sua-note-key {
		flex: 0 0 auto;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11.5px;
		font-weight: 800;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.sua-note-role {
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.sua-note-text {
		font-size: 11.5px;
		font-weight: 500;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* token + sig caption cards inherit their segment's tint. */
	.sua-note--token {
		border-left-color: var(--sua-green);
		background: color-mix(in srgb, var(--sua-green) 9%, transparent);
	}
	.sua-note--token .sua-note-key,
	.sua-note--token .sua-note-role {
		color: color-mix(in srgb, var(--sua-green) 80%, var(--sl-color-text));
	}
	.sua-note--sig {
		border-left-color: var(--sua-blue);
		background: color-mix(in srgb, var(--sua-blue) 9%, transparent);
	}
	.sua-note--sig .sua-note-key,
	.sua-note--sig .sua-note-role {
		color: color-mix(in srgb, var(--sua-blue) 84%, var(--sl-color-text));
	}

	/* ── Panel A: the signing formula ───────────────────────────────────── */
	.sua-formula {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 6px;
		margin: 12px 0 0;
		padding: 9px 11px;
		border-radius: 8px;
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 12%, transparent);
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 12px;
		line-height: 1.35;
	}
	.sua-formula-lhs {
		font-weight: 800;
		color: color-mix(in srgb, var(--sua-blue) 84%, var(--sl-color-text));
		margin: 0;
	}
	.sua-formula-eq {
		font-weight: 700;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.sua-formula-rhs {
		font-weight: 600;
		color: var(--sl-color-gray-1, #334155);
		overflow-wrap: anywhere;
		margin: 0;
	}
	.sua-tok-secret {
		font-weight: 800;
		color: color-mix(in srgb, var(--sl-color-orange, #ea580c) 88%, var(--sl-color-text));
		margin: 0;
	}
	.sua-tok-id {
		font-weight: 800;
		color: var(--sl-color-gray-1, #334155);
		margin: 0;
	}
	.sua-tok-dot {
		font-weight: 700;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.sua-tok-token {
		font-weight: 800;
		color: color-mix(in srgb, var(--sua-green) 82%, var(--sl-color-text));
		margin: 0;
	}

	/* ── Panel B: the verify-side flow ──────────────────────────────────── */
	.sua-flow {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
	}

	.sua-step {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 9px;
		min-width: 0;
		padding: 9px 11px;
		border-radius: 9px;
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 24%, transparent);
		margin: 0;
	}
	.sua-step-n {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 22px;
		height: 22px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: 800;
		color: #ffffff;
		background: var(--sua-blue);
		margin: 0;
	}
	.sua-step-text {
		font-size: 12px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	/* Step 3 is the gate — the rejection that fires before any DB work. */
	.sua-step--gate {
		border-color: color-mix(in srgb, var(--sua-blue) 60%, transparent);
		background: color-mix(in srgb, var(--sua-blue) 12%, transparent);
	}
	.sua-step--gate .sua-step-n {
		background: #dc2626;
	}
	.sua-step--gate .sua-step-text {
		font-weight: 700;
		color: color-mix(in srgb, var(--sua-blue) 84%, var(--sl-color-text));
	}

	/* The gate rail — the line everything DB-side must clear. */
	.sua-gate-rail {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 1px 0;
		padding: 0;
		border-top: 2px dashed color-mix(in srgb, var(--sua-blue) 55%, transparent);
	}
	.sua-gate-rail-label {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--sua-blue) 82%, var(--sl-color-text));
		background: var(--sl-color-bg-sidebar, #f6f7f9);
		padding: 0 8px;
		margin: -9px 0 0;
	}

	/* Behind the gate — muted; reached only after a valid sig. */
	.sua-behind {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 9px;
		min-width: 0;
		padding: 9px 11px;
		border-radius: 9px;
		border: 1.5px dashed var(--sl-color-gray-4, #94a3b8);
		background: transparent;
		opacity: 0.82;
		margin: 0;
	}
	.sua-behind-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 22px;
		height: 22px;
		border-radius: 999px;
		color: #ffffff;
		background: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.sua-behind-text {
		font-size: 12px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.sua-behind-text code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11px;
		font-weight: 700;
		color: var(--sl-color-gray-1, #334155);
		background: transparent;
		border: 0;
		padding: 0;
		margin: 0;
	}

	/* Narrow viewports: panels stack; the verify flow drops below the anatomy. */
	@media (max-width: 760px) {
		.sua {
			grid-template-columns: 1fr;
			gap: 12px;
		}
	}
</style>
