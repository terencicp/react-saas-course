---
/**
 * Senior-calls summary table for Lesson 058.5.
 *
 * Three columns: edge case → senior call → where the check lives. The third
 * column is the load-bearing axis the lesson foregrounds, so each enforcing
 * layer is rendered as a tinted badge keyed to one of three categories —
 * `db`, `action`, or `none` — the same three layers the Buckets exercise that
 * follows asks the student to sort into.
 */

type Layer = 'db' | 'action' | 'page' | 'none';

interface Row {
  case: string;
  call: string;
  layer: Layer;
  layerLabel: string;
  /** Terse phrase shown beside the layer badge. */
  where: string;
}

const layerNames: Record<Layer, string> = {
  db: 'DB',
  action: 'Action',
  page: 'Accept page',
  none: 'No check',
};

const rows: Row[] = [
  {
    case: 'Inviter removed before accept',
    call: 'Honor the invite',
    layer: 'none',
    layerLabel: layerNames.none,
    where: "the org's decision still stands",
  },
  {
    case: 'Inviter demoted before accept',
    call: 'Honor the snapshotted role',
    layer: 'none',
    layerLabel: layerNames.none,
    where: 'role is frozen on the row',
  },
  {
    case: 'Email mismatch (session ≠ invited)',
    call: 'Strict refuse, no "accept anyway"',
    layer: 'action',
    layerLabel: layerNames.action,
    where: 'action body, before any write',
  },
  {
    case: 'Double-click / two tabs',
    call: 'First wins, second is idempotent',
    layer: 'db',
    layerLabel: layerNames.db,
    where: "UPDATE … WHERE status = 'pending'",
  },
  {
    case: 'Already a member',
    call: 'Refuse before writing the invite',
    layer: 'action',
    layerLabel: layerNames.action,
    where: 'sendInvitation body, a membership read',
  },
  {
    case: 'Org deleted before accept',
    call: 'Refuse — nothing to handle',
    layer: 'db',
    layerLabel: layerNames.db,
    where: "DDL: onDelete: 'cascade'",
  },
  {
    case: 'Expired / tampered / revoked link',
    call: 'Refuse (generic; expiry & revoked fork)',
    layer: 'page',
    layerLabel: layerNames.page,
    where: 'accept-page verify ladder, at render',
  },
];

/** Cells whose `where` text reads better as inline code. */
const monoWhere = new Set(rows.filter((r) => r.where.includes("'")).map((r) => r.case));
---

<div class="senior-calls">
  <table>
    <caption class="sr-only">
      Invite edge cases, the senior call for each, and the layer that enforces it
    </caption>
    <thead>
      <tr>
        <th scope="col">Edge case</th>
        <th scope="col">Senior call</th>
        <th scope="col">Where the check lives</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            <th scope="row">{row.case}</th>
            <td>{row.call}</td>
            <td class="where">
              <span class="layer-badge" data-layer={row.layer}>
                {row.layerLabel}
              </span>
              {monoWhere.has(row.case) ? <code>{row.where}</code> : <span>{row.where}</span>}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .senior-calls {
    overflow-x: auto;
  }

  table {
    width: 100%;
    margin: 0;
    border-collapse: collapse;
    font-size: var(--sl-text-sm);
    line-height: 1.4;
  }

  /* Accessible name lives in <caption>; <Figure> shows the visible caption. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  thead th {
    text-align: left;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding: 0 0.85rem 0.55rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  /* The enforcing-layer column is the load-bearing axis — give it the widest
   * share and emphasize its header. */
  thead th:last-child {
    color: var(--sl-color-white);
    width: 42%;
  }

  tbody th,
  tbody td {
    padding: 0.65rem 0.85rem;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-hairline-shade);
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: 0;
  }

  /* Row-identifying cell: the edge case. */
  tbody th {
    text-align: left;
    font-weight: 600;
    color: var(--sl-color-white);
    white-space: nowrap;
  }

  tbody td {
    color: var(--sl-color-gray-2);
  }

  .where {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.55rem;
  }

  .where code {
    font-size: 0.85em;
    background: var(--sl-color-gray-6);
    padding: 0.05rem 0.3rem;
    border-radius: 0.25rem;
  }

  .layer-badge {
    flex: none;
    align-self: center;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    line-height: 1;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    border: 1px solid;
    white-space: nowrap;
  }

  .layer-badge[data-layer='db'] {
    background: var(--mark-blue-bg);
    border-color: var(--mark-blue-brd);
    color: var(--sl-color-white);
  }

  .layer-badge[data-layer='action'] {
    background: var(--mark-orange-bg);
    border-color: var(--mark-orange-brd);
    color: var(--sl-color-white);
  }

  /* The accept-page verify ladder runs at render time, server-side — a real
   * check, but a distinct layer from the action body. A solid neutral badge
   * keeps it legible as its own enforcement without borrowing the DB or
   * action colors. */
  .layer-badge[data-layer='page'] {
    background: var(--sl-color-gray-5);
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  /* "No check" is deliberately quiet — it isn't an enforcement, so it reads
   * as the absence of one rather than competing with the real layers. */
  .layer-badge[data-layer='none'] {
    background: transparent;
    border-color: var(--sl-color-gray-5);
    border-style: dashed;
    color: var(--sl-color-gray-3);
  }

  @media (max-width: 30rem) {
    tbody th,
    .where {
      white-space: normal;
    }
  }
</style>
