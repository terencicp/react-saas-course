---
// One frame of the Shape-D signup loop, used inside <DiagramSequence>.
// A flat horizontal strip of four stages a brand-new invitee passes through:
// Click -> Sign up -> Back to accept URL -> Accept. The strip is identical in
// every frame; only `active` changes which box is highlighted, so scrubbing the
// sequence walks the round trip that ends back at the Accept button (Shape A).
//
// Green is the lesson's "correct write path" accent (the accept action and the
// render-then-gate variant share it), so the highlight ties the loop to the one
// place the member row is written.

interface Props {
  active: "click" | "signup" | "return" | "accept";
}

const { active } = Astro.props;

const arrow = "▸";

// The four stages in order. Each box is a short title + a one-glance subtitle.
const stages = [
  { id: "click", title: "Click", sub: "GET · Shape D" },
  { id: "signup", title: "Sign up", sub: "next → accept URL" },
  { id: "return", title: "Back to accept URL", sub: "now Shape A" },
  { id: "accept", title: "Accept", sub: "writes member" },
] as const;

// Shared chrome for the rounded card boxes.
const boxBase = [
  "margin: 0",
  "padding: 7px 12px",
  "border-radius: 8px",
  "min-width: 0",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 2px",
  "transition: opacity 200ms ease, transform 200ms ease, border-color 200ms ease, background-color 200ms ease, box-shadow 200ms ease",
].join("; ");

// Inactive box — muted neutral so the active green pops.
const boxDim = `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 16%, transparent); background: color-mix(in srgb, currentColor 4%, transparent); opacity: 0.4;`;

// Active box — saturated green fill, lifted, ringed. #22c55e reads in both themes.
const boxActive = `${boxBase}; border: 1.5px solid #22c55e; background: color-mix(in srgb, #22c55e 20%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #22c55e 16%, transparent); transform: translateY(-1px); opacity: 1;`;

const titleStyle =
  "margin: 0; font-size: 13px; font-weight: 600; line-height: 1.2; white-space: nowrap;";
const subtitleStyle =
  "margin: 0; font-size: 10.5px; opacity: 0.6; line-height: 1.2; white-space: nowrap;";

const arrowStyle = [
  "margin: 0",
  "color: currentColor",
  "opacity: 0.35",
  "font-size: 14px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");
---

<div
  style="margin: 0; display: flex; flex-direction: row; align-items: center; justify-content: center; flex-wrap: wrap; gap: 6px; min-width: 0; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {
    stages.map((stage, i) => (
      <>
        <div style={active === stage.id ? boxActive : boxDim}>
          <div style={titleStyle}>{stage.title}</div>
          <div style={subtitleStyle}>{stage.sub}</div>
        </div>
        {i < stages.length - 1 && <div style={arrowStyle}>{arrow}</div>}
      </>
    ))
  }
</div>
