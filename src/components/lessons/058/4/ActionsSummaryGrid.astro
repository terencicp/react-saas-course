---
// Summary grid for the three actions on a pending-invite row. Five columns:
// Action · DB write · Sends email? · Audit event · Row after; three data rows
// (resend, revoke, blocked re-invite). The "Sends email?" column is the only
// color-carrying column — a green pill for resend's "Yes", muted grey pills for
// the two "No" cells — so the resend-is-the-only-send asymmetry reads straight
// down that column at a glance. Everything else is neutral chrome so nothing
// competes with that one signal.
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the layout with
// a fixed five-column count so the table never wraps unpredictably; cells wrap
// their own text instead of the whole grid scrolling. `margin: 0` reset on every
// inner element defeats Starlight's prose-margin injection. Code-like tokens
// (column names, statuses, audit events) render monospace; the green fill is the
// only saturated mid-tone (green-600), which reads on both light and dark theme.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// A run of text inside a cell: either plain prose ("kind" omitted) or an inline
// monospace token (kind: "code"). A cell is an array of these so a single cell
// can mix prose and code without leaning on the prose CSS pill.
type Run = { text: string; kind?: "code" };

type Row = {
  action: string; // the button name — the row's identity
  dbWrite: Run[]; // what it writes
  sendsEmail: boolean; // drives the green / grey pill
  emailNote: string; // the small print under the pill
  audit: Run | null; // the audit event token, or null when no row is written
  auditNote?: string; // shown when there is no audit event
  rowAfter: Run[]; // the row's state once the action settles
};

const ROWS: Row[] = [
  {
    action: "Resend",
    dbWrite: [
      { text: "UPDATE " },
      { text: "tokenHash", kind: "code" },
      { text: ", " },
      { text: "expiresAt", kind: "code" },
    ],
    sendsEmail: true,
    emailNote: "new link",
    audit: { text: "invitation.resent", kind: "code" },
    rowAfter: [
      { text: "still " },
      { text: "pending", kind: "code" },
      { text: ", new window" },
    ],
  },
  {
    action: "Revoke",
    dbWrite: [
      { text: "UPDATE " },
      { text: "status = 'canceled'", kind: "code" },
    ],
    sendsEmail: false,
    emailNote: "—",
    audit: { text: "invitation.revoked", kind: "code" },
    rowAfter: [
      { text: "" },
      { text: "canceled", kind: "code" },
      { text: " (kept)" },
    ],
  },
  {
    action: "Re-invite (collision)",
    dbWrite: [{ text: "INSERT blocked by index" }],
    sendsEmail: false,
    emailNote: "returns conflict",
    audit: null,
    auditNote: "no row written",
    rowAfter: [
      { text: "existing " },
      { text: "pending", kind: "code" },
      { text: " unchanged" },
    ],
  },
];

const HEADERS = [
  "Action",
  "DB write",
  "Sends email?",
  "Audit event",
  "Row after",
];

// ---- styles -------------------------------------------------------------

const grid = [
  reset,
  "display: grid",
  // Action column slightly wider (it carries the row identity); four data
  // columns share the rest. Fixed column count → never wraps unpredictably.
  "grid-template-columns: minmax(120px, 1.05fr) minmax(150px, 1.25fr) minmax(116px, 0.85fr) minmax(140px, 1fr) minmax(150px, 1.1fr)",
  "gap: 6px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// Column header cell — small uppercase caption sitting above its column.
const headCell = [
  reset,
  sans,
  "padding: 4px 10px 8px",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The leftmost (Action) header is left-aligned with the body; the email-column
// header centers over its centered pills.
const headEmail = `${headCell}; text-align: center;`;

// Body cell shell — shared by every data cell.
const cellBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 5px",
  "padding: 12px 12px",
  "border-radius: 9px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
  "box-sizing: border-box",
  "min-height: 62px",
].join("; ");

// The Action cell gets a touch more weight + a hairline accent on the left so
// each row reads as a unit without color competing with the email column.
const actionCell = [
  cellBase,
  "border-left: 3px solid var(--sl-color-gray-4)",
].join("; ");

const actionText = [
  reset,
  sans,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.25",
  "color: var(--sl-color-white)",
].join("; ");

// Body prose run.
const runText = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.45",
  "color: var(--sl-color-gray-2)",
].join("; ");

// Inline monospace token — no prose pill (transparent background, no padding)
// so it doesn't blow out the cell width or wrap oddly inside the grid.
const codeRun = [
  mono,
  "font-size: 12.5px",
  "font-weight: 600",
  "color: var(--sl-color-white)",
  "white-space: nowrap",
].join("; ");

// The email cell centers its pill + note.
const emailCell = [
  cellBase,
  "align-items: center",
  "text-align: center",
].join("; ");

// green-600 "Yes" pill — the one saturated signal in the figure.
const yesPill = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "padding: 4px 11px",
  "border-radius: 999px",
  "background: #16a34a",
  "color: #ffffff",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1",
].join("; ");

// muted grey "No" pill — deliberately recessive so "Yes" pops.
const noPill = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "padding: 4px 11px",
  "border-radius: 999px",
  "background: var(--sl-color-gray-5)",
  "color: var(--sl-color-gray-2)",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1",
  "border: 1px solid var(--sl-color-gray-4)",
].join("; ");

const emailNote = [
  reset,
  sans,
  "font-size: 11px",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// audit-event monospace token, sitting in its own neutral cell.
const auditNoteText = [
  reset,
  sans,
  "font-size: 12px",
  "line-height: 1.3",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
].join("; ");

// A small SVG check glyph for the "Yes" pill.
---

<div class="not-content" style={grid}>
  {/* Header row */}
  {
    HEADERS.map((h, i) => (
      <div style={i === 2 ? headEmail : headCell}>{h}</div>
    ))
  }

  {/* One grid row per action */}
  {
    ROWS.map((r) => (
      <Fragment>
        <div style={actionCell}>
          <span style={actionText}>{r.action}</span>
        </div>

        <div style={cellBase}>
          <p style={runText}>
            {r.dbWrite.map((run) =>
              run.kind === "code" ? (
                <code style={codeRun}>{run.text}</code>
              ) : (
                run.text
              ),
            )}
          </p>
        </div>

        <div style={emailCell}>
          {r.sendsEmail ? (
            <span style={yesPill}>
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#ffffff"
                stroke-width="3.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                style="margin: 0; display: block;"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
              Yes
            </span>
          ) : (
            <span style={noPill}>No</span>
          )}
          <span style={emailNote}>{r.emailNote}</span>
        </div>

        <div style={cellBase}>
          {r.audit ? (
            <code style={codeRun}>{r.audit.text}</code>
          ) : (
            <span style={auditNoteText}>{r.auditNote}</span>
          )}
        </div>

        <div style={cellBase}>
          <p style={runText}>
            {r.rowAfter.map((run) =>
              run.kind === "code" ? (
                <code style={codeRun}>{run.text}</code>
              ) : (
                run.text
              ),
            )}
          </p>
        </div>
      </Fragment>
    ))
  }
</div>
