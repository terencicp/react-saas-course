---
import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Architecture flow for the tag-driven invoice cache. The whole point is that
// the cached-reads box is the hub: the read path feeds it, two write paths
// invalidate it, and the inspector reads its fetchedAt. So the layout puts the
// cached reads dead center and aims every arrow at it.
//
// Layout: /invoices on the left → cached reads in the center. The two write
// paths stack on the right and both point LEFT into the cached reads, each
// carrying its own invalidation primitive (the lesson's decision lens). The
// inspector sits below and reads fetchedAt off the hub.
//
// Arrowhead-stacking fix (per ArrowDiagram doc): four arrows all aim at the
// cached-reads box, so it is split into four anchorable zones — the title strip
// (read call lands), and three body rows (one per incoming invalidation/read),
// so the heads land tens of px apart instead of on top of each other.
//
// Color = meaning: slate for the read call, green for updateTag (synchronous,
// read-your-writes — someone is waiting), amber for revalidateTag (eventual,
// background — nobody waiting), grey for the inspector's passive read.
const SLATE = '#64748b'; // read call
const GREEN = '#16a34a'; // updateTag — read-your-writes
const AMBER = '#d97706'; // revalidateTag — eventual
const GREY = '#94a3b8'; // inspector read
---

<Figure expandable={false}>
  <ArrowDiagram
    arrows={[
      {
        from: 'af-read',
        to: 'af-hub-title',
        label: 'calls with orgId',
        color: SLATE,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [90, 0],
        endSocketGravity: [-90, 0],
        labelOffset: [0, -16],
      },
      {
        from: 'af-actions',
        to: 'af-hub-update',
        label: 'updateTag · read-your-writes',
        color: GREEN,
        startSocket: 'left',
        endSocket: 'right',
        startSocketGravity: [-100, -14],
        endSocketGravity: [110, -14],
        labelOffset: [0, -16],
      },
      {
        from: 'af-job',
        to: 'af-hub-revalidate',
        label: 'revalidateTag · eventual',
        color: AMBER,
        startSocket: 'left',
        endSocket: 'right',
        startSocketGravity: [-100, 14],
        endSocketGravity: [110, 14],
        labelOffset: [0, 18],
      },
      {
        from: 'af-inspector',
        to: 'af-hub-inspect',
        label: 'reads fetchedAt',
        color: GREY,
        startSocket: 'top',
        endSocket: 'bottom',
        startSocketGravity: [0, -70],
        endSocketGravity: [0, 70],
        labelOffset: [0, 0],
      },
    ]}
  >
    <div class="af-grid">
      {/* Left: the read path */}
      <div class="af-box af-box--read af-col-read">
        <div class="af-box-title" id="af-read">/invoices Server Component</div>
        <div class="af-box-body">
          <p class="af-line">Reads the session, then passes <code class="af-k">orgId</code> in as an argument.</p>
          <code class="af-code">listInvoices(args)</code>
          <code class="af-code">getOrgInvoiceSummary(orgId)</code>
          <code class="af-code">getInvoiceDetail({'{'} orgId, id {'}'})</code>
        </div>
      </div>

      {/* Center: the cached-reads hub — split into anchor zones so the four
          incoming arrowheads don't stack. */}
      <div class="af-box af-box--hub af-col-hub">
        <div class="af-box-title af-hub-title" id="af-hub-title">Cached reads</div>
        <div class="af-box-body">
          <div class="af-hub-row" id="af-hub-update">
            <code class="af-code"><span class="af-d">'use cache'</span></code>
          </div>
          <div class="af-hub-row">
            <code class="af-code">cacheLife(<span class="af-d">profile</span>)</code>
          </div>
          <div class="af-hub-row" id="af-hub-revalidate">
            <code class="af-code">cacheTag(<span class="af-mod">tags.ts</span>)</code>
          </div>
          <div class="af-hub-row af-hub-row--out" id="af-hub-inspect">
            <span class="af-arrow">→</span>
            <code class="af-code"><span class="af-out">fetchedAt</span></code>
          </div>
        </div>
      </div>

      {/* Right: the two write paths, stacked. */}
      <div class="af-box af-box--update af-col-update">
        <div class="af-box-title" id="af-actions">Lifecycle Server Actions</div>
        <div class="af-box-body">
          <p class="af-line af-mono-line"><code class="af-code-inline">update · archive · restore · softDelete</code></p>
          <p class="af-flow">commit <span class="af-sep">→</span> <span class="af-em af-em--update">updateTag(list, record, summary)</span> <span class="af-sep">→</span> redirect</p>
          <p class="af-sub af-sub--update">The same user lands on a fresh read.</p>
        </div>
      </div>

      <div class="af-box af-box--job af-col-job">
        <div class="af-box-title" id="af-job">recomputeOrgSummary job</div>
        <div class="af-box-body">
          <p class="af-flow">recompute <span class="af-sep">→</span> <span class="af-em af-em--job">revalidateTag(summary)</span></p>
          <p class="af-sub af-sub--job">No one is waiting — the next visit picks up the new aggregate.</p>
        </div>
      </div>

      {/* Below: the inspector reads off the hub. */}
      <div class="af-box af-box--inspector af-col-inspector">
        <div class="af-box-title" id="af-inspector">/inspector Server Component</div>
        <div class="af-box-body">
          <p class="af-line">Drives every cache-state observation — the <code class="af-k">fetchedAt</code> strip, the hit/miss probe, the one-click lifecycle and run-summary buttons, the misuse toggle, and the invalidation-log tail.</p>
        </div>
      </div>
    </div>
  </ArrowDiagram>
  <Fragment slot="caption">
    The cached reads are the hub: <code>/invoices</code> feeds them, the lifecycle actions invalidate them with <code>updateTag</code> (read-your-writes, a user is waiting), the recompute job with <code>revalidateTag</code> (eventual, no one is waiting), and <code>/inspector</code> reads <code>fetchedAt</code> off them.
  </Fragment>
</Figure>

<style>
  .af-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr) minmax(0, 1.05fr);
    grid-template-areas:
      'read    hub  update'
      'read    hub  job'
      'insp    hub  .';
    column-gap: 130px;
    row-gap: 0.85rem;
    align-items: stretch;
    max-width: 960px;
    margin-inline: auto;
    padding-block: 0.5rem 0.75rem;
  }

  .af-col-read {
    grid-area: read;
  }
  .af-col-hub {
    grid-area: hub;
    align-self: center;
  }
  .af-col-update {
    grid-area: update;
  }
  .af-col-job {
    grid-area: job;
  }
  .af-col-inspector {
    grid-area: insp;
  }

  .af-box {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.6rem;
    background: var(--sl-color-black);
    overflow: hidden;
    min-width: 0;
  }

  .af-box--hub {
    border-color: color-mix(in srgb, var(--sl-color-accent) 60%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--sl-color-accent) 8%, var(--sl-color-black));
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--sl-color-accent) 18%, transparent);
  }

  .af-box--update {
    border-color: color-mix(in srgb, #16a34a 50%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #16a34a 6%, var(--sl-color-black));
  }

  .af-box--job {
    border-color: color-mix(in srgb, #d97706 50%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #d97706 6%, var(--sl-color-black));
  }

  .af-box-title {
    font-weight: 600;
    font-size: 0.82rem;
    padding: 0.4rem 0.7rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-6) 60%, transparent);
    color: var(--sl-color-white);
  }

  .af-box--hub .af-box-title {
    border-bottom-color: color-mix(in srgb, var(--sl-color-accent) 32%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
    color: var(--sl-color-text-accent);
    text-align: center;
  }

  .af-box--update .af-box-title {
    border-bottom-color: color-mix(in srgb, #16a34a 32%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #16a34a 13%, transparent);
    color: var(--sl-color-green-high, #4ade80);
  }

  .af-box--job .af-box-title {
    border-bottom-color: color-mix(in srgb, #d97706 34%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #d97706 14%, transparent);
    color: #fbbf24;
  }

  .af-box-body {
    padding: 0.6rem 0.7rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .af-line {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.45;
    color: var(--sl-color-gray-2);
  }

  .af-code {
    display: block;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.73rem;
    line-height: 1.4;
    color: var(--sl-color-white);
    word-break: break-word;
  }

  .af-code-inline {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    color: var(--sl-color-white);
  }

  .af-k {
    color: var(--sl-color-text-accent);
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.85em;
  }

  .af-d {
    color: #c084fc;
  }

  .af-mod {
    color: var(--sl-color-text-accent);
  }

  .af-out {
    color: var(--sl-color-green-high, #4ade80);
    font-weight: 600;
  }

  /* Hub interior rows — compact, each is an anchor target for an arrow. */
  .af-hub-row {
    padding: 0.18rem 0.4rem;
    border-radius: 0.35rem;
    background: color-mix(in srgb, var(--sl-color-gray-6) 30%, transparent);
  }

  .af-hub-row--out {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: color-mix(in srgb, #16a34a 9%, transparent);
    border: 1px solid color-mix(in srgb, #16a34a 30%, transparent);
  }

  .af-hub-row--out .af-arrow {
    color: var(--sl-color-green-high, #4ade80);
    font-weight: 700;
    flex: 0 0 auto;
  }

  /* Write-path interiors */
  .af-mono-line {
    color: var(--sl-color-gray-3);
  }

  .af-flow {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.5;
    color: var(--sl-color-gray-2);
  }

  .af-sep {
    color: var(--sl-color-gray-4);
    padding-inline: 0.12rem;
  }

  .af-em {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.92em;
    font-weight: 600;
    white-space: nowrap;
  }

  .af-em--update {
    color: var(--sl-color-green-high, #4ade80);
  }

  .af-em--job {
    color: #fbbf24;
  }

  .af-sub {
    margin: 0;
    font-size: 0.7rem;
    line-height: 1.4;
    color: var(--sl-color-gray-3);
  }

  .af-sub--update {
    color: color-mix(in srgb, #16a34a 50%, var(--sl-color-gray-2));
  }

  .af-sub--job {
    color: color-mix(in srgb, #d97706 55%, var(--sl-color-gray-2));
  }

  /* Stack on narrow viewports: arrows degrade to top-to-bottom arcs. */
  @media (max-width: 720px) {
    .af-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        'read'
        'hub'
        'update'
        'job'
        'insp';
      column-gap: 0;
      row-gap: 64px;
    }

    .af-col-hub {
      align-self: stretch;
    }
  }
</style>
