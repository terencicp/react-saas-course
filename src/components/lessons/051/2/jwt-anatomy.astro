---
import Figure from '../../../figures/Figure.astro';

// Annotated illustration of a JWT's three dot-separated segments.
// Goal: make it visually obvious that the payload is readable (base64url),
// not encrypted — the signature is tamper-evidence, not secrecy.
// Saturated 600-range fills with white text so the color signal survives
// both light and dark themes.
const BLUE = '#2563eb'; // blue-600 — header
const ORANGE = '#ea580c'; // orange-600 — payload
const VIOLET = '#7c3aed'; // violet-600 — signature
---

<Figure>
  <div class="jwt">
    <div class="jwt-token">
      <div class="jwt-seg">
        <span
          class="jwt-pill"
          style={`--seg: ${BLUE}`}>header</span
        >
        <span class="jwt-label">
          algorithm
          <code class="jwt-code">{'{ alg: '}'HS256'{' }'}</code>
        </span>
      </div>

      <span class="jwt-dot" aria-hidden="true">.</span>

      <div class="jwt-seg">
        <span
          class="jwt-pill"
          style={`--seg: ${ORANGE}`}>payload</span
        >
        <span class="jwt-label">
          the claims
          <code class="jwt-code">{'{ sub, email, role, exp }'}</code>
        </span>
      </div>

      <span class="jwt-dot" aria-hidden="true">.</span>

      <div class="jwt-seg">
        <span
          class="jwt-pill"
          style={`--seg: ${VIOLET}`}>signature</span
        >
        <span class="jwt-label">
          proof it wasn't <em>changed</em>
        </span>
      </div>
    </div>

    <p class="jwt-note">
      The payload is just <strong>base64url</strong>. Anyone holding the cookie
      can decode it and read every claim. The signature only proves the claims
      weren't <em>tampered with</em> — it does not hide them.
    </p>
  </div>

  <Fragment slot="caption">
    A JWT is signed, not encrypted. Tamper-evident is not the same as secret.
  </Fragment>
</Figure>

<style>
  .jwt {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
    max-width: 720px;
    margin-inline: auto;
    padding-block: 0.5rem;
  }

  .jwt-token {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    column-gap: 0.5rem;
    row-gap: 1.1rem;
  }

  .jwt-seg {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    text-align: center;
  }

  .jwt-pill {
    display: inline-block;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    background: var(--seg);
    padding: 0.4rem 1.1rem;
    border-radius: 0.5rem;
    letter-spacing: 0.01em;
  }

  .jwt-dot {
    align-self: flex-start;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--sl-color-gray-3);
    padding-top: 0.05rem;
  }

  .jwt-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    line-height: 1.35;
    color: var(--sl-color-gray-2);
    max-width: 12rem;
  }

  .jwt-label em {
    font-style: italic;
  }

  .jwt-code {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.74rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    padding: 0.15rem 0.4rem;
    border-radius: 0.35rem;
    white-space: nowrap;
  }

  .jwt-note {
    margin: 0;
    max-width: 640px;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--sl-color-white);
    background: color-mix(in srgb, #ea580c 9%, var(--sl-color-black));
    border-left: 3px solid #ea580c;
    border-radius: 0 0.4rem 0.4rem 0;
    padding: 0.7rem 0.9rem;
  }

  .jwt-note strong {
    color: var(--sl-color-orange-high, #fb923c);
    font-weight: 600;
  }

  .jwt-note em {
    font-style: normal;
    font-weight: 600;
    color: var(--sl-color-orange-high, #fb923c);
  }

  @media (max-width: 540px) {
    .jwt-dot {
      display: none;
    }

    .jwt-token {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
