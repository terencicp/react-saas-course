---
import Figure from '../../../figures/Figure.astro';

// Annotated illustration of the full auth-cookie string, attribute by attribute.
// A flat labeled artifact (not a flowchart): the cookie renders as one wrapping
// line of segmented pills, each with a terse callout beneath. The name+value
// (the handle) carry an accent fill to read as the payload; the attribute flags
// are outlined pills. Matches the pill+label-below style of jwt-anatomy.astro
// so the lesson's figures stay visually consistent across light and dark themes.
const ACCENT = '#0d9488'; // teal-600 — the handle (name + value)

// Each part of the cookie: its rendered text, a kind that drives styling, and
// the terse callout that sits under it. `name` and `value` are the handle;
// everything else is an attribute flag.
const parts = [
  {
    kind: 'name',
    text: '__Host-session',
    note: 'the browser enforces tight scope — refuses the cookie otherwise',
  },
  { kind: 'eq', text: '=' },
  { kind: 'value', text: 'a8f3c1d9…', note: 'the opaque handle' },
  { kind: 'flag', text: 'HttpOnly', note: "JavaScript can't read it" },
  { kind: 'flag', text: 'Secure', note: 'HTTPS only' },
  {
    kind: 'flag',
    text: 'SameSite=Lax',
    note: 'withheld on cross-site POSTs',
  },
  { kind: 'flag', text: 'Path=/', note: 'sent on every same-origin request' },
  {
    kind: 'flag',
    text: 'Max-Age=2592000',
    note: 'lifetime — 30 days, renewed on use',
  },
];
---

<Figure>
  <div class="ck" style={`--accent: ${ACCENT}`}>
    <div class="ck-string">
      {
        parts.map((part, i) => (
          <>
            {part.kind === 'eq' ? (
              <span class="ck-eq" aria-hidden="true">
                =
              </span>
            ) : (
              <span class={`ck-seg ck-seg--${part.kind}`}>
                <code class={`ck-pill ck-pill--${part.kind}`}>{part.text}</code>
                <span class="ck-note">{part.note}</span>
              </span>
            )}
            {part.kind !== 'name' &&
              part.kind !== 'eq' &&
              i < parts.length - 1 && (
                <span class="ck-sep" aria-hidden="true">
                  ;
                </span>
              )}
          </>
        ))
      }
    </div>
  </div>

  <Fragment slot="caption">
    The auth cookie, attribute by attribute. Each one closes a specific attack.
  </Fragment>
</Figure>

<style>
  .ck {
    max-width: 820px;
    margin-inline: auto;
    padding-block: 0.75rem 0.25rem;
  }

  .ck-string {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    column-gap: 0.3rem;
    row-gap: 1.3rem;
  }

  .ck-seg {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .ck-pill {
    display: inline-block;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.2;
    padding: 0.4rem 0.7rem;
    border-radius: 0.45rem;
    white-space: nowrap;
  }

  /* The handle: name + value carry the accent so they read as the payload. */
  .ck-pill--name {
    color: #fff;
    background: var(--accent);
  }

  .ck-pill--value {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, var(--sl-color-black));
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
  }

  /* The attribute flags: outlined, lower-contrast than the handle. */
  .ck-pill--flag {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
  }

  .ck-eq {
    align-self: flex-start;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--sl-color-gray-2);
    padding-top: 0.45rem;
  }

  .ck-sep {
    align-self: flex-start;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--sl-color-gray-3);
    padding: 0.4rem 0.3rem 0 0;
  }

  .ck-note {
    font-size: 0.73rem;
    line-height: 1.35;
    color: var(--sl-color-gray-2);
    max-width: 9.5rem;
  }

  .ck-seg--name .ck-note,
  .ck-seg--value .ck-note {
    color: color-mix(in srgb, var(--accent) 55%, var(--sl-color-gray-2));
    font-weight: 500;
  }

  @media (max-width: 560px) {
    .ck-string {
      flex-direction: column;
      align-items: center;
    }

    .ck-eq,
    .ck-sep {
      display: none;
    }

    .ck-note {
      max-width: 16rem;
    }
  }
</style>
