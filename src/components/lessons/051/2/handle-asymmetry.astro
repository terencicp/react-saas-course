---
import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Two-box asymmetry figure: the browser holds an opaque handle, the server
// owns the source-of-truth record. Cyclic A<->B relationship, so the two
// arrows are anchored at different sub-elements (top strip vs. bottom strip)
// and routed on opposite sides of the midline to keep their curves apart.
const ACCENT = '#475569'; // slate-600 — request direction
const GREEN = '#16a34a'; // green-600 — answer from the authority
---

<Figure expandable={false}>
  <ArrowDiagram
    arrows={[
      {
        from: 'ha-browser-top',
        to: 'ha-server-top',
        label: 'presents the ID on every request',
        color: ACCENT,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [120, -36],
        endSocketGravity: [-120, -36],
        labelOffset: [0, -16],
      },
      {
        from: 'ha-server-bottom',
        to: 'ha-browser-bottom',
        label: 'looks it up → User | null',
        color: GREEN,
        startSocket: 'left',
        endSocket: 'right',
        startSocketGravity: [-120, 36],
        endSocketGravity: [120, 36],
        labelOffset: [0, 18],
      },
    ]}
  >
    <div class="ha-grid">
      <div class="ha-box">
        <div class="ha-box-title" id="ha-browser-top">Browser</div>
        <div class="ha-box-body" id="ha-browser-bottom">
          <code class="ha-code"
            ><span class="ha-key">__Host-session</span> = <span class="ha-val"
              >a8f3c1d9…</span
            ></code
          >
          <p class="ha-sub">an opaque handle — no readable meaning</p>
        </div>
      </div>

      <div class="ha-box ha-box--authority">
        <div class="ha-box-title" id="ha-server-top">Server</div>
        <div class="ha-box-body" id="ha-server-bottom">
          <code class="ha-code ha-code--block"
            >{'{'} id: <span class="ha-val">'a8f3c1d9…'</span>, userId: <span
              class="ha-val">'usr_7Q…'</span
            >, expiresAt, lastActiveAt, … {'}'}</code
          >
          <p class="ha-sub ha-sub--authority">the source of truth</p>
        </div>
      </div>
    </div>
  </ArrowDiagram>
  <Fragment slot="caption">
    The cookie carries only a handle. The server owns the record it points to —
    and can delete it at will.
  </Fragment>
</Figure>

<style>
  .ha-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 150px;
    align-items: stretch;
    max-width: 760px;
    margin-inline: auto;
    padding-block: 0.75rem;
  }

  .ha-box {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.6rem;
    background: var(--sl-color-black);
    overflow: hidden;
  }

  .ha-box--authority {
    border-color: color-mix(in srgb, #16a34a 55%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #16a34a 7%, var(--sl-color-black));
  }

  .ha-box-title {
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-6) 60%, transparent);
  }

  .ha-box--authority .ha-box-title {
    border-bottom-color: color-mix(in srgb, #16a34a 35%, var(--sl-color-gray-5));
    background: color-mix(in srgb, #16a34a 14%, transparent);
    color: var(--sl-color-green-high, #4ade80);
  }

  .ha-box-body {
    padding: 0.85rem;
    flex: 1;
  }

  .ha-code {
    display: block;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--sl-color-white);
    word-break: break-word;
  }

  .ha-code--block {
    font-size: 0.78rem;
  }

  .ha-key {
    color: var(--sl-color-text-accent);
  }

  .ha-val {
    color: var(--sl-color-green-high, #4ade80);
  }

  .ha-sub {
    margin: 0.6rem 0 0;
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--sl-color-gray-3);
  }

  .ha-sub--authority {
    color: color-mix(in srgb, #16a34a 60%, var(--sl-color-gray-2));
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .ha-grid {
      grid-template-columns: 1fr;
      gap: 64px;
    }
  }
</style>
