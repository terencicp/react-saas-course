---
import Figure from '../../../figures/Figure.astro';

// Two-column mapping: each non-obvious session-row column on the left, the
// concrete feature it powers on the right, joined by a left→right arrow so the
// relationship reads as "this column exists *because of* that feature".
// Indigo-600 accent fill on the column-name pills marks them as the data side;
// the feature side stays neutral text. Matches the saturated-600 pill + note
// style of cookie-anatomy / jwt-anatomy so the lesson's figures stay consistent
// across light and dark themes.
const ACCENT = '#4f46e5'; // indigo-600 — the session-row columns

// Each row of the map: the column name(s) as code, and the feature(s) the
// column unlocks. Order mirrors the prose that follows the figure.
const rows = [
  {
    columns: ['lastActiveAt'],
    feature: '“Last seen 3 hours ago” UI · idle-timeout policies',
  },
  {
    columns: ['userAgent', 'ipAddress'],
    feature: 'The active-sessions list · “new device signed in” alerts',
  },
  {
    columns: ['activeOrganizationId'],
    feature: 'Which org’s data to show (multi-tenancy)',
  },
  {
    columns: ['impersonatedBy'],
    feature: 'Admin support — “acting as this user”',
  },
];
---

<Figure>
  <div class="sc" style={`--accent: ${ACCENT}`}>
    <div class="sc-head">
      <span class="sc-head-col">Session-row column</span>
      <span class="sc-head-spacer" aria-hidden="true"></span>
      <span class="sc-head-feat">What it powers</span>
    </div>

    <div class="sc-min">
      <span class="sc-min-label">minimum</span>
      <code class="sc-min-code">(id, userId, expiresAt)</code>
      <span class="sc-min-note">— always present; everything below is leverage</span>
    </div>

    <ul class="sc-rows">
      {
        rows.map((row) => (
          <li class="sc-row">
            <span class="sc-cols">
              {row.columns.map((col, i) => (
                <>
                  {i > 0 && (
                    <span class="sc-plus" aria-hidden="true">
                      +
                    </span>
                  )}
                  <code class="sc-pill">{col}</code>
                </>
              ))}
            </span>
            <span class="sc-arrow" aria-hidden="true">→</span>
            <span class="sc-feat">{row.feature}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <Fragment slot="caption">
    Every non-obvious column on the session row exists because a downstream
    feature needs it.
  </Fragment>
</Figure>

<style>
  .sc {
    max-width: 760px;
    margin-inline: auto;
    padding-block: 0.5rem 0.25rem;
  }

  /* Column headers, aligned to the same grid as the rows below. */
  .sc-head {
    display: grid;
    grid-template-columns: 15rem 1.5rem 1fr;
    align-items: center;
    padding: 0 0.4rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .sc-head-feat {
    grid-column: 3;
  }

  /* The always-present minimum, set apart from the optional columns. */
  .sc-min {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.45rem;
    padding: 0.5rem 0.6rem;
    margin-bottom: 0.6rem;
    border: 1px dashed var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
  }

  .sc-min-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .sc-min-code {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .sc-min-note {
    font-size: 0.74rem;
    color: var(--sl-color-gray-2);
  }

  .sc-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .sc-row {
    display: grid;
    grid-template-columns: 15rem 1.5rem 1fr;
    align-items: center;
    padding: 0.5rem 0.4rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
  }

  .sc-cols {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .sc-pill {
    display: inline-block;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    background: var(--accent);
    padding: 0.28rem 0.55rem;
    border-radius: 0.4rem;
    white-space: nowrap;
  }

  .sc-plus {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--sl-color-gray-3);
  }

  .sc-arrow {
    justify-self: center;
    font-size: 1rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--accent) 70%, var(--sl-color-gray-2));
  }

  .sc-feat {
    font-size: 0.84rem;
    line-height: 1.4;
    color: var(--sl-color-white);
  }

  @media (max-width: 560px) {
    .sc-head {
      display: none;
    }

    .sc-row {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      row-gap: 0.35rem;
    }

    .sc-arrow {
      display: none;
    }

    .sc-feat {
      color: var(--sl-color-gray-2);
    }
  }
</style>
