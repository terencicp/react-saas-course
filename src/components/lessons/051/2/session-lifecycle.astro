---
import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// The session lifecycle as a five-beat scrubbable sequence: issue → request →
// refresh → revoke → stale-cookie-rejected. Two actors per beat — the Browser
// (left) holding the cookie, the Server (right) holding the session row — with a
// labeled wire between them carrying that beat's request and the server's action.
//
// The load-bearing move is steps 4→5: the browser's cookie value is byte-for-byte
// identical, but the server-side row has been deleted, so the next lookup finds
// nothing and the request dies. Every step keeps the same three-column skeleton
// (browser · wire · server) so the grid-stacked stage sizes to the tallest step
// and never reflows as the reader scrubs. Visual language reuses the lesson's
// other figures: slate for a plain request, green for the authority/success,
// red for revoke and the failed lookup.

const SLATE = '#475569'; // request direction
const GREEN = '#16a34a'; // the authority / success
const RED = '#dc2626'; // revoke / failed lookup

// The opaque handle the cookie carries — identical from issue onward. Keeping it
// the same string across steps is the whole point of beats 4 and 5.
const TOKEN = 'a8f3c1d9…';

// `cookie`  — what the browser holds this beat ('none' before issue).
// `wire`    — { dir, text, tone } the message travelling on the wire.
// `row`     — server-side session row state: 'new' | 'present' | 'bumped' |
//             'deleted' | 'absent'.
// `verdict` — { text, tone } the server's outcome for this beat.
const steps = [
  {
    n: 1,
    title: 'Issue',
    cookie: 'set',
    wire: {
      dir: 'rtl',
      text: 'Set-Cookie: __Host-session=' + TOKEN,
      tone: 'green',
    },
    request: { dir: 'ltr', text: 'POST /sign-in  (email + password)', tone: 'slate' },
    row: 'new',
    verdict: { text: 'verified → INSERT a new session row', tone: 'green' },
    caption:
      'Sign-in succeeds. The server creates the session row and sets the cookie.',
  },
  {
    n: 2,
    title: 'Authenticated request',
    cookie: 'has',
    request: {
      dir: 'ltr',
      text: 'GET /dashboard   Cookie: __Host-session=' + TOKEN,
      tone: 'slate',
    },
    row: 'present',
    verdict: { text: 'indexed lookup → row found → runs as user X', tone: 'green' },
    caption:
      'Every later request carries the cookie. The server looks it up and runs as that user.',
  },
  {
    n: 3,
    title: 'Refresh',
    cookie: 'has',
    request: {
      dir: 'ltr',
      text: 'GET /invoices   Cookie: __Host-session=' + TOKEN,
      tone: 'slate',
    },
    row: 'bumped',
    verdict: {
      text: 'lookup found → bump lastActiveAt · rotate on a cadence, not per request',
      tone: 'green',
    },
    caption:
      'On activity the server updates last-seen, and rotates the token on a cadence — not every request.',
  },
  {
    n: 4,
    title: 'Revoke',
    cookie: 'has',
    request: {
      dir: 'ltr',
      text: 'POST /sign-out-everywhere   (or an admin kills the account)',
      tone: 'red',
    },
    row: 'deleted',
    verdict: { text: 'DELETE the row — one statement', tone: 'red' },
    caption:
      'Sign-out, a compromised account, a stolen cookie — one DELETE removes the row.',
  },
  {
    n: 5,
    title: 'Stale cookie',
    cookie: 'stale',
    request: {
      dir: 'ltr',
      text: 'GET /dashboard   Cookie: __Host-session=' + TOKEN,
      tone: 'red',
    },
    row: 'absent',
    verdict: { text: 'lookup → no row → 401, redirect to /sign-in', tone: 'red' },
    caption:
      'The cookie is unchanged — but it now points to nothing. The next request fails and is bounced to sign-in.',
  },
];
---

<div class="sl-vars" style={`--slate:${SLATE};--green:${GREEN};--red:${RED}`}>
  <DiagramSequence>
    {
      steps.map((step) => (
        <DiagramStep caption={step.caption}>
          <div class="sl">
            <div class="sl-badge">
              <span class="sl-badge-n">{step.n}</span>
              <span class="sl-badge-title">{step.title}</span>
            </div>

            <div class="sl-stage">
              {/* Browser */}
              <div class="sl-actor">
                <div class="sl-actor-title">Browser</div>
                <div class="sl-actor-body">
                  {step.cookie === 'set' && (
                    <div class="sl-cookie sl-cookie--new">
                      <span class="sl-cookie-tag">cookie stored</span>
                      <code class="sl-cookie-val">
                        <span class="sl-k">__Host-session</span>={TOKEN}
                      </code>
                    </div>
                  )}
                  {step.cookie === 'has' && (
                    <div class="sl-cookie">
                      <code class="sl-cookie-val">
                        <span class="sl-k">__Host-session</span>={TOKEN}
                      </code>
                    </div>
                  )}
                  {step.cookie === 'stale' && (
                    <div class="sl-cookie sl-cookie--stale">
                      <span class="sl-cookie-tag sl-cookie-tag--stale">
                        unchanged — same bytes
                      </span>
                      <code class="sl-cookie-val">
                        <span class="sl-k">__Host-session</span>={TOKEN}
                      </code>
                    </div>
                  )}
                </div>
              </div>

              {/* Wire: request out, optional response back */}
              <div class="sl-wire">
                {step.request && (
                  <div class={`sl-msg sl-msg--ltr sl-msg--${step.request.tone}`}>
                    <span class="sl-msg-text">{step.request.text}</span>
                    <span class="sl-arrow sl-arrow--r" aria-hidden="true">
                      →
                    </span>
                  </div>
                )}
                {step.wire && (
                  <div class={`sl-msg sl-msg--rtl sl-msg--${step.wire.tone}`}>
                    <span class="sl-arrow sl-arrow--l" aria-hidden="true">
                      ←
                    </span>
                    <span class="sl-msg-text">{step.wire.text}</span>
                  </div>
                )}
              </div>

              {/* Server */}
              <div class="sl-actor sl-actor--server">
                <div class="sl-actor-title">Server</div>
                <div class="sl-actor-body">
                  <div class={`sl-row sl-row--${step.row}`}>
                    {step.row === 'absent' ? (
                      <span class="sl-row-empty">no matching row</span>
                    ) : (
                      <>
                        {step.row === 'new' && (
                          <span class="sl-row-tag sl-row-tag--new">+ new row</span>
                        )}
                        {step.row === 'deleted' && (
                          <span class="sl-row-tag sl-row-tag--del">row deleted</span>
                        )}
                        <code class="sl-row-code">
                          {'{ '}id: <span class="sl-v">'{TOKEN}'</span>, userId:{' '}
                          <span class="sl-v">'usr_7Q…'</span>,
                          <br />
                          {'  '}lastActiveAt:{' '}
                          <span
                            class={
                              step.row === 'bumped' ? 'sl-v sl-v--hot' : 'sl-v'
                            }
                          >
                            {step.row === 'bumped' ? '09:32 ↑' : '09:14'}
                          </span>, expiresAt: <span class="sl-v">…</span>
                          {' }'}
                        </code>
                      </>
                    )}
                  </div>
                  <div class={`sl-verdict sl-verdict--${step.verdict.tone}`}>
                    {step.verdict.text}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </DiagramStep>
      ))
    }
  </DiagramSequence>
</div>

<style>
  .sl {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  /* Step number + name, top-left of each panel. */
  .sl-badge {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .sl-badge-n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    background: var(--sl-color-accent);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    flex: 0 0 auto;
  }

  .sl-badge-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  /* Three columns: browser · wire · server. Fixed track widths so the layout
     reads consistently across all five steps and the stage never reflows. */
  .sl-stage {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr) minmax(0, 1fr);
    align-items: stretch;
    gap: 0.6rem;
  }

  .sl-actor {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.6rem;
    background: var(--sl-color-black);
    overflow: hidden;
    min-width: 0;
  }

  .sl-actor--server {
    border-color: color-mix(in srgb, var(--green) 50%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--green) 6%, var(--sl-color-black));
  }

  .sl-actor-title {
    font-weight: 600;
    font-size: 0.85rem;
    padding: 0.4rem 0.7rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-6) 60%, transparent);
  }

  .sl-actor--server .sl-actor-title {
    border-bottom-color: color-mix(in srgb, var(--green) 32%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--green) 13%, transparent);
    color: var(--sl-color-green-high, #4ade80);
  }

  .sl-actor-body {
    padding: 0.65rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    justify-content: center;
  }

  /* ---- Browser cookie ---- */
  .sl-cookie {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.45rem;
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-6) 35%, transparent);
  }

  .sl-cookie--new {
    border-color: color-mix(in srgb, var(--green) 45%, transparent);
    background: color-mix(in srgb, var(--green) 9%, var(--sl-color-black));
  }

  .sl-cookie--stale {
    border-color: color-mix(in srgb, var(--red) 45%, transparent);
    background: color-mix(in srgb, var(--red) 8%, var(--sl-color-black));
  }

  .sl-cookie-tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--green) 65%, var(--sl-color-gray-2));
  }

  .sl-cookie-tag--stale {
    color: color-mix(in srgb, var(--red) 70%, var(--sl-color-gray-2));
  }

  .sl-cookie-val {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.76rem;
    line-height: 1.4;
    color: var(--sl-color-white);
    word-break: break-all;
  }

  .sl-k {
    color: var(--sl-color-text-accent);
  }

  /* ---- Wire ---- */
  .sl-wire {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .sl-msg {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.4rem;
    border: 1px solid color-mix(in srgb, var(--tone) 40%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--tone) 8%, var(--sl-color-black));
  }

  .sl-msg--slate {
    --tone: var(--slate);
  }
  .sl-msg--green {
    --tone: var(--green);
  }
  .sl-msg--red {
    --tone: var(--red);
  }

  .sl-msg--rtl {
    flex-direction: row;
  }

  .sl-msg-text {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.68rem;
    line-height: 1.35;
    color: var(--sl-color-white);
    word-break: break-word;
    min-width: 0;
    flex: 1;
  }

  .sl-arrow {
    flex: 0 0 auto;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1;
    color: color-mix(in srgb, var(--tone) 85%, var(--sl-color-white));
  }

  /* ---- Server row ---- */
  .sl-row {
    position: relative;
    padding: 0.5rem 0.6rem;
    border-radius: 0.45rem;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-black);
  }

  .sl-row--new {
    border-color: color-mix(in srgb, var(--green) 55%, transparent);
    background: color-mix(in srgb, var(--green) 10%, var(--sl-color-black));
  }

  .sl-row--bumped {
    border-color: color-mix(in srgb, var(--green) 40%, transparent);
  }

  .sl-row--deleted {
    border-color: color-mix(in srgb, var(--red) 55%, transparent);
    background: color-mix(in srgb, var(--red) 9%, var(--sl-color-black));
  }

  .sl-row--deleted .sl-row-code {
    opacity: 0.55;
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--red) 75%, transparent);
  }

  .sl-row--absent {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--red) 45%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--red) 5%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
  }

  .sl-row-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .sl-row-tag--new {
    color: var(--sl-color-green-high, #4ade80);
  }

  .sl-row-tag--del {
    color: color-mix(in srgb, var(--red) 80%, var(--sl-color-white));
  }

  .sl-row-code {
    display: block;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    line-height: 1.5;
    color: var(--sl-color-white);
    word-break: break-word;
  }

  .sl-v {
    color: var(--sl-color-green-high, #4ade80);
  }

  /* The bumped field gets a brief highlight so the change is obvious. */
  .sl-v--hot {
    color: #fff;
    background: var(--green);
    padding: 0 0.25rem;
    border-radius: 0.25rem;
    font-weight: 600;
  }

  .sl-row-empty {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--red) 80%, var(--sl-color-white));
  }

  .sl-verdict {
    font-size: 0.74rem;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
    padding-left: 0.1rem;
    border-left: 2px solid var(--tone);
    padding-inline-start: 0.5rem;
  }

  .sl-verdict--green {
    --tone: var(--green);
  }
  .sl-verdict--red {
    --tone: var(--red);
    color: color-mix(in srgb, var(--red) 22%, var(--sl-color-white));
  }

  /* Stack the three columns on narrow viewports. The wire's arrows still read
     top-to-bottom (browser above, server below). */
  @media (max-width: 680px) {
    .sl-stage {
      grid-template-columns: 1fr;
    }

    .sl-arrow--r {
      transform: rotate(90deg);
    }
    .sl-arrow--l {
      transform: rotate(90deg);
    }
  }
</style>
