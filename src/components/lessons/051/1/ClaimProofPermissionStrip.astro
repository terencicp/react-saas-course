---
// ClaimProofPermissionStrip — Chapter 051 Lesson 1 ("Authn, authz, and the
// 401/403 split"), the figure for the section "Identification, authentication,
// authorization — three things, not two".
//
// Pedagogical goal: make the ESCALATION visible. The three concerns stack —
// each layer presupposes the one beneath it (you can't authorize an identity
// you haven't authenticated; you can't authenticate a claim that was never
// made). A vertical stack ordered BOTTOM-TO-TOP encodes "rests on the one
// below" literally: Identification is the base, Authentication the middle,
// Authorization the cap. A small "builds on ↓" rail down the left edge plus a
// rising question per band reinforce that each layer asks a sharper question
// than the last. (The lesson's other diagram, the 401/403 flowchart, is a
// horizontal LR flow — keeping this one vertical also gives visual variety.)
//
// This is a simple labelled aid, NOT a system graph. Plain HTML + CSS per the
// diagram index's "color-coded segments with callouts" / "nested hierarchies"
// row. Inline style strings for every primitive so a reader can copy the source
// and see exactly what styled it; `margin: 0` on every element defeats
// Starlight's injected prose margin-top; `not-content` on the root does the
// same for the article-level reset.
//
// Each band carries three pieces of text: the layer name (the Term), the
// question it answers, and the concrete sign-in-form example. Three distinct
// saturated hues (Tailwind 600-range) keep the concepts visually separable and
// hold contrast on both light and dark page backgrounds; white text on the
// fills keeps the colour the signal. Intensity rises up the stack to echo the
// escalation: warm slate (a soft, unproven claim) -> blue (proof) -> violet
// (the permission gate).

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const reset = "margin: 0";

// Per-layer accents (Tailwind 600-range). Distinct hues, rising intensity.
const SLATE = "#475569"; // identification — the soft, unproven claim (base)
const BLUE = "#2563eb"; // authentication — the proof
const VIOLET = "#7c3aed"; // authorization — the permission gate (cap)

type Layer = {
  /** The concept name shown as the band's heading. */
  name: string;
  /** The question this layer answers. */
  question: string;
  /** The concrete sign-in-form example. */
  example: string;
  /** Saturated fill for the band. */
  color: string;
};

// Authored top-to-bottom for reading order (Authorization first in the DOM so
// it sits at the visual top of the stack); the base of the stack is the last
// entry, which is what every band above "rests on".
const layers: Layer[] = [
  {
    name: "Authorization",
    question: "May you do this specific thing?",
    example: "Your role is checked before the delete runs.",
    color: VIOLET,
  },
  {
    name: "Authentication",
    question: "Can you prove that claim?",
    example: "The password matches the stored hash.",
    color: BLUE,
  },
  {
    name: "Identification",
    question: "Who do you claim to be?",
    example: "The email you type into the form.",
    color: SLATE,
  },
];

// ---- styles --------------------------------------------------------------

// The stack: a column of bands top (Authorization) to bottom (Identification),
// capped so the whole figure stays short. Centred with a comfortable max width.
const stack = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 560px",
  "margin-left: auto",
  "margin-right: auto",
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
].join("; ");

// One band: the saturated fill, white text, a left rail (the lighter strip the
// "builds on" arrows sit against), then the three text pieces in a row.
const band = (color: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "gap: 14px",
    "padding: 12px 16px",
    "border-radius: 12px",
    `background: ${color}`,
    "color: #ffffff",
  ].join("; ");

// Left cell: the layer name, the band's heading. Fixed width so the three
// names form a clean column and the questions/examples align across bands.
const nameCell = [
  reset,
  "box-sizing: border-box",
  "flex: 0 0 124px",
  "font-size: 16px",
  "font-weight: 800",
  "letter-spacing: 0.01em",
  "line-height: 1.2",
].join("; ");

// Right cell: question stacked over example, takes the remaining width.
const textCell = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 auto",
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
  "gap: 3px",
].join("; ");

// The question — the prominent line of the pair.
const questionLine = [
  reset,
  "box-sizing: border-box",
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.3",
].join("; ");

// The concrete example — slightly recessed beneath the question.
const exampleLine = [
  reset,
  "box-sizing: border-box",
  "font-size: 12.5px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: rgba(255, 255, 255, 0.82)",
].join("; ");

// The "builds on" connector between two bands: a centred down-arrow with a
// short caption, in muted theme-aware grey so it reads as chrome, not a band.
const connector = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "gap: 7px",
  "color: var(--sl-color-gray-3)",
].join("; ");

const connectorLabel = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.07em",
  "text-transform: uppercase",
  "line-height: 1",
].join("; ");

// A downward chevron drawn from borders so it needs no font glyph and inherits
// the connector's currentColor.
const chevron = [
  reset,
  "box-sizing: border-box",
  "width: 0",
  "height: 0",
  "border-left: 6px solid transparent",
  "border-right: 6px solid transparent",
  "border-top: 7px solid currentColor",
].join("; ");

// A small footing slab under the base band — a visual "ground" the stack rests
// on, making the foundation metaphor unmistakable.
const footing = [
  reset,
  "box-sizing: border-box",
  "width: 70%",
  "max-width: 360px",
  "height: 6px",
  "margin-left: auto",
  "margin-right: auto",
  "margin-top: 4px",
  "border-radius: 0 0 6px 6px",
  "background: var(--sl-color-gray-5)",
  "border-bottom: 2px solid var(--sl-color-gray-4)",
].join("; ");
---

<div class="not-content" style={stack}>
  {
    layers.map((layer, i) => (
      <>
        <div style={band(layer.color)}>
          <div style={nameCell}>{layer.name}</div>
          <div style={textCell}>
            <p style={questionLine}>{layer.question}</p>
            <p style={exampleLine}>{layer.example}</p>
          </div>
        </div>
        {i < layers.length - 1 && (
          <div style={connector} aria-hidden="true">
            <span style={connectorLabel}>builds on</span>
            <span style={chevron} />
          </div>
        )}
      </>
    ))
  }
  <div style={footing} aria-hidden="true"></div>
</div>
