---
// "Token taxonomy" — Chapter 051 L3, "OAuth 2.1, PKCE, and the code-for-tokens
// exchange".
//
// A compact comparison table holding the three tokens that arrive together in
// the token response apart by *purpose*, which is where beginners conflate
// them. Five columns — Token / Lifetime / Lives where / Purpose / Kept for a
// pure login? — and three rows (access, refresh, id token). The rightmost
// column is the punchline the caption sets up ("you read identity and can
// discard the rest"): each cell carries a small verdict pill so the "what do I
// actually keep?" answer reads at a glance. The id_token row — the one that
// answers "who is this?" and the only one a login truly needs — gets a faint
// accent tint so the eye lands on it.
//
// Engine: a real semantic <table> styled with HTML + CSS. A token -> attributes
// matrix is exactly a table (header row + a row header per token), so plain
// HTML beats any graph engine, and the placeholder asks for this shape directly.
//
// Styling mirrors the sibling lesson figures (051/3 RolesMapping): inline style
// arrays joined with '; ', `not-content` to drop Starlight's prose/table chrome,
// `margin: 0` resets to defeat the prose-margin selector, theme-aware chrome via
// Starlight CSS variables, and the one accent (indigo, matching the flow
// diagram's app-side rects) mixed with color-mix so the tint reads on both
// light and dark themes.
//
// <Figure> + caption are supplied by the MDX, not here.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Indigo — the same hue the eight-step flow diagram tints the app-side rects
// with. A saturated mid-tone that reads on light and dark page backgrounds;
// only ever used via color-mix so the tint stays subtle.
const indigo = "#6366f1";

// The verdict shown in the "Kept for a pure login?" column. Three flavours, each
// with its own hue so the answer is scannable down the column:
//  - "no"   (rose)   — discarded after one use, don't store it
//  - "maybe"(amber)  — only if a later feature needs it
//  - "read" (teal)   — read for identity, then not needed as a token
type Verdict = "no" | "maybe" | "read";

const verdictHue: Record<Verdict, string> = {
  no: "#e11d48", // rose-600
  maybe: "#d97706", // amber-600
  read: "#0d9488", // teal-600
};

type TokenRow = {
  // Token name. `mono` marks the part rendered monospace (the literal token
  // name); `sub` is a parenthetical clarifier shown muted under it.
  name: string;
  sub?: string;
  lifetime: string;
  livesWhere: string;
  purpose: string;
  // The verdict pill text + flavour for the rightmost column.
  kept: string;
  keptVerdict: Verdict;
  // Whether this is the identity token — the one a login actually needs. Gets
  // the faint accent tint across the row.
  accent?: boolean;
};

const rows: TokenRow[] = [
  {
    name: "access_token",
    lifetime: "minutes to ~1h",
    livesWhere: "server-side (here)",
    purpose: "call the resource server's APIs — a bearer credential",
    kept: "No",
    keptVerdict: "no",
  },
  {
    name: "refresh_token",
    lifetime: "long-lived",
    livesWhere: "server-side only, never the browser",
    purpose: "mint new access tokens without re-prompting the user",
    kept: "Usually not",
    keptVerdict: "maybe",
  },
  {
    name: "id_token",
    sub: "OIDC",
    lifetime: "short",
    livesWhere: "read once on the callback",
    purpose: "carry identity claims (sub, email, aud, iss, exp) — a signed JWT",
    kept: "Read, not stored",
    keptVerdict: "read",
    accent: true,
  },
];

// ── Outer wrapper ───────────────────────────────────────────────────────────
// Five terse columns; let it run close to page width but cap so it never
// stretches awkwardly on very wide cards.
const wrap = [
  reset,
  sans,
  "box-sizing: border-box",
  "max-width: 960px",
  "margin: 0 auto",
  "overflow-x: auto",
].join("; ");

const table = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "min-width: 640px",
  "border-collapse: separate",
  "border-spacing: 0",
].join("; ");

// ── Header row ──────────────────────────────────────────────────────────────
const headBase = [
  reset,
  sans,
  "box-sizing: border-box",
  "padding: 9px 14px",
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1.3",
  "letter-spacing: 0.01em",
  "text-align: left",
  "vertical-align: bottom",
  "color: var(--sl-color-gray-2)",
  "border-bottom: 1.5px solid var(--sl-color-gray-4)",
].join("; ");

// ── Body cells ──────────────────────────────────────────────────────────────
const cellBase = [
  reset,
  sans,
  "box-sizing: border-box",
  "padding: 11px 14px",
  "vertical-align: top",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
  "font-size: 13.5px",
  "line-height: 1.4",
];

// Faint accent wash for the id_token row so the eye lands on the one a login
// actually needs.
const tint = `background: color-mix(in srgb, ${indigo} 8%, var(--sl-color-bg))`;

const cellText = (accent?: boolean) =>
  [...cellBase, "color: var(--sl-color-gray-2)", ...(accent ? [tint] : [])].join(
    "; ",
  );

// The token-name row header.
const cellName = (accent?: boolean) =>
  [
    ...cellBase,
    "text-align: left",
    "white-space: nowrap",
    ...(accent ? [tint] : []),
  ].join("; ");

// The monospace token literal inside the row header; transparent so it gets no
// inline-code pill, and sized to stand out as the row's anchor.
const nameMono = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 13.5px",
  "font-weight: 700",
  "color: var(--sl-color-text)",
  "background: transparent",
  "padding: 0",
].join("; ");

// The "OIDC" clarifier under the id_token name.
const nameSub = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: block",
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "margin: 3px 0 0",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Monospace fragments embedded in the purpose prose (claim names) — kept inline
// and pill-free so they don't bloat the cell.
const inlineMono = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 12.5px",
  "color: var(--sl-color-text)",
  "background: transparent",
  "padding: 0",
].join("; ");

// ── The verdict pill ──────────────────────────────────────────────────────────
const keptCell = (accent?: boolean) =>
  [...cellBase, "white-space: nowrap", ...(accent ? [tint] : [])].join("; ");

const verdictPill = (v: Verdict) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: inline-block",
    "font-size: 12px",
    "font-weight: 700",
    "line-height: 1.2",
    "padding: 3px 9px",
    "border-radius: 999px",
    `background: color-mix(in srgb, ${verdictHue[v]} 14%, var(--sl-color-bg))`,
    `border: 1px solid color-mix(in srgb, ${verdictHue[v]} 45%, transparent)`,
    `color: color-mix(in srgb, ${verdictHue[v]} 72%, var(--sl-color-text))`,
  ].join("; ");
---

<div class="not-content" style={wrap}>
  <table style={table}>
    <thead>
      <tr>
        <th scope="col" style={headBase}>Token</th>
        <th scope="col" style={headBase}>Lifetime</th>
        <th scope="col" style={headBase}>Lives where</th>
        <th scope="col" style={headBase}>Purpose</th>
        <th scope="col" style={headBase}>Kept for a pure login?</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((r) => (
          <tr>
            <th scope="row" style={cellName(r.accent)}>
              <code style={nameMono}>{r.name}</code>
              {r.sub && <span style={nameSub}>{r.sub}</span>}
            </th>
            <td style={cellText(r.accent)}>{r.lifetime}</td>
            <td style={cellText(r.accent)}>{r.livesWhere}</td>
            <td style={cellText(r.accent)}>
              {/* The id_token purpose lists claim names monospace; the others
                  are plain prose. Rendered manually so the claims read as code
                  without an MDX round-trip. */}
              {r.name === "id_token" ? (
                <>
                  carry identity claims (
                  <code style={inlineMono}>sub</code>,{" "}
                  <code style={inlineMono}>email</code>,{" "}
                  <code style={inlineMono}>aud</code>,{" "}
                  <code style={inlineMono}>iss</code>,{" "}
                  <code style={inlineMono}>exp</code>) — a signed JWT
                </>
              ) : (
                r.purpose
              )}
            </td>
            <td style={keptCell(r.accent)}>
              <span style={verdictPill(r.keptVerdict)}>{r.kept}</span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
