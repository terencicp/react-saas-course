---
// "Roles mapping" — Chapter 051 L3, "OAuth 2.1, PKCE, and the code-for-tokens
// exchange".
//
// A compact reference table mapping the four spec-named OAuth roles to who
// actually plays each one in a "Sign in with Google" login. The whole point of
// the figure is the punchline that one company (Google) wears two of the four
// hats: the authorization server AND the resource server. So the two Google-
// server rows share a subtle blue tint and a bracket on the right reading
// "both are Google", driving home that there aren't four machines on the wire.
//
// Engine: a real semantic <table> styled with HTML + CSS — a role -> actor
// mapping is exactly a two-column table (header row + row headers), so plain
// HTML beats any graph engine here. A third, borderless gutter column carries a
// single rowspan=2 cell with the bracket + label spanning the two server rows.
//
// Styling mirrors the sibling lesson figures (e.g. 049/1 SupportMatrix): inline
// style arrays joined with '; ', `not-content` to drop Starlight's prose/table
// chrome, `margin: 0` resets to defeat the prose-margin selector, theme-aware
// chrome via Starlight CSS variables, and the one accent (Google blue) mixed
// with color-mix so the tint reads on both light and dark themes.
//
// <Figure> + caption are supplied by the MDX, not here.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Google's brand blue — a saturated mid-tone that reads on light and dark page
// backgrounds. Only ever used via color-mix so the tint stays subtle.
const blue = "#1a73e8";

type Role = {
  // The spec role name.
  role: string;
  // Who plays it in a Google login. `mono` marks a value rendered monospace
  // (an endpoint / hostname) rather than plain prose.
  actor: string;
  mono?: boolean;
  // Whether this row is one of the two Google plays (gets the blue tint + is
  // spanned by the bracket).
  google?: boolean;
};

const rows: Role[] = [
  { role: "Resource owner", actor: "The human signing in" },
  { role: "Client", actor: "Your app" },
  { role: "Authorization server", actor: "accounts.google.com", mono: true, google: true },
  { role: "Resource server", actor: "Google's userinfo endpoint", google: true },
];

// ── Outer wrapper ───────────────────────────────────────────────────────────
// Capped + centred so the two columns stay tight; a reference table, not a hero.
const wrap = [
  reset,
  sans,
  "box-sizing: border-box",
  "max-width: 620px",
  "margin: 0 auto",
].join("; ");

const table = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "border-collapse: separate",
  "border-spacing: 0",
].join("; ");

// ── Header row ──────────────────────────────────────────────────────────────
const headBase = [
  reset,
  sans,
  "box-sizing: border-box",
  "padding: 9px 14px",
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1.3",
  "letter-spacing: 0.01em",
  "text-align: left",
  "vertical-align: bottom",
  "color: var(--sl-color-gray-2)",
  "border-bottom: 1.5px solid var(--sl-color-gray-4)",
];

const headRole = headBase.join("; ");
const headActor = headBase.join("; ");
// The gutter header is empty and carries no rule.
const headGutter = [
  reset,
  "box-sizing: border-box",
  "padding: 0",
  "border: 0",
].join("; ");

// ── Body cells ──────────────────────────────────────────────────────────────
const cellBase = [
  reset,
  sans,
  "box-sizing: border-box",
  "padding: 11px 14px",
  "vertical-align: middle",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
];

// Plain (non-Google) rows.
const cellRole = [
  ...cellBase,
  "text-align: left",
  "font-weight: 600",
  "font-size: 14px",
  "color: var(--sl-color-text)",
].join("; ");

const cellActor = [
  ...cellBase,
  "text-align: left",
  "font-size: 14px",
  "color: var(--sl-color-gray-2)",
].join("; ");

// Google rows: a faint blue wash on both cells so the pair reads as one band.
const tint = `background: color-mix(in srgb, ${blue} 8%, var(--sl-color-bg))`;
const cellRoleG = [...cellBase, "text-align: left", "font-weight: 600", "font-size: 14px", "color: var(--sl-color-text)", tint].join("; ");
const cellActorG = [...cellBase, "text-align: left", "font-size: 14px", "color: var(--sl-color-gray-1)", tint].join("; ");

// Monospace endpoint values sit inline; transparent so no inline-code pill.
const endpoint = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 13px",
  "font-weight: 600",
  "color: var(--sl-color-text)",
  "background: transparent",
  "padding: 0",
].join("; ");

// ── The "both are Google" bracket gutter ─────────────────────────────────────
// A single rowspan=2 cell holds a flex row: a curly-bracket drawn as an SVG
// path, then the stacked label. The bracket spans exactly the two server rows.
const gutterCell = [
  reset,
  "box-sizing: border-box",
  "padding: 0 0 0 12px",
  "vertical-align: middle",
  "border: 0",
  "white-space: nowrap",
].join("; ");

const gutterRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "gap: 8px",
].join("; ");

const bracketColor = `color: color-mix(in srgb, ${blue} 65%, var(--sl-color-gray-2))`;
const bracketSvg = [reset, "box-sizing: border-box", "display: block", "flex: none"].join("; ");

const label = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 12px",
  "line-height: 1.25",
  "font-weight: 600",
  bracketColor,
].join("; ");

const labelStrong = [reset, "box-sizing: border-box", "display: block", "font-weight: 800"].join("; ");
const labelSub = [
  reset,
  "box-sizing: border-box",
  "display: block",
  "font-weight: 500",
  "font-size: 11px",
  "margin: 1px 0 0",
  "color: var(--sl-color-gray-3)",
].join("; ");
---

<div class="not-content" style={wrap}>
  <table style={table}>
    <thead>
      <tr>
        <th scope="col" style={headRole}>Role</th>
        <th scope="col" style={headActor}>Who plays it in a Google login</th>
        <th scope="col" style={headGutter} aria-hidden="true"></th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((r, i) => (
          <tr>
            <th scope="row" style={r.google ? cellRoleG : cellRole}>
              {r.role}
            </th>
            <td style={r.google ? cellActorG : cellActor}>
              {r.mono ? <code style={endpoint}>{r.actor}</code> : r.actor}
            </td>
            {/* The bracket cell is emitted once, on the first Google row, and
                spans both server rows via rowspan. */}
            {r.role === "Authorization server" && (
              <td rowspan="2" style={gutterCell}>
                <div style={gutterRow}>
                  <svg
                    width="11"
                    height="54"
                    viewBox="0 0 11 54"
                    fill="none"
                    style={bracketSvg}
                    aria-hidden="true"
                  >
                    <path
                      d="M9 1 C4 1 4 5 4 9 L4 23 C4 26 3 27 1 27 C3 27 4 28 4 31 L4 45 C4 49 4 53 9 53"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span style={label}>
                    <span style={labelStrong}>both are Google</span>
                    <span style={labelSub}>one company, two server roles</span>
                  </span>
                </div>
              </td>
            )}
            {/* Non-Google rows still need their gutter cell so the grid stays
                rectangular; the second Google row is covered by the rowspan. */}
            {!r.google && (
              <td style={headGutter} aria-hidden="true"></td>
            )}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
