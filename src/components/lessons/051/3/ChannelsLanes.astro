---
// "Channels lanes" — Chapter 051 L3, "OAuth 2.1, PKCE, and the code-for-tokens
// exchange".
//
// A two-lane anchor visual for the front-channel / back-channel distinction —
// the load-bearing framing the rest of the lesson leans on. Two stacked
// horizontal lanes, each a rounded saturated bar: the TOP lane is the front
// channel (browser, redirects, URLs) in a cautionary amber, carrying the
// authorization request and the callback-with-?code chips; the BOTTOM lane is
// the back channel (server <-> server, HTTPS) in a safe teal, carrying the
// token exchange and the tokens-returned chips. The colour split IS the
// argument: warm = "watch out, anything here is visible"; cool = "trusted, TLS,
// secrets are safe". A minimal App / Google gutter on the right implies both
// lanes connect the same two parties without committing to a single direction.
//
// Engine: plain HTML + CSS. The diagram guidance routes "color-coded segments
// with callouts / sequential phase strips" to HTML+CSS, and the pedagogical USP
// is that the lanes are real flex layout a reader can inspect in devtools. This
// is a small spatial anchor, not the main diagram (that is the eight-step
// DiagramSequence below it), so the height is capped tight.
//
// Styling mirrors the sibling lesson figures (e.g. 051/3 RolesMapping): inline
// style arrays joined with '; ', `not-content` to drop Starlight prose chrome,
// `margin: 0` resets on every inner element to defeat the prose-margin selector,
// saturated 600-range fills with white text so the colour reads on both light
// and dark themes, and theme-aware neutral chrome via Starlight CSS variables
// for the App / Google endpoint pills.
//
// <Figure> + caption are supplied by the MDX, not here.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// The two channel hues: a cautionary amber for the untrusted front channel, a
// safe teal for the trusted back channel. Both saturated mid-tones that read
// under white text on light and dark page backgrounds.
const amber = "#d97706"; // amber-600 — "watch out"
const teal = "#0d9488"; // teal-600  — "safe"

type Lane = {
  // Accent hue for the lane bar fill.
  hue: string;
  // Channel name (white, bold) on the left label block.
  name: string;
  // The trust verdict shown as a badge under the name.
  badge: string;
  // Longer trust subtitle under the badge.
  trust: string;
  // What travels here, left -> right. `mono` marks a chip whose text is an
  // artifact (a URL fragment / a payload) rather than prose.
  chips: { text: string; mono?: boolean }[];
};

const lanes: Lane[] = [
  {
    hue: amber,
    name: "Front channel",
    badge: "untrusted",
    trust: "browser, redirects, URLs — visible in history, logs, Referer, extensions",
    chips: [
      { text: "authorization request" },
      { text: "callback with ?code=…&state=…", mono: true },
    ],
  },
  {
    hue: teal,
    name: "Back channel",
    badge: "trusted",
    trust: "server ↔ server, HTTPS — TLS end to end, no browser in the middle",
    chips: [
      { text: "token exchange (code + secret + verifier)", mono: true },
      { text: "tokens returned" },
    ],
  },
];

// ── Outer wrapper ─────────────────────────────────────────────────────────────
// Capped + centred so the lanes stay legible rather than stretched page-wide.
const wrap = [
  reset,
  sans,
  "box-sizing: border-box",
  "max-width: 860px",
  "margin: 0 auto",
  "display: flex",
  "align-items: stretch",
  "gap: 12px",
].join("; ");

// The two lanes stack vertically and flex to fill the width left of the gutter.
const lanesCol = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "flex: 1 1 auto",
  "min-width: 0",
].join("; ");

// ── A lane bar ────────────────────────────────────────────────────────────────
// The whole bar is the saturated fill; the label block sits inset darker on the
// left, the chips ride the rest. Wraps gracefully on narrow cards.
const laneBar = (hue: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-wrap: wrap",
    "align-items: center",
    "column-gap: 14px",
    "row-gap: 10px",
    "padding: 12px 14px",
    "border-radius: 12px",
    `background: ${hue}`,
    "border: 1px solid rgba(0, 0, 0, 0.12)",
    "color: #fff",
  ].join("; ");

// Left label block: name + badge + trust line, all white on the fill.
const labelBlock = [
  reset,
  "box-sizing: border-box",
  "flex: 0 1 260px",
  "min-width: 200px",
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
].join("; ");

const nameRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "flex-wrap: wrap",
  "gap: 8px",
].join("; ");

const laneName = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 15px",
  "font-weight: 800",
  "line-height: 1.2",
  "color: #fff",
].join("; ");

// The trust verdict pill — a brighter inset on the fill so "untrusted" /
// "trusted" pops as the one-word judgement.
const badge = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 10.5px",
  "font-weight: 800",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 3px 7px",
  "border-radius: 999px",
  "background: rgba(255, 255, 255, 0.22)",
  "border: 1px solid rgba(255, 255, 255, 0.4)",
  "color: #fff",
  "white-space: nowrap",
].join("; ");

const trustLine = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 11.5px",
  "font-weight: 500",
  "line-height: 1.35",
  "color: rgba(255, 255, 255, 0.92)",
].join("; ");

// ── Chips row ─────────────────────────────────────────────────────────────────
// The chips that ride the lane, with a small arrow between them suggesting the
// left -> right order in which they travel.
const chipsRow = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 320px",
  "min-width: 0",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "column-gap: 8px",
  "row-gap: 8px",
].join("; ");

const chipBase = [
  reset,
  "box-sizing: border-box",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.25",
  "padding: 6px 11px",
  "border-radius: 8px",
  "background: rgba(255, 255, 255, 0.2)",
  "border: 1px solid rgba(255, 255, 255, 0.45)",
  "color: #fff",
];

const chipSans = [...chipBase, sans].join("; ");
const chipMono = [...chipBase, mono, "font-size: 12px"].join("; ");

const arrow = [
  reset,
  "box-sizing: border-box",
  "font-size: 14px",
  "font-weight: 800",
  "line-height: 1",
  "color: rgba(255, 255, 255, 0.85)",
].join("; ");

// ── App / Google endpoint gutter ──────────────────────────────────────────────
// A minimal right-side column: an "App" pill over a "Google" pill with a vertical
// double-arrow between, implying both lanes run between the same two parties.
// Theme-native neutral chrome so it doesn't compete with the coloured lanes.
const gutter = [
  reset,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "justify-content: center",
  "gap: 6px",
  "padding-left: 2px",
].join("; ");

const endpointPill = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1",
  "text-align: center",
  "padding: 9px 12px",
  "border-radius: 8px",
  "background: var(--sl-color-bg-sidebar)",
  "border: 1px solid var(--sl-color-gray-4)",
  "color: var(--sl-color-text)",
  "white-space: nowrap",
].join("; ");

const linker = [
  reset,
  "box-sizing: border-box",
  "font-size: 15px",
  "font-weight: 800",
  "line-height: 1",
  "text-align: center",
  "color: var(--sl-color-gray-3)",
].join("; ");

const linkerLabel = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 9.5px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "text-align: center",
  "line-height: 1",
  "margin: 1px 0 0",
  "color: var(--sl-color-gray-3)",
].join("; ");
---

<div class="not-content" style={wrap}>
  <div style={lanesCol}>
    {
      lanes.map((lane) => (
        <div style={laneBar(lane.hue)}>
          <div style={labelBlock}>
            <div style={nameRow}>
              <span style={laneName}>{lane.name}</span>
              <span style={badge}>{lane.badge}</span>
            </div>
            <span style={trustLine}>{lane.trust}</span>
          </div>
          <div style={chipsRow}>
            {lane.chips.map((chip, i) => (
              <>
                {i > 0 && (
                  <span style={arrow} aria-hidden="true">
                    →
                  </span>
                )}
                <span style={chip.mono ? chipMono : chipSans}>{chip.text}</span>
              </>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  {/* Both lanes connect the same two parties. */}
  <div style={gutter}>
    <span style={endpointPill}>App</span>
    <div>
      <div style={linker} aria-hidden="true">
        ⇅
      </div>
      <div style={linkerLabel}>both lanes</div>
    </div>
    <span style={endpointPill}>Google</span>
  </div>
</div>
