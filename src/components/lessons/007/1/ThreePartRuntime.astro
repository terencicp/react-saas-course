---
// Diagram: the three pieces of the runtime — call stack, microtask queue,
// macrotask queue — laid out as three labeled panels. Each panel's content
// hints at its shape: the call stack is drawn as a vertical pile of cells
// (bottom to top, with a "top" marker); the two queues are drawn as
// horizontal rows of cells with a "next" marker on the leftmost slot.
//
// Pure HTML + CSS, no interactivity. Three saturated mid-tones — readable
// on light and dark backgrounds — make the three pieces easy to refer to
// in the surrounding prose. The illustrative cells inside each panel are
// muted greys: they are shape hints, not semantic content.
//
// On narrow viewports the three columns stack vertically.

import Figure from '../../../figures/Figure.astro';

const STACK_COLOR = '#0d9488';     // teal-600 — call stack
const MICROTASK_COLOR = '#7c3aed'; // violet-600 — microtask queue
const MACROTASK_COLOR = '#dc2626'; // red-600 — macrotask queue

const headerStyle = (color: string) =>
	[
		'margin: 0',
		'padding: 4px 10px',
		'border-radius: 999px',
		'font-family: system-ui, -apple-system, "Segoe UI", sans-serif',
		'font-size: 11px',
		'font-weight: 700',
		'text-transform: uppercase',
		'letter-spacing: 0.06em',
		'color: #ffffff',
		`background: ${color}`,
		`border: 1px solid ${color}`,
		'align-self: center',
		'white-space: nowrap',
	].join('; ');

const panelStyle = (color: string) =>
	[
		'margin: 0',
		'padding: 14px 14px 12px',
		'border-radius: 10px',
		`border: 1px solid color-mix(in srgb, ${color} 45%, transparent)`,
		`background: color-mix(in srgb, ${color} 8%, transparent)`,
		'display: flex',
		'flex-direction: column',
		'gap: 12px',
		'min-width: 0',
	].join('; ');

const subtitleStyle =
	'margin: 0; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 12px; line-height: 1.45; color: var(--sl-color-gray-2); text-align: center;';

const markerStyle =
	'margin: 0; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 10.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--sl-color-gray-3);';

const cellMonoStyle =
	'margin: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; color: var(--sl-color-gray-2);';

// Vertical stack cell — call stack
const stackCellStyle =
	'margin: 0; padding: 6px 10px; border-radius: 4px; background: var(--sl-color-bg-sidebar); border: 1px solid color-mix(in srgb, currentColor 22%, transparent); text-align: center;';

// Horizontal queue cell
const queueCellStyle =
	'margin: 0; padding: 6px 10px; border-radius: 4px; background: var(--sl-color-bg-sidebar); border: 1px solid color-mix(in srgb, currentColor 22%, transparent); min-width: 32px; text-align: center;';

// Inline SVG: short rightward arrow used to hint queue direction
---

<Figure
	caption="The call stack drains synchronous code; between macrotasks the microtask queue is drained completely."
>
	<div class="tpr-grid">
		{/* CALL STACK — vertical, bottom to top */}
		<div style={panelStyle(STACK_COLOR)}>
			<div style={headerStyle(STACK_COLOR)}>Call stack</div>
			<div class="tpr-stack-body">
				<div style={markerStyle}>Top (runs now) &darr;</div>
				<div class="tpr-stack">
					<div style={stackCellStyle}><span style={cellMonoStyle}>frame</span></div>
					<div style={stackCellStyle}><span style={cellMonoStyle}>frame</span></div>
					<div style={stackCellStyle}><span style={cellMonoStyle}>frame</span></div>
				</div>
				<div class="tpr-baseline" aria-hidden="true"></div>
			</div>
			<div style={subtitleStyle}>
				Synchronous frames.<br />Top entry is what runs now.
			</div>
		</div>

		{/* MICROTASK QUEUE — horizontal, leftmost next */}
		<div style={panelStyle(MICROTASK_COLOR)}>
			<div style={headerStyle(MICROTASK_COLOR)}>Microtask queue</div>
			<div class="tpr-queue-body">
				<div class="tpr-queue-headrow">
					<div style={markerStyle}>Next &rarr;</div>
				</div>
				<div class="tpr-queue">
					<div style={queueCellStyle}><span style={cellMonoStyle}>task</span></div>
					<div style={queueCellStyle}><span style={cellMonoStyle}>task</span></div>
					<div style={queueCellStyle}><span style={cellMonoStyle}>task</span></div>
					<div style={queueCellStyle}><span style={cellMonoStyle}>task</span></div>
				</div>
			</div>
			<div style={subtitleStyle}>
				Promise continuations,<br /><code class="tpr-code">await</code> resumptions, <code class="tpr-code">queueMicrotask</code>.
			</div>
		</div>

		{/* MACROTASK QUEUE — horizontal, leftmost next */}
		<div style={panelStyle(MACROTASK_COLOR)}>
			<div style={headerStyle(MACROTASK_COLOR)}>Macrotask queue</div>
			<div class="tpr-queue-body">
				<div class="tpr-queue-headrow">
					<div style={markerStyle}>Next &rarr;</div>
				</div>
				<div class="tpr-queue">
					<div style={queueCellStyle}><span style={cellMonoStyle}>task</span></div>
					<div style={queueCellStyle}><span style={cellMonoStyle}>task</span></div>
					<div style={queueCellStyle}><span style={cellMonoStyle}>task</span></div>
				</div>
			</div>
			<div style={subtitleStyle}>
				<code class="tpr-code">setTimeout</code>, I/O,<br />message events, user input.
			</div>
		</div>
	</div>
</Figure>

<style>
	.tpr-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr) minmax(0, 1.15fr);
		gap: 14px;
		align-items: stretch;
		margin: 0;
	}

	.tpr-stack-body {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		margin: 0;
	}

	.tpr-stack {
		display: flex;
		flex-direction: column;
		gap: 4px;
		width: 100%;
		max-width: 160px;
		margin: 0;
	}

	.tpr-baseline {
		width: 100%;
		max-width: 180px;
		border-bottom: 2px solid color-mix(in srgb, currentColor 35%, transparent);
		margin: 2px 0 0;
	}

	.tpr-queue-body {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 6px;
		margin: 0;
	}

	.tpr-queue-headrow {
		display: flex;
		justify-content: flex-start;
		margin: 0;
	}

	.tpr-queue {
		display: flex;
		flex-direction: row;
		gap: 4px;
		margin: 0;
		justify-content: flex-start;
		flex-wrap: nowrap;
		overflow: hidden;
	}

	.tpr-queue > div {
		flex: 1 1 0;
	}

	.tpr-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		padding: 0 4px;
		border-radius: 3px;
		background: color-mix(in srgb, currentColor 8%, transparent);
	}

	@media (max-width: 720px) {
		.tpr-grid {
			grid-template-columns: minmax(0, 1fr);
			gap: 12px;
		}
	}
</style>
