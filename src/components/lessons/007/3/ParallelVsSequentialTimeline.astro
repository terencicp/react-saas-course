---
// Diagram: Gantt-style comparison of three awaits run sequentially vs. via
// Promise.all. Bar widths are proportional to a 600ms total axis — the
// slowest-of-three (220ms) sits at ~37% of the axis, making the sum-vs-max
// difference visually obvious at a glance.
//
// Pure HTML + CSS. Two rows share the same time axis at the bottom.
// On the "Sequential" row, three bars stack head-to-tail. On the
// "Promise.all" row, three bars stack vertically, all anchored at t=0.

import Figure from '../../../figures/Figure.astro';

// Axis bounds: 0..AXIS_MS pixels of timeline. 600ms covers the slow case
// exactly; the parallel case lands at 220 / 600 ≈ 36.7%.
const AXIS_MS = 600;

// Three reads, with their durations and a saturated mid-tone fill that
// reads on both light and dark backgrounds.
const reads = [
	{ name: 'getUser', ms: 200, color: '#2563eb' /* blue-600 */ },
	{ name: 'getOrg', ms: 180, color: '#ea580c' /* orange-600 */ },
	{ name: 'listRecentInvoices', ms: 220, color: '#7c3aed' /* violet-600 */ },
];

const parallelTotalMs = Math.max(...reads.map((r) => r.ms));
const sequentialTotalMs = reads.reduce((s, r) => s + r.ms, 0);

// Pre-compute sequential start offsets (cumulative sum).
let acc = 0;
const sequentialBars = reads.map((r) => {
	const start = acc;
	acc += r.ms;
	return { ...r, start };
});

const pct = (ms: number) => `${(ms / AXIS_MS) * 100}%`;

// Tick marks along the shared axis.
const ticks = [0, 200, 400, 600];

const rowLabelStyle = [
	'margin: 0',
	'font-family: system-ui, -apple-system, "Segoe UI", sans-serif',
	'font-size: 11px',
	'font-weight: 700',
	'text-transform: uppercase',
	'letter-spacing: 0.06em',
	'color: var(--sl-color-gray-2)',
].join('; ');

const barTextStyle = [
	'margin: 0',
	'font-family: system-ui, -apple-system, "Segoe UI", sans-serif',
	'font-size: 12px',
	'font-weight: 600',
	'color: #ffffff',
	'white-space: nowrap',
	'overflow: hidden',
	'text-overflow: ellipsis',
].join('; ');

const totalPillStyle = [
	'margin: 0',
	'padding: 2px 8px',
	'border-radius: 999px',
	'border: 1px solid color-mix(in srgb, currentColor 30%, transparent)',
	'background: var(--sl-color-bg-sidebar)',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 11px',
	'font-weight: 600',
	'color: var(--sl-color-gray-1)',
	'white-space: nowrap',
].join('; ');

const tickLabelStyle = [
	'margin: 0',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 11px',
	'color: var(--sl-color-gray-3)',
].join('; ');
---

<Figure
	caption="Sequential awaits stack head-to-tail; Promise.all overlaps them. The total time is the sum in one case, the max in the other."
>
	<div class="pvs-grid">
		{/* ─── Sequential row ─── */}
		<div style={rowLabelStyle}>Sequential</div>
		<div class="pvs-track-wrap">
			<div class="pvs-track" style="height: 36px;">
				{sequentialBars.map((bar) => (
					<div
						class="pvs-bar"
						style={`left: ${pct(bar.start)}; width: ${pct(bar.ms)}; background: ${bar.color};`}
					>
						<span style={barTextStyle}>{bar.name} ({bar.ms}ms)</span>
					</div>
				))}
			</div>
			<div class="pvs-total pvs-total--right" style={`left: ${pct(sequentialTotalMs)};`}>
				<div class="pvs-total-line"></div>
				<div style={totalPillStyle}>Total: {sequentialTotalMs}ms</div>
			</div>
		</div>

		{/* ─── Promise.all row ─── */}
		<div style={rowLabelStyle}>Promise.all</div>
		<div class="pvs-track-wrap">
			<div class="pvs-track" style={`height: ${reads.length * 28 + (reads.length - 1) * 4}px;`}>
				{reads.map((bar, i) => (
					<div
						class="pvs-bar"
						style={`left: 0; width: ${pct(bar.ms)}; top: ${i * 32}px; height: 28px; background: ${bar.color};`}
					>
						<span style={barTextStyle}>{bar.name} ({bar.ms}ms)</span>
					</div>
				))}
			</div>
			<div class="pvs-total" style={`left: ${pct(parallelTotalMs)};`}>
				<div class="pvs-total-line"></div>
				<div style={totalPillStyle}>Total: {parallelTotalMs}ms</div>
			</div>
		</div>

		{/* ─── Shared time axis ─── */}
		<div></div>
		<div class="pvs-axis">
			<div class="pvs-axis-line"></div>
			{ticks.map((t) => (
				<div class="pvs-tick" style={`left: ${pct(t)};`}>
					<div class="pvs-tick-mark"></div>
					<div style={tickLabelStyle}>{t}ms</div>
				</div>
			))}
		</div>
	</div>
</Figure>

<style>
	.pvs-grid {
		display: grid;
		grid-template-columns: minmax(0, max-content) minmax(0, 1fr);
		column-gap: 16px;
		row-gap: 18px;
		align-items: center;
		margin: 0;
	}

	.pvs-track-wrap {
		position: relative;
		padding-bottom: 22px;
		margin: 0;
	}

	.pvs-track {
		position: relative;
		width: 100%;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-radius: 6px;
		margin: 0;
		overflow: visible;
	}

	.pvs-bar {
		position: absolute;
		top: 4px;
		height: 28px;
		border-radius: 4px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 8px;
		box-sizing: border-box;
		margin: 0;
		min-width: 0;
	}

	.pvs-total {
		position: absolute;
		top: 0;
		bottom: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		transform: translateX(-50%);
		pointer-events: none;
		margin: 0;
	}

	.pvs-total--right {
		align-items: flex-end;
		transform: translateX(-100%);
	}

	.pvs-total-line {
		width: 0;
		height: calc(100% - 22px);
		border-left: 1.5px dashed color-mix(in srgb, currentColor 40%, transparent);
		margin: 0;
	}

	.pvs-total > div:last-child {
		position: absolute;
		bottom: 0;
	}

	.pvs-axis {
		position: relative;
		height: 32px;
		margin: 0;
	}

	.pvs-axis-line {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		border-top: 1px solid color-mix(in srgb, currentColor 30%, transparent);
		margin: 0;
	}

	.pvs-tick {
		position: absolute;
		top: 0;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		margin: 0;
	}

	.pvs-tick-mark {
		width: 1px;
		height: 6px;
		background: color-mix(in srgb, currentColor 40%, transparent);
		margin: 0;
	}

	@media (max-width: 600px) {
		.pvs-grid {
			column-gap: 10px;
			row-gap: 14px;
		}
	}
</style>