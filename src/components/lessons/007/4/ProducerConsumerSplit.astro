---
// Diagram: producer-consumer split for AbortController/AbortSignal.
//
// Three-row vertical stack inside a Figure (expandable={false} because the
// ArrowDiagram's LeaderLines are positioned from document.body and don't
// survive being moved into a <dialog>):
//
//   1. "your code" — the party that decides when to cancel.
//   2. AbortController — the single producer. Sub-label `.signal` hints at
//      the value it exposes.
//   3. Three consumers side-by-side — `fetch`, `addEventListener`, `setTimeout`.
//
// Arrow choreography:
//   - One inbound arrow from "your code" to the controller, labeled `.abort()`.
//     Default theme color — this is the "trigger" axis.
//   - Three outbound arrows from the controller to each consumer, labeled
//     `signal`, all in the same orange (#f97316). Identical color reinforces
//     the pedagogical point: the same value is broadcast to many consumers.
//
// Pure HTML boxes wrapped by <ArrowDiagram>; arrows drawn by leader-line.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const SIGNAL_COLOR = '#f97316'; // orange-500 — the signal broadcast

const arrows = [
	{
		from: 'pcs-code',
		to: 'pcs-controller',
		label: '.abort(reason?)',
		startSocket: 'bottom' as const,
		endSocket: 'top' as const,
		labelOffset: [0, -2] as [number, number],
	},
	{
		from: 'pcs-controller',
		to: 'pcs-fetch',
		label: 'signal',
		color: SIGNAL_COLOR,
		startSocket: 'bottom' as const,
		endSocket: 'top' as const,
		startSocketGravity: [-160, 60] as [number, number],
		endSocketGravity: [0, -50] as [number, number],
		labelOffset: [0, -2] as [number, number],
	},
	{
		from: 'pcs-controller',
		to: 'pcs-listener',
		label: 'signal',
		color: SIGNAL_COLOR,
		startSocket: 'bottom' as const,
		endSocket: 'top' as const,
		startSocketGravity: [0, 60] as [number, number],
		endSocketGravity: [0, -50] as [number, number],
		labelOffset: [0, -2] as [number, number],
	},
	{
		from: 'pcs-controller',
		to: 'pcs-timer',
		label: 'signal',
		color: SIGNAL_COLOR,
		startSocket: 'bottom' as const,
		endSocket: 'top' as const,
		startSocketGravity: [160, 60] as [number, number],
		endSocketGravity: [0, -50] as [number, number],
		labelOffset: [0, -2] as [number, number],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="pcs-stage">
			{/* Row 1 — producer (caller) */}
			<div class="pcs-row">
				<div class="pcs-box pcs-code" id="pcs-code">
					<span class="pcs-box-eyebrow">your code</span>
					<span class="pcs-box-sub">the caller that decides <em>when</em></span>
				</div>
			</div>

			{/* Row 2 — controller */}
			<div class="pcs-row">
				<div class="pcs-box pcs-controller" id="pcs-controller">
					<span class="pcs-box-title"><code>AbortController</code></span>
					<span class="pcs-box-mono">.signal</span>
				</div>
			</div>

			{/* Row 3 — consumers */}
			<div class="pcs-row pcs-row-consumers">
				<div class="pcs-box pcs-consumer" id="pcs-fetch">
					<span class="pcs-box-eyebrow">consumer</span>
					<code class="pcs-box-code">fetch(url, &#123; signal &#125;)</code>
				</div>
				<div class="pcs-box pcs-consumer" id="pcs-listener">
					<span class="pcs-box-eyebrow">consumer</span>
					<code class="pcs-box-code">addEventListener('click', fn, &#123; signal &#125;)</code>
				</div>
				<div class="pcs-box pcs-consumer" id="pcs-timer">
					<span class="pcs-box-eyebrow">consumer</span>
					<code class="pcs-box-code">setTimeout(1_000, undefined, &#123; signal &#125;)</code>
				</div>
			</div>
		</div>
	</ArrowDiagram>

	<Fragment slot="caption">
		One producer, one signal, many consumers. The controller is held
		privately; the signal is the value you pass around.
	</Fragment>
</Figure>

<style>
	.pcs-stage {
		display: flex;
		flex-direction: column;
		gap: 56px;
		align-items: stretch;
		padding: 4px 8px 8px;
	}

	.pcs-row {
		display: flex;
		justify-content: center;
		align-items: stretch;
		gap: 14px;
	}

	.pcs-row-consumers {
		gap: 18px;
	}

	.pcs-box {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		padding: 10px 14px;
		border-radius: 10px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		text-align: center;
		min-width: 0;
	}

	.pcs-code {
		min-width: 180px;
		max-width: 260px;
		padding: 8px 14px;
		background: color-mix(in srgb, var(--sl-color-accent) 8%, var(--sl-color-bg));
		border-color: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}

	.pcs-controller {
		width: 100%;
		max-width: 360px;
		padding: 14px 18px;
		background: color-mix(in srgb, #f97316 10%, var(--sl-color-bg));
		border-color: color-mix(in srgb, #f97316 45%, transparent);
	}

	.pcs-consumer {
		flex: 1 1 0;
		max-width: 280px;
		padding: 10px 8px;
		background: color-mix(in srgb, #f97316 5%, var(--sl-color-bg));
		border-color: color-mix(in srgb, #f97316 30%, transparent);
	}

	.pcs-box-eyebrow {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3);
	}

	.pcs-box-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 14px;
		font-weight: 600;
		color: var(--sl-color-white);
	}

	.pcs-box-title :global(code) {
		font-family: inherit;
		font-size: inherit;
		background: transparent;
		padding: 0;
		color: inherit;
	}

	.pcs-box-sub {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 12px;
		line-height: 1.35;
		color: var(--sl-color-gray-2);
	}

	.pcs-box-sub em {
		font-style: italic;
		color: var(--sl-color-white);
	}

	.pcs-box-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11.5px;
		color: var(--sl-color-gray-3);
	}

	.pcs-box-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		color: var(--sl-color-white);
		background: transparent;
		padding: 0;
		white-space: normal;
		word-break: normal;
		overflow-wrap: anywhere;
		line-height: 1.4;
	}

	@media (max-width: 640px) {
		.pcs-row-consumers {
			flex-direction: column;
			align-items: center;
			gap: 12px;
		}

		.pcs-consumer {
			width: 100%;
			max-width: 320px;
		}
	}
</style>
</content>
