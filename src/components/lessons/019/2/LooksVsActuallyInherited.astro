---
// Looks-inherited vs. actually-inherited — the opacity/color distinction for
// Chapter 019 L2 ("When the page lies: inheritance look-alikes").
//
// The prose claims two things that look identical on screen but aren't:
//   - opacity only LOOKS inherited — a parent group is made translucent as a
//     whole, so children fade as a side effect. The tell: a child's own
//     `opacity: 1` does nothing; it can't escape the half-transparent group.
//   - color ACTUALLY inherits — the value flows to children, and the tell of a
//     real inherited value is that a child can freely override it.
//
// Shape: a TabbedContent (the lesson explicitly wants the two cases on tabs, and
// TabbedContent provides its own figure card — so this component does NOT wrap
// in <Figure>). Each tab body is a tiny live HTML/CSS preview: one parent box
// wrapping two child chips. Both tabs use the SAME parent+two-children skeleton
// so the ONLY thing that differs is the mechanism, and the contrast lands.
//
// In each tab, child B carries a small rule label naming the declaration it sets
// on itself (`opacity: 1` / `color: …`), so the reader sees that B *tried* to
// opt out — then reads off the result. In tab 1 B fails (stays faded); in tab 2
// B succeeds (shows its own color). The rule label is what turns "two chips"
// into "one chip tried to escape and the outcome proves the mechanism."
//
// Pure HTML + CSS, devtools-inspectable: the opacity really is set on the parent
// and on child B, and the color really inherits — so a curious student can crack
// open DevTools on this very widget and confirm every claim. `not-content` root
// + a `margin: 0` reset on inner elements defeat Starlight's prose-margin
// injection; box-sizing: border-box throughout. Signal colors reuse the lesson's
// theme-aware --mark-* palette so they read in both light and dark mode.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Fixed signal mid-tones — readable on both themes, paired with the theme-aware
// --mark-*-bg / --mark-*-brd fills. GREEN is the inheriting/text-ish signal
// reused from the drip + roster figures above; BLUE (the TS accent) marks child
// B's deliberate color override so it can't be confused with the inherited tone.
const GREEN = "#16a34a"; // the value the parent sets / the inherited color
const BLUE = "#3178c6"; // child B's own color override

// ---- shared chrome ---------------------------------------------------------

const stage = [
  reset,
  sans,
  "display: flex",
  "justify-content: center",
  "padding: 8px 4px 4px",
].join("; ");

// The parent box. Holds the declaration under test (opacity, or color) plus a
// dashed frame + corner tag so the reader can see exactly which element owns it.
const parent = (extra: string) =>
  [
    reset,
    sans,
    "position: relative",
    "display: flex",
    "flex-direction: column",
    "gap: 14px",
    "min-width: 240px",
    "max-width: 100%",
    "padding: 26px 18px 18px",
    "border-radius: 12px",
    "background: var(--sl-color-gray-7, rgba(0, 0, 0, 0.03))",
    "border: 1px dashed var(--sl-color-gray-4)",
    "box-sizing: border-box",
    extra,
  ].join("; ");

// The corner tag naming the declaration that lives on the parent.
const parentTag = [
  reset,
  mono,
  "position: absolute",
  "top: 0",
  "left: 0",
  "padding: 3px 8px",
  "border-radius: 11px 0 8px 0",
  "font-size: 10.5px",
  "font-weight: 700",
  "line-height: 1",
  "white-space: nowrap",
  "color: var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6)",
  "border-right: 1px dashed var(--sl-color-gray-4)",
  "border-bottom: 1px dashed var(--sl-color-gray-4)",
  "box-sizing: border-box",
].join("; ");

// A child cluster = the chip itself + its rule label underneath.
const childWrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: flex-start",
  "gap: 5px",
].join("; ");

// The child chip. `tint` carries the per-tab visual (faded fill, or a color).
const chip = (tint: string) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "gap: 7px",
    "padding: 6px 12px",
    "border-radius: 8px",
    "font-size: 13px",
    "font-weight: 700",
    "line-height: 1.1",
    "box-sizing: border-box",
    tint,
  ].join("; ");

// The small mono label naming what the child declares on itself. `muted` styles
// the "(inherits / nothing)" non-declaration so it reads as the absence of a rule.
const ruleLabel = (muted: boolean) =>
  [
    reset,
    mono,
    "font-size: 11px",
    "font-weight: 600",
    "line-height: 1.2",
    "padding-left: 2px",
    muted ? "color: var(--sl-color-gray-3)" : "color: var(--sl-color-gray-2)",
  ].join("; ");

// ---- tab 1 (opacity) data --------------------------------------------------
// Neutral foreground chips so opacity is the only variable — no color confound.
// Child B sets opacity: 1 on itself; the parent's 0.5 still wins the group, so B
// renders exactly as faded as A.

const opaqueChipBase = [
  "color: var(--sl-color-white)",
  "background: var(--sl-color-gray-5)",
  "border: 1px solid var(--sl-color-gray-4)",
].join("; ");

// ---- tab 2 (color) data ----------------------------------------------------
// The parent sets color: green. Child A declares nothing -> inherits green.
// Child B declares color: blue -> overrides. currentColor drives both chip text
// and a faint matching fill so the inherited vs. overridden tone is unmistakable.

const colorChip = (color: string, inherited: boolean) =>
  [
    inherited ? "" : `color: ${color}`, // A inherits from parent; B sets its own
    "background: color-mix(in srgb, currentColor 12%, transparent)",
    "border: 1px solid color-mix(in srgb, currentColor 45%, transparent)",
  ]
    .filter(Boolean)
    .join("; ");
---

<TabbedContent>
  <TabbedItem
    label="Looks inherited (opacity)"
    caption="The parent is one half-transparent group; the child's opacity: 1 does nothing — it can't escape the group, so both children stay equally faded."
  >
    <div class="not-content" style={stage}>
      <div style={parent("opacity: 0.5")}>
        <span style={parentTag}>parent · opacity: 0.5</span>
        <div style={childWrap}>
          <span style={chip(opaqueChipBase)}>child A</span>
          <span style={ruleLabel(true)}>declares nothing → faded</span>
        </div>
        <div style={childWrap}>
          <span style={chip(`${opaqueChipBase}; opacity: 1`)}>child B</span>
          <span style={ruleLabel(false)}>opacity: 1 → still faded</span>
        </div>
      </div>
    </div>
  </TabbedItem>

  <TabbedItem
    label="Actually inherited (color)"
    caption="color inherits, so child A takes the parent's color; child B overrides it with its own. A real inherited value bends to the child."
  >
    <div class="not-content" style={stage}>
      <div style={parent(`color: ${GREEN}`)}>
        <span style={parentTag}>parent · color: green</span>
        <div style={childWrap}>
          <span style={chip(colorChip(GREEN, true))}>child A</span>
          <span style={ruleLabel(true)}>declares nothing → inherits green</span>
        </div>
        <div style={childWrap}>
          <span style={chip(colorChip(BLUE, false))}>child B</span>
          <span style={ruleLabel(false)}>color: blue → overrides</span>
        </div>
      </div>
    </div>
  </TabbedItem>
</TabbedContent>
