---
// The inheritance drip — the opening glance of Chapter 019 L2.
//
// Sibling to CascadeWaterfall / LayerStack in 019/1: same pure-HTML+CSS house
// style, same Starlight-var chrome, same theme-aware mark palette. Where the
// waterfall showed the cascade picking ONE winner, this figure shows what
// happens AFTER the cascade leaves a property with no value — the per-property
// inherit/initial flag — by contrasting two values dropped on the same node.
//
// Shape: a single vertical DOM chain (html -> body -> main -> p) drawn as four
// node cards in a center column, with two rails aligned row-for-row beside it.
//   - LEFT rail (green = "flows down"): a `color`/`font` value SET on <body>
//     that drips through <main> down to <p>. A "set here" chip at <body>, then
//     an "inherits" chip at EVERY node below, with a continuous rail line, so
//     the eye sees the value keep going all the way down.
//   - RIGHT rail (orange = "stops"): a `padding`/`width` value attached ONLY to
//     <body>, with a "stops here" cap on the connector below it. No chips repeat
//     on <main> or <p> — the rail line ends at <body>.
//
// The split is planted before it is named in prose: text-ish drips, box-ish
// stays. <html> sits ABOVE where the value is set, so on the left rail its row
// is dim (the value hasn't entered the chain yet) — this keeps "set on body,
// reaches descendants of body" honest rather than implying html declared it.
//
// Pure HTML + CSS, devtools-inspectable. `not-content` root + a `margin: 0`
// reset on every inner element defeat Starlight's prose-margin injection;
// box-sizing: border-box throughout. Theme chrome from Starlight gray/hairline
// vars; the two rails use the course's theme-aware --mark-green-* (flows) and
// --mark-orange-* (stops) pairs plus a fixed mid-tone for each rail's text so
// the signal colors read in both light and dark mode.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Fixed signal mid-tones — readable on both themes, paired with the theme-aware
// --mark-*-bg / --mark-*-brd fills for the chips.
const GREEN = "#16a34a"; // "flows down" rail
const ORANGE = "#d97706"; // "stops here" rail

// The DOM chain, top (root) to bottom (leaf). `source` marks the node that
// actually declares the two values; everything above it is dim on both rails,
// everything below inherits the green value and is excluded from the orange one.
const nodes = [
  { tag: "html", source: false },
  { tag: "body", source: true },
  { tag: "main", source: false },
  { tag: "p", source: false },
];
const sourceIdx = nodes.findIndex((n) => n.source);

// ---- layout ----------------------------------------------------------------

const grid = [
  reset,
  sans,
  "display: grid",
  // left rail | chain | right rail — chain is the fixed center spine.
  "grid-template-columns: 1fr 168px 1fr",
  "align-items: stretch",
  "column-gap: 0",
  "row-gap: 0",
  "max-width: 600px",
  "margin-left: auto",
  "margin-right: auto",
  "box-sizing: border-box",
].join("; ");

// Each DOM-chain row is a fixed height so the rails can align their chips and
// rail segments to the node centers with simple flex centering.
const ROW_H = 64;

// A cell in any of the three columns for one node row.
const cell = (extra = "") =>
  [
    reset,
    "display: flex",
    "align-items: center",
    `min-height: ${ROW_H}px`,
    "box-sizing: border-box",
    extra,
  ].join("; ");

// ---- center column: the node cards + connectors ----------------------------

const chainCol = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "box-sizing: border-box",
].join("; ");

const nodeCard = [
  reset,
  mono,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "min-width: 96px",
  "padding: 7px 14px",
  "border-radius: 9px",
  "font-size: 14px",
  "font-weight: 700",
  "color: var(--sl-color-white)",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.025))",
  "border: 1px solid var(--sl-color-hairline)",
  "box-sizing: border-box",
].join("; ");

// Short vertical connector between two consecutive node cards.
const CONN_H = ROW_H - 38; // node card is ~38px tall; the rest is connector
const connector = [
  reset,
  `height: ${CONN_H}px`,
  "width: 0",
  "border-left: 2px solid var(--sl-color-gray-4)",
].join("; ");

const angle = "color: var(--sl-color-gray-3)";

// ---- chips (shared) --------------------------------------------------------

const chipBase = [
  reset,
  mono,
  "display: inline-flex",
  "align-items: center",
  "gap: 6px",
  "padding: 4px 9px",
  "border-radius: 7px",
  "font-size: 11.5px",
  "font-weight: 600",
  "line-height: 1.1",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

const greenChip = (strong: boolean) =>
  [
    chipBase,
    "background: var(--mark-green-bg)",
    `border: 1px solid var(--mark-green-brd)`,
    `color: ${GREEN}`,
    strong ? "font-weight: 700" : "",
  ].join("; ");

const orangeChip = [
  chipBase,
  "background: var(--mark-orange-bg)",
  `border: 1px solid var(--mark-orange-brd)`,
  `color: ${ORANGE}`,
].join("; ");

// A tiny color swatch inside the green chip so "color flows" reads visually.
const swatch = [
  reset,
  "width: 10px",
  "height: 10px",
  "border-radius: 3px",
  "flex: none",
  // a calm foreground-ish fill that survives both themes
  "background: var(--sl-color-text)",
  "border: 1px solid var(--sl-color-hairline)",
].join("; ");

// ---- rails -----------------------------------------------------------------

// LEFT rail: a continuous vertical line from the source node down to the leaf,
// living behind the per-row chips. RIGHT rail: a line from the source node that
// is capped (stops) right below it. Both are drawn per-row as short segments so
// they align to ROW_H without absolute positioning.

// A vertical rail segment occupying the FULL row height, centered, colored.
const railSeg = (color: string, on: boolean) =>
  [
    reset,
    `height: ${ROW_H}px`,
    "width: 0",
    on
      ? `border-left: 2px solid ${color}`
      : "border-left: 2px solid transparent",
    "box-sizing: border-box",
  ].join("; ");

// Left rail cell: the rail segment sits between the chain and the chip, hugging
// the chain side; the chip floats to the left of it.
const leftCell = (extra = "") =>
  [
    cell(extra),
    "justify-content: flex-end",
    "gap: 10px",
    "padding-right: 14px",
  ].join("; ");

const rightCell = (extra = "") =>
  [
    cell(extra),
    "justify-content: flex-start",
    "gap: 10px",
    "padding-left: 14px",
  ].join("; ");

// Rail header chips (sit in the html row, label what each rail is).
const railHead = (color: string) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "flex-direction: column",
    "gap: 1px",
    "font-size: 10.5px",
    "font-weight: 700",
    "line-height: 1.15",
    "letter-spacing: 0.02em",
    "text-transform: uppercase",
    `color: ${color}`,
  ].join("; ");

const railHeadProp = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 700",
  "text-transform: none",
  "letter-spacing: 0",
  "opacity: 0.95",
].join("; ");

// The "stops here" cap on the right rail, sitting on the connector below body.
const stopCap = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 6px",
  "font-size: 10.5px",
  "font-weight: 700",
  "white-space: nowrap",
  `color: ${ORANGE}`,
].join("; ");

// Small down-arrow glyph for the green "keeps going" cue between chips.
// (rendered as an SVG polyline so it tints with the rail color)

// Precompute, per node row, what each rail shows.
// left rail "on" from the source row downward (inclusive); chip on every such row.
// right rail "on" only on the source row; cap rendered just below it.
const rows = nodes.map((n, i) => ({
  ...n,
  leftOn: i >= sourceIdx,
  leftChip: i >= sourceIdx,
  leftStrong: i === sourceIdx,
  rightOn: i === sourceIdx,
  rightChip: i === sourceIdx,
}));
---

<Figure
  caption="Inheriting properties fall down the DOM tree to every descendant. Non-inheriting ones stay on the element that set them."
>
  <div class="not-content" style={grid}>
    {/* ============================ HEADER ROW ============================ */}
    {/* left rail header */}
    <div style={leftCell("align-items: flex-end; padding-bottom: 6px; min-height: 38px")}>
      <div style={railHead(GREEN) + "; align-items: flex-end; text-align: right;"}>
        <span>flows down</span>
        <span style={railHeadProp}>color · font</span>
      </div>
    </div>
    {/* chain header spacer (sits above the html card) */}
    <div style={cell("justify-content: center; min-height: 38px; align-items: flex-end; padding-bottom: 6px;")}>
      <span style={[reset, sans, "font-size: 10.5px", "font-weight: 600", "letter-spacing: 0.04em", "text-transform: uppercase", "color: var(--sl-color-gray-3)"].join("; ")}
      >DOM tree</span>
    </div>
    {/* right rail header */}
    <div style={rightCell("align-items: flex-end; padding-bottom: 6px; min-height: 38px")}>
      <div style={railHead(ORANGE)}>
        <span>stays put</span>
        <span style={railHeadProp}>padding · width</span>
      </div>
    </div>

    {/* ============================ NODE ROWS ============================ */}
    {
      rows.map((row, i) => (
        <>
          {/* -------- LEFT rail cell -------- */}
          <div style={leftCell()}>
            {row.leftChip && (
              <span style={greenChip(row.leftStrong)}>
                {row.leftStrong && <span style={swatch} aria-hidden="true" />}
                {row.leftStrong ? "set here" : "inherits"}
              </span>
            )}
            <span style={railSeg(GREEN, row.leftOn)} aria-hidden="true" />
          </div>

          {/* -------- CENTER chain cell -------- */}
          <div style={cell("justify-content: center; flex-direction: column; gap: 0;")}>
            <div style={nodeCard}>
              <span style={angle}>{"<"}</span>
              {row.tag}
              <span style={angle}>{">"}</span>
            </div>
          </div>

          {/* -------- RIGHT rail cell -------- */}
          <div style={rightCell()}>
            <span style={railSeg(ORANGE, row.rightOn)} aria-hidden="true" />
            {row.rightChip && <span style={orangeChip}>padding: 2rem</span>}
          </div>

          {/* -------- CONNECTOR ROW (between this node and the next) -------- */}
          {i < rows.length - 1 && (
            <>
              {/* left connector: green drip continues downward */}
              <div style={cell("justify-content: flex-end; padding-right: 14px; min-height: " + CONN_H + "px; align-items: center;")}>
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke={GREEN}
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  style="margin: 0 14px 0 0; flex: none;"
                >
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
                <span style={railSeg(GREEN, true) + "; height: " + CONN_H + "px;"} aria-hidden="true" />
              </div>

              {/* center connector line */}
              <div style={cell("justify-content: center; min-height: " + CONN_H + "px; align-items: center;")}>
                <span style={connector} aria-hidden="true" />
              </div>

              {/* right connector: the orange value is declared ON <body> and
                  never enters a connector — every right-rail connector is off.
                  The cap appears on the FIRST connector below the source node. */}
              <div style={cell("justify-content: flex-start; padding-left: 14px; min-height: " + CONN_H + "px; align-items: center; gap: 10px;")}>
                <span style={railSeg(ORANGE, false) + "; height: " + CONN_H + "px;"} aria-hidden="true" />
                {i === sourceIdx && (
                  <span style={stopCap}>
                    <svg
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke={ORANGE}
                      stroke-width="2.4"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      style="margin: 0; flex: none;"
                    >
                      <circle cx="12" cy="12" r="9"></circle>
                      <line x1="8" y1="12" x2="16" y2="12"></line>
                    </svg>
                    does not descend
                  </span>
                )}
              </div>
            </>
          )}
        </>
      ))
    }
  </div>
</Figure>
