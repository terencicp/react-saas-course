---
// The Computed panel, read for INHERITANCE — Chapter 019 L2 ("Reading
// inheritance in DevTools"). Sibling to 019/1's ComputedPanelTrace: same dark
// DevTools window chrome, same VS-Code property/value colors, same disclosure
// triangles, same numbered-callout + legend idiom. A student who met the L1
// figure recognises this as the same Computed sub-tab — only the affordance it
// points at has changed.
//
// Where L1 pointed at the cascade-LAYER pill on a winning rule, this figure
// points at the "Inherited from <ancestor>" attribution Chrome prints under an
// inherited property's trace. The scene is a selected <span> deep in the tree,
// with three properties expanded so the contrast is unmistakable:
//
//   font-family  ui-sans-serif, …   -> Inherited from  body   (the section)
//     color        oklch(…)          -> Inherited from  body
//     padding      4px 12px          -> (no attribution — resolved locally)
//
// The two inheriting properties (font-family, color) carry the green
// "Inherited from" badge that ties back to this lesson's drip / families
// figures (green = flows down). The non-inheriting padding row has NO
// attribution line and an orange "this element" tag — it resolved from the
// element's own rule, not from any ancestor. That dissociation, read straight
// off the panel, IS the takeaway: the panel names the ancestor a value fell
// from, and only for the properties that actually inherited.
//
// Fixed-color island: the panel is a dark DevTools window in both site themes
// (DevTools is dark here), so panel text uses fixed VS-Code colors, not theme
// vars — exactly as ComputedPanelTrace does. The Figure card and the legend
// below still flip with the theme. `margin: 0` on every inner element defeats
// Starlight's prose-margin injection.

import Figure from "../../../figures/Figure.astro";

// --- DevTools window palette (fixed; the panel is dark in both site themes) ---
const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BORDER = "#3a3a3a";
const ROW_HOVER = "#262626";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const ACCENT = "#60a5fa"; // selected tab
const PROP = "#9cdcfe"; // CSS property name
const VAL = "#ce9178"; // CSS value
const LINK = "#6cb6ff"; // stylesheet source link
const CALLOUT_BG = "#f59e0b";
const CALLOUT_TEXT = "#0b0b0b";

// Signal pair — the same two the lesson's drip / families figures bound:
// GREEN = "flows down" (inherited), ORANGE = "stays put" (resolved locally).
const GREEN = "#34d399"; // inherited-from badge (reads on the dark panel)
const ORANGE = "#fbbf24"; // "this element" — resolved locally, no inheritance

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 11.5px; line-height: 1.5;";

// --- tab strip --------------------------------------------------------------
const tabBase = [
  reset,
  sans,
  "padding: 6px 12px",
  "font-size: 11px",
  `border-right: 1px solid ${PANEL_BORDER}`,
  "white-space: nowrap",
].join("; ");
const tabSelected = `${tabBase}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 4px;`;
const tabDim = `${tabBase}; color: ${TEXT_DIM}; background: ${PANEL_BG_ALT};`;

// --- selected-element breadcrumb (names the node the panel is reading) -------
const crumb = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "padding: 5px 10px",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
  "white-space: nowrap",
].join("; ");
const crumbDim = `${reset}; color: ${TEXT_DIM};`;
const crumbSel = `${reset}; color: ${PROP};`;
const crumbAngle = `${reset}; color: ${TEXT_DIM};`;

// --- toolbar (filter + "Show all" — real Computed-panel chrome) -------------
const toolbar = [
  reset,
  "padding: 6px 10px",
  "display: flex",
  "align-items: center",
  "gap: 10px",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
].join("; ");

const filterPill = [
  reset,
  codeFont,
  `color: ${TEXT_MUTED}`,
  "padding: 2px 8px",
  `border: 1px solid ${PANEL_BORDER}`,
  "border-radius: 3px",
].join("; ");

const checkboxRow = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "gap: 5px",
  "font-size: 11px",
  `color: ${TEXT_MUTED}`,
].join("; ");

// --- property rows ----------------------------------------------------------
const rowBase = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "padding: 2px 10px",
  "white-space: nowrap",
].join("; ");

const propName = `${reset}; color: ${PROP};`;
const propVal = `${reset}; color: ${VAL};`;
const colon = `${reset}; color: ${TEXT_BRIGHT};`;

// Disclosure triangle (CSS-only, rotates for expanded).
const triangle = (open: boolean) =>
  [
    reset,
    "display: inline-block",
    "width: 0",
    "height: 0",
    "border-top: 4px solid transparent",
    "border-bottom: 4px solid transparent",
    `border-left: 5px solid ${TEXT_MUTED}`,
    "flex: 0 0 auto",
    open ? "transform: rotate(90deg)" : "transform: none",
  ].join("; ");

// An expanded property's header row (the resolved final value, bold).
const expandedHead = `${rowBase}; background: ${ROW_HOVER}; padding-top: 3px; padding-bottom: 3px;`;

// The trace row under an expanded property: the value, then the rule that
// supplied it, then the stylesheet link. Indented to read as a child of the
// property above it.
const traceRow = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 10px",
  "padding: 3px 10px 3px 30px",
  "white-space: nowrap",
].join("; ");
const traceVal = `${reset}; color: ${VAL}; min-width: 110px;`;
const traceSel = `${reset}; color: ${TEXT_BRIGHT};`;
const traceLink = `${reset}; color: ${LINK}; opacity: 0.85; margin-left: auto;`;

// The "Inherited from <selector>" attribution line Chrome prints above an
// inherited declaration's source — dimmed, italic, the signature affordance.
const attribRow = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 7px",
  "padding: 2px 10px 2px 30px",
  "white-space: nowrap",
].join("; ");
const attribLabel = `${reset}; color: ${TEXT_MUTED}; font-style: italic;`;

// The ancestor pill inside the attribution line — a cool "in the tree" chip
// styled like a selector, tinted green to read as the inheritance signal.
const ancestorPill = [
  reset,
  codeFont,
  "font-style: normal",
  "padding: 0px 7px",
  "border-radius: 4px",
  `color: ${GREEN}`,
  `background: ${GREEN}1f`,
  `border: 1px solid ${GREEN}66`,
].join("; ");

// The "this element" tag on the non-inheriting row — orange, names that the
// value came from the element itself, NOT an ancestor.
const localTag = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "padding: 1px 7px",
  "border-radius: 999px",
  "white-space: nowrap",
  "flex: 0 0 auto",
  `color: ${ORANGE}`,
  `background: ${ORANGE}22`,
  `border: 1px solid ${ORANGE}88`,
].join("; ");

// --- numbered callouts + legend ---------------------------------------------
const calloutDot = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 20px",
  "height: 20px",
  "border-radius: 50%",
  `background: ${CALLOUT_BG}`,
  `color: ${CALLOUT_TEXT}`,
  "font-weight: 700",
  "font-size: 11px",
  "box-shadow: 0 0 0 2px rgba(0,0,0,0.5)",
  "flex: 0 0 auto",
].join("; ");

const legendGrid = [
  reset,
  sans,
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  "column-gap: 18px",
  "row-gap: 8px",
  "font-size: 12px",
].join("; ");
const legendRow = [
  reset,
  "display: flex",
  "align-items: flex-start",
  "gap: 7px",
].join("; ");
const legendLabel = [
  reset,
  "color: var(--sl-color-text)",
  "line-height: 1.35",
].join("; ");
const legendCode = `background: transparent; padding: 0; color: inherit; ${codeFont}`;

// A collapsed sibling property, for realism around the expanded ones.
const collapsed = { name: "line-height", val: "24px" };
---

<Figure
  caption="The Computed panel flags each inherited property with the ancestor it resolved from — here, font-family and color fell from body, while padding shows no attribution because it resolved on the element itself."
>
  <div
    class="not-content"
    style={`${reset}; ${sans}; display: flex; flex-direction: column; gap: 14px;`}
  >
    {/* DevTools window mock */}
    <div
      style={`${reset}; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2); max-width: 640px; margin-left: auto; margin-right: auto; width: 100%;`}
    >
      {/* Tab strip — Computed selected */}
      <div
        style={`${reset}; display: flex; flex-direction: row; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER};`}
      >
        <div style={tabDim}>Styles</div>
        <div style={tabSelected}>Computed</div>
        <div style={tabDim}>Layout</div>
        <div style={tabDim}>Event Listeners</div>
      </div>

      {/* Selected-element breadcrumb — names the node the panel is reading */}
      <div style={crumb}>
        <span style={crumbDim}>body</span>
        <span style={crumbAngle}>{"›"}</span>
        <span style={crumbDim}>main</span>
        <span style={crumbAngle}>{"›"}</span>
        <span style={crumbDim}>div.card</span>
        <span style={crumbAngle}>{"›"}</span>
        <span style={crumbSel}>span.badge</span>
      </div>

      {/* Toolbar: filter + Show all */}
      <div style={toolbar}>
        <span style={filterPill}>Filter</span>
        <span style={checkboxRow}>
          <span
            style={`${reset}; display: inline-flex; align-items: center; justify-content: center; width: 12px; height: 12px; border: 1px solid ${ACCENT}; border-radius: 2px; background: ${ACCENT}; color: ${PANEL_BG}; font-size: 9px; font-weight: 800; line-height: 1;`}
            aria-hidden="true">{"✓"}</span>
          Show all
        </span>
      </div>

      {/* Computed property list (position: relative anchors the callout overlay) */}
      <div style={`${reset}; padding: 8px 0; position: relative;`}>
        {/* ---- font-family: expanded, inherited from body ---- */}
        <div style={expandedHead}>
          <span style={triangle(true)} aria-hidden="true"></span>
          <span style={propName}>font-family</span>
          <span style={colon}>:</span>
          <span style={`${propVal}; font-weight: 700;`}
            >ui-sans-serif, system-ui, …</span
          >
        </div>
        <div style={attribRow}>
          <span style={attribLabel}>Inherited from</span>
          <span style={ancestorPill}>body</span>
        </div>
        <div style={traceRow}>
          <span style={traceVal}>var(--font-sans)</span>
          <span style={traceSel}>body</span>
          <span style={traceLink}>globals.css:5</span>
        </div>

        {/* ---- color: expanded, inherited from body ---- */}
        <div style={`${expandedHead}; margin-top: 4px;`}>
          <span style={triangle(true)} aria-hidden="true"></span>
          <span style={propName}>color</span>
          <span style={colon}>:</span>
          <span style={`${propVal}; font-weight: 700;`}
            >oklch(0.21 0.03 264)</span
          >
        </div>
        <div style={attribRow}>
          <span style={attribLabel}>Inherited from</span>
          <span style={ancestorPill}>body</span>
        </div>
        <div style={traceRow}>
          <span style={traceVal}>var(--color-foreground)</span>
          <span style={traceSel}>body</span>
          <span style={traceLink}>globals.css:6</span>
        </div>

        {/* ---- padding: expanded, NO attribution — resolved locally ---- */}
        <div style={`${expandedHead}; margin-top: 4px;`}>
          <span style={triangle(true)} aria-hidden="true"></span>
          <span style={propName}>padding</span>
          <span style={colon}>:</span>
          <span style={`${propVal}; font-weight: 700;`}>4px 12px</span>
          <span style={localTag}>this element</span>
        </div>
        <div style={traceRow}>
          <span style={traceVal}>4px 12px</span>
          <span style={traceSel}>.badge</span>
          <span style={traceLink}>globals.css:41</span>
        </div>

        {/* one collapsed sibling below, for realism */}
        <div style={`${rowBase}; margin-top: 4px;`}>
          <span style={triangle(false)} aria-hidden="true"></span>
          <span style={propName}>{collapsed.name}</span>
          <span style={colon}>:</span>
          <span style={propVal}>{collapsed.val}</span>
        </div>

        {/* Numbered callouts — one absolute overlay over the list, each dot in
            the right gutter of its target row (empty space, so the offsets stay
            valid whatever the panel width). Row tops measured against the list
            container's content box. */}
        <div
          style={`${reset}; position: absolute; inset: 0; pointer-events: none;`}
          aria-hidden="true"
        >
          {/* 1 — the font-family "Inherited from" attribution row */}
          <span style={`${calloutDot}; position: absolute; top: 32px; right: 10px;`}>1</span>
          {/* 2 — the color "Inherited from" attribution row */}
          <span style={`${calloutDot}; position: absolute; top: 104px; right: 10px;`}>2</span>
          {/* 3 — the padding row, where no attribution line appears */}
          <span style={`${calloutDot}; position: absolute; top: 157px; right: 10px;`}>3</span>
        </div>
      </div>
    </div>

    {/* Legend — what each numbered region tells you */}
    <div style={legendGrid}>
      <div style={legendRow}>
        <span style={calloutDot}>1</span>
        <span style={legendLabel}>
          <strong>Inherited from</strong> — the section that appears under a
          value the element <em>didn't</em> declare itself.
        </span>
      </div>
      <div style={legendRow}>
        <span style={calloutDot}>2</span>
        <span style={legendLabel}>
          <strong>The ancestor</strong> — names exactly which element the value
          fell from. Here <code style={legendCode}>color</code> came from{" "}
          <code style={legendCode}>body</code>.
        </span>
      </div>
      <div style={legendRow}>
        <span style={calloutDot}>3</span>
        <span style={legendLabel}>
          <strong>No attribution</strong> — <code style={legendCode}>padding</code>{" "}
          doesn't inherit, so it resolved on the element, with no ancestor line.
        </span>
      </div>
    </div>
  </div>
</Figure>
