---
// Inherits vs. doesn't — the classification figure for Chapter 019 L2.
//
// Sibling to InheritanceDrip (same lesson) and the 019/1 cascade figures: same
// pure-HTML+CSS house style, same Starlight-var chrome, same theme-aware mark
// palette. The drip just above taught the *behavior* (text-ish flows down,
// box-ish stays put) on a single DOM chain; this figure is the *full roster* —
// the two families filled in, so the student has one image to photograph.
//
// Continuity of color is deliberate: the LEFT (inherits / text-ish) column
// reuses the drip's GREEN "flows down" signal, and the RIGHT (doesn't inherit /
// box-ish) column reuses the drip's ORANGE "stays put" signal. The student
// already bound those two colors to the two behaviors one figure ago.
//
// Shape: two tinted column panels side by side. Each panel = a heuristic header
// (the column caption that makes the rule visible) + a stack of small labeled
// sub-clusters, each a row of <code>-styled chips. Chips are styled <span>s
// (not raw Starlight <code>, which adds an opaque pill + wraps awkwardly) tinted
// to the column color, so the color-coding carries down to every property name.
// On narrow figure cards the two panels wrap to a single stacked column.
//
// Pure HTML + CSS, devtools-inspectable. `not-content` root + a `margin: 0`
// reset on every inner element defeat Starlight's prose-margin injection;
// box-sizing: border-box throughout.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Fixed signal mid-tones — same pair the drip uses, readable on both themes and
// paired with the theme-aware --mark-*-bg / --mark-*-brd fills for the chips.
const GREEN = "#16a34a"; // inherits — text-ish
const ORANGE = "#d97706"; // doesn't inherit — box-ish

// ---- data ------------------------------------------------------------------
// `solo` chips are the two heuristic-breaking edge cases worth a second glance
// (cursor / visibility inherit despite feeling box-ish). They get a faint dot so
// the eye lands on them without a second color competing with the column tint.

type Cluster = { label: string; items: { text: string; flag?: boolean }[] };

const inheritsClusters: Cluster[] = [
  {
    label: "Typography",
    items: [
      "color",
      "font-family",
      "font-size",
      "font-weight",
      "font-style",
      "line-height",
      "letter-spacing",
      "text-align",
      "text-transform",
      "white-space",
      "direction",
    ].map((text) => ({ text })),
  },
  { label: "Lists", items: [{ text: "list-style" }] },
  {
    label: "Edge cases",
    items: [
      { text: "cursor", flag: true },
      { text: "visibility", flag: true },
    ],
  },
  { label: "Design tokens", items: [{ text: "--*" }] },
];

const notClusters: Cluster[] = [
  {
    label: "Box model",
    items: ["padding", "margin", "border", "width", "height", "min/max-*"].map(
      (text) => ({ text }),
    ),
  },
  {
    label: "Layout",
    items: [
      "display",
      "position",
      "top/right/bottom/left",
      "z-index",
      "flex",
      "grid",
      "gap",
    ].map((text) => ({ text })),
  },
  {
    label: "Background",
    items: ["background-color", "background-image"].map((text) => ({ text })),
  },
  {
    label: "Effects",
    items: ["box-shadow", "opacity", "transform", "filter"].map((text) => ({
      text,
    })),
  },
];

// ---- layout ----------------------------------------------------------------

const wrap = [
  reset,
  sans,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "column-gap: 16px",
  "row-gap: 16px",
  "max-width: 760px",
  "margin-left: auto",
  "margin-right: auto",
  "box-sizing: border-box",
].join("; ");

// One column panel: tinted fill + matching hairline, fills its half of the row
// and grows to the taller of the two so both panels read as equal blocks.
const panel = (bg: string, brd: string) =>
  [
    reset,
    "flex: 1 1 320px",
    "min-width: 280px",
    "display: flex",
    "flex-direction: column",
    "gap: 14px",
    "padding: 16px 16px 18px",
    "border-radius: 12px",
    `background: ${bg}`,
    `border: 1px solid ${brd}`,
    "box-sizing: border-box",
  ].join("; ");

// Panel header: the heuristic, made the loud thing in the figure.
const head = (color: string) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "gap: 3px",
    "padding-bottom: 10px",
    `border-bottom: 1px solid ${color}`,
    "box-sizing: border-box",
  ].join("; ");

const headTitle = (color: string) =>
  [
    reset,
    sans,
    "font-size: 15px",
    "font-weight: 800",
    "line-height: 1.15",
    "letter-spacing: 0.01em",
    `color: ${color}`,
  ].join("; ");

const headRule = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");

// A sub-cluster: small uppercase label above a wrapping row of chips.
const cluster = [reset, "display: flex", "flex-direction: column", "gap: 7px"].join(
  "; ",
);

const clusterLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
].join("; ");

const chipRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "column-gap: 6px",
  "row-gap: 6px",
].join("; ");

// A property chip — styled <span>, not Starlight <code>, so the column tint
// carries to every name and the pill width/wrap is under our control.
const chip = (bg: string, brd: string, color: string) =>
  [
    reset,
    mono,
    "display: inline-flex",
    "align-items: center",
    "gap: 5px",
    "padding: 3px 8px",
    "border-radius: 6px",
    "font-size: 12px",
    "font-weight: 600",
    "line-height: 1.1",
    "white-space: nowrap",
    `background: ${bg}`,
    `border: 1px solid ${brd}`,
    `color: ${color}`,
    "box-sizing: border-box",
  ].join("; ");

// The faint dot marking the two heuristic edge cases on the inherits side.
const flagDot = (color: string) =>
  [
    reset,
    "width: 5px",
    "height: 5px",
    "border-radius: 50%",
    "flex: none",
    `background: ${color}`,
    "opacity: 0.7",
  ].join("; ");

const columns = [
  {
    title: "Inherits — text-ish",
    rule: "Describes the text, so it flows to every descendant.",
    color: GREEN,
    bg: "var(--mark-green-bg)",
    brd: "var(--mark-green-brd)",
    clusters: inheritsClusters,
    flagged: true,
  },
  {
    title: "Doesn't inherit — box-ish",
    rule: "Describes the box — size, position, background, effects — so it stays local.",
    color: ORANGE,
    bg: "var(--mark-orange-bg)",
    brd: "var(--mark-orange-brd)",
    clusters: notClusters,
    flagged: false,
  },
];
---

<Figure
  caption="Text-ish properties flow to descendants; box-ish properties stay local. The heuristic — does this describe the text, or the box? — predicts almost every property's family. (cursor and visibility, dotted, are the two that inherit despite feeling box-ish.)"
>
  <div class="not-content" style={wrap}>
    {
      columns.map((col) => (
        <div style={panel(col.bg, col.brd)}>
          <div style={head(col.brd)}>
            <span style={headTitle(col.color)}>{col.title}</span>
            <span style={headRule}>{col.rule}</span>
          </div>
          {col.clusters.map((c) => (
            <div style={cluster}>
              <span style={clusterLabel}>{c.label}</span>
              <div style={chipRow}>
                {c.items.map((item) => (
                  <span style={chip(col.bg, col.brd, col.color)}>
                    {item.flag && col.flagged && (
                      <span style={flagDot(col.color)} aria-hidden="true" />
                    )}
                    {item.text}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      ))
    }
  </div>
</Figure>
