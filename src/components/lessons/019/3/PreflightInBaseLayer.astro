---
// The STYLES panel, read for PREFLIGHT — Chapter 019 L3 ("Reading Preflight in
// DevTools"). Third sibling in this chapter's DevTools-mock family, after L1's
// ComputedPanelTrace and L2's InheritedFromPanel: same dark DevTools window
// chrome, same fixed VS-Code property/value colors (the panel stays dark in both
// site themes), same selected-element breadcrumb, same numbered-amber-callout +
// 3-column legend idiom. A student who met those two figures recognises this as
// the SAME panel — only the sub-tab (Styles, not Computed) and the affordance it
// points at have changed.
//
// Where L1 pointed at a cascade-LAYER pill on a winning trace row and L2 at the
// "Inherited from" attribution, this figure points at the dimmed `@layer base`
// BAND at the bottom of the Styles panel. The Styles panel lists whole RULE
// BLOCKS (selector { decls }) top-to-bottom, winners first, grouped under their
// cascade-layer headers — so the scene reads exactly like Chrome:
//
//   element.style { }                                   (empty inline block)
//
//   @layer utilities                                    <- pill, the later layer
//     .text-2xl  { font-size: 1.5rem }                  globals.css  (WINS, not struck)
//     .font-bold { font-weight: 700 }                   globals.css
//
//   @layer base                                         <- dimmed band, emphasized
//     h1, h2, h3, h4, h5, h6 {                          preflight.css
//       font-size:   inherit;   <- STRUCK (the utility above beat it)
//       font-weight: inherit;   <- STRUCK
//     }
//
// Reading the dimmed `@layer base` band as "Preflight, beneath everything, doing
// its job" — and seeing `font-size: inherit` struck through by the utility above
// it, exactly as the layer gate predicts — IS the takeaway. The student is being
// trained to see the band at the bottom as confirmation, not a culprit.
//
// Layer pills reuse L1's family: cool LAYER_OK for a real @layer; here BOTH
// layers are real (no unlayered trap), so both pills are cool — the contrast the
// figure teaches is winner-vs-reset (struck-through), not layered-vs-unlayered.
//
// Fixed-color island: the panel is a dark DevTools window in both site themes, so
// panel text uses fixed VS-Code colors, not theme vars — exactly as the two
// sibling figures do. The Figure card and the legend below still flip with the
// theme. `margin: 0` on every inner element defeats Starlight's prose-margin
// injection.

import Figure from "../../../figures/Figure.astro";

// --- DevTools window palette (fixed; the panel is dark in both site themes) ---
const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BORDER = "#3a3a3a";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const ACCENT = "#60a5fa"; // selected tab
const PROP = "#9cdcfe"; // CSS property name
const VAL = "#ce9178"; // CSS value
const SEL = "#d7ba7d"; // CSS selector (Chrome tints selectors gold)
const LINK = "#6cb6ff"; // stylesheet source link
const CALLOUT_BG = "#f59e0b";
const CALLOUT_TEXT = "#0b0b0b";

// Cascade-layer pill — the family from L1's LayerStack / ComputedPanelTrace.
// Both layers here are REAL (cool), so the pill is one colour.
const LAYER_OK = "#3b82f6"; // a real @layer (cool / "in the system")

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 11.5px; line-height: 1.5;";

// --- tab strip — STYLES selected this time ----------------------------------
const tabBase = [
  reset,
  sans,
  "padding: 6px 12px",
  "font-size: 11px",
  `border-right: 1px solid ${PANEL_BORDER}`,
  "white-space: nowrap",
].join("; ");
const tabSelected = `${tabBase}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 4px;`;
const tabDim = `${tabBase}; color: ${TEXT_DIM}; background: ${PANEL_BG_ALT};`;

// --- selected-element breadcrumb (names the node the panel is reading) -------
const crumb = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "padding: 5px 10px",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
  "white-space: nowrap",
].join("; ");
const crumbDim = `${reset}; color: ${TEXT_DIM};`;
const crumbSel = `${reset}; color: ${PROP};`;
const crumbAngle = `${reset}; color: ${TEXT_DIM};`;

// --- toolbar (filter + :hov / .cls — real Styles-panel chrome) --------------
const toolbar = [
  reset,
  "padding: 6px 10px",
  "display: flex",
  "align-items: center",
  "gap: 10px",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
].join("; ");
const filterPill = [
  reset,
  codeFont,
  `color: ${TEXT_MUTED}`,
  "padding: 2px 8px",
  `border: 1px solid ${PANEL_BORDER}`,
  "border-radius: 3px",
].join("; ");
const toolTag = [
  reset,
  sans,
  "font-size: 10px",
  "letter-spacing: 0.02em",
  `color: ${TEXT_MUTED}`,
  "padding: 1px 6px",
  `border: 1px solid ${PANEL_BORDER}`,
  "border-radius: 3px",
].join("; ");

// --- cascade-layer section header ("@layer <name>" divider band) ------------
// Chrome prints a thin band above each layer's rules. The base band is the one
// this figure exists to point at, so it gets a touch more emphasis (a left
// accent + slightly brighter fill) without leaving the dark-panel register.
const layerHeader = (dim: boolean) =>
  [
    reset,
    codeFont,
    "display: flex",
    "align-items: center",
    "gap: 8px",
    "padding: 4px 10px",
    `background: ${dim ? "#242424" : PANEL_BG_ALT}`,
    `border-top: 1px solid ${PANEL_BORDER}`,
    `border-bottom: 1px solid ${PANEL_BORDER}`,
    dim ? "border-left: 3px solid " + LAYER_OK + "; padding-left: 7px;" : "",
  ].join("; ");
const layerHeaderText = (dim: boolean) =>
  `${reset}; color: ${dim ? TEXT_MUTED : TEXT_DIM}; font-style: italic;`;

// The "@layer <name>" pill that names which layer a rule block sits in.
const layerPill = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "padding: 1px 7px",
  "border-radius: 999px",
  "white-space: nowrap",
  "flex: 0 0 auto",
  `color: #cfe2ff`,
  `background: ${LAYER_OK}33`,
  `border: 1px solid ${LAYER_OK}99`,
].join("; ");

// --- CSS rule block ---------------------------------------------------------
// A whole rule as the Styles panel draws it: selector line (with the source link
// pushed right), indented declaration lines, closing brace. `dim` fades the
// whole base block so it visibly recedes beneath the utilities above it.
const ruleBlock = (dim: boolean) =>
  [
    reset,
    codeFont,
    "padding: 5px 10px 6px",
    dim ? "opacity: 0.92" : "",
  ].join("; ");

const selLine = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "white-space: nowrap",
].join("; ");
const selText = `${reset}; color: ${SEL};`;
const brace = `${reset}; color: ${TEXT_BRIGHT};`;
const srcLink = `${reset}; color: ${LINK}; opacity: 0.85; margin-left: auto; font-size: 11px;`;

// A declaration line inside a rule block, indented under the selector.
const declLine = [
  reset,
  codeFont,
  "display: flex",
  "align-items: baseline",
  "gap: 5px",
  "padding-left: 16px",
  "white-space: nowrap",
].join("; ");
const propName = `${reset}; color: ${PROP};`;
const colon = `${reset}; color: ${TEXT_BRIGHT};`;
const valText = `${reset}; color: ${VAL};`;
// A struck declaration — the reset that the utility above it beat. Same
// line-through + dim convention the two sibling figures use for "this lost".
const propStruck = `${propName}; text-decoration: line-through; opacity: 0.55;`;
const valStruck = `${valText}; text-decoration: line-through; opacity: 0.55;`;
const colonStruck = `${colon}; text-decoration: line-through; opacity: 0.55;`;

// --- numbered callouts + legend ---------------------------------------------
const calloutDot = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 20px",
  "height: 20px",
  "border-radius: 50%",
  `background: ${CALLOUT_BG}`,
  `color: ${CALLOUT_TEXT}`,
  "font-weight: 700",
  "font-size: 11px",
  "box-shadow: 0 0 0 2px rgba(0,0,0,0.5)",
  "flex: 0 0 auto",
].join("; ");

const legendGrid = [
  reset,
  sans,
  "display: grid",
  "grid-template-columns: repeat(2, minmax(0, 1fr))",
  "column-gap: 18px",
  "row-gap: 8px",
  "font-size: 12px",
].join("; ");
const legendRow = [
  reset,
  "display: flex",
  "align-items: flex-start",
  "gap: 7px",
].join("; ");
const legendLabel = [
  reset,
  "color: var(--sl-color-text)",
  "line-height: 1.35",
].join("; ");
const legendCode = `background: transparent; padding: 0; color: inherit; ${codeFont}`;
---

<Figure
  caption="The Styles panel, read for a selected <h1>: your text-2xl wins in @layer utilities up top, while Preflight's heading rule sits in the dimmed @layer base band below with its font-size: inherit struck through. The reset is doing its job; the utility is your job."
>
  <div
    class="not-content"
    style={`${reset}; ${sans}; display: flex; flex-direction: column; gap: 14px;`}
  >
    {/* DevTools window mock */}
    <div
      style={`${reset}; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2); max-width: 640px; margin-left: auto; margin-right: auto; width: 100%;`}
    >
      {/* Tab strip — Styles selected */}
      <div
        style={`${reset}; display: flex; flex-direction: row; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER};`}
      >
        <div style={tabSelected}>Styles</div>
        <div style={tabDim}>Computed</div>
        <div style={tabDim}>Layout</div>
        <div style={tabDim}>Event Listeners</div>
      </div>

      {/* Selected-element breadcrumb — names the node the panel is reading */}
      <div style={crumb}>
        <span style={crumbDim}>body</span>
        <span style={crumbAngle}>{"›"}</span>
        <span style={crumbDim}>main</span>
        <span style={crumbAngle}>{"›"}</span>
        <span style={crumbSel}>h1.title</span>
      </div>

      {/* Toolbar: filter + :hov / .cls (Styles-panel chrome) */}
      <div style={toolbar}>
        <span style={filterPill}>Filter</span>
        <span style={toolTag}>:hov</span>
        <span style={toolTag}>.cls</span>
      </div>

      {/* The rule list (position: relative anchors the callout overlay) */}
      <div style={`${reset}; padding: 4px 0 8px; position: relative;`}>
        {/* element.style {} — the empty inline block Chrome always shows first */}
        <div style={`${ruleBlock(false)}; padding-bottom: 4px;`}>
          <div style={selLine}>
            <span style={`${reset}; color: ${TEXT_MUTED};`}>element.style</span>
            <span style={brace}>{"{"}</span>
            <span style={brace}>{"}"}</span>
          </div>
        </div>

        {/* ---- @layer utilities — your winning rules, on top ---- */}
        <div style={layerHeader(false)}>
          <span style={layerHeaderText(false)}>@layer</span>
          <span style={layerPill}>utilities</span>
        </div>

        <div style={ruleBlock(false)}>
          <div style={selLine}>
            <span style={selText}>.text-2xl</span>
            <span style={brace}>{"{"}</span>
            <span style={srcLink}>globals.css:1</span>
          </div>
          <div style={declLine}>
            <span style={propName}>font-size</span>
            <span style={colon}>:</span>
            <span style={valText}>1.5rem;</span>
          </div>
          <div style={selLine}>
            <span style={brace}>{"}"}</span>
          </div>
        </div>

        <div style={`${ruleBlock(false)}; padding-top: 0;`}>
          <div style={selLine}>
            <span style={selText}>.font-bold</span>
            <span style={brace}>{"{"}</span>
            <span style={srcLink}>globals.css:1</span>
          </div>
          <div style={declLine}>
            <span style={propName}>font-weight</span>
            <span style={colon}>:</span>
            <span style={valText}>700;</span>
          </div>
          <div style={selLine}>
            <span style={brace}>{"}"}</span>
          </div>
        </div>

        {/* ---- @layer base — Preflight, beneath everything, dimmed ---- */}
        <div style={`${layerHeader(true)}; margin-top: 4px;`}>
          <span style={layerHeaderText(true)}>@layer</span>
          <span style={layerPill}>base</span>
        </div>

        <div style={ruleBlock(true)}>
          <div style={selLine}>
            <span style={selText}>h1, h2, h3, h4, h5, h6</span>
            <span style={brace}>{"{"}</span>
            <span style={srcLink}>preflight.css</span>
          </div>
          {/* font-size: inherit — STRUCK: the .text-2xl above it won */}
          <div style={declLine}>
            <span style={propStruck}>font-size</span>
            <span style={colonStruck}>:</span>
            <span style={valStruck}>inherit;</span>
          </div>
          {/* font-weight: inherit — STRUCK: .font-bold above it won */}
          <div style={declLine}>
            <span style={propStruck}>font-weight</span>
            <span style={colonStruck}>:</span>
            <span style={valStruck}>inherit;</span>
          </div>
          <div style={selLine}>
            <span style={brace}>{"}"}</span>
          </div>
        </div>

        {/* Numbered callouts — one absolute overlay over the list, each dot in
            the right gutter of its target band. Row tops measured against the
            list container's content box. */}
        <div
          style={`${reset}; position: absolute; inset: 0; pointer-events: none;`}
          aria-hidden="true"
        >
          {/* 1 — the @layer utilities header band (the winner's layer) */}
          <span style={`${calloutDot}; position: absolute; top: 32px; right: 10px;`}>1</span>
          {/* 2 — the @layer base header band (the reset, beneath everything) */}
          <span style={`${calloutDot}; position: absolute; top: 187px; right: 10px;`}>2</span>
        </div>
      </div>
    </div>

    {/* Legend — what each numbered region tells you */}
    <div style={legendGrid}>
      <div style={legendRow}>
        <span style={calloutDot}>1</span>
        <span style={legendLabel}>
          <strong>@layer utilities</strong> — your{" "}
          <code style={legendCode}>text-2xl</code> sits in the later layer, so it
          wins. Its declarations aren't struck.
        </span>
      </div>
      <div style={legendRow}>
        <span style={calloutDot}>2</span>
        <span style={legendLabel}>
          <strong>@layer base</strong> — Preflight, beneath everything. Its{" "}
          <code style={legendCode}>font-size: inherit</code> is struck through:
          the reset did its job, your utility took over.
        </span>
      </div>
    </div>
  </div>
</Figure>
