---
// One frame of the "broke my HTML -> blank canvas" sequence. Each
// <PreflightStrip step={n} /> is the body of one DiagramStep in the lesson's
// DiagramSequence. The figure renders the SAME small card of real, semantic
// markup -- an <h1>, a two-item <ul>, a <p>, and a <button> -- and walks it from
// the browser's raw user-agent defaults (step 1) to the flat Preflight surface
// (step 6), one reset at a time, then repaints it with utilities (step 7).
//
// The card is built from real elements styled with REAL inline CSS, so it is
// honest and DevTools-inspectable -- not a screenshot, not a mock. Crucially the
// UA defaults are set explicitly (h1 = 2em/bold/0.67em margin, ul = disc +
// 40px indent, p = 1em margin, a beveled native-looking button) rather than
// leaned on, because the surrounding DiagramSequence root carries `not-content`
// (which strips Starlight's prose styling) and the page itself runs a reset --
// so "what the browser ships" has to be painted on deliberately to be shown at
// all. Each later step then OVERRIDES exactly the property the named reset would
// change, cumulatively: step N keeps every subtraction from the steps before it.
//
// Frames (cumulative):
//   1  raw UA defaults                       -- big bold heading, bulleted indented list, native button
//   2  margin: 0; padding: 0  everywhere     -- gaps collapse, list loses its indent (padding)
//   3  h1..h6 { font-size/​weight: inherit }   -- heading drops to body size + weight
//   4  ol, ul, menu { list-style: none }      -- bullets vanish
//   5  button { font: inherit; color: inherit }-- button sheds native chrome, becomes inline text
//   6  the blank canvas                       -- flat surface, faint dashed outline cue
//   7  utilities painted back                 -- text-2xl/font-bold, spaced list, a real <Button>
//
// Conventions match the sibling figures in this chapter family (018's
// DesugarPanel): a `not-content` wrapper, an explicit reset on inner nodes,
// Starlight gray/white/hairline variables so the card chrome flips with the
// site theme, and inline `style` strings assembled from arrays.

interface Props {
  /** Which frame of the sequence to draw, 1-7. */
  step: 1 | 2 | 3 | 4 | 5 | 6 | 7;
}

const { step } = Astro.props;

// Cumulative reset flags. A reset that fires at step k stays on for every k+.
const marginsZeroed = step >= 2; // margin: 0; padding: 0
const headingFlat = step >= 3; // h1 { font-size: inherit; font-weight: inherit }
const listUnstyled = step >= 4; // ul { list-style: none }
const buttonInherits = step >= 5; // button { font: inherit; color: inherit }
const painted = step === 7; // utilities layered back on

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// The body font the card "inherits". A real serif/sans UA default would be the
// document font; here we pin the site's sans so inheritance is visible and the
// flattened heading/button clearly take the body face.
const bodyFont =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const bodySize = "0.9375rem"; // the "body" size everything flattens toward
const bodyColor = "color: var(--sl-color-white)";

// --- The card shell --------------------------------------------------------
// A neutral surface that is NOT one of the browser defaults under test, so the
// resets read against a stable frame. On the final blank-canvas step it gains a
// faint dashed outline to read as a deliberate surface, not a failure.
const card = [
  "margin: 0",
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 340px",
  bodyFont,
  `font-size: ${bodySize}`,
  bodyColor,
  "padding: 18px 20px",
  "border-radius: 12px",
  "background: var(--sl-color-gray-7, rgba(0,0,0,0.03))",
  step === 6
    ? "border: 1px dashed var(--sl-color-gray-4)"
    : "border: 1px solid var(--sl-color-hairline)",
  // Painted step gets a touch more vertical rhythm so the utilities read.
  painted ? "padding: 20px 20px 22px" : "",
].join("; ");

// --- <h1> ------------------------------------------------------------------
const h1Style = (() => {
  const s = ["box-sizing: border-box"];
  // size + weight
  if (painted) {
    s.push("font-size: 1.5rem"); // text-2xl
    s.push("font-weight: 700"); // font-bold
    s.push("line-height: 1.2");
  } else if (headingFlat) {
    s.push("font-size: inherit"); // -> body size
    s.push("font-weight: inherit"); // -> body weight (400)
    s.push("line-height: 1.5");
  } else {
    s.push("font-size: 2em"); // UA <h1>
    s.push("font-weight: bold"); // UA <h1>
    s.push("line-height: 1.2");
  }
  // margin
  if (marginsZeroed) s.push("margin: 0");
  else s.push("margin: 0.67em 0"); // UA <h1>
  return s.join("; ");
})();

// --- <ul> ------------------------------------------------------------------
const ulStyle = (() => {
  const s = ["box-sizing: border-box"];
  // list markers
  s.push(listUnstyled ? "list-style: none" : "list-style: disc");
  // indent (padding) + outer margin
  if (marginsZeroed) {
    s.push("margin: 0");
    s.push("padding: 0");
  } else {
    s.push("margin: 1em 0"); // UA <ul>
    s.push("padding-left: 40px"); // UA <ul> indent lives in padding
  }
  return s.join("; ");
})();

const liStyle = "box-sizing: border-box; margin: 0; padding: 0; line-height: 1.5";

// On the painted step the items get deliberate spacing (a stand-in for space-y-*).
const liPaintedSpacing = "margin-top: 0.375rem";

// --- <p> -------------------------------------------------------------------
const pStyle = (() => {
  const s = ["box-sizing: border-box", "line-height: 1.5"];
  if (marginsZeroed) s.push("margin: 0");
  else s.push("margin: 1em 0"); // UA <p>
  if (painted) s.push("color: var(--sl-color-gray-3)"); // muted, tokenized
  return s.join("; ");
})();

// --- <button> --------------------------------------------------------------
const buttonStyle = (() => {
  const s = ["box-sizing: border-box"];
  if (painted) {
    // A real, filled, rounded button -- a stand-in for shadcn's <Button>.
    s.push(bodyFont);
    s.push("font-size: 0.875rem");
    s.push("font-weight: 500");
    s.push("line-height: 1");
    s.push("color: var(--sl-color-text-invert, #fff)");
    s.push("background: var(--sl-color-accent)");
    s.push("border: 0 solid");
    s.push("border-radius: 8px");
    s.push("padding: 0.5rem 0.875rem");
    s.push("cursor: pointer");
    return s.join("; ");
  }

  // Font. Until the inherit reset (step 5) the control wears its own UI font;
  // after, it takes the body font -- the visible payoff of `font: inherit`.
  if (buttonInherits) {
    s.push("font: inherit"); // -> body font + size
  } else {
    s.push("font-family: system-ui, sans-serif"); // UA control font
    s.push("font-size: 13.333px");
  }

  // Color. Three legible states that also make the step-5 reset visible:
  //   bevel present (step 1)  -> dark text, read against the light native bevel
  //   bevel gone, pre-inherit -> muted grey on the themed card (still "not yours")
  //   inherited (step 5+)     -> the body color, brightening to rejoin your type
  if (buttonInherits) {
    s.push("color: inherit"); // -> body color
  } else if (marginsZeroed) {
    s.push("color: var(--sl-color-gray-3)"); // UA text color, on the page surface
  } else {
    s.push("color: #111"); // UA text color on the native bevel
  }

  // Chrome (border + background + padding).
  if (marginsZeroed) {
    // Preflight: border 0 solid, padding 0 -- the native chrome is gone, but
    // until font/color inherit it still carries the UA font/color.
    s.push("border: 0 solid");
    s.push("margin: 0");
    s.push("padding: 0");
    s.push("background: transparent");
  } else {
    // UA button: beveled grey background + border, default padding.
    s.push("border: 1px solid #767676");
    s.push("border-radius: 3px");
    s.push("margin: 0");
    s.push("padding: 1px 7px");
    s.push("background: linear-gradient(#fafafa, #e3e3e3)");
  }
  return s.join("; ");
})();

// Native form controls compute their own `display`, so toggling it per-step is
// unreliable; the "just a run of text" reading at steps 5-6 already comes through
// from the subtracted chrome (no border, no background, body font + color). Keep
// the button in normal inline-block flow throughout.
const buttonDisplay = "display: inline-block";

// Spacing above the button in the painted state (deliberate, tokenized).
const buttonWrapStyle = painted
  ? "margin: 0; margin-top: 0.875rem"
  : "margin: 0";

// A tiny corner tag naming the cumulative state, so a reader landing mid-scrub
// knows which resets are active without reading the caption.
const tagText = painted
  ? "utilities applied"
  : marginsZeroed || headingFlat || listUnstyled || buttonInherits
    ? "preflight"
    : "browser defaults";

const tag = [
  "margin: 0",
  bodyFont,
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  painted
    ? "color: var(--sl-color-accent)"
    : marginsZeroed || headingFlat || listUnstyled || buttonInherits
      ? "color: var(--sl-color-gray-3)"
      : "color: var(--sl-color-gray-3)",
].join("; ");

// Stage wrapper: center the card and reserve a stable height so the
// DiagramSequence stage (which sizes to the tallest step) does not jump.
const stage = [
  "margin: 0",
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 8px",
  "min-height: 232px",
  "justify-content: center",
].join("; ");
---

<div class="not-content" style={stage} data-step={step}>
  <div style={tag} aria-hidden="true">{tagText}</div>

  <div style={card}>
    <h1 style={h1Style}>Upgrade to Pro</h1>
    <ul style={ulStyle}>
      <li style={liStyle}>Unlimited projects</li>
      <li style={painted ? `${liStyle}; ${liPaintedSpacing}` : liStyle}>
        Priority support
      </li>
    </ul>
    <p style={pStyle}>Your trial ends in 3 days.</p>
    <div style={buttonWrapStyle}>
      <button type="button" style={`${buttonStyle}; ${buttonDisplay}`}>
        Start trial
      </button>
    </div>
  </div>
</div>
