---
// The lesson's keystone figure: it makes the three-tier *indirection* literal.
// One utility, `bg-primary`, resolves down through the tiers it never names —
// semantic -> primitive -> value — and a parallel dark strand re-points only the
// MIDDLE tier, landing the same untouched utility on a different color.
//
// Why HTML+CSS color-matching instead of <ArrowDiagram>: the relationship is a
// chain of *identities* (the same token name read in one box, declared in the
// next), and the boxes hold multi-line code. Leader-line arrows between adjacent
// code boxes would have to leave/enter at box edges and skim the token text;
// color matching expresses "this token IS that token" at zero visual cost and
// never crosses text (ArrowDiagram doc, "When color matching beats arrows").
// Direction is still legible from the left-to-right strip + chevron connectors.
//
// Two color threads carry the indirection:
//   * VIOLET = the semantic token's identity. `bg-primary` (the consumer, box 1)
//     and `--color-primary` (the declaration, box 2 / dark box) share violet, so
//     the eye reads "the utility reads this exact token". Violet is the semantic
//     tier's color throughout the lesson's token figures.
//   * BLUE = the primitive's identity. `var(--blue-600)` (box 2, the pointer) and
//     `--blue-600` (box 3, the holder) share blue, so the eye reads "the semantic
//     token points at this exact primitive".
// green / red are deliberately avoided so no box reads as correct/wrong.
//
// The two rendered swatches are painted with the *resolved values* the diagram is
// about (oklch(0.55 0.2 264) light, a lighter same-hue blue for dark), so they are
// fixed and theme-independent — they must NOT follow the reader's own theme, the
// same rule BgCardResolution follows for its surface swatches.
//
// Pure HTML + CSS, devtools-inspectable. `not-content` + a `margin: 0` reset on
// every inner element defeat Starlight's prose-margin injection. Chrome uses
// Starlight gray/white/hairline variables so it flips with the site theme; the
// accent tints come from the theme-aware --mark-* palette (custom.css) so they
// flip too.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The resolved values of --color-primary the diagram lands on. Fixed,
// theme-independent: these ARE what the chain paints in each theme.
const LIGHT_FILL = "oklch(0.55 0.2 264)"; // --blue-600, what bg-primary paints in light
const DARK_FILL = "oklch(0.72 0.16 264)"; // --blue-400, what bg-primary paints under .dark

// ── shared inline-style strings ───────────────────────────────────────────

const strand = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 4px",
  "row-gap: 16px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// A labelled column: a small uppercase tag above its box.
const cell = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 6px",
  "box-sizing: border-box",
  "min-width: 0",
].join("; ");

// The small uppercase tag above each box.
const tag = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
  "padding-left: 2px",
  "max-width: 180px",
].join("; ");

// A code box holding token text. One block so inline segments flow as text and
// the literal spaces survive.
const codeBox = [
  reset,
  mono,
  "font-size: 13.5px",
  "font-weight: 600",
  "line-height: 1.45",
  "padding: 9px 12px",
  "border-radius: 9px",
  "white-space: nowrap",
  "display: flex",
  "align-items: center",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.035))",
  "border: 1px solid var(--sl-color-hairline)",
  "color: var(--sl-color-white)",
  "box-sizing: border-box",
].join("; ");

// A matched token slice. `color` is a --mark-* family (violet = semantic,
// blue = primitive); the inset ring sharpens the identity in the busy strip.
const matched = (color: string) =>
  [
    reset,
    "padding: 1px 4px",
    "margin: 0 -1px",
    "border-radius: 5px",
    `background: var(--mark-${color}-bg)`,
    `box-shadow: inset 0 0 0 1px var(--mark-${color}-brd)`,
    "color: var(--sl-color-white)",
    "font-weight: 700",
  ].join("; ");

// The chevron connector column between two boxes — a right-chevron over a tiny
// label so the strip reads source -> target.
const connector = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 2px",
  "padding: 0 2px",
  "align-self: center",
  "color: var(--sl-color-gray-3)",
].join("; ");

const connectorLabel = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "white-space: nowrap",
].join("; ");

// The rendered button swatch — a mock button painted with the *resolved* fill.
const swatch = (fill: string) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "padding: 9px 16px",
    "border-radius: 9px",
    "font-size: 13px",
    "font-weight: 600",
    "line-height: 1",
    "white-space: nowrap",
    "background: " + fill,
    "color: #fff",
    "border: 1px solid color-mix(in oklch, " + fill + " 70%, #000 12%)",
    "box-shadow: 0 1px 2px rgba(0,0,0,0.18)",
  ].join("; ");

// The faint echo of box 1 in the dark strand — same component, dimmed, to say
// "this never changed".
const echoBox = [
  reset,
  mono,
  "font-size: 13.5px",
  "font-weight: 600",
  "line-height: 1.45",
  "padding: 9px 12px",
  "border-radius: 9px",
  "white-space: nowrap",
  "display: flex",
  "align-items: center",
  "background: transparent",
  "border: 1px dashed var(--sl-color-hairline)",
  "color: var(--sl-color-gray-3)",
  "opacity: 0.85",
  "box-sizing: border-box",
].join("; ");

// The `.dark { … }` selector wrapper pill carrying the re-pointed declaration.
const darkBox = [
  reset,
  mono,
  "font-size: 13.5px",
  "font-weight: 600",
  "line-height: 1.45",
  "padding: 9px 12px",
  "border-radius: 9px",
  "white-space: nowrap",
  "display: flex",
  "align-items: center",
  "background: var(--sl-color-black)",
  "border: 1px solid var(--sl-color-hairline)",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

// The divider rule + label between the two strands.
const divider = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 10px",
  "width: 100%",
  "margin: 18px 0 4px",
].join("; ");

const dividerRule = [
  reset,
  "flex: 1",
  "height: 1px",
  "background: var(--sl-color-hairline)",
].join("; ");

const dividerLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--mark-violet-brd)",
  "white-space: nowrap",
].join("; ");

const chevronR = `<svg width="20" height="20" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 3 10 7 5 11"></polyline></svg>`;
---

<Figure>
  <div
    class="not-content"
    style={[reset, "display: flex", "flex-direction: column", "align-items: center", "box-sizing: border-box"].join("; ")}
  >
    {/* ── Primary strand: one utility resolving down the three tiers ─────── */}
    <div style={strand}>
      {/* Box 1 — the component reads the SEMANTIC tier */}
      <div style={cell}>
        <div style={tag}>Component reads the semantic tier</div>
        <div style={codeBox}>
          <span style={reset}>{`<button className="`}</span>
          <span style={matched("violet")}>bg-primary</span>
          <span style={reset}>{`">`}</span>
        </div>
      </div>

      <div style={connector} aria-hidden="true">
        <Fragment set:html={chevronR} />
        <span style={connectorLabel}>reads</span>
      </div>

      {/* Box 2 — semantic token points at a PRIMITIVE */}
      <div style={cell}>
        <div style={tag}>Semantic token points at a primitive</div>
        <div style={codeBox}>
          <span style={matched("violet")}>--color-primary</span>
          <span style={reset}>{`: `}</span>
          <span style={matched("blue")}>var(--blue-600)</span>
        </div>
      </div>

      <div style={connector} aria-hidden="true">
        <Fragment set:html={chevronR} />
        <span style={connectorLabel}>points at</span>
      </div>

      {/* Box 3 — the PRIMITIVE holds the value */}
      <div style={cell}>
        <div style={tag}>Primitive holds the value</div>
        <div style={codeBox}>
          <span style={matched("blue")}>--blue-600</span>
          <span style={reset}>{`: ${LIGHT_FILL}`}</span>
        </div>
      </div>

      <div style={connector} aria-hidden="true">
        <Fragment set:html={chevronR} />
        <span style={connectorLabel}>paints</span>
      </div>

      {/* Box 4 — what paints */}
      <div style={cell}>
        <div style={tag}>What paints</div>
        <div style={[codeBox, "background: transparent", "border-color: transparent", "padding: 0"].join("; ")}>
          <span style={swatch(LIGHT_FILL)}>bg-primary</span>
        </div>
      </div>
    </div>

    {/* ── Divider into the dark strand ─────────────────────────────────── */}
    <div style={divider} aria-hidden="true">
      <span style={dividerRule}></span>
      <span style={dividerLabel}>{`.dark re-points only the middle tier`}</span>
      <span style={dividerRule}></span>
    </div>

    {/* ── Dark strand: same component, middle pointer moved ────────────── */}
    <div style={strand}>
      {/* The same box 1, echoed and dimmed — untouched */}
      <div style={cell}>
        <div style={tag}>Same component, untouched</div>
        <div style={echoBox}>
          <span style={reset}>{`<button className="`}</span>
          <span style={[reset, "color: var(--mark-violet-brd)", "font-weight: 700"].join("; ")}>bg-primary</span>
          <span style={reset}>{`">`}</span>
        </div>
      </div>

      <div style={connector} aria-hidden="true">
        <Fragment set:html={chevronR} />
        <span style={connectorLabel}>reads</span>
      </div>

      {/* The SAME semantic token, re-pointed at a different primitive */}
      <div style={cell}>
        <div style={tag}>Dark re-points the same token</div>
        <div style={darkBox}>
          <span style={reset}>{`.dark { `}</span>
          <span style={matched("violet")}>--color-primary</span>
          <span style={reset}>{`: `}</span>
          <span style={matched("blue")}>var(--blue-400)</span>
          <span style={reset}>{` }`}</span>
        </div>
      </div>

      <div style={connector} aria-hidden="true">
        <Fragment set:html={chevronR} />
        <span style={connectorLabel}>paints</span>
      </div>

      {/* A lighter-blue swatch — the SAME utility, a different color */}
      <div style={cell}>
        <div style={tag}>Same utility, different color</div>
        <div style={[codeBox, "background: transparent", "border-color: transparent", "padding: 0"].join("; ")}>
          <span style={swatch(DARK_FILL)}>bg-primary</span>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="caption">
    One utility, three hops. <code>bg-primary</code> reads the semantic token, which
    points at a primitive, which holds the value. Dark mode re-points the middle hop
    and the same utility lands on a different color — the component is untouched.
  </Fragment>
</Figure>
