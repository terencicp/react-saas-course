---
// The Computed panel, one property expanded — gate-2 ("which layer won?") read
// straight off a DevTools mock, for Chapter 019 L1 ("Reading the cascade in
// DevTools").
//
// Fallback for a real Chrome DevTools capture (the outline's first choice): a
// faithful HTML+CSS mock of the **Computed** sub-tab with `font-size` expanded
// into its trace. The scene is the lesson's opening BUG, frozen at the moment
// the Computed trace explains it:
//
//   font-size  ->  16px              (the resolved final value)
//     16px      .heading   [unlayered]      <- WINS, and the amber label is the bug
//     24px      .text-2xl  [@layer utilities] (struck through — the utility lost)
//
// So the figure carries both layer pills the outline asks for (an amber
// `unlayered` pill on the winner, a cool `@layer utilities` pill on the
// struck-through loser) and teaches the durable move in one glance: expand the
// property, read which rule won and which LAYER it sits in. A winner labelled
// `unlayered` IS the bug.
//
// Chrome direction is honoured: the Computed trace lists the winning declaration
// first (active), with overridden declarations beneath it, struck through.
//
// Visual idiom matches this course's other DevTools mock (010/3
// ElementsPanelOverview): the same dark window chrome, VS-Code property/value
// colors, struck = line-through + 0.55 opacity, amber numbered callouts with a
// matched legend. A student who met that figure recognises this as the Computed
// sub-tab of the same panel. The one departure: the cascade-layer pills, the
// whole point of THIS figure, reuse L1's family — cool --sl-color-accent for a
// real @layer, the chapter's amber (#f59e0b) for the unlayered trap.
//
// Fixed-color island: the panel is a dark DevTools window in both site themes
// (DevTools is dark here), so panel text uses fixed VS-Code colors, not theme
// vars. The Figure card around it and the legend below still flip with the theme.
// `margin: 0` on every inner element defeats Starlight's prose-margin injection.

import Figure from "../../../figures/Figure.astro";

// --- DevTools window palette (fixed; the panel is dark in both site themes) ---
const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BORDER = "#3a3a3a";
const ROW_HOVER = "#262626";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const ACCENT = "#60a5fa"; // selected tab
const PROP = "#9cdcfe"; // CSS property name
const VAL = "#ce9178"; // CSS value
const LINK = "#6cb6ff"; // stylesheet source link
const CALLOUT_BG = "#f59e0b";
const CALLOUT_TEXT = "#0b0b0b";

// Cascade-layer pills — the family from L1's LayerStack.
const AMBER = "#f59e0b"; // the unlayered trap (warning)
const LAYER_OK = "#3b82f6"; // a real @layer (cool / "in the system")

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 11.5px; line-height: 1.5;";

// --- tab strip --------------------------------------------------------------
const tabBase = [
  reset,
  sans,
  "padding: 6px 12px",
  "font-size: 11px",
  `border-right: 1px solid ${PANEL_BORDER}`,
  "white-space: nowrap",
].join("; ");
const tabSelected = `${tabBase}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 4px;`;
const tabDim = `${tabBase}; color: ${TEXT_DIM}; background: ${PANEL_BG_ALT};`;

// --- toolbar (filter + "Show all" — real Computed-panel chrome) -------------
const toolbar = [
  reset,
  "padding: 6px 10px",
  "display: flex",
  "align-items: center",
  "gap: 10px",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
].join("; ");

const filterPill = [
  reset,
  codeFont,
  `color: ${TEXT_MUTED}`,
  "padding: 2px 8px",
  `border: 1px solid ${PANEL_BORDER}`,
  "border-radius: 3px",
].join("; ");

const checkboxRow = [reset, sans, "display: flex", "align-items: center", "gap: 5px", "font-size: 11px", `color: ${TEXT_MUTED}`].join("; ");

// --- property rows ----------------------------------------------------------
// A collapsed row: disclosure triangle + property: value.
const rowBase = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "padding: 2px 10px",
  "white-space: nowrap",
].join("; ");

const propName = `${reset}; color: ${PROP};`;
const propVal = `${reset}; color: ${VAL};`;
const colon = `${reset}; color: ${TEXT_BRIGHT};`;

// Disclosure triangle (CSS-only, rotates for expanded).
const triangle = (open: boolean) =>
  [
    reset,
    "display: inline-block",
    "width: 0",
    "height: 0",
    "border-top: 4px solid transparent",
    "border-bottom: 4px solid transparent",
    `border-left: 5px solid ${TEXT_MUTED}`,
    "flex: 0 0 auto",
    open ? "transform: rotate(90deg)" : "transform: none",
  ].join("; ");

// A trace row under the expanded property: value, then selector, then the
// stylesheet link, then the cascade-layer pill. The losing one is struck.
const traceRow = [
  reset,
  codeFont,
  "display: flex",
  "align-items: center",
  "gap: 10px",
  "padding: 3px 10px 3px 30px",
  "white-space: nowrap",
].join("; ");
const traceRowWin = `${traceRow}; background: ${ROW_HOVER};`;

const traceVal = `${reset}; color: ${VAL}; min-width: 38px;`;
const traceValStruck = `${traceVal}; text-decoration: line-through; opacity: 0.5;`;
const traceSel = `${reset}; color: ${TEXT_BRIGHT};`;
const traceSelStruck = `${traceSel}; text-decoration: line-through; opacity: 0.5;`;
const traceLink = `${reset}; color: ${LINK}; opacity: 0.85; margin-left: auto;`;
const traceLinkStruck = `${traceLink}; text-decoration: line-through; opacity: 0.45;`;

// Cascade-layer pill — the affordance this whole figure exists to point at.
const layerPill = (kind: "ok" | "warn") =>
  [
    reset,
    sans,
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.02em",
    "padding: 1px 7px",
    "border-radius: 999px",
    "white-space: nowrap",
    "flex: 0 0 auto",
    kind === "ok"
      ? `color: #cfe2ff; background: ${LAYER_OK}33; border: 1px solid ${LAYER_OK}99;`
      : `color: #ffe2b0; background: ${AMBER}26; border: 1px solid ${AMBER};`,
  ].join("; ");

// --- numbered callouts + legend ---------------------------------------------
const calloutDot = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 20px",
  "height: 20px",
  "border-radius: 50%",
  `background: ${CALLOUT_BG}`,
  `color: ${CALLOUT_TEXT}`,
  "font-weight: 700",
  "font-size: 11px",
  "box-shadow: 0 0 0 2px rgba(0,0,0,0.5)",
  "flex: 0 0 auto",
].join("; ");

const calloutInPanel = (top: string, right: string) =>
  `margin: 0; position: absolute; top: ${top}; right: ${right};`;

const legendGrid = [
  reset,
  sans,
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  "column-gap: 18px",
  "row-gap: 8px",
  "font-size: 12px",
].join("; ");
const legendRow = [reset, "display: flex", "align-items: flex-start", "gap: 7px"].join("; ");
const legendLabel = [reset, "color: var(--sl-color-text)", "line-height: 1.35"].join("; ");

// Collapsed sibling properties around the expanded one, for realism.
const siblings = [
  { name: "color", val: "oklch(0.21 0.03 264)" },
  { name: "display", val: "block" },
  { name: "line-height", val: "24px" },
];
---

<Figure
  caption="The Computed panel, font-size expanded into its trace: the struck-through rule lost, the rule above it won — and the amber layer label says why. A winner tagged unlayered is the bug; the fix is a layer move, not !important."
>
  <div class="not-content" style={`${reset}; ${sans}; display: flex; flex-direction: column; gap: 14px;`}>
    {/* DevTools window mock */}
    <div
      style={`${reset}; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2); max-width: 620px; margin-left: auto; margin-right: auto; width: 100%;`}
    >
      {/* Tab strip — Computed selected this time */}
      <div
        style={`${reset}; display: flex; flex-direction: row; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER};`}
      >
        <div style={tabDim}>Styles</div>
        <div style={tabSelected}>Computed</div>
        <div style={tabDim}>Layout</div>
        <div style={tabDim}>Event Listeners</div>
      </div>

      {/* Toolbar: filter + Show all */}
      <div style={toolbar}>
        <span style={filterPill}>Filter</span>
        <span style={checkboxRow}>
          <span
            style={`${reset}; display: inline-flex; align-items: center; justify-content: center; width: 12px; height: 12px; border: 1px solid ${ACCENT}; border-radius: 2px; background: ${ACCENT}; color: ${PANEL_BG}; font-size: 9px; font-weight: 800; line-height: 1;`}
            aria-hidden="true">{"✓"}</span>
          Show all
        </span>
      </div>

      {/* Computed property list */}
      <div style={`${reset}; padding: 8px 0; position: relative;`}>
        {/* Callout 1 — the resolved final value (beside font-size: 16px) */}
        <div style={calloutInPanel("33px", "10px")} aria-hidden="true">
          <span style={calloutDot}>1</span>
        </div>

        {/* one collapsed sibling above, for context */}
        <div style={rowBase}>
          <span style={triangle(false)} aria-hidden="true"></span>
          <span style={propName}>{siblings[0].name}</span>
          <span style={colon}>:</span>
          <span style={propVal}>{siblings[0].val}</span>
        </div>

        {/* THE expanded property — font-size, with its trace */}
        <div style={`${rowBase}; background: ${ROW_HOVER}; padding-top: 3px; padding-bottom: 3px;`}>
          <span style={triangle(true)} aria-hidden="true"></span>
          <span style={propName}>font-size</span>
          <span style={colon}>:</span>
          <span style={`${propVal}; font-weight: 700;`}>16px</span>
        </div>

        {/* trace row 1 — the WINNER (the bug): unlayered .heading */}
        <div style={traceRowWin}>
          <span style={traceVal}>16px</span>
          <span style={traceSel}>.heading</span>
          <span style={layerPill("warn")}>unlayered</span>
          <span style={traceLink}>globals.css:8</span>
        </div>

        {/* trace row 2 — the LOSER (struck): the utility you expected to win */}
        <div style={traceRow}>
          <span style={traceValStruck}>24px</span>
          <span style={traceSelStruck}>.text-2xl</span>
          <span style={layerPill("ok")}>@layer utilities</span>
          <span style={traceLinkStruck}>index.css</span>
        </div>

        {/* callouts 2 & 3 pinned to the layer label + the struck loser */}
        <div style={`${reset}; position: relative; height: 0;`} aria-hidden="true">
          <span style={`${calloutDot}; position: absolute; top: -45px; left: 220px;`}>2</span>
          <span style={`${calloutDot}; position: absolute; top: -19px; left: 4px;`}>3</span>
        </div>

        {/* remaining collapsed siblings below */}
        {siblings.slice(1).map((s) => (
          <div style={rowBase}>
            <span style={triangle(false)} aria-hidden="true"></span>
            <span style={propName}>{s.name}</span>
            <span style={colon}>:</span>
            <span style={propVal}>{s.val}</span>
          </div>
        ))}
      </div>
    </div>

    {/* Legend — what each numbered region tells you */}
    <div style={legendGrid}>
      <div style={legendRow}>
        <span style={calloutDot}>1</span>
        <span style={legendLabel}>
          <strong>Final value</strong> — what actually paints: <code style={`background: transparent; padding: 0; color: inherit; ${codeFont}`}>16px</code>, not the <code style={`background: transparent; padding: 0; color: inherit; ${codeFont}`}>text-2xl</code> you asked for.
        </span>
      </div>
      <div style={legendRow}>
        <span style={calloutDot}>2</span>
        <span style={legendLabel}>
          <strong>Layer label</strong> — names the gate-2 winner. Here it reads <strong style={`color: ${AMBER};`}>unlayered</strong>: the bug.
        </span>
      </div>
      <div style={legendRow}>
        <span style={calloutDot}>3</span>
        <span style={legendLabel}>
          <strong>Struck through</strong> — this declaration lost. The utility was beaten by the unlayered rule above it.
        </span>
      </div>
    </div>
  </div>
</Figure>
