---
// The specificity tuple — gate 3 (specificity) made concrete for Chapter 019 L1.
//
// Sibling to CascadeWaterfall.astro and LayerStack.astro in this folder. The
// waterfall shows the four gates; LayerStack zooms gate 2; this figure zooms
// gate 3 and shows HOW a specificity score is read: four labelled slots, a few
// example selectors scored beneath, all on ONE shared CSS grid so the four score
// columns line up vertically and the student can compare left-to-right by eye.
//
// Why a CSS grid (not flex, not SVG): the entire lesson is "compare the tuples
// slot by slot from the left", which only reads if the four score columns are
// pixel-aligned across rows. `grid-template-columns` enforces that for free and
// is devtools-inspectable — a bonus the prose calls out, since the lesson IS the
// cascade. Flex would drift; hand-placed SVG <text> would be fragile.
//
// Two ideas have to land:
//   1. The slots are ordered, and a higher number in a LEFTER slot wins outright
//      no matter what sits to its right. To make "where the weight sits" jump
//      out, the leftmost NON-ZERO cell in every row is accented (amber); zeros
//      are muted. So #cta's lone ID `1` reads as heavier than .btn's class `1`
//      purely from which column lights up — the ID column sits left of class.
//   2. :where(...) contributes ZERO. The :where(.dark) row renders its selector
//      in two segments: the :where(.dark) part greyed + struck with a small
//      (0,0,0,0) tag, and the trailing .btn in normal weight — so only .btn's
//      class `1` lights up, and the row scores identically to plain `.btn`.
//
// Conventions match the chapter-018/019 figures: a `not-content` root + a
// `margin: 0` reset on every inner element defeat Starlight's prose-margin
// injection; box-sizing: border-box throughout; theme chrome from Starlight
// gray/hairline vars; the warning/emphasis accent is the same amber (#f59e0b)
// the two sibling figures use, readable in both light and dark themes.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const AMBER = "#f59e0b"; // emphasis accent — matches CascadeWaterfall / LayerStack

// The four slot headers, left-to-right in tuple order. `hint` is the tiny second
// line under each header naming what feeds that slot.
const slots = [
  { name: "inline", hint: "style={…}" },
  { name: "ID", hint: "#id" },
  { name: "class / attr /\npseudo-class", hint: ".cls  [attr]  :hover" },
  { name: "element /\npseudo-element", hint: "div  ::before" },
];

// Example selectors, each scored across the four slots. `note` is an optional
// right-hand annotation; `where` flags the row whose selector is split into a
// zeroed :where(...) segment + a counting tail.
const rows = [
  { sel: ".btn", score: [0, 0, 1, 0] },
  { sel: "a:hover", score: [0, 0, 1, 1] },
  {
    sel: "#cta",
    score: [0, 1, 0, 0],
    note: "the ID slot sits left of class — this 1 beats both rows above",
  },
  {
    sel: ":where(.dark) .btn",
    score: [0, 0, 1, 0],
    where: { zero: ":where(.dark)", tail: ".btn" },
    note: ":where(…) adds 0 — only the trailing .btn counts",
  },
];

// Index of the leftmost non-zero slot in a score (the slot that "decides" the
// row when read left-to-right). -1 when every slot is zero.
const decidingSlot = (score: number[]) => score.findIndex((n) => n > 0);

// ---- shared block styles ----------------------------------------------------

// One grid governs header + all rows so the four score columns share a single
// coordinate system. Col 1 (selector) is fluid; the four score cols are a fixed,
// equal track so the digits line up dead-centre under their headers.
const SCORE_COL = "62px";
const grid = [
  reset,
  sans,
  "display: grid",
  `grid-template-columns: minmax(0, 1fr) repeat(4, ${SCORE_COL})`,
  "align-items: stretch",
  "max-width: 620px",
  "margin-left: auto",
  "margin-right: auto",
  "box-sizing: border-box",
  "row-gap: 0",
  "column-gap: 0",
].join("; ");

// Header cells -----------------------------------------------------------------
const headLabel = [
  reset,
  "align-self: end",
  "padding: 0 10px 9px",
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-2)",
].join("; ");

const headSlot = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: flex-end",
  "gap: 3px",
  "padding: 0 4px 8px",
  "text-align: center",
  "border-bottom: 1.5px solid var(--sl-color-hairline)",
].join("; ");

const slotName = [
  reset,
  "font-size: 11.5px",
  "font-weight: 700",
  "line-height: 1.15",
  "white-space: pre-line",
  "color: var(--sl-color-white)",
].join("; ");

const slotHint = [
  reset,
  mono,
  "font-size: 9px",
  "line-height: 1.1",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

// Row cells --------------------------------------------------------------------
const cellBase = [
  reset,
  "display: flex",
  "align-items: center",
  "box-sizing: border-box",
  "border-bottom: 1px solid var(--sl-color-hairline)",
  "padding-top: 11px",
  "padding-bottom: 11px",
].join("; ");

const selCell = (last: boolean) =>
  [
    cellBase,
    mono,
    "gap: 0",
    "padding-left: 4px",
    "padding-right: 14px",
    "font-size: 13px",
    "font-weight: 600",
    "color: var(--sl-color-white)",
    "white-space: nowrap",
    "overflow: hidden",
    last ? "border-bottom: none" : "",
  ].join("; ");

// A score cell. `decides` lights the leftmost non-zero digit; zeros are muted so
// the lit column is what the eye lands on.
const scoreCell = (
  value: number,
  decides: boolean,
  last: boolean,
) =>
  [
    cellBase,
    mono,
    "justify-content: center",
    "font-size: 16px",
    "font-variant-numeric: tabular-nums",
    decides ? "font-weight: 800" : "font-weight: 600",
    decides
      ? `color: ${AMBER}`
      : value === 0
        ? "color: var(--sl-color-gray-4)"
        : "color: var(--sl-color-white)",
    // faint vertical guide between the four score columns
    "border-left: 1px solid var(--sl-color-gray-6, rgba(128,128,128,0.12))",
    last ? "border-bottom: none" : "",
  ].join("; ");

// The two halves of a :where(...) selector: zeroed part (muted + struck) and the
// counting tail (normal). Rendered inline so they read as one selector.
const whereZero = [
  reset,
  "color: var(--sl-color-gray-3)",
  "text-decoration: line-through",
  "text-decoration-color: var(--sl-color-gray-4)",
  "text-decoration-thickness: 1px",
].join("; ");

const whereTag = [
  reset,
  sans,
  "font-size: 8.5px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "vertical-align: super",
  "margin-left: 3px",
  "color: var(--sl-color-gray-3)",
  "text-decoration: none",
].join("; ");

const whereTail = [reset, "color: var(--sl-color-white)"].join("; ");

// Per-row note pinned under the grid, aligned to its row via a thin connector.
const noteRow = [
  reset,
  sans,
  "grid-column: 1 / -1",
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "padding: 8px 4px 0",
].join("; ");

const noteDot = [
  reset,
  "flex: none",
  "width: 6px",
  "height: 6px",
  "border-radius: 999px",
  `background: ${AMBER}`,
].join("; ");

const noteText = [
  reset,
  "font-size: 11px",
  "line-height: 1.35",
  "color: var(--sl-color-gray-1)",
].join("; ");

const noteCode = [
  reset,
  mono,
  "font-size: 10.5px",
  "color: var(--sl-color-white)",
].join("; ");
---

<Figure
  caption="Compared left to right — the first slot that differs decides, and a higher number there wins no matter what sits to its right. But the browser only reaches this gate after layer order has already had its say."
>
  <div class="not-content" style={grid}>
    {/* ---- header: selector column + the four slot labels ---- */}
    <div style={headLabel}>selector</div>
    {
      slots.map((s) => (
        <div style={headSlot}>
          <div style={slotName}>{s.name}</div>
          <div style={slotHint}>{s.hint}</div>
        </div>
      ))
    }

    {/* ---- one row per example selector ---- */}
    {
      rows.map((r, ri) => {
        const last = ri === rows.length - 1;
        const decides = decidingSlot(r.score);
        return (
          <>
            <div style={selCell(last)}>
              {r.where ? (
                <span>
                  <span style={whereZero}>
                    {r.where.zero}
                    <span style={whereTag}>0,0,0,0</span>
                  </span>
                  <span style={whereTail}> {r.where.tail}</span>
                </span>
              ) : (
                <span>{r.sel}</span>
              )}
            </div>
            {r.score.map((n, ci) => (
              <div style={scoreCell(n, ci === decides, last)}>{n}</div>
            ))}
          </>
        );
      })
    }
  </div>

  {/* ---- annotations for the two rows that teach a rule ---- */}
  <div class="not-content" style={grid}>
    {
      rows
        .filter((r) => r.note)
        .map((r) => (
          <div style={noteRow}>
            <span style={noteDot} aria-hidden="true" />
            <span style={noteText}>
              <code style={noteCode}>{r.sel}</code> — {r.note}
            </span>
          </div>
        ))
    }
  </div>
</Figure>
