---
// The cascade waterfall — the load-bearing diagram of Chapter 019 L1.
//
// The cascade is a SHORT-CIRCUITING funnel, not a scorecard. A cluster of
// competing `font-size` declarations enters at the top and drops through four
// gates IN ORDER; the first gate that leaves a single winner stops the descent.
// Every gate carries a side-exit arrow to a "decided here -> winner" pill,
// making visible that a winner can fall out at any gate and skip every gate
// below it. That side-exit cue is the whole point — it is what distinguishes a
// waterfall from a scorecard.
//
// Vertical flow is deliberate here (the default is horizontal): the waterfall
// metaphor needs the descent. The viewBox height is the dial on how much screen
// the figure eats, so each gate is a single compact band, not a tall card.
//
// Gate 2 (cascade layer) is visually emphasized — accent band stroke, heavier
// accent exit arrow, accent pill — because on a Tailwind v4 project that is the
// gate where most real conflicts exit.
//
// Theme adaptation: `currentColor` for primary strokes / gate names (flips with
// the Starlight theme), a fixed mid-gray (#9ca3af) for the tiebreak sub-labels
// and the spine / leader lines, and one accent (amber, reads in both modes) for
// the emphasized layer gate. All <text> string content is wrapped in JS
// expressions ({'...'}) so remark-smartypants can't curl the quotes.

import Figure from "../../../figures/Figure.astro";

const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";
const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

const GRAY = "#9ca3af"; // subordinate lines + tiebreak sub-labels
const ACCENT = "#f59e0b"; // amber-500 — emphasizes the layer gate; reads in both themes

// ---- Central gate column geometry -------------------------------------------
const COL_X = 64; // left edge of the gate bands
const COL_W = 320; // band width
const COL_R = COL_X + COL_W; // right edge of the bands (exit arrows leave here)
const BAND_H = 56; // single compact row per gate
const GAP = 22; // vertical gap between bands (spine segment lives here)
const TOP = 86; // y of the first band's top

// Per-gate band top.
const bandTop = (i: number) => TOP + i * (BAND_H + GAP);
// Vertical center of a band — where its exit arrow and number badge sit.
const bandMid = (i: number) => bandTop(i) + BAND_H / 2;

const colMidX = COL_X + COL_W / 2; // x of the central spine

// ---- Right exit lane --------------------------------------------------------
const PILL_X = COL_R + 38; // left edge of the "winner" pills
const PILL_W = 132;
const PILL_H = 26;

// ---- The four gates, in the order the browser runs them ----------------------
const gates = [
  {
    n: "1",
    name: "Origin & importance",
    note: "author vs. browser; !important flips the order",
  },
  {
    n: "2",
    name: "Cascade layer",
    note: "later layer wins; unlayered beats all",
    emphasis: true,
  },
  {
    n: "3",
    name: "Specificity",
    note: "more specific selector wins",
  },
  {
    n: "4",
    name: "Source order",
    note: "last one in the stylesheet wins",
  },
];

// Competing declarations entering the funnel.
const chips = ["font-size: 1.5rem", "font-size: 2rem", "font-size: 1rem"];

const CHIP_Y = 16; // top of the chip row
const CHIP_H = 22;
const CHIP_CY = CHIP_Y + CHIP_H / 2;

const VB_H = bandTop(gates.length - 1) + BAND_H + 14; // crop tight below last band
---

<Figure
  caption="The cascade algorithm every browser runs, top to bottom — it stops at the first gate that leaves a single winner, so the gates below never run."
>
  <svg
    viewBox={`0 0 600 ${VB_H}`}
    role="img"
    aria-label="The CSS cascade as a four-gate waterfall. Three competing font-size declarations enter a funnel at the top and drop through four gates in order: gate 1 origin and importance (tiebreak: author vs. browser, !important flips the order), gate 2 cascade layer (tiebreak: later layer wins, unlayered beats all), gate 3 specificity (tiebreak: more specific selector wins), gate 4 source order (tiebreak: last one in the stylesheet wins). Each gate has a side exit pointing right to a 'decided here, winner' pill, showing a single winner can drop out at any gate and the descent stops. The cascade-layer gate is emphasized because on a Tailwind project most conflicts exit there."
    xmlns="http://www.w3.org/2000/svg"
    style="width: 100%; height: auto; display: block;"
  >
    {/* ---------- competing declaration chips entering the funnel ---------- */}
    <g font-family={mono} font-size="11">
      {
        chips.map((c, i) => {
          const cw = c.length * 6.6 + 16;
          const cx = colMidX + (i - 1) * 122; // spread three chips across the top
          return (
            <>
              <rect
                x={cx - cw / 2}
                y={CHIP_Y}
                width={cw}
                height={CHIP_H}
                rx="5"
                fill="none"
                stroke="currentColor"
                stroke-opacity="0.55"
              />
              <text
                x={cx}
                y={CHIP_CY}
                fill="currentColor"
                fill-opacity="0.85"
                text-anchor="middle"
                dominant-baseline="central"
              >
                {c}
              </text>
              {/* funnel leg: each chip converges onto the spine above gate 1 */}
              <line
                x1={cx}
                y1={CHIP_Y + CHIP_H}
                x2={colMidX}
                y2={TOP - 12}
                stroke={GRAY}
                stroke-width="1"
              />
            </>
          );
        })
      }
      <text
        x={colMidX}
        y={CHIP_Y - 4}
        fill={GRAY}
        font-family={sans}
        font-size="10"
        text-anchor="middle">{"competing declarations on one element"}</text>
    </g>

    {/* ---------- central spine: chips -> gate 1, then gate-to-gate ---------- */}
    <g stroke={GRAY} stroke-width="1.5" fill="none">
      {/* funnel neck into gate 1 */}
      <line x1={colMidX} y1={TOP - 12} x2={colMidX} y2={TOP} />
      {/* between consecutive bands */}
      {
        gates.slice(0, -1).map((_, i) => (
          <line
            x1={colMidX}
            y1={bandTop(i) + BAND_H}
            x2={colMidX}
            y2={bandTop(i + 1)}
          />
        ))
      }
      {/* small downward arrowhead on each spine segment, mid-gap */}
      {
        gates.slice(0, -1).map((_, i) => {
          const y = bandTop(i) + BAND_H + GAP / 2;
          return (
            <path
              d={`M ${colMidX - 4} ${y - 2} L ${colMidX} ${y + 3} L ${colMidX + 4} ${y - 2}`}
              stroke-width="1.3"
            />
          );
        })
      }
    </g>

    {/* ---------- the four gate bands + side exits ---------- */}
    {
      gates.map((g, i) => {
        const top = bandTop(i);
        const mid = bandMid(i);
        const stroke = g.emphasis ? ACCENT : "currentColor";
        const sw = g.emphasis ? 2 : 1.25;
        const pillStroke = g.emphasis ? ACCENT : GRAY;
        const pillTextFill = g.emphasis ? ACCENT : "currentColor";
        const exitSw = g.emphasis ? 2 : 1.25;
        return (
          <>
            {/* band */}
            <rect
              x={COL_X}
              y={top}
              width={COL_W}
              height={BAND_H}
              rx="9"
              fill="var(--sl-color-bg, transparent)"
              stroke={stroke}
              stroke-width={sw}
              stroke-opacity={g.emphasis ? "1" : "0.7"}
            />
            {/* number badge */}
            <circle
              cx={COL_X + 26}
              cy={mid}
              r="13"
              fill="none"
              stroke={stroke}
              stroke-width="1.4"
              stroke-opacity={g.emphasis ? "1" : "0.7"}
            />
            <text
              x={COL_X + 26}
              y={mid}
              font-family={sans}
              font-size="13"
              font-weight="700"
              fill={g.emphasis ? ACCENT : "currentColor"}
              text-anchor="middle"
              dominant-baseline="central">{g.n}</text>
            {/* gate name */}
            <text
              x={COL_X + 50}
              y={mid - 7}
              font-family={sans}
              font-size="13.5"
              font-weight="700"
              fill="currentColor"
              dominant-baseline="central">{g.name}</text>
            {/* tiebreak sub-label */}
            <text
              x={COL_X + 50}
              y={mid + 11}
              font-family={sans}
              font-size="10.5"
              fill={GRAY}
              dominant-baseline="central">{g.note}</text>

            {/* side-exit: leave the band's right edge, bend, into the winner pill */}
            <path
              d={`M ${COL_R} ${mid} H ${PILL_X - 10}`}
              fill="none"
              stroke={pillStroke}
              stroke-width={exitSw}
            />
            {/* arrowhead at the pill */}
            <path
              d={`M ${PILL_X - 10} ${mid - 4} L ${PILL_X - 2} ${mid} L ${PILL_X - 10} ${mid + 4} Z`}
              fill={pillStroke}
            />
            {/* winner pill */}
            <rect
              x={PILL_X}
              y={mid - PILL_H / 2}
              width={PILL_W}
              height={PILL_H}
              rx={PILL_H / 2}
              fill="none"
              stroke={pillStroke}
              stroke-width={g.emphasis ? "1.6" : "1.1"}
            />
            <text
              x={PILL_X + PILL_W / 2}
              y={mid}
              font-family={sans}
              font-size="10.5"
              font-weight={g.emphasis ? "700" : "600"}
              fill={pillTextFill}
              text-anchor="middle"
              dominant-baseline="central">{"decided here → winner"}</text>
          </>
        );
      })
    }
  </svg>
</Figure>
