---
// The layer stack — gate 2 (cascade layer) made concrete for Chapter 019 L1.
//
// Sibling to CascadeWaterfall.astro in this same folder: the waterfall shows the
// FOUR gates in order; this figure zooms into gate 2 and shows the ORDER OF THE
// LAYERS plus the unlayered trap in one glance. Higher on the page = wins, so the
// student can read "later layer beats earlier" straight off the vertical axis.
//
// Two ideas have to land together:
//   1. Tailwind emits four layers, declared theme -> base -> components ->
//      utilities, and the LATER one wins. So the stack is drawn bottom-to-top
//      theme (loses) ... utilities (wins), and the four read as one calm, related
//      family: a shared cool (TS-blue) accent that grows in weight as you climb,
//      mirroring "more likely to win the higher you are."
//   2. Anything you write OUTSIDE a layer sits ABOVE all four and wins BY
//      ACCIDENT. That fifth tier is the bug, so it is deliberately the anomaly:
//      it sits visually detached above the grouped four (a gap + a dashed
//      "above every layer" gutter), is filled amber, and carries a warning glyph.
//      The four layers are bracketed together as "Tailwind's layers" so the
//      unlayered tier reads as plainly OUTSIDE that system.
//
// Pure HTML + CSS, devtools-inspectable (a bonus the prose calls out, since the
// lesson literally is the cascade). Conventions match the chapter-018 figures:
// a `not-content` root + a `margin: 0` reset on every inner element defeat
// Starlight's prose-margin injection; box-sizing: border-box throughout; theme
// chrome from Starlight gray/hairline vars; the cool accent from the course's
// TS-blue --sl-color-accent family (flips with theme); the warning tier from the
// theme-aware --mark-orange-* pair plus a fixed amber (#f59e0b, the same accent
// CascadeWaterfall uses for the emphasized layer gate, readable in both modes).

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const AMBER = "#f59e0b"; // warning accent — matches CascadeWaterfall's layer-gate emphasis

// The four Tailwind layers, in DECLARED order (theme first). We render the stack
// reversed (utilities on top) so that visual-top == wins. `lift` ramps the cool
// accent's weight as you climb, so the family reads as "stronger / more likely to
// win the higher it sits". `owner` distinguishes Tailwind-managed from author-
// authored layers — the two you write into (base, components) get a subtle "you
// author here" tag.
const layers = [
  {
    name: "theme",
    role: "Tailwind-managed",
    detail: "your --color-* and --spacing-* tokens",
    lift: 0,
  },
  {
    name: "base",
    role: "Preflight + your global element rules",
    detail: "h2, code, kbd, link baselines",
    lift: 1,
    author: true,
  },
  {
    name: "components",
    role: "Tailwind-managed + your component classes",
    detail: "the rare .btn utilities can't express",
    lift: 2,
    author: true,
  },
  {
    name: "utilities",
    role: "Tailwind-managed",
    detail: "text-2xl, px-4, bg-primary, …",
    lift: 3,
  },
];

// Render top-to-bottom = wins-to-loses, so reverse the declared order.
const tiers = [...layers].reverse();

// ---- shared block styles ----------------------------------------------------

const wrap = [
  reset,
  sans,
  "display: flex",
  "flex-direction: column",
  "gap: 9px",
  "max-width: 560px",
  "margin-left: auto",
  "margin-right: auto",
  "box-sizing: border-box",
].join("; ");

// A single tier row: a left accent rail (the cool family / the amber anomaly),
// the layer name, and a one-line description. Flex so name + detail sit on a row
// with the detail pushed to fill.
const tierBase = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 12px",
  "padding: 9px 14px",
  "border-radius: 9px",
  "box-sizing: border-box",
].join("; ");

// Cool-family tier: neutral sidebar card + a left accent bar whose strength grows
// with `lift`. opacity climbs 0.4 -> 1 across the four so the ramp is legible.
const coolTier = (lift: number) =>
  [
    tierBase,
    "background: var(--sl-color-gray-6, rgba(0,0,0,0.025))",
    "border: 1px solid var(--sl-color-hairline)",
    `border-left: 4px solid color-mix(in oklab, var(--sl-color-accent) ${40 + lift * 20}%, transparent)`,
  ].join("; ");

// The warning (unlayered) tier: amber fill + amber border + glyph. Stands apart.
const warnTier = [
  tierBase,
  "background: var(--mark-orange-bg, rgba(245,158,11,0.13))",
  `border: 1.5px solid ${AMBER}`,
  `border-left: 4px solid ${AMBER}`,
].join("; ");

// The layer/tier name (monospace, since these are literal @layer identifiers).
const tierName = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.1",
  "white-space: nowrap",
].join("; ");

const tierNameCool = [tierName, "color: var(--sl-color-white)"].join("; ");
const tierNameWarn = [tierName, `color: ${AMBER}`].join("; ");

// The role line (top) + detail line (bottom), stacked, to the right of the name.
const tierText = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 2px",
  "min-width: 0",
  "flex: 1",
].join("; ");

const roleLine = (warn = false) =>
  [
    reset,
    "font-size: 12px",
    "font-weight: 600",
    "line-height: 1.2",
    warn ? `color: ${AMBER}` : "color: var(--sl-color-gray-1)",
  ].join("; ");

const detailLine = [
  reset,
  mono,
  "font-size: 11px",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Small "you author here" tag on the two student-authored layers.
const authorTag = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "white-space: nowrap",
  "padding: 2px 7px",
  "border-radius: 999px",
  "color: var(--sl-color-accent-high)",
  "background: color-mix(in oklab, var(--sl-color-accent) 15%, transparent)",
].join("; ");

// The dashed gutter between the unlayered tier and the layered family — the
// visual break that says "this one is outside the system".
const gutter = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 10px",
  "padding: 1px 4px 2px",
].join("; ");

const gutterRule = [
  reset,
  "flex: 1",
  "height: 0",
  `border-top: 1.5px dashed ${AMBER}`,
  "opacity: 0.8",
].join("; ");

const gutterLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "white-space: nowrap",
  `color: ${AMBER}`,
].join("; ");

// The left-hand "wins ↑ / loses ↓" axis spanning the whole stack.
const stageRow = [
  reset,
  "display: flex",
  "align-items: stretch",
  "gap: 14px",
  "box-sizing: border-box",
].join("; ");

const axis = [
  reset,
  sans,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: space-between",
  "padding: 2px 0",
  "flex: none",
  "color: var(--sl-color-gray-2)",
].join("; ");

const axisCap = [
  reset,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "white-space: nowrap",
].join("; ");

const axisLine = [
  reset,
  "flex: 1",
  "width: 0",
  "border-left: 1.5px solid var(--sl-color-gray-4)",
  "margin: 4px 0",
].join("; ");

// The grouping bracket label that ties the four cool tiers together.
const familyTag = [
  reset,
  sans,
  "align-self: center",
  "font-size: 10.5px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "color: var(--sl-color-gray-3)",
  "margin-top: 2px",
].join("; ");
---

<Figure
  caption="Tailwind emits four layers; later layers win. Anything you write outside a layer sits on top of all of them — the usual culprit behind a utility that won't apply."
>
  <div class="not-content" style={stageRow}>
    {/* left wins/loses axis spanning the full height of the stack */}
    <div style={axis} aria-hidden="true">
      <span style={axisCap}>wins</span>
      <svg
        width="14"
        height="12"
        viewBox="0 0 14 12"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        style="margin: 1px 0 0;"
      >
        <polyline points="3 5 7 1 11 5"></polyline>
      </svg>
      <span style={axisLine}></span>
      <svg
        width="14"
        height="12"
        viewBox="0 0 14 12"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        style="margin: 0 0 1px;"
      >
        <polyline points="3 7 7 11 11 7"></polyline>
      </svg>
      <span style={axisCap}>loses</span>
    </div>

    <div style={wrap}>
      {/* the anomaly: unlayered, sitting above every layer */}
      <div style={warnTier}>
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke={AMBER}
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          style="margin: 0; flex: none;"
        >
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"
          ></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        <div style={tierName + "; color: " + AMBER + ";"}>Unlayered</div>
        <div style={tierText}>
          <div style={roleLine(true)}>your stray CSS — sits ABOVE every layer</div>
          <div style={detailLine + `; color: ${AMBER};`}>
            wins by accident
          </div>
        </div>
      </div>

      {/* the break that marks "outside the layered system" */}
      <div style={gutter} aria-hidden="true">
        <span style={gutterRule}></span>
        <span style={gutterLabel}>above the layered system</span>
        <span style={gutterRule}></span>
      </div>

      {/* the four Tailwind layers, utilities (wins) at the top */}
      {
        tiers.map((l) => (
          <div style={coolTier(l.lift)}>
            <div style={tierNameCool}>{l.name}</div>
            <div style={tierText}>
              <div style={roleLine()}>{l.role}</div>
              <div style={detailLine}>{l.detail}</div>
            </div>
            {l.author && <span style={authorTag}>you author here</span>}
          </div>
        ))
      }

      <div style={familyTag}>— Tailwind's four layers, declared in this order —</div>
    </div>
  </div>
</Figure>
