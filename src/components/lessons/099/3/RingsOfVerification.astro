---
// rings-of-verification — the lesson's anchor visual (Lesson 99.3).
//
// The story in one glance: a migration sits at the centre, wrapped by two
// concentric rings of verification.
//   - Inner ring (neutral / "the machine does it"): the AUTOMATIC ring —
//     the build runs `db:migrate` and CI type-checks + tests. It proves the
//     migration APPLIES and the typed code COMPILES.
//   - Outer ring (saturated accent / "you do it by hand"): the MANUAL ring —
//     you walk the preview URL and query the branch directly. It proves the
//     change is CORRECT.
//
// HTML+CSS because this is a static containment relationship the student holds
// in working memory, not a sequence or a graph. The two rings are visually
// distinguished (calm neutral vs accent tone) so "the part the machine does"
// vs "the part you do" reads at a glance. Each ring carries a fieldset-legend
// label on its top border and a one-line proof label inside it. `not-content`
// + margin: 0 on every inner element defeats Starlight's prose-margin selector.

import Figure from "../../../figures/Figure.astro";

// The two members of each ring, rendered as a pair flanking the centre.
const automatic = [
  { icon: "▸", text: "build runs", code: "db:migrate" },
  { icon: "▸", text: "CI type-check + tests" },
];
const manual = [
  { icon: "▸", text: "walk the preview URL" },
  { icon: "▸", text: "query the branch directly" },
];
---

<Figure caption="Two concentric rings wrap every migration. The inner automatic ring runs on its own and proves the migration applies and the code compiles; the outer manual ring is the work you do by hand, and only it proves the change is correct.">
  <div class="rov not-content">
    {/* ---- Outer band: the MANUAL ring (accent) ---- */}
    <div class="rov-ring rov-ring--manual">
      <span class="rov-legend rov-legend--manual">Manual ring</span>

      <div class="rov-members">
        <div class="rov-member rov-member--manual">
          <span class="rov-member-mark">{manual[0].icon}</span>
          <span class="rov-member-text">{manual[0].text}</span>
        </div>

        {/* ---- Inner band: the AUTOMATIC ring (neutral) ---- */}
        <div class="rov-ring rov-ring--auto">
          <span class="rov-legend rov-legend--auto">Automatic ring</span>

          <div class="rov-members">
            <div class="rov-member rov-member--auto">
              <span class="rov-member-mark">{automatic[0].icon}</span>
              <span class="rov-member-text"
                >{automatic[0].text}
                <code class="rov-code">{automatic[0].code}</code></span
              >
            </div>

            {/* ---- The centre: the migration itself ---- */}
            <div class="rov-core">
              <span class="rov-core-kicker">Your migration</span>
              <code class="rov-core-code">ADD COLUMN customer_id</code>
            </div>

            <div class="rov-member rov-member--auto">
              <span class="rov-member-mark">{automatic[1].icon}</span>
              <span class="rov-member-text">{automatic[1].text}</span>
            </div>
          </div>

          <div class="rov-proof rov-proof--auto">proves it applies + compiles</div>
        </div>

        <div class="rov-member rov-member--manual">
          <span class="rov-member-mark">{manual[1].icon}</span>
          <span class="rov-member-text">{manual[1].text}</span>
        </div>
      </div>

      <div class="rov-proof rov-proof--manual">proves it is correct</div>
    </div>
  </div>
</Figure>

<style>
  .rov {
    margin: 0;
    width: 100%;
    max-width: 760px;
    margin-inline: auto;
    box-sizing: border-box;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --rov-accent: #0d9488; /* teal — the "you do it" ring */
    --rov-accent-hi: #0f766e;
  }

  /* ---- Shared ring shell (band with a legend straddling its top border) ---- */
  .rov-ring {
    margin: 0;
    position: relative;
    border-radius: 18px;
    box-sizing: border-box;
  }

  /* Outer / manual ring: accent-tinted, rounded, the dominant frame. */
  .rov-ring--manual {
    border: 2px solid var(--rov-accent);
    background: color-mix(in oklch, var(--rov-accent) 9%, var(--sl-color-bg-sidebar));
    padding: 30px 22px 14px;
  }

  /* Inner / automatic ring: neutral, calmer — "the machine does it". */
  .rov-ring--auto {
    margin: 0;
    flex: 1 1 0;
    min-width: 0;
    border: 1.5px dashed var(--sl-color-gray-3);
    background: var(--sl-color-bg-sidebar);
    padding: 28px 16px 12px;
  }

  /* ---- Fieldset-legend labels sitting on each ring's top border ---- */
  .rov-legend {
    display: block;
    width: fit-content;
    position: absolute;
    top: 0;
    left: 18px;
    transform: translateY(-50%);
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0;
  }

  .rov-legend--manual {
    background: var(--rov-accent);
    color: #fff;
  }

  .rov-legend--auto {
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-2);
    border: 1.5px dashed var(--sl-color-gray-3);
  }

  /* ---- The row of members flanking whatever they wrap ---- */
  .rov-members {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px 14px;
  }

  .rov-member {
    margin: 0;
    flex: 1 1 0;
    min-width: 150px;
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding: 8px 11px;
    border-radius: 9px;
    box-sizing: border-box;
    line-height: 1.3;
  }

  .rov-member--auto {
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6, var(--sl-color-bg-sidebar));
  }

  .rov-member--manual {
    border: 1.5px solid var(--rov-accent);
    background: color-mix(in oklch, var(--rov-accent) 14%, var(--sl-color-bg-sidebar));
  }

  .rov-member-mark {
    margin: 0;
    font-size: 11px;
    line-height: 1;
    color: var(--rov-accent-hi);
  }

  .rov-member--auto .rov-member-mark {
    color: var(--sl-color-gray-3);
  }

  .rov-member-text {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .rov-code {
    margin: 0;
    padding: 1px 5px;
    background: var(--sl-color-gray-5, var(--sl-color-bg-sidebar));
    border-radius: 5px;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
    color: var(--sl-color-white);
  }

  /* ---- The centre: the migration under test ---- */
  .rov-core {
    margin: 0;
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 12px 16px;
    border-radius: 12px;
    border: 2px solid var(--sl-color-white);
    background: var(--sl-color-black, var(--sl-color-bg));
    box-shadow: 0 4px 14px -8px rgba(0, 0, 0, 0.5);
  }

  .rov-core-kicker {
    margin: 0;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-gray-2);
  }

  .rov-core-code {
    margin: 0;
    padding: 0;
    background: transparent;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 13.5px;
    font-weight: 800;
    white-space: nowrap;
    color: var(--sl-color-white);
  }

  /* ---- Proof labels: one per ring, right-aligned below its members ---- */
  .rov-proof {
    margin: 10px 0 0;
    text-align: center;
    font-size: 11.5px;
    font-weight: 700;
    font-style: italic;
    letter-spacing: 0.01em;
  }

  .rov-proof--auto {
    color: var(--sl-color-gray-2);
  }

  .rov-proof--manual {
    color: var(--rov-accent-hi);
  }

  /* Narrow viewports: members stack above/below the inner ring naturally via
     flex-wrap; keep the inner ring full-width so it doesn't collapse. */
  @media (max-width: 560px) {
    .rov-ring--auto {
      flex-basis: 100%;
    }
    .rov-member {
      flex-basis: 100%;
    }
  }
</style>
