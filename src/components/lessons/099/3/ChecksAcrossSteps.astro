---
// checks-across-steps — the lesson's second anchor visual (Lesson 99.3).
//
// The story in one glance: the SAME four checks run on EVERY cadence step.
// What changes from step to step is which check carries the most weight.
//   - Columns = the three cadence steps (Expand / Migrate / Contract), each
//     shipped as its own pull request and so earning its own rehearsal.
//   - Rows = the four checks, always in the same order.
//   - One cell per column is the "heavy" check for that step — highlighted with
//     the teal accent so the shifting emphasis reads as a diagonal across the
//     grid. Expand leans on Check 4, Migrate on Check 4's dual-write inspection,
//     Contract on Check 3.
//
// HTML+CSS grid because this is a static matrix the student scans, not a
// sequence or graph. Matches the sibling RingsOfVerification component's accent
// (teal) and Starlight color vars. `not-content` + margin: 0 everywhere defeats
// Starlight's prose-margin selector.

import Figure from "../../../figures/Figure.astro";

const checks = [
  "Migration applied + matches the PR",
  "Ran fast on the branch",
  "Preview URL critical paths work",
  "Old shape still behaves",
];

// One column per cadence step. `heavy` marks the index (0-based) of the check
// that carries the most weight for that step; `note` is the step-specific thing
// to look for in each cell.
const steps = [
  {
    name: "Expand",
    kicker: "additive — broke nothing",
    cells: [
      "New column present, type + nullability match",
      "Additive change, near-instant",
      "Everything renders as before",
      "Old column still reads + writes",
    ],
    heavy: 3,
  },
  {
    name: "Migrate",
    kicker: "dual-write + backfill",
    cells: [
      "Backfill ran, migration row present",
      "Time it, extrapolate to prod rows",
      "Mutations succeed end to end",
      "A mutated row has BOTH columns populated",
    ],
    heavy: 3,
  },
  {
    name: "Contract",
    kicker: "old shape removed",
    cells: [
      "Old column gone, type still matches",
      "Drop is fast",
      "Nothing broke when the old shape vanished",
      "No typed or raw read of the old column remains",
    ],
    heavy: 2,
  },
];
---

<Figure
  caption="The same four checks run on every cadence step — what shifts is which check carries the most weight. The highlighted cell in each column is that step's heavy check: Expand leans on the old shape still working, Migrate on a mutated row carrying both columns, Contract on nothing breaking once the old shape is gone."
>
  <div class="cas not-content">
    <div class="cas-grid">
      {/* ---- Corner + the three step headers ---- */}
      <div class="cas-corner">Run on <em>each</em> step</div>
      {
        steps.map((step) => (
          <div class="cas-head">
            <span class="cas-head-name">{step.name}</span>
            <span class="cas-head-kicker">{step.kicker}</span>
          </div>
        ))
      }

      {/* ---- One row per check: label + a cell under each step ---- */}
      {
        checks.map((check, r) => (
          <>
            <div class="cas-rowlabel">
              <span class="cas-rownum">{r + 1}</span>
              <span class="cas-rowtext">{check}</span>
            </div>
            {steps.map((step) => (
              <div class={`cas-cell${step.heavy === r ? " cas-cell--heavy" : ""}`}>
                {step.heavy === r && <span class="cas-heavy-tag">heaviest here</span>}
                <span class="cas-cell-text">{step.cells[r]}</span>
              </div>
            ))}
          </>
        ))
      }
    </div>

    <p class="cas-foot">
      Three separate pull requests &rarr; three separate rehearsals. Rehearsing
      the cadence means rehearsing <em>every</em> step, not once.
    </p>
  </div>
</Figure>

<style>
  .cas {
    margin: 0;
    width: 100%;
    box-sizing: border-box;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --cas-accent: #0d9488; /* teal — matches the rings figure */
    --cas-accent-hi: #0f766e;
  }

  .cas-grid {
    margin: 0;
    display: grid;
    grid-template-columns: minmax(140px, 1.15fr) repeat(3, minmax(0, 1fr));
    gap: 6px;
    box-sizing: border-box;
  }

  /* ---- Top-left corner cell ---- */
  .cas-corner {
    margin: 0;
    display: flex;
    align-items: flex-end;
    padding: 6px 8px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--sl-color-gray-2);
  }

  .cas-corner em {
    font-style: italic;
    color: var(--sl-color-white);
  }

  /* ---- Column headers: one per cadence step ---- */
  .cas-head {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: center;
    justify-content: center;
    padding: 8px 6px;
    border-radius: 9px;
    border: 1.5px solid var(--cas-accent);
    background: color-mix(in oklch, var(--cas-accent) 14%, var(--sl-color-bg-sidebar));
    text-align: center;
  }

  .cas-head-name {
    margin: 0;
    font-size: 14px;
    font-weight: 800;
    color: var(--sl-color-white);
  }

  .cas-head-kicker {
    margin: 0;
    font-size: 10.5px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--cas-accent-hi);
  }

  /* ---- Row labels: the check name ---- */
  .cas-rowlabel {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 8px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-sidebar);
  }

  .cas-rownum {
    margin: 0;
    flex: 0 0 auto;
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--sl-color-gray-5, var(--sl-color-bg));
    font-size: 11px;
    font-weight: 800;
    color: var(--sl-color-white);
  }

  .cas-rowtext {
    margin: 0;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-white);
  }

  /* ---- Body cells ---- */
  .cas-cell {
    margin: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4px;
    justify-content: center;
    padding: 8px 9px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6, var(--sl-color-bg-sidebar));
  }

  .cas-cell-text {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--sl-color-gray-1, var(--sl-color-white));
  }

  /* ---- The heavy cell: the step's load-bearing check ---- */
  .cas-cell--heavy {
    border: 1.5px solid var(--cas-accent);
    background: color-mix(in oklch, var(--cas-accent) 16%, var(--sl-color-bg-sidebar));
  }

  .cas-cell--heavy .cas-cell-text {
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .cas-heavy-tag {
    margin: 0;
    align-self: flex-start;
    padding: 1px 7px;
    border-radius: 999px;
    background: var(--cas-accent);
    font-size: 9.5px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
  }

  /* ---- Footer rule ---- */
  .cas-foot {
    margin: 14px 0 0;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
  }

  .cas-foot em {
    font-style: italic;
    color: var(--sl-color-white);
  }

  /* Narrow viewports: collapse to a stacked, per-step reading order. The grid
     reflows so each step's column sits under its header band, and row labels
     repeat their number for orientation. */
  @media (max-width: 620px) {
    .cas-grid {
      grid-template-columns: 1fr 1fr;
    }
    .cas-corner {
      grid-column: 1 / -1;
    }
    .cas-rowlabel {
      grid-column: 1 / -1;
    }
  }
</style>
