---
/**
 * A hand-built 2x2 matrix showing the two independent gates a schema change
 * can fail: the lock axis (vertical) and the overlap-window / breaks-code axis
 * (horizontal). Pure layout artifact — no diagram engine.
 *
 * Cell tints map to verdicts:
 *   green  = neither gate fails (ship one PR)
 *   orange = exactly one gate fails (needs work, but different fixes)
 *   red    = both gates fail
 */

const cells = [
  // top row — needs a long ACCESS EXCLUSIVE lock
  {
    heading: 'Redesign the SQL, then re-check',
    example: 'Index without CONCURRENTLY',
    tint: 'orange',
  },
  {
    heading: 'Both gates fail',
    example: 'Naive SET NOT NULL on a big table',
    tint: 'red',
  },
  // bottom row — no long lock
  {
    heading: 'Ship it, one PR',
    example: 'Add a nullable column · new table',
    tint: 'green',
  },
  {
    heading: 'Cadence — code is out of sync',
    example: 'Rename a column · drop a read column',
    tint: 'orange',
  },
];

const tints = {
  green: {
    bg: 'color-mix(in oklab, #16a34a 16%, var(--sl-color-bg))',
    border: 'color-mix(in oklab, #16a34a 55%, var(--sl-color-bg))',
  },
  orange: {
    bg: 'color-mix(in oklab, #ea580c 15%, var(--sl-color-bg))',
    border: 'color-mix(in oklab, #ea580c 55%, var(--sl-color-bg))',
  },
  red: {
    bg: 'color-mix(in oklab, #dc2626 16%, var(--sl-color-bg))',
    border: 'color-mix(in oklab, #dc2626 55%, var(--sl-color-bg))',
  },
};
---

<div
  style="display: grid; grid-template-columns: auto 1fr; grid-template-rows: 1fr auto; gap: 10px; margin: 0; max-width: 760px; margin-inline: auto;"
>
  {/* y-axis label, rotated, spanning the grid rows */}
  <div
    style="grid-column: 1; grid-row: 1; display: flex; align-items: center; justify-content: center; margin: 0;"
  >
    <div
      style="writing-mode: vertical-rl; transform: rotate(180deg); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.01em; color: var(--sl-color-white); text-align: center; margin: 0;"
    >
      Needs a long ACCESS EXCLUSIVE lock?
    </div>
  </div>

  {/* the 2x2 grid of cells, with row tags down its own left edge */}
  <div
    style="grid-column: 2; grid-row: 1; display: grid; grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); gap: 8px; margin: 0;"
  >
    {
      cells.map((cell, i) => (
        <div
          style={`position: relative; display: flex; flex-direction: column; gap: 6px; padding: 14px 14px; border-radius: 10px; box-sizing: border-box; min-width: 0; background: ${tints[cell.tint].bg}; border: 1px solid ${tints[cell.tint].border}; margin: 0;`}
        >
          {/* row axis-value tag, only on the left column cells */}
          {i % 2 === 0 && (
            <span
              style="position: absolute; top: 8px; right: 10px; font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--sl-color-gray-3); margin: 0;"
            >
              {i === 0 ? 'lock: yes' : 'lock: no'}
            </span>
          )}
          <span
            style="font-size: 0.92rem; font-weight: 700; line-height: 1.25; color: var(--sl-color-white); margin: 0; padding-right: 56px;"
          >
            {cell.heading}
          </span>
          <span
            style="font-size: 0.8rem; line-height: 1.35; color: var(--sl-color-gray-2); margin: 0;"
          >
            {cell.example}
          </span>
        </div>
      ))
    }
  </div>

  {/* x-axis: column value labels + axis title, under the grid, aligned to it */}
  <div
    style="grid-column: 2; grid-row: 2; display: flex; flex-direction: column; gap: 4px; margin: 0;"
  >
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin: 0;">
      <div
        style="text-align: center; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--sl-color-gray-3); margin: 0;"
      >
        breaks code: no
      </div>
      <div
        style="text-align: center; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--sl-color-gray-3); margin: 0;"
      >
        breaks code: yes
      </div>
    </div>
    <div
      style="text-align: center; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.01em; color: var(--sl-color-white); margin: 4px 0 0;"
    >
      Breaks the old or new code?
    </div>
  </div>
</div>
