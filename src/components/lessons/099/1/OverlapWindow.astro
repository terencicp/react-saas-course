---
// The overlap window: where both code fleets meet one database during a deploy.
//
// One component, three phases ("before" | "overlap" | "after"), each rendered as
// a DiagramStep body. Keeping a single implementation guarantees all three steps
// share an identical layout footprint, so the DiagramSequence grid stack (which
// sizes to the tallest step) never jumps height as the reader scrubs.
//
// Layout: a horizontal strip — a fleet column on the left (v1 stacked over v2),
// an arrow gutter in the middle, and one Database box on the right. An alias
// pill above the fleet column shows which deployment the production domain points
// at. The whole arrow gutter + DB tints red during the overlap phase to mark the
// danger zone where two schemas would both have to be valid at once.
//
// `margin: 0` on every inner element defeats the Starlight prose-margin selector
// that injects ~16px on block-level descendants after the first.

type Phase = "before" | "overlap" | "after";
interface Props {
  phase: Phase;
}

const { phase } = Astro.props;

const isOverlap = phase === "overlap";
// v1 (old code) is live in "before" (serving) and "overlap" (draining); gone in "after".
const v1State =
  phase === "before" ? "serving" : phase === "overlap" ? "draining" : "gone";
// v2 (new code) is gone in "before"; warming in "overlap"; serving in "after".
const v2State =
  phase === "before" ? "gone" : phase === "overlap" ? "warming" : "serving";

const aliasTarget = phase === "before" ? "v1" : "v2";

// ── Box chrome ────────────────────────────────────────────────────────────────
const boxBase = [
  "margin: 0",
  "padding: 8px 10px",
  "border-radius: 8px",
  "min-width: 96px",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 2px",
  "transition: opacity 0.2s, border-color 0.2s, background-color 0.2s",
].join("; ");

// Active fleet: tinted blue, solid.
const fleetActive = (accent: string) =>
  `${boxBase}; border: 1px solid color-mix(in srgb, ${accent} 55%, transparent); background: color-mix(in srgb, ${accent} 12%, transparent); opacity: 1;`;
// Draining fleet: still live but dashed + dimmed to read as "on the way out".
const fleetDraining = (accent: string) =>
  `${boxBase}; border: 1px dashed color-mix(in srgb, ${accent} 55%, transparent); background: color-mix(in srgb, ${accent} 8%, transparent); opacity: 0.78;`;
// Absent fleet: faint dotted ghost so the slot keeps its height but reads as empty.
const fleetGhost =
  `${boxBase}; border: 1px dotted color-mix(in srgb, currentColor 22%, transparent); background: transparent; opacity: 0.32;`;

const V1 = "#38bdf8"; // sky — old code
const V2 = "#34d399"; // emerald — new code

const v1Style =
  v1State === "serving"
    ? fleetActive(V1)
    : v1State === "draining"
      ? fleetDraining(V1)
      : fleetGhost;
const v2Style =
  v2State === "serving"
    ? fleetActive(V2)
    : v2State === "warming"
      ? fleetDraining(V2)
      : fleetGhost;

const dbStyle = [
  boxBase,
  isOverlap
    ? "border: 1px solid color-mix(in srgb, #f43f5e 55%, transparent); background: color-mix(in srgb, #f43f5e 10%, transparent);"
    : "border: 1px solid color-mix(in srgb, currentColor 30%, transparent); background: color-mix(in srgb, currentColor 7%, transparent);",
].join("; ");

const titleStyle =
  "margin: 0; font-size: 13px; font-weight: 600; line-height: 1.2; white-space: nowrap;";
const subStyle =
  "margin: 0; font-size: 10px; opacity: 0.65; line-height: 1.2; white-space: nowrap;";

const aliasStyle = [
  "margin: 0 0 10px",
  "align-self: center",
  "padding: 3px 10px",
  "border-radius: 999px",
  "font-size: 11px",
  "font-weight: 600",
  "white-space: nowrap",
  `border: 1px solid color-mix(in srgb, ${aliasTarget === "v1" ? V1 : V2} 55%, transparent)`,
  `background: color-mix(in srgb, ${aliasTarget === "v1" ? V1 : V2} 14%, transparent)`,
].join("; ");

// Arrow gutter: each row holds one connector to the DB. A live fleet's connector
// is solid; an absent fleet's row is empty (keeps the height).
const labels: Record<string, string> = {
  serving: "serving",
  draining: "draining",
  warming: "warming",
  gone: "",
};
const v1Live = v1State !== "gone";
const v2Live = v2State !== "gone";
const arrowColor = (live: boolean, accent: string) =>
  live
    ? `color-mix(in srgb, ${isOverlap ? "#f43f5e" : accent} 70%, transparent)`
    : "transparent";
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 10px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  <div
    style="margin: 0; display: flex; flex-direction: row; align-items: stretch; justify-content: center; gap: 0; min-width: 0;"
  >
    {/* Left: alias pill above the two stacked fleets */}
    <div
      style="margin: 0; display: flex; flex-direction: column; justify-content: center; flex: 0 0 auto;"
    >
      <div style={aliasStyle}>
        alias &rarr; {aliasTarget}
      </div>
      <div style="margin: 0; display: flex; flex-direction: column; gap: 14px;">
        <div style={v1Style}>
          <div style={titleStyle}>v1 fleet</div>
          <div style={subStyle}>{v1State === "gone" ? "drained" : `old code · ${labels[v1State]}`}</div>
        </div>
        <div style={v2Style}>
          <div style={titleStyle}>v2 fleet</div>
          <div style={subStyle}>{v2State === "gone" ? "not yet live" : `new code · ${labels[v2State]}`}</div>
        </div>
      </div>
    </div>

    {/* Middle: arrow gutter — one connector row per fleet, aligned to the boxes */}
    <div
      style="margin: 0; align-self: flex-end; display: flex; flex-direction: column; gap: 14px; flex: 0 0 auto; width: 72px;"
    >
      {/* spacer matching the alias pill height so rows line up with the fleets */}
      <svg
        viewBox="0 0 72 88"
        width="72"
        height="88"
        role="img"
        aria-label={
          isOverlap
            ? "Both the v1 and v2 fleets point arrows at the same database."
            : v1Live
              ? "The v1 fleet points an arrow at the database."
              : "The v2 fleet points an arrow at the database."
        }
        style="margin: 0; display: block;"
        preserveAspectRatio="none"
      >
        {/* v1 row is the top box; v2 row is the bottom box. Box height ≈ 37, gap 14. */}
        {v1Live && (
          <g>
            <line x1="0" y1="18" x2="60" y2="18" stroke={arrowColor(true, V1)} stroke-width="1.6" stroke-dasharray={v1State === "draining" ? "4 3" : undefined} />
            <path d="M 72 18 L 60 13 L 60 23 Z" fill={arrowColor(true, V1)} />
          </g>
        )}
        {v2Live && (
          <g>
            <line x1="0" y1="70" x2="60" y2="70" stroke={arrowColor(true, V2)} stroke-width="1.6" stroke-dasharray={v2State === "warming" ? "4 3" : undefined} />
            <path d="M 72 70 L 60 65 L 60 75 Z" fill={arrowColor(true, V2)} />
          </g>
        )}
      </svg>
    </div>

    {/* Right: the one shared database */}
    <div
      style="margin: 0; display: flex; flex-direction: column; justify-content: center; flex: 0 0 auto;"
    >
      <div style={dbStyle}>
        <div style={titleStyle}>Database</div>
        <div style={subStyle}>one shared schema</div>
      </div>
    </div>
  </div>

  {/* Danger banner — only in the overlap phase */}
  <div
    style="margin: 0; min-height: 22px; display: flex; justify-content: center; align-items: center;"
  >
    {isOverlap && (
      <span
        style="margin: 0; padding: 3px 12px; border-radius: 999px; font-size: 11px; font-weight: 600; color: color-mix(in srgb, #f43f5e 88%, var(--sl-color-text)); border: 1px solid color-mix(in srgb, #f43f5e 45%, transparent); background: color-mix(in srgb, #f43f5e 10%, transparent);"
      >
        Danger zone — both fleets, one schema
      </span>
    )}
  </div>
</div>
