---
// The reversibility of each cadence step at a glance — the artifact the student
// screenshots. A small three-column table, Expand | Migrate | Contract, mirroring
// the left-to-right ordering (and palette) of CadenceStrip so the two figures
// rhyme. Each column carries the rollback METHOD and a colour-coded COST tag:
// the first two steps roll back cheaply by deploy (green); the third is a
// data-recovery problem (red). That green / green / red rhythm is the whole
// point — two safe, one dangerous, and the dangerous one goes last.
//
// Plain HTML + inline styles so the layout is devtools-inspectable. `margin: 0`
// on every inner element defeats Starlight's prose-margin selector, which injects
// ~16px on block-level descendants after the first (and reaches into flex children).
//
// Step accents reuse CadenceStrip's palette (emerald / amber / sky) to anchor each
// column to its step; the COST tag uses its own green/red so cost reads independently
// of which step it belongs to.

interface Column {
  step: string;
  index: string;
  accent: string;
  method: string;
  costLabel: string;
  costText: string;
  costColor: string; // green = cheap, red = data-recovery
}

const columns: Column[] = [
  {
    step: "Expand",
    index: "Deploy 1",
    accent: "#34d399", // emerald — matches CadenceStrip
    method: "git revert the empty app PR, plus a forward-fix migration that drops the unread new column.",
    costLabel: "Cheap",
    costText: "revert + forward-fix drop",
    costColor: "#22c55e",
  },
  {
    step: "Migrate",
    index: "Deploy 2",
    accent: "#f59e0b", // amber — matches CadenceStrip
    method: "git revert the app PR — no migration. Reads fall through to the old column, which still holds the truth.",
    costLabel: "Cheap",
    costText: "just git revert, data is harmless",
    costColor: "#22c55e",
  },
  {
    step: "Contract",
    index: "Deploy 3",
    accent: "#38bdf8", // sky — matches CadenceStrip
    method: "Not a deploy at all. Re-add the column, then backfill it from a known good source — a snapshot, replica, or export.",
    costLabel: "Data-recovery",
    costText: "re-add + backfill from a known source",
    costColor: "#ef4444",
  },
];

const columnStyle = (accent: string) =>
  [
    "margin: 0",
    "flex: 1 1 0",
    "min-width: 0",
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 12px",
    "padding: 14px 14px 16px",
    "border-radius: 12px",
    `border: 1px solid color-mix(in srgb, ${accent} 50%, transparent)`,
    `background: color-mix(in srgb, ${accent} 9%, transparent)`,
  ].join("; ");

// Step header: an index eyebrow over the step name (same shape as CadenceStrip).
const headerStyle = "margin: 0; display: flex; flex-direction: column; gap: 2px;";
const eyebrowStyle =
  "margin: 0; font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.6; line-height: 1.2;";
const stepNameStyle = (accent: string) =>
  `margin: 0; font-size: 17px; font-weight: 700; line-height: 1.15; color: color-mix(in srgb, ${accent} 78%, var(--sl-color-text));`;

// The rollback-method cell.
const cellStyle = "margin: 0; display: flex; flex-direction: column; gap: 4px; flex: 1 1 auto;";
const cellLabelStyle =
  "margin: 0; font-size: 10px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; opacity: 0.55; line-height: 1.2;";
const methodStyle = "margin: 0; font-size: 12.5px; line-height: 1.4;";

// The colour-coded cost tag.
const costTagStyle = (color: string) =>
  [
    "margin: 0",
    "align-self: flex-start",
    "display: inline-flex",
    "flex-direction: column",
    "gap: 2px",
    "padding: 6px 10px",
    "border-radius: 8px",
    `border: 1px solid color-mix(in srgb, ${color} 55%, transparent)`,
    `background: color-mix(in srgb, ${color} 14%, transparent)`,
  ].join("; ");
const costLabelStyle = (color: string) =>
  `margin: 0; font-size: 12px; font-weight: 700; line-height: 1.2; color: color-mix(in srgb, ${color} 80%, var(--sl-color-text));`;
const costTextStyle =
  "margin: 0; font-size: 10.5px; opacity: 0.7; line-height: 1.25; font-family: var(--sl-font-mono, ui-monospace, monospace);";
---

<div
  style="margin: 0; display: flex; flex-direction: row; align-items: stretch; gap: 8px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {
    columns.map((c) => (
      <div style={columnStyle(c.accent)}>
        <div style={headerStyle}>
          <div style={eyebrowStyle}>{c.index}</div>
          <div style={stepNameStyle(c.accent)}>{c.step}</div>
        </div>

        <div style={cellStyle}>
          <div style={cellLabelStyle}>Rollback method</div>
          <p style={methodStyle}>{c.method}</p>
        </div>

        <div style={costTagStyle(c.costColor)}>
          <div style={costLabelStyle(c.costColor)}>{c.costLabel}</div>
          <div style={costTextStyle}>{c.costText}</div>
        </div>
      </div>
    ))
  }
</div>
