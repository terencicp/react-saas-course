---
// The spine of the expand-migrate-contract cadence, as a single horizontal
// three-panel strip the student holds in working memory for the rest of the
// lesson. Deliberately minimal — a memory anchor, not a detailed diagram.
//
// Three equal columns, left to right: Expand | Migrate | Contract. Each column
// shows two labelled rows of state — the SCHEMA state (old-only → both → new-only)
// and the APP-CODE state (unchanged → dual-write/read → cleaned up). A subtle
// left-to-right accent progression plus chevrons between panels make the eye read
// it as a timeline.
//
// Plain HTML + inline styles so the layout is devtools-inspectable. `margin: 0`
// on every inner element defeats Starlight's prose-margin selector, which injects
// ~16px on block-level descendants after the first (and reaches into flex children).
//
// Colours stay in the lesson's palette: emerald for the additive/safe expand step
// (matching the green "key step" accent the dual-write code uses), amber for the
// in-flight migrate step where the scaffolding lives, and a settled sky/blue for
// the clean contract step.

interface Panel {
  step: string;
  index: string;
  accent: string;
  schema: string;
  schemaNote: string;
  app: string;
  appNote: string;
}

const panels: Panel[] = [
  {
    step: "Expand",
    index: "Deploy 1",
    accent: "#34d399", // emerald — additive, safe
    schema: "old + new",
    schemaNote: "new column empty",
    app: "unchanged",
    appNote: "old code untouched",
  },
  {
    step: "Migrate",
    index: "Deploy 2",
    accent: "#f59e0b", // amber — work in flight, scaffolding lives here
    schema: "old + new",
    schemaNote: "both columns filled",
    app: "dual-write + dual-read",
    appNote: "scaffolding added",
  },
  {
    step: "Contract",
    index: "Deploy 3",
    accent: "#38bdf8", // sky — settled, clean
    schema: "new only",
    schemaNote: "old column dropped",
    app: "cleaned up",
    appNote: "scaffolding removed",
  },
];

const panelStyle = (accent: string) =>
  [
    "margin: 0",
    "flex: 1 1 0",
    "min-width: 0",
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 12px",
    "padding: 14px 14px 16px",
    "border-radius: 12px",
    `border: 1px solid color-mix(in srgb, ${accent} 50%, transparent)`,
    `background: color-mix(in srgb, ${accent} 9%, transparent)`,
  ].join("; ");

// The step header: an index eyebrow over the step name, with an accent rule.
const headerStyle = "margin: 0; display: flex; flex-direction: column; gap: 2px;";
const eyebrowStyle =
  "margin: 0; font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.6; line-height: 1.2;";
const stepNameStyle = (accent: string) =>
  `margin: 0; font-size: 17px; font-weight: 700; line-height: 1.15; color: color-mix(in srgb, ${accent} 78%, var(--sl-color-text));`;

// Each state row: a tiny label, the value pill, and a muted note beneath.
const rowStyle = "margin: 0; display: flex; flex-direction: column; gap: 3px;";
const rowLabelStyle =
  "margin: 0; font-size: 10px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; opacity: 0.55; line-height: 1.2;";
const valueStyle =
  "margin: 0; font-family: var(--sl-font-mono, ui-monospace, monospace); font-size: 13px; font-weight: 600; line-height: 1.25;";
const noteStyle = "margin: 0; font-size: 11px; opacity: 0.65; line-height: 1.25;";

// Chevron between panels — reinforces the left-to-right timeline read.
const chevronStyle =
  "margin: 0; flex: 0 0 auto; align-self: center; font-size: 18px; opacity: 0.4; line-height: 1;";
---

<div
  style="margin: 0; display: flex; flex-direction: row; align-items: stretch; gap: 4px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {
    panels.map((p, i) => (
      <>
        <div style={panelStyle(p.accent)}>
          <div style={headerStyle}>
            <div style={eyebrowStyle}>{p.index}</div>
            <div style={stepNameStyle(p.accent)}>{p.step}</div>
          </div>

          <div style={rowStyle}>
            <div style={rowLabelStyle}>Schema</div>
            <div style={valueStyle}>{p.schema}</div>
            <div style={noteStyle}>{p.schemaNote}</div>
          </div>

          <div style={rowStyle}>
            <div style={rowLabelStyle}>App code</div>
            <div style={valueStyle}>{p.app}</div>
            <div style={noteStyle}>{p.appNote}</div>
          </div>
        </div>

        {i < panels.length - 1 && (
          <div style={chevronStyle} aria-hidden="true">
            &rarr;
          </div>
        )}
      </>
    ))
  }
</div>
