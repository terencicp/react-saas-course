---
// Diagram: Temporal runtime support matrix, May 2026.
//
// Three columns: Runtime | Native Temporal | Course's reach.
// Three rows: Node 26+, Node 24 LTS, Browser. Each row gets a status accent
// (green = yes, red = no, amber = partial) driven by the "native" column, so
// the support story reads at a glance — the row color tells you whether the
// course needs a polyfill seam in that environment.
//
// Pedagogical goal: name where Temporal is native, where it isn't, and the
// course's reach for each — the polyfill lives in lib/temporal.ts (Node 24),
// the browser receives server-rendered ISO strings (no client dependency).
//
// Sits inside a <Figure>, which already provides the figure card chrome, so
// no outer wrapper here.

const YES_ACCENT = '#16a34a'; // green-600
const NO_ACCENT = '#dc2626'; // red-600
const PARTIAL_ACCENT = '#f59e0b'; // amber-500

type Status = 'yes' | 'no' | 'partial';

type Row = {
	runtime: string;
	runtimeNote: string;
	status: Status;
	statusLabel: string;
	statusDetail: string;
	reach: string;
};

const rows: Row[] = [
	{
		runtime: 'Node 26+',
		runtimeNote: 'Course deploy target on Vercel',
		status: 'yes',
		statusLabel: 'Yes, native',
		statusDetail: 'Unflagged since May 5, 2026',
		reach: "Direct import — no polyfill.",
	},
	{
		runtime: 'Node 24 LTS',
		runtimeNote: 'Until Node 26 promotes (Oct 2026)',
		status: 'no',
		statusLabel: 'No',
		statusDetail: 'Pre-Temporal runtime',
		reach: 'temporal-polyfill re-exported from lib/temporal.ts',
	},
	{
		runtime: 'Browser',
		runtimeNote: 'Firefox 139+, Chrome 144 (late 2026), Safari pending',
		status: 'partial',
		statusLabel: 'Partial',
		statusDetail: 'Patchy across vendors',
		reach: 'Server-rendered ISO strings — no client-side dependency.',
	},
];

const statusToClass: Record<Status, string> = {
	yes: 'tsm-status-yes',
	no: 'tsm-status-no',
	partial: 'tsm-status-partial',
};

const statusToGlyph: Record<Status, string> = {
	yes: '+',
	no: '-',
	partial: '~',
};
---

<div class="tsm-root">
	<div class="tsm-row tsm-header">
		<div class="tsm-cell tsm-head-cell">Runtime</div>
		<div class="tsm-cell tsm-head-cell">Native Temporal</div>
		<div class="tsm-cell tsm-head-cell">Course's reach</div>
	</div>

	{
		rows.map((r) => (
			<div class={`tsm-row ${statusToClass[r.status]}`}>
				<div class="tsm-cell tsm-runtime" data-label="Runtime">
					<span class="tsm-runtime-name">{r.runtime}</span>
					<span class="tsm-runtime-note">{r.runtimeNote}</span>
				</div>
				<div class="tsm-cell tsm-status" data-label="Native Temporal">
					<span class="tsm-badge" aria-hidden="true">
						<span class="tsm-glyph">{statusToGlyph[r.status]}</span>
						<span class="tsm-badge-label">{r.statusLabel}</span>
					</span>
					<span class="tsm-status-detail">{r.statusDetail}</span>
				</div>
				<div class="tsm-cell tsm-reach" data-label="Course's reach">
					{r.reach}
				</div>
			</div>
		))
	}
</div>

<style
	define:vars={{
		YES_ACCENT,
		NO_ACCENT,
		PARTIAL_ACCENT,
	}}
>
	.tsm-root {
		display: grid;
		grid-template-columns: max-content max-content minmax(0, 1fr);
		row-gap: 1px;
		column-gap: 0;
		padding: 0;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	.tsm-row {
		display: contents;
	}

	.tsm-cell {
		padding: 12px 14px;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
	}

	.tsm-head-cell {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		padding-top: 8px;
		padding-bottom: 8px;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.tsm-runtime-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-text);
		white-space: nowrap;
	}

	.tsm-runtime-note {
		font-size: 11.5px;
		color: var(--sl-color-gray-3);
		line-height: 1.4;
	}

	.tsm-badge {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 3px 8px 3px 5px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: 600;
		width: max-content;
		background: color-mix(in srgb, var(--row-accent) 14%, transparent);
		color: var(--row-accent);
	}

	.tsm-glyph {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 16px;
		height: 16px;
		border-radius: 999px;
		background: var(--row-accent);
		color: #ffffff;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		font-weight: 700;
		line-height: 1;
	}

	.tsm-status-detail {
		font-size: 11.5px;
		color: var(--sl-color-gray-3);
		line-height: 1.4;
	}

	.tsm-reach {
		font-size: 12.5px;
		color: var(--sl-color-text);
	}

	/* Per-row status accents. The CSS variable propagates to every cell in the
	   row (via display: contents on .tsm-row) so badge / glyph / left bar /
	   background tint all share the same color. */
	.tsm-status-yes {
		--row-accent: var(--YES_ACCENT);
	}
	.tsm-status-no {
		--row-accent: var(--NO_ACCENT);
	}
	.tsm-status-partial {
		--row-accent: var(--PARTIAL_ACCENT);
	}

	.tsm-status-yes .tsm-cell,
	.tsm-status-no .tsm-cell,
	.tsm-status-partial .tsm-cell {
		background: color-mix(in srgb, var(--row-accent) 7%, transparent);
	}

	.tsm-status-yes .tsm-runtime,
	.tsm-status-no .tsm-runtime,
	.tsm-status-partial .tsm-runtime {
		border-left: 3px solid color-mix(in srgb, var(--row-accent) 65%, transparent);
	}

	/* Narrow viewport: stack into per-row cards with field labels in front of
	   each cell, matching the sibling diagram in this lesson. */
	@media (max-width: 720px) {
		.tsm-root {
			grid-template-columns: 1fr;
			row-gap: 12px;
		}

		.tsm-row.tsm-header {
			display: none;
		}

		.tsm-row {
			display: block;
			padding: 10px 12px;
			border-radius: 8px;
			margin: 0;
		}

		.tsm-status-yes,
		.tsm-status-no,
		.tsm-status-partial {
			background: color-mix(in srgb, var(--row-accent) 7%, transparent);
			border-left: 3px solid color-mix(in srgb, var(--row-accent) 65%, transparent);
		}

		.tsm-cell {
			background: transparent !important;
			border-left: none !important;
			padding: 4px 0;
			flex-direction: column;
			align-items: flex-start;
			gap: 4px;
		}

		.tsm-cell::before {
			content: attr(data-label);
			font-size: 10.5px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--sl-color-gray-3);
			flex-shrink: 0;
		}

		.tsm-runtime::before {
			display: none;
		}

		.tsm-runtime {
			padding-top: 0;
			padding-bottom: 6px;
		}
	}
</style>
