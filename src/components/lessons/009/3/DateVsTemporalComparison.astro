---
// Diagram: side-by-side comparison of Date vs Temporal for five common
// operations. Two columns; five rows. Left column (red accent) is the old
// Date way and its quirk; right column (green accent) is the Temporal
// equivalent and what fixes the quirk.
//
// Each cell renders one inline code snippet plus a one-line italic note.
// Row alignment is the only thing that pairs the two sides — no arrows.
//
// Lives inside a <TabbedItem>, which already provides figure card chrome,
// so no outer <Figure> wrapper here.

const DATE_ACCENT = '#dc2626'; // red-600
const TEMPORAL_ACCENT = '#16a34a'; // green-600

type Row = {
	dateCode: string;
	dateNote: string;
	temporalCode: string;
	temporalNote: string;
};

const rows: Row[] = [
	{
		dateCode: `new Date('2026-05-15')`,
		dateNote: 'UTC midnight — ambiguous "date".',
		temporalCode: `Temporal.PlainDate.from('2026-05-15')`,
		temporalNote: 'Calendar date — unambiguous.',
	},
	{
		dateCode: `Date.now()`,
		dateNote: 'Milliseconds since the epoch.',
		temporalCode: `Temporal.Now.instant()`,
		temporalNote: 'Nanosecond-precision instant.',
	},
	{
		dateCode: `new Date(d.getTime() + 30 * 86_400_000)`,
		dateNote: 'Raw milliseconds — breaks across DST.',
		temporalCode: `d.add({ days: 30 })`,
		temporalNote: 'Calendar-aware — DST-safe.',
	},
	{
		dateCode: `new Date('garbage')`,
		dateNote: 'Silent Invalid Date sentinel.',
		temporalCode: `Temporal.Instant.from('garbage')`,
		temporalNote: 'Throws RangeError at the parse seam.',
	},
	{
		dateCode: `date.setMonth(5)`,
		dateNote: 'Mutates the caller in place.',
		temporalCode: `date.with({ month: 5 })`,
		temporalNote: 'Returns a new instance.',
	},
];
---

<div class="dvtc-root">
	<div class="dvtc-row dvtc-header">
		<div class="dvtc-cell dvtc-head dvtc-head-date">
			<span class="dvtc-dot dvtc-dot-date" aria-hidden="true"></span>
			<span>Date (the old way)</span>
		</div>
		<div class="dvtc-cell dvtc-head dvtc-head-temporal">
			<span class="dvtc-dot dvtc-dot-temporal" aria-hidden="true"></span>
			<span>Temporal (the 2026 way)</span>
		</div>
	</div>

	{
		rows.map((r) => (
			<div class="dvtc-row">
				<div class="dvtc-cell dvtc-cell-date" data-label="Date (the old way)">
					<code class="dvtc-code">{r.dateCode}</code>
					<span class="dvtc-note">{r.dateNote}</span>
				</div>
				<div
					class="dvtc-cell dvtc-cell-temporal"
					data-label="Temporal (the 2026 way)"
				>
					<code class="dvtc-code">{r.temporalCode}</code>
					<span class="dvtc-note">{r.temporalNote}</span>
				</div>
			</div>
		))
	}
</div>

<style
	define:vars={{
		DATE_ACCENT,
		TEMPORAL_ACCENT,
	}}
>
	.dvtc-root {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		row-gap: 1px;
		column-gap: 0;
		padding: 0;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	.dvtc-row {
		display: contents;
	}

	.dvtc-cell {
		padding: 12px 14px;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 6px;
		justify-content: center;
	}

	.dvtc-head {
		flex-direction: row;
		align-items: center;
		gap: 10px;
		font-size: 11.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		padding-top: 10px;
		padding-bottom: 10px;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.dvtc-head-date {
		border-left: 3px solid color-mix(in srgb, var(--DATE_ACCENT) 65%, transparent);
	}

	.dvtc-head-temporal {
		border-left: 3px solid
			color-mix(in srgb, var(--TEMPORAL_ACCENT) 65%, transparent);
	}

	.dvtc-dot {
		display: inline-block;
		flex-shrink: 0;
		width: 8px;
		height: 8px;
		border-radius: 999px;
		margin: 0;
	}

	.dvtc-dot-date {
		background: var(--DATE_ACCENT);
	}

	.dvtc-dot-temporal {
		background: var(--TEMPORAL_ACCENT);
	}

	.dvtc-cell-date {
		background: color-mix(in srgb, var(--DATE_ACCENT) 7%, transparent);
		border-left: 3px solid color-mix(in srgb, var(--DATE_ACCENT) 65%, transparent);
	}

	.dvtc-cell-temporal {
		background: color-mix(in srgb, var(--TEMPORAL_ACCENT) 7%, transparent);
		border-left: 3px solid
			color-mix(in srgb, var(--TEMPORAL_ACCENT) 65%, transparent);
	}

	.dvtc-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		color: var(--sl-color-text);
		background: transparent;
		padding: 0;
		margin: 0;
		word-break: break-word;
	}

	.dvtc-note {
		font-size: 12px;
		font-style: italic;
		color: var(--sl-color-gray-3);
		line-height: 1.4;
		margin: 0;
	}

	/* Narrow viewport: stack the two columns as a sequence of paired cards. */
	@media (max-width: 720px) {
		.dvtc-root {
			grid-template-columns: 1fr;
			row-gap: 10px;
		}

		.dvtc-row.dvtc-header {
			display: none;
		}

		.dvtc-row {
			display: block;
			margin: 0;
		}

		.dvtc-cell {
			border-radius: 6px;
			margin: 0 0 4px;
		}

		.dvtc-cell::before {
			content: attr(data-label);
			font-size: 10px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: var(--sl-color-gray-3);
			margin: 0 0 2px;
		}
	}
</style>
