---
// Diagram: the Temporal type catalog — five rows, one per type.
//
// Four columns: Type | What it names | Use it for | Postgres column.
// Each row gets its own accent color (left border + tinted background +
// dot next to the type name) so the five-way distinction is visible at a
// glance. Type names render as inline monospace, the rest in prose font.
//
// Pedagogical goal: the student leaves with a one-line idea of each type
// and which storage column it maps to in unit 17. The Postgres column is
// a forward pointer — called out below the table.
//
// Sits inside a <TabbedItem>, which already provides a figure card, so no
// outer <Figure> wrapper here.

const INSTANT_ACCENT = '#3b82f6'; // blue-500
const ZONED_ACCENT = '#a855f7'; // violet-500
const PLAINDATE_ACCENT = '#16a34a'; // green-600
const PLAINDT_ACCENT = '#f59e0b'; // amber-500
const DURATION_ACCENT = '#e11d48'; // rose-600

type Accent = 'instant' | 'zoned' | 'plaindate' | 'plaindt' | 'duration';

type Row = {
	type: string;
	names: string;
	uses: string;
	pg: string;
	accent: Accent;
};

const rows: Row[] = [
	{
		type: 'Temporal.Instant',
		names: 'A UTC moment in real time, nanosecond precision, no timezone.',
		uses: 'Server timestamps: createdAt, lastSeenAt, webhook arrival.',
		pg: 'timestamptz',
		accent: 'instant',
	},
	{
		type: 'Temporal.ZonedDateTime',
		names: 'An Instant paired with an IANA timezone, DST-aware.',
		uses: 'Wall-clock display, recurring schedules: "every Monday 9 AM in the user\'s tz".',
		pg: 'Derived, not stored',
		accent: 'zoned',
	},
	{
		type: 'Temporal.PlainDate',
		names: 'A calendar date — year, month, day — with no time and no tz.',
		uses: 'dueDate, birthDate, anniversaries; "May 15" semantics.',
		pg: 'date',
		accent: 'plaindate',
	},
	{
		type: 'Temporal.PlainDateTime',
		names: 'A wall-clock date and time with no timezone commitment.',
		uses: 'Rare. "5 PM local" without specifying which local. Most domain code does not need it.',
		pg: 'Rarely stored',
		accent: 'plaindt',
	},
	{
		type: 'Temporal.Duration',
		names: 'An explicit span: years, months, weeks, days, hours, minutes, seconds, and sub-second units down to nanoseconds.',
		uses: '"30 days", "1 month", "2 hours" — never as raw milliseconds.',
		pg: 'Not stored; computed',
		accent: 'duration',
	},
];
---

<div class="ttt-root">
	<div class="ttt-row ttt-header">
		<div class="ttt-cell ttt-head-cell">Type</div>
		<div class="ttt-cell ttt-head-cell">What it names</div>
		<div class="ttt-cell ttt-head-cell">Use it for</div>
		<div class="ttt-cell ttt-head-cell">Postgres column</div>
	</div>

	{
		rows.map((r) => (
			<div class={`ttt-row ttt-accent-${r.accent}`}>
				<div class="ttt-cell ttt-type" data-label="Type">
					<span class="ttt-dot" aria-hidden="true" />
					<span class="ttt-mono">{r.type}</span>
				</div>
				<div class="ttt-cell ttt-names" data-label="What it names">
					{r.names}
				</div>
				<div class="ttt-cell ttt-uses" data-label="Use it for">
					{r.uses}
				</div>
				<div class="ttt-cell ttt-pg" data-label="Postgres column">
					<span class="ttt-mono-pg">{r.pg}</span>
				</div>
			</div>
		))
	}
</div>

<p class="ttt-note">
	The Postgres column on the right is a forward pointer to unit 17. For now,
	focus on the leftmost three columns.
</p>

<style
	define:vars={{
		INSTANT_ACCENT,
		ZONED_ACCENT,
		PLAINDATE_ACCENT,
		PLAINDT_ACCENT,
		DURATION_ACCENT,
	}}
>
	.ttt-root {
		display: grid;
		grid-template-columns: max-content minmax(0, 1.4fr) minmax(0, 1.4fr) max-content;
		row-gap: 1px;
		column-gap: 0;
		padding: 0;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	.ttt-row {
		display: contents;
	}

	.ttt-cell {
		padding: 10px 14px;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.ttt-head-cell {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		padding-top: 8px;
		padding-bottom: 8px;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.ttt-type {
		flex-direction: row;
		align-items: center;
		gap: 10px;
	}

	.ttt-dot {
		display: inline-block;
		flex-shrink: 0;
		width: 8px;
		height: 8px;
		border-radius: 999px;
		background: currentColor;
		margin: 0;
	}

	.ttt-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		color: var(--sl-color-text);
		white-space: nowrap;
		margin: 0;
	}

	.ttt-mono-pg {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		color: var(--sl-color-text);
		white-space: nowrap;
		margin: 0;
	}

	/* Per-row accent: dot color + tinted background + left bar on the first cell. */
	.ttt-accent-instant .ttt-dot {
		color: var(--INSTANT_ACCENT);
	}
	.ttt-accent-zoned .ttt-dot {
		color: var(--ZONED_ACCENT);
	}
	.ttt-accent-plaindate .ttt-dot {
		color: var(--PLAINDATE_ACCENT);
	}
	.ttt-accent-plaindt .ttt-dot {
		color: var(--PLAINDT_ACCENT);
	}
	.ttt-accent-duration .ttt-dot {
		color: var(--DURATION_ACCENT);
	}

	.ttt-accent-instant .ttt-cell {
		background: color-mix(in srgb, var(--INSTANT_ACCENT) 7%, transparent);
	}
	.ttt-accent-zoned .ttt-cell {
		background: color-mix(in srgb, var(--ZONED_ACCENT) 7%, transparent);
	}
	.ttt-accent-plaindate .ttt-cell {
		background: color-mix(in srgb, var(--PLAINDATE_ACCENT) 7%, transparent);
	}
	.ttt-accent-plaindt .ttt-cell {
		background: color-mix(in srgb, var(--PLAINDT_ACCENT) 7%, transparent);
	}
	.ttt-accent-duration .ttt-cell {
		background: color-mix(in srgb, var(--DURATION_ACCENT) 7%, transparent);
	}

	.ttt-accent-instant .ttt-type {
		border-left: 3px solid color-mix(in srgb, var(--INSTANT_ACCENT) 65%, transparent);
	}
	.ttt-accent-zoned .ttt-type {
		border-left: 3px solid color-mix(in srgb, var(--ZONED_ACCENT) 65%, transparent);
	}
	.ttt-accent-plaindate .ttt-type {
		border-left: 3px solid color-mix(in srgb, var(--PLAINDATE_ACCENT) 65%, transparent);
	}
	.ttt-accent-plaindt .ttt-type {
		border-left: 3px solid color-mix(in srgb, var(--PLAINDT_ACCENT) 65%, transparent);
	}
	.ttt-accent-duration .ttt-type {
		border-left: 3px solid color-mix(in srgb, var(--DURATION_ACCENT) 65%, transparent);
	}

	.ttt-note {
		margin: 14px 4px 0;
		font-size: 12px;
		font-style: italic;
		color: var(--sl-color-gray-3);
		line-height: 1.5;
	}

	/* Narrow viewport: collapse to a stacked card layout, one row per type. */
	@media (max-width: 720px) {
		.ttt-root {
			grid-template-columns: 1fr;
			row-gap: 12px;
		}

		.ttt-row.ttt-header {
			display: none;
		}

		.ttt-row {
			display: block;
			padding: 10px 12px;
			border-radius: 8px;
			margin: 0;
		}

		.ttt-accent-instant {
			background: color-mix(in srgb, var(--INSTANT_ACCENT) 7%, transparent);
			border-left: 3px solid color-mix(in srgb, var(--INSTANT_ACCENT) 65%, transparent);
		}
		.ttt-accent-zoned {
			background: color-mix(in srgb, var(--ZONED_ACCENT) 7%, transparent);
			border-left: 3px solid color-mix(in srgb, var(--ZONED_ACCENT) 65%, transparent);
		}
		.ttt-accent-plaindate {
			background: color-mix(in srgb, var(--PLAINDATE_ACCENT) 7%, transparent);
			border-left: 3px solid color-mix(in srgb, var(--PLAINDATE_ACCENT) 65%, transparent);
		}
		.ttt-accent-plaindt {
			background: color-mix(in srgb, var(--PLAINDT_ACCENT) 7%, transparent);
			border-left: 3px solid color-mix(in srgb, var(--PLAINDT_ACCENT) 65%, transparent);
		}
		.ttt-accent-duration {
			background: color-mix(in srgb, var(--DURATION_ACCENT) 7%, transparent);
			border-left: 3px solid color-mix(in srgb, var(--DURATION_ACCENT) 65%, transparent);
		}

		.ttt-cell {
			background: transparent !important;
			border-left: none !important;
			padding: 4px 0;
			flex-direction: row;
			align-items: baseline;
			gap: 6px;
		}

		.ttt-cell::before {
			content: attr(data-label) ' — ';
			font-size: 10.5px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--sl-color-gray-3);
			flex-shrink: 0;
		}

		.ttt-type::before {
			display: none;
		}

		.ttt-type {
			padding-top: 0;
			padding-bottom: 4px;
		}

		.ttt-mono {
			white-space: normal;
		}
	}
</style>
