---
// Diagram: four wire sites converging on one JSON codec.
//
// Layout: three columns inside the figure.
//   - Left column: two stacked outer boxes (Server Action body, Webhook POST)
//     with a right-pointing arrow at their inner edge.
//   - Center: the codec pill (JSON.parse / JSON.stringify) with a faint accent
//     border, slightly emphasized vs. the outer boxes.
//   - Right column: two stacked outer boxes (Route handler response,
//     localStorage round-trip) with a left-pointing arrow at their inner edge.
//
// Pedagogical goal: the four sites share the codec; whatever direction the
// bytes flow, they all pass through the same two functions. No directional
// asymmetry between in / out — every arrow points toward the codec to convey
// convergence.
//
// Compact: targets ~200px tall at desktop widths. Falls back to a single
// column with the codec sandwiched between the two halves under ~640px.

type Site = {
	label: string;
	note: string;
};

const leftSites: Site[] = [
	{
		label: 'Server Action body',
		note: 'request comes in as JSON',
	},
	{
		label: 'Webhook POST',
		note: 'third party sends JSON to your route handler',
	},
];

const rightSites: Site[] = [
	{
		label: 'Route handler response',
		note: 'response goes out as JSON',
	},
	{
		label: 'localStorage round-trip',
		note: 'browser-side persistence; string in, string out',
	},
];
---

<div class="fd-root">
	<div class="fd-col fd-col-left">
		{
			leftSites.map((site) => (
				<div class="fd-site">
					<div class="fd-site-body">
						<div class="fd-site-label">{site.label}</div>
						<div class="fd-site-note">{site.note}</div>
					</div>
					<div class="fd-arrow fd-arrow-right" aria-hidden="true">
						&rarr;
					</div>
				</div>
			))
		}
	</div>

	<div class="fd-codec">
		<div class="fd-codec-title">JSON.parse</div>
		<div class="fd-codec-title">JSON.stringify</div>
		<div class="fd-codec-sub">one codec</div>
	</div>

	<div class="fd-col fd-col-right">
		{
			rightSites.map((site) => (
				<div class="fd-site">
					<div class="fd-arrow fd-arrow-left" aria-hidden="true">
						&larr;
					</div>
					<div class="fd-site-body">
						<div class="fd-site-label">{site.label}</div>
						<div class="fd-site-note">{site.note}</div>
					</div>
				</div>
			))
		}
	</div>
</div>

<style>
	.fd-root {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 12px;
		padding: 8px 4px;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	.fd-col {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
		min-width: 0;
	}

	.fd-site {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 0;
	}

	.fd-col-left .fd-site {
		flex-direction: row;
	}

	.fd-col-right .fd-site {
		flex-direction: row;
	}

	.fd-site-body {
		flex: 1;
		min-width: 0;
		padding: 10px 12px;
		border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
		border-radius: 8px;
		background: color-mix(in srgb, currentColor 3%, transparent);
		margin: 0;
	}

	.fd-site-label {
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-text);
		margin: 0;
		line-height: 1.3;
	}

	.fd-site-note {
		font-size: 11.5px;
		color: var(--sl-color-gray-3);
		margin: 3px 0 0;
		line-height: 1.35;
	}

	.fd-arrow {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 20px;
		line-height: 1;
		color: color-mix(in srgb, currentColor 55%, transparent);
		flex: 0 0 auto;
		margin: 0;
	}

	.fd-codec {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		padding: 14px 18px;
		border: 1.5px solid var(--sl-color-accent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
		margin: 0;
		min-width: 0;
	}

	.fd-codec-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		font-weight: 600;
		color: var(--sl-color-text);
		margin: 0;
		line-height: 1.35;
		white-space: nowrap;
	}

	.fd-codec-sub {
		font-size: 10.5px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3);
		margin: 4px 0 0;
	}

	/* Responsive: stack the three columns vertically under ~640px.
	   The codec sits between the two halves. */
	@media (max-width: 640px) {
		.fd-root {
			grid-template-columns: 1fr;
			gap: 10px;
		}

		.fd-codec {
			border-radius: 12px;
			padding: 12px 16px;
		}

		.fd-arrow-right,
		.fd-arrow-left {
			display: none;
		}

		.fd-site {
			border-left: 2px solid color-mix(in srgb, var(--sl-color-accent) 35%, transparent);
			padding-left: 10px;
		}
	}
</style>
