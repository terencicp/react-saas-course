---
// A faithful hand-authored mock of a *paused* VS Code debug session — no real
// screenshot is available, so this synthetic chrome stands in for the live
// window the BreakpointHitReveal sequence above models. It shows the whole
// layout at once: Variables + Call Stack docked left, the editor with a red
// gutter breakpoint and the paused line highlighted, and the Debug Console
// across the bottom. The scenario matches the rest of the lesson: a closure
// captured the wrong tenant scope, so a valid input fails the org check.
import Figure from '../../../figures/Figure.astro';

// The mocked helper source, rendered line by line so we can paint the gutter
// dot and the paused-line highlight on the exact line the breakpoint sits on.
const codeLines = [
	{ n: 1, text: 'export function belongsToOrg(', tone: 'kw' },
	{ n: 2, text: '  input: { orgId: string },' },
	{ n: 3, text: ') {' },
	{ n: 4, text: '  if (input.orgId === scopedOrgId) {' },
	{ n: 5, text: '    return true;' },
	{ n: 6, text: '  }' },
	{ n: 7, text: '  return false;' },
	{ n: 8, text: '}' },
];
const BP_LINE = 7;
---

<Figure caption="The real VS Code debug layout — gutter breakpoint, paused line, Variables and Call Stack on the left, Debug Console below. This is the live window the synthetic diagram above models.">
	<div class="vps-win" role="img" aria-label="A paused VS Code debug session. The lib/authz.ts file is open with a red breakpoint dot on the `return false;` line, which is highlighted because execution is paused on it. The left sidebar shows a Variables panel (Local scope: input with orgId 'org_customerA'; Closure scope: scopedOrgId 'org_customerB') and a Call Stack panel (belongsToOrg, then createInvoice, then the server action runner). The Debug Console at the bottom evaluates the mismatch as false.">
		<!-- Title bar with debug-toolbar controls -->
		<div class="vps-titlebar">
			<span class="vps-dot vps-dot-r"></span>
			<span class="vps-dot vps-dot-y"></span>
			<span class="vps-dot vps-dot-g"></span>
			<span class="vps-title">lib/authz.ts — react-saas</span>
			<span class="vps-toolbar">
				<span class="vps-tool vps-tool-paused" title="Paused">⏸</span>
				<span class="vps-tool" title="Continue (F5)">▶</span>
				<span class="vps-tool" title="Step over (F10)">⤵</span>
				<span class="vps-tool" title="Step into (F11)">↧</span>
				<span class="vps-tool" title="Step out (⇧F11)">↥</span>
				<span class="vps-tool vps-tool-stop" title="Stop (⇧F5)">■</span>
			</span>
		</div>

		<div class="vps-body">
			<!-- Left sidebar: Variables + Call Stack -->
			<div class="vps-side">
				<div class="vps-panel-head">VARIABLES</div>
				<div class="vps-tree">
					<div class="vps-scope">▾ Local</div>
					<div class="vps-row">
						<span class="vps-twist">▾</span>
						<span class="vps-key">input</span>: <span class="vps-obj">{'{orgId: …}'}</span>
					</div>
					<div class="vps-row vps-indent">
						<span class="vps-key">orgId</span>:
						<span class="vps-str vps-val-a">"org_customerA"</span>
					</div>
					<div class="vps-scope">▾ Closure</div>
					<div class="vps-row">
						<span class="vps-key">scopedOrgId</span>:
						<span class="vps-str vps-val-b">"org_customerB"</span>
					</div>
					<div class="vps-scope vps-scope-muted">▸ Global</div>
				</div>

				<div class="vps-panel-head vps-panel-head-2">CALL STACK</div>
				<div class="vps-stack">
					<div class="vps-frame vps-frame-active">
						<span class="vps-frame-fn">belongsToOrg</span>
						<span class="vps-frame-loc">authz.ts 7:3</span>
					</div>
					<div class="vps-frame">
						<span class="vps-frame-fn">createInvoice</span>
						<span class="vps-frame-loc">invoices.ts 42:9</span>
					</div>
					<div class="vps-frame">
						<span class="vps-frame-fn">authedAction</span>
						<span class="vps-frame-loc">safe-action.ts 31:7</span>
					</div>
					<div class="vps-frame vps-frame-skipped">
						<span class="vps-frame-fn">&lt;node_internals&gt;</span>
						<span class="vps-frame-loc">skipped</span>
					</div>
				</div>
			</div>

			<!-- Editor -->
			<div class="vps-editor">
				<div class="vps-tabbar">
					<span class="vps-tab vps-tab-active">authz.ts</span>
					<span class="vps-tab">invoices.ts</span>
				</div>
				<div class="vps-code">
					{
						codeLines.map((l) => (
							<div class:list={['vps-line', l.n === BP_LINE && 'is-paused']}>
								<span class="vps-gutter">
									{l.n === BP_LINE && <span class="vps-bp" />}
									<span class="vps-ln">{l.n}</span>
								</span>
								<code class="vps-src">{l.text}</code>
							</div>
						))
					}
				</div>
			</div>
		</div>

		<!-- Debug Console docked at the bottom -->
		<div class="vps-console">
			<div class="vps-panel-head vps-panel-head-2">DEBUG CONSOLE</div>
			<div class="vps-repl">
				<div class="vps-repl-line">
					<span class="vps-prompt">&gt;</span> <code class="vps-in">input.orgId === scopedOrgId</code>
				</div>
				<div class="vps-repl-out vps-false">false</div>
				<div class="vps-repl-prompt">
					<span class="vps-prompt">&gt;</span> <span class="vps-caret"></span>
				</div>
			</div>
		</div>
	</div>
</Figure>

<style>
	.vps-win {
		max-width: 46rem;
		margin: 0 auto;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.55rem;
		overflow: hidden;
		background: var(--sl-color-bg);
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
		box-shadow: 0 1px 0 var(--sl-color-hairline);
	}

	/* ── Title bar ─────────────────────────────────────────────────── */
	.vps-titlebar {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.35rem 0.7rem;
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-hairline);
		font-size: 0.74rem;
	}

	.vps-dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		flex: none;
	}
	.vps-dot-r {
		background: #ef5350;
	}
	.vps-dot-y {
		background: #f5b740;
	}
	.vps-dot-g {
		background: #4caf50;
	}

	.vps-title {
		margin-left: 0.4rem;
		color: var(--sl-color-gray-2);
		font-weight: 600;
	}

	.vps-toolbar {
		margin-left: auto;
		display: flex;
		align-items: center;
		gap: 0.45rem;
	}

	.vps-tool {
		color: var(--sl-color-gray-3);
		font-size: 0.72rem;
		line-height: 1;
	}
	.vps-tool-paused {
		color: #f59e0b;
	}
	.vps-tool-stop {
		color: #ef5350;
		font-size: 0.6rem;
	}

	/* ── Body: sidebar + editor ────────────────────────────────────── */
	.vps-body {
		display: grid;
		grid-template-columns: 13.5rem 1fr;
	}

	.vps-side {
		border-right: 1px solid var(--sl-color-hairline);
		background: color-mix(in srgb, var(--sl-color-bg-sidebar) 60%, var(--sl-color-bg));
		min-width: 0;
		overflow: hidden;
	}

	.vps-panel-head {
		padding: 0.35rem 0.7rem;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		color: var(--sl-color-gray-3);
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-hairline);
	}
	.vps-panel-head-2 {
		border-top: 1px solid var(--sl-color-hairline);
	}

	.vps-tree {
		padding: 0.4rem 0.6rem 0.55rem;
		font-size: 0.74rem;
		line-height: 1.65;
	}

	.vps-scope {
		color: var(--sl-color-gray-2);
		font-weight: 700;
		font-size: 0.68rem;
		letter-spacing: 0.02em;
		margin-top: 0.25rem;
	}
	.vps-scope:first-child {
		margin-top: 0;
	}
	.vps-scope-muted {
		color: var(--sl-color-gray-4);
		font-weight: 600;
	}

	.vps-row {
		color: var(--sl-color-gray-1);
		white-space: nowrap;
	}
	.vps-indent {
		padding-left: 1rem;
	}

	.vps-twist {
		color: var(--sl-color-gray-4);
		font-size: 0.6rem;
		margin-right: 0.15rem;
	}

	.vps-key {
		color: #7dd3fc;
	}
	.vps-obj {
		color: var(--sl-color-gray-3);
	}
	.vps-str {
		font-weight: 600;
	}
	/* The two tenant values, tinted so the mismatch reads at a glance. */
	.vps-val-a {
		color: #4ade80;
	}
	.vps-val-b {
		color: #fb923c;
	}

	/* ── Call stack ────────────────────────────────────────────────── */
	.vps-stack {
		padding: 0.3rem 0;
		font-size: 0.72rem;
	}
	.vps-frame {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.13rem 0.7rem;
		color: var(--sl-color-gray-2);
	}
	.vps-frame-active {
		background: color-mix(in srgb, #f59e0b 16%, transparent);
		border-left: 2px solid #f59e0b;
		padding-left: calc(0.7rem - 2px);
	}
	.vps-frame-active .vps-frame-fn {
		color: var(--sl-color-white);
		font-weight: 600;
	}
	.vps-frame-loc {
		color: var(--sl-color-gray-4);
		font-size: 0.64rem;
		flex: none;
	}
	.vps-frame-skipped {
		color: var(--sl-color-gray-4);
		font-style: italic;
		opacity: 0.7;
	}

	/* ── Editor ────────────────────────────────────────────────────── */
	.vps-editor {
		min-width: 0;
		overflow: hidden;
	}
	.vps-tabbar {
		display: flex;
		gap: 0;
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-hairline);
		font-size: 0.72rem;
	}
	.vps-tab {
		padding: 0.35rem 0.8rem;
		color: var(--sl-color-gray-3);
		border-right: 1px solid var(--sl-color-hairline);
	}
	.vps-tab-active {
		color: var(--sl-color-white);
		background: var(--sl-color-bg);
		border-bottom: 1px solid var(--sl-color-bg);
		margin-bottom: -1px;
		font-weight: 600;
	}

	.vps-code {
		padding: 0.4rem 0 0.5rem;
		font-size: 0.8rem;
		line-height: 1.7;
	}

	.vps-line {
		display: flex;
		align-items: center;
	}
	.vps-line.is-paused {
		background: color-mix(in srgb, #f59e0b 15%, transparent);
		box-shadow: inset 2px 0 0 #f59e0b;
	}

	.vps-gutter {
		position: relative;
		flex: none;
		width: 2.8rem;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		padding-right: 0.6rem;
		color: var(--sl-color-gray-4);
		font-size: 0.72rem;
	}
	.vps-ln {
		min-width: 1ch;
		text-align: right;
	}
	.vps-bp {
		position: absolute;
		left: 0.55rem;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: #e5484d;
	}

	.vps-src {
		background: none;
		padding: 0;
		white-space: pre;
		color: var(--sl-color-white);
	}

	/* ── Debug Console ─────────────────────────────────────────────── */
	.vps-console {
		border-top: 1px solid var(--sl-color-hairline);
	}
	.vps-repl {
		padding: 0.45rem 0.7rem 0.55rem;
		font-size: 0.78rem;
		line-height: 1.7;
	}
	.vps-repl-line {
		color: var(--sl-color-white);
	}
	.vps-prompt {
		color: var(--sl-color-gray-4);
		user-select: none;
		margin-right: 0.25rem;
	}
	.vps-in {
		background: none;
		padding: 0;
		color: var(--sl-color-white);
	}
	.vps-repl-out {
		padding-left: 1rem;
	}
	.vps-false {
		color: #f87171;
		font-weight: 700;
		padding-left: 1rem;
	}
	.vps-repl-prompt {
		display: flex;
		align-items: center;
		margin-top: 0.1rem;
	}
	.vps-caret {
		display: inline-block;
		width: 1px;
		height: 0.9rem;
		background: var(--sl-color-text-accent, #7dd3fc);
		animation: vps-blink 1.1s step-end infinite;
	}
	@keyframes vps-blink {
		50% {
			opacity: 0;
		}
	}

	/* ── Narrow viewports: stack sidebar above editor ──────────────── */
	@media (max-width: 560px) {
		.vps-body {
			grid-template-columns: 1fr;
		}
		.vps-side {
			border-right: none;
			border-bottom: 1px solid var(--sl-color-hairline);
		}
		.vps-code,
		.vps-tree,
		.vps-stack,
		.vps-repl {
			font-size: 0.7rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.vps-caret {
			animation: none;
		}
	}
</style>
