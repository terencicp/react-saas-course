---
// "One server, many clients" — the Node inspector lives in the runtime;
// editors are just CDP clients that attach to it.
import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const arrows = [
	{
		from: 'ic-vscode',
		to: 'ic-srv-head',
		label: 'attach',
		color: '#0ea5e9',
		startSocket: 'left',
		endSocket: 'right',
		startSocketGravity: [-70, 0],
		endSocketGravity: [80, -30],
		labelOffset: [0, -12],
	},
	{
		from: 'ic-chrome',
		to: 'ic-srv-port',
		label: 'attach',
		color: '#0ea5e9',
		startSocket: 'left',
		endSocket: 'right',
		startSocketGravity: [-70, 0],
		endSocketGravity: [70, 0],
		labelOffset: [0, -12],
	},
	{
		from: 'ic-webstorm',
		to: 'ic-srv-port',
		label: 'attach',
		color: '#0ea5e9',
		startSocket: 'left',
		endSocket: 'right',
		startSocketGravity: [-70, 0],
		endSocketGravity: [80, 40],
		labelOffset: [0, 12],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="ic-stage">
			<div class="ic-server">
				<div class="ic-srv-head" id="ic-srv-head">
					<span class="ic-srv-glyph">▲</span>
					<code>node --inspect</code>
				</div>
				<div class="ic-srv-sub">your server process</div>
				<div class="ic-srv-port" id="ic-srv-port">
					<span class="ic-srv-dot"></span>
					<code>:9229</code> — CDP over WebSocket
				</div>
			</div>

			<div class="ic-clients">
				<div class="ic-client" id="ic-vscode">VS Code</div>
				<div class="ic-client" id="ic-chrome">Chrome DevTools</div>
				<div class="ic-client" id="ic-webstorm">WebStorm</div>
			</div>
		</div>
	</ArrowDiagram>
</Figure>

<style>
	.ic-stage {
		display: grid;
		grid-template-columns: 1fr 130px 1fr;
		align-items: center;
		gap: 0;
		padding: 0.4rem 0;
		color: var(--sl-color-white);
	}

	/* The single runtime box on the left. */
	.ic-server {
		grid-column: 1;
		justify-self: start;
		max-width: 18rem;
		border: 1px solid color-mix(in srgb, #0ea5e9 55%, var(--sl-color-gray-5));
		border-radius: 0.6rem;
		background: color-mix(in srgb, #0ea5e9 10%, var(--sl-color-bg));
		padding: 0.7rem 0.85rem;
	}

	.ic-srv-head {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		font-weight: 600;
	}

	.ic-srv-head code {
		background: none;
		font-size: 0.95rem;
		padding: 0;
	}

	.ic-srv-glyph {
		color: #0ea5e9;
		font-size: 0.8rem;
		line-height: 1;
	}

	.ic-srv-sub {
		font-size: 0.78rem;
		color: var(--sl-color-gray-3);
		margin: 0.15rem 0 0.55rem;
	}

	.ic-srv-port {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.78rem;
		color: var(--sl-color-gray-2);
		border-top: 1px dashed color-mix(in srgb, #0ea5e9 35%, var(--sl-color-gray-5));
		padding-top: 0.5rem;
	}

	.ic-srv-port code {
		background: none;
		padding: 0;
		color: #0ea5e9;
		font-weight: 600;
		font-size: 0.82rem;
	}

	.ic-srv-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #0ea5e9;
		box-shadow: 0 0 0 3px color-mix(in srgb, #0ea5e9 25%, transparent);
		flex: none;
	}

	/* The vertical stack of clients on the right. */
	.ic-clients {
		grid-column: 3;
		justify-self: end;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		width: 11rem;
	}

	.ic-client {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		background: var(--sl-color-bg);
		padding: 0.55rem 0.8rem;
		font-weight: 600;
		font-size: 0.9rem;
		text-align: center;
	}

	/* When the columns collapse, the curved arrows still read top-to-bottom. */
	@media (max-width: 520px) {
		.ic-stage {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			justify-items: center;
		}
		.ic-server,
		.ic-clients {
			grid-column: 1;
			justify-self: center;
		}
	}
</style>
