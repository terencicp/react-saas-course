---
// The chapter's thesis as a one-glance figure: three surfaces, three questions,
// one incident. You only descend (move right) when the surface to the left runs out.
import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const arrows = [
	{
		from: 'tsr-sentry',
		to: 'tsr-logs',
		label: 'then',
		color: '#0ea5e9',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
		labelOffset: [0, -14],
	},
	{
		from: 'tsr-logs',
		to: 'tsr-debugger',
		label: 'then',
		color: '#0ea5e9',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
		labelOffset: [0, -14],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="tsr-stage">
			<div class="tsr-card" id="tsr-sentry">
				<div class="tsr-surface">Sentry</div>
				<div class="tsr-question">what threw</div>
				<div class="tsr-detail">the rebound stack trace, the failing line</div>
			</div>

			<div class="tsr-card" id="tsr-logs">
				<div class="tsr-surface">Logs <span class="tsr-surface-sub">(the drain)</span></div>
				<div class="tsr-question">what happened</div>
				<div class="tsr-detail">the per-request narrative, by <code>requestId</code></div>
			</div>

			<div class="tsr-card" id="tsr-debugger">
				<div class="tsr-surface">Debugger</div>
				<div class="tsr-question">what's in scope right now</div>
				<div class="tsr-detail">the live locals, closure, and call stack</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		Three surfaces, three questions, one incident — and you only move right when the surface to the left runs out of answers.
	</Fragment>
</Figure>

<style>
	.tsr-stage {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		align-items: stretch;
		column-gap: 64px;
		padding: 0.4rem 0;
		color: var(--sl-color-white);
	}

	.tsr-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		gap: 0.3rem;
		border: 1px solid color-mix(in srgb, #0ea5e9 45%, var(--sl-color-gray-5));
		border-radius: 0.7rem;
		background: color-mix(in srgb, #0ea5e9 8%, var(--sl-color-bg));
		padding: 0.85rem 0.95rem;
		text-align: center;
	}

	.tsr-surface {
		font-weight: 700;
		font-size: 1.05rem;
		line-height: 1.2;
	}

	.tsr-surface-sub {
		font-weight: 500;
		font-size: 0.8rem;
		color: var(--sl-color-gray-3);
	}

	.tsr-question {
		font-weight: 600;
		font-size: 0.92rem;
		color: #0ea5e9;
		font-style: italic;
	}

	.tsr-detail {
		font-size: 0.78rem;
		line-height: 1.35;
		color: var(--sl-color-gray-2);
		margin-top: 0.1rem;
	}

	.tsr-detail code {
		background: none;
		padding: 0;
		font-size: 0.78rem;
		color: #0ea5e9;
	}

	/* When the row collapses, the arrows still read top-to-bottom. */
	@media (max-width: 640px) {
		.tsr-stage {
			grid-template-columns: 1fr;
			column-gap: 0;
			row-gap: 2.5rem;
			justify-items: center;
		}
		.tsr-card {
			max-width: 22rem;
		}
	}
</style>
