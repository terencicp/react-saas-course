---
// "The breakpoint hit, scrubbed step by step." Synthetic VS Code chrome
// (no real screenshot) modeling a breakpoint on a failing validation
// predicate: the closure captured the wrong tenant scope, so a genuinely
// valid input fails the org check. The Variables panel / Debug Console
// reveal the value no log line carried.
import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// The mocked helper source, rendered line by line so we can paint the
// gutter dot, the paused-line highlight, and the resume marker per step.
const codeLines = [
	{ n: 1, text: 'export function belongsToOrg(' },
	{ n: 2, text: '  input: { orgId: string },' },
	{ n: 3, text: ') {' },
	{ n: 4, text: '  if (input.orgId === scopedOrgId) {' },
	{ n: 5, text: '    return true;' },
	{ n: 6, text: '  }' },
	{ n: 7, text: '  return false;' },
	{ n: 8, text: '}' },
];
const BP_LINE = 7;
---

<DiagramSequence>
	{/* Step 1 — breakpoint set on the return false line. */}
	<DiagramStep caption="A breakpoint set on the predicate's `return false` line — the line the Sentry stack trace pointed at.">
		<div class="bhr-win">
			<div class="bhr-titlebar">
				<span class="bhr-tab">lib/authz.ts</span>
			</div>
			<div class="bhr-code">
				{codeLines.map((l) => (
					<div class:list={['bhr-row', l.n === BP_LINE && 'is-bp']}>
						<span class="bhr-gutter">
							{l.n === BP_LINE && <span class="bhr-dot" />}
							<span class="bhr-ln">{l.n}</span>
						</span>
						<code class="bhr-src">{l.text}</code>
					</div>
				))}
			</div>
		</div>
	</DiagramStep>

	{/* Step 2 — execution paused on that line. */}
	<DiagramStep caption="Replay the same input from the log line. Execution pauses exactly here.">
		<div class="bhr-win">
			<div class="bhr-titlebar">
				<span class="bhr-tab">lib/authz.ts</span>
				<span class="bhr-paused">⏸ Paused on breakpoint</span>
			</div>
			<div class="bhr-code">
				{codeLines.map((l) => (
					<div
						class:list={[
							'bhr-row',
							l.n === BP_LINE && 'is-bp',
							l.n === BP_LINE && 'is-active',
						]}
					>
						<span class="bhr-gutter">
							{l.n === BP_LINE && <span class="bhr-dot" />}
							{l.n === BP_LINE && <span class="bhr-arrow">▶</span>}
							<span class="bhr-ln">{l.n}</span>
						</span>
						<code class="bhr-src">{l.text}</code>
					</div>
				))}
			</div>
		</div>
	</DiagramStep>

	{/* Step 3 — the Variables panel, mismatch made obvious. */}
	<DiagramStep caption="The Variables panel shows the predicate comparing the input's org against a closure-captured scope — and the captured `orgId` is the wrong tenant.">
		<div class="bhr-panel">
			<div class="bhr-panel-head">VARIABLES</div>
			<div class="bhr-tree">
				<div class="bhr-scope">Local</div>
				<div class="bhr-var">
					<span class="bhr-key">input</span>: <span class="bhr-obj">{'{orgId: …}'}</span>
				</div>
				<div class="bhr-var bhr-indent">
					<span class="bhr-key">orgId</span>:
					<span class="bhr-val bhr-val-a">"org_customerA"</span>
				</div>
				<div class="bhr-scope">Closure</div>
				<div class="bhr-var">
					<span class="bhr-key">scopedOrgId</span>:
					<span class="bhr-val bhr-val-b">"org_customerB"</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* Step 4 — confirm in the Debug Console. */}
	<DiagramStep caption="Confirm it in the Debug Console. The values don't match — a fact no log line carried, because nobody thought to log the closure's scope.">
		<div class="bhr-panel">
			<div class="bhr-panel-head">DEBUG CONSOLE</div>
			<div class="bhr-repl">
				<div class="bhr-line">
					<span class="bhr-prompt">&gt;</span> <code class="bhr-in">input.orgId</code>
				</div>
				<div class="bhr-out bhr-val-a">"org_customerA"</div>
				<div class="bhr-line">
					<span class="bhr-prompt">&gt;</span> <code class="bhr-in">scopedOrgId</code>
				</div>
				<div class="bhr-out bhr-val-b">"org_customerB"</div>
				<div class="bhr-line">
					<span class="bhr-prompt">&gt;</span> <code class="bhr-in">input.orgId === scopedOrgId</code>
				</div>
				<div class="bhr-out bhr-false">false</div>
			</div>
		</div>
	</DiagramStep>

	{/* Step 5 — resume, the bug understood. */}
	<DiagramStep caption="Resume. You've found the why in seconds — now the fix is one line, and the durable artifact is the regression test that locks it in.">
		<div class="bhr-win">
			<div class="bhr-titlebar">
				<span class="bhr-tab">lib/authz.ts</span>
				<span class="bhr-resume">▶ Continue (F5)</span>
			</div>
			<div class="bhr-code">
				{codeLines.map((l) => (
					<div class:list={['bhr-row', l.n === BP_LINE && 'is-bp']}>
						<span class="bhr-gutter">
							{l.n === BP_LINE && <span class="bhr-dot" />}
							<span class="bhr-ln">{l.n}</span>
						</span>
						<code class="bhr-src">{l.text}</code>
					</div>
				))}
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>

<style>
	/* ── Editor window chrome ─────────────────────────────────────── */
	.bhr-win,
	.bhr-panel {
		max-width: 40rem;
		margin: 0 auto;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		overflow: hidden;
		background: var(--sl-color-bg);
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
	}

	.bhr-titlebar {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.3rem 0.6rem;
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-hairline);
		font-size: 0.78rem;
	}

	.bhr-tab {
		color: var(--sl-color-gray-2);
		font-weight: 600;
	}

	.bhr-paused {
		margin-left: auto;
		color: #f59e0b;
		font-weight: 600;
	}

	.bhr-resume {
		margin-left: auto;
		color: #22c55e;
		font-weight: 600;
	}

	/* ── Code body ────────────────────────────────────────────────── */
	.bhr-code {
		padding: 0.4rem 0;
		font-size: 0.82rem;
		line-height: 1.7;
	}

	.bhr-row {
		display: flex;
		align-items: center;
	}

	.bhr-row.is-active {
		background: color-mix(in srgb, #f59e0b 16%, transparent);
	}

	.bhr-gutter {
		position: relative;
		flex: none;
		width: 3.1rem;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.3rem;
		padding-right: 0.6rem;
		color: var(--sl-color-gray-4);
		font-size: 0.74rem;
	}

	.bhr-ln {
		min-width: 1ch;
		text-align: right;
	}

	.bhr-dot {
		position: absolute;
		left: 0.5rem;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: #e5484d;
	}

	.bhr-arrow {
		color: #f59e0b;
		font-size: 0.6rem;
		line-height: 1;
	}

	.bhr-src {
		background: none;
		padding: 0;
		white-space: pre;
		color: var(--sl-color-white);
	}

	/* ── Variables / Debug Console panels ─────────────────────────── */
	.bhr-panel-head {
		padding: 0.4rem 0.7rem;
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-hairline);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3);
	}

	.bhr-tree,
	.bhr-repl {
		padding: 0.6rem 0.8rem;
		font-size: 0.84rem;
		line-height: 1.9;
	}

	.bhr-scope {
		color: var(--sl-color-gray-3);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		margin-top: 0.3rem;
	}

	.bhr-scope:first-child {
		margin-top: 0;
	}

	.bhr-var {
		color: var(--sl-color-gray-1);
	}

	.bhr-indent {
		padding-left: 1.1rem;
	}

	.bhr-key {
		color: #7dd3fc;
	}

	.bhr-obj {
		color: var(--sl-color-gray-3);
	}

	/* The two tenant values, tinted to make the mismatch obvious. */
	.bhr-val-a {
		color: #4ade80;
		font-weight: 600;
	}

	.bhr-val-b {
		color: #fb923c;
		font-weight: 600;
	}

	.bhr-false {
		color: #f87171;
		font-weight: 700;
	}

	/* ── REPL ─────────────────────────────────────────────────────── */
	.bhr-line {
		color: var(--sl-color-white);
	}

	.bhr-prompt {
		color: var(--sl-color-gray-4);
		user-select: none;
	}

	.bhr-in {
		background: none;
		padding: 0;
		color: var(--sl-color-white);
	}

	.bhr-out {
		padding-left: 1.1rem;
		border-bottom: 1px solid var(--sl-color-hairline);
		padding-bottom: 0.15rem;
		margin-bottom: 0.15rem;
	}

	.bhr-repl .bhr-out:last-child {
		border-bottom: none;
		margin-bottom: 0;
	}

	@media (max-width: 480px) {
		.bhr-code,
		.bhr-tree,
		.bhr-repl {
			font-size: 0.74rem;
		}
	}
</style>
