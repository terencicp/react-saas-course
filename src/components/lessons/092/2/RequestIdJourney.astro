---
/**
 * requestId journey sequence for Chapter 092, Lesson 2.
 *
 * A scrubbable five-step walk of one `requestId` (req_a1b2) traveling through a
 * single request: proxy.ts -> authedAction -> a deep /lib helper's child logger
 * -> the Sentry event / response, and finally the on-call pivot that joins the
 * two surfaces back together by the shared ID.
 *
 * Goals (from the lesson):
 *   - Make the *invisible* visible: the ALS scope propagating the same requestId
 *     down to a helper that never received it as a parameter (step 3).
 *   - Make the shared-ID *join* concrete: the Sentry event and the log line carry
 *     the same `req_a1b2`, drawn as a dashed link in step 5.
 *
 * Plain HTML + CSS (scoped) inside the lesson's <DiagramSequence>:
 *   - A fixed horizontal node strip stays put across all five steps so scrubbing
 *     animates *one* picture lighting up, not five swapped diagrams. The grid-stack
 *     stage sizes to the tallest step and never reflows.
 *   - The active node carries the live `req_a1b2` chip so the reader watches the
 *     same ID travel left to right.
 *   - A per-step detail row below the strip shows the context object growing
 *     ({ requestId } -> { requestId, userId, orgId }), the emitted log line, the
 *     Sentry context, and the dashed join.
 *
 * Palette mirrors the sibling Sentry/log lessons: blue #3b82f6 for the live ALS
 * scope / requestId, green #22c55e for the join payoff, neutral grays for dormant
 * nodes, mono for IDs and code.
 *
 * DiagramSequence provides its own card and must NOT be wrapped in <Figure>.
 */
import DiagramSequence from '../../../../components/figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../../components/figures/diagram-sequence/DiagramStep.astro';

const nodes = [
  { key: 'proxy', label: 'proxy.ts', sub: 'edge seam' },
  { key: 'action', label: 'authedAction', sub: 'after auth' },
  { key: 'helper', label: '/lib helper', sub: 'child logger' },
  { key: 'out', label: 'Sentry · response', sub: 'outbound' },
];

// Render the fixed node strip; `active` lights one node and shows the live ID on it.
const REQ_ID = 'req_a1b2';
---

<DiagramSequence>
  {/* ── Step 1: proxy reads-or-generates the id and opens the scope ──────── */}
  <DiagramStep>
    <div class="rj">
      <div class="rj-strip" data-active="proxy">
        {
          nodes.map((n, i) => (
            <>
              {i > 0 && <span class="rj-arrow" aria-hidden="true">&#8594;</span>}
              <span class={`rj-node n-${n.key}`}>
                <span class="rj-node-label">{n.label}</span>
                <span class="rj-node-sub">{n.sub}</span>
                <span class="rj-chip">{REQ_ID}</span>
              </span>
            </>
          ))
        }
      </div>

      <div class="rj-detail">
        <div class="rj-row">
          <span class="rj-tag rj-tag-blue">opens scope</span>
          <code class="rj-code">runWithContext(&#123; requestId &#125;, …)</code>
        </div>
        <div class="rj-ctx">
          <span class="rj-ctx-key">context</span>
          <code class="rj-ctx-val">&#123; requestId: <b>'req_a1b2'</b> &#125;</code>
        </div>
      </div>
    </div>
    <Fragment slot="caption">
      <strong>The request arrives.</strong> <code>proxy.ts</code> reads-or-generates
      the <code>requestId</code> (<code>req_a1b2</code>) and opens the ALS scope with
      <code>runWithContext(&#123; requestId &#125;, …)</code>.
    </Fragment>
  </DiagramStep>

  {/* ── Step 2: authedAction enriches the scope with user + org ─────────── */}
  <DiagramStep>
    <div class="rj">
      <div class="rj-strip" data-active="action">
        {
          nodes.map((n, i) => (
            <>
              {i > 0 && <span class="rj-arrow" aria-hidden="true">&#8594;</span>}
              <span class={`rj-node n-${n.key}`}>
                <span class="rj-node-label">{n.label}</span>
                <span class="rj-node-sub">{n.sub}</span>
                <span class="rj-chip">{REQ_ID}</span>
              </span>
            </>
          ))
        }
      </div>

      <div class="rj-detail">
        <div class="rj-row">
          <span class="rj-tag rj-tag-blue">re-opens scope</span>
          <code class="rj-code">runWithContext(&#123; requestId, userId, orgId &#125;, …)</code>
        </div>
        <div class="rj-ctx">
          <span class="rj-ctx-key">context</span>
          <code class="rj-ctx-val"
            >&#123; requestId: <b>'req_a1b2'</b>, <span class="rj-add">userId, orgId</span> &#125;</code
          >
        </div>
      </div>
    </div>
    <Fragment slot="caption">
      <strong>Auth resolves inside <code>authedAction</code>.</strong> The proxy's
      scope didn't cross the boundary, so the wrapper recovers the same
      <code>requestId</code> from the <code>x-request-id</code> header and opens an
      <em>enriched</em> scope — same ID, now with <code>userId</code> and
      <code>orgId</code>.
    </Fragment>
  </DiagramStep>

  {/* ── Step 3: a deep helper emits a line — IDs appear, unpassed ───────── */}
  <DiagramStep>
    <div class="rj">
      <div class="rj-strip" data-active="helper">
        {
          nodes.map((n, i) => (
            <>
              {i > 0 && <span class="rj-arrow" aria-hidden="true">&#8594;</span>}
              <span class={`rj-node n-${n.key}`}>
                <span class="rj-node-label">{n.label}</span>
                <span class="rj-node-sub">{n.sub}</span>
                <span class="rj-chip">{REQ_ID}</span>
              </span>
            </>
          ))
        }
      </div>

      <div class="rj-detail">
        <div class="rj-row">
          <span class="rj-tag rj-tag-blue">reads scope</span>
          <code class="rj-code">logger.child(getRequestContext())</code>
        </div>
        <div class="rj-logline">
          <span class="rj-log-key">log line</span>
          <code class="rj-log-val"
            >&#123; <span class="rj-mut">level: 'info'</span>, requestId: <b>'req_a1b2'</b>,
            userId, orgId, <span class="rj-mut">invoiceId, msg</span> &#125;</code
          >
        </div>
        <p class="rj-note">
          The helper never received <code>requestId</code> as an argument — it reached up
          through the ALS scope. <strong>No prop-drilling.</strong>
        </p>
      </div>
    </div>
    <Fragment slot="caption">
      <strong>Deep in a <code>/lib</code> helper</strong>, the child logger emits a
      line. <code>requestId</code>, <code>userId</code>, and <code>orgId</code> all
      appear on it — nobody passed them down.
    </Fragment>
  </DiagramStep>

  {/* ── Step 4: throws/completes — same id on Sentry + echoed on response ── */}
  <DiagramStep>
    <div class="rj">
      <div class="rj-strip" data-active="out">
        {
          nodes.map((n, i) => (
            <>
              {i > 0 && <span class="rj-arrow" aria-hidden="true">&#8594;</span>}
              <span class={`rj-node n-${n.key}`}>
                <span class="rj-node-label">{n.label}</span>
                <span class="rj-node-sub">{n.sub}</span>
                <span class="rj-chip">{REQ_ID}</span>
              </span>
            </>
          ))
        }
      </div>

      <div class="rj-detail">
        <div class="rj-pair">
          <div class="rj-surface">
            <span class="rj-surface-head">Sentry event</span>
            <code class="rj-surface-val"
              >context.request = &#123; requestId: <b>'req_a1b2'</b> &#125;</code
            >
          </div>
          <div class="rj-surface">
            <span class="rj-surface-head">HTTP response</span>
            <code class="rj-surface-val">x-request-id: <b>req_a1b2</b></code>
          </div>
        </div>
      </div>
    </div>
    <Fragment slot="caption">
      <strong>The action throws or completes.</strong>
      <code>Sentry.captureException</code> sets the same <code>requestId</code> on the
      event's <em>context</em>, and the response echoes <code>x-request-id</code>.
    </Fragment>
  </DiagramStep>

  {/* ── Step 5: the join — on-call pivots Sentry -> logs by the shared id ── */}
  <DiagramStep>
    <div class="rj">
      <div class="rj-strip rj-strip-join" data-active="join">
        {
          nodes.map((n, i) => (
            <>
              {i > 0 && <span class="rj-arrow" aria-hidden="true">&#8594;</span>}
              <span class={`rj-node n-${n.key}`}>
                <span class="rj-node-label">{n.label}</span>
                <span class="rj-node-sub">{n.sub}</span>
                <span class="rj-chip">{REQ_ID}</span>
              </span>
            </>
          ))
        }
      </div>

      <div class="rj-detail">
        <div class="rj-join">
          <div class="rj-surface rj-surface-join">
            <span class="rj-surface-head">Sentry event</span>
            <code class="rj-surface-val"><b>req_a1b2</b> · stack trace</code>
          </div>
          <span class="rj-join-link" aria-hidden="true">
            <span class="rj-join-id">req_a1b2</span>
          </span>
          <div class="rj-surface rj-surface-join">
            <span class="rj-surface-head">Log destination</span>
            <code class="rj-surface-val"><b>req_a1b2</b> · request narrative</code>
          </div>
        </div>
      </div>
    </div>
    <Fragment slot="caption">
      <strong>On-call pivots.</strong> Later, an engineer opens that Sentry event,
      copies <code>req_a1b2</code>, and filters the log destination by it — reading the
      whole request narrative the stack trace couldn't tell. <em>(That pivot UI is
      built a couple of lessons from now.)</em>
    </Fragment>
  </DiagramStep>
</DiagramSequence>

<style>
  .rj {
    --rj-blue: #3b82f6;
    --rj-blue-soft: color-mix(in srgb, #3b82f6 16%, var(--sl-color-bg));
    --rj-green: #22c55e;
    --rj-green-soft: color-mix(in srgb, #22c55e 16%, var(--sl-color-bg));
    width: 100%;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  /* ── The fixed node strip — same geometry across every step ──────────── */
  .rj-strip {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 0.35rem;
    flex-wrap: nowrap;
  }
  .rj-node {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    text-align: center;
    padding: 0.55rem 0.4rem 0.5rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 10px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    transition:
      border-color 0.15s,
      background-color 0.15s,
      color 0.15s,
      box-shadow 0.15s;
  }
  .rj-node-label {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-weight: 700;
    font-size: 0.82rem;
    line-height: 1.15;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .rj-node-sub {
    font-size: 0.66rem;
    color: var(--sl-color-gray-3);
    line-height: 1.1;
  }
  /* The travelling requestId chip — hidden on dormant nodes, lit on the active one. */
  .rj-chip {
    margin-top: 0.25rem;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.08rem 0.4rem;
    border-radius: 999px;
    background: var(--rj-blue);
    color: #fff;
    line-height: 1.4;
    opacity: 0;
    visibility: hidden;
  }
  .rj-arrow {
    align-self: center;
    color: var(--sl-color-gray-4);
    font-size: 1.05rem;
    line-height: 1;
    flex: 0 0 auto;
  }

  /* Light the active node (and any node before it, dimmer, to show the path so
     far). The strip carries data-active = the current node key. */
  .rj-strip[data-active='proxy'] .n-proxy,
  .rj-strip[data-active='action'] .n-action,
  .rj-strip[data-active='helper'] .n-helper,
  .rj-strip[data-active='out'] .n-out,
  .rj-strip[data-active='join'] .n-out {
    border-color: var(--rj-blue);
    background: var(--rj-blue-soft);
    color: var(--sl-color-white);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--rj-blue) 40%, transparent);
  }
  .rj-strip[data-active='proxy'] .n-proxy .rj-chip,
  .rj-strip[data-active='action'] .n-action .rj-chip,
  .rj-strip[data-active='helper'] .n-helper .rj-chip,
  .rj-strip[data-active='out'] .n-out .rj-chip,
  .rj-strip[data-active='join'] .n-out .rj-chip {
    opacity: 1;
    visibility: visible;
  }

  /* In the join step, the requestId chip glows green on both surfaces. */
  .rj-strip-join .n-out .rj-chip {
    background: var(--rj-green);
  }
  .rj-strip-join[data-active='join'] .n-out {
    border-color: var(--rj-green);
    background: var(--rj-green-soft);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--rj-green) 40%, transparent);
  }

  /* ── Per-step detail row ─────────────────────────────────────────────── */
  .rj-detail {
    margin-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-height: 5.2rem; /* keeps the stage height stable across steps */
  }
  .rj-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .rj-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.12rem 0.5rem;
    border-radius: 999px;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .rj-tag-blue {
    background: var(--rj-blue);
    color: #fff;
  }
  .rj-code,
  .rj-ctx-val,
  .rj-log-val,
  .rj-surface-val {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
  }
  .rj-code {
    color: var(--sl-color-gray-2);
  }

  .rj-ctx,
  .rj-logline {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.45rem 0.6rem;
    border: 1px solid var(--sl-color-hairline);
    border-left: 3px solid var(--rj-blue);
    border-radius: 8px;
    background: var(--sl-color-bg);
  }
  .rj-ctx-key,
  .rj-log-key {
    flex: 0 0 auto;
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
  }
  .rj-ctx-val,
  .rj-log-val {
    color: var(--sl-color-gray-1);
    min-width: 0;
  }
  .rj-ctx-val b,
  .rj-log-val b,
  .rj-surface-val b {
    color: var(--rj-blue);
    font-weight: 700;
  }
  .rj-add {
    color: var(--rj-green);
    font-weight: 700;
  }
  .rj-mut {
    color: var(--sl-color-gray-3);
  }
  .rj-note {
    margin: 0;
    font-size: 0.78rem;
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  /* ── Step 4: two outbound surfaces ───────────────────────────────────── */
  .rj-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .rj-surface {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.5rem 0.6rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    background: var(--sl-color-bg);
  }
  .rj-surface-head {
    font-size: 0.64rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
  }
  .rj-surface-val {
    color: var(--sl-color-gray-1);
  }

  /* ── Step 5: the join ────────────────────────────────────────────────── */
  .rj-join {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.5rem;
  }
  .rj-surface-join {
    border-color: var(--rj-green);
    border-left-width: 3px;
    background: var(--rj-green-soft);
  }
  .rj-surface-join b {
    color: var(--rj-green);
  }
  .rj-join-link {
    position: relative;
    flex: 0 0 auto;
    align-self: center;
    /* dashed connecting line behind the id pill */
    min-width: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rj-join-link::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    border-top: 2px dashed var(--rj-green);
  }
  .rj-join-id {
    position: relative;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.66rem;
    font-weight: 700;
    padding: 0.08rem 0.4rem;
    border-radius: 999px;
    background: var(--rj-green);
    color: #fff;
    white-space: nowrap;
  }

  /* ── Narrow viewports ────────────────────────────────────────────────── */
  @media (max-width: 34rem) {
    .rj-node-sub {
      display: none;
    }
    .rj-node-label {
      font-size: 0.72rem;
    }
    .rj-arrow {
      font-size: 0.85rem;
    }
    .rj-pair {
      grid-template-columns: 1fr;
    }
    .rj-join {
      grid-template-columns: 1fr;
      justify-items: stretch;
    }
    .rj-join-link {
      min-height: 1.4rem;
    }
    .rj-join-link::before {
      left: 50%;
      right: auto;
      top: 0;
      bottom: 0;
      border-top: none;
      border-left: 2px dashed var(--rj-green);
    }
  }
</style>
