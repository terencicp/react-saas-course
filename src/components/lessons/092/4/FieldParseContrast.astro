---
// FieldParseContrast — Chapter 092 Lesson 4 ("Shipping logs with Drains").
//
// Two tabs contrasting how one log line looks in the destination depending on
// whether the inner pino JSON got parsed. This is the verification step's
// teaching target: "did my fields survive the wire?"
//
//   Tab 1 — Parsed (queryable): every key (level, requestId, orgId, service,
//     msg) is promoted to its own labeled, indexed column. orgId == "org_4Qd"
//     is a real filter. Visually GOOD (teal accent, check chip).
//   Tab 2 — Unparsed (broken): Vercel's envelope fields are columns, but the
//     application data is trapped in one opaque `message` string. There is no
//     orgId field to filter on. Visually BROKEN (amber accent, warning chip),
//     and the message value is a visibly long unparsed string.
//
// A hand-built HTML+CSS mock of a destination record view, per the diagrams
// guide and the lesson's capture note (no live Axiom account) — the contrast
// (top-level fields vs nested blob) IS the teaching point, and a mock controls
// it precisely. Built as a labeled key/value row list styled like a log-record
// inspector.
//
// Colors track the rest of the lesson's figures: teal (#0d9488) for the
// good/parsed side, amber (#d97706) for the limited/broken side. The `message`
// row in the broken tab carries the amber tone to mark it as the trap.
//
// TabbedContent supplies its own card, so this is NOT wrapped in <Figure>.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

const GOOD = "#0d9488"; // teal — parsed, queryable
const BROKEN = "#d97706"; // amber — unparsed, trapped in a string

// The parsed record: each application key is its own indexed column.
const parsedFields = [
	{ key: "level", value: "error" },
	{ key: "requestId", value: "req_8fK2" },
	{ key: "orgId", value: "org_4Qd" },
	{ key: "service", value: "app" },
	{ key: "msg", value: "stripe webhook failed" },
];

// The broken record: Vercel's envelope fields are columns, the whole pino line
// is stuck inside `message` as one escaped string.
const envelopeFields = [
	{ key: "level", value: "error", note: "Vercel's envelope level" },
	{ key: "requestId", value: "iad1::abc-123", note: "Vercel's envelope requestId" },
];
const trappedMessage =
	'{"level":"error","time":"2026-06-13T02:14:09.412Z",' +
	'"requestId":"req_8fK2","orgId":"org_4Qd","service":"app",' +
	'"msg":"stripe webhook failed"}';
---

<TabbedContent>
	<TabbedItem label="Parsed (queryable)">
		<div class="fpc not-content" style={`--fpc-good:${GOOD};`}>
			<div class="fpc-record fpc-record--good">
				<div class="fpc-head">
					<span class="fpc-chip fpc-chip--good">
						<svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
							<path
								d="M5 13l4 4L19 7"
								fill="none"
								stroke="currentColor"
								stroke-width="2.8"
								stroke-linecap="round"
								stroke-linejoin="round"></path>
						</svg>
						Indexed fields
					</span>
					<span class="fpc-head-sub">1 record</span>
				</div>
				<dl class="fpc-rows">
					{
						parsedFields.map((f) => (
							<div class="fpc-row fpc-row--good">
								<dt class="fpc-key">{f.key}</dt>
								<dd class="fpc-val">{f.value}</dd>
							</div>
						))
					}
				</dl>
			</div>
		</div>
		<Fragment slot="caption">
			Each key is its own indexed column. <code>orgId == "org_4Qd"</code> is
			now a real filter.
		</Fragment>
	</TabbedItem>

	<TabbedItem label="Unparsed (broken)">
		<div class="fpc not-content" style={`--fpc-broken:${BROKEN};`}>
			<div class="fpc-record fpc-record--broken">
				<div class="fpc-head">
					<span class="fpc-chip fpc-chip--broken">
						<svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
							<path
								d="M12 8v5M12 16.5v.5"
								fill="none"
								stroke="currentColor"
								stroke-width="2.6"
								stroke-linecap="round"></path>
							<path
								d="M12 3.5l9 16H3l9-16z"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linejoin="round"></path>
						</svg>
						message not parsed
					</span>
					<span class="fpc-head-sub">1 record</span>
				</div>
				<dl class="fpc-rows">
					{
						envelopeFields.map((f) => (
							<div class="fpc-row">
								<dt class="fpc-key">{f.key}</dt>
								<dd class="fpc-val">
									{f.value}
									<span class="fpc-row-note">{f.note}</span>
								</dd>
							</div>
						))
					}
					<div class="fpc-row fpc-row--trap">
						<dt class="fpc-key">message</dt>
						<dd class="fpc-val fpc-val--trap">
							<span class="fpc-string">{trappedMessage}</span>
							<span class="fpc-row-note">
								one opaque string — no <code>orgId</code> to filter on
							</span>
						</dd>
					</div>
				</dl>
			</div>
		</div>
		<Fragment slot="caption">
			The inner JSON stayed a string. There is no <code>orgId</code> field to
			filter on — only an opaque <code>message</code>.
		</Fragment>
	</TabbedItem>
</TabbedContent>

<style>
	.fpc {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* The record card — a stylized destination "view one record" panel. The
	   left border carries the verdict tone (teal = parsed, amber = broken). */
	.fpc-record {
		box-sizing: border-box;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #d1d5db);
		background: var(--sl-color-bg, #fff);
		overflow: hidden;
		margin: 0;
	}

	.fpc-record--good {
		border-left: 3px solid var(--fpc-good);
	}

	.fpc-record--broken {
		border-left: 3px solid var(--fpc-broken);
	}

	/* Header strip — a status chip plus a faint "1 record" count, echoing a
	   destination's record inspector. */
	.fpc-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		padding: 9px 12px;
		border-bottom: 1px solid var(--sl-color-gray-6, #e5e7eb);
		background: var(--sl-color-gray-7, #f7f8fa);
		margin: 0;
	}

	.fpc-chip {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 3px 9px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1.2;
	}

	.fpc-chip svg {
		display: block;
		flex: 0 0 auto;
	}

	.fpc-chip--good {
		color: color-mix(in srgb, var(--fpc-good) 82%, var(--sl-color-white));
		background: color-mix(in srgb, var(--fpc-good) 14%, transparent);
	}

	.fpc-chip--broken {
		color: color-mix(in srgb, var(--fpc-broken) 84%, var(--sl-color-white));
		background: color-mix(in srgb, var(--fpc-broken) 15%, transparent);
	}

	.fpc-head-sub {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9ca3af);
	}

	/* The field rows — a two-column grid (key | value) so keys align as a
	   column the eye can scan, like a record inspector. */
	.fpc-rows {
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: minmax(78px, max-content) 1fr;
	}

	.fpc-row {
		display: contents;
	}

	.fpc-key {
		grid-column: 1;
		box-sizing: border-box;
		padding: 8px 12px;
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		border-bottom: 1px solid var(--sl-color-gray-6, #e5e7eb);
		white-space: nowrap;
	}

	.fpc-val {
		grid-column: 2;
		box-sizing: border-box;
		padding: 8px 12px;
		font-size: 12.5px;
		line-height: 1.4;
		color: var(--sl-color-white, #1e293b);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-weight: 600;
		border-bottom: 1px solid var(--sl-color-gray-6, #e5e7eb);
		min-width: 0;
		word-break: break-word;
	}

	/* Last row drops its divider so the card bottom reads clean. */
	.fpc-rows > .fpc-row:last-child .fpc-key,
	.fpc-rows > .fpc-row:last-child .fpc-val {
		border-bottom: none;
	}

	/* In the parsed tab, the application keys get a faint teal key column so
	   "these are your fields, promoted" reads at a glance. */
	.fpc-row--good .fpc-key {
		color: color-mix(in srgb, var(--fpc-good) 70%, var(--sl-color-text));
		background: color-mix(in srgb, var(--fpc-good) 5%, transparent);
	}

	/* A small grey annotation under an envelope value. */
	.fpc-row-note {
		display: block;
		margin-top: 2px;
		font-size: 10.5px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #9ca3af);
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			sans-serif
		);
	}

	.fpc-row-note code {
		font-size: 10px;
	}

	/* The trap row — the whole pino line stuck inside `message` as one string.
	   Amber-tinted so the eye lands on it as the broken thing. */
	.fpc-row--trap .fpc-key {
		color: color-mix(in srgb, var(--fpc-broken) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--fpc-broken) 8%, transparent);
		vertical-align: top;
	}

	.fpc-val--trap {
		background: color-mix(in srgb, var(--fpc-broken) 6%, transparent);
	}

	/* The escaped JSON, presented as one long unparsed string — quoted, dim,
	   and visibly a blob rather than structured fields. */
	.fpc-string {
		display: block;
		color: color-mix(in srgb, var(--fpc-broken) 75%, var(--sl-color-text));
		font-weight: 600;
		word-break: break-all;
		line-height: 1.5;
	}

	.fpc-string::before,
	.fpc-string::after {
		content: '"';
		color: var(--sl-color-gray-4, #b0b8c4);
	}
</style>
