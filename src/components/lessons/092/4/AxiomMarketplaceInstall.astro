---
// AxiomMarketplaceInstall — Chapter 092 Lesson 4 ("Shipping logs with Drains").
//
// A faithful hand-built HTML+CSS MOCK of the Vercel Marketplace Axiom integration
// page (the install screen). No real Axiom account or Vercel Pro project is
// provisioned for the course, so per the lesson's capture note we render a mock
// rather than a blank/placeholder image. The teaching point — and the figure's
// caption — is that *adding the integration provisions the drain and wires ingest
// auth for you*, so there is no app-side AXIOM_TOKEN to manage. The mock makes
// that concrete by surfacing the "What gets set up" panel listing exactly that.
//
// Structure mirrors the real screen so it reads as a screenshot:
//   - a Vercel top chrome bar (logo, breadcrumb "Marketplace / Axiom")
//   - the integration header: Axiom mark, name, "by Axiom", an "Add Integration"
//     CTA, and a free-tier pill
//   - a two-column body: left = description + "Permissions"/"What gets set up"
//     panel; right = a sticky-feeling info card (category, plan, pricing).
//
// Built to sit inside <Screenshot viewport="desktop"> inside <Figure caption>,
// so it carries NO outer card of its own. `not-content` + margin:0 defeat
// Starlight prose margins. Colors track the theme via --sl-* tokens; the Axiom
// brand teal (#0d9488, also the course accent) is the one load-bearing accent.

const ACCENT = "#0d9488"; // Axiom teal / course accent

// What the integration writes for you — the load-bearing list. Each row is a
// thing you would otherwise hand-manage on the manual-drain path.
const provisions: string[] = [
	"Creates the Logs Drain on your project",
	"Routes ingest auth through the integration",
	"Provisions an Axiom dataset per environment",
];
---

<div class="ami not-content" style={`--ami-accent:${ACCENT};`}>
	{/* Vercel top chrome */}
	<div class="ami-chrome">
		<svg
			class="ami-vlogo"
			viewBox="0 0 76 65"
			width="16"
			height="14"
			aria-hidden="true"
		>
			<path d="M37.5274 0L75.0548 65H0L37.5274 0Z" fill="currentColor"></path>
		</svg>
		<span class="ami-crumb">Marketplace</span>
		<span class="ami-crumb-sep">/</span>
		<span class="ami-crumb ami-crumb--active">Axiom</span>
		<div class="ami-chrome-spacer"></div>
		<div class="ami-avatar" aria-hidden="true"></div>
	</div>

	{/* Integration header */}
	<div class="ami-header">
		<div class="ami-mark" aria-hidden="true">
			<svg viewBox="0 0 24 24" width="26" height="26">
				<path
					d="M12 3L4 18h4l4-7 4 7h4L12 3z"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linejoin="round"></path>
			</svg>
		</div>
		<div class="ami-titleblock">
			<div class="ami-titlerow">
				<h3 class="ami-name">Axiom</h3>
				<span class="ami-verified" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="13" height="13">
						<path
							d="M5 13l4 4L19 7"
							fill="none"
							stroke="currentColor"
							stroke-width="2.6"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</span>
			</div>
			<p class="ami-by">by Axiom · Logging &amp; Observability</p>
		</div>
		<button class="ami-cta" type="button" tabindex="-1">Add Integration</button>
	</div>

	{/* Body: description + provision panel | side info card */}
	<div class="ami-body">
		<div class="ami-main">
			<p class="ami-desc">
				Ship your Vercel logs to Axiom with one click. Axiom auto-parses your
				JSON log lines into queryable fields — no pipeline to build, no token to
				manage.
			</p>

			<div class="ami-panel">
				<div class="ami-panel-head">
					<span class="ami-panel-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="14" height="14">
							<path
								d="M5 13l4 4L19 7"
								fill="none"
								stroke="currentColor"
								stroke-width="2.4"
								stroke-linecap="round"
								stroke-linejoin="round"></path>
						</svg>
					</span>
					<span class="ami-panel-title">What gets set up for you</span>
				</div>
				<ul class="ami-prov">
					{
						provisions.map((line) => (
							<li class="ami-prov-item">
								<span class="ami-tick" aria-hidden="true">
									<svg viewBox="0 0 24 24" width="12" height="12">
										<path
											d="M5 13l4 4L19 7"
											fill="none"
											stroke="currentColor"
											stroke-width="2.6"
											stroke-linecap="round"
											stroke-linejoin="round"
										/>
									</svg>
								</span>
								<span class="ami-prov-text">{line}</span>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<aside class="ami-aside">
			<div class="ami-meta-row">
				<span class="ami-meta-label">Category</span>
				<span class="ami-meta-value">Observability</span>
			</div>
			<div class="ami-meta-row">
				<span class="ami-meta-label">Plan</span>
				<span class="ami-meta-value">Pro · Enterprise</span>
			</div>
			<div class="ami-meta-row">
				<span class="ami-meta-label">Pricing</span>
				<span class="ami-pill">Free tier available</span>
			</div>
		</aside>
	</div>
</div>

<style>
	.ami {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		background: var(--sl-color-bg);
		color: var(--sl-color-white, #1e293b);
		font-size: 13px;
		line-height: 1.45;
	}

	/* Vercel chrome bar */
	.ami-chrome {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 9px 16px;
		border-bottom: 1px solid var(--sl-color-gray-5);
		background: color-mix(in srgb, var(--sl-color-gray-6) 50%, var(--sl-color-bg));
	}
	.ami-vlogo {
		color: var(--sl-color-white, #111);
		flex: 0 0 auto;
	}
	.ami-crumb {
		font-size: 12.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
	}
	.ami-crumb--active {
		color: var(--sl-color-white, #1e293b);
	}
	.ami-crumb-sep {
		color: var(--sl-color-gray-4, #94a3b8);
	}
	.ami-chrome-spacer {
		flex: 1 1 auto;
	}
	.ami-avatar {
		width: 22px;
		height: 22px;
		border-radius: 999px;
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--ami-accent) 70%, transparent),
			color-mix(in srgb, var(--ami-accent) 30%, var(--sl-color-gray-4))
		);
		flex: 0 0 auto;
	}

	/* Integration header */
	.ami-header {
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 20px 22px;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.ami-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 52px;
		border-radius: 12px;
		flex: 0 0 auto;
		color: var(--ami-accent);
		background: color-mix(in srgb, var(--ami-accent) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--ami-accent) 32%, transparent);
	}
	.ami-titleblock {
		flex: 1 1 auto;
		min-width: 0;
	}
	.ami-titlerow {
		display: flex;
		align-items: center;
		gap: 7px;
	}
	.ami-name {
		margin: 0;
		font-size: 19px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
	}
	.ami-verified {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 17px;
		height: 17px;
		border-radius: 999px;
		color: #fff;
		background: var(--ami-accent);
		flex: 0 0 auto;
	}
	.ami-by {
		margin: 3px 0 0;
		font-size: 12px;
		color: var(--sl-color-gray-3, #9ca3af);
	}
	.ami-cta {
		flex: 0 0 auto;
		border: 0;
		border-radius: 7px;
		padding: 9px 16px;
		font-size: 13px;
		font-weight: 600;
		font-family: inherit;
		color: #fff;
		background: var(--ami-accent);
		cursor: default;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
	}

	/* Body */
	.ami-body {
		display: grid;
		grid-template-columns: 1fr minmax(150px, 0.5fr);
		gap: 22px;
		padding: 20px 22px 22px;
		align-items: start;
	}
	.ami-main {
		min-width: 0;
	}
	.ami-desc {
		margin: 0 0 16px;
		font-size: 13px;
		line-height: 1.55;
		color: var(--sl-color-gray-2, #475569);
	}

	/* "What gets set up" panel — the load-bearing element. */
	.ami-panel {
		border: 1px solid color-mix(in srgb, var(--ami-accent) 30%, transparent);
		background: color-mix(in srgb, var(--ami-accent) 6%, var(--sl-color-bg));
		border-radius: 10px;
		padding: 13px 15px;
	}
	.ami-panel-head {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 9px;
	}
	.ami-panel-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		border-radius: 999px;
		color: #fff;
		background: var(--ami-accent);
		flex: 0 0 auto;
	}
	.ami-panel-title {
		font-size: 12.5px;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: color-mix(in srgb, var(--ami-accent) 80%, var(--sl-color-white));
	}
	.ami-prov {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 7px;
	}
	.ami-prov-item {
		display: flex;
		align-items: center;
		gap: 9px;
		margin: 0;
		font-size: 12.5px;
		color: var(--sl-color-white, #1e293b);
	}
	.ami-tick {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		border-radius: 999px;
		flex: 0 0 auto;
		color: var(--ami-accent);
		background: color-mix(in srgb, var(--ami-accent) 16%, transparent);
	}
	.ami-prov-text {
		min-width: 0;
		font-weight: 500;
	}

	/* Side info card */
	.ami-aside {
		display: flex;
		flex-direction: column;
		gap: 0;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 10px;
		padding: 4px 14px;
		background: color-mix(in srgb, var(--sl-color-gray-6) 40%, var(--sl-color-bg));
	}
	.ami-meta-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		padding: 10px 0;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.ami-meta-row:last-child {
		border-bottom: 0;
	}
	.ami-meta-label {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #9ca3af);
	}
	.ami-meta-value {
		font-size: 12.5px;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		text-align: right;
	}
	.ami-pill {
		font-size: 11px;
		font-weight: 700;
		padding: 3px 9px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--ami-accent) 82%, var(--sl-color-white));
		background: color-mix(in srgb, var(--ami-accent) 13%, transparent);
		border: 1px solid color-mix(in srgb, var(--ami-accent) 30%, transparent);
		white-space: nowrap;
	}

	/* Narrow viewports: drop the side card under the main column. */
	@media (max-width: 560px) {
		.ami-body {
			grid-template-columns: 1fr;
			gap: 16px;
		}
		.ami-header {
			flex-wrap: wrap;
		}
		.ami-cta {
			width: 100%;
		}
	}
</style>
