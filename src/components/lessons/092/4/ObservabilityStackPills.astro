---
// ObservabilityStackPills — Chapter 092 Lesson 4 ("Shipping logs with Drains").
//
// The chapter's synthesis as a single horizontal row of three labeled pills:
// the minimum viable observability floor for a 2026 SaaS. Each pill names one
// tool and the one question it answers, so the division of labor reads at a
// glance — three tools, one workflow.
//
//   Sentry            → what threw     (the signature of the failure)
//   Drain destination → what happened  (the per-request narrative)
//   Vercel UI         → platform health (build/deploy/runtime metrics)
//
// Pure HTML+CSS per the diagrams guide — an annotated illustration, not a
// system graph, and small enough to live inline. Goes inside a <Figure>
// (supplied in the MDX, which also carries the caption).
//
// Each pill gets its own accent so the three read as three DISTINCT surfaces
// rather than a good/bad verdict (this lesson reserves teal/amber for the
// parsed-vs-broken contrast figures). Tints via color-mix so they track the
// theme background. `not-content` + margin:0 defeats Starlight prose margins.

type Pill = {
	tool: string;
	question: string;
	accent: string;
	// A small inline SVG glyph for each surface; kept tiny and monochrome so
	// the accent does the identifying, not the icon.
	icon: "alert" | "scroll" | "gauge";
};

const pills: Pill[] = [
	{
		tool: "Sentry",
		question: "what threw",
		accent: "#8b5cf6", // violet — the error surface
		icon: "alert",
	},
	{
		tool: "Drain destination",
		question: "what happened",
		accent: "#0d9488", // teal — the structured-logs surface
		icon: "scroll",
	},
	{
		tool: "Vercel UI",
		question: "platform health",
		accent: "#0ea5e9", // sky — the platform surface
		icon: "gauge",
	},
];
---

<div class="osp not-content">
	<div class="osp-row">
		{
			pills.map((p, i) => (
				<>
					<div class="osp-pill" style={`--osp-accent:${p.accent};`}>
						<span class="osp-mark" aria-hidden="true">
							{p.icon === "alert" && (
								<svg viewBox="0 0 24 24" width="16" height="16">
									<path
										d="M10.3 3.8L2.4 18a2 2 0 0 0 1.7 3h15.8a2 2 0 0 0 1.7-3L13.7 3.8a2 2 0 0 0-3.4 0z"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
										stroke-linejoin="round"
									/>
									<path
										d="M12 9v4.5M12 16.8v.2"
										fill="none"
										stroke="currentColor"
										stroke-width="2.1"
										stroke-linecap="round"
									/>
								</svg>
							)}
							{p.icon === "scroll" && (
								<svg viewBox="0 0 24 24" width="16" height="16">
									<rect
										x="4"
										y="3.5"
										width="16"
										height="17"
										rx="2"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
									/>
									<path
										d="M8 8.5h8M8 12h8M8 15.5h5"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
										stroke-linecap="round"
									/>
								</svg>
							)}
							{p.icon === "gauge" && (
								<svg viewBox="0 0 24 24" width="16" height="16">
									<path
										d="M3.5 18a8.5 8.5 0 0 1 17 0"
										fill="none"
										stroke="currentColor"
										stroke-width="1.9"
										stroke-linecap="round"
									/>
									<path
										d="M12 18l4-4.5"
										fill="none"
										stroke="currentColor"
										stroke-width="2.1"
										stroke-linecap="round"
									/>
									<circle cx="12" cy="18" r="1.6" fill="currentColor" />
								</svg>
							)}
						</span>
						<span class="osp-text">
							<span class="osp-tool">{p.tool}</span>
							<span class="osp-question">{p.question}</span>
						</span>
					</div>
					{i < pills.length - 1 && (
						<span class="osp-plus" aria-hidden="true">
							+
						</span>
					)}
				</>
			))
		}
	</div>
</div>

<style>
	.osp {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* One horizontal row: three pills joined by faint "+" separators. Wraps to a
	   column on narrow viewports so each pill stays readable. */
	.osp-row {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 10px;
		margin: 0;
	}

	.osp-pill {
		display: flex;
		align-items: center;
		gap: 9px;
		flex: 1 1 128px;
		min-width: 0;
		box-sizing: border-box;
		padding: 12px 13px;
		border-radius: 12px;
		background: color-mix(in srgb, var(--osp-accent) 8%, var(--sl-color-bg));
		border: 1.5px solid color-mix(in srgb, var(--osp-accent) 36%, transparent);
		margin: 0;
	}

	/* The accent-tinted glyph badge — the strongest carrier of each surface's
	   identity. */
	.osp-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 30px;
		height: 30px;
		border-radius: 8px;
		color: var(--osp-accent);
		background: color-mix(in srgb, var(--osp-accent) 16%, transparent);
	}

	.osp-mark svg {
		display: block;
	}

	.osp-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.osp-tool {
		font-size: 14.5px;
		font-weight: 700;
		line-height: 1.2;
		color: color-mix(in srgb, var(--osp-accent) 72%, var(--sl-color-white));
		margin: 0;
	}

	.osp-question {
		font-size: 12px;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* The "+" between pills: three tools that add up to one floor. Muted so it
	   joins rather than competes with the pills. */
	.osp-plus {
		display: flex;
		align-items: center;
		flex: 0 0 auto;
		font-size: 20px;
		font-weight: 400;
		line-height: 1;
		color: var(--sl-color-gray-4, #b0b8c4);
		margin: 0;
	}

	/* Stack on narrow viewports; turn the "+" into a horizontal joiner so the
	   "they add up" read survives the vertical layout. */
	@media (max-width: 560px) {
		.osp-row {
			flex-direction: column;
			align-items: stretch;
		}
		.osp-pill {
			flex: 1 1 auto;
		}
		.osp-plus {
			justify-content: center;
			font-size: 16px;
		}
	}
</style>
