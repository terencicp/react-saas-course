---
// SentryToLogsPivot — Chapter 092 Lesson 4 ("Shipping logs with Drains").
//
// The lesson's signature visual: one `requestId` bridges two tools. A stylized
// Sentry event card (left) and a drain query view (right), with a single labeled
// arrow flowing from the Sentry request-context row to the drain's filter box.
// The whole teaching point is the JOIN — read the value on one surface, paste it
// into the other, and the per-request narrative is one query away.
//
//   LEFT  — a Sentry event card: title, grouped-events count, an orgId tag chip,
//           and a "request context" row exposing requestId: req_8fK2.
//   RIGHT — a drain query view: a filter box (where requestId == "req_8fK2")
//           over a short result list — an `info` "webhook received" line, then an
//           `error` "signature verification failed" line.
//
// Engine: <ArrowDiagram> (leader-line), per the lesson TODO. The arrow needs to
// span the gap between two real HTML mocks, which D2/Mermaid can't render — this
// is exactly the cross-region case the ArrowDiagram guide describes.
//
// MUST live inside <Figure expandable={false}> — leader-line positions arrows
// from document.body, so relocating the figure into the expand lightbox would
// break them. The lesson MDX wraps it accordingly.
//
// Cross-region anchoring (per the guide): the arrow attaches at the ROW / BOX
// level (full-width blocks), not at an inline span — anchoring on a span inside
// the card would make the line exit *inside* the panel and cut across the card's
// other rows. Instead the `req_8fK2` token is highlighted in blue on BOTH
// surfaces, so the eye reads "highlight in Sentry -> curve in the gap -> filter
// box -> highlight in the result". startSocket 'right' / endSocket 'left'; a
// generous centre track reserves room for the curve + the `requestId` label.
//
// Color: blue (#2563eb) is the JOIN color — the arrow, the label, and the
// matched `req_8fK2` highlight all share it, so identity carries across the gap.
// Sentry's card wears a muted purple (its brand tone); the drain card wears the
// lesson's teal (#0d9488), the accent every other figure in this lesson uses.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const JOIN = "#2563eb"; // blue-600 — the requestId join color
const SENTRY = "#8b5cf6"; // violet-500 — Sentry's brand tone
const DRAIN = "#0d9488"; // teal-600 — the lesson's drain/destination accent

const REQ_ID = "req_8fK2";

const arrows = [
	{
		from: "pivot-sentry-ctx",
		to: "pivot-drain-filter",
		label: "requestId",
		color: JOIN,
		startSocket: "right" as const,
		endSocket: "left" as const,
		startSocketGravity: [80, 0] as [number, number],
		endSocketGravity: [-80, 0] as [number, number],
		labelOffset: [0, -16] as [number, number],
		labelStyle: `background:${JOIN};color:#fff;border:none;`,
	},
];

// The drain's per-request narrative: the info line that ran before the throw,
// then the error line it ended at.
const resultRows = [
	{ level: "info", msg: "webhook received" },
	{ level: "error", msg: "signature verification failed" },
];
---

<div class="stl not-content" style={`--stl-join:${JOIN};--stl-sentry:${SENTRY};--stl-drain:${DRAIN};`}>
	<ArrowDiagram arrows={arrows}>
		<div class="stl-flow">
			{/* LEFT — the Sentry event card */}
			<div class="stl-cell">
				<div class="stl-card stl-card--sentry">
					<div class="stl-card-head">
						<span class="stl-tool stl-tool--sentry">Sentry</span>
						<span class="stl-head-meta">event</span>
					</div>
					<div class="stl-card-body">
						<div class="stl-event-title">
							<span class="stl-dot" aria-hidden="true"></span>
							<span class="stl-event-title-text">Error · stripe webhook failed</span>
						</div>
						<div class="stl-event-meta">
							<span class="stl-count">47 events</span>
							<span class="stl-tag">orgId:&nbsp;org_4Qd</span>
						</div>
						<div class="stl-ctx" id="pivot-sentry-ctx">
							<span class="stl-ctx-label">request context</span>
							<span class="stl-ctx-row">
								<span class="stl-ctx-key">requestId</span>
								<span class="stl-match">{REQ_ID}</span>
							</span>
						</div>
					</div>
				</div>
			</div>

			{/* centre gap — holds the curve + the requestId label */}
			<div class="stl-gap" aria-hidden="true"></div>

			{/* RIGHT — the drain query view */}
			<div class="stl-cell">
				<div class="stl-card stl-card--drain">
					<div class="stl-card-head">
						<span class="stl-tool stl-tool--drain">Drain destination</span>
						<span class="stl-head-meta">query</span>
					</div>
					<div class="stl-card-body">
						<div class="stl-filter" id="pivot-drain-filter">
							<span class="stl-kw">where</span>
							<span class="stl-field">requestId</span>
							<span class="stl-op">==</span>
							<span class="stl-match">"{REQ_ID}"</span>
						</div>
						<div class="stl-results">
							{
								resultRows.map((r) => (
									<div class:list={["stl-result", `stl-result--${r.level}`]}>
										<span class:list={["stl-lvl", `stl-lvl--${r.level}`]}>
											{r.level}
										</span>
										<span class="stl-result-msg">{r.msg}</span>
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	</ArrowDiagram>
</div>

<style>
	.stl {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* Three-track grid: Sentry card | gap (curve + label) | drain card. The wide
	   centre track reserves room for the curve and the `requestId` badge so they
	   sit clear of both panels. */
	.stl-flow {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 110px minmax(0, 1fr);
		align-items: center;
		gap: 0;
		max-width: 720px;
		margin: 0 auto;
	}

	.stl-cell {
		min-width: 0;
		display: flex;
	}

	.stl-gap {
		min-width: 0;
	}

	/* The two surface cards. */
	.stl-card {
		box-sizing: border-box;
		width: 100%;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-5, #d1d5db);
		background: var(--sl-color-bg, #fff);
		overflow: hidden;
	}

	.stl-card--sentry {
		border-top: 3px solid var(--stl-sentry);
	}

	.stl-card--drain {
		border-top: 3px solid var(--stl-drain);
	}

	.stl-card-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		padding: 8px 12px;
		border-bottom: 1px solid var(--sl-color-gray-6, #e5e7eb);
		background: var(--sl-color-gray-7, #f7f8fa);
	}

	.stl-tool {
		font-size: 11.5px;
		font-weight: 800;
		letter-spacing: 0.01em;
	}

	.stl-tool--sentry {
		color: color-mix(in srgb, var(--stl-sentry) 78%, var(--sl-color-white));
	}

	.stl-tool--drain {
		color: color-mix(in srgb, var(--stl-drain) 80%, var(--sl-color-white));
	}

	.stl-head-meta {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9ca3af);
	}

	.stl-card-body {
		padding: 11px 12px 12px;
		display: flex;
		flex-direction: column;
		gap: 9px;
	}

	/* --- Sentry event card --- */
	.stl-event-title {
		display: flex;
		align-items: center;
		gap: 7px;
	}

	.stl-dot {
		flex: 0 0 auto;
		width: 8px;
		height: 8px;
		border-radius: 999px;
		background: #ef4444; /* red — an error event */
	}

	.stl-event-title-text {
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
	}

	.stl-event-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 7px;
	}

	.stl-count {
		font-size: 10.5px;
		font-weight: 700;
		color: var(--sl-color-gray-3, #9ca3af);
	}

	.stl-tag {
		font-size: 10.5px;
		font-weight: 700;
		padding: 2px 8px;
		border-radius: 999px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		color: color-mix(in srgb, var(--stl-sentry) 78%, var(--sl-color-white));
		background: color-mix(in srgb, var(--stl-sentry) 13%, transparent);
		white-space: nowrap;
	}

	/* The request-context block — the arrow's source anchor (block-level, so the
	   line exits the card's right edge, not from inside a token). */
	.stl-ctx {
		border-radius: 8px;
		border: 1px dashed var(--sl-color-gray-5, #d1d5db);
		background: var(--sl-color-gray-7, #f7f8fa);
		padding: 7px 9px;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stl-ctx-label {
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9ca3af);
	}

	.stl-ctx-row {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
	}

	.stl-ctx-key {
		font-size: 12px;
		font-weight: 700;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		color: var(--sl-color-gray-2, #475569);
	}

	/* --- drain query view --- */
	.stl-filter {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 6px;
		padding: 8px 10px;
		border-radius: 8px;
		border: 1.5px solid color-mix(in srgb, var(--stl-drain) 45%, var(--sl-color-gray-5));
		background: color-mix(in srgb, var(--stl-drain) 7%, var(--sl-color-bg));
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 12px;
		font-weight: 700;
		line-height: 1.3;
	}

	.stl-kw {
		color: color-mix(in srgb, var(--stl-drain) 78%, var(--sl-color-white));
	}

	.stl-field {
		color: var(--sl-color-gray-2, #475569);
	}

	.stl-op {
		color: var(--sl-color-gray-3, #9ca3af);
	}

	.stl-results {
		display: flex;
		flex-direction: column;
		gap: 5px;
	}

	.stl-result {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 8px;
		border-radius: 7px;
		border: 1px solid var(--sl-color-gray-6, #e5e7eb);
		background: var(--sl-color-gray-7, #f7f8fa);
	}

	.stl-result--error {
		border-color: color-mix(in srgb, #ef4444 40%, var(--sl-color-gray-5));
		background: color-mix(in srgb, #ef4444 7%, var(--sl-color-bg));
	}

	.stl-lvl {
		flex: 0 0 auto;
		font-size: 9.5px;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 2px 7px;
		border-radius: 999px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}

	.stl-lvl--info {
		color: color-mix(in srgb, var(--stl-drain) 80%, var(--sl-color-white));
		background: color-mix(in srgb, var(--stl-drain) 13%, transparent);
	}

	.stl-lvl--error {
		color: color-mix(in srgb, #ef4444 82%, var(--sl-color-white));
		background: color-mix(in srgb, #ef4444 14%, transparent);
	}

	.stl-result-msg {
		font-size: 12px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		min-width: 0;
		word-break: break-word;
	}

	/* The join token, highlighted identically on BOTH surfaces — blue tint with a
	   1px inset ring so the match reads at a glance, the eye following it across
	   the gap to where the arrow lands. */
	.stl-match {
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 12px;
		font-weight: 800;
		color: color-mix(in srgb, var(--stl-join) 82%, var(--sl-color-white));
		background: color-mix(in srgb, var(--stl-join) 16%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--stl-join) 55%, transparent);
		padding: 1px 6px;
		border-radius: 5px;
		white-space: nowrap;
	}

	/* Narrow viewports: stack the panels and drop the gap track. The arrow will
	   arc between the stacked cards — readable, if not as crisp as the side-by-side
	   gap. */
	@media (max-width: 560px) {
		.stl-flow {
			grid-template-columns: 1fr;
			gap: 40px;
		}
		.stl-gap {
			display: none;
		}
	}
</style>
