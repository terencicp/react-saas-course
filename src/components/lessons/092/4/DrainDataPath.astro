---
// DrainDataPath — Chapter 092 Lesson 4 ("Shipping logs with Drains").
//
// A DiagramSequence that traces ONE log line through the drain pipe, hop by hop:
//   pino → stdout → Vercel capture → batch POST → destination index.
// Each step lights one hop (teal) and dims the others, so scrubbing the slider
// literally walks the line down the pipe. Per-step captions carry the
// one-sentence explanation.
//
// The payoff is step 5: the "destination index" box expands to show the
// two-layers idea SPATIALLY — an outer "Vercel envelope" box physically
// containing a nested inner "pino JSON" box. That nesting is the whole point of
// the surrounding prose ("there are two layers, and they are not the same
// fields"), made visible.
//
// Built as plain HTML+CSS per the diagrams guide — this is an annotated
// illustration of a pipe, not an architecture graph. The DiagramSequence
// supplies its own card, so this is NOT wrapped in <Figure>.
//
// Color is load-bearing: teal (#0d9488, the course accent) marks the ACTIVE hop;
// inactive hops fade to a muted gray. The same teal threads the envelope/inner
// split so the eye reads the active destination step as "this is where the line
// becomes queryable".

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

const ACCENT = "#0d9488"; // teal — the active hop

// The five hops, in order. Each step below highlights one by index.
const hops = [
	{ key: "pino", label: "pino", sub: ".child(...)" },
	{ key: "stdout", label: "stdout", sub: "JSON line" },
	{ key: "capture", label: "Vercel", sub: "captures" },
	{ key: "post", label: "batch POST", sub: "HTTP" },
	{ key: "index", label: "destination", sub: "indexes" },
];
---

<DiagramSequence>
	<DiagramStep caption="Your logger writes one JSON line straight to stdout — synchronous, no transport thread.">
		<div class="ddp not-content" style={`--ddp-accent:${ACCENT};`}>
			<div class="ddp-pipe">
				{
					hops.map((hop, i) => (
						<>
							<div class:list={["ddp-node", { "is-on": i === 0 }]}>
								<span class="ddp-node-label">{hop.label}</span>
								<span class="ddp-node-sub">{hop.sub}</span>
							</div>
							{i < hops.length - 1 && (
								<span class="ddp-arrow" aria-hidden="true">
									→
								</span>
							)}
						</>
					))
				}
			</div>
		</div>
	</DiagramStep>

	<DiagramStep caption="The function's stdout is captured by Vercel for every invocation.">
		<div class="ddp not-content" style={`--ddp-accent:${ACCENT};`}>
			<div class="ddp-pipe">
				{
					hops.map((hop, i) => (
						<>
							<div class:list={["ddp-node", { "is-on": i === 1 }]}>
								<span class="ddp-node-label">{hop.label}</span>
								<span class="ddp-node-sub">{hop.sub}</span>
							</div>
							{i < hops.length - 1 && (
								<span class="ddp-arrow" aria-hidden="true">
									→
								</span>
							)}
						</>
					))
				}
			</div>
		</div>
	</DiagramStep>

	<DiagramStep caption="Vercel buffers the captured lines and groups them into batches.">
		<div class="ddp not-content" style={`--ddp-accent:${ACCENT};`}>
			<div class="ddp-pipe">
				{
					hops.map((hop, i) => (
						<>
							<div class:list={["ddp-node", { "is-on": i === 2 }]}>
								<span class="ddp-node-label">{hop.label}</span>
								<span class="ddp-node-sub">{hop.sub}</span>
							</div>
							{i < hops.length - 1 && (
								<span class="ddp-arrow" aria-hidden="true">
									→
								</span>
							)}
						</>
					))
				}
			</div>
		</div>
	</DiagramStep>

	<DiagramStep caption="Vercel POSTs each batch over HTTP to your drain's destination.">
		<div class="ddp not-content" style={`--ddp-accent:${ACCENT};`}>
			<div class="ddp-pipe">
				{
					hops.map((hop, i) => (
						<>
							<div class:list={["ddp-node", { "is-on": i === 3 }]}>
								<span class="ddp-node-label">{hop.label}</span>
								<span class="ddp-node-sub">{hop.sub}</span>
							</div>
							{i < hops.length - 1 && (
								<span class="ddp-arrow" aria-hidden="true">
									→
								</span>
							)}
						</>
					))
				}
			</div>
		</div>
	</DiagramStep>

	<DiagramStep>
		<div class="ddp not-content" style={`--ddp-accent:${ACCENT};`}>
			<div class="ddp-pipe">
				{
					hops.map((hop, i) => (
						<>
							<div class:list={["ddp-node", { "is-on": i === 4 }]}>
								<span class="ddp-node-label">{hop.label}</span>
								<span class="ddp-node-sub">{hop.sub}</span>
							</div>
							{i < hops.length - 1 && (
								<span class="ddp-arrow" aria-hidden="true">
									→
								</span>
							)}
						</>
					))
				}
			</div>

			{/* The spatial payoff: the destination's indexed record, with the inner
			    pino JSON physically nested inside Vercel's envelope. */}
			<div class="ddp-split">
				<div class="ddp-envelope">
					<span class="ddp-layer-tag ddp-layer-tag--env">
						Vercel envelope
					</span>
					<span class="ddp-fields">id · timestamp · source · level · requestId</span>
					<div class="ddp-inner">
						<span class="ddp-layer-tag ddp-layer-tag--inner">
							pino JSON <span class="ddp-inner-where">(inside message)</span>
						</span>
						<span class="ddp-fields ddp-fields--inner">
							level · requestId · orgId
						</span>
					</div>
				</div>
			</div>
		</div>
		<Fragment slot="caption">
			The destination parses each line and indexes its fields. Your <code>level</code>,{" "}
			<code>requestId</code> and <code>orgId</code> live <em>inside</em> the{" "}
			<code>message</code> string — only that inner parse makes them queryable.
		</Fragment>
	</DiagramStep>
</DiagramSequence>

<style>
	.ddp {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 18px;
		padding: 8px 4px 4px;
	}

	/* The pipe — a horizontal row of five hop boxes joined by arrows. */
	.ddp-pipe {
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 4px;
		width: 100%;
	}

	.ddp-node {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		box-sizing: border-box;
		min-width: 0;
		padding: 9px 9px;
		border-radius: 9px;
		border: 1.5px solid var(--sl-color-gray-5, #d1d5db);
		background: var(--sl-color-gray-7, #f3f4f6);
		/* Inactive hops fade back so the active one carries the eye. */
		opacity: 0.45;
		transition:
			opacity 0.2s ease,
			border-color 0.2s ease;
	}

	.ddp-node.is-on {
		opacity: 1;
		border-color: var(--ddp-accent);
		background: color-mix(in srgb, var(--ddp-accent) 12%, var(--sl-color-bg));
		box-shadow: 0 0 0 3px
			color-mix(in srgb, var(--ddp-accent) 22%, transparent);
	}

	.ddp-node-label {
		font-size: 13px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
	}

	.ddp-node.is-on .ddp-node-label {
		color: color-mix(in srgb, var(--ddp-accent) 80%, var(--sl-color-white));
	}

	.ddp-node-sub {
		font-size: 10.5px;
		font-weight: 600;
		line-height: 1.1;
		color: var(--sl-color-gray-3, #9ca3af);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}

	.ddp-arrow {
		display: flex;
		align-items: center;
		flex: 0 0 auto;
		font-size: 16px;
		font-weight: 700;
		color: var(--sl-color-gray-4, #b0b8c4);
		line-height: 1;
	}

	/* Step 5 — the envelope / inner-message split. */
	.ddp-split {
		width: 100%;
		display: flex;
		justify-content: center;
	}

	.ddp-envelope {
		box-sizing: border-box;
		width: min(420px, 100%);
		padding: 12px 14px 14px;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-5, #d1d5db);
		background: var(--sl-color-gray-7, #f3f4f6);
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.ddp-inner {
		margin-top: 8px;
		padding: 10px 12px 12px;
		border-radius: 9px;
		border: 1.5px solid var(--ddp-accent);
		background: color-mix(in srgb, var(--ddp-accent) 10%, var(--sl-color-bg));
		display: flex;
		flex-direction: column;
		gap: 5px;
	}

	.ddp-layer-tag {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.ddp-layer-tag--env {
		color: var(--sl-color-gray-2, #475569);
	}

	.ddp-layer-tag--inner {
		color: color-mix(in srgb, var(--ddp-accent) 82%, var(--sl-color-white));
		text-transform: none;
		letter-spacing: 0;
		font-size: 11px;
	}

	.ddp-inner-where {
		font-weight: 600;
		color: var(--sl-color-gray-3, #9ca3af);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}

	.ddp-fields {
		font-size: 12px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		line-height: 1.4;
	}

	.ddp-fields--inner {
		color: color-mix(in srgb, var(--ddp-accent) 75%, var(--sl-color-text));
		font-weight: 700;
	}

	@media (max-width: 520px) {
		.ddp-arrow {
			transform: rotate(90deg);
		}
		.ddp-pipe {
			flex-direction: column;
			align-items: center;
		}
		.ddp-node {
			width: min(220px, 100%);
		}
	}
</style>
