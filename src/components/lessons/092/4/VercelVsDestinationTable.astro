---
// VercelVsDestinationTable — Chapter 092 Lesson 4 ("Shipping logs with Drains").
//
// A compact two-column capability comparison that makes the gap between Vercel's
// built-in log viewer and a real log destination (Axiom) legible at a glance.
// The point of the figure is the *shape* of the two columns: the Vercel viewer
// is a column of dim, amber "limited" cells (a wall of crosses on the last three
// rows); the destination is a column of teal "capable" cells (a wall of checks).
// Reading down each column, the gap is visceral before you read a single word.
//
// Pure HTML+CSS per the diagrams guide — a color-coded comparison, not a system
// graph. Built as a CSS grid (3 cols: feature label / Vercel / destination) so
// rows align across both sides and it collapses to a stacked, per-feature layout
// on narrow viewports. `not-content` + margin:0 defeats Starlight prose margins.
//
// Colors are LOAD-BEARING: teal (#0d9488, the course "good"/accent) for the
// capable destination side, amber (#d97706, the course "limited"/watch-out tone)
// for the viewer side. Tints via color-mix so they track the theme background.
//
// Goes inside <Figure> (supplied here, no caption — the surrounding prose already
// enumerates each row).

const GOOD = "#0d9488"; // teal — the destination, the capable side
const LIMITED = "#d97706"; // amber — the viewer, the limited side

type Cell = {
	// `kind` drives the icon + tone: a hard "no" gets a cross, a present
	// capability gets a check, a plain capability fact gets a neutral dot.
	kind: "yes" | "no" | "fact";
	text: string;
};

type Row = {
	feature: string;
	viewer: Cell;
	destination: Cell;
};

const rows: Row[] = [
	{
		feature: "Retention",
		viewer: { kind: "fact", text: "~1 hour" },
		destination: { kind: "fact", text: "Weeks to months, you choose" },
	},
	{
		feature: "Query model",
		viewer: { kind: "fact", text: "Substring text search" },
		destination: { kind: "fact", text: 'Field-typed (orgId == "org_123")' },
	},
	{
		feature: "Cross-request joins",
		viewer: { kind: "no", text: "No" },
		destination: { kind: "yes", text: "Yes — filter the whole window" },
	},
	{
		feature: "Saved views / dashboards",
		viewer: { kind: "no", text: "No" },
		destination: { kind: "yes", text: "Yes" },
	},
	{
		feature: "Alerting",
		viewer: { kind: "no", text: "No" },
		destination: { kind: "yes", text: "Yes" },
	},
];
---

<div class="vvd not-content" style={`--vvd-good:${GOOD};--vvd-limited:${LIMITED};`}>
	<div class="vvd-grid">
		{/* Header row */}
		<div class="vvd-corner" aria-hidden="true"></div>
		<div class="vvd-head vvd-head--limited">
			<span class="vvd-head-name">Vercel logs viewer</span>
			<span class="vvd-head-sub">built-in</span>
		</div>
		<div class="vvd-head vvd-head--good">
			<span class="vvd-head-name">Log destination</span>
			<span class="vvd-head-sub">Axiom</span>
		</div>

		{/* Feature rows */}
		{
			rows.map((row) => (
				<>
					<div class="vvd-feature">{row.feature}</div>

					<div
						class:list={[
							"vvd-cell",
							"vvd-cell--limited",
							`vvd-cell--${row.viewer.kind}`,
						]}
					>
						<span class="vvd-mark" aria-hidden="true">
							{row.viewer.kind === "no" ? (
								<svg viewBox="0 0 24 24" width="15" height="15">
									<path
										d="M6 6l12 12M18 6L6 18"
										fill="none"
										stroke="currentColor"
										stroke-width="2.6"
										stroke-linecap="round"
									/>
								</svg>
							) : (
								<svg viewBox="0 0 24 24" width="13" height="13">
									<circle cx="12" cy="12" r="4" fill="currentColor" />
								</svg>
							)}
						</span>
						<span class="vvd-text">{row.viewer.text}</span>
					</div>

					<div
						class:list={[
							"vvd-cell",
							"vvd-cell--good",
							`vvd-cell--${row.destination.kind}`,
						]}
					>
						<span class="vvd-mark" aria-hidden="true">
							{row.destination.kind === "yes" ? (
								<svg viewBox="0 0 24 24" width="15" height="15">
									<path
										d="M5 13l4 4L19 7"
										fill="none"
										stroke="currentColor"
										stroke-width="2.6"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							) : (
								<svg viewBox="0 0 24 24" width="13" height="13">
									<circle cx="12" cy="12" r="4" fill="currentColor" />
								</svg>
							)}
						</span>
						<span class="vvd-text">{row.destination.text}</span>
					</div>
				</>
			))
		}
	</div>
</div>

<style>
	.vvd {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* 3 columns: feature label | viewer | destination. Hairline gaps between
	   cells let each side read as its own tinted column. */
	.vvd-grid {
		display: grid;
		grid-template-columns: minmax(120px, 0.9fr) 1fr 1fr;
		gap: 6px;
		align-items: stretch;
		min-width: 0;
		margin: 0;
	}

	.vvd-corner {
		margin: 0;
	}

	/* Column headers — each carries its side's tone so the column identity is
	   set before the first feature row. */
	.vvd-head {
		display: flex;
		flex-direction: column;
		gap: 1px;
		justify-content: center;
		padding: 10px 12px;
		border-radius: 10px 10px 4px 4px;
		margin: 0;
		min-width: 0;
	}

	.vvd-head--limited {
		background: color-mix(in srgb, var(--vvd-limited) 13%, transparent);
		border: 1.5px solid color-mix(in srgb, var(--vvd-limited) 38%, transparent);
	}

	.vvd-head--good {
		background: color-mix(in srgb, var(--vvd-good) 13%, transparent);
		border: 1.5px solid color-mix(in srgb, var(--vvd-good) 45%, transparent);
	}

	.vvd-head-name {
		font-size: 14px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.vvd-head--limited .vvd-head-name {
		color: color-mix(in srgb, var(--vvd-limited) 78%, var(--sl-color-white));
	}

	.vvd-head--good .vvd-head-name {
		color: color-mix(in srgb, var(--vvd-good) 80%, var(--sl-color-white));
	}

	.vvd-head-sub {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9ca3af);
		margin: 0;
	}

	/* The feature label sits in the left gutter, vertically centered against its
	   two cells. */
	.vvd-feature {
		display: flex;
		align-items: center;
		padding: 8px 12px 8px 2px;
		font-size: 12.5px;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
		min-width: 0;
	}

	.vvd-cell {
		display: flex;
		align-items: center;
		gap: 8px;
		box-sizing: border-box;
		padding: 9px 12px;
		border-radius: 6px;
		font-size: 12.5px;
		line-height: 1.3;
		margin: 0;
		min-width: 0;
	}

	.vvd-cell--limited {
		background: color-mix(in srgb, var(--vvd-limited) 7%, var(--sl-color-bg));
		border: 1px solid color-mix(in srgb, var(--vvd-limited) 22%, transparent);
	}

	.vvd-cell--good {
		background: color-mix(in srgb, var(--vvd-good) 7%, var(--sl-color-bg));
		border: 1px solid color-mix(in srgb, var(--vvd-good) 26%, transparent);
	}

	/* The mark — a small circular badge holding the check / cross / dot. Its
	   color is what builds the column-of-checks vs column-of-crosses read. */
	.vvd-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 20px;
		height: 20px;
		border-radius: 999px;
		margin: 0;
	}

	.vvd-cell--no .vvd-mark {
		color: var(--vvd-limited);
		background: color-mix(in srgb, var(--vvd-limited) 16%, transparent);
	}

	.vvd-cell--yes .vvd-mark {
		color: var(--vvd-good);
		background: color-mix(in srgb, var(--vvd-good) 16%, transparent);
	}

	/* Neutral capability facts (retention, query model) get a muted dot in the
	   side's own tone rather than a verdict mark. */
	.vvd-cell--fact.vvd-cell--limited .vvd-mark {
		color: color-mix(in srgb, var(--vvd-limited) 55%, var(--sl-color-gray-3));
		background: transparent;
	}

	.vvd-cell--fact.vvd-cell--good .vvd-mark {
		color: color-mix(in srgb, var(--vvd-good) 60%, var(--sl-color-gray-3));
		background: transparent;
	}

	.vvd-mark svg {
		display: block;
	}

	.vvd-text {
		min-width: 0;
		color: var(--sl-color-white, #1e293b);
		font-weight: 500;
		margin: 0;
	}

	.vvd-cell--no .vvd-text {
		font-weight: 700;
		color: color-mix(in srgb, var(--vvd-limited) 80%, var(--sl-color-text));
	}

	.vvd-cell--yes .vvd-text {
		font-weight: 700;
		color: color-mix(in srgb, var(--vvd-good) 82%, var(--sl-color-text));
	}

	/* Narrow viewports: drop the gutter column and stack each feature as its own
	   block — feature label, then the two cells side by side underneath. */
	@media (max-width: 560px) {
		.vvd-grid {
			grid-template-columns: 1fr 1fr;
		}
		.vvd-corner {
			display: none;
		}
		.vvd-feature {
			grid-column: 1 / -1;
			padding: 10px 2px 2px;
			font-size: 13px;
			font-weight: 700;
			color: var(--sl-color-white, #1e293b);
		}
		.vvd-feature:first-of-type {
			padding-top: 2px;
		}
	}
</style>
