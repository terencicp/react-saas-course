---
// two-capture-paths — the spine diagram for Lesson 92.1.
//
// The one rule the whole lesson hangs on: a server-side error reaches Sentry
// by EXACTLY ONE of two paths, and you should always be able to say which.
// This DiagramSequence puts the two paths in space and lets the student scrub
// the rule into place:
//
//   1. The uncaught lane lights up:  throw -> Next.js boundary -> onRequestError
//   2. ...and connects through to the shared Sentry issue (wired by the wizard).
//   3. The caught lane appears, but DEAD-ENDS: authedAction swallows the throw
//      to return Result.err, so onRequestError never fires -> no Sentry.
//   4. The fix: captureException inside the catch. Both lanes now converge on
//      the same Sentry issue.
//
// Layout is fixed across all four steps so the stage never reflows (the
// DiagramSequence stack sizes to the tallest step and keeps inactive ones in
// layout). Only per-box / per-connector STATE changes between steps:
//   - lane "active" vs "dim"            -> focus
//   - box "on" / "ghost" / "miss"       -> present, pending, or broken
//   - connector "on" / "off" / "cut"    -> wired, idle, or severed
// Every box stays in the DOM in every step; we only swap classes.
//
// Pure HTML + CSS (devtools-inspectable). Starlight theme variables keep it
// native in light and dark; green = "reaches Sentry", grey = absence/idle,
// a dashed red cut = the broken caught path. `not-content` + margin resets
// defeat Starlight's prose-margin selector.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

type Box = { label: string; state: "on" | "dim" | "ghost" | "miss" };
type Lane = {
  title: string;
  state: "active" | "dim";
  boxes: Box[];
  // connector from the lane's last box to the shared Sentry box
  link: "on" | "off" | "cut";
  // small note hanging under the caught lane (Result.err -> user)
  note?: { label: string; state: "on" | "dim" };
};

type StepDef = {
  top: Lane;
  bottom: Lane;
  // is the shared Sentry box reached by at least one lane in this step?
  sentry: "on" | "dim";
};

const steps: StepDef[] = [
  // Step 1 — uncaught lane lit, not yet connected; caught lane dimmed/empty.
  {
    sentry: "dim",
    top: {
      title: "Uncaught — framework boundary",
      state: "active",
      link: "off",
      boxes: [
        { label: "throw", state: "on" },
        { label: "Next.js boundary", state: "on" },
        { label: "onRequestError", state: "on" },
      ],
    },
    bottom: {
      title: "Caught & handled — your wrapper",
      state: "dim",
      link: "off",
      boxes: [
        { label: "throw", state: "dim" },
        { label: "catch in authedAction", state: "dim" },
        { label: "Sentry.captureException", state: "ghost" },
      ],
      note: { label: "Result.err → user", state: "dim" },
    },
  },

  // Step 2 — uncaught lane fully connected through to Sentry (wired green).
  {
    sentry: "on",
    top: {
      title: "Uncaught — framework boundary",
      state: "active",
      link: "on",
      boxes: [
        { label: "throw", state: "on" },
        { label: "Next.js boundary", state: "on" },
        { label: "onRequestError", state: "on" },
      ],
    },
    bottom: {
      title: "Caught & handled — your wrapper",
      state: "dim",
      link: "off",
      boxes: [
        { label: "throw", state: "dim" },
        { label: "catch in authedAction", state: "dim" },
        { label: "Sentry.captureException", state: "ghost" },
      ],
      note: { label: "Result.err → user", state: "dim" },
    },
  },

  // Step 3 — caught lane active but DEAD-ENDS: catch returns Result.err, the
  // path to Sentry is severed. Top lane dims to shift focus.
  {
    sentry: "dim",
    top: {
      title: "Uncaught — framework boundary",
      state: "dim",
      link: "off",
      boxes: [
        { label: "throw", state: "dim" },
        { label: "Next.js boundary", state: "dim" },
        { label: "onRequestError", state: "dim" },
      ],
    },
    bottom: {
      title: "Caught & handled — your wrapper",
      state: "active",
      link: "cut",
      boxes: [
        { label: "throw", state: "on" },
        { label: "catch in authedAction", state: "on" },
        { label: "Sentry.captureException", state: "miss" },
      ],
      note: { label: "Result.err → user", state: "on" },
    },
  },

  // Step 4 — the fix. captureException inside the catch connects the caught
  // lane to the same Sentry issue; both lanes converge. Result.err still
  // returns to the user.
  {
    sentry: "on",
    top: {
      title: "Uncaught — framework boundary",
      state: "active",
      link: "on",
      boxes: [
        { label: "throw", state: "on" },
        { label: "Next.js boundary", state: "on" },
        { label: "onRequestError", state: "on" },
      ],
    },
    bottom: {
      title: "Caught & handled — your wrapper",
      state: "active",
      link: "on",
      boxes: [
        { label: "throw", state: "on" },
        { label: "catch in authedAction", state: "on" },
        { label: "Sentry.captureException", state: "on" },
      ],
      note: { label: "Result.err → user", state: "on" },
    },
  },
];

const captions = [
  "An uncaught throw in a Server Component, route handler, or Server Action bubbles up to Next.js's framework boundary.",
  "Next.js binds onRequestError to Sentry — the uncaught path is wired for you by the wizard, no code of yours required.",
  "But authedAction catches its own throw to return Result.err, so the error never reaches the boundary — onRequestError never fires, and nothing reaches Sentry.",
  "The fix: call captureException inside the catch. Both lanes now converge on the same Sentry issue — and Result.err still returns to the user.",
];
---

<DiagramSequence>
  {
    steps.map((step, i) => (
      <DiagramStep caption={captions[i]}>
        <div class="tcp not-content">
          <div class="tcp-grid">
            <div class="tcp-lanes">
              {[step.top, step.bottom].map((lane) => (
                <div class={`tcp-lane tcp-lane--${lane.state}`}>
                  <div class="tcp-lane-title">{lane.title}</div>
                  <div class="tcp-flow">
                    {lane.boxes.map((box, bi) => (
                      <>
                        {bi > 0 && <span class="tcp-arrow" aria-hidden="true" />}
                        <div class={`tcp-box tcp-box--${box.state}`}>
                          <code>{box.label}</code>
                        </div>
                      </>
                    ))}
                    {/* connector from the last box toward the shared Sentry box */}
                    <span class={`tcp-link tcp-link--${lane.link}`} aria-hidden="true">
                      {lane.link === "cut" && <span class="tcp-link-x">✕</span>}
                    </span>
                  </div>
                  {lane.note && (
                    <div class={`tcp-note tcp-note--${lane.note.state}`}>
                      <span class="tcp-branch" aria-hidden="true" />
                      <code>{lane.note.label}</code>
                    </div>
                  )}
                </div>
              ))}
            </div>

            <div class={`tcp-sentry tcp-sentry--${step.sentry}`}>
              <span class="tcp-sentry-dot" aria-hidden="true" />
              <span class="tcp-sentry-label">Sentry issue</span>
            </div>
          </div>
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>

<style>
  .tcp {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --tcp-green: var(--sl-color-green, #16a34a);
    --tcp-green-hi: var(--sl-color-green-high, #16a34a);
    --tcp-red: var(--sl-color-red, #ef4444);
  }

  /* Lanes on the left, the shared Sentry box on the right, vertically centred
     so a single connector visually feeds both lanes into it. */
  .tcp-grid {
    margin: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 0;
  }

  .tcp-lanes {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  /* ---- Lane ------------------------------------------------------------- */

  .tcp-lane {
    margin: 0;
    padding: 12px 12px 10px;
    border-radius: 11px;
    border: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
    transition: opacity 0.2s ease;
    min-width: 0;
  }

  .tcp-lane--dim {
    opacity: 0.4;
  }

  .tcp-lane-title {
    margin: 0 0 9px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-2);
  }

  /* ---- Flow row: boxes joined by arrows, ending in a connector --------- */

  .tcp-flow {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0;
    min-width: 0;
  }

  .tcp-box {
    margin: 0;
    flex: 1 1 0;
    min-width: 0;
    padding: 7px 8px;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    text-align: center;
    box-sizing: border-box;
  }

  .tcp-box code {
    margin: 0;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12px;
    line-height: 1.25;
    color: var(--sl-color-text);
    background: none;
    border: none;
    padding: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  /* Box states.
     on    — live in this step (neutral, readable).
     dim   — present but out of focus (handled by lane opacity; box stays flat).
     ghost — not yet wired: dashed outline, faded, signals "pending".
     miss  — the broken caught path: dashed red, struck through. */
  .tcp-box--ghost {
    border-style: dashed;
    border-color: var(--sl-color-gray-5);
    background: transparent;
    opacity: 0.5;
  }

  .tcp-box--miss {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--tcp-red) 55%, transparent);
    background: color-mix(in srgb, var(--tcp-red) 7%, transparent);
  }

  .tcp-box--miss code {
    color: color-mix(in srgb, var(--tcp-red) 80%, var(--sl-color-text));
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--tcp-red) 70%, transparent);
  }

  /* When a lane is active AND its link is wired, tint the live boxes green so
     the eye reads the whole path as "reaches Sentry". */
  .tcp-lane--active:has(.tcp-link--on) .tcp-box--on {
    border-color: color-mix(in srgb, var(--tcp-green) 45%, transparent);
    background: color-mix(in srgb, var(--tcp-green) 8%, transparent);
  }

  /* ---- Inter-box arrow ------------------------------------------------- */

  .tcp-arrow {
    flex: 0 0 22px;
    height: 2px;
    position: relative;
    background: var(--sl-color-gray-4);
  }

  .tcp-arrow::after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    border-left: 5px solid var(--sl-color-gray-4);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
  }

  /* ---- Connector toward the shared Sentry box -------------------------- */
  /* Fixed-width so the lanes line up; the visual state encodes wired / idle /
     severed. It reaches to the grid's right edge where the Sentry box sits. */
  .tcp-link {
    flex: 0 0 26px;
    height: 2px;
    position: relative;
    background: var(--sl-color-gray-5);
  }

  .tcp-link--off {
    background: var(--sl-color-gray-5);
    opacity: 0.5;
  }

  .tcp-link--on {
    background: color-mix(in srgb, var(--tcp-green) 60%, transparent);
  }

  .tcp-link--on::after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    border-left: 6px solid color-mix(in srgb, var(--tcp-green) 75%, transparent);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
  }

  /* Severed path: dashed red stub with an ✕ where it would have continued. */
  .tcp-link--cut {
    background: none;
    border-top: 2px dashed color-mix(in srgb, var(--tcp-red) 60%, transparent);
    height: 0;
  }

  .tcp-link-x {
    position: absolute;
    right: -3px;
    top: 50%;
    transform: translate(50%, -50%);
    font-size: 13px;
    line-height: 1;
    font-weight: 700;
    color: var(--tcp-red);
  }

  /* ---- Result.err note under the caught lane -------------------------- */

  .tcp-note {
    margin: 7px 0 0;
    display: flex;
    align-items: center;
    gap: 6px;
    padding-left: 4px;
  }

  .tcp-branch {
    flex: 0 0 14px;
    height: 10px;
    border-left: 2px solid var(--sl-color-gray-4);
    border-bottom: 2px solid var(--sl-color-gray-4);
    border-bottom-left-radius: 4px;
    margin-top: -8px;
  }

  .tcp-note code {
    margin: 0;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 11px;
    color: var(--sl-color-gray-2);
    background: none;
    border: none;
    padding: 0;
  }

  .tcp-note--dim {
    opacity: 0.45;
  }

  /* ---- Shared Sentry box ---------------------------------------------- */

  .tcp-sentry {
    margin: 0;
    margin-left: -2px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 92px;
    padding: 16px 10px;
    border-radius: 11px;
    border: 1.5px solid color-mix(in srgb, var(--tcp-green) 50%, transparent);
    background: color-mix(in srgb, var(--tcp-green) 10%, transparent);
    transition: opacity 0.2s ease;
  }

  .tcp-sentry--dim {
    opacity: 0.4;
    border-color: var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-5) 14%, transparent);
  }

  .tcp-sentry-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--tcp-green-hi);
  }

  .tcp-sentry--dim .tcp-sentry-dot {
    background: var(--sl-color-gray-4);
  }

  .tcp-sentry-label {
    font-size: 12px;
    font-weight: 700;
    text-align: center;
    line-height: 1.2;
    color: var(--sl-color-text);
  }

  /* Narrow viewports: three boxes can't sit side-by-side and stay readable, so
     flip each lane's flow to a vertical stack (boxes full-width, arrows point
     down) and drop the shared Sentry box below the lanes in a single column. */
  @media (max-width: 560px) {
    .tcp-grid {
      grid-template-columns: minmax(0, 1fr);
      row-gap: 12px;
    }

    .tcp-flow {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .tcp-box {
      flex: 0 0 auto;
      width: 100%;
    }

    .tcp-box code {
      white-space: normal;
      overflow: visible;
    }

    /* Inter-box arrow becomes a short vertical stem pointing down. */
    .tcp-arrow {
      flex: 0 0 14px;
      width: 2px;
      height: 14px;
      align-self: center;
    }
    .tcp-arrow::after {
      right: 50%;
      top: auto;
      bottom: 0;
      transform: translateX(50%);
      border-left: 4px solid transparent;
      border-right: 4px solid transparent;
      border-top: 5px solid var(--sl-color-gray-4);
      border-bottom: none;
    }

    /* Connector from the lane's last box down toward the Sentry box. */
    .tcp-link {
      flex: 0 0 14px;
      width: 2px;
      height: 14px;
      align-self: center;
    }
    .tcp-link--on::after {
      right: 50%;
      top: auto;
      bottom: 0;
      transform: translateX(50%);
      border-left: 5px solid transparent;
      border-right: 5px solid transparent;
      border-top: 6px solid color-mix(in srgb, var(--tcp-green) 75%, transparent);
      border-bottom: none;
    }
    .tcp-link--cut {
      border-top: none;
      border-left: 2px dashed color-mix(in srgb, var(--tcp-red) 60%, transparent);
      width: 0;
    }
    .tcp-link-x {
      right: 50%;
      top: auto;
      bottom: -3px;
      transform: translate(50%, 50%);
    }

    .tcp-sentry {
      margin-left: 0;
      width: 100%;
      flex-direction: row;
      padding: 12px;
    }
  }
</style>
