---
// sentry-vs-log-surface — the "why this tool" contrast for Lesson 92.1.
//
// One picture of the delta: the SAME production failure, as Vercel's function
// log sees it (a bare minified line, nothing attached) vs. as a Sentry issue
// sees it (the same failure enriched along five axes). The point is the gap
// BETWEEN the columns, not the styling of either side.
//
// Layout is a 3-column CSS grid so the eye reads ACROSS each row:
//
//   [ Vercel cell ]   [ attribute label ]   [ Sentry cell ]
//
// A header row names the two surfaces; then five aligned rows, one per
// enrichment (stack trace, grouping, release, user/org, breadcrumbs). The
// centre column is the spine — the attribute every row compares on.
//
// Left cells are muted/grey to read as ABSENCE; right cells carry a subtle
// green positive accent to read as PRESENCE. Pure HTML + CSS so the contrast
// is devtools-inspectable. `not-content` + a `margin: 0` reset on every inner
// element defeat Starlight's prose-margin selector; Starlight theme variables
// keep it native in light and dark.

import Figure from "../../../figures/Figure.astro";

const rows = [
  {
    attr: "Stack trace",
    left: "chunk-abc123.js:1:42",
    leftMono: true,
    right: "createInvoice.ts:34",
    rightMono: true,
  },
  {
    attr: "Grouping",
    left: "one line per occurrence",
    leftMono: false,
    right: "47 occurrences → 1 issue",
    rightMono: false,
  },
  {
    attr: "Release",
    left: "none",
    leftMono: false,
    right: "tagged a1b2c3d",
    rightMono: false,
    rightCode: "a1b2c3d",
  },
  {
    attr: "User / org",
    left: "none",
    leftMono: false,
    right: "user_8fa… · org_pro_12",
    rightMono: true,
  },
  {
    attr: "Trail before the throw",
    left: "none",
    leftMono: false,
    right: "navigate → load invoice → submit",
    rightMono: false,
  },
];
---

<Figure
  caption="The same production failure, as Vercel sees it and as Sentry sees it."
>
  <div class="svl not-content">
    {/* Header row: the two surfaces, with a spacer over the centre spine */}
    <div class="svl-grid">
      <div class="svl-head svl-head--left">Vercel function log</div>
      <div class="svl-spine-head" aria-hidden="true"></div>
      <div class="svl-head svl-head--right">Sentry issue</div>

      {
        rows.map((r) => (
          <>
            <div class="svl-cell svl-cell--left">
              <span class={r.leftMono ? "svl-mono" : "svl-text"}>{r.left}</span>
            </div>
            <div class="svl-attr">{r.attr}</div>
            <div class="svl-cell svl-cell--right">
              {r.rightCode ? (
                <span class="svl-text">
                  tagged <code class="svl-code">{r.rightCode}</code>
                </span>
              ) : (
                <span class={r.rightMono ? "svl-mono" : "svl-text"}>
                  {r.right}
                </span>
              )}
            </div>
          </>
        ))
      }
    </div>
  </div>
</Figure>

<style>
  .svl {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  .svl-grid {
    display: grid;
    /* A fixed, modest centre spine so the long "Trail before the throw"
       label can't starve the two value columns; the label wraps instead. */
    grid-template-columns: minmax(0, 1fr) 116px minmax(0, 1fr);
    align-items: stretch;
    column-gap: 12px;
    row-gap: 8px;
    margin: 0;
  }

  /* ---- Column headers -------------------------------------------------- */

  .svl-head {
    margin: 0;
    padding: 8px 12px;
    border-radius: 9px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-align: center;
    box-sizing: border-box;
  }

  .svl-head--left {
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-5) 22%, transparent);
    color: var(--sl-color-gray-2);
  }

  .svl-head--right {
    border: 1px solid
      color-mix(in srgb, var(--sl-color-green, #16a34a) 50%, transparent);
    background: color-mix(in srgb, var(--sl-color-green, #16a34a) 12%, transparent);
    color: var(--sl-color-green-high, #16a34a);
  }

  /* The centre column above the rows is empty — keeps the spine clear. */
  .svl-spine-head {
    margin: 0;
  }

  /* ---- Attribute spine (centre column) -------------------------------- */

  .svl-attr {
    margin: 0;
    align-self: center;
    padding: 0 4px;
    text-align: center;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.25;
    color: var(--sl-color-gray-3);
  }

  /* ---- Value cells ----------------------------------------------------- */

  .svl-cell {
    margin: 0;
    display: flex;
    align-items: center;
    padding: 10px 12px;
    border-radius: 9px;
    box-sizing: border-box;
    min-width: 0;
    font-size: 13px;
    line-height: 1.3;
  }

  /* Left = absence: muted grey, flat. */
  .svl-cell--left {
    justify-content: flex-end;
    text-align: right;
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-5) 14%, transparent);
    color: var(--sl-color-gray-3);
  }

  /* Right = presence: subtle positive green accent. */
  .svl-cell--right {
    justify-content: flex-start;
    text-align: left;
    border: 1px solid
      color-mix(in srgb, var(--sl-color-green, #16a34a) 35%, transparent);
    background: color-mix(in srgb, var(--sl-color-green, #16a34a) 8%, transparent);
    color: var(--sl-color-text);
  }

  .svl-text {
    margin: 0;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .svl-mono {
    margin: 0;
    min-width: 0;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12px;
    overflow-wrap: anywhere;
  }

  /* Inline release tag, styled as a small monospace pill. */
  .svl-code {
    margin: 0;
    padding: 1px 6px;
    border-radius: 5px;
    border: 1px solid
      color-mix(in srgb, var(--sl-color-green, #16a34a) 40%, transparent);
    background: color-mix(in srgb, var(--sl-color-green, #16a34a) 16%, transparent);
    color: var(--sl-color-green-high, #16a34a);
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }

  /* Narrow viewports: drop the centre spine into each row as a label above
     the two cells, stacking the comparison. */
  @media (max-width: 540px) {
    .svl-grid {
      grid-template-columns: 1fr 1fr;
      row-gap: 6px;
    }

    .svl-spine-head {
      display: none;
    }

    .svl-attr {
      grid-column: 1 / -1;
      text-align: left;
      margin: 8px 0 0;
      white-space: normal;
    }

    .svl-cell--left {
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>
