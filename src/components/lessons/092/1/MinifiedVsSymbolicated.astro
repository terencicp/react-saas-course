---
// minified-vs-symbolicated — what source maps + releases buy you, Lesson 92.1.
//
// Verification made visual: the SAME stack frame before and after Sentry does
// its enrichment. Left is the raw minified frame the server emits — a
// `chunk-abc123.js:1:42` that names nothing and is dated to nothing. Right is
// the symbolicated frame Sentry shows — rebound to your `.ts` source, file and
// line, plus a release pill that dates it to a specific deploy.
//
// Two columns side-by-side so the eye reads the transform across the gap
// (before → after); they collapse to stacked rows on narrow viewports. The
// left column is muted/grey to read as ABSENCE of meaning; the right column
// carries the same positive-green accent the sibling SentryVsLogSurface figure
// uses for PRESENCE, so the two figures in this lesson speak one color
// language. Pure HTML + CSS, devtools-inspectable; `not-content` + a `margin: 0`
// reset on every inner element defeat Starlight's prose-margin selector, and
// Starlight theme variables keep it native in light and dark.

import Figure from "../../../figures/Figure.astro";

// Each frame is a list of lines so the first (the throwing frame) can be
// emphasised over the lower caller frames.
const before = [
  { text: "Function.t [as h] (chunk-abc123.js:1:42)", lead: true },
  { text: "at r (chunk-abc123.js:1:1180)", lead: false },
];

const after = [
  { text: "createInvoice (src/app/_lib/actions/create-invoice.ts:34:11)", lead: true },
  { text: "at authedAction (src/lib/auth/authed-action.ts:58:9)", lead: false },
];
---

<Figure
  caption="Source maps rebind the frame to your source; the release tag dates it to a deploy."
>
  <div class="mvs not-content">
    <div class="mvs-grid">
      {/* Before — the raw minified frame the server emits. */}
      <div class="mvs-col mvs-col--before">
        <div class="mvs-head mvs-head--before">Before — what the server emits</div>
        <pre class="mvs-frame mvs-frame--before">{
          before.map((line) => (
            <div class={line.lead ? "mvs-line mvs-line--lead" : "mvs-line"}>
              {line.text}
            </div>
          ))
        }</pre>
        <div class="mvs-meta mvs-meta--muted">no release</div>
      </div>

      {/* The transform glyph sitting in the gap. */}
      <div class="mvs-arrow" aria-hidden="true">→</div>

      {/* After — the symbolicated frame Sentry shows, with a release pill. */}
      <div class="mvs-col mvs-col--after">
        <div class="mvs-head mvs-head--after">After — what Sentry shows</div>
        <pre class="mvs-frame mvs-frame--after">{
          after.map((line) => (
            <div class={line.lead ? "mvs-line mvs-line--lead" : "mvs-line"}>
              {line.text}
            </div>
          ))
        }</pre>
        <div class="mvs-meta">
          <span class="mvs-pill">
            release <code class="mvs-pill-code">a1b2c3d</code> · first seen 2d ago
          </span>
        </div>
      </div>
    </div>
  </div>
</Figure>

<style>
  .mvs {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  .mvs-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: stretch;
    column-gap: 14px;
    margin: 0;
  }

  /* ---- Columns -------------------------------------------------------- */

  .mvs-col {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  /* ---- Column headers ------------------------------------------------- */

  .mvs-head {
    margin: 0;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .mvs-head--before {
    color: var(--sl-color-gray-3);
  }

  .mvs-head--after {
    color: var(--sl-color-green-high, #16a34a);
  }

  /* ---- Frame blocks --------------------------------------------------- */

  .mvs-frame {
    margin: 0;
    padding: 12px 14px;
    border-radius: 9px;
    box-sizing: border-box;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12.5px;
    line-height: 1.4;
    white-space: normal;
    overflow: visible;
  }

  /* Before = absence of meaning: muted grey, flat. */
  .mvs-frame--before {
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-5) 14%, transparent);
    color: var(--sl-color-gray-3);
  }

  /* After = presence: subtle positive green accent. */
  .mvs-frame--after {
    border: 1px solid
      color-mix(in srgb, var(--sl-color-green, #16a34a) 35%, transparent);
    background: color-mix(in srgb, var(--sl-color-green, #16a34a) 8%, transparent);
    color: var(--sl-color-text);
  }

  .mvs-line {
    margin: 0;
    overflow-wrap: anywhere;
  }

  /* The throwing frame: full weight; caller frames sit back. */
  .mvs-frame--before .mvs-line--lead {
    color: var(--sl-color-gray-2);
  }

  .mvs-frame--after .mvs-line--lead {
    color: var(--sl-color-green-high, #16a34a);
    font-weight: 600;
  }

  .mvs-frame--before .mvs-line:not(.mvs-line--lead),
  .mvs-frame--after .mvs-line:not(.mvs-line--lead) {
    opacity: 0.7;
    padding-left: 6px;
  }

  /* ---- Transform glyph ------------------------------------------------ */

  .mvs-arrow {
    margin: 0;
    align-self: center;
    font-size: 22px;
    line-height: 1;
    color: var(--sl-color-gray-4);
  }

  /* ---- Meta line under each frame ------------------------------------- */

  .mvs-meta {
    margin: 0;
    min-height: 22px;
    display: flex;
    align-items: center;
  }

  .mvs-meta--muted {
    font-size: 11px;
    font-style: italic;
    color: var(--sl-color-gray-4);
  }

  .mvs-pill {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid
      color-mix(in srgb, var(--sl-color-green, #16a34a) 40%, transparent);
    background: color-mix(in srgb, var(--sl-color-green, #16a34a) 12%, transparent);
    color: var(--sl-color-green-high, #16a34a);
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
  }

  .mvs-pill-code {
    margin: 0;
    padding: 0;
    background: transparent;
    border: 0;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 11px;
    font-weight: 700;
    color: inherit;
  }

  /* Narrow viewports: stack the two columns, drop the horizontal arrow. */
  @media (max-width: 560px) {
    .mvs-grid {
      grid-template-columns: 1fr;
      row-gap: 10px;
    }

    .mvs-arrow {
      transform: rotate(90deg);
      justify-self: center;
    }
  }
</style>
