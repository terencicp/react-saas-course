---
// breadcrumb-trail-vs-log-stream — the breadcrumb-vs-log distinction, Lesson 92.1.
//
// The section's whole point made literal: a breadcrumb trail is BOUNDED and
// tied to ONE throw; a log stream is UNBOUNDED and indifferent to throws. Two
// columns side-by-side so the eye reads the contrast across the gap.
//
// Left — "Breadcrumbs (this event)": a short, fixed stack of entries inside a
// visible bracket/box, terminating in a red exception marker. The box edge and
// the terminus are the signal: this trail starts somewhere, ends at the throw,
// and is gone once it fires.
//
// Right — "Logs (always on)": a taller list of timestamped lines that fade out
// at BOTH ends (ellipses top and bottom) — no start, no end, no throw required.
// The stream runs whether or not anything ever breaks.
//
// Colour language: breadcrumbs lead to an exception, so the column carries a
// red accent and a red terminus (distinct from the green "Sentry enrichment"
// accent the sibling figures use). The log column is neutral/blue —
// informational, ongoing. One `error` line inside the stream is tinted red to
// show that even when a log records an error, the stream keeps flowing past it.
//
// Pure HTML + CSS, devtools-inspectable; `not-content` + a `margin: 0` reset on
// every inner element defeat Starlight's prose-margin selector, and Starlight
// theme variables keep it native in light and dark.

import Figure from "../../../figures/Figure.astro";

// The bounded breadcrumb trail — a fixed handful of entries, last is the throw.
const breadcrumbs = [
  { text: "navigate  /invoices/123", throw: false },
  { text: "fetch  GET /api/invoice/123  200", throw: false },
  { text: "breadcrumb: loaded invoice for billing", throw: false },
  { text: 'click  "Pay"', throw: false },
  { text: "TypeError: cannot read 'amount' of null", throw: true },
];

// The unbounded log stream — timestamped lines, one of them an error, all of
// which exist regardless of any throw. Ellipses at both ends signal it runs on.
const logs = [
  { time: "14:31:58", level: "info", body: "invoice.list  org_12", error: false },
  { time: "14:32:01", level: "info", body: "invoice.get   org_12", error: false },
  { time: "14:32:04", level: "error", body: "invoice.pay   org_12", error: true },
  { time: "14:32:09", level: "info", body: "invoice.list  org_44", error: false },
];
---

<Figure
  caption="Breadcrumbs are a bounded trail that ships with one error. Logs run whether or not anything throws."
>
  <div class="btl not-content">
    <div class="btl-grid">
      {/* ---- Left: the bounded breadcrumb trail ----------------------- */}
      <div class="btl-col">
        <div class="btl-head btl-head--crumb">Breadcrumbs (this event)</div>
        {/* The bracket/box IS the boundedness signal. */}
        <div class="btl-trail">
          {
            breadcrumbs.map((c) =>
              c.throw ? (
                <div class="btl-crumb btl-crumb--throw">
                  <span class="btl-marker btl-marker--throw" aria-hidden="true">
                    &#x2715;
                  </span>
                  <span class="btl-crumb-text">{c.text}</span>
                </div>
              ) : (
                <div class="btl-crumb">
                  <span class="btl-marker" aria-hidden="true">&#x2022;</span>
                  <span class="btl-crumb-text">{c.text}</span>
                </div>
              ),
            )
          }
        </div>
        <div class="btl-foot btl-foot--crumb">
          Bounded · ships with this one error · then dropped
        </div>
      </div>

      {/* ---- Right: the unbounded log stream -------------------------- */}
      <div class="btl-col">
        <div class="btl-head btl-head--log">Logs (always on)</div>
        <div class="btl-stream">
          <div class="btl-ellipsis" aria-hidden="true">&#x22EF;</div>
          {
            logs.map((l) => (
              <div class={l.error ? "btl-log btl-log--error" : "btl-log"}>
                <span class="btl-time">{l.time}</span>
                <span class={l.error ? "btl-level btl-level--error" : "btl-level"}>
                  {l.level}
                </span>
                <span class="btl-body">{l.body}</span>
              </div>
            ))
          }
          <div class="btl-ellipsis" aria-hidden="true">&#x22EF;</div>
        </div>
        <div class="btl-foot btl-foot--log">
          Unbounded · runs whether or not anything throws
        </div>
      </div>
    </div>
  </div>
</Figure>

<style>
  .btl {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  .btl-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: start;
    column-gap: 20px;
    margin: 0;
  }

  .btl-col {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  /* ---- Column headers ------------------------------------------------- */

  .btl-head {
    margin: 0;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .btl-head--crumb {
    color: var(--sl-color-red-high, #dc2626);
  }

  .btl-head--log {
    color: var(--sl-color-blue-high, #2563eb);
  }

  /* ---- Left: bounded breadcrumb trail --------------------------------- */

  /* The visible box is the boundedness signal — a closed container with a
     defined top and a defined bottom (the throw). */
  .btl-trail {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px 14px;
    border-radius: 10px;
    box-sizing: border-box;
    border: 1.5px solid
      color-mix(in srgb, var(--sl-color-red, #dc2626) 45%, transparent);
    background: color-mix(in srgb, var(--sl-color-red, #dc2626) 7%, transparent);
  }

  .btl-crumb {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
    min-width: 0;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12px;
    line-height: 1.4;
    color: var(--sl-color-text);
  }

  .btl-marker {
    margin: 0;
    flex: none;
    font-size: 11px;
    color: var(--sl-color-gray-3);
  }

  .btl-crumb-text {
    margin: 0;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  /* The terminus: the throw the whole trail leads to. */
  .btl-crumb--throw {
    margin: 4px 0 0;
    padding: 6px 8px;
    border-radius: 7px;
    background: color-mix(in srgb, var(--sl-color-red, #dc2626) 15%, transparent);
    color: var(--sl-color-red-high, #dc2626);
    font-weight: 600;
  }

  .btl-marker--throw {
    color: var(--sl-color-red-high, #dc2626);
    font-weight: 700;
  }

  /* ---- Right: unbounded log stream ------------------------------------ */

  .btl-stream {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px 14px;
    border-radius: 10px;
    box-sizing: border-box;
    /* Dashed, open edges read as "this keeps going" — not a closed box. */
    border: 1px dashed var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-5) 8%, transparent);
  }

  .btl-ellipsis {
    margin: 0;
    text-align: center;
    font-size: 16px;
    line-height: 1;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-4);
  }

  .btl-log {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
    min-width: 0;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12px;
    line-height: 1.4;
    color: var(--sl-color-text);
  }

  /* The lines nearest the ellipses fade, reinforcing the open-ended read. */
  .btl-stream .btl-log:first-of-type {
    opacity: 0.62;
  }

  .btl-stream .btl-log:last-of-type {
    opacity: 0.62;
  }

  .btl-time {
    margin: 0;
    flex: none;
    color: var(--sl-color-gray-3);
  }

  .btl-level {
    margin: 0;
    flex: none;
    width: 38px;
    color: var(--sl-color-blue-high, #2563eb);
    font-weight: 600;
  }

  .btl-level--error {
    color: var(--sl-color-red-high, #dc2626);
  }

  .btl-log--error {
    /* Even an error line is just another line — the stream flows past it. */
    color: var(--sl-color-red-high, #dc2626);
  }

  .btl-body {
    margin: 0;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  /* ---- Footer captions per column ------------------------------------- */

  .btl-foot {
    margin: 0;
    font-size: 11px;
    line-height: 1.3;
    font-style: italic;
  }

  .btl-foot--crumb {
    color: color-mix(in srgb, var(--sl-color-red-high, #dc2626) 80%, var(--sl-color-gray-2));
  }

  .btl-foot--log {
    color: var(--sl-color-gray-3);
  }

  /* Narrow viewports: stack the two columns. */
  @media (max-width: 560px) {
    .btl-grid {
      grid-template-columns: 1fr;
      row-gap: 18px;
    }
  }
</style>
