---
// LogStreamsCompare — Chapter 092 Lesson 3 ("The 3am rule and PII exclusion").
//
// Closing figure for the "two streams, two rule sets" section. The operational
// logger built this chapter is NOT the audit log from the security chapter, and
// conflating them breaks both. This is a row-aligned, side-by-side comparison of
// the two streams across the four axes that actually distinguish them, so the
// contrast reads horizontally: pick a row, see how each stream answers it.
//
//   axis        Operational log (this chapter)   Audit log (security chapter)
//   Durability  ephemeral, best-effort           durable, transactional
//   Retention   ~30 days                         per legal basis (longer)
//   PII         redact aggressively              preserves stripped payloads
//   Audience    on-call operator                 compliance / security review
//
// Layout: a 3-column CSS grid — a narrow axis-label rail on the left, then one
// column per stream — so every row aligns across both streams. A plain table
// would align rows too but reads flat and can't color-code the two streams as
// distinct identities; two separate Cards would lose the per-row alignment that
// IS the point. The grid gets both.
//
// Pure HTML+CSS per the diagrams guide (a static row-aligned comparison, not a
// graph). Modeled on this lesson's sibling SafeRedactSplit: `not-content` plus a
// margin:0 reset on every node defeats Starlight's injected prose margins. Goes
// inside <Figure>, which the MDX supplies. Static visual, default `expandable`.
//
// Colour language: the two streams get distinct hues so the eye tracks a column
// as one identity — amber (#d97706) = operational (ephemeral, warm, short-lived);
// indigo (#4f46e5) = audit (durable, cold, archival). Saturated mid-tones reused
// in both themes since the hue itself is the signal; tints via color-mix so they
// track the page background.

const axes = [
	{
		key: "Durability",
		op: "Ephemeral, best-effort",
		opSub: "stdout → drain",
		audit: "Durable, transactional",
		auditSub: "a DB write inside the transaction",
	},
	{
		key: "Retention",
		op: "~30 days",
		opSub: "rolls off on a timer",
		audit: "Per legal basis",
		auditSub: "longer, kept as required",
	},
	{
		key: "PII",
		op: "Redact aggressively",
		opSub: "secrets & user-side PII stripped",
		audit: "Preserves payloads",
		auditSub: "keeps what the op log strips",
	},
	{
		key: "Audience",
		op: "On-call operator",
		opSub: "diagnose the incident",
		audit: "Compliance / security",
		auditSub: "answer the regulator",
	},
];

const terminalIcon = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>`;
const ledgerIcon = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><path d="M5 3h11a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5z"></path><path d="M9 3v18"></path><line x1="13" y1="8" x2="15" y2="8"></line><line x1="13" y1="12" x2="15" y2="12"></line></svg>`;
---

<div class="lsc not-content">
	{/* ── Header row: the two stream identities ── */}
	<div class="lsc-corner" aria-hidden="true"></div>
	<div class="lsc-head lsc-head--op">
		<span class="lsc-mark lsc-mark--op">
			<Fragment set:html={terminalIcon} />
		</span>
		<div class="lsc-head-text">
			<span class="lsc-head-title">Operational log</span>
			<span class="lsc-head-sub">this chapter</span>
		</div>
	</div>
	<div class="lsc-head lsc-head--audit">
		<span class="lsc-mark lsc-mark--audit">
			<Fragment set:html={ledgerIcon} />
		</span>
		<div class="lsc-head-text">
			<span class="lsc-head-title">Audit log</span>
			<span class="lsc-head-sub">the security chapter</span>
		</div>
	</div>

	{/* ── One aligned row per axis ── */}
	{
		axes.map((row) => (
			<>
				<div class="lsc-axis">{row.key}</div>
				<div class="lsc-cell lsc-cell--op">
					<span class="lsc-cell-main">{row.op}</span>
					<span class="lsc-cell-sub">{row.opSub}</span>
				</div>
				<div class="lsc-cell lsc-cell--audit">
					<span class="lsc-cell-main">{row.audit}</span>
					<span class="lsc-cell-sub">{row.auditSub}</span>
				</div>
			</>
		))
	}
</div>

<style>
	.lsc {
		display: grid;
		grid-template-columns: minmax(72px, auto) 1fr 1fr;
		gap: 8px;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		/* Per-stream hues — the hue is the signal, identical in both themes. */
		--lsc-op: #d97706; /* amber — ephemeral, warm, short-lived */
		--lsc-audit: #4f46e5; /* indigo — durable, cold, archival */
	}

	/* ── Header cells ───────────────────────────────────────────────────── */
	.lsc-corner {
		margin: 0;
	}
	.lsc-head {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 10px 13px;
		border-radius: 10px 10px 0 0;
		margin: 0;
	}
	.lsc-head--op {
		border: 1.5px solid color-mix(in srgb, var(--lsc-op) 50%, transparent);
		border-bottom-width: 0;
		background: color-mix(in srgb, var(--lsc-op) 12%, transparent);
	}
	.lsc-head--audit {
		border: 1.5px solid color-mix(in srgb, var(--lsc-audit) 48%, transparent);
		border-bottom-width: 0;
		background: color-mix(in srgb, var(--lsc-audit) 12%, transparent);
	}

	.lsc-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		flex: 0 0 auto;
		border-radius: 7px;
		color: #ffffff;
		margin: 0;
	}
	.lsc-mark--op {
		background: var(--lsc-op);
	}
	.lsc-mark--audit {
		background: var(--lsc-audit);
	}

	.lsc-head-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
		min-width: 0;
		margin: 0;
	}
	.lsc-head-title {
		font-size: 14px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.lsc-head-sub {
		font-size: 11px;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── Axis label rail ────────────────────────────────────────────────── */
	.lsc-axis {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		text-align: right;
		padding: 0 4px 0 0;
		font-size: 11.5px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── Body cells ─────────────────────────────────────────────────────── */
	.lsc-cell {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
		padding: 9px 13px;
		border-left-width: 1.5px;
		border-right-width: 1.5px;
		border-left-style: solid;
		border-right-style: solid;
		margin: 0;
	}
	.lsc-cell--op {
		border-color: color-mix(in srgb, var(--lsc-op) 50%, transparent);
		background: color-mix(in srgb, var(--lsc-op) 6%, transparent);
	}
	.lsc-cell--audit {
		border-color: color-mix(in srgb, var(--lsc-audit) 48%, transparent);
		background: color-mix(in srgb, var(--lsc-audit) 6%, transparent);
	}
	/* Hairline separators between rows, drawn on the top of each cell after the
	   first so the columns read as continuous panels with ruled rows. */
	.lsc-cell {
		border-top: 1px solid transparent;
	}
	.lsc-cell--op {
		border-top-color: color-mix(in srgb, var(--lsc-op) 22%, transparent);
	}
	.lsc-cell--audit {
		border-top-color: color-mix(in srgb, var(--lsc-audit) 22%, transparent);
	}
	/* Close the bottom edge of each column on the last row. */
	.lsc-cell:nth-last-child(2),
	.lsc-cell:last-child {
		border-bottom-width: 1.5px;
		border-bottom-style: solid;
		border-radius: 0 0 10px 10px;
	}
	.lsc-cell--op:nth-last-child(2) {
		border-bottom-color: color-mix(in srgb, var(--lsc-op) 50%, transparent);
	}
	.lsc-cell--audit:last-child {
		border-bottom-color: color-mix(in srgb, var(--lsc-audit) 48%, transparent);
	}

	.lsc-cell-main {
		font-size: 13px;
		font-weight: 650;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.lsc-cell--op .lsc-cell-main {
		color: color-mix(in srgb, var(--lsc-op) 78%, var(--sl-color-text));
	}
	.lsc-cell--audit .lsc-cell-main {
		color: color-mix(in srgb, var(--lsc-audit) 80%, var(--sl-color-text));
	}
	.lsc-cell-sub {
		font-size: 11.5px;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: the axis rail crushes the two stream columns. Collapse
	   to a single column — the source order (axis, op cell, audit cell, repeated
	   per row) stacks cleanly into per-axis trios, the axis label leading each.
	   The two stream headers fall to the top and read as a shared legend. */
	@media (max-width: 560px) {
		.lsc {
			grid-template-columns: 1fr;
			gap: 6px;
		}
		.lsc-corner {
			display: none;
		}
		.lsc-head {
			border-radius: 10px;
			border-bottom-width: 1.5px;
		}
		.lsc-axis {
			justify-content: flex-start;
			text-align: left;
			padding: 10px 0 1px;
		}
		.lsc-cell {
			border-width: 1.5px;
			border-style: solid;
			border-radius: 8px;
		}
		.lsc-cell--op {
			border-color: color-mix(in srgb, var(--lsc-op) 50%, transparent);
		}
		.lsc-cell--audit {
			border-color: color-mix(in srgb, var(--lsc-audit) 48%, transparent);
		}
	}
</style>
