---
// SafeRedactSplit — Chapter 092 Lesson 3 ("The 3am rule and PII exclusion").
//
// The "scalpel" figure for the operator/user split, applied to logging.
// One log object, cut down the middle: the operator-side fields go to the log,
// the user-side fields get redacted. The whole point of the picture is the
// counterintuitive placement — `email` and the internal IDs land on the GREEN
// (safe) side, not the red one. Beginners over-correct after hearing "GDPR"
// and redact identifiers too, which blinds the operator; this figure is the
// mental image they recall at a call site to stop that reflex.
//
// Two columns separated by a labeled divider:
//   Operator side — LOG IT   (green, check) — userId, email, orgId, plan, role,
//                                              requestId, validated input, stack, code
//   User side — REDACT       (red, x)       — password, token, Authorization,
//                                              full name, address, phone, full IP,
//                                              card number, special-category data
// The divider carries the caption "the split, enforced at serialize time."
// The two highest-risk-of-mis-sorting chips (email, userId/orgId) get a subtle
// emphasis ring so the eye lands on them first on the green side.
//
// Pure HTML+CSS per the diagrams guide (a static two-column annotated
// illustration, not a graph engine), modeled on this chapter family's
// 058/2 TokenTrustBoundaries. `not-content` + a margin:0 reset on every node
// defeats Starlight's injected prose margins. Goes inside <Figure>, which the
// MDX supplies along with the caption. Static visual, so the Figure keeps its
// default `expandable`.
//
// Colour language: green (#16a34a) = operator-side, safe to log; red (#dc2626)
// = user-side, must be redacted. Saturated mid-tones reused verbatim in light
// + dark since the colour itself is the signal; tints derived with color-mix so
// they track the page background.

const checkIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
const xIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>`;

// `code: true` renders the chip in monospace (it's a field/key name).
// `emphasis: true` adds the "look here first" ring — reserved for the fields
// students most often mis-sort onto the redact side.
const safe = [
	{ label: "userId", code: true, emphasis: true },
	{ label: "email", code: true, emphasis: true },
	{ label: "orgId", code: true, emphasis: false },
	{ label: "plan", code: true, emphasis: false },
	{ label: "role", code: true, emphasis: false },
	{ label: "requestId", code: true, emphasis: false },
	{ label: "validated request shape", code: false, emphasis: false },
	{ label: "Error.stack", code: true, emphasis: false },
	{ label: "error code", code: false, emphasis: false },
];

const redact = [
	{ label: "password", code: true },
	{ label: "token", code: true },
	{ label: "Authorization header", code: false },
	{ label: "full name", code: false },
	{ label: "postal address", code: false },
	{ label: "phone", code: false },
	{ label: "IP (full)", code: false },
	{ label: "card number", code: false },
	{ label: "special-category data", code: false },
];
---

<div class="srs not-content">
	{/* ── Operator side — LOG IT (green / safe) ── */}
	<div class="srs-col srs-col--log">
		<div class="srs-head">
			<span class="srs-mark srs-mark--check">
				<Fragment set:html={checkIcon} />
			</span>
			<div class="srs-head-text">
				<span class="srs-head-title">Operator side &mdash; LOG IT</span>
				<span class="srs-head-sub">diagnostic, not decorative</span>
			</div>
		</div>
		<div class="srs-chips">
			{
				safe.map((item) => (
					<span
						class:list={[
							"srs-chip srs-chip--safe",
							{ "srs-chip--code": item.code },
							{ "srs-chip--emph": item.emphasis },
						]}
					>
						{item.label}
					</span>
				))
			}
		</div>
	</div>

	{/* ── The divider, labeled: this is where the cut happens ── */}
	<div class="srs-divider" aria-hidden="true">
		<span class="srs-divider-label">the split, enforced at serialize time</span>
	</div>

	{/* ── User side — REDACT (red / unsafe) ── */}
	<div class="srs-col srs-col--redact">
		<div class="srs-head">
			<span class="srs-mark srs-mark--x">
				<Fragment set:html={xIcon} />
			</span>
			<div class="srs-head-text">
				<span class="srs-head-title">User side &mdash; REDACT</span>
				<span class="srs-head-sub">secrets &amp; user-side PII</span>
			</div>
		</div>
		<div class="srs-chips">
			{
				redact.map((item) => (
					<span
						class:list={[
							"srs-chip srs-chip--redact",
							{ "srs-chip--code": item.code },
						]}
					>
						{item.label}
					</span>
				))
			}
		</div>
	</div>
</div>

<style>
	.srs {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: stretch;
		gap: 0;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		/* Saturated mid-tones — the colour is the signal, identical in both themes. */
		--srs-green: #16a34a;
		--srs-red: #dc2626;
	}

	/* ── Column shell ───────────────────────────────────────────────────── */
	.srs-col {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		min-width: 0;
		border-radius: 12px;
		padding: 12px 14px 14px;
		margin: 0;
	}
	.srs-col--log {
		border: 1.5px solid color-mix(in srgb, var(--srs-green) 55%, transparent);
		background: color-mix(in srgb, var(--srs-green) 8%, transparent);
	}
	.srs-col--redact {
		border: 1.5px solid color-mix(in srgb, var(--srs-red) 50%, transparent);
		background: color-mix(in srgb, var(--srs-red) 7%, transparent);
	}

	/* ── Column header ──────────────────────────────────────────────────── */
	.srs-head {
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 0 0 11px;
		margin: 0 0 11px;
		border-bottom: 1px solid transparent;
	}
	.srs-col--log .srs-head {
		border-bottom-color: color-mix(in srgb, var(--srs-green) 32%, transparent);
	}
	.srs-col--redact .srs-head {
		border-bottom-color: color-mix(in srgb, var(--srs-red) 30%, transparent);
	}

	.srs-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		flex: 0 0 auto;
		border-radius: 999px;
		color: #ffffff;
		margin: 0;
	}
	.srs-mark--check {
		background: var(--srs-green);
	}
	.srs-mark--x {
		background: var(--srs-red);
	}

	.srs-head-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
		min-width: 0;
		margin: 0;
	}
	.srs-head-title {
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.srs-head-sub {
		font-size: 11px;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── Chip cloud ─────────────────────────────────────────────────────── */
	.srs-chips {
		display: flex;
		flex-wrap: wrap;
		align-content: flex-start;
		gap: 7px;
		flex: 1 1 auto;
		margin: 0;
	}
	.srs-chip {
		box-sizing: border-box;
		display: inline-flex;
		align-items: center;
		padding: 4px 9px;
		border-radius: 7px;
		font-size: 12px;
		font-weight: 600;
		line-height: 1.2;
		border: 1px solid transparent;
		margin: 0;
	}
	.srs-chip--code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-weight: 700;
	}
	.srs-chip--safe {
		color: color-mix(in srgb, var(--srs-green) 70%, var(--sl-color-text));
		background: color-mix(in srgb, var(--srs-green) 13%, transparent);
		border-color: color-mix(in srgb, var(--srs-green) 30%, transparent);
	}
	.srs-chip--redact {
		color: color-mix(in srgb, var(--srs-red) 72%, var(--sl-color-text));
		background: color-mix(in srgb, var(--srs-red) 12%, transparent);
		border-color: color-mix(in srgb, var(--srs-red) 28%, transparent);
	}
	/* The counterintuitive pair — email + userId — gets a lift so the eye lands
	   here first and registers "these are SAFE" before reading anything else. */
	.srs-chip--emph {
		color: #ffffff;
		background: var(--srs-green);
		border-color: var(--srs-green);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--srs-green) 22%, transparent);
	}

	/* ── The divider — the scalpel line, with its straddling label ──────── */
	.srs-divider {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		flex: 0 0 auto;
		margin: 0;
	}
	.srs-divider::before {
		content: "";
		position: absolute;
		top: 6px;
		bottom: 6px;
		left: 50%;
		width: 0;
		border-left: 2px dashed var(--sl-color-gray-4, #94a3b8);
		transform: translateX(-50%);
	}
	.srs-divider-label {
		position: relative;
		writing-mode: vertical-rl;
		text-orientation: mixed;
		transform: rotate(180deg);
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		background: var(--sl-color-bg-sidebar);
		padding: 8px 0;
		margin: 0;
		white-space: nowrap;
	}

	/* Narrow viewports: side-by-side columns crush, and a vertical divider
	   makes no sense stacked. Switch to a stacked layout with a horizontal rule. */
	@media (max-width: 640px) {
		.srs {
			grid-template-columns: 1fr;
			gap: 12px;
		}
		.srs-divider {
			width: auto;
			height: 22px;
		}
		.srs-divider::before {
			top: 50%;
			bottom: auto;
			left: 10px;
			right: 10px;
			width: auto;
			border-left: 0;
			border-top: 2px dashed var(--sl-color-gray-4, #94a3b8);
			transform: translateY(-50%);
		}
		.srs-divider-label {
			writing-mode: horizontal-tb;
			transform: none;
			padding: 0 10px;
		}
	}
</style>
