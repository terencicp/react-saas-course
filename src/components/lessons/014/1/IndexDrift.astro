---
// Index-drift walkthrough — one frame of the buggy live-collection loop, used
// inside <DiagramSequence>. Scrubbing the three frames makes the skip visible
// in TIME, which prose alone can't do.
//
// The buggy loop (from the CodeVariants block just above this diagram):
//   for (let i = 0; i < list.children.length; i++) {
//     if (list.children[i].classList.contains('done')) list.children[i].remove();
//   }
//
// The collection starts [A(done), B(done), C]. Removing A at index 0 shifts B
// down to index 0 and C to index 1 — but `i` has already advanced to 1, so the
// loop reads C and steps right over B. B survives even though it is `.done`.
//
// `step` selects the frame:
//   0  Start            i=0, caret under A, A flagged for removal (red)
//   1  After removing A i=1, collection re-indexed, caret on C, B skipped (orange)
//   2  After checking C i=2 past length, loop ends, B still skipped
//
// Pure HTML + CSS, matching the lesson's other figures: `not-content`, theme
// gray variables for chrome, saturated mid-tones for signal (red-600 for the
// .done flag, amber-500 for the skipped victim). `margin: 0` reset on every
// inner element defeats Starlight's prose-margin selector.

interface Props {
  step: 0 | 1 | 2;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const DONE = "#dc2626"; // red-600 — flagged .done / about to be removed
const SKIP = "#f59e0b"; // amber-500 — the victim the loop skipped

// Per-frame state. `cells` is the live collection as the loop sees it now.
// `caret` is the index `i` points at (null = past the end).
type Tone = "done" | "skip" | "plain";
interface Cell {
  label: string;
  tone: Tone;
}

const frames: Record<
  Props["step"],
  {
    i: number;
    caretOnIndex: number | null;
    ghost: string | null; // a removed cell shown faded to anchor the shift
    cells: Cell[];
    note: string; // short label on the loop-state readout
  }
> = {
  0: {
    i: 0,
    caretOnIndex: 0,
    ghost: null,
    cells: [
      { label: "A", tone: "done" },
      { label: "B", tone: "done" },
      { label: "C", tone: "plain" },
    ],
    note: "A is .done → remove it",
  },
  1: {
    i: 1,
    caretOnIndex: 1,
    ghost: "A",
    cells: [
      { label: "B", tone: "skip" },
      { label: "C", tone: "plain" },
    ],
    note: "i jumped past B",
  },
  2: {
    i: 2,
    caretOnIndex: null,
    ghost: "A",
    cells: [
      { label: "B", tone: "skip" },
      { label: "C", tone: "plain" },
    ],
    note: "i ≥ length → stop",
  },
};

const frame = frames[step];
const length = frame.cells.length;

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 16px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// Loop-state readout: a code pill showing the live `i` and `length` plus a
// short note on what the loop is doing this tick.
const readout = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "justify-content: center",
  "gap: 8px 10px",
  mono,
  "font-size: 13px",
  "line-height: 1",
].join("; ");

const pill = [
  reset,
  "display: inline-flex",
  "align-items: baseline",
  "gap: 5px",
  "padding: 5px 9px",
  "border-radius: 7px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "white-space: nowrap",
].join("; ");

const pillKey = `${reset}; ${mono}; color: var(--sl-color-gray-2); font-size: 11.5px;`;
const pillVal = `${reset}; ${mono}; color: var(--sl-color-gray-1); font-weight: 700;`;

const note = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-style: italic",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
].join("; ");

// The collection track: a row of self-contained columns, each stacking its
// index label, box, and caret vertically. Each column is its own flex stack
// (rather than shared grid rows) so the caret always lands dead-centre under
// its own box regardless of how many columns precede it.
const track = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: flex-start",
  "justify-content: center",
  "gap: 14px",
].join("; ");

// One column = index label (top) · box (middle) · caret slot (bottom).
const col = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 6px",
].join("; ");

// Fixed-height caret slot so all columns share a baseline whether or not the
// caret is present in that column.
const caretSlot = [
  reset,
  "height: 34px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: flex-start",
].join("; ");

const indexLabel = [
  reset,
  mono,
  "font-size: 11px",
  "color: var(--sl-color-gray-3)",
  "line-height: 1",
].join("; ");

const boxBase = [
  reset,
  "width: 64px",
  "height: 56px",
  "box-sizing: border-box",
  "border-radius: 10px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 3px",
  "font-weight: 700",
].join("; ");

const boxTone: Record<Tone, string> = {
  done: `${boxBase}; border: 1.5px solid ${DONE}; background: color-mix(in srgb, ${DONE} 16%, transparent); color: color-mix(in srgb, ${DONE} 80%, var(--sl-color-white));`,
  skip: `${boxBase}; border: 1.5px solid ${SKIP}; background: color-mix(in srgb, ${SKIP} 18%, transparent); color: color-mix(in srgb, ${SKIP} 78%, var(--sl-color-white));`,
  plain: `${boxBase}; border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6); color: var(--sl-color-gray-1);`,
};

const boxLabel = `${reset}; font-size: 18px; line-height: 1;`;
const boxTag = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
].join("; ");

// A removed cell, shown faded with a strike to anchor "this left, the rest
// shifted". Reuses the column stack so its box lines up with the live boxes.
const ghostBox = [
  reset,
  "width: 64px",
  "height: 56px",
  "box-sizing: border-box",
  "border-radius: 10px",
  "border: 1.5px dashed var(--sl-color-gray-4)",
  "background: transparent",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 3px",
  "opacity: 0.5",
  "color: var(--sl-color-gray-3)",
  "font-weight: 700",
  "text-decoration: line-through",
].join("; ");
const ghostTag = `${reset}; ${sans}; font-size: 9px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; line-height: 1; color: var(--sl-color-gray-3); text-decoration: none;`;

const caretWrap = "margin: 0; display: flex; flex-direction: column; align-items: center; gap: 2px;";
const caretLabel = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 700",
  "line-height: 1",
].join("; ");
---

<div class="not-content" style={root}>
  {/* Loop-state readout — the live `i` and `length` the loop is reading */}
  <div style={readout}>
    <span style={pill}>
      <span style={pillKey}>i</span>
      <span style={pillVal}>= {frame.i}</span>
    </span>
    <span style={pill}>
      <span style={pillKey}>list.children.length</span>
      <span style={pillVal}>= {length}</span>
    </span>
    <span style={note}>{frame.note}</span>
  </div>

  {/* The live collection track — a row of self-contained columns */}
  <div style={track}>
    {/* Leading ghost column for the just-removed cell (steps 1–2). Same column
        stack so its box lines up with the live boxes; the index slot is a blank
        spacer, and the strike caption sits in the caret slot. */}
    {
      frame.ghost && (
        <div style={col}>
          <span style={indexLabel} aria-hidden="true">
            &nbsp;
          </span>
          <div style={ghostBox}>
            <span style={boxLabel}>{frame.ghost}</span>
            <span style={ghostTag}>removed</span>
          </div>
          <div style={caretSlot}>
            <span style={`${reset}; ${sans}; font-size: 9.5px; color: var(--sl-color-gray-3); line-height: 1.2; text-align: center;`}>
              shifted ↓ the rest
            </span>
          </div>
        </div>
      )
    }

    {
      frame.cells.map((cell, idx) => (
        <div style={col}>
          {/* index label */}
          <span style={indexLabel}>[{idx}]</span>
          {/* the box */}
          <div style={boxTone[cell.tone]}>
            <span style={boxLabel}>{cell.label}</span>
            {cell.tone !== "plain" && <span style={boxTag}>.done</span>}
          </div>
          {/* caret slot */}
          <div style={caretSlot}>
            {frame.caretOnIndex === idx && (
              <div style={caretWrap}>
                <svg
                  width="18"
                  height="12"
                  viewBox="0 0 18 12"
                  role="img"
                  aria-label={`The loop index i points at index ${idx}.`}
                  style="margin: 0; display: block;"
                >
                  <path
                    d="M 9 12 L 1 0 L 17 0 Z"
                    fill="currentColor"
                    fill-opacity="0.85"
                  />
                </svg>
                <span style={`${caretLabel}; color: var(--sl-color-gray-1);`}>
                  i = {frame.i}
                </span>
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>
</div>
