---
// Snapshot-vs-live-tree diagram — the spine of Chapter 014.
//
// Two panels side by side encode "two views of one element, two answers":
//   LEFT  — "HTML bytes" the server sent / View-Source. A flat, greyed,
//           faded code card reading as a frozen photograph: the markup is a
//           byte string captured once and never edited afterward.
//   RIGHT — "Live DOM tree" DevTools shows. A vibrant, active card holding a
//           tiny node tree whose `.value` property reads the autofilled
//           "ada@example.com" — the divergence, highlighted green so the eye
//           lands on it.
//
// Between them a straight rightward arrow labelled "parser builds once".
// A self-loop arrow curves back onto the RIGHT panel only, labelled
// "JS + browser mutate", signalling the tree keeps changing forever after
// while the left panel never does.
//
// Pure HTML + CSS. `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector. Theme-aware chrome via Starlight gray
// variables; the live card's accent + the divergence highlight use saturated
// mid-tones (green-600 family) that read in both light and dark themes. `<`
// in the source snippet is escaped as `&lt;`.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer row: left panel · connector · right panel. Wraps on narrow cards so
// nothing is ever clipped (per the wrap-don't-scroll guidance).
const root = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "justify-content: center",
  "column-gap: 8px",
  "row-gap: 18px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// Shared panel chrome. Narrow flex-basis + small min-width so the two panels
// and the connector sit side by side on a normal figure card, and only wrap
// on a genuinely narrow one.
const panelBase = [
  reset,
  "flex: 1 1 230px",
  "min-width: 196px",
  "box-sizing: border-box",
  "border-radius: 10px",
  "padding: 14px 16px",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
].join("; ");

// LEFT — frozen photograph: hairline grey border, faint grey fill, the whole
// card slightly desaturated and dimmed to read as "captured once, dead".
const frozenPanel = [
  panelBase,
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "opacity: 0.72",
  "filter: grayscale(0.4)",
].join("; ");

// RIGHT — live state: saturated green-tinted border + fill so it reads as
// active against the faded left.
const livePanel = [
  panelBase,
  "border: 1px solid color-mix(in srgb, #16a34a 55%, transparent)",
  "background: color-mix(in srgb, #16a34a 9%, transparent)",
].join("; ");

const panelTitle = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1.3",
].join("; ");

const frozenTitle = `${panelTitle}; color: var(--sl-color-gray-2);`;
const liveTitle = `${panelTitle}; color: color-mix(in srgb, #16a34a 80%, var(--sl-color-white));`;

const codeBlock = [
  reset,
  mono,
  "font-size: 13.5px",
  "line-height: 1.55",
  "white-space: pre",
  "color: var(--sl-color-gray-1)",
].join("; ");

const treeBlock = [
  reset,
  mono,
  "font-size: 13.5px",
  "line-height: 1.55",
  "white-space: pre",
].join("; ");

const subLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-style: italic",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The divergence — the autofilled property value, painted green so the eye
// lands here.
const valueHighlight = [
  reset,
  mono,
  "font-size: 13.5px",
  "font-weight: 700",
  "color: #16a34a",
  "background: color-mix(in srgb, #16a34a 16%, transparent)",
  "border-radius: 4px",
  "padding: 0 4px",
].join("; ");

// Center connector — a rightward arrow with its label stacked beneath.
const connector = [
  reset,
  "flex: 0 0 auto",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 4px",
  "padding: 0 2px",
].join("; ");

const connectorLabel = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "line-height: 1.2",
  "text-align: center",
  "color: var(--sl-color-gray-2)",
  "max-width: 84px",
].join("; ");

// Self-loop label sits beside the curved arrow that re-enters the right panel.
const loopLabel = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "line-height: 1.2",
  "white-space: nowrap",
  "color: color-mix(in srgb, #16a34a 75%, var(--sl-color-gray-1))",
].join("; ");

// The live node tree, kept as literal lines so the box-drawing glyph aligns.
const treeLineMuted = "color: var(--sl-color-gray-1);";
---

<div class="not-content" style={root}>
  {/* LEFT — frozen HTML bytes */}
  <div style={frozenPanel}>
    <p style={frozenTitle}>HTML bytes<br />what the server sent / View-Source</p>
    <pre style={codeBlock}>{`<form>\n  <input value="">\n</form>`}</pre>
    <p style={subLabel}>a byte string, captured once</p>
  </div>

  {/* CENTER — parser builds once */}
  <div style={connector}>
    <svg
      width="46"
      height="20"
      viewBox="0 0 46 20"
      role="img"
      aria-label="The parser builds the live tree from the bytes."
      style="margin: 0; display: block;"
    >
      <line
        x1="0"
        y1="10"
        x2="38"
        y2="10"
        stroke="currentColor"
        stroke-opacity="0.55"
        stroke-width="1.6"></line>
      <path d="M 46 10 L 36 5 L 36 15 Z" fill="currentColor" fill-opacity="0.7"
      ></path>
    </svg>
    <span style={connectorLabel}>parser builds once</span>
  </div>

  {/* RIGHT — live DOM tree, with the self-loop "mutate" arrow above it */}
  <div
    style="margin: 0; flex: 1 1 250px; min-width: 210px; display: flex; flex-direction: column; align-items: stretch; gap: 4px;"
  >
    {/* Self-loop arrow: leaves the top-right of the card and curves back in. */}
    <div
      style="margin: 0; display: flex; align-items: center; justify-content: flex-end; gap: 6px; padding-right: 8px;"
    >
      <span style={loopLabel}>JS + browser mutate</span>
      <svg
        width="44"
        height="30"
        viewBox="0 0 44 30"
        role="img"
        aria-label="JavaScript and the browser keep mutating the live tree."
        style="margin: 0; display: block;"
      >
        <path
          d="M 6 28 C 6 4, 38 4, 38 24"
          fill="none"
          stroke="#16a34a"
          stroke-opacity="0.75"
          stroke-width="1.6"></path>
        <path d="M 38 30 L 33 20 L 43 20 Z" fill="#16a34a" fill-opacity="0.85"
        ></path>
      </svg>
    </div>

    <div style={livePanel}>
      <p style={liveTitle}>Live DOM tree<br />what DevTools shows</p>
      <div style={treeBlock}>
        <div style={`margin: 0; ${treeLineMuted}`}>form</div>
        <div style="margin: 0; display: flex; align-items: baseline; flex-wrap: wrap; gap: 6px;">
          <span style={`margin: 0; ${treeLineMuted}`}>└─ input</span>
          <span style={valueHighlight}>.value = "ada@example.com"</span>
        </div>
      </div>
      <p style={`${subLabel}; color: color-mix(in srgb, #16a34a 55%, var(--sl-color-gray-2));`}>
        a property, rewritten by autofill
      </p>
    </div>
  </div>
</div>
