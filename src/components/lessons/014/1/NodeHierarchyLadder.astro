---
// Node-hierarchy ladder — the type-narrowing model for Chapter 014 L1.
//
// A LEFT-TO-RIGHT inheritance chain of four connected boxes:
//
//   Node  →  Element  →  HTMLElement  →  HTMLInputElement
//
// Each box lists only the 2-3 members it ADDS on top of the level to its
// left (not a full API dump), so the eye reads "what you gain at each step
// down the chain". Rightward arrows carry the "adds-onto / more specific"
// direction. The accent fill warms very slightly left→right to reinforce
// "more specialised" without turning into four loud colours.
//
// A short, deliberately MUTED side-branch drops out of the `Node` box and
// lists the other node types that also inherit from `Node`
// (Text · Comment · Document · DocumentFragment) — signalling
// "recognize, don't memorize" rather than "learn these APIs".
//
// Pure HTML + CSS, inline styles only (devtools-inspectable). `margin: 0`
// reset on every inner element to defeat Starlight's prose-margin selector.
// Theme-aware chrome via Starlight gray variables; the accent uses the
// saturated teal-600 family that reads in both light and dark themes. The
// row wraps rather than scrolls on a narrow card. `<` and `>` in member
// names are escaped where they appear as text.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const accent = "#0d9488"; // teal-600 — reads in light + dark

// Outer column: the chain row, then the muted side-branch under box 1.
const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// The four-box chain. Wraps on a genuinely narrow card so nothing clips.
const chain = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 6px",
  "row-gap: 16px",
].join("; ");

// Shared box chrome. Narrow flex-basis + min-width keeps all four side by
// side on a normal figure card and only wraps when truly cramped.
const boxBase = [
  reset,
  "flex: 1 1 158px",
  "min-width: 150px",
  "box-sizing: border-box",
  "border-radius: 10px",
  "padding: 11px 12px 12px",
  "display: flex",
  "flex-direction: column",
  "gap: 7px",
].join("; ");

// Accent intensity ramps gently across the four levels: faintest at `Node`,
// strongest at the leaf, so the chain reads as "increasingly specific".
const boxAt = (pct: number) =>
  [
    boxBase,
    `border: 1px solid color-mix(in srgb, ${accent} ${30 + pct}%, transparent)`,
    `background: color-mix(in srgb, ${accent} ${4 + Math.round(pct / 3)}%, transparent)`,
  ].join("; ");

const className = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  `color: color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
].join("; ");

const addsTag = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

const memberList = [
  reset,
  "list-style: none",
  "padding: 0",
  "display: flex",
  "flex-direction: column",
  "gap: 3px",
].join("; ");

const member = [
  reset,
  mono,
  "font-size: 12px",
  "line-height: 1.35",
  "color: var(--sl-color-gray-1)",
].join("; ");

// Center connector between two boxes: a short rightward arrow.
const connector = [
  reset,
  "flex: 0 0 auto",
  "align-self: center",
  "display: flex",
  "align-items: center",
].join("; ");

// Side-branch wrapper: pinned under the leftmost box's column. The chain row
// centers its content, so a small left padding nudges the branch under box 1
// without hard pixel math; it also wraps gracefully when the chain wraps.
const branchWrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: flex-start",
  "margin-top: 10px",
  "max-width: 360px",
].join("; ");

// Vertical stub dropping from the Node box into the muted branch.
const branchStub = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "padding-left: 14px",
].join("; ");

const branchLabel = [
  reset,
  sans,
  "font-size: 10px",
  "font-style: italic",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

const branchCard = [
  reset,
  "box-sizing: border-box",
  "border: 1px dashed var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "border-radius: 8px",
  "padding: 8px 11px",
  "opacity: 0.78",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "column-gap: 4px",
  "row-gap: 4px",
].join("; ");

const branchNode = [
  reset,
  mono,
  "font-size: 12px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");

const branchDot = [
  reset,
  sans,
  "font-size: 12px",
  "color: var(--sl-color-gray-4)",
].join("; ");

// The four levels, each with the members it FIRST introduces.
const levels = [
  {
    name: "Node",
    pct: 0,
    adds: "adds",
    members: ["parentNode", "childNodes", "nodeType"],
  },
  {
    name: "Element",
    pct: 18,
    adds: "+ adds",
    members: ["getAttribute()", "classList", "querySelector()"],
  },
  {
    name: "HTMLElement",
    pct: 36,
    adds: "+ adds",
    members: ["style", "dataset", "tabIndex"],
  },
  {
    name: "HTMLInputElement",
    pct: 54,
    adds: "+ adds",
    members: [".value", ".checked"],
  },
];

const branchNodes = ["Text", "Comment", "Document", "DocumentFragment"];
---

<div class="not-content" style={root}>
  <div style={chain}>
    {
      levels.map((level, i) => (
        <>
          <div style={boxAt(level.pct)}>
            <p style={className}>{level.name}</p>
            <span style={addsTag}>{level.adds}</span>
            <ul style={memberList}>
              {level.members.map((m) => (
                <li style={member}>{m}</li>
              ))}
            </ul>
          </div>
          {i < levels.length - 1 && (
            <div style={connector}>
              <svg
                width="22"
                height="16"
                viewBox="0 0 22 16"
                role="img"
                aria-label="inherits from, and adds to"
                style="margin: 0; display: block;"
              >
                <line
                  x1="0"
                  y1="8"
                  x2="15"
                  y2="8"
                  stroke="currentColor"
                  stroke-opacity="0.5"
                  stroke-width="1.6"
                />
                <path
                  d="M 22 8 L 13 3.5 L 13 12.5 Z"
                  fill="currentColor"
                  fill-opacity="0.65"
                />
              </svg>
            </div>
          )}
        </>
      ))
    }
  </div>

  {/* Muted side-branch off `Node`: recognize, don't memorize. */}
  <div style={branchWrap}>
    <div style={branchStub}>
      <svg
        width="14"
        height="20"
        viewBox="0 0 14 20"
        role="img"
        aria-label="Node also has these other subtypes."
        style="margin: 0; display: block;"
      >
        <path
          d="M 1 0 L 1 11 Q 1 15 5 15 L 14 15"
          fill="none"
          stroke="var(--sl-color-gray-4)"
          stroke-width="1.4"></path>
      </svg>
      <span style={branchLabel}>
        also <code style="margin: 0; background: transparent; padding: 0; font-size: 12px;">Node</code>s — recognize, don&rsquo;t memorize
      </span>
    </div>
    <div style={branchCard}>
      {
        branchNodes.map((n, i) => (
          <>
            <span style={branchNode}>{n}</span>
            {i < branchNodes.length - 1 && <span style={branchDot}>·</span>}
          </>
        ))
      }
    </div>
  </div>
</div>
