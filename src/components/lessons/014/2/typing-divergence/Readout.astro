---
// One step's body for the typing-divergence DiagramSequence (Chapter 014 L2).
//
// Renders the same two-row readout in every step so the reader's eye stays
// anchored while the values change underneath:
//   ROW 1 — Attribute: getAttribute('value') -> a quoted-string chip.
//   ROW 2 — Property:  input.value           -> a quoted-string chip.
//
// Each chip carries a `state`:
//   'neutral' — in agreement, plain chrome.
//   'changed' — this value just moved (orange fill + a "changed" tag).
//   'held'    — this value deliberately did NOT move while the other did
//               (orange outline only + a "left untouched" tag).
//   'live'    — emphasised as the live/current answer (orange outline).
// A `gap` flag drops a severed connector between the two rows (step 3),
// reusing the broken-link motif from the anchor TwoSlotsNode figure.
//
// Pure HTML + CSS, devtools-inspectable. `margin: 0` resets defeat
// Starlight's prose-margin selector; theme-aware via Starlight gray vars; the
// divergence signal uses orange-600 (#ea580c), legible in both themes —
// matched to TwoSlotsNode so the two figures read as one model.

type ChipState = "neutral" | "changed" | "held" | "live";

interface Props {
  attr: string;
  prop: string;
  attrState?: ChipState;
  propState?: ChipState;
  gap?: boolean;
}

const {
  attr,
  prop,
  attrState = "neutral",
  propState = "neutral",
  gap = false,
} = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Warning / divergence tint — orange-600, matched to TwoSlotsNode.
const warn = "#ea580c";

const stage = [
  reset,
  sans,
  "box-sizing: border-box",
  "max-width: 460px",
  "margin: 0 auto",
  "padding: 4px 2px",
].join("; ");

// A row: label on the left, value chip on the right, aligned in a 2-col grid.
const row = [
  reset,
  "display: grid",
  "grid-template-columns: minmax(0, 1fr) auto",
  "align-items: center",
  "column-gap: 16px",
].join("; ");

const rowLabel = [
  reset,
  sans,
  "display: flex",
  "flex-direction: column",
  "row-gap: 2px",
  "min-width: 0",
].join("; ");

const rowKind = [
  reset,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");

const rowAccess = [
  reset,
  mono,
  "font-size: 12px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");

const chipBase = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-block",
  "text-align: center",
  "min-width: 78px",
  "font-size: 15px",
  "line-height: 1.5",
  "padding: 8px 12px",
  "border-radius: 8px",
  "white-space: nowrap",
].join("; ");

const chipNeutral = [
  chipBase,
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-text)",
].join("; ");

// Filled orange — the value that just moved.
const chipChanged = [
  chipBase,
  `border: 1px solid color-mix(in srgb, ${warn} 60%, transparent)`,
  `background: color-mix(in srgb, ${warn} 12%, transparent)`,
  `color: color-mix(in srgb, ${warn} 88%, var(--sl-color-text))`,
  "font-weight: 600",
].join("; ");

// Orange outline only — held-in-place or live-current emphasis.
const chipOutline = [
  chipBase,
  `border: 1.5px solid color-mix(in srgb, ${warn} 55%, transparent)`,
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-text)",
  "font-weight: 600",
].join("; ");

const chipStyleFor = (state: ChipState) =>
  state === "changed"
    ? chipChanged
    : state === "held" || state === "live"
      ? chipOutline
      : chipNeutral;

// Tiny annotation tag pinned under a chip when its state is meaningful.
const tagFor = (state: ChipState) =>
  state === "changed"
    ? "changed"
    : state === "held"
      ? "left untouched"
      : state === "live"
        ? "current / live"
        : null;

const tagStyle = [
  reset,
  sans,
  "display: block",
  "margin-top: 4px",
  "font-size: 10px",
  "font-style: italic",
  "line-height: 1.2",
  "text-align: center",
  `color: color-mix(in srgb, ${warn} 80%, var(--sl-color-gray-1))`,
].join("; ");

const chipCell = [reset, "display: block", "justify-self: end"].join("; ");

const attrTag = tagFor(attrState);
const propTag = tagFor(propState);
---

<div class="not-content" style={stage}>
  {/* ROW 1 — attribute */}
  <div style={row}>
    <span style={rowLabel}>
      <span style={rowKind}>Attribute</span>
      <span style={rowAccess}>getAttribute('value')</span>
    </span>
    <span style={chipCell}>
      <span style={chipStyleFor(attrState)}>{attr}</span>
      {attrTag && <span style={tagStyle}>{attrTag}</span>}
    </span>
  </div>

  {/* CONNECTOR — solid neutral, or severed (step 3) */}
  <div
    aria-hidden="true"
    style={[
      reset,
      "display: grid",
      "grid-template-columns: minmax(0, 1fr) auto",
      "column-gap: 16px",
    ].join("; ")}
  >
    <span style="margin: 0;"></span>
    <span style={[reset, "display: flex", "justify-content: center", "min-width: 78px"].join("; ")}>
      {
        gap ? (
          <svg
            width="58"
            height="26"
            viewBox="0 0 58 26"
            role="img"
            aria-label="The attribute and property are no longer the same value."
            style="margin: 0; display: block; overflow: visible;"
          >
            <line x1="29" y1="0" x2="29" y2="9" stroke={warn} stroke-width="2" stroke-dasharray="3 3" />
            <line x1="29" y1="17" x2="29" y2="26" stroke={warn} stroke-width="2" stroke-dasharray="3 3" />
            <line x1="23" y1="16" x2="35" y2="10" stroke={warn} stroke-width="1.6" />
          </svg>
        ) : (
          <svg width="2" height="26" viewBox="0 0 2 26" style="margin: 0; display: block;">
            <line x1="1" y1="0" x2="1" y2="26" stroke="var(--sl-color-gray-3)" stroke-width="2" />
          </svg>
        )
      }
    </span>
  </div>

  {/* ROW 2 — property */}
  <div style={row}>
    <span style={rowLabel}>
      <span style={rowKind}>Property</span>
      <span style={rowAccess}>input.value</span>
    </span>
    <span style={chipCell}>
      <span style={chipStyleFor(propState)}>{prop}</span>
      {propTag && <span style={tagStyle}>{propTag}</span>}
    </span>
  </div>
</div>
