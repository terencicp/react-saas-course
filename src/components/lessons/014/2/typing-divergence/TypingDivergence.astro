---
// typing-divergence — the temporal payoff of Chapter 014 L2.
//
// A DiagramSequence the reader scrubs through to watch one <input>'s value
// attribute (the parsed snapshot) and value property (the live value) start
// equal at parse time and then split apart once the user types. The static
// TwoSlotsNode figure above shows the *end state*; this shows it *happening*.
//
// Every step reuses <Readout> so the two-row layout never moves under the
// reader — only the chip values and their highlight states change. Step 4
// swaps the bare values for role labels (initial/parsed vs current/live),
// landing the punchline.

import DiagramSequence from "../../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../figures/diagram-sequence/DiagramStep.astro";
import Readout from "./Readout.astro";
---

<DiagramSequence>
  <DiagramStep caption="Parse time. The browser reads <input value=&quot;&quot;> from the source and builds the node. Both slots start equal.">
    <Readout attr={"''"} prop={"''"} />
  </DiagramStep>

  <DiagramStep caption="The user types hello. The browser updates the live property; it does not rewrite the source it already parsed, so the attribute is left untouched.">
    <Readout attr={"''"} prop={"'hello'"} attrState="held" propState="changed" />
  </DiagramStep>

  <DiagramStep caption="Now read both back. input.value returns the live current value; input.getAttribute('value') returns the original parsed string. They disagree — and both are right.">
    <Readout attr={"''"} prop={"'hello'"} attrState="live" propState="live" gap />
  </DiagramStep>

  <DiagramStep caption="The punchline: the attribute is the value the parser saw; the property is the value the field has. Neither is broken — they were never tracking the same thing.">
    <Readout attr={"'' = initial / parsed"} prop={"'hello' = current / live"} gap />
  </DiagramStep>
</DiagramSequence>
