---
// Two-slots-node diagram — the anchor figure of Chapter 014 L2.
//
// One <input> node, drawn as a single rounded box with a tag-name pill
// straddling its top border. Inside, two stacked shelves encode the lesson's
// whole model:
//   TOP    — "Attributes": the parsed strings the HTML parser recorded. Each
//            entry is a quoted-string code chip (id="email", type="text",
//            value="").
//   BOTTOM — "Properties": the live, typed values on the element object. Each
//            entry shows its real type (id: 'email', type: 'text',
//            value: 'hello').
//
// The two shelves share one 3-column grid so each pair (id / type / value)
// lines up in a column. A connector band between the shelves draws a vertical
// line per column:
//   - id and type are SYNCED — a solid neutral line: write one side, the
//     other follows.
//   - value is DIVERGED — a severed, dashed orange line with a gap and a tiny
//     "diverged after the user typed" label, foreshadowing default-vs-current.
//
// Pure HTML + CSS so a reader can open devtools and see real grid layout.
// `margin: 0` reset on every inner element defeats Starlight's prose-margin
// selector. Theme-aware chrome via Starlight gray variables; the divergence
// signal uses an orange-600 mid-tone that reads in both light and dark themes.
// `<input>` and the empty-string chips escape `<`/`"` only where they sit in
// JSX text; style attributes are unaffected.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Warning / divergence tint — orange-600, reads on both themes.
const warn = "#ea580c";

// Outer node box: rounded card, hairline border, sidebar-ish fill. Centered
// and capped so it stays compact and horizontal on a wide-but-short viewport.
const node = [
  reset,
  "position: relative",
  "box-sizing: border-box",
  "max-width: 560px",
  "margin: 0 auto",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "border-radius: 12px",
  "background: var(--sl-color-bg-sidebar)",
  "padding: 26px 20px 18px",
  sans,
].join("; ");

// Tag-name pill straddling the top border (fieldset-legend technique).
const tagPill = [
  reset,
  mono,
  "display: block",
  "width: fit-content",
  "margin: -36px auto 14px",
  "padding: 3px 12px",
  "font-size: 13px",
  "font-weight: 600",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "border-radius: 999px",
  "background: var(--sl-color-bg-sidebar)",
  "color: var(--sl-color-text)",
].join("; ");

// Shelf header — small uppercase label with the access syntax beside it.
const shelfHeader = [
  reset,
  sans,
  "display: flex",
  "align-items: baseline",
  "flex-wrap: wrap",
  "column-gap: 8px",
  "row-gap: 2px",
  "margin: 0 0 7px",
].join("; ");

const shelfTitle = [
  reset,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");

const shelfSyntax = [
  reset,
  mono,
  "font-size: 11px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The 3-column grid shared by both shelves + the connector band, so each
// attribute / connector / property triple sits in one column.
const tripleGrid = [
  reset,
  "display: grid",
  "grid-template-columns: repeat(3, 1fr)",
  "gap: 8px",
].join("; ");

// A value chip — code, but without Starlight's inline-<code> pill so the grid
// columns stay predictable.
const chipBase = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: block",
  "text-align: center",
  "font-size: 13.5px",
  "line-height: 1.5",
  "padding: 7px 6px",
  "border-radius: 7px",
  "white-space: nowrap",
].join("; ");

// Synced chip — neutral chrome.
const chipSynced = [
  chipBase,
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-text)",
].join("; ");

// Diverged chip — orange-tinted, both sides of the broken link.
const chipDiverged = [
  chipBase,
  `border: 1px solid color-mix(in srgb, ${warn} 55%, transparent)`,
  `background: color-mix(in srgb, ${warn} 10%, transparent)`,
  `color: color-mix(in srgb, ${warn} 88%, var(--sl-color-text))`,
  "font-weight: 600",
].join("; ");

// Type tag appended after a property value, e.g. "string".
const typeTag = [
  reset,
  sans,
  "font-size: 10px",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Connector band — same 3-col grid; each cell centers one vertical connector.
const connectorBand = [
  tripleGrid,
  "margin: 9px 0",
  "align-items: stretch",
].join("; ");

const connectorCell = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
].join("; ");
---

<div class="not-content" style={node}>
  <span style={tagPill}>{"<input>"}</span>

  {/* TOP SHELF — parsed strings */}
  <div style={shelfHeader}>
    <span style={shelfTitle}>Attributes &mdash; parsed strings</span>
    <span style={shelfSyntax}>getAttribute(name)</span>
  </div>
  <div style={tripleGrid}>
    <span style={chipSynced}>{'id="email"'}</span>
    <span style={chipSynced}>{'type="text"'}</span>
    <span style={chipDiverged}>{'value=""'}</span>
  </div>

  {/* CONNECTOR BAND — solid where synced, severed dashed where diverged */}
  <div style={connectorBand} aria-hidden="true">
    {/* id — synced */}
    <div style={connectorCell}>
      <svg width="2" height="34" viewBox="0 0 2 34" style="margin: 0; display: block; overflow: visible;">
        <line x1="1" y1="0" x2="1" y2="34" stroke="var(--sl-color-gray-3)" stroke-width="2"></line>
      </svg>
    </div>
    {/* type — synced */}
    <div style={connectorCell}>
      <svg width="2" height="34" viewBox="0 0 2 34" style="margin: 0; display: block; overflow: visible;">
        <line x1="1" y1="0" x2="1" y2="34" stroke="var(--sl-color-gray-3)" stroke-width="2"></line>
      </svg>
    </div>
    {/* value — severed: two stubs with a gap, dashed + orange */}
    <div style={connectorCell}>
      <svg
        width="60"
        height="34"
        viewBox="0 0 60 34"
        role="img"
        aria-label="The value attribute and value property are no longer linked."
        style="margin: 0; display: block; overflow: visible;"
      >
        {/* top stub from the attribute chip */}
        <line x1="30" y1="0" x2="30" y2="12" stroke={warn} stroke-width="2" stroke-dasharray="3 3"></line>
        {/* bottom stub to the property chip */}
        <line x1="30" y1="22" x2="30" y2="34" stroke={warn} stroke-width="2" stroke-dasharray="3 3"></line>
        {/* the break — a small slash crossing the gap */}
        <line x1="24" y1="20" x2="36" y2="14" stroke={warn} stroke-width="1.6"></line>
      </svg>
    </div>
  </div>

  {/* BOTTOM SHELF — live typed values */}
  <div style={tripleGrid}>
    <span style={chipSynced}>{"id: 'email'"} <span style={typeTag}>string</span></span>
    <span style={chipSynced}>{"type: 'text'"} <span style={typeTag}>string</span></span>
    <span style={chipDiverged}>{"value: 'hello'"} <span style={typeTag}>string</span></span>
  </div>
  <div style={`${shelfHeader}; margin: 7px 0 0;`}>
    <span style={shelfTitle}>Properties &mdash; live typed values</span>
    <span style={shelfSyntax}>element.prop</span>
  </div>

  {/* divergence note pinned under the broken value column */}
  <div style="margin: 4px 0 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;">
    <span style="margin: 0;"></span>
    <span style="margin: 0;"></span>
    <span style={`margin: 0; ${sans}; font-size: 10px; font-style: italic; line-height: 1.3; text-align: center; color: color-mix(in srgb, ${warn} 80%, var(--sl-color-gray-1));`}>diverged after the user typed</span>
  </div>
</div>
