---
// Event-phase walkthrough — one frame of a single click's trip through the
// tree, used inside <DiagramSequence>. Scrubbing the eight frames makes the
// "two trips" (down through capture, up through bubble) visible in TIME, which
// a static diagram can't show.
//
// The tree is a fixed vertical stack of four nested ancestors, outermost at top
// (down = toward the target, matching the capture leg's direction):
//   window  →  document  →  <form>  →  <button>   (the target, deepest)
//
// `step` selects the frame (source order = scrub order):
//   0  idle      nothing lit, no phase
//   1  capture   window lit,   arrow ↓
//   2  capture   document lit, arrow ↓
//   3  capture   form lit,     arrow ↓
//   4  target    button lit,   "target" tag, no arrow
//   5  bubble    form lit,     arrow ↑
//   6  bubble    document lit, arrow ↑
//   7  bubble    window lit,   arrow ↑
//
// Pure HTML + CSS, matching the chapter's other figures (see IndexDrift): the
// `not-content` wrapper, theme gray variables for chrome, a saturated mid-tone
// (teal-600) for the "event is here right now" signal so it reads in both light
// and dark, and a `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector.

interface Props {
  step: 0 | 1 | 2 | 3 | 4 | 5 | 6 | 7;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const LIT = "#0d9488"; // teal-600 — where the event is right now

// The fixed tree, top (outermost) to bottom (target). Index = depth.
const NODES = [
  { label: "window", code: false },
  { label: "document", code: false },
  { label: "<form>", code: true },
  { label: "<button>", code: true },
] as const;

type Phase = "idle" | "capture" | "target" | "bubble";

// Per-frame state: which depth is lit and which phase we're in. The arrow
// direction follows the phase (capture ↓, bubble ↑, target none).
const frames: Record<Props["step"], { lit: number | null; phase: Phase }> = {
  0: { lit: null, phase: "idle" },
  1: { lit: 0, phase: "capture" },
  2: { lit: 1, phase: "capture" },
  3: { lit: 2, phase: "capture" },
  4: { lit: 3, phase: "target" },
  5: { lit: 2, phase: "bubble" },
  6: { lit: 1, phase: "bubble" },
  7: { lit: 0, phase: "bubble" },
};

const frame = frames[step];

const PHASE_LABEL: Record<Phase, string> = {
  idle: "Not started",
  capture: "Capturing",
  target: "Target",
  bubble: "Bubbling",
};

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 14px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// Phase banner at the top — names the active phase + draws the trip direction.
const isCapture = frame.phase === "capture";
const isBubble = frame.phase === "bubble";
const isTarget = frame.phase === "target";
const isLive = isCapture || isBubble || isTarget;

const banner = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "gap: 8px",
  "padding: 5px 12px",
  "border-radius: 999px",
  "border: 1px solid " + (isLive ? LIT : "var(--sl-color-gray-4)"),
  "background: " +
    (isLive
      ? `color-mix(in srgb, ${LIT} 14%, transparent)`
      : "var(--sl-color-gray-6)"),
  sans,
  "font-size: 12px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "color: " + (isLive ? `color-mix(in srgb, ${LIT} 75%, var(--sl-color-white))` : "var(--sl-color-gray-2)"),
  "line-height: 1",
].join("; ");

// The tree: a row pairing a left direction rail with the stacked node column,
// so the arrow always sits beside the lit box and points the way the event
// travels this tick.
const treeRow = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "gap: 12px",
].join("; ");

// Fixed-width rail carrying the long down/up arrow for the active leg.
const rail = [
  reset,
  "width: 26px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
].join("; ");

// The node column — four boxes stacked vertically, joined by a thin spine.
const column = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 0",
].join("; ");

const boxBase = [
  reset,
  "width: 200px",
  "box-sizing: border-box",
  "padding: 9px 14px",
  "border-radius: 9px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "font-weight: 700",
  "font-size: 15px",
  "line-height: 1",
].join("; ");

const boxLit = `${boxBase}; border: 1.5px solid ${LIT}; background: ${LIT}; color: var(--sl-color-white); box-shadow: 0 0 0 4px color-mix(in srgb, ${LIT} 22%, transparent);`;
const boxDim = `${boxBase}; border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6); color: var(--sl-color-gray-2);`;

// The connector between two stacked boxes.
const spine = [
  reset,
  "width: 2px",
  "height: 14px",
  "align-self: center",
  "background: var(--sl-color-gray-4)",
].join("; ");

// A small "target" badge that rides the right edge of the lit box at step 4.
const targetTag = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "color: var(--sl-color-white)",
  "border: 1px solid color-mix(in srgb, var(--sl-color-white) 55%, transparent)",
  "border-radius: 5px",
  "padding: 2px 5px",
  "margin-left: 8px",
  "line-height: 1",
].join("; ");

// Monospace label for the element-name nodes (<form>, <button>).
const codeLabel = `${reset}; ${mono}; font-size: 14px;`;
---

<div class="not-content" style={root}>
  {/* Phase banner — what phase the trip is in this tick, with a direction glyph */}
  <div style={banner}>
    {isCapture && (
      <svg width="11" height="13" viewBox="0 0 11 13" role="img" aria-label="Heading down toward the target" style="margin: 0; display: block;">
        <path d="M 5.5 13 L 0.5 6 L 10.5 6 Z" fill="currentColor" />
        <rect x="4.5" y="0" width="2" height="7" fill="currentColor" />
      </svg>
    )}
    {isBubble && (
      <svg width="11" height="13" viewBox="0 0 11 13" role="img" aria-label="Rising back up toward the top" style="margin: 0; display: block;">
        <path d="M 5.5 0 L 0.5 7 L 10.5 7 Z" fill="currentColor" />
        <rect x="4.5" y="6" width="2" height="7" fill="currentColor" />
      </svg>
    )}
    <span style={`${reset}; line-height: 1;`}>{PHASE_LABEL[frame.phase]}</span>
  </div>

  {/* The tree: direction rail + stacked node column */}
  <div style={treeRow}>
    <div style={rail}>
      {isCapture && (
        <svg width="16" height="180" viewBox="0 0 16 180" role="img" aria-label="The event travels downward through the tree." style="margin: 0; display: block;">
          <line x1="8" y1="2" x2="8" y2="168" stroke={LIT} stroke-width="2" />
          <path d="M 8 178 L 2 166 L 14 166 Z" fill={LIT} />
        </svg>
      )}
      {isBubble && (
        <svg width="16" height="180" viewBox="0 0 16 180" role="img" aria-label="The event travels upward through the tree." style="margin: 0; display: block;">
          <line x1="8" y1="178" x2="8" y2="12" stroke={LIT} stroke-width="2" />
          <path d="M 8 2 L 2 14 L 14 14 Z" fill={LIT} />
        </svg>
      )}
    </div>

    <div style={column}>
      {
        NODES.map((node, idx) => {
          const lit = frame.lit === idx;
          return (
            <>
              {idx > 0 && <div style={spine} aria-hidden="true" />}
              <div style={lit ? boxLit : boxDim}>
                {node.code ? (
                  <span style={codeLabel}>{node.label}</span>
                ) : (
                  <span style={`${reset}; line-height: 1;`}>{node.label}</span>
                )}
                {lit && isTarget && <span style={targetTag}>target</span>}
              </div>
            </>
          );
        })
      }
    </div>
  </div>
</div>
