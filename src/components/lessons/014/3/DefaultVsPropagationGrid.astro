---
// Default-action vs propagation 2x2 grid — makes the orthogonality of the two
// methods literal. The horizontal axis is the browser's DEFAULT ACTION, worked
// by `preventDefault` (happens | cancelled). The vertical axis is PROPAGATION,
// worked by `stopPropagation` (continues | stopped). The two never touch each
// other's axis, so every combination of the two switches has its own cell.
//
// Pure HTML + CSS, matching the chapter's other figures (see EventPhaseWalk):
// a `not-content` wrapper, theme gray variables for chrome, two saturated
// mid-tones to color-code the two independent axes (so "two axes" reads
// visually), and a `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// One accent per axis. Default-action axis (preventDefault) = amber-600;
// propagation axis (stopPropagation) = violet-600. Both read on light + dark.
const DEFAULT_AXIS = "#d97706"; // amber-600 — preventDefault works this axis
const PROP_AXIS = "#7c3aed"; // violet-600 — stopPropagation works this axis

type Cell = {
  call: string | null; // the method call(s), monospace; null = "neither"
  callPlain?: string; // plain-text label when there is no call to render mono
  note: string; // one-line example of the resulting behavior
};

// Body cells in reading order: row 0 (propagation continues), row 1 (stopped),
// each with column 0 (default happens) then column 1 (default cancelled).
const CELLS: Cell[][] = [
  [
    {
      call: null,
      callPlain: "neither",
      note: "The normal case — the link navigates and the event reaches ancestors.",
    },
    {
      call: "preventDefault()",
      note: "The link does NOT navigate, but ancestor listeners still run.",
    },
  ],
  [
    {
      call: "stopPropagation()",
      note: "Ancestors don't hear it, but the link still navigates.",
    },
    {
      call: "both",
      note: "The link doesn't navigate AND ancestors don't hear it.",
    },
  ],
];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 14px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// The whole figure is one grid with explicit placement so nothing depends on
// auto-flow. Columns: [propagation-axis label | default happens | default cancelled].
// Rows: [axis title | column value headers | "continues" band | continues body
// | "stopped" band | stopped body].
const grid = [
  reset,
  "display: grid",
  "grid-template-columns: auto minmax(0, 1fr) minmax(0, 1fr)",
  "grid-template-rows: auto auto auto 1fr auto 1fr",
  "gap: 8px",
  "width: 100%",
  "max-width: 660px",
  "box-sizing: border-box",
].join("; ");

// Axis title chip (the "Default action" / "Propagation" headers), tinted to
// its axis color so the two axes are visually distinct.
const axisTitle = (color: string, extra = "") =>
  [
    reset,
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "gap: 6px",
    "padding: 4px 10px",
    "border-radius: 999px",
    "border: 1px solid " + `color-mix(in srgb, ${color} 45%, transparent)`,
    "background: " + `color-mix(in srgb, ${color} 12%, transparent)`,
    "color: " + `color-mix(in srgb, ${color} 70%, var(--sl-color-white))`,
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "line-height: 1",
    "white-space: nowrap",
    extra,
  ].join("; ");

// Column value header ("happens" / "cancelled") and row value header
// ("continues" / "stopped").
const valueHeader = (color: string, extra = "") =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "padding: 6px 8px",
    "border-radius: 8px",
    "border: 1px dashed " + `color-mix(in srgb, ${color} 50%, var(--sl-color-gray-4))`,
    "background: var(--sl-color-gray-6)",
    "color: " + `color-mix(in srgb, ${color} 65%, var(--sl-color-white))`,
    sans,
    "font-size: 13px",
    "font-weight: 700",
    "line-height: 1.1",
    "text-align: center",
    extra,
  ].join("; ");

// The vertical-axis title is rotated so it reads up the left edge.
const rotated = "writing-mode: vertical-rl; transform: rotate(180deg)";

// A body cell.
const cell = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 7px",
  "padding: 11px 13px",
  "border-radius: 10px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "box-sizing: border-box",
  "min-height: 78px",
].join("; ");

// The call name inside a cell, monospace pill — tinted to BOTH axes when the
// call touches both, otherwise to the axis it works.
const callPill = (color: string) =>
  [
    reset,
    mono,
    "display: inline-block",
    "width: fit-content",
    "padding: 3px 8px",
    "border-radius: 6px",
    "border: 1px solid " + `color-mix(in srgb, ${color} 40%, transparent)`,
    "background: " + `color-mix(in srgb, ${color} 14%, transparent)`,
    "color: " + `color-mix(in srgb, ${color} 78%, var(--sl-color-white))`,
    "font-size: 13px",
    "font-weight: 600",
    "line-height: 1.2",
  ].join("; ");

// "neither" / "both" plain-text label — neutral, since it isn't one method.
const plainPill = [
  reset,
  sans,
  "display: inline-block",
  "width: fit-content",
  "padding: 3px 8px",
  "border-radius: 6px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-5)",
  "color: var(--sl-color-gray-1)",
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
].join("; ");

const cellNote = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.45",
  "color: var(--sl-color-gray-2)",
].join("; ");

// "both" sits at the intersection of the two axes, so blend the two colors.
const BOTH = `color-mix(in srgb, ${DEFAULT_AXIS} 50%, ${PROP_AXIS})`;
---

<div class="not-content" style={root}>
  <div style={grid}>
    {/* Row 1: empty corner + the horizontal-axis title over its two columns */}
    <div style={`${reset}; grid-column: 2 / span 2; grid-row: 1; display: flex; align-items: center; justify-content: center;`}>
      <span style={axisTitle(DEFAULT_AXIS)}>Default action</span>
    </div>

    {/* Row 2: the two default-action column value headers */}
    <div style={`${valueHeader(DEFAULT_AXIS)}; grid-column: 2; grid-row: 2;`}>happens</div>
    <div style={`${valueHeader(DEFAULT_AXIS)}; grid-column: 3; grid-row: 2;`}>cancelled</div>

    {/* Vertical-axis title, rotated, spanning the four propagation rows (3–6) */}
    <div style={`${reset}; grid-column: 1; grid-row: 3 / span 4; display: flex; align-items: center; justify-content: center;`}>
      <span style={axisTitle(PROP_AXIS, rotated)}>Propagation</span>
    </div>

    {/* "continues" band header + its two body cells */}
    <div style={`${valueHeader(PROP_AXIS)}; grid-column: 2 / span 2; grid-row: 3;`}>continues</div>
    <div style={`${cell}; grid-column: 2; grid-row: 4;`}>
      {CELLS[0][0].call === null ? (
        <span style={plainPill}>{CELLS[0][0].callPlain}</span>
      ) : (
        <span style={callPill(DEFAULT_AXIS)}>{CELLS[0][0].call}</span>
      )}
      <p style={cellNote}>{CELLS[0][0].note}</p>
    </div>
    <div style={`${cell}; grid-column: 3; grid-row: 4;`}>
      <span style={callPill(DEFAULT_AXIS)}>{CELLS[0][1].call}</span>
      <p style={cellNote}>{CELLS[0][1].note}</p>
    </div>

    {/* "stopped" band header + its two body cells */}
    <div style={`${valueHeader(PROP_AXIS)}; grid-column: 2 / span 2; grid-row: 5;`}>stopped</div>
    <div style={`${cell}; grid-column: 2; grid-row: 6;`}>
      <span style={callPill(PROP_AXIS)}>{CELLS[1][0].call}</span>
      <p style={cellNote}>{CELLS[1][0].note}</p>
    </div>
    <div style={`${cell}; grid-column: 3; grid-row: 6;`}>
      <span style={`${callPill(BOTH)}; background: color-mix(in srgb, ${BOTH} 14%, transparent); border-color: color-mix(in srgb, ${BOTH} 40%, transparent);`}>{CELLS[1][1].call}</span>
      <p style={cellNote}>{CELLS[1][1].note}</p>
    </div>
  </div>
</div>
