---
// dispatcher-flow — Chapter 071 Lesson 1, "Project overview".
//
// The whole project as one named seam, read left to right:
//   Call sites ──(after commit)──▶ dispatch(event) ──fan out──▶ Channels
// with the registry adjacent to dispatch (the box it reads from) and the
// three backing tables shown as a band below the flow.
//
// dispatch is expanded inline into its ordered pipeline so the read order is
// unambiguous: registry lookup → batched prefs read → per recipient
// (resolve channels → dedup → fan out). The per-recipient steps sit inside a
// nested "per recipient" frame so the loop boundary is legible.
//
// Engine is plain HTML + CSS — the diagrams index's pick for a labeled,
// color-coded, devtools-inspectable flow that needs a true two-row layout
// (horizontal flow on top, table band below) with readable text inside the
// figure card, which a downscaled wide Mermaid SVG can't deliver here.
//
// Colors echo the chapter-070 dispatcher vocabulary so this overview and the
// implementation lessons read as one system:
//   • blue   — the entry edge (call sites).
//   • slate  — the dispatch pipeline steps.
//   • amber  — the registry, the source of truth.
//   • green  — the channel functions.
//   • violet — the backing tables.
//
// The <Figure> wrapper and caption come from the MDX call site.

const PIPELINE = [
	{ label: 'registry lookup', note: 'reads the registry' },
	{ label: 'batched prefs read', note: 'once, all recipients' },
];

const PER_RECIPIENT = ['resolve channels', 'dedup', 'fan out'];

const CHANNELS = ['sendEmailChannel', 'writeInboxChannel'];

const TABLES = [
	{ name: 'notifications', role: 'inbox feed' },
	{ name: 'user_notification_preferences', role: 'per-category toggles' },
	{ name: 'notification_dedup', role: 'the time window' },
];

const ALT =
	'A left-to-right flow. Call sites (sendInvitation, changeMemberRole, the billing webhook) hand off after commit to dispatch(event). Dispatch runs an ordered pipeline: registry lookup, then a batched preferences read, then per recipient it resolves channels, claims the dedup window, and fans out. Dispatch reads from the registry, the source of truth. Fan-out reaches the channel functions sendEmailChannel and writeInboxChannel. Below the flow, a backing-store band holds three tables: notifications, user_notification_preferences, and notification_dedup.';
---

<div class="df not-content" role="img" aria-label={ALT}>
	{/* ── Top row: the horizontal flow ─────────────────────────────────── */}
	<div class="df-flow">
		{/* Call sites */}
		<div class="df-card df-entry">
			<div class="df-card-title">Call sites</div>
			<ul class="df-list">
				<li>sendInvitation</li>
				<li>changeMemberRole</li>
				<li>billing webhook</li>
			</ul>
		</div>

		<div class="df-arrow">
			<span class="df-arrow-label">after commit</span>
			<span class="df-arrow-line" aria-hidden="true">→</span>
		</div>

		{/* dispatch(event) */}
		<div class="df-card df-dispatch">
			<div class="df-card-title">
				<code>dispatch(event)</code>
			</div>
			<div class="df-pipeline">
				{
					PIPELINE.map((step, i) => (
						<>
							<div class="df-step">{step.label}</div>
							{i < PIPELINE.length - 1 && (
								<span class="df-chev" aria-hidden="true">›</span>
							)}
						</>
					))
				}
				<div class="df-loop">
					<span class="df-loop-tag">per recipient</span>
					<div class="df-loop-steps">
						{
							PER_RECIPIENT.map((label, i) => (
								<>
									<div class="df-step df-step-loop">{label}</div>
									{i < PER_RECIPIENT.length - 1 && (
										<span class="df-chev" aria-hidden="true">›</span>
									)}
								</>
							))
						}
					</div>
				</div>
			</div>

			{/* registry — the box dispatch reads from */}
			<div class="df-registry">
				<span class="df-reads" aria-hidden="true">reads ▴</span>
				<div class="df-registry-box">
					<code>registry</code>
					<span class="df-registry-sub">source of truth</span>
				</div>
			</div>
		</div>

		<div class="df-arrow">
			<span class="df-arrow-label">fan out</span>
			<span class="df-arrow-line" aria-hidden="true">→</span>
		</div>

		{/* Channels */}
		<div class="df-card df-channels">
			<div class="df-card-title">Channels</div>
			<div class="df-channel-list">
				{CHANNELS.map((c) => <code class="df-channel">{c}</code>)}
			</div>
		</div>
	</div>

	{/* ── Bottom band: the backing store ───────────────────────────────── */}
	<div class="df-store">
		<span class="df-store-tag">Backing store</span>
		<div class="df-store-tables">
			{
				TABLES.map((t) => (
					<div class="df-table">
						<code class="df-table-name">{t.name}</code>
						<span class="df-table-role">{t.role}</span>
					</div>
				))
			}
		</div>
	</div>
</div>

<style>
	.df {
		--entry: #1d4ed8;
		--entry-bg: color-mix(in srgb, #1d4ed8 12%, transparent);
		--slate: #475569;
		--amber: #b45309;
		--amber-bg: color-mix(in srgb, #b45309 12%, transparent);
		--green: #15803d;
		--green-bg: color-mix(in srgb, #15803d 12%, transparent);
		--violet: #7e22ce;
		--violet-bg: color-mix(in srgb, #7e22ce 12%, transparent);
		--line: var(--sl-color-gray-4, #cbd5e1);

		margin: 0;
		padding: 4px 2px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 13px;
		color: var(--sl-color-text, #1e293b);
	}

	.df :global(*) {
		margin: 0;
	}

	.df :global(code) {
		background: transparent;
		padding: 0;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
	}

	/* ── Top flow row ───────────────────────────────────────────────────── */
	.df-flow {
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
		flex-wrap: wrap;
	}

	.df-card {
		box-sizing: border-box;
		border: 1px solid var(--line);
		border-radius: 10px;
		padding: 10px 12px;
		background: var(--sl-color-bg, #fff);
		display: flex;
		flex-direction: column;
	}

	.df-card-title {
		font-weight: 700;
		font-size: 13px;
		margin: 0 0 6px;
	}
	.df-card-title :global(code) {
		font-size: 13px;
		font-weight: 700;
	}

	.df-entry {
		border-color: var(--entry);
		background: var(--entry-bg);
		justify-content: center;
	}
	.df-list {
		list-style: none;
		padding: 0;
		margin: 0;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		line-height: 1.6;
		color: var(--sl-color-text, #1e293b);
	}

	/* ── dispatch(event) ────────────────────────────────────────────────── */
	.df-dispatch {
		border-color: var(--slate);
		border-width: 2px;
		max-width: 360px;
	}
	.df-pipeline {
		display: flex;
		align-items: center;
		gap: 4px 6px;
		flex-wrap: wrap;
	}
	.df-step {
		box-sizing: border-box;
		background: #1f2937;
		color: #f8fafc;
		border: 1px solid #94a3b8;
		border-radius: 7px;
		padding: 5px 9px;
		font-size: 12px;
		white-space: nowrap;
	}
	.df-chev {
		color: var(--slate);
		font-size: 15px;
		line-height: 1;
	}
	.df-loop {
		position: relative;
		display: flex;
		align-items: center;
		width: 100%;
		border: 1px dashed var(--slate);
		border-radius: 9px;
		padding: 12px 8px 7px;
		margin: 6px 0 0;
	}
	.df-loop-tag {
		position: absolute;
		top: -9px;
		left: 8px;
		background: var(--sl-color-bg-sidebar, #fff);
		padding: 0 5px;
		font-size: 11px;
		font-weight: 600;
		color: var(--slate);
	}
	.df-loop-steps {
		display: flex;
		align-items: center;
		gap: 4px;
		flex-wrap: wrap;
	}
	.df-step-loop {
		background: #334155;
	}

	/* ── registry ───────────────────────────────────────────────────────── */
	.df-registry {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 2px;
		margin: 8px 0 0;
	}
	.df-reads {
		font-size: 11px;
		color: var(--amber);
		font-weight: 600;
		padding-left: 6px;
	}
	.df-registry-box {
		display: inline-flex;
		flex-direction: column;
		border: 1px solid var(--amber);
		background: var(--amber-bg);
		border-radius: 8px;
		padding: 5px 10px;
	}
	.df-registry-box :global(code) {
		font-size: 12px;
		font-weight: 700;
		color: var(--amber);
	}
	.df-registry-sub {
		font-size: 10.5px;
		color: var(--sl-color-gray-2, #64748b);
	}

	/* ── Channels ───────────────────────────────────────────────────────── */
	.df-channels {
		border-color: var(--green);
		background: var(--green-bg);
		justify-content: center;
	}
	.df-channel-list {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	code.df-channel {
		box-sizing: border-box;
		background: #bbf7d0;
		color: #14532d;
		border: 1px solid var(--green);
		border-radius: 7px;
		padding: 5px 9px;
		font-size: 12px;
		font-weight: 600;
		white-space: nowrap;
		text-align: center;
	}

	/* ── Arrows between cards ───────────────────────────────────────────── */
	.df-arrow {
		align-self: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1px;
		min-width: 64px;
	}
	.df-arrow-label {
		font-size: 11px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #64748b);
		white-space: nowrap;
	}
	.df-arrow-line {
		font-size: 22px;
		line-height: 0.7;
		color: var(--slate);
	}

	/* ── Backing-store band ─────────────────────────────────────────────── */
	.df-store {
		position: relative;
		border: 1px dashed var(--violet);
		border-radius: 10px;
		padding: 16px 12px 12px;
		margin: 20px 0 0;
	}
	.df-store-tag {
		position: absolute;
		top: -9px;
		left: 14px;
		background: var(--sl-color-bg-sidebar, #fff);
		padding: 0 6px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--violet);
	}
	.df-store-tables {
		display: flex;
		justify-content: center;
		gap: 12px;
		flex-wrap: wrap;
	}
	.df-table {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		background: var(--violet-bg);
		border: 1px solid var(--violet);
		border-radius: 8px;
		padding: 7px 12px;
	}
	.df-table-name {
		font-size: 12px;
		font-weight: 700;
		color: var(--violet);
	}
	.df-table-role {
		font-size: 10.5px;
		color: var(--sl-color-gray-2, #64748b);
	}

	/* Dark-mode legibility for the saturated channel chip text */
	:global([data-theme='dark']) .df-channel {
		background: color-mix(in srgb, #15803d 35%, #0b1220);
		color: #d1fae5;
	}
	:global([data-theme='dark']) .df-registry-box :global(code) {
		color: #fbbf24;
	}
	:global([data-theme='dark']) .df-table-name {
		color: #d8b4fe;
	}
</style>
