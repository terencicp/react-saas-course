---
// Static annotated illustration for Commitment 4 (target size).
//
// The whole teach is to split TWO different measurements that juniors conflate:
//   - VISUAL size  = the icon glyph (kept small, ~16px)
//   - HIT AREA     = the padded tappable region around it (grown to 44px)
//
// Two targets sit side by side, both holding the SAME 16px icon:
//   left  → a correct 44x44 target. The padding (drawn as a dashed box) is what
//           makes it thumb-sized; the glyph stays small and crisp.
//   right → a too-small 24x24 target, the bare WCAG 2.2 AA floor (SC 2.5.8).
//
// A faint ~44px "thumb" circle is overlaid on each, centered on the glyph, to
// dramatize the same fingertip landing on both: it sits comfortably inside the
// 44px hit area but overshoots the 24px one. Real CSS box-model throughout
// (box-sizing: content-box so padding literally is the hit area), so a reader
// can open devtools and see that the 44px region is padding, not a bigger icon.

import { Icon } from 'astro-icon/components';
---

<div class="tsf not-content">
  {/* ---- Left: the correct target (44px hit area, 16px glyph) ---- */}
  <figure class="tsf-card">
    <div class="tsf-stage">
      {/* Callout: hit area, pointing at the dashed padding box. */}
      <div class="tsf-callout tsf-callout-area">
        <span class="tsf-callout-text">
          <strong>hit area: 44px</strong>
          <span class="tsf-callout-sub">the padding</span>
        </span>
        <span class="tsf-leader tsf-leader-area" aria-hidden="true"></span>
      </div>

      {/* The padded target. content-box → the 44x44 box IS icon + padding. */}
      <div class="tsf-target tsf-target-good">
        <span class="tsf-thumb" aria-hidden="true"></span>
        <Icon name="lucide:trash-2" class="tsf-glyph" aria-hidden="true" />
      </div>

      {/* Callout: the icon, pointing at the glyph. */}
      <div class="tsf-callout tsf-callout-icon">
        <span class="tsf-leader tsf-leader-icon" aria-hidden="true"></span>
        <span class="tsf-callout-text">
          <strong>icon: 16px</strong>
          <span class="tsf-callout-sub">what you see</span>
        </span>
      </div>
    </div>
    <figcaption class="tsf-verdict tsf-verdict-good">
      <span class="tsf-tick" aria-hidden="true">✓</span>
      Comfortable on touch
    </figcaption>
  </figure>

  {/* ---- Right: the too-small target (24px, the bare floor) ---- */}
  <figure class="tsf-card">
    <div class="tsf-stage">
      <div class="tsf-target tsf-target-bad">
        <span class="tsf-thumb" aria-hidden="true"></span>
        <Icon name="lucide:trash-2" class="tsf-glyph" aria-hidden="true" />
      </div>

      <div class="tsf-callout tsf-callout-bad">
        <span class="tsf-leader tsf-leader-bad" aria-hidden="true"></span>
        <span class="tsf-callout-text">
          <strong>24px</strong>
          <span class="tsf-callout-sub">bare WCAG minimum</span>
        </span>
      </div>
    </div>
    <figcaption class="tsf-verdict tsf-verdict-bad">
      <span class="tsf-cross" aria-hidden="true">✕</span>
      Awkward on touch
    </figcaption>
  </figure>
</div>

<style>
  .tsf {
    --tsf-good: hsl(160, 84%, 39%);
    --tsf-bad: hsl(0, 72%, 51%);
    --tsf-thumb: color-mix(in srgb, hsl(217, 91%, 60%) 22%, transparent);
    --tsf-thumb-edge: color-mix(in srgb, hsl(217, 91%, 60%) 55%, transparent);

    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 18px;
    margin: 0;
  }

  .tsf-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin: 0;
    flex: 0 1 280px;
    min-width: 240px;
    padding: 18px 16px 16px;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 10px;
    background: var(--sl-color-bg);
  }

  /* The stage carries the target plus its two flanking callouts. A fixed
     height keeps both cards the same size whether they have one callout
     or two. */
  .tsf-stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 132px;
    margin: 0;
  }

  /* ---- Targets ---- */
  /* content-box is deliberate: the declared 16px is the GLYPH box, and the
     padding is added around it, so the rendered hit area literally equals
     icon + padding. A reader inspecting this in devtools sees padding, not a
     scaled-up icon. */
  .tsf-target {
    box-sizing: content-box;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    margin: 0;
    border-radius: 9px;
    color: var(--sl-color-text);
  }

  /* Correct target: 16px glyph + 14px padding on every side = 44px hit area. */
  .tsf-target-good {
    padding: 14px;
    border: 1.5px dashed var(--tsf-good);
    background: color-mix(in srgb, var(--tsf-good) 7%, var(--sl-color-bg));
  }

  /* Too-small target: 16px glyph + 4px padding = 24px hit area. */
  .tsf-target-bad {
    padding: 4px;
    border: 1.5px dashed var(--tsf-bad);
    background: color-mix(in srgb, var(--tsf-bad) 7%, var(--sl-color-bg));
  }

  .tsf-glyph {
    width: 16px;
    height: 16px;
    margin: 0;
    display: block;
    /* Above the thumb overlay so the glyph stays legible. */
    position: relative;
    z-index: 2;
  }

  /* The fingertip: a ~44px translucent disc centered on the glyph. It sits
     inside the good target's hit area but spills well past the 24px one. */
  .tsf-thumb {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 44px;
    height: 44px;
    margin: 0;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: var(--tsf-thumb);
    border: 1px solid var(--tsf-thumb-edge);
    z-index: 1;
    pointer-events: none;
  }

  /* ---- Callouts ---- */
  .tsf-callout {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 2px;
    margin: 0;
    pointer-events: none;
  }
  .tsf-callout-text {
    display: flex;
    flex-direction: column;
    margin: 0;
    line-height: 1.2;
    white-space: nowrap;
  }
  .tsf-callout-text strong {
    font: 700 12px ui-sans-serif, system-ui, sans-serif;
    color: var(--sl-color-text);
  }
  .tsf-callout-sub {
    margin: 1px 0 0;
    font: 500 10.5px ui-sans-serif, system-ui, sans-serif;
    color: var(--sl-color-gray-3);
  }

  /* Hit-area callout: top-left, leader runs down-right to the dashed box. */
  .tsf-callout-area {
    top: 4px;
    left: 6px;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }
  .tsf-callout-area .tsf-callout-text {
    align-items: flex-start;
    text-align: left;
  }

  /* Icon callout: bottom-right, leader runs up-left to the glyph. */
  .tsf-callout-icon {
    bottom: 6px;
    right: 6px;
    flex-direction: column;
    align-items: flex-end;
    gap: 0;
  }
  .tsf-callout-icon .tsf-callout-text {
    align-items: flex-end;
    text-align: right;
  }

  /* 24px callout on the bad card: below the target, centered. */
  .tsf-callout-bad {
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .tsf-callout-bad .tsf-callout-text {
    align-items: center;
    text-align: center;
  }

  /* ---- Leader lines (thin diagonal connectors) ---- */
  .tsf-leader {
    display: block;
    margin: 0;
    background: var(--sl-color-gray-4);
  }
  .tsf-leader-area {
    width: 1px;
    height: 18px;
    margin: 3px 0 0 10px;
    transform: rotate(-32deg);
    transform-origin: top;
  }
  .tsf-leader-icon {
    width: 1px;
    height: 16px;
    margin: 0 10px 3px auto;
    transform: rotate(-32deg);
    transform-origin: bottom;
  }
  .tsf-leader-bad {
    width: 1px;
    height: 12px;
    margin: 0 auto 3px;
  }

  /* ---- Verdict footers ---- */
  .tsf-verdict {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    padding: 4px 12px;
    border-radius: 999px;
    font: 600 11.5px ui-sans-serif, system-ui, sans-serif;
    letter-spacing: 0.01em;
  }
  .tsf-verdict-good {
    color: var(--tsf-good);
    background: color-mix(in srgb, var(--tsf-good) 12%, var(--sl-color-bg));
    border: 1px solid color-mix(in srgb, var(--tsf-good) 40%, transparent);
  }
  .tsf-verdict-bad {
    color: var(--tsf-bad);
    background: color-mix(in srgb, var(--tsf-bad) 12%, var(--sl-color-bg));
    border: 1px solid color-mix(in srgb, var(--tsf-bad) 40%, transparent);
  }
  .tsf-tick,
  .tsf-cross {
    font-size: 12px;
    line-height: 1;
  }
</style>
