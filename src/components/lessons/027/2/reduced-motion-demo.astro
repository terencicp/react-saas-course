---
// Interactive "replace, don't remove" demo for Commitment 3 (reduced motion).
//
// A toggle SIMULATES `prefers-reduced-motion: reduce` (it does not read the OS
// setting, so every student sees both states regardless of their own machine).
// The toggle drives an `.is-reduced` class on the stage. Clicking "Show
// notification" mounts a toast-like card:
//
//   full motion (.is-reduced off)  → the card slides up + fades in (~320ms)
//   reduced       (.is-reduced on) → the card appears instantly, with a brief
//                                     background flash so it still ANNOUNCES
//                                     itself — the same information, minus the
//                                     vestibular cost.
//
// That swap is the whole teach: reduced motion replaces communicative motion,
// it does not delete it. The card arrives either way.
//
// Re-clicking "Show notification" replays the entrance. The card auto-dismisses
// after a few seconds, or the student can close it. A small readout names the
// entrance that last played ("slide + fade" vs "instant + flash").
//
// All CSS is owned here; the animation is gated purely by `.is-reduced` so the
// motion path and the reduced path are two CSS states of one element, mirroring
// how `motion-reduce:` and the `@media (prefers-reduced-motion)` block gate a
// real animation in the codebase.
---

<div class="rmd not-content" data-rmd-root>
  <div class="rmd-bar">
    <label class="rmd-toggle">
      <input
        type="checkbox"
        data-rmd-reduce
        aria-label="Simulate prefers-reduced-motion: reduce"
      />
      <span class="rmd-toggle-track" aria-hidden="true"></span>
      <span class="rmd-toggle-label">
        Simulate <code>prefers-reduced-motion: reduce</code>
      </span>
    </label>
    <span class="rmd-state" data-rmd-state>full motion</span>
  </div>

  <div class="rmd-stage" data-rmd-stage>
    <button type="button" class="rmd-trigger" data-rmd-trigger>
      Show notification
    </button>

    <div class="rmd-toast-area" aria-hidden="true">
      {/* Toast is cloned from the template below and appended here on click. */}
    </div>

    <span class="rmd-hint">Toggle the switch, then replay.</span>
  </div>

  {/* Authored in the template (not built dynamically) so the cloned node
      carries Astro's scoped-style class and the scoped CSS below applies. */}
  <template data-rmd-toast-template>
    <div class="rmd-toast">
      <span class="rmd-toast-dot" aria-hidden="true">✓</span>
      <div class="rmd-toast-body">
        <div class="rmd-toast-title">Changes saved</div>
        <div class="rmd-toast-text">Your report settings were updated.</div>
      </div>
      <button type="button" class="rmd-toast-close" aria-label="Dismiss notification">
        ×
      </button>
    </div>
  </template>

  <div class="rmd-readouts">
    <div class="rmd-readout">
      <span class="rmd-readout-label">Mode</span>
      <span class="rmd-readout-value" data-rmd-readout-mode>full motion</span>
    </div>
    <div class="rmd-readout">
      <span class="rmd-readout-label">Entrance</span>
      <span class="rmd-readout-value" data-rmd-readout-entrance>—</span>
    </div>
  </div>
</div>

<style>
  .rmd {
    --rmd-accent: hsl(217, 91%, 60%);
    --rmd-track-bg: color-mix(in srgb, var(--sl-color-text) 20%, transparent);
    --rmd-track-border: color-mix(in srgb, var(--sl-color-text) 28%, transparent);

    margin: 1.5rem 0;
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 12px;
    padding: 16px 18px 18px;
  }

  /* === Top bar: the simulate toggle + a live state pill === */
  .rmd-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .rmd-toggle {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    user-select: none;
    min-width: 0;
  }
  .rmd-toggle input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .rmd-toggle-track {
    position: relative;
    flex: 0 0 auto;
    width: 34px;
    height: 20px;
    background: var(--rmd-track-bg);
    border: 1px solid var(--rmd-track-border);
    border-radius: 999px;
    transition:
      background-color 0.14s,
      border-color 0.14s;
  }
  .rmd-toggle-track::before {
    content: '';
    position: absolute;
    top: 1px;
    left: 1px;
    width: 16px;
    height: 16px;
    background: color-mix(in srgb, var(--sl-color-text) 55%, var(--sl-color-bg));
    border-radius: 50%;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
    transition:
      transform 0.14s,
      background-color 0.14s;
  }
  .rmd-toggle input:checked + .rmd-toggle-track {
    background: var(--rmd-accent);
    border-color: var(--rmd-accent);
  }
  .rmd-toggle input:checked + .rmd-toggle-track::before {
    background: #fff;
    transform: translateX(14px);
  }
  .rmd-toggle input:focus-visible + .rmd-toggle-track {
    outline: 2px solid var(--rmd-accent);
    outline-offset: 2px;
  }
  .rmd-toggle-label {
    font: 600 12.5px ui-sans-serif, system-ui, sans-serif;
    color: var(--sl-color-text);
    line-height: 1.3;
  }
  .rmd-toggle-label code {
    font: 600 11.5px ui-monospace, SFMono-Regular, Menlo, monospace;
    background: color-mix(in srgb, var(--sl-color-text) 8%, transparent);
    padding: 1px 5px;
    border-radius: 5px;
    white-space: nowrap;
  }

  .rmd-state {
    flex: 0 0 auto;
    font: 600 11px ui-sans-serif, system-ui, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
    padding: 4px 11px;
    border-radius: 999px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
  }
  .rmd.is-reduced .rmd-state {
    color: var(--rmd-accent);
    border-color: color-mix(in srgb, var(--rmd-accent) 45%, transparent);
    background: color-mix(in srgb, var(--rmd-accent) 10%, var(--sl-color-bg));
  }

  /* === Stage: trigger + the area the toast lands in === */
  .rmd-stage {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    min-height: 168px;
    padding: 20px 16px;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    /* A faint dotted backdrop so the empty stage reads as a "screen". */
    background-image: radial-gradient(
      color-mix(in srgb, var(--sl-color-text) 9%, transparent) 1px,
      transparent 1px
    );
    background-size: 14px 14px;
    overflow: hidden;
  }

  .rmd-trigger {
    appearance: none;
    margin: 0;
    font: 600 13px ui-sans-serif, system-ui, sans-serif;
    line-height: 1;
    padding: 10px 16px;
    min-height: 40px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--rmd-accent) 55%, transparent);
    background: var(--rmd-accent);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
    transition:
      filter 0.14s,
      transform 0.06s;
  }
  .rmd-trigger:hover {
    filter: brightness(1.06);
  }
  .rmd-trigger:active {
    transform: translateY(1px);
  }
  .rmd-trigger:focus-visible {
    outline: 2px solid var(--rmd-accent);
    outline-offset: 2px;
  }

  .rmd-toast-area {
    position: relative;
    width: 100%;
    max-width: 320px;
    /* Reserve room so the trigger doesn't jump when the toast mounts. */
    min-height: 64px;
    display: flex;
    justify-content: center;
  }

  .rmd-hint {
    font: 500 11px ui-sans-serif, system-ui, sans-serif;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.02em;
  }

  /* === The toast card === */
  .rmd-toast {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    width: 100%;
    padding: 11px 12px;
    border-radius: 10px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-sidebar);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.16);
    text-align: left;
  }
  .rmd-toast-dot {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 1px;
    border-radius: 50%;
    background: #10b981;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font: 700 11px ui-sans-serif, system-ui, sans-serif;
    line-height: 1;
  }
  .rmd-toast-body {
    flex: 1 1 auto;
    min-width: 0;
  }
  .rmd-toast-title {
    font: 600 13px ui-sans-serif, system-ui, sans-serif;
    color: var(--sl-color-text);
    line-height: 1.3;
  }
  .rmd-toast-text {
    margin-top: 2px;
    font: 400 12px ui-sans-serif, system-ui, sans-serif;
    color: var(--sl-color-gray-2);
    line-height: 1.35;
  }
  .rmd-toast-close {
    appearance: none;
    flex: 0 0 auto;
    margin: -2px -2px 0 0;
    width: 22px;
    height: 22px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-gray-3);
    font: 600 15px ui-sans-serif, system-ui, sans-serif;
    line-height: 1;
    cursor: pointer;
  }
  .rmd-toast-close:hover {
    background: color-mix(in srgb, var(--sl-color-text) 8%, transparent);
    color: var(--sl-color-text);
  }
  .rmd-toast-close:focus-visible {
    outline: 2px solid var(--rmd-accent);
    outline-offset: 1px;
  }

  /* --- Full-motion entrance: slide up + fade. --- */
  @keyframes rmd-slide-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .rmd-toast.rmd-enter {
    animation: rmd-slide-in 320ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* --- Reduced entrance: NO transform. Appears instantly, with a brief
         background flash so it still announces itself. This is the
         "replace, don't remove" swap. --- */
  @keyframes rmd-flash {
    0% {
      background: color-mix(in srgb, var(--rmd-accent) 30%, var(--sl-color-bg-sidebar));
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--rmd-accent) 35%, transparent);
    }
    100% {
      background: var(--sl-color-bg-sidebar);
      box-shadow: 0 10px 26px rgba(0, 0, 0, 0.16);
    }
  }
  .rmd.is-reduced .rmd-toast.rmd-enter {
    animation: rmd-flash 600ms ease-out both;
  }

  /* If the visitor's OS itself asks for reduced motion, honor it too — the
     simulated path already proves the point, so never force a transform. */
  @media (prefers-reduced-motion: reduce) {
    .rmd-toast.rmd-enter {
      animation: rmd-flash 600ms ease-out both;
    }
  }

  /* === Readouts === */
  .rmd-readouts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  .rmd-readout {
    display: inline-flex;
    gap: 8px;
    align-items: baseline;
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    padding: 4px 12px;
  }
  .rmd-readout-label {
    font: 600 11px ui-sans-serif, system-ui, sans-serif;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .rmd-readout-value {
    font: 600 12px ui-monospace, SFMono-Regular, Menlo, monospace;
    color: var(--sl-color-text);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-rmd-root]').forEach((root) => {
    const reduce = root.querySelector<HTMLInputElement>('[data-rmd-reduce]');
    const statePill = root.querySelector<HTMLElement>('[data-rmd-state]');
    const trigger = root.querySelector<HTMLButtonElement>('[data-rmd-trigger]');
    const area = root.querySelector<HTMLElement>('.rmd-toast-area');
    const template = root.querySelector<HTMLTemplateElement>('[data-rmd-toast-template]');
    const readoutMode = root.querySelector<HTMLElement>('[data-rmd-readout-mode]');
    const readoutEntrance = root.querySelector<HTMLElement>('[data-rmd-readout-entrance]');
    if (!reduce || !statePill || !trigger || !area || !template) return;

    let dismissTimer: number | null = null;

    // Mirror the toggle onto the root (gates the CSS) and the labels.
    const applyMode = () => {
      const on = reduce.checked;
      root.classList.toggle('is-reduced', on);
      statePill.textContent = on ? 'reduced motion' : 'full motion';
      if (readoutMode) readoutMode.textContent = on ? 'reduced motion' : 'full motion';
    };
    reduce.addEventListener('change', applyMode);
    applyMode();

    const buildToast = () => {
      // Clone the template so the node inherits Astro's scoped-style class.
      const toast = template.content.firstElementChild!.cloneNode(true) as HTMLElement;
      toast
        .querySelector<HTMLButtonElement>('.rmd-toast-close')
        ?.addEventListener('click', () => dismiss());
      return toast;
    };

    const dismiss = () => {
      if (dismissTimer !== null) {
        window.clearTimeout(dismissTimer);
        dismissTimer = null;
      }
      area.replaceChildren();
    };

    const show = () => {
      // Replace any existing toast so each click is a clean replay.
      dismiss();
      const toast = buildToast();
      area.appendChild(toast);

      // Force a reflow before adding the entrance class so re-clicking
      // restarts the animation even when the same node type is reused.
      void toast.offsetWidth;
      toast.classList.add('rmd-enter');

      if (readoutEntrance) {
        readoutEntrance.textContent = reduce.checked ? 'instant + flash' : 'slide + fade';
      }

      // Auto-dismiss after a few seconds so the stage clears on its own.
      dismissTimer = window.setTimeout(() => dismiss(), 3200);
    };

    trigger.addEventListener('click', show);
  });
</script>
