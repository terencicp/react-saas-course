---
// One frame of the live-region "pre-mount rule" timeline, scrubbed inside a
// <DiagramSequence>. The point is to make an INVISIBLE timing visible: a screen
// reader announces a *mutation inside a region it is already watching* — not a
// region that appears with its text already inside it.
//
// Two side-by-side tracks, fixed for the whole sequence so nothing jumps as you
// scrub:
//   Correct  (always-mounted region)   — green:  empty <div role="status"> mounts
//                                          first, AT registers it, later text
//                                          insertions are announced.
//   Broken   (conditional render)       — red:    {msg && <div role="status">…}
//                                          renders nothing until msg is truthy,
//                                          so the region only ever appears WITH
//                                          text already inside — AT never saw it
//                                          register, so it stays silent.
//
// Each track shows three rows that tell the story together:
//   1. the JSX shape (so the structural difference is on screen)
//   2. a DOM mock of the region — present+empty, present+filled, or absent
//   3. an "AT" indicator — a speaker glyph that either announces the new text
//      or sits muted/silent.
//
// `step` (1–3) selects the frame; source order = scrub order:
//   1  mount          — region exists (empty) vs. nothing in the DOM
//   2  setMsg('Saved')— mutation in a watched region vs. region appears w/ text
//   3  setMsg('Saved ✓') — every subsequent change announces vs. still unreliable
//
// Pure HTML + CSS like the chapter's other figures: `not-content` wrapper,
// theme gray variables for chrome, saturated mid-tones (green / red) with white
// text so the lane colors read in light and dark, and a `margin: 0` reset on
// every inner element to defeat Starlight's prose-margin selector.

interface Props {
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const reset = 'margin: 0';
const mono =
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = 'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';

const OK = '#16a34a'; // green-600 — the correct, always-mounted track
const BAD = '#dc2626'; // red-600   — the broken, conditional-render track

// The DOM mock can be in one of three conditions per frame.
type RegionState =
  | { kind: 'absent' } // not in the DOM at all (conditional render, msg falsy)
  | { kind: 'empty' } // present in the DOM, no text yet
  | { kind: 'filled'; text: string; fresh: boolean }; // present, holding text;
//                                                       `fresh` = text just arrived

// The AT indicator: did the screen reader announce, and if so, what.
type AtState =
  | { kind: 'silent'; note: string }
  | { kind: 'announces'; text: string };

type Track = { region: RegionState; at: AtState };

const frames: Record<Props['step'], { ok: Track; bad: Track }> = {
  // 1 — Mount. Correct: empty region is in the DOM, AT registers and watches it.
  //     Broken: msg is falsy, so the region is not rendered at all — nothing to watch.
  1: {
    ok: {
      region: { kind: 'empty' },
      at: { kind: 'silent', note: 'registers & watches this region' },
    },
    bad: {
      region: { kind: 'absent' },
      at: { kind: 'silent', note: 'no region in the DOM to watch' },
    },
  },
  // 2 — setMsg('Saved'). Correct: text is inserted INTO the already-watched
  //     region → AT detects the mutation and announces. Broken: msg turns
  //     truthy, so the region mounts WITH "Saved" already inside it — AT sees a
  //     brand-new node, not a change in a watched region → silent / unreliable.
  2: {
    ok: {
      region: { kind: 'filled', text: 'Saved', fresh: true },
      at: { kind: 'announces', text: 'Saved' },
    },
    bad: {
      region: { kind: 'filled', text: 'Saved', fresh: true },
      at: { kind: 'silent', note: 'region appeared with text already in it' },
    },
  },
  // 3 — setMsg('Saved ✓'). Correct: still watched, every subsequent change is
  //     announced. Broken: even though the region now exists, it was never
  //     registered, so changes to it remain unreliable.
  3: {
    ok: {
      region: { kind: 'filled', text: 'Saved ✓', fresh: true },
      at: { kind: 'announces', text: 'Saved ✓' },
    },
    bad: {
      region: { kind: 'filled', text: 'Saved ✓', fresh: false },
      at: { kind: 'silent', note: 'never registered — still unreliable' },
    },
  },
};

const frame = frames[step];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  'display: grid',
  'grid-template-columns: 1fr 1fr',
  'gap: 14px',
  'width: 100%',
  'max-width: 720px',
  'margin-left: auto',
  'margin-right: auto',
  'box-sizing: border-box',
  sans,
].join('; ');

const column = (accent: string) =>
  [
    reset,
    'display: flex',
    'flex-direction: column',
    'gap: 10px',
    'padding: 12px',
    'border-radius: 11px',
    'border: 1px solid ' + `color-mix(in srgb, ${accent} 30%, var(--sl-color-hairline))`,
    'background: ' + `color-mix(in srgb, ${accent} 6%, transparent)`,
    'box-sizing: border-box',
    'min-width: 0',
  ].join('; ');

// The column header: a color-keyed title with a one-line subtitle.
const head = [reset, 'display: flex', 'flex-direction: column', 'gap: 2px'].join('; ');

const headTitle = (accent: string) =>
  [
    reset,
    sans,
    'display: flex',
    'align-items: center',
    'gap: 7px',
    'font-size: 13.5px',
    'font-weight: 700',
    'letter-spacing: 0.01em',
    'line-height: 1.15',
    'color: ' + `color-mix(in srgb, ${accent} 65%, var(--sl-color-text))`,
  ].join('; ');

const headDot = (accent: string) =>
  [
    reset,
    'flex: 0 0 auto',
    'width: 9px',
    'height: 9px',
    'border-radius: 50%',
    `background: ${accent}`,
  ].join('; ');

const headSub = [
  reset,
  mono,
  'font-size: 11px',
  'font-weight: 500',
  'line-height: 1.2',
  'color: var(--sl-color-gray-3)',
].join('; ');

// The faux DOM stage each region sits inside, labelled "DOM".
const stage = [
  reset,
  'position: relative',
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'min-height: 64px',
  'padding: 16px 12px 12px',
  'border-radius: 9px',
  'border: 1px dashed var(--sl-color-hairline)',
  'background: var(--sl-color-gray-6)',
  'box-sizing: border-box',
].join('; ');

const stageTag = [
  reset,
  sans,
  'position: absolute',
  'top: 5px',
  'left: 8px',
  'font-size: 9px',
  'font-weight: 700',
  'letter-spacing: 0.06em',
  'text-transform: uppercase',
  'line-height: 1',
  'color: var(--sl-color-gray-4)',
].join('; ');

// The <div role="status"> mock when it is present in the DOM.
const regionBox = (accent: string, filled: boolean, fresh: boolean) =>
  [
    reset,
    'position: relative',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'min-width: 116px',
    'min-height: 32px',
    'padding: 6px 12px',
    'border-radius: 7px',
    mono,
    'font-size: 12.5px',
    'font-weight: 600',
    'line-height: 1.2',
    filled
      ? `background: ${accent}; border: 1.5px solid ${accent}; color: var(--sl-color-white);`
      : `background: var(--sl-color-bg); border: 1.5px solid color-mix(in srgb, ${accent} 45%, var(--sl-color-gray-4)); color: color-mix(in srgb, ${accent} 70%, var(--sl-color-text));`,
    // A subtle ring on a freshly-changed region to draw the eye to the mutation.
    fresh
      ? `box-shadow: 0 0 0 3px color-mix(in srgb, ${accent} 22%, transparent);`
      : '',
  ].join('; ');

// A tiny tag pinned above the region box naming the element.
const regionTag = (accent: string) =>
  [
    reset,
    mono,
    'position: absolute',
    'top: -9px',
    'left: 50%',
    'transform: translateX(-50%)',
    'white-space: nowrap',
    'padding: 1px 7px',
    'border-radius: 999px',
    'font-size: 9px',
    'font-weight: 700',
    'letter-spacing: 0.01em',
    'line-height: 1.4',
    `background: color-mix(in srgb, ${accent} 14%, var(--sl-color-bg))`,
    `color: color-mix(in srgb, ${accent} 75%, var(--sl-color-text))`,
    `border: 1px solid color-mix(in srgb, ${accent} 40%, transparent)`,
  ].join('; ');

// The "absent from the DOM" placeholder — a ghosted, dashed empty slot.
const absentBox = [
  reset,
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'min-width: 116px',
  'min-height: 32px',
  'padding: 6px 12px',
  'border-radius: 7px',
  'border: 1.5px dashed var(--sl-color-gray-4)',
  'background: transparent',
  sans,
  'font-size: 10.5px',
  'font-weight: 600',
  'letter-spacing: 0.02em',
  'color: var(--sl-color-gray-4)',
].join('; ');

// The AT indicator strip beneath the stage.
const atRow = (announces: boolean, accent: string) =>
  [
    reset,
    'display: flex',
    'align-items: center',
    'gap: 8px',
    'padding: 7px 10px',
    'border-radius: 8px',
    'box-sizing: border-box',
    announces
      ? `background: color-mix(in srgb, ${accent} 13%, var(--sl-color-bg)); border: 1px solid color-mix(in srgb, ${accent} 40%, transparent);`
      : 'background: var(--sl-color-bg); border: 1px dashed var(--sl-color-gray-4);',
  ].join('; ');

const atIcon = (announces: boolean, accent: string) =>
  [
    reset,
    'flex: 0 0 auto',
    'display: inline-flex',
    'align-items: center',
    'justify-content: center',
    'width: 22px',
    'height: 22px',
    'color: ' + (announces ? accent : 'var(--sl-color-gray-3)'),
  ].join('; ');

const atText = (announces: boolean, accent: string) =>
  [
    reset,
    sans,
    'min-width: 0',
    'font-size: 11.5px',
    'font-weight: 600',
    'line-height: 1.3',
    'color: ' + (announces ? `color-mix(in srgb, ${accent} 70%, var(--sl-color-text))` : 'var(--sl-color-gray-3)'),
  ].join('; ');

const atQuote = (accent: string) =>
  [reset, mono, 'font-weight: 700', `color: ${accent}`].join('; ');

type ColView = { title: string; sub: string; accent: string; track: Track };

const columns: ColView[] = [
  {
    title: 'Correct',
    sub: 'always-mounted region',
    accent: OK,
    track: frame.ok,
  },
  {
    title: 'Broken',
    sub: 'conditional render',
    accent: BAD,
    track: frame.bad,
  },
];

const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
---

<div class="pre-mount-rule not-content" style={root}>
  {
    columns.map((col) => (
      <div style={column(col.accent)}>
        <div style={head}>
          <span style={headTitle(col.accent)}>
            <span style={headDot(col.accent)} aria-hidden="true" />
            {col.title}: {col.sub}
          </span>
          <span
            style={headSub}
            set:html={
              col.accent === OK
                ? esc('<div role="status">{msg}</div>')
                : esc('{msg && <div role="status">{msg}</div>}')
            }
          />
        </div>

        {/* DOM stage holding the region mock (or its absence) */}
        <div style={stage}>
          <span style={stageTag}>DOM</span>
          {col.track.region.kind === 'absent' ? (
            <div style={absentBox}>not rendered</div>
          ) : (
            <div
              style={regionBox(
                col.accent,
                col.track.region.kind === 'filled',
                col.track.region.kind === 'filled' && col.track.region.fresh,
              )}
            >
              <span style={regionTag(col.accent)}>role="status"</span>
              {col.track.region.kind === 'filled' ? col.track.region.text : ' '}
            </div>
          )}
        </div>

        {/* AT indicator */}
        <div style={atRow(col.track.at.kind === 'announces', col.accent)}>
          <span style={atIcon(col.track.at.kind === 'announces', col.accent)} aria-hidden="true">
            {col.track.at.kind === 'announces' ? (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 5 6 9H2v6h4l5 4z" />
                <path d="M15.5 8.5a5 5 0 0 1 0 7" />
                <path d="M18.5 5.5a9 9 0 0 1 0 13" />
              </svg>
            ) : (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 5 6 9H2v6h4l5 4z" />
                <line x1="22" y1="9" x2="16" y2="15" />
                <line x1="16" y1="9" x2="22" y2="15" />
              </svg>
            )}
          </span>
          <span style={atText(col.track.at.kind === 'announces', col.accent)}>
            {col.track.at.kind === 'announces' ? (
              <Fragment>
                AT announces <span style={atQuote(col.accent)} set:html={'“' + esc(col.track.at.text) + '”'} />
              </Fragment>
            ) : (
              <Fragment>AT silent — {col.track.at.note}</Fragment>
            )}
          </span>
        </div>
      </div>
    ))
  }
</div>

<style>
  /* On narrow viewports the two tracks stack so labels and boxes stay legible. */
  @media (max-width: 520px) {
    .pre-mount-rule {
      grid-template-columns: 1fr !important;
    }
  }
</style>
