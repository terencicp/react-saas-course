---
// FilterChipRow — Chapter 060 Lesson 2, "showing and undoing filters".
//
// A STATIC (non-interactive) mockup of the active-filter chip row that sits above
// the invoices table. Pure visual grounding for the prose: one small pill per
// active filter, each carrying a label and a ✕ affordance, then a "Clear filters"
// text link set apart from the chips. A faint, greyed-out table header peeks below
// so the row reads as "above the table".
//
// The chips render from server-derived props in the real app; this is just their
// shape, so nothing here is wired — the ✕ and the link are visual affordances only
// (aria-hidden, not real buttons).
//
// Engine: plain HTML + CSS — the diagrams index's pick for a small color-coded UI
// mockup, and it mirrors the sibling StaleCursorBreakage figure's grammar (muted
// surface, hairline borders, theme-aware Starlight tokens + color-mix). `.not-content`
// strips Starlight prose styling; a `margin: 0` reset on every descendant defeats
// the prose-margin injection. <Figure> + caption come from the MDX call site.

// One active filter per chip. `label` names the filter, `value` is what it narrows
// to — the two halves the real chip pulls from the parsed server state.
const chips = [
	{ label: "Status", value: "Paid" },
	{ label: "Tags", value: "Billing, Urgent" },
	{ label: "Created", value: "Jan – Mar" },
];

// Greyed ghost of the table header below the chip row, so the mockup is anchored
// "above the table". Purely decorative.
const columns = ["Invoice", "Customer", "Amount", "Created", "Status"];

const ALT =
	"A horizontal row of active-filter chips above an invoices table. Three rounded pills each show a filter and its value with a small close icon on the right: Status: Paid, Tags: Billing, Urgent, and Created: Jan to Mar. After the chips, set apart, is a Clear filters text link. Below, faded, is the table header row reading Invoice, Customer, Amount, Created, Status, grounding the chips as sitting above the table.";
---

<div class="fcr not-content" role="img" aria-label={ALT}>
	{/* ── The active-filter chip row ────────────────────────────────────────── */}
	<div class="fcr-row">
		<span class="fcr-lead" aria-hidden="true">Filters</span>

		{
			chips.map((chip) => (
				<span class="fcr-chip">
					<span class="fcr-chip-label">{chip.label}:</span>
					<span class="fcr-chip-value">{chip.value}</span>
					<span class="fcr-chip-x" aria-hidden="true">
						&times;
					</span>
				</span>
			))
		}

		<span class="fcr-clear" aria-hidden="true">Clear filters</span>
	</div>

	{/* ── A faded table header, just enough to read "above the table" ────────── */}
	<div class="fcr-table" aria-hidden="true">
		<div class="fcr-thead">
			{columns.map((col) => <span class="fcr-th">{col}</span>)}
		</div>
		<div class="fcr-trow"></div>
		<div class="fcr-trow"></div>
	</div>
</div>

<style>
	.fcr {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 10px;
		width: 100%;
		max-width: 640px;
		margin-inline: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.fcr * {
		box-sizing: border-box;
		margin: 0;
	}

	/* ── The chip row ──────────────────────────────────────────────────────── */
	.fcr-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		column-gap: 8px;
		row-gap: 8px;
	}
	.fcr-lead {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* An active-filter chip: rounded pill, label + value + ✕. */
	.fcr-chip {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 4px 5px 4px 11px;
		border-radius: 999px;
		font-size: 12.5px;
		line-height: 1.2;
		border: 1px solid
			color-mix(in srgb, var(--sl-color-accent, #3b82f6) 38%, transparent);
		background: color-mix(
			in srgb,
			var(--sl-color-accent, #3b82f6) 10%,
			var(--sl-color-bg, #fff)
		);
		color: var(--sl-color-white, #1e293b);
	}
	.fcr-chip-label {
		font-weight: 400;
		color: var(--sl-color-gray-2, #475569);
	}
	.fcr-chip-value {
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}
	/* The ✕ affordance — a small round target on the right of each chip. */
	.fcr-chip-x {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 17px;
		height: 17px;
		border-radius: 999px;
		font-size: 14px;
		line-height: 1;
		font-weight: 700;
		color: color-mix(in srgb, var(--sl-color-accent, #3b82f6) 70%, var(--sl-color-text));
		background: color-mix(in srgb, var(--sl-color-accent, #3b82f6) 20%, transparent);
	}

	/* "Clear filters" — a text link, set apart from the chips. */
	.fcr-clear {
		margin-left: 4px;
		font-size: 12px;
		font-weight: 600;
		color: var(--sl-color-text-accent, #2563eb);
		text-decoration: underline;
		text-underline-offset: 2px;
		text-decoration-thickness: 1px;
		cursor: pointer;
	}

	/* ── The ghost table header below ──────────────────────────────────────── */
	.fcr-table {
		display: flex;
		flex-direction: column;
		border-radius: 9px;
		overflow: hidden;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
		opacity: 0.55;
	}
	.fcr-thead {
		display: flex;
		gap: 14px;
		padding: 8px 13px;
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}
	.fcr-th {
		flex: 1 1 0;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		white-space: nowrap;
	}
	/* Two empty body rows — hairline separators hint at table content. */
	.fcr-trow {
		height: 13px;
		border-top: 1px solid var(--sl-color-gray-6, #e6e8ec);
	}
	.fcr-trow:first-of-type {
		border-top: none;
	}
</style>
