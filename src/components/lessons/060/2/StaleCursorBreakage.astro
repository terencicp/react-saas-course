---
// StaleCursorBreakage — Chapter 060 Lesson 2, "the reset invariant".
//
// The one takeaway: a `cursor` bookmarks a POSITION in one specific ordering.
// Change the sort and carry the same cursor along, and it now decodes against a
// DIFFERENT ordering — pointing at a meaningless spot. Rows repeat, rows vanish.
// This is the canonical bug of URL-state list views, and the reason every write
// that changes what-is-shown must bundle `cursor: null`.
//
// Layout: two compact "result list" tables side by side.
//   LEFT  — sorted newest-first; the cursor sits on the boundary after row D
//           ("next page starts here"), the honest, intended position.
//   RIGHT — the SAME five rows reordered by amount (high→low); the cursor came
//           along UNCHANGED to the same raw boundary (after the 4th row), where
//           it now means nothing. Two rows are flagged with a saturated red fill:
//           one "shown twice", one "skipped", to make the breakage concrete.
// Below ~540px the two tables stack via flex-wrap.
//
// Engine: plain HTML + CSS — the diagrams index's pick for a colour-coded,
// table-shaped illustration with callouts, and it matches the sibling list-view
// figures' grammar (muted card, hairline borders, theme-aware Starlight tokens +
// color-mix). `.not-content` drops Starlight prose styling; a `margin: 0` reset on
// every descendant defeats the prose-margin injection. <Figure> + the rich
// caption come from the MDX call site, not here.

// Saturated mid-tones (Tailwind 600-range) that read on both light and dark
// Figure cards. GREEN = the cursor that is correctly placed; RED = the breakage.
const GREEN = "#16a34a";
const RED = "#dc2626";

// Five invoices, identified by a stable letter so the eye can track each row
// across the two orderings.
const byDate = [
	{ id: "A", date: "Apr 18", amount: "$9,100" },
	{ id: "B", date: "Apr 12", amount: "$2,300" },
	{ id: "C", date: "Apr 09", amount: "$12,400" },
	{ id: "D", date: "Apr 03", amount: "$880" },
	{ id: "E", date: "Mar 28", amount: "$6,750" },
];

// The same rows, now ordered by amount, high → low: C, A, E, B, D.
const byAmount = [byDate[2], byDate[0], byDate[4], byDate[1], byDate[3]];

// On the right list, mark the two rows whose fate is broken by the stale cursor.
const flagged: Record<string, "twice" | "skipped"> = {
	E: "twice", // already shown on page 1 of the date list, served again here
	B: "skipped", // falls past the misplaced boundary and is never shown
};

const ALT =
	"Two small invoice tables side by side. The left table is sorted newest first: rows A, B, C, D, E by date, with a cursor marker on the boundary after row D reading next page starts here. The right table holds the same five rows reordered by amount from high to low: C, A, E, B, D. The cursor has been carried over unchanged to the same physical boundary after the fourth row, where it now lands in a meaningless spot. Two rows are highlighted in red to show the breakage: row E is flagged shown twice and row B is flagged skipped. The point is that a cursor bookmarks a position in one ordering and becomes nonsense under another, so every change to the result set must clear the cursor.";
---

<div
	class="scb not-content"
	role="img"
	aria-label={ALT}
	style={`--green:${GREEN};--red:${RED}`}
>
	{/* ── LEFT: the date ordering, cursor correctly placed ──────────────────── */}
	<div class="scb-panel">
		<div class="scb-head">
			<span class="scb-eyebrow">before</span>
			<span class="scb-title">Sort: newest first</span>
			<span class="scb-sub">
				<code class="scb-mono">?sort=-createdAt&amp;cursor=…</code>
			</span>
		</div>

		<div class="scb-table">
			<div class="scb-row scb-row-head" aria-hidden="true">
				<span class="scb-cell scb-cell-id">#</span>
				<span class="scb-cell scb-cell-key">Created</span>
			</div>
			{
				byDate.map((row, i) => (
					<>
						<div class="scb-row">
							<span class="scb-cell scb-cell-id">{row.id}</span>
							<span class="scb-cell scb-cell-key">{row.date}</span>
						</div>
						{i === 3 && (
							<div class="scb-cursor scb-cursor-ok">
								<span class="scb-cursor-line" />
								<span class="scb-cursor-tag">
									cursor &rarr; next page starts here
								</span>
								<span class="scb-cursor-line" />
							</div>
						)}
					</>
				))
			}
		</div>
		<span class="scb-foot scb-foot-ok">
			A position in <strong>this</strong> ordering &mdash; correct.
		</span>
	</div>

	{/* The hand-off: the same cursor, dragged across unchanged. */}
	<div class="scb-bridge" aria-hidden="true">
		<span class="scb-bridge-arrow">&rarr;</span>
		<span class="scb-bridge-label">same cursor,<br />carried over</span>
	</div>

	{/* ── RIGHT: the amount ordering, cursor now meaningless ────────────────── */}
	<div class="scb-panel">
		<div class="scb-head">
			<span class="scb-eyebrow scb-eyebrow-bad">after</span>
			<span class="scb-title">Sort: amount, high &rarr; low</span>
			<span class="scb-sub">
				<code class="scb-mono">?sort=-total&amp;cursor=…</code>
				<span class="scb-stale">cursor unchanged</span>
			</span>
		</div>

		<div class="scb-table">
			<div class="scb-row scb-row-head" aria-hidden="true">
				<span class="scb-cell scb-cell-id">#</span>
				<span class="scb-cell scb-cell-key">Amount</span>
			</div>
			{
				byAmount.map((row, i) => (
					<>
						<div
							class={
								"scb-row" +
								(flagged[row.id] === "twice" ? " scb-row-bad" : "") +
								(flagged[row.id] === "skipped" ? " scb-row-bad" : "")
							}
						>
							<span class="scb-cell scb-cell-id">{row.id}</span>
							<span class="scb-cell scb-cell-key">{row.amount}</span>
							{flagged[row.id] === "twice" && (
								<span class="scb-flag">shown twice</span>
							)}
							{flagged[row.id] === "skipped" && (
								<span class="scb-flag">skipped</span>
							)}
						</div>
						{i === 3 && (
							<div class="scb-cursor scb-cursor-bad">
								<span class="scb-cursor-line" />
								<span class="scb-cursor-tag">
									cursor lands here &mdash; meaningless
								</span>
								<span class="scb-cursor-line" />
							</div>
						)}
					</>
				))
			}
		</div>
		<span class="scb-foot scb-foot-bad">
			Same bookmark, <strong>wrong</strong> list &mdash; rows repeat and vanish.
		</span>
	</div>
</div>

<style>
	.scb {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 14px;
		width: 100%;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.scb * {
		box-sizing: border-box;
		margin: 0;
	}
	.scb-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
	}

	/* ── A result-list panel: header + compact table + footnote ────────────── */
	.scb-panel {
		display: flex;
		flex-direction: column;
		flex: 1 1 250px;
		min-width: 0;
		max-width: 320px;
		gap: 9px;
		padding: 13px 14px 12px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
	}

	.scb-head {
		display: flex;
		flex-direction: column;
		gap: 3px;
	}
	.scb-eyebrow {
		align-self: flex-start;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 2px 7px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--green) 80%, var(--sl-color-white, #14532d));
		background: color-mix(in srgb, var(--green) 14%, transparent);
	}
	.scb-eyebrow-bad {
		color: color-mix(in srgb, var(--red) 80%, var(--sl-color-white, #7f1d1d));
		background: color-mix(in srgb, var(--red) 14%, transparent);
	}
	.scb-title {
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
	}
	.scb-sub {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 6px;
		font-size: 11px;
	}
	.scb-sub .scb-mono {
		font-size: 10.5px;
		color: var(--sl-color-gray-2, #475569);
		background: transparent;
		padding: 0;
		white-space: nowrap;
	}
	.scb-stale {
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		padding: 1px 6px;
		border-radius: 999px;
		white-space: nowrap;
		color: color-mix(in srgb, var(--red) 82%, var(--sl-color-text));
		background: color-mix(in srgb, var(--red) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--red) 34%, transparent);
	}

	/* ── The table itself: hairline-separated rows ─────────────────────────── */
	.scb-table {
		display: flex;
		flex-direction: column;
		border-radius: 9px;
		overflow: hidden;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.scb-row {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 7px 11px;
		border-top: 1px solid var(--sl-color-gray-6, #e6e8ec);
		font-size: 12.5px;
		line-height: 1.2;
	}
	.scb-row:first-child {
		border-top: none;
	}
	.scb-row-head {
		padding-top: 6px;
		padding-bottom: 6px;
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.scb-cell-id {
		flex: 0 0 1.4em;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}
	.scb-row-head .scb-cell-id {
		color: var(--sl-color-gray-3, #64748b);
	}
	.scb-cell-key {
		flex: 1 1 auto;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-1, #334155);
	}

	/* A broken row: saturated red fill, white text — survives both themes. */
	.scb-row-bad {
		background: var(--red);
	}
	.scb-row-bad .scb-cell-id,
	.scb-row-bad .scb-cell-key {
		color: #fff;
	}
	.scb-flag {
		flex: 0 0 auto;
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		padding: 1px 6px;
		border-radius: 999px;
		color: var(--red);
		background: #fff;
	}

	/* ── The cursor boundary, drawn between two rows ───────────────────────── */
	.scb-cursor {
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 4px 11px;
	}
	.scb-cursor-line {
		flex: 1 1 auto;
		height: 0;
		border-top: 2px dashed currentColor;
	}
	.scb-cursor-tag {
		flex: 0 0 auto;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.02em;
		white-space: nowrap;
	}
	.scb-cursor-ok {
		color: color-mix(in srgb, var(--green) 78%, var(--sl-color-text));
		background: color-mix(in srgb, var(--green) 9%, transparent);
	}
	.scb-cursor-bad {
		color: color-mix(in srgb, var(--red) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--red) 9%, transparent);
	}

	.scb-foot {
		font-size: 10.5px;
		line-height: 1.35;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
	}
	.scb-foot strong {
		font-weight: 700;
	}
	.scb-foot-ok strong {
		color: color-mix(in srgb, var(--green) 74%, var(--sl-color-text));
	}
	.scb-foot-bad strong {
		color: color-mix(in srgb, var(--red) 78%, var(--sl-color-text));
	}

	/* ── The bridge between the two panels: same cursor, carried over ──────── */
	.scb-bridge {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		flex: 0 0 auto;
		padding: 0 2px;
	}
	.scb-bridge-arrow {
		font-size: 22px;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-3, #94a3b8);
	}
	.scb-bridge-label {
		font-size: 9.5px;
		font-weight: 600;
		line-height: 1.25;
		text-align: center;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── Narrow Figure: stack the panels, turn the bridge horizontal ───────── */
	@media (max-width: 540px) {
		.scb {
			flex-direction: column;
			align-items: center;
		}
		.scb-panel {
			max-width: 340px;
			width: 100%;
		}
		.scb-bridge {
			flex-direction: row;
			gap: 8px;
			padding: 2px 0;
		}
		.scb-bridge-arrow {
			transform: rotate(90deg);
		}
		.scb-bridge-label br {
			display: none;
		}
	}
</style>
