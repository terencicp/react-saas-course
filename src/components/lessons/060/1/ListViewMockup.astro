---
// ListViewMockup — Chapter 060 Lesson 1, "The list-view anatomy".
//
// The chapter-opening visual anchor: a faithful, STATIC (non-interactive) mockup
// of a SaaS invoices list-view surface, with every control tied to the slice of
// the URL it owns. Its one job is to map UI affordance -> URL parameter before any
// code appears, so the "four controls, four fragments, one URL" idea lands as a
// picture.
//
// Layout, top to bottom:
//   1. a toolbar row — a status FILTER dropdown, a SORT control, and a SEARCH box,
//      each carrying a small coloured pill naming its pillar and the URL fragment
//      it writes (?status=overdue, &sort=-total, &q=Acme);
//   2. the TABLE — a header row + a few stub data rows. It is labelled
//      "DATA (server-rendered)" and is deliberately NOT a pillar: it is the result
//      the four parameters produce, not a control;
//   3. a PAGINATE row — Page 2 with prev/next chevrons and its &cursor=… pill.
//
// The four pillar colours are the SAME key the student already met in chapter 046
// L4's UrlDimensionStrip (filter = blue, sort = violet, search = orange,
// paginate = green), so the colour-to-pillar mapping carries across the course.
// The neutral table sits outside that key in muted grey, reinforcing "result, not
// pillar". The MDX call site wraps this in <Figure> and supplies the caption that
// stitches the four fragments into one address.
//
// Built as plain HTML + CSS (the diagrams index's pick for an annotated UI
// illustration), themed with Starlight CSS variables so it reads as a native app
// surface on both light and dark. `not-content` + `margin: 0` resets defeat
// Starlight's prose-margin injection; an aria-label describes the figure for
// assistive tech since there is no <img>.

const ALT =
	'A SaaS invoices list-view surface. A toolbar holds three controls, each tied ' +
	'to a URL parameter: a status filter set to Overdue (?status=overdue), a sort ' +
	'control set to Amount, descending (&sort=-total), and a search box containing ' +
	'Acme (&q=Acme). Below sits the server-rendered table of matching invoices, and ' +
	'a pagination row showing Page 2 (&cursor=…).';

// Stub rows for the result table — terse fake invoices that all satisfy the
// toolbar (status Overdue, mentioning Acme, largest amount first).
const rows = [
	{ customer: 'Acme Corp', amount: '$12,400', due: 'Apr 3' },
	{ customer: 'Acme Logistics', amount: '$8,900', due: 'Mar 28' },
	{ customer: 'Acme Studio', amount: '$3,150', due: 'Apr 11' },
];
---

<div class="lvm not-content" role="img" aria-label={ALT}>
	{/* ---- the app surface ------------------------------------------------- */}
	<div class="lvm-card">
		{/* window chrome so it reads as a real screen, not a wireframe */}
		<div class="lvm-chrome" aria-hidden="true">
			<span class="lvm-dot"></span>
			<span class="lvm-dot"></span>
			<span class="lvm-dot"></span>
			<span class="lvm-url">/invoices</span>
		</div>

		{/* (1) toolbar: the three control pillars */}
		<div class="lvm-toolbar">
			{/* FILTER — status dropdown */}
			<div class="lvm-control">
				<div class="lvm-field lvm-field-select">
					<span class="lvm-field-label">Status</span>
					<span class="lvm-field-val">Overdue</span>
					<span class="lvm-caret" aria-hidden="true">▾</span>
				</div>
				<span class="lvm-tag lvm-tag-filter">
					<span class="lvm-tag-pillar">Filter</span>
					<code class="lvm-tag-frag">?status=overdue</code>
				</span>
			</div>

			{/* SORT — order control */}
			<div class="lvm-control">
				<div class="lvm-field lvm-field-select">
					<span class="lvm-field-label">Sort</span>
					<span class="lvm-field-val">Amount&nbsp;↓</span>
					<span class="lvm-caret" aria-hidden="true">▾</span>
				</div>
				<span class="lvm-tag lvm-tag-sort">
					<span class="lvm-tag-pillar">Sort</span>
					<code class="lvm-tag-frag">&sort=-total</code>
				</span>
			</div>

			{/* SEARCH — free-text box, shown with a committed value */}
			<div class="lvm-control lvm-control-search">
				<div class="lvm-field lvm-field-search">
					<span class="lvm-search-icon" aria-hidden="true">⌕</span>
					<span class="lvm-field-val">Acme</span>
				</div>
				<span class="lvm-tag lvm-tag-search">
					<span class="lvm-tag-pillar">Search</span>
					<code class="lvm-tag-frag">&q=Acme</code>
				</span>
			</div>
		</div>

		{/* (2) the result table — NOT a pillar, the data those params produce */}
		<div class="lvm-table">
			<div class="lvm-thead">
				<span class="lvm-th lvm-col-customer">Customer</span>
				<span class="lvm-th lvm-col-status">Status</span>
				<span class="lvm-th lvm-col-amount">Amount</span>
				<span class="lvm-th lvm-col-due">Due</span>
			</div>
			{
				rows.map((row) => (
					<div class="lvm-tr">
						<span class="lvm-td lvm-col-customer">{row.customer}</span>
						<span class="lvm-col-status">
							<span class="lvm-badge">Overdue</span>
						</span>
						<span class="lvm-td lvm-td-amount lvm-col-amount">{row.amount}</span>
						<span class="lvm-td lvm-col-due">{row.due}</span>
					</div>
				))
			}
			<span class="lvm-tag lvm-tag-data">Data (server-rendered)</span>
		</div>

		{/* (3) pagination — the slice of the result the user is on */}
		<div class="lvm-pager-row">
			<div class="lvm-pager">
				<span class="lvm-chev" aria-hidden="true">‹</span>
				<span class="lvm-page">Page 2</span>
				<span class="lvm-chev" aria-hidden="true">›</span>
			</div>
			<span class="lvm-tag lvm-tag-paginate">
				<span class="lvm-tag-pillar">Paginate</span>
				<code class="lvm-tag-frag">&cursor=…</code>
			</span>
		</div>
	</div>
</div>

<style>
	/* ---- shell ----------------------------------------------------------- */
	.lvm {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		color: var(--sl-color-white, #1e293b);
	}
	.lvm * {
		box-sizing: border-box;
	}

	/* the app-surface card */
	.lvm-card {
		margin: 0;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		border-radius: 12px;
		background: var(--sl-color-bg, #fff);
		overflow: hidden;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
	}

	/* window chrome */
	.lvm-chrome {
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 9px 14px;
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
	}
	.lvm-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--sl-color-gray-4, #cbd5e1);
	}
	.lvm-url {
		margin: 0 0 0 8px;
		padding: 3px 10px;
		border-radius: 6px;
		background: var(--sl-color-bg, #fff);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12px;
		color: var(--sl-color-gray-2, #475569);
	}

	/* ---- toolbar (the three control pillars) ----------------------------- */
	.lvm-toolbar {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: 14px;
		padding: 16px 16px 18px;
	}
	.lvm-control {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 8px;
		min-width: 0;
	}
	.lvm-control-search {
		flex: 1 1 150px;
	}

	/* a control "field" — looks like a real dropdown / input */
	.lvm-field {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		height: 36px;
		padding: 0 12px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
		font-size: 13.5px;
		white-space: nowrap;
	}
	.lvm-field-search {
		width: 100%;
	}
	.lvm-field-label {
		color: var(--sl-color-gray-3, #64748b);
		font-weight: 600;
	}
	.lvm-field-val {
		color: var(--sl-color-white, #0f172a);
		font-weight: 600;
	}
	.lvm-caret {
		margin-left: 2px;
		font-size: 10px;
		color: var(--sl-color-gray-3, #94a3b8);
	}
	.lvm-search-icon {
		font-size: 15px;
		color: var(--sl-color-gray-3, #94a3b8);
	}
	.lvm-field-search .lvm-field-val {
		font-weight: 500;
	}

	/* ---- the URL-fragment tag pinned under each control ------------------ */
	.lvm-tag {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		padding: 3px 4px 3px 8px;
		border-radius: 7px;
		font-size: 11px;
		line-height: 1.4;
		border: 1px solid color-mix(in srgb, var(--tag) 35%, transparent);
		background: color-mix(in srgb, var(--tag) 12%, var(--sl-color-bg, #fff));
	}
	.lvm-tag-pillar {
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		font-size: 9.5px;
		color: var(--tag);
	}
	.lvm-tag-frag {
		margin: 0;
		padding: 1px 6px;
		border-radius: 5px;
		background: var(--tag);
		color: #fff;
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11px;
		font-weight: 600;
		white-space: nowrap;
	}

	/* the four pillar colours — the same key as ch 046 L4's UrlDimensionStrip */
	.lvm-tag-filter {
		--tag: #2563eb;
	} /* blue */
	.lvm-tag-sort {
		--tag: #7c3aed;
	} /* violet */
	.lvm-tag-search {
		--tag: #ea580c;
	} /* orange */
	.lvm-tag-paginate {
		--tag: #16a34a;
	} /* green */

	/* ---- the result table (NOT a pillar) --------------------------------- */
	.lvm-table {
		position: relative;
		margin: 0 16px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		border-radius: 10px;
		overflow: hidden;
		background: var(--sl-color-bg, #fff);
	}
	.lvm-thead,
	.lvm-tr {
		display: grid;
		grid-template-columns: 1.6fr 1fr 1fr 0.8fr;
		align-items: center;
		gap: 10px;
		padding: 9px 14px;
	}
	.lvm-thead {
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		border-bottom: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}
	.lvm-th {
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}
	.lvm-tr + .lvm-tr {
		border-top: 1px solid
			color-mix(in srgb, var(--sl-color-gray-5, #d0d5dd) 60%, transparent);
	}
	.lvm-td {
		font-size: 13px;
		color: var(--sl-color-white, #0f172a);
	}
	.lvm-td-amount {
		font-variant-numeric: tabular-nums;
		font-weight: 600;
	}
	.lvm-col-amount {
		text-align: right;
	}
	.lvm-badge {
		display: inline-block;
		padding: 2px 9px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 600;
		color: #b91c1c;
		background: color-mix(in srgb, #ef4444 16%, var(--sl-color-bg, #fff));
		border: 1px solid color-mix(in srgb, #ef4444 32%, transparent);
	}
	/* the table's "result, not pillar" label, floated on its top-right edge */
	.lvm-tag-data {
		position: absolute;
		top: -10px;
		right: 12px;
		padding: 2px 9px;
		border-radius: 6px;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
	}

	/* ---- pagination ------------------------------------------------------ */
	.lvm-pager-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 14px;
		padding: 16px 16px 18px;
	}
	.lvm-pager {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 4px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.lvm-chev {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 6px;
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		color: var(--sl-color-gray-2, #475569);
		font-size: 15px;
		line-height: 1;
	}
	.lvm-page {
		padding: 0 10px;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-white, #0f172a);
	}

	/* On a narrow Figure, let the search control take a full row of its own so
	   no tag ever collides with its neighbour. */
	@media (max-width: 560px) {
		.lvm-control-search {
			flex-basis: 100%;
		}
		.lvm-thead,
		.lvm-tr {
			grid-template-columns: 1.4fr 1fr 1fr;
		}
		.lvm-col-due {
			display: none;
		}
	}
</style>
