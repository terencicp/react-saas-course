---
// TypedCommittedTimeline — Chapter 060 Lesson 3, "typed vs. committed".
//
// The unlock of the whole lesson in one static picture: the search box holds TWO
// pieces of state with two homes, and they diverge ON PURPOSE while you type.
//   TOP track  — "typed" (component state): one pill per keystroke, marching
//                left→right as the user spells out `overdue`. Fast, blue.
//   BOTTOM track — "committed" (URL ?q=): a flat segment pinned at the OLD value
//                (no q) under the entire typing burst, then — after a visible
//                settling gap — a single green pill snapping to `overdue`.
// A shaded vertical band over the gap+commit columns, dropping across BOTH
// tracks and labelled "settles → commit", marks the one moment typed →
// committed. Seeing both tracks at once is the point, so this is a single static
// two-track figure, not a scrubbable sequence.
//
// Engine: plain HTML + CSS — the diagrams index's pick for an annotated, colour-
// coded illustration, matching the sibling list-view figures' grammar (muted
// card, hairline borders, theme-aware Starlight tokens + color-mix).
//
// Layout: ONE CSS grid gives both tracks a genuine shared time axis. Columns:
//   [label gutter] [k1 … k7 keystrokes, 1fr each] [settling gap] [commit].
// The typed pills each occupy one keystroke column; the committed flat segment
// spans all seven; the committed pill sits in the commit column; the settling
// band spans the gap+commit columns across both track rows. Putting both rows in
// the SAME grid is what keeps the commit pill aligned under the band and just
// past the burst — independent grids drift. `.not-content` drops Starlight prose
// styling; a `margin: 0` reset on every descendant defeats the prose-margin
// injection. <Figure> + the rich caption come from the MDX call site, not here.

// Saturated mid-tones (Tailwind 600-range) that read on both light and dark
// Figure cards. BLUE = typed (fast, every keystroke); GREEN = committed (settled).
const BLUE = "#2563eb"; // typed — component state
const GREEN = "#16a34a"; // committed — the URL

// One pill per keystroke as the user spells out the search term. Each is the full
// growing value, so the eye reads the box filling up character by character.
const typed = ["o", "ov", "ove", "over", "overd", "overdu", "overdue"];

const ALT =
	"A two-track timeline sharing one left-to-right time axis. The top track, labelled typed (component state), is a row of blue pills marching rightward as a user spells out a search term, one pill per keystroke: o, ov, ove, over, overd, overdu, overdue — fast, on every keystroke. The bottom track, labelled committed (URL ?q=), is a long flat segment pinned at the old value, shown as (no q), running underneath the entire typing burst. After a visible settling gap a single green pill snaps to overdue. A shaded vertical band over the gap, labelled settles then commit, drops across both tracks and marks the moment the committed value catches up to the typed value. The two tracks diverge on purpose while typing and reconverge a beat after it settles.";
---

<div
	class="tct not-content"
	role="img"
	aria-label={ALT}
	style={`--blue:${BLUE};--green:${GREEN}`}
>
	{/* ── ROW 1: typed — the axis label, then a tight burst of keystroke pills ── */}
	<span class="tct-axis tct-axis-typed" style="grid-row: 1;">
		typed <span class="tct-axis-home">component state</span>
	</span>
	<div class="tct-lane tct-lane-typed" style="grid-row: 1;">
		<span class="tct-burst">
			{
				typed.map((value) => (
					<span class="tct-pill tct-pill-typed">{value}</span>
				))
			}
		</span>
		<span class="tct-rightslot" aria-hidden="true" />
	</div>

	{/* ── The settling band: drops across both rows over the reserved right slot ─ */}
	<div class="tct-settle" aria-hidden="true">
		<span class="tct-settle-label">settles &rarr; commit</span>
	</div>

	{/* ── ROW 2: committed — flat old value across the burst, then one snap ──── */}
	<span class="tct-axis tct-axis-committed" style="grid-row: 2;">
		committed <span class="tct-axis-home">URL &middot; ?q=</span>
	</span>
	<div class="tct-lane tct-lane-committed" style="grid-row: 2;">
		<span class="tct-burst tct-burst-flat">
			<span class="tct-flat-value">(no q)</span>
			<span class="tct-flat-line" aria-hidden="true" />
		</span>
		<span class="tct-rightslot tct-rightslot-commit">
			<span class="tct-pill tct-pill-committed">?q=overdue</span>
		</span>
	</div>

	{/* ── ROW 3: the shared time axis, flowing rightward under both tracks ───── */}
	<div class="tct-timeaxis" style="grid-row: 3;" aria-hidden="true">
		<span class="tct-timeaxis-line" />
		<span class="tct-timeaxis-label">time &rarr;</span>
	</div>
</div>

<style>
	.tct {
		margin: 0;
		box-sizing: border-box;
		display: grid;
		/* col 1 = label gutter; col 2 = the lane (its own internal grid carries the
		   keystroke columns). Three rows: typed, committed, time axis. */
		grid-template-columns: minmax(86px, max-content) 1fr;
		grid-template-rows: auto auto auto;
		align-items: center;
		column-gap: 12px;
		row-gap: 10px;
		width: 100%;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.tct * {
		box-sizing: border-box;
		margin: 0;
	}

	/* ── The left axis labels ──────────────────────────────────────────────── */
	.tct-axis {
		grid-column: 1;
		display: flex;
		flex-direction: column;
		gap: 1px;
		font-size: 12px;
		font-weight: 700;
		line-height: 1.15;
		text-align: right;
		justify-self: end;
	}
	.tct-axis-typed {
		color: color-mix(in srgb, var(--blue) 80%, var(--sl-color-text));
	}
	.tct-axis-committed {
		color: color-mix(in srgb, var(--green) 78%, var(--sl-color-text));
	}
	.tct-axis-home {
		font-size: 9.5px;
		font-weight: 600;
		letter-spacing: 0.01em;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── A lane is the time axis for one track: a flexible burst region on the
	   left and a fixed-width "right slot" (settling gap + commit) on the right.
	   Both lanes reserve the SAME right-slot width, so the end of the typed burst
	   and the committed pill share a vertical line — that is the shared axis. ─ */
	.tct-lane {
		grid-column: 2;
		display: flex;
		align-items: center;
		min-width: 0;
		min-height: 42px;
		padding: 4px 8px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.tct-burst {
		flex: 1 1 auto;
		min-width: 0;
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		gap: 4px;
	}
	/* The committed flat: the old value pinned left, a flat line trailing to the
	   edge of the burst region — held the whole time the user types. */
	.tct-burst-flat {
		flex-wrap: nowrap;
		gap: 8px;
	}
	.tct-rightslot {
		flex: 0 0 96px;
		min-width: 0;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		padding-left: 8px;
	}

	/* ── The pills (typed pills size to their growing content) ─────────────── */
	.tct-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 4px 8px;
		border-radius: 7px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12px;
		font-weight: 700;
		line-height: 1.1;
		white-space: nowrap;
	}
	.tct-pill-typed {
		color: color-mix(in srgb, var(--blue) 82%, var(--sl-color-text));
		background: color-mix(in srgb, var(--blue) 13%, var(--sl-color-bg));
		border: 1.5px solid color-mix(in srgb, var(--blue) 55%, transparent);
	}
	.tct-pill-committed {
		color: color-mix(in srgb, var(--green) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--green) 14%, var(--sl-color-bg));
		border: 1.5px solid color-mix(in srgb, var(--green) 58%, transparent);
	}

	/* ── The held old value, drawn flat under the whole keystroke region ────── */
	.tct-flat-line {
		flex: 1 1 auto;
		min-width: 10px;
		height: 0;
		border-top: 2px solid color-mix(in srgb, var(--green) 38%, var(--sl-color-gray-4));
	}
	.tct-flat-value {
		flex: 0 0 auto;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		white-space: nowrap;
	}

	/* ── The settling band: same grid as .tct, placed over the gap+commit cells
	   and spanning the two track rows. It bridges the two lanes, marking the one
	   moment typed → committed. Pulled a hair above/below for an obvious band. ─ */
	.tct-settle {
		grid-column: 2;
		grid-row: 1 / 3;
		justify-self: end;
		/* Width = the reserved right slot; sit it just inside the lane's right
		   padding so it covers exactly the settling gap + the committed pill. */
		width: 96px;
		margin-right: 8px;
		align-self: stretch;
		margin-top: -3px;
		margin-bottom: -3px;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 3px;
		border-radius: 9px;
		border: 1px dashed color-mix(in srgb, var(--green) 50%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--green) 9%, transparent);
		pointer-events: none;
		z-index: 1;
	}
	.tct-settle-label {
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.02em;
		line-height: 1.1;
		text-align: center;
		white-space: nowrap;
		color: color-mix(in srgb, var(--green) 80%, var(--sl-color-text));
		background: var(--sl-color-bg-sidebar, #f7f8fa);
		padding: 1px 6px;
		border-radius: 999px;
	}

	/* ── The shared time axis under both tracks ────────────────────────────── */
	.tct-timeaxis {
		grid-column: 2;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	.tct-timeaxis-line {
		align-self: stretch;
		height: 0;
		border-top: 1.5px solid var(--sl-color-gray-4, #94a3b8);
	}
	.tct-timeaxis-label {
		margin-top: 3px;
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── Narrow Figure: tighten the gutter and shrink pills. Seven full-word
	   pills can't fit one row on a phone, so the typed burst wraps there — many
	   pills over a few lines still reads as "fast, every keystroke" against the
	   committed track's single pill, and the band stretches to bridge them. ── */
	@media (max-width: 560px) {
		.tct {
			grid-template-columns: minmax(64px, max-content) 1fr;
			column-gap: 8px;
		}
		.tct-axis {
			font-size: 11px;
		}
		.tct-burst {
			flex-wrap: wrap;
			gap: 3px;
		}
		.tct-pill {
			font-size: 10px;
			padding: 3px 6px;
		}
		.tct-rightslot {
			flex-basis: 80px;
			padding-left: 5px;
		}
		.tct-flat-value {
			font-size: 10px;
		}
		.tct-settle {
			width: 80px;
		}
		.tct-settle-label {
			font-size: 9px;
			padding: 1px 4px;
		}
	}
</style>
