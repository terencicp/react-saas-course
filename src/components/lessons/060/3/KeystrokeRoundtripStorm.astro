---
// One frame of the per-keystroke round-trip "storm", scrubbed inside a
// <DiagramSequence>. The point prose can't carry: with the naive search box
// (shallow: false write straight from onChange) EVERY keystroke fires the WHOLE
// pipeline end to end, and the work compounds — three of four queries are thrown
// away the instant the next key lands. The climbing counter IS the argument.
//
// The strip is a fixed left-to-right pipeline, identical every frame so nothing
// jumps as you scrub — only the typed value, the live result, the discarded
// ghost, and the "queries run" counter advance:
//   keystroke → URL write → Server re-render → DB query → table
//
// `step` (1–4) selects the frame; source order = scrub order. The typed value
// grows p → pa → pai → paid; the counter ticks 1 → 4 and warms from neutral to
// alarm so the waste reads at a glance.
//
// Pure HTML + CSS like the chapter's other figures: `not-content` wrapper, theme
// gray variables for chrome, one saturated accent (blue-600) for the lit
// pipeline and a red-600 alarm tone for the counter, with a `margin: 0` reset on
// every inner element to defeat Starlight's prose-margin selector.

interface Props {
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = 'margin: 0';
const mono =
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = 'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';

const ACCENT = '#2563eb'; // blue-600 — the lit pipeline
const ALARM = '#dc2626'; // red-600  — the climbing waste counter

// Per-frame state: the value typed so far, and the value of the query each of
// the EARLIER keystrokes already fired and then discarded.
const frames: Record<Props['step'], { typed: string; discarded: string[] }> = {
  1: { typed: 'p', discarded: [] },
  2: { typed: 'pa', discarded: ['p'] },
  3: { typed: 'pai', discarded: ['p', 'pa'] },
  4: { typed: 'paid', discarded: ['p', 'pa', 'pai'] },
};

const frame = frames[step];
const count = step; // one full round-trip has fired per keystroke so far

// The fixed pipeline. Each stage shows what fires for THIS keystroke; the
// `value` slot echoes the current typed string where it is meaningful.
const stages: { label: string; value?: string }[] = [
  { label: 'keystroke', value: frame.typed },
  { label: 'URL write', value: '?q=' + frame.typed },
  { label: 'Server re-render' },
  { label: 'DB query', value: 'q = ' + frame.typed },
  { label: 'table', value: frame.typed + ' …' },
];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  'display: flex',
  'flex-direction: column',
  'gap: 14px',
  'width: 100%',
  'max-width: 680px',
  'margin-left: auto',
  'margin-right: auto',
  'box-sizing: border-box',
  sans,
].join('; ');

// The "queries run: N" counter — the loud part. Warms from neutral grey at 1 to
// a saturated alarm fill at 4 so the cost reads without reading the caption.
const counterTone = count >= 3 ? ALARM : count === 2 ? ACCENT : 'var(--sl-color-gray-3)';

const counterRow = [
  reset,
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'gap: 10px',
].join('; ');

const counterPill = [
  reset,
  sans,
  'display: inline-flex',
  'align-items: baseline',
  'gap: 8px',
  'padding: 6px 16px',
  'border-radius: 999px',
  'border: 1.5px solid ' + `color-mix(in srgb, ${counterTone} 50%, var(--sl-color-hairline))`,
  'background: ' + `color-mix(in srgb, ${counterTone} 12%, transparent)`,
  'box-sizing: border-box',
].join('; ');

const counterLabel = [
  reset,
  sans,
  'font-size: 12px',
  'font-weight: 600',
  'letter-spacing: 0.04em',
  'text-transform: uppercase',
  'color: var(--sl-color-gray-3)',
].join('; ');

const counterValue = [
  reset,
  mono,
  'font-size: 22px',
  'font-weight: 800',
  'line-height: 1',
  'color: ' + `color-mix(in srgb, ${counterTone} 78%, var(--sl-color-text))`,
].join('; ');

// The pipeline strip: boxes laid out in a row, arrows between them. It is the
// SAME pipeline every frame (that is the point) — only the values change. Wraps
// gracefully on narrow viewports.
const strip = [
  reset,
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'gap: 4px',
  'padding: 12px 8px',
  'border-radius: 11px',
  'border: 1px solid ' + `color-mix(in srgb, ${ACCENT} 22%, var(--sl-color-hairline))`,
  'background: ' + `color-mix(in srgb, ${ACCENT} 6%, var(--sl-color-bg))`,
  'box-sizing: border-box',
].join('; ');

// One lit pipeline box. Every stage is "on" because the whole round-trip fires
// for each keystroke.
const box = [
  reset,
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 3px',
  'flex: 1 1 0',
  'min-width: 64px',
  'padding: 8px 7px',
  'border-radius: 8px',
  'border: 1.5px solid ' + ACCENT,
  'background: ' + `color-mix(in srgb, ${ACCENT} 14%, var(--sl-color-bg))`,
  'box-sizing: border-box',
  'text-align: center',
].join('; ');

const boxLabel = [
  reset,
  sans,
  'font-size: 11px',
  'font-weight: 700',
  'line-height: 1.15',
  'color: ' + `color-mix(in srgb, ${ACCENT} 72%, var(--sl-color-text))`,
].join('; ');

const boxValue = [
  reset,
  mono,
  'font-size: 11px',
  'font-weight: 600',
  'line-height: 1.15',
  'color: var(--sl-color-text)',
  'background: ' + `color-mix(in srgb, ${ACCENT} 16%, transparent)`,
  'padding: 1px 5px',
  'border-radius: 5px',
  'max-width: 100%',
  'overflow: hidden',
  'text-overflow: ellipsis',
  'white-space: nowrap',
].join('; ');

// The connector between boxes — a small accent chevron.
const arrow = [
  reset,
  sans,
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'flex: 0 0 auto',
  'font-size: 14px',
  'font-weight: 700',
  'line-height: 1',
  'color: ' + `color-mix(in srgb, ${ACCENT} 60%, var(--sl-color-gray-3))`,
].join('; ');

// The discarded-queries ghost row beneath the strip: the round-trips that fired
// for earlier keystrokes and were thrown away the moment the next key landed.
const discardRow = [
  reset,
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'justify-content: center',
  'gap: 7px',
  'min-height: 24px',
].join('; ');

const discardLabel = [
  reset,
  sans,
  'font-size: 11px',
  'font-weight: 600',
  'letter-spacing: 0.02em',
  'color: var(--sl-color-gray-3)',
].join('; ');

// One discarded query chip — struck through and faded.
const discardChip = [
  reset,
  mono,
  'position: relative',
  'padding: 1px 8px',
  'border-radius: 999px',
  'border: 1px dashed var(--sl-color-gray-4)',
  'background: var(--sl-color-gray-6)',
  'font-size: 11px',
  'font-weight: 600',
  'color: var(--sl-color-gray-3)',
  'text-decoration: line-through',
  'text-decoration-color: ' + `color-mix(in srgb, ${ALARM} 60%, var(--sl-color-gray-3))`,
  'opacity: 0.85',
].join('; ');
---

<div class="not-content" style={root}>
  {/* The loud counter — climbs and warms with every keystroke */}
  <div style={counterRow}>
    <span style={counterPill}>
      <span style={counterLabel}>queries run</span>
      <span style={counterValue}>{count}</span>
    </span>
  </div>

  {/* The fixed pipeline, lit end to end for this keystroke */}
  <div style={strip}>
    {
      stages.map((stage, i) => (
        <>
          <div style={box}>
            <span style={boxLabel} set:html={stage.label.replace(/</g, '&lt;')} />
            {stage.value && (
              <span style={boxValue} set:html={stage.value.replace(/</g, '&lt;')} />
            )}
          </div>
          {i < stages.length - 1 && (
            <span style={arrow} aria-hidden="true">
              &rsaquo;
            </span>
          )}
        </>
      ))
    }
  </div>

  {/* The wasted round-trips: queries fired by earlier keystrokes, thrown away */}
  <div style={discardRow}>
    {frame.discarded.length === 0 ? (
      <span style={discardLabel}>First keystroke — nothing discarded yet.</span>
    ) : (
      <>
        <span style={discardLabel}>discarded:</span>
        {frame.discarded.map((q) => (
          <span style={discardChip}>?q={q}</span>
        ))}
      </>
    )}
  </div>
</div>
