---
// InsertedRowDrift — Chapter 060 Lesson 4, "Cursor by default, offset when small".
//
// The lesson's dramatic core, scrubbed inside a <DiagramSequence>. The point prose
// can't make land on its own: under an insert, OFFSET-based "page 2" repeats the
// last row of page 1 (a DUPLICATE) and drops a fresh row off the window (a SKIP),
// while a CURSOR anchors to a value and is structurally immune.
//
// One vertical row-stack is the constant spine across all four frames (newest at
// top), so nothing jumps as the reader scrubs — only the inserted row, the page
// boundary, the active-query label, the highlighted page window, and the tints
// advance. A windowed list keeps the figure short: position 1 (row A), an ellipsis
// for the middle of page 1, then the rows straddling the page-20 boundary (S, T)
// and the top of page 2 (U, V) where the whole drama happens.
//
// `step` (1–4) selects the frame; source order = scrub order:
//   1  Offset, page 1   — OFFSET 0 LIMIT 20, boundary after row T.
//   2  Insert row Z     — lands at the top (orange); every row shifts down one.
//   3  Offset, page 2   — OFFSET 20 LIMIT 20 now opens on T (duplicate, red) and a
//                         fresh row falls past the window (skipped).
//   4  Cursor, page 2   — WHERE (createdAt,id) < cursorOf(T); Z sits ABOVE the
//                         anchor so it can't move it; page 2 opens cleanly at U
//                         (row 21, green). No duplicate, no skip.
//
// Engine: plain HTML + CSS — the diagrams index's pick for a colour-coded,
// table-shaped illustration, and it matches the sibling list-view figures'
// grammar (muted card, hairline borders, Starlight theme tokens + color-mix). The
// pillar key carries the course-wide PAGINATE = green; ORANGE marks the insert,
// RED the duplicate. `.not-content` + a `margin: 0` reset on every descendant
// defeat Starlight's prose-margin injection. <DiagramSequence> + the per-step
// captions come from the MDX call site, not here.

interface Props {
	step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const isCursor = step === 4;

// Saturated mid-tones (Tailwind 600-range) that read on both light and dark cards.
const GREEN = "#16a34a"; // the clean cursor row — paginate's course-wide key
const ORANGE = "#ea580c"; // the freshly-inserted row
const RED = "#dc2626"; // the duplicated / skipped breakage
const BLUE = "#2563eb"; // the active page-2 query under inspection

// The query label shown for this frame.
const query = isCursor
	? "WHERE (createdAt, id) < cursorOf(T)"
	: step >= 3
		? "OFFSET 20 LIMIT 20"
		: "OFFSET 0 LIMIT 20";

const queryNote = isCursor
	? "page 2 — by value"
	: step >= 3
		? "page 2 — skip 20 rows"
		: "page 1 — skip 0 rows";

// Whether the insert (row Z) has happened in this frame.
const inserted = step >= 2;

// A row in the constant spine. `kind` drives the tint; `pos` is the live position
// label (it shifts by one once Z is inserted). `tag` is the small status chip.
type Row = {
	letter: string;
	created: string;
	// position label before / after the insert
	pos: number;
};

// Page 1, newest-first. A is position 1; we only render the ends plus the
// boundary-straddling rows, with an ellipsis standing in for positions 2–18.
const head: Row = { letter: "A", created: "Apr 18", pos: 1 };
const page1Tail: Row[] = [
	{ letter: "S", created: "Apr 04", pos: 19 },
	{ letter: "T", created: "Apr 03", pos: 20 }, // last row the user saw on page 1
];
const page2Head: Row[] = [
	{ letter: "U", created: "Apr 02", pos: 21 }, // the genuine "row 21"
	{ letter: "V", created: "Apr 01", pos: 22 },
];

// Live position label for a row: everything below Z drops by one once inserted.
const livePos = (r: Row) => (inserted ? r.pos + 1 : r.pos);

// Status chip for a given letter in this frame.
const chipFor = (
	letter: string,
): { text: string; tone: "green" | "red" | "orange" } | null => {
	if (isCursor && letter === "U") return { text: "page 2 starts here", tone: "green" };
	if (isCursor && letter === "T") return { text: "anchor — unmoved by Z", tone: "green" };
	if (step === 3 && letter === "T")
		return { text: "duplicate — already seen on page 1", tone: "red" };
	return null;
};

// Does the active page-2 window cover this row? (steps 3–4 only.)
const inWindow = (letter: string) => {
	if (step === 3) return letter === "T" || letter === "U" || letter === "V";
	if (isCursor) return letter === "U" || letter === "V";
	return false;
};

const ALT =
	"A vertical stack of invoice rows, newest at the top, illustrating how an inserted row drifts offset pagination but not cursor pagination. " +
	(step === 1
		? "Step 1: offset page 1 runs OFFSET 0 LIMIT 20, returning rows A down to T, with a page boundary line after row T at position 20."
		: step === 2
			? "Step 2: a teammate inserts a new invoice, row Z, at the very top in orange; every existing row shifts down one position so the row that was 20, T, is now at position 21."
			: step === 3
				? "Step 3: offset page 2 runs OFFSET 20 LIMIT 20. Because the rows shifted, the window now opens on row T highlighted in red as a duplicate the user already saw on page 1, and a fresh row falls past the bottom of the window and is skipped."
				: "Step 4: cursor page 2 runs WHERE createdAt id is less than the cursor of T. The new row Z sits above that anchor so it cannot move it, and page 2 opens cleanly at row U, the true row 21, highlighted in green, with no duplicate and no skip.");
---

<div
	class="ird not-content"
	role="img"
	aria-label={ALT}
	style={`--green:${GREEN};--red:${RED};--orange:${ORANGE};--blue:${BLUE}`}
	data-mode={isCursor ? "cursor" : "offset"}
>
	{/* ── The active query for this frame ─────────────────────────────────── */}
	<div class="ird-query" data-mode={isCursor ? "cursor" : "offset"}>
		<span class="ird-query-kind">{isCursor ? "cursor" : "offset"}</span>
		<code class="ird-query-sql">{query}</code>
		<span class="ird-query-note">{queryNote}</span>
	</div>

	{/* ── The row stack — the constant spine across every frame ───────────── */}
	<div class="ird-stack">
		{/* The freshly-inserted row Z — present from step 2 on, always on top. */}
		{
			inserted && (
				<div class="ird-row ird-row-new">
					<span class="ird-pos">1</span>
					<span class="ird-letter">Z</span>
					<span class="ird-created">Apr 19</span>
					<span class="ird-chip ird-chip-orange">new — inserted at top</span>
				</div>
			)
		}

		{/* Position 1 of page 1: row A. */}
		<div class="ird-row">
			<span class="ird-pos">{livePos(head)}</span>
			<span class="ird-letter">{head.letter}</span>
			<span class="ird-created">{head.created}</span>
		</div>

		{/* The compressed middle of page 1. */}
		<div class="ird-ellipsis" aria-hidden="true">
			<span>rows B … R</span>
		</div>

		{/* End of page 1: S, T. */}
		{
			page1Tail.map((r) => {
				const chip = chipFor(r.letter);
				return (
					<div
						class={
							"ird-row" +
							(step === 3 && r.letter === "T" ? " ird-row-dup" : "") +
							(isCursor && r.letter === "T" ? " ird-row-anchor" : "") +
							(inWindow(r.letter) ? " ird-row-win" : "")
						}
					>
						<span class="ird-pos">{livePos(r)}</span>
						<span class="ird-letter">{r.letter}</span>
						<span class="ird-created">{r.created}</span>
						{chip && <span class={`ird-chip ird-chip-${chip.tone}`}>{chip.text}</span>}
					</div>
				);
			})
		}

		{/* The page-20 boundary. In offset frames it is the OFFSET cut line; in the
		    cursor frame it is where T's anchor sits. */}
		<div
			class={"ird-boundary" + (isCursor ? " ird-boundary-anchor" : "")}
			aria-hidden="true"
		>
			<span class="ird-boundary-line" />
			<span class="ird-boundary-tag">
				{isCursor ? "anchor: after T's sort key" : "page boundary — after 20 rows"}
			</span>
			<span class="ird-boundary-line" />
		</div>

		{/* Top of page 2: U, V. */}
		{
			page2Head.map((r) => {
				const chip = chipFor(r.letter);
				return (
					<div
						class={
							"ird-row" +
							(isCursor && r.letter === "U" ? " ird-row-clean" : "") +
							(inWindow(r.letter) ? " ird-row-win" : "")
						}
					>
						<span class="ird-pos">{livePos(r)}</span>
						<span class="ird-letter">{r.letter}</span>
						<span class="ird-created">{r.created}</span>
						{chip && <span class={`ird-chip ird-chip-${chip.tone}`}>{chip.text}</span>}
					</div>
				);
			})
		}

		{/* The skipped row — only in the offset-page-2 frame. A fresh row that
		    should have closed the page falls past the bottom of the window. */}
		{
			step === 3 && (
				<div class="ird-skip">
					<span class="ird-skip-arrow" aria-hidden="true">
						&darr;
					</span>
					<span class="ird-skip-text">
						a fresh row is pushed past the window &mdash; <strong>skipped</strong>
					</span>
				</div>
			)
		}
	</div>

	{/* ── The one-line verdict for this frame ─────────────────────────────── */}
	<div class={"ird-foot ird-foot-" + (isCursor ? "ok" : step === 3 ? "bad" : "neutral")}>
		{
			step === 1
				? "Page 1 is rows A–T. The user has now seen T."
				: step === 2
					? "Z lands at the top — every row below it shifts down one position."
					: step === 3
						? "Offset counts rows, so the shift makes page 2 repeat T and drop a row."
						: "Cursor anchors to T's value — Z above it changes nothing. Clean page 2."
		}
	</div>
</div>

<style>
	.ird {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 12px;
		width: 100%;
		max-width: 460px;
		margin-left: auto;
		margin-right: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.ird * {
		box-sizing: border-box;
		margin: 0;
	}

	/* ── Active-query banner ─────────────────────────────────────────────── */
	.ird-query {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
		padding: 8px 12px;
		border-radius: 10px;
		border: 1px solid color-mix(in srgb, var(--blue) 28%, var(--sl-color-hairline));
		background: color-mix(in srgb, var(--blue) 8%, var(--sl-color-bg));
	}
	.ird-query[data-mode="cursor"] {
		border-color: color-mix(in srgb, var(--green) 32%, var(--sl-color-hairline));
		background: color-mix(in srgb, var(--green) 8%, var(--sl-color-bg));
	}
	.ird-query-kind {
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 2px 8px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--blue) 82%, var(--sl-color-white));
		background: color-mix(in srgb, var(--blue) 16%, transparent);
	}
	.ird-query[data-mode="cursor"] .ird-query-kind {
		color: color-mix(in srgb, var(--green) 82%, var(--sl-color-white));
		background: color-mix(in srgb, var(--green) 16%, transparent);
	}
	.ird-query-sql {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12px;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		flex: 1 1 auto;
		min-width: 0;
	}
	.ird-query-note {
		font-size: 10px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		white-space: nowrap;
	}

	/* ── The row stack ───────────────────────────────────────────────────── */
	.ird-stack {
		display: flex;
		flex-direction: column;
		border-radius: 11px;
		overflow: hidden;
		border: 1px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
	}
	.ird-row {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 8px 12px;
		border-top: 1px solid var(--sl-color-gray-6, #e6e8ec);
		font-size: 12.5px;
		line-height: 1.2;
	}
	.ird-row:first-child {
		border-top: none;
	}
	.ird-pos {
		flex: 0 0 1.9em;
		text-align: right;
		font-variant-numeric: tabular-nums;
		font-size: 10.5px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #94a3b8);
	}
	.ird-letter {
		flex: 0 0 1.5em;
		font-weight: 800;
		color: var(--sl-color-white, #1e293b);
	}
	.ird-created {
		flex: 0 0 auto;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-2, #475569);
	}
	.ird-chip {
		flex: 1 1 auto;
		text-align: right;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.01em;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.ird-chip-orange {
		color: color-mix(in srgb, var(--orange) 88%, var(--sl-color-text));
	}
	.ird-chip-red {
		color: #fff;
	}
	.ird-chip-green {
		color: #fff;
	}

	/* The freshly-inserted row Z — orange wash, full row. */
	.ird-row-new {
		background: color-mix(in srgb, var(--orange) 16%, var(--sl-color-bg));
		border-top: none;
	}
	.ird-row-new .ird-letter {
		color: color-mix(in srgb, var(--orange) 92%, var(--sl-color-text));
	}
	.ird-row-new .ird-pos {
		color: color-mix(in srgb, var(--orange) 78%, var(--sl-color-text));
	}

	/* The active page-2 window — a tinted band behind the rows it returns. */
	.ird-row-win {
		background: color-mix(in srgb, var(--blue) 9%, var(--sl-color-bg));
	}
	.ird[data-mode="cursor"] .ird-row-win {
		background: color-mix(in srgb, var(--green) 9%, var(--sl-color-bg));
	}

	/* The duplicate row — saturated red fill, white text. */
	.ird-row-dup {
		background: var(--red);
	}
	.ird-row-dup .ird-pos,
	.ird-row-dup .ird-letter,
	.ird-row-dup .ird-created {
		color: #fff;
	}

	/* The clean first row of cursor page 2 — saturated green fill, white text. */
	.ird-row-clean {
		background: var(--green);
	}
	.ird-row-clean .ird-pos,
	.ird-row-clean .ird-letter,
	.ird-row-clean .ird-created {
		color: #fff;
	}

	/* The anchor row T under cursor — green outline, kept legible, not filled. */
	.ird-row-anchor {
		background: color-mix(in srgb, var(--green) 12%, var(--sl-color-bg));
		box-shadow: inset 2px 0 0 var(--green);
	}
	.ird-row-anchor .ird-letter {
		color: color-mix(in srgb, var(--green) 86%, var(--sl-color-text));
	}

	/* The compressed middle of page 1. */
	.ird-ellipsis {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4px 12px;
		border-top: 1px solid var(--sl-color-gray-6, #e6e8ec);
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-3, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 14%, transparent);
	}

	/* ── The page boundary / anchor line ─────────────────────────────────── */
	.ird-boundary {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 5px 12px;
		border-top: 1px solid var(--sl-color-gray-6, #e6e8ec);
		color: color-mix(in srgb, var(--blue) 78%, var(--sl-color-text));
		background: color-mix(in srgb, var(--blue) 7%, transparent);
	}
	.ird-boundary-anchor {
		color: color-mix(in srgb, var(--green) 80%, var(--sl-color-text));
		background: color-mix(in srgb, var(--green) 7%, transparent);
	}
	.ird-boundary-line {
		flex: 1 1 auto;
		height: 0;
		border-top: 2px dashed currentColor;
	}
	.ird-boundary-tag {
		flex: 0 0 auto;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.02em;
		white-space: nowrap;
	}

	/* ── The skipped-row marker (offset page 2 only) ─────────────────────── */
	.ird-skip {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 7px 12px;
		border-top: 1px dashed color-mix(in srgb, var(--red) 45%, var(--sl-color-gray-5));
		background: color-mix(in srgb, var(--red) 8%, transparent);
	}
	.ird-skip-arrow {
		flex: 0 0 auto;
		font-size: 14px;
		font-weight: 800;
		line-height: 1;
		color: var(--red);
	}
	.ird-skip-text {
		font-size: 10.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
	}
	.ird-skip-text strong {
		font-weight: 800;
		color: color-mix(in srgb, var(--red) 82%, var(--sl-color-text));
	}

	/* ── The per-frame verdict ───────────────────────────────────────────── */
	.ird-foot {
		font-size: 11px;
		line-height: 1.35;
		text-align: center;
		padding: 0 4px;
		color: var(--sl-color-gray-2, #475569);
	}
	.ird-foot-ok {
		color: color-mix(in srgb, var(--green) 72%, var(--sl-color-text));
		font-weight: 600;
	}
	.ird-foot-bad {
		color: color-mix(in srgb, var(--red) 76%, var(--sl-color-text));
		font-weight: 600;
	}
</style>
