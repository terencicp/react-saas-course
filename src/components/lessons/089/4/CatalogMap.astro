---
/**
 * The catalog map (Chapter 089, Lesson 4).
 *
 * A compact 5-row reference grid: one row per catalog component, keyed to the
 * single trigger it meets (a tinted pill in the trigger vocabulary from L1) and
 * the line on what someone else covers. CSS grid so the three columns stay
 * aligned; wrapped by <Figure> in the lesson for the card chrome + caption.
 */

type Trigger = 'critical-ux' | 'complex-state' | 'shared-library';

interface Row {
  component: string;
  trigger: Trigger;
  triggerLabel: string;
  elsewhere: string;
}

// Tint per trigger type — saturated mid-tones that read on both themes,
// white text on the fill (per the html+css theme-adaptation guidance).
const triggerStyle: Record<Trigger, string> = {
  'critical-ux': 'background: #d97706;', // amber-600
  'complex-state': 'background: #7c3aed;', // violet-600 (the component-test band)
  'shared-library': 'background: #0d9488;', // teal-600
};

const rows: Row[] = [
  {
    component: 'Cookie consent gate',
    trigger: 'critical-ux',
    triggerLabel: 'Critical UX',
    elsewhere: 'PostHog gate fires → E2E',
  },
  {
    component: 'Subscribe form',
    trigger: 'complex-state',
    triggerLabel: 'Complex state',
    elsewhere: 'DB write + Stripe → seam',
  },
  {
    component: 'Date-range picker',
    trigger: 'shared-library',
    triggerLabel: 'Shared library',
    elsewhere: 'library internals',
  },
  {
    component: 'Data table',
    trigger: 'shared-library',
    triggerLabel: 'Shared library',
    elsewhere: 'pagination → seam',
  },
  {
    component: 'Checkout summary line',
    trigger: 'critical-ux',
    triggerLabel: 'Critical UX',
    elsewhere: 'Stripe redirect → E2E',
  },
];

const headerCell =
  'margin: 0; padding: 0 4px 8px; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--sl-color-gray-3);';
const cell =
  'margin: 0; min-width: 0; display: flex; align-items: center; padding: 12px 4px; border-top: 1px solid var(--sl-color-gray-5);';
---

<div
  style="margin: 0; display: grid; grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr) minmax(0, 1.4fr); column-gap: 16px; max-width: 760px; margin-inline: auto;"
>
  {/* Header row */}
  <div style={headerCell}>Component</div>
  <div style={headerCell}>Trigger met</div>
  <div style={headerCell}>Left to someone else</div>

  {
    rows.map((row) => (
      <>
        <div style={cell}>
          <span style="margin: 0; font-weight: 600; color: var(--sl-color-white); line-height: 1.3;">
            {row.component}
          </span>
        </div>
        <div style={cell}>
          <span
            style={`margin: 0; display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.8rem; font-weight: 600; color: #fff; white-space: nowrap; ${triggerStyle[row.trigger]}`}
          >
            {row.triggerLabel}
          </span>
        </div>
        <div style={cell}>
          <span style="margin: 0; color: var(--sl-color-gray-2); line-height: 1.3;">
            {row.elsewhere}
          </span>
        </div>
      </>
    ))
  }
</div>
