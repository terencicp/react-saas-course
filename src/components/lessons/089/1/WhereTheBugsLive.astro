---
// WhereTheBugsLive — Chapter 089 Lesson 1 ("When RTL earns its weight").
//
// One horizontal strip standing in for a typical SaaS page's rendered tree,
// split left-to-right into three bands whose widths track their weight in the
// argument. The eye should land on the small accented band on the right and
// read it as the exception:
//
//   [ Server Components ......... | Thin Client Components ..... | Stateful ]
//     ~50%, muted                   ~35%, slightly less muted      ~15%, ACCENT
//     bugs -> the seam              trivial / action test          RTL here
//
// The pedagogical point is purely the *proportion*: the RTL-worthy surface is a
// thin highlighted slice of the page, not the whole page. Most of the tree is
// muted (its bugs live at the seam, covered last chapter); the interactive
// middle is mostly too thin to test; only the narrow accented band earns RTL.
//
// Pure HTML+CSS per the diagrams guide (colour-coded segments + labels, no
// graph engine). `not-content` + margin:0 on every node defeats Starlight's
// injected prose margins. Goes inside <Figure>, which the MDX supplies along
// with the caption.
//
// Colour: the two left bands lean on Starlight greys so they recede; the
// accent band uses the course's teal (#0d9488) so it pops in both themes.
// Tints via color-mix so they track the page background in either theme.

const ACCENT = '#0d9488'; // the RTL-worthy slice — the one band that stands out

type Band = {
	width: number; // flex weight (roughly the % share of the strip)
	label: string;
	sub: string;
	foot: string;
	tone: 'muted' | 'mid' | 'accent';
};

const bands: Band[] = [
	{
		width: 50,
		label: 'Server Components',
		sub: 'fetch + render, framework-orchestrated',
		foot: 'bugs → the seam (covered last chapter)',
		tone: 'muted',
	},
	{
		width: 35,
		label: 'Thin Client Components',
		sub: 'forms, modals, tooltips, nav',
		foot: 'mostly trivial / covered by the action test',
		tone: 'mid',
	},
	{
		width: 15,
		label: 'Stateful Client Components',
		sub: 'state is the behavior',
		foot: 'RTL earns its weight here',
		tone: 'accent',
	},
];
---

<div class="wbl not-content" style={`--wbl-accent:${ACCENT};`}>
	<div class="wbl-strip">
		{
			bands.map((band) => (
				<div
					class:list={['wbl-band', `wbl-band--${band.tone}`]}
					style={`flex: ${band.width};`}
				>
					<div class="wbl-body">
						<div class="wbl-label">{band.label}</div>
						<div class="wbl-sub">{band.sub}</div>
					</div>
					<div class="wbl-foot">{band.foot}</div>
				</div>
			))
		}
	</div>
</div>

<style>
	.wbl {
		margin: 0;
		padding: 4px 2px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* The page's rendered tree as one horizontal strip. */
	.wbl-strip {
		display: flex;
		align-items: stretch;
		gap: 8px;
		min-width: 0;
		margin: 0;
	}

	/* A band: a label block over a footer tag, stacked. Equal height across the
	   strip via align-items:stretch on the parent. */
	.wbl-band {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 14px;
		min-width: 0;
		min-height: 132px;
		padding: 14px 14px 12px;
		border-radius: 12px;
		margin: 0;
	}

	/* Left band — recedes the most. Its bugs are elsewhere. */
	.wbl-band--muted {
		background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
		border: 1.5px solid color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent);
	}

	/* Middle band — slightly less muted, still secondary. */
	.wbl-band--mid {
		background: color-mix(in srgb, var(--sl-color-gray-5) 80%, transparent);
		border: 1.5px solid color-mix(in srgb, var(--sl-color-gray-4) 65%, transparent);
	}

	/* Right band — the exception. Accent fill + heavier accent border so the eye
	   lands here and reads it as the thin slice that earns RTL. */
	.wbl-band--accent {
		background: color-mix(in srgb, var(--wbl-accent) 14%, transparent);
		border: 2px solid color-mix(in srgb, var(--wbl-accent) 60%, transparent);
	}

	.wbl-body {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 0;
		margin: 0;
	}

	.wbl-label {
		font-size: 14px;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.wbl-band--accent .wbl-label {
		color: color-mix(in srgb, var(--wbl-accent) 78%, var(--sl-color-white));
	}

	.wbl-sub {
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The footer tag — where this band's bugs are actually caught. */
	.wbl-foot {
		font-size: 11px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #475569);
		padding: 6px 9px;
		border-radius: 8px;
		background: color-mix(in srgb, var(--sl-color-gray-6) 65%, transparent);
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 70%, transparent);
		margin: 0;
	}

	/* The accent band's footer is the payoff line — paint it in the accent. */
	.wbl-band--accent .wbl-foot {
		color: color-mix(in srgb, var(--wbl-accent) 82%, var(--sl-color-text));
		background: color-mix(in srgb, var(--wbl-accent) 18%, transparent);
		border-color: color-mix(in srgb, var(--wbl-accent) 50%, transparent);
		font-weight: 700;
	}

	/* Narrow viewports: stack the three bands vertically so labels stay legible.
	   The proportion argument is carried by the prose at that width. */
	@media (max-width: 560px) {
		.wbl-strip {
			flex-direction: column;
		}
		.wbl-band {
			min-height: 0;
			gap: 10px;
		}
	}
</style>
