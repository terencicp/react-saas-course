---
// Three-lanes orientation strip (Chapter 089 L2): the three Vitest projects laid
// side by side so the student SEES that `component` is the third, slowest,
// deliberately-isolated lane — and that the file suffix is what routes a test
// into each lane.
//
// Read left to right and the per-test cost climbs (unit ~5ms -> integration
// 20-80ms -> component 100-300ms). Each card carries that lane's band color and
// a thin cost bar at the foot whose length tracks the cost figure, so the ramp
// is visceral without turning this into a system graph.
//
// Band colors are LOAD-BEARING — reused verbatim from the chapter-086 figures
// (CostVsBugs / BugLayersStack / PyramidVsHoneycomb) so band -> color reads
// consistently across the whole testing unit:
//   unit = blue, integration = teal, component = violet.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// `min-width: 0` on flex children lets labels wrap instead of stealing width.
// Horizontal, height-capped, no JS.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--sl-font-system-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

const UNIT = "#2563eb"; // blue-600
const INTEGRATION = "#0d9488"; // teal-600
const COMPONENT = "#7c3aed"; // violet-600

// `cost` is a qualitative fill width (0-100) for the foot bar; the ramp climbs
// left to right. `emphasis` flags the component lane as the one this lesson adds.
const lanes = [
	{
		name: "unit",
		color: UNIT,
		env: "node",
		suffix: "*.test.ts",
		cost: "~5 ms",
		costBar: 14,
		emphasis: false,
	},
	{
		name: "integration",
		color: INTEGRATION,
		env: "node + Postgres",
		suffix: "*.int.test.ts",
		cost: "~20–80 ms",
		costBar: 42,
		emphasis: false,
	},
	{
		name: "component",
		color: COMPONENT,
		env: "jsdom",
		suffix: "*.dom.test.tsx",
		cost: "~100–300 ms",
		costBar: 100,
		emphasis: true,
	},
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-wrap: wrap",
	"justify-content: center",
	"column-gap: 14px",
	"row-gap: 14px",
	"width: 100%",
	"box-sizing: border-box",
	sans,
].join("; ");

const card = (color: string, emphasis: boolean) =>
	[
		reset,
		"box-sizing: border-box",
		"flex: 1 1 200px",
		"min-width: 180px",
		"max-width: 280px",
		"display: flex",
		"flex-direction: column",
		"gap: 12px",
		"padding: 16px 16px 14px",
		"border-radius: 12px",
		"border: " +
			(emphasis ? "2px" : "1.5px") +
			" solid color-mix(in srgb, " +
			color +
			(emphasis ? " 70%" : " 38%") +
			", transparent)",
		"background: color-mix(in srgb, " + color + " 9%, var(--sl-color-bg))",
	].join("; ");

const laneName = (color: string) =>
	[
		reset,
		mono,
		"font-size: 16px",
		"font-weight: 700",
		"letter-spacing: -0.01em",
		"color: color-mix(in srgb, " + color + " 80%, var(--sl-color-text))",
	].join("; ");

const fieldLabel = [
	reset,
	sans,
	"font-size: 10px",
	"font-weight: 700",
	"letter-spacing: 0.06em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3, #9ca3af)",
	"margin-bottom: 4px",
].join("; ");

const envPill = (color: string) =>
	[
		reset,
		sans,
		"display: inline-block",
		"width: fit-content",
		"padding: 3px 9px",
		"border-radius: 999px",
		"font-size: 12px",
		"font-weight: 600",
		"white-space: nowrap",
		"background: color-mix(in srgb, " + color + " 16%, transparent)",
		"border: 1px solid color-mix(in srgb, " + color + " 40%, transparent)",
		"color: color-mix(in srgb, " + color + " 82%, var(--sl-color-text))",
	].join("; ");

const suffixCode = [
	reset,
	mono,
	"display: block",
	"width: fit-content",
	"padding: 0",
	"background: transparent",
	"font-size: 13px",
	"font-weight: 500",
	"white-space: nowrap",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

const field = [reset, "display: flex", "flex-direction: column"].join("; ");

// Cost block: the figure on top, a thin foot bar below whose fill length tracks
// the cost. The bar is what makes the left-to-right ramp visible at a glance.
const costFigure = [
	reset,
	sans,
	"font-size: 14px",
	"font-weight: 700",
	"color: var(--sl-color-white, currentColor)",
	"margin-bottom: 6px",
].join("; ");

const costTrack = [
	reset,
	"box-sizing: border-box",
	"width: 100%",
	"height: 8px",
	"border-radius: 4px",
	"overflow: hidden",
	"background: var(--sl-color-gray-6, rgba(125,125,125,0.14))",
].join("; ");

const costFill = (pct: number, color: string) =>
	[
		reset,
		"box-sizing: border-box",
		"width: " + pct + "%",
		"height: 100%",
		"border-radius: 4px",
		"background: " + color,
	].join("; ");

// Push the cost block to the foot so all three cost bars align across cards of
// uneven body height.
const costBlock = [reset, "margin-top: auto"].join("; ");
---

<div class="not-content" style={root}>
	{
		lanes.map((l) => (
			<div style={card(l.color, l.emphasis)}>
				<div style={laneName(l.color)}>{l.name}</div>

				<div style={field}>
					<div style={fieldLabel}>environment</div>
					<span style={envPill(l.color)}>{l.env}</span>
				</div>

				<div style={field}>
					<div style={fieldLabel}>file suffix</div>
					<code style={suffixCode}>{l.suffix}</code>
				</div>

				<div style={costBlock}>
					<div style={fieldLabel}>per-test cost</div>
					<div style={costFigure}>{l.cost}</div>
					<div style={costTrack}>
						<div style={costFill(l.costBar, l.color)} />
					</div>
				</div>
			</div>
		))
	}
</div>
