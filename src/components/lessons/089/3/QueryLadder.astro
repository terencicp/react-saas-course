---
// Diagram: ladder-diagram (Chapter 089, Lesson 3 — "The query ladder is the
// accessibility audit"). Testing Library's query priority ladder rendered as a
// vertical ranked strip: eight rungs, top to bottom, each carrying the query
// name (monospace, left) and a three-word use case (right).
//
// The whole point is *precedence at a glance*, so colour groups the rungs by
// how much they should be reached for:
//   - Rungs 1-3 (role / label / text) sit on the accessibility tree — tinted a
//     green/blue "reach for these" band. This is where a real user, including a
//     screen-reader user, actually interacts.
//   - Rungs 4-7 (placeholder / displayValue / alt / title) — the neutral grey
//     tail. They exist; you rarely want them.
//   - Rung 8 (testid) — orange/red "last resort": no semantic surface, you have
//     left the accessibility tree entirely.
//
// Plain HTML+CSS per the diagrams index (a colour-coded ordered list, not a
// graph). `margin: 0` everywhere defeats Starlight's injected prose margins;
// height-capped, no JS. Saturated mid-tone left-edge bars + theme-aware tints
// keep it readable on light and dark backgrounds.

import Figure from "../../../figures/Figure.astro";

// Band accents. Saturated mid-tones, readable on both themes; used both as the
// left-edge rail and (color-mixed down) as the rung tint.
const REACH = "#0d9488"; // teal-600  — the accessibility band
const TAIL = "#64748b"; // slate-500 — the neutral tail
const LAST = "#dc2626"; // red-600   — the escape hatch

type Band = "reach" | "tail" | "last";

type Rung = {
	rank: number;
	query: string;
	use: string;
	band: Band;
};

const rungs: Rung[] = [
	{ rank: 1, query: "getByRole", use: "interactive + headings", band: "reach" },
	{ rank: 2, query: "getByLabelText", use: "labelled form inputs", band: "reach" },
	{ rank: 3, query: "getByText", use: "non-interactive content", band: "reach" },
	{ rank: 4, query: "getByPlaceholderText", use: "input, no label", band: "tail" },
	{ rank: 5, query: "getByDisplayValue", use: "current input value", band: "tail" },
	{ rank: 6, query: "getByAltText", use: "image alt text", band: "tail" },
	{ rank: 7, query: "getByTitle", use: "the title attribute", band: "tail" },
	{ rank: 8, query: "getByTestId", use: "no semantic surface", band: "last" },
];

const accent: Record<Band, string> = {
	reach: REACH,
	tail: TAIL,
	last: LAST,
};

// First rung of each band carries an edge tag. The top tag says "this is the
// accessibility tree"; the bottom says "you've left it".
const bandTag: Partial<Record<Band, string>> = {
	reach: "On the accessibility tree — reach for these",
	last: "Off the accessibility tree — last resort",
};
---

<Figure caption="Testing Library's query priority ladder. Reach for the highest rung the element supports; treat every rung you drop as a compromise you can defend.">
	<div class="ql-root not-content">
		{
			rungs.map((r, i) => {
				const isBandStart = rungs[i - 1]?.band !== r.band;
				const tag = isBandStart ? bandTag[r.band] : undefined;
				return (
					<>
						{tag && (
							<div class:list={["ql-tag", `ql-tag-${r.band}`]}>{tag}</div>
						)}
						<div class:list={["ql-rung", `ql-${r.band}`]}>
							<span class="ql-rank">{r.rank}</span>
							<code class="ql-query">{r.query}</code>
							<span class="ql-use">{r.use}</span>
						</div>
					</>
				);
			})
		}
	</div>
</Figure>

<style define:vars={{ REACH: accent.reach, TAIL: accent.tail, LAST: accent.last }}>
	.ql-root {
		display: flex;
		flex-direction: column;
		gap: 4px;
		width: 100%;
		max-width: 560px;
		margin-left: auto;
		margin-right: auto;
		box-sizing: border-box;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* An edge tag introducing a band. Small, uppercase, coloured to its band. */
	.ql-tag {
		margin: 0;
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1.2;
		padding: 0 2px 1px;
	}
	.ql-tag-reach {
		color: color-mix(in srgb, var(--REACH) 78%, var(--sl-color-text));
	}
	.ql-tag-last {
		color: color-mix(in srgb, var(--LAST) 80%, var(--sl-color-text));
		margin-top: 4px;
	}

	/* One rung: rank · query · use, on a tinted bar with a coloured left rail. */
	.ql-rung {
		display: flex;
		align-items: center;
		gap: 12px;
		margin: 0;
		box-sizing: border-box;
		min-height: 40px;
		padding: 8px 14px;
		border-radius: 8px;
		border: 1px solid transparent;
	}

	.ql-rank {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 700;
		color: #ffffff;
		margin: 0;
	}

	.ql-query {
		flex: 0 0 auto;
		margin: 0;
		padding: 1px 8px;
		border-radius: 5px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 13.5px;
		font-weight: 600;
		white-space: nowrap;
		color: var(--sl-color-white);
		background: color-mix(in srgb, currentColor 8%, transparent);
		border: none;
	}

	.ql-use {
		flex: 1 1 0;
		min-width: 0;
		margin: 0;
		text-align: right;
		font-size: 12.5px;
		font-weight: 500;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
	}

	/* Accessibility band — the top three rungs. */
	.ql-reach {
		background: color-mix(in srgb, var(--REACH) 12%, transparent);
		border-color: color-mix(in srgb, var(--REACH) 30%, transparent);
		border-left: 4px solid var(--REACH);
	}
	.ql-reach .ql-rank {
		background: var(--REACH);
	}

	/* The neutral tail — rungs 4-7. */
	.ql-tail {
		background: color-mix(in srgb, var(--TAIL) 9%, transparent);
		border-color: color-mix(in srgb, var(--TAIL) 24%, transparent);
		border-left: 4px solid color-mix(in srgb, var(--TAIL) 65%, transparent);
	}
	.ql-tail .ql-rank {
		background: color-mix(in srgb, var(--TAIL) 85%, transparent);
	}
	.ql-tail .ql-query {
		color: var(--sl-color-text);
	}

	/* Last resort — rung 8. */
	.ql-last {
		background: color-mix(in srgb, var(--LAST) 13%, transparent);
		border-color: color-mix(in srgb, var(--LAST) 38%, transparent);
		border-left: 4px solid var(--LAST);
	}
	.ql-last .ql-rank {
		background: var(--LAST);
	}

	@media (max-width: 460px) {
		.ql-rung {
			flex-wrap: wrap;
			gap: 6px 10px;
		}
		.ql-use {
			flex-basis: 100%;
			text-align: left;
			padding-left: 32px;
		}
	}
</style>
