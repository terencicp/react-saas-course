---
// One frame of the checkout-completion timeline for lesson 064/2.
// Renders the four actors as a row of boxes — Stripe, Browser,
// Webhook, Your DB — with the currently-"live" actors accented, an
// optional flow arrow between two adjacent actors, and the
// plan-entitlements row shown as free/pro under the DB box.
//
// Used inside <DiagramSequence>; one instance per <DiagramStep>.

type Actor = 'stripe' | 'browser' | 'webhook' | 'db';

interface Props {
	// Actors that are "live" (acting) in this frame.
	live?: Actor[];
	// Optional directed flow(s) between actors, e.g. ['browser', 'stripe'].
	// Each pair draws an accented arrow along the row.
	flows?: [Actor, Actor][];
	// The plan_entitlements row value the DB currently holds.
	entitlement?: 'free' | 'pro';
	// Highlight the entitlements row as just-written this frame.
	wrote?: boolean;
	// What the success page is showing, if it has rendered yet.
	page?: 'finalizing' | 'pro' | null;
}

const {
	live = [],
	flows = [],
	entitlement = 'free',
	wrote = false,
	page = null,
} = Astro.props;

const order: Actor[] = ['stripe', 'browser', 'webhook', 'db'];
const meta: Record<Actor, { head: string; sub: string }> = {
	stripe: { head: 'Stripe', sub: 'payments + events' },
	browser: { head: 'Browser', sub: 'success page' },
	webhook: { head: 'Webhook', sub: 'your server' },
	db: { head: 'Your DB', sub: 'entitlements' },
};

// Map each actor to its column index so flows know which gap to fill.
const col = Object.fromEntries(order.map((a, i) => [a, i])) as Record<Actor, number>;

// Build the set of "gaps" (between column i and i+1) that should show an
// arrow, plus its direction. The four actors sit in a 4-column grid; the
// three gaps live in dedicated 3 narrow columns interleaved between them.
const gapFlow: Record<number, 'fwd' | 'back'> = {};
for (const [from, to] of flows) {
	const a = col[from];
	const b = col[to];
	const lo = Math.min(a, b);
	gapFlow[lo] = a < b ? 'fwd' : 'back';
}
---

<div class="ctl">
	<div class="ctl-row">
		{
			order.map((actor, i) => (
				<>
					<div
						class:list={['ctl-box', { 'is-live': live.includes(actor) }]}
						data-actor={actor}
					>
						<span class="ctl-head">{meta[actor].head}</span>
						<span class="ctl-sub">{meta[actor].sub}</span>
						{actor === 'db' && (
							<span
								class:list={[
									'ctl-pill',
									entitlement === 'pro' ? 'is-pro' : 'is-free',
									{ 'is-wrote': wrote },
								]}
							>
								{entitlement}
							</span>
						)}
						{actor === 'browser' && page && (
							<span class:list={['ctl-screen', { 'is-pro': page === 'pro' }]}>
								{page === 'pro' ? "You're on Pro" : 'Finalizing…'}
							</span>
						)}
					</div>
					{i < order.length - 1 && (
						<div class="ctl-gap">
							{gapFlow[i] && (
								<span
									class:list={['ctl-arrow', gapFlow[i] === 'back' ? 'is-back' : 'is-fwd']}
									aria-hidden="true"
								>
									<svg viewBox="0 0 40 12" width="40" height="12">
										<line x1="2" y1="6" x2="34" y2="6" />
										<polyline points="29 2 35 6 29 10" />
									</svg>
								</span>
							)}
						</div>
					)}
				</>
			))
		}
	</div>
</div>

<style>
	.ctl {
		padding: 0.4rem 0.1rem;
	}

	.ctl-row {
		display: grid;
		/* four actor columns interleaved with three narrow arrow gaps */
		grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
		align-items: stretch;
		gap: 0;
	}

	.ctl-box {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 0.2rem;
		text-align: center;
		min-height: 116px;
		padding: 0.7rem 0.5rem;
		border-radius: 0.6rem;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		transition: border-color 0.16s, background-color 0.16s, box-shadow 0.16s;
	}

	/* The actor(s) acting in this frame light up with the accent. */
	.ctl-box.is-live {
		border-color: color-mix(in srgb, var(--sl-color-accent) 70%, transparent);
		background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--sl-color-accent) 45%, transparent);
	}

	.ctl-head {
		font-weight: 600;
		font-size: 0.92rem;
		line-height: 1.15;
		color: var(--sl-color-white);
	}

	.ctl-sub {
		font-size: 0.72rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3);
	}

	/* plan_entitlements value pill under the DB box */
	.ctl-pill {
		margin-top: 0.35rem;
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		padding: 0.12rem 0.5rem;
		border-radius: 999px;
		border: 1px solid transparent;
		transition: background-color 0.16s, color 0.16s, border-color 0.16s;
	}
	.ctl-pill.is-free {
		background: color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent);
		color: var(--sl-color-gray-2);
		border-color: var(--sl-color-gray-4);
	}
	.ctl-pill.is-pro {
		background: hsl(var(--sl-hue-green, 147), 50%, 42%);
		color: #fff;
		border-color: hsl(var(--sl-hue-green, 147), 50%, 42%);
	}
	/* the frame where the write actually lands gets a ring */
	.ctl-pill.is-wrote.is-pro {
		box-shadow: 0 0 0 3px color-mix(in srgb, hsl(var(--sl-hue-green, 147), 50%, 42%) 35%, transparent);
	}

	/* the success page's current message under the Browser box */
	.ctl-screen {
		margin-top: 0.35rem;
		font-size: 0.72rem;
		font-weight: 500;
		padding: 0.12rem 0.45rem;
		border-radius: 0.4rem;
		background: var(--sl-color-gray-6, var(--sl-color-bg-sidebar));
		border: 1px dashed var(--sl-color-gray-4);
		color: var(--sl-color-gray-2);
	}
	.ctl-screen.is-pro {
		border-style: solid;
		border-color: hsl(var(--sl-hue-green, 147), 50%, 42%);
		color: hsl(var(--sl-hue-green, 147), 45%, 55%);
	}

	.ctl-gap {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 46px;
	}

	.ctl-arrow {
		display: inline-flex;
		color: var(--sl-color-accent);
	}
	.ctl-arrow svg {
		fill: none;
		stroke: currentColor;
		stroke-width: 1.6;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
	/* a backward flow just mirrors the same arrow horizontally */
	.ctl-arrow.is-back {
		transform: scaleX(-1);
	}

	@media (max-width: 560px) {
		.ctl-row {
			grid-template-columns: 1fr auto 1fr;
			grid-auto-rows: auto;
			row-gap: 0.5rem;
		}
		.ctl-box {
			min-height: 0;
		}
	}
</style>
