---
// Static three-box topology strip for the Checkout Session lesson.
// Goes inside a <Figure expandable={false}> wrapping an <ArrowDiagram>:
// the app owns the two ends (tinted), Stripe owns the middle (neutral).
---

<div class="topo">
	<div class="topo-box topo-app" id="topo-server">
		<span class="topo-head">Your server</span>
		<span class="topo-sub">creates the session</span>
	</div>
	<div class="topo-box topo-stripe" id="topo-stripe">
		<span class="topo-head">Stripe-hosted page</span>
		<span class="topo-sub">the user pays</span>
	</div>
	<div class="topo-box topo-app" id="topo-success">
		<span class="topo-head">Your success page</span>
		<span class="topo-sub">reads &amp; polls</span>
	</div>
</div>

<style>
	.topo {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 90px;
		align-items: stretch;
		padding: 0.75rem 0.25rem;
		max-width: 760px;
		margin-inline: auto;
	}

	.topo-box {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		justify-content: center;
		text-align: center;
		min-height: 64px;
		padding: 0.75rem 0.5rem;
		border-radius: 0.6rem;
		border: 1px solid var(--sl-color-gray-4);
	}

	/* App-owned ends: subtle accent tint so the eye reads "the app is here". */
	.topo-app {
		background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}

	/* Stripe in the middle: deliberately neutral/distinct. */
	.topo-stripe {
		background: var(--sl-color-bg);
	}

	.topo-head {
		font-weight: 600;
		font-size: 0.95rem;
		line-height: 1.2;
		color: var(--sl-color-white);
	}

	.topo-sub {
		font-size: 0.8rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3);
	}

	/* Stack on narrow viewports — arrows degrade gracefully, text stays readable. */
	@media (max-width: 640px) {
		.topo {
			grid-template-columns: 1fr;
			gap: 48px;
		}
	}
</style>
