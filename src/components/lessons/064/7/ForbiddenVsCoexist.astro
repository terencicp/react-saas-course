---
import Figure from '../../../figures/Figure.astro';

// "Forbidden vs. coexist" — the helper/interface distinction made spatial.
//
//   LEFT  (Wrapped / Stripe):  app code -> billing.* (the seam, accented as a
//          WALL) -> stripe SDK (buried, import-restricted). A single arrow from
//          app code STOPS at the seam; nothing reaches the SDK directly. The
//          seam is a wall.
//
//   RIGHT (Un-wrapped / Resend): app code with TWO legal paths down — one
//          through a sendEmail helper box to the SDK, one straight to the SDK,
//          bypassing the helper. Both arrows are neutral (legal, not error). The
//          helper is a shortcut next to an open door.
//
// The asymmetry — one door vs. two — is the whole point.
const STRIPE = '#635bff'; // Stripe brand violet — the wrapped seam
const RESEND = '#f59e0b'; // amber — the un-wrapped helper path
---

<Figure>
  <div
    class="fvc"
    role="img"
    aria-label="Two side-by-side structures. Left, Wrapped (Stripe): three stacked layers — app code at the top, then the billing-dot-star seam labelled 'the only door', then the stripe SDK at the bottom, greyed out and labelled 'import-restricted to /lib/billing'. A single arrow runs from app code down to the seam and stops there; no arrow reaches the SDK directly. The seam is a wall. Right, Un-wrapped (Resend): app code at the top with two legal paths going down — one routes through a sendEmail helper box to the resend SDK, the other goes straight from app code to the resend SDK, bypassing the helper. Both paths are allowed. The helper is a shortcut sitting next to an open door."
  >
    {/* ── LEFT: Wrapped (Stripe) — one door ─────────────────────────── */}
    <section class="fvc-panel fvc-panel--wrapped">
      <header class="fvc-phead">
        <span class="fvc-title">Wrapped <span class="fvc-vendor">(Stripe)</span></span>
        <span class="fvc-verdict fvc-verdict--wall">one door</span>
      </header>

      <div class="fvc-stack">
        <div class="fvc-node fvc-node--app">app code</div>

        <div class="fvc-arrow fvc-arrow--stop" aria-hidden="true">
          <span class="fvc-line"></span>
          <span class="fvc-head"></span>
        </div>

        {/* The seam — accented bar that doubles as the wall. */}
        <div class="fvc-seam">
          <code class="fvc-seam-name">billing.*</code>
          <span class="fvc-seam-tag">the only door</span>
        </div>

        {/* The wall line: nothing crosses it from above except the seam. */}
        <div class="fvc-wall" aria-hidden="true">
          <span class="fvc-wall-label">SDK forbidden above</span>
        </div>

        <div class="fvc-node fvc-node--sdk fvc-node--buried">
          <code class="fvc-sdk-name">stripe SDK</code>
          <span class="fvc-sdk-tag">import-restricted to <code>/lib/billing</code></span>
        </div>
      </div>
    </section>

    <div class="fvc-gap" aria-hidden="true"></div>

    {/* ── RIGHT: Un-wrapped (Resend) — two doors ────────────────────── */}
    <section class="fvc-panel fvc-panel--unwrapped">
      <header class="fvc-phead">
        <span class="fvc-title">Un-wrapped <span class="fvc-vendor">(Resend)</span></span>
        <span class="fvc-verdict fvc-verdict--open">two doors</span>
      </header>

      <div class="fvc-branch">
        <div class="fvc-node fvc-node--app fvc-branch-top">app code</div>

        {/* Two diverging arrows — both legal. */}
        <div class="fvc-fork" aria-hidden="true">
          <div class="fvc-fork-leg fvc-fork-leg--helper">
            <span class="fvc-line"></span>
            <span class="fvc-head"></span>
          </div>
          <div class="fvc-fork-leg fvc-fork-leg--direct">
            <span class="fvc-line"></span>
            <span class="fvc-head"></span>
          </div>
        </div>

        {/* Left leg: through the helper. Right leg: straight past it. */}
        <div class="fvc-mid">
          <div class="fvc-node fvc-node--helper">
            <code class="fvc-helper-name">sendEmail</code>
            <span class="fvc-helper-tag">helper</span>
          </div>
          <div class="fvc-door" aria-hidden="true">
            <span class="fvc-door-label">door left open</span>
          </div>
        </div>

        {/* Helper's own arrow down to the SDK. */}
        <div class="fvc-helper-arrow" aria-hidden="true">
          <span class="fvc-line"></span>
          <span class="fvc-head"></span>
        </div>

        <div class="fvc-node fvc-node--sdk fvc-branch-bottom">
          <code class="fvc-sdk-name">resend SDK</code>
          <span class="fvc-sdk-tag">importable anywhere</span>
        </div>
      </div>
    </section>
  </div>

  <Fragment slot="caption">
    A helper simplifies a call; an interface <em>forbids</em> the call from
    happening anywhere else.
  </Fragment>
</Figure>

<style define:vars={{ stripe: STRIPE, resend: RESEND }}>
  .fvc {
    display: flex;
    align-items: stretch;
    gap: 0;
    max-width: 760px;
    margin: 0 auto;
    padding-block: 0.25rem;
  }

  .fvc-panel {
    flex: 1 1 0;
    min-width: 0;
    margin: 0;
    padding: 0.9rem 1rem 1.1rem;
    border-radius: 0.7rem;
  }

  .fvc-panel--wrapped {
    background: color-mix(in srgb, var(--stripe) 8%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--stripe) 26%, transparent);
  }

  .fvc-panel--unwrapped {
    background: color-mix(in srgb, var(--resend) 7%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--resend) 28%, transparent);
  }

  .fvc-gap {
    flex: 0 0 1.1rem;
    margin: 0;
  }

  /* ── Panel header ─────────────────────────────────────────────── */
  .fvc-phead {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.3rem 0.5rem;
    margin: 0 0 0.9rem;
  }

  .fvc-title {
    font-weight: 700;
    font-size: 0.98rem;
    color: var(--sl-color-white);
  }

  .fvc-vendor {
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }

  .fvc-verdict {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.14rem 0.5rem;
    border-radius: 0.35rem;
    margin: 0;
  }

  .fvc-verdict--wall {
    color: color-mix(in srgb, var(--stripe) 60%, var(--sl-color-white));
    background: color-mix(in srgb, var(--stripe) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--stripe) 40%, transparent);
  }

  .fvc-verdict--open {
    color: color-mix(in srgb, var(--resend) 55%, var(--sl-color-white));
    background: color-mix(in srgb, var(--resend) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--resend) 42%, transparent);
  }

  /* ── Shared node boxes ────────────────────────────────────────── */
  .fvc-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.12rem;
    margin: 0;
    padding: 0.5rem 0.7rem;
    border-radius: 0.5rem;
    text-align: center;
  }

  .fvc-node--app {
    background: var(--sl-color-gray-6, var(--sl-color-gray-5));
    box-shadow: inset 0 0 0 1px var(--sl-color-gray-4);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--sl-color-white);
  }

  .fvc-node--sdk {
    background: color-mix(in srgb, var(--sl-color-gray-5) 26%, transparent);
    box-shadow: inset 0 0 0 1px var(--sl-color-gray-5);
  }

  /* The Stripe SDK is buried: dimmed and visually pushed back. */
  .fvc-node--buried {
    opacity: 0.62;
    filter: saturate(0.7);
  }

  .fvc-sdk-name,
  .fvc-helper-name,
  .fvc-seam-name {
    background: transparent;
    padding: 0;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .fvc-sdk-name {
    font-size: 0.86rem;
  }

  .fvc-sdk-tag {
    font-size: 0.66rem;
    line-height: 1.3;
    color: var(--sl-color-gray-3);
  }

  .fvc-sdk-tag code {
    background: transparent;
    padding: 0;
    font-size: 0.92em;
    color: var(--sl-color-gray-2);
  }

  /* ── LEFT panel: vertical stack with a wall ───────────────────── */
  .fvc-stack {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    margin: 0;
  }

  .fvc-stack > .fvc-node {
    width: 100%;
  }

  /* The seam — the one accented door. */
  .fvc-seam {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    margin: 0;
    padding: 0.5rem 0.7rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--stripe) 22%, transparent);
    box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--stripe) 70%, transparent);
  }

  .fvc-seam-name {
    color: color-mix(in srgb, var(--stripe) 30%, var(--sl-color-white));
    font-size: 0.92rem;
  }

  .fvc-seam-tag {
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--stripe) 55%, var(--sl-color-white));
  }

  /* The wall: a hard rule that the SDK lives beneath. */
  .fvc-wall {
    position: relative;
    height: 0;
    margin: 0.85rem 0;
    border-top: 2px dashed color-mix(in srgb, var(--stripe) 55%, var(--sl-color-gray-4));
  }

  .fvc-wall-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    padding: 0.08rem 0.45rem;
    border-radius: 0.3rem;
    background: var(--sl-color-bg-sidebar);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
  }

  /* ── Arrows ───────────────────────────────────────────────────── */
  .fvc-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
  }

  .fvc-arrow--stop {
    padding: 0.4rem 0;
  }

  .fvc-line {
    width: 2px;
    height: 1.3rem;
    margin: 0;
    background: var(--sl-color-gray-3);
  }

  .fvc-head {
    width: 0;
    height: 0;
    margin: 0;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 7px solid var(--sl-color-gray-3);
  }

  /* ── RIGHT panel: branch into two legal paths ─────────────────── */
  .fvc-branch {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    margin: 0;
  }

  .fvc-branch-top,
  .fvc-branch-bottom {
    width: 100%;
  }

  /* Two diverging arrows side by side. */
  .fvc-fork {
    display: flex;
    margin: 0;
    padding: 0.35rem 0 0.1rem;
  }

  .fvc-fork-leg {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
  }

  .fvc-fork-leg .fvc-line {
    height: 1.15rem;
    background: color-mix(in srgb, var(--resend) 60%, var(--sl-color-gray-3));
  }

  .fvc-fork-leg .fvc-head {
    border-top-color: color-mix(in srgb, var(--resend) 60%, var(--sl-color-gray-3));
  }

  /* Middle row: helper box (left leg) beside the open door (right leg). */
  .fvc-mid {
    display: flex;
    align-items: stretch;
    gap: 0.6rem;
    margin: 0;
  }

  .fvc-mid > * {
    flex: 1 1 0;
    min-width: 0;
  }

  .fvc-node--helper {
    background: color-mix(in srgb, var(--resend) 16%, transparent);
    box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--resend) 50%, transparent);
  }

  .fvc-helper-name {
    color: color-mix(in srgb, var(--resend) 40%, var(--sl-color-white));
    font-size: 0.86rem;
  }

  .fvc-helper-tag {
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--resend) 55%, var(--sl-color-white));
  }

  /* The "open door" — the direct path's destination marker, dashed/empty. */
  .fvc-door {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0.5rem 0.6rem;
    border-radius: 0.5rem;
    border: 1.5px dashed color-mix(in srgb, var(--resend) 45%, var(--sl-color-gray-4));
  }

  .fvc-door-label {
    font-size: 0.66rem;
    font-weight: 600;
    line-height: 1.3;
    text-align: center;
    color: color-mix(in srgb, var(--resend) 45%, var(--sl-color-gray-1));
  }

  /* The helper's own arrow continues down to the SDK (left leg only). */
  .fvc-helper-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 50%;
    margin: 0;
    padding: 0.1rem 0;
  }

  .fvc-helper-arrow .fvc-line {
    height: 1.15rem;
    background: color-mix(in srgb, var(--resend) 60%, var(--sl-color-gray-3));
  }

  .fvc-helper-arrow .fvc-head {
    border-top-color: color-mix(in srgb, var(--resend) 60%, var(--sl-color-gray-3));
  }

  /* ── Stack on narrow viewports ────────────────────────────────── */
  @media (max-width: 600px) {
    .fvc {
      flex-direction: column;
    }

    .fvc-gap {
      flex-basis: 1rem;
    }
  }
</style>
