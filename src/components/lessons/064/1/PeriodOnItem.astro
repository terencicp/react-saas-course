---
import Figure from '../../../figures/Figure.astro';

// Where the billing period lives in the Subscription object, drawn as a nested
// object tree. The field `current_period_end` is shown TWICE:
//   - at the Subscription root, struck through and red — its old home, now
//     `undefined` (what stale tutorials reach for).
//   - inside items.data[0], highlighted green — its real home since the
//     2025-03-31 API version.
// The visual carries the lesson "same field, new home" in a single glance.
const STRIPE = '#635bff'; // Stripe brand violet
const STALE = '#dc2626'; // red-600 — the dead, old location
const LIVE = '#16a34a'; // green-600 — the correct, current location
---

<Figure>
  <div class="poi">
    <div class="poi-tree" role="img" aria-label="The Subscription object: current_period_end no longer sits at the root, it now lives inside items.data[0].">
      <span class="poi-brace">subscription <span class="poi-punc">{'{'}</span></span>

      <div class="poi-level">
        <span class="poi-prop poi-prop--stale">
          <span class="poi-key">current_period_end</span><span class="poi-punc">:</span>
          <span class="poi-val">undefined</span>
        </span>
        <span class="poi-tag poi-tag--stale">old home &mdash; gone since 2025-03-31</span>
      </div>

      <div class="poi-level">
        <span class="poi-brace poi-brace--sub">items.data[0] <span class="poi-punc">{'{'}</span></span>

        <div class="poi-level poi-level--inner">
          <span class="poi-prop poi-prop--live">
            <span class="poi-key">current_period_end</span><span class="poi-punc">:</span>
            <span class="poi-val poi-val--live">1748736000</span>
          </span>
          <span class="poi-tag poi-tag--live">read it here now</span>
        </div>

        <span class="poi-brace poi-brace--sub">{'}'}</span>
      </div>

      <span class="poi-brace">{'}'}</span>
    </div>
  </div>
  <Fragment slot="caption">
    Same field, new home. As of Stripe&rsquo;s <code>2025-03-31</code> API version the
    billing period moved off the Subscription root and onto the item &mdash; read it as{' '}
    <code>subscription.items.data[0].current_period_end</code>, never{' '}
    <code>subscription.current_period_end</code>.
  </Fragment>
</Figure>

<style define:vars={{ stripe: STRIPE, stale: STALE, live: LIVE }}>
  .poi {
    max-width: 640px;
    margin-inline: auto;
    padding-block: 0.5rem;
  }

  .poi-tree {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.6rem;
    background: var(--sl-color-black);
    padding: 1rem 1.1rem;
  }

  .poi-punc {
    color: var(--sl-color-gray-3);
  }

  .poi-brace {
    display: block;
    font-weight: 600;
  }

  .poi-brace--sub {
    color: var(--stripe);
  }

  /* Each nested level steps in and gets a left rail. */
  .poi-level {
    margin: 0.35rem 0 0.35rem 0.4rem;
    padding-left: 1rem;
    border-left: 2px solid color-mix(in srgb, var(--stripe) 40%, var(--sl-color-gray-5));
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }

  .poi-level--inner {
    border-left-color: color-mix(in srgb, var(--live) 55%, var(--sl-color-gray-5));
  }

  .poi-prop {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .poi-key {
    color: var(--sl-color-white);
  }

  .poi-val {
    color: var(--sl-color-gray-2);
  }

  /* The stale, struck-through field at the root. */
  .poi-prop--stale {
    text-decoration: line-through;
    text-decoration-color: var(--stale);
    text-decoration-thickness: 2px;
    opacity: 0.7;
  }

  .poi-prop--stale .poi-key,
  .poi-prop--stale .poi-val {
    color: color-mix(in srgb, var(--stale) 55%, var(--sl-color-gray-2));
  }

  /* The live field, inside items.data[0]. */
  .poi-prop--live {
    padding: 0.05rem 0.35rem;
    border-radius: 0.35rem;
    background: color-mix(in srgb, var(--live) 14%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--live) 45%, transparent);
  }

  .poi-val--live {
    color: color-mix(in srgb, var(--live) 30%, var(--sl-color-white));
  }

  /* Small annotation pills sitting beside each field. */
  .poi-tag {
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 0.1rem 0.5rem;
    border-radius: 0.4rem;
  }

  .poi-tag--stale {
    color: color-mix(in srgb, var(--stale) 70%, var(--sl-color-white));
    background: color-mix(in srgb, var(--stale) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--stale) 35%, transparent);
  }

  .poi-tag--live {
    color: color-mix(in srgb, var(--live) 70%, var(--sl-color-white));
    background: color-mix(in srgb, var(--live) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--live) 35%, transparent);
  }
</style>
