---
import Figure from '../../../figures/Figure.astro';

// The ownership line between Stripe and the app, drawn as two side-by-side
// panels split by a vertical divider — the "line" the prose talks about.
//   - LEFT (Stripe, brand violet): the full billing truth and state machine.
//   - RIGHT (the app, neutral): only the thin derived slice read on the hot path.
// The asymmetry (heavy source of truth vs. thin projection) is the whole point.
const STRIPE = '#635bff'; // Stripe brand violet

type Row = { code?: string; text: string; note?: string };

const stripeOwns: Row[] = [
  { text: 'The Customer, Subscription, and Price catalog' },
  { text: 'Invoices and payment methods' },
  { text: 'The full billing state machine', note: 'every status transition' },
];

const appStores: Row[] = [
  { code: 'organizations.stripe_customer_id', text: 'the pointer to the Customer' },
  { code: 'plan_entitlements', text: 'the derived row', note: 'plan, status, period — built in a later lesson' },
  { text: 'Immutable invoice records', note: 'pulled down for reporting — named, not built here' },
];
---

<Figure>
  <div class="own" role="img" aria-label="The ownership line. Stripe owns the full billing truth — the Customer, Subscription, Price catalog, invoices, payment methods, and the full billing state machine. The app stores only a thin projection: a pointer to the Customer, a derived plan_entitlements row, and immutable invoice records pulled for reporting.">
    <section class="own-col own-col--stripe">
      <header class="own-head">
        <span class="own-owner">Stripe owns</span>
        <span class="own-tag own-tag--stripe">source of truth</span>
      </header>
      <ul class="own-list">
        {stripeOwns.map((row) => (
          <li class="own-item">
            <span class="own-dot own-dot--stripe" aria-hidden="true"></span>
            <span class="own-body">
              <span class="own-text">{row.text}</span>
              {row.note && <span class="own-note">{row.note}</span>}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <div class="own-divider" aria-hidden="true"></div>

    <section class="own-col own-col--app">
      <header class="own-head">
        <span class="own-owner">The app stores</span>
        <span class="own-tag own-tag--app">thin projection</span>
      </header>
      <ul class="own-list">
        {appStores.map((row) => (
          <li class="own-item">
            <span class="own-dot own-dot--app" aria-hidden="true"></span>
            <span class="own-body">
              <span class="own-text">
                {row.code && <code class="own-code">{row.code}</code>}
                {row.code ? ' ' : ''}{row.text}
              </span>
              {row.note && <span class="own-note">{row.note}</span>}
            </span>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <Fragment slot="caption">
    The ownership line. Stripe is the source of truth for billing facts; the app
    keeps only the thin, derived slice it reads on the hot path &mdash;{' '}
    <strong>don&rsquo;t mirror Stripe&rsquo;s schema, mirror only what your app reads.</strong>
  </Fragment>
</Figure>

<style define:vars={{ stripe: STRIPE }}>
  .own {
    display: flex;
    align-items: stretch;
    gap: 0;
    max-width: 720px;
    margin: 0 auto;
    padding-block: 0.25rem;
  }

  .own-col {
    flex: 1 1 0;
    min-width: 0;
    margin: 0;
    padding: 0.85rem 1.1rem;
    border-radius: 0.6rem;
  }

  .own-col--stripe {
    background: color-mix(in srgb, var(--stripe) 9%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--stripe) 28%, transparent);
  }

  .own-col--app {
    background: color-mix(in srgb, var(--sl-color-gray-5) 22%, transparent);
    box-shadow: inset 0 0 0 1px var(--sl-color-gray-5);
  }

  /* The vertical "line" that splits the two worlds. */
  .own-divider {
    flex: 0 0 auto;
    align-self: stretch;
    width: 1px;
    margin: 0.4rem 0.9rem;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--sl-color-gray-4) 12%,
      var(--sl-color-gray-4) 88%,
      transparent
    );
  }

  .own-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.5rem;
    margin: 0 0 0.7rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .own-owner {
    font-weight: 700;
    font-size: 1rem;
    color: var(--sl-color-white);
  }

  .own-tag {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.12rem 0.45rem;
    border-radius: 0.35rem;
    margin: 0;
  }

  .own-tag--stripe {
    color: color-mix(in srgb, var(--stripe) 65%, var(--sl-color-white));
    background: color-mix(in srgb, var(--stripe) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--stripe) 38%, transparent);
  }

  .own-tag--app {
    color: var(--sl-color-gray-2);
    background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent);
    border: 1px solid var(--sl-color-gray-5);
  }

  .own-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .own-item {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin: 0;
  }

  .own-dot {
    flex: 0 0 auto;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: 0.42rem;
    border-radius: 50%;
  }

  .own-dot--stripe {
    background: var(--stripe);
  }

  .own-dot--app {
    background: var(--sl-color-gray-3);
  }

  .own-body {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    min-width: 0;
  }

  .own-text {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.4;
    color: var(--sl-color-white);
  }

  .own-note {
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.35;
    color: var(--sl-color-gray-3);
  }

  .own-code {
    background: transparent;
    padding: 0;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.85em;
    color: color-mix(in srgb, var(--stripe) 35%, var(--sl-color-white));
    word-break: break-word;
  }

  /* Stack the two worlds on narrow viewports; divider goes horizontal. */
  @media (max-width: 560px) {
    .own {
      flex-direction: column;
    }

    .own-divider {
      width: auto;
      height: 1px;
      margin: 0.6rem 0.9rem;
      background: linear-gradient(
        to right,
        transparent,
        var(--sl-color-gray-4) 12%,
        var(--sl-color-gray-4) 88%,
        transparent
      );
    }
  }
</style>
