---
import Figure from '../../../figures/Figure.astro';

// The webhook events a subscription SaaS actually listens to, as a two-column
// reference: event type(s) on the left, what the app does with each on the
// right. The three customer.subscription.* lifecycle events share one row
// because they all drive the same action (refresh the entitlement).
const STRIPE = '#635bff'; // Stripe brand violet

type Row = { events: string[]; action: string; note?: string };

const rows: Row[] = [
  {
    events: ['checkout.session.completed'],
    action: 'Provision the entitlement on first subscribe.',
  },
  {
    events: [
      'customer.subscription.created',
      'customer.subscription.updated',
      'customer.subscription.deleted',
    ],
    action: 'Refresh the entitlement — plan, status, period.',
  },
  {
    events: ['invoice.paid'],
    action: 'Record the invoice and advance the period.',
  },
  {
    events: ['invoice.payment_failed'],
    action: 'Drive the past_due transition.',
    note: 'semantics covered in the status lesson',
  },
];
---

<Figure>
  <div
    class="surface"
    role="img"
    aria-label="The webhook events a subscription SaaS listens to and what each tells the app to do. checkout.session.completed provisions the entitlement on first subscribe. customer.subscription.created, updated, and deleted all refresh the entitlement — plan, status, period. invoice.paid records the invoice and advances the period. invoice.payment_failed drives the past_due transition."
  >
    <div class="surface-head" aria-hidden="true">
      <span class="surface-col-label">Event type</span>
      <span class="surface-col-label">What the app does</span>
    </div>

    {
      rows.map((row) => (
        <div class="surface-row">
          <div class="surface-events">
            {row.events.map((event) => (
              <code class="surface-event">{event}</code>
            ))}
          </div>
          <span class="surface-arrow" aria-hidden="true">
            &rarr;
          </span>
          <div class="surface-action">
            <span class="surface-action-text">{row.action}</span>
            {row.note && <span class="surface-note">{row.note}</span>}
          </div>
        </div>
      ))
    }
  </div>

  <Fragment slot="caption">
    The events that matter, and what each one tells your app to do &mdash; four
    or five types, not the hundreds Stripe can emit. The full handler code lands
    in the project chapter; here you only meet the surface.
  </Fragment>
</Figure>

<style define:vars={{ stripe: STRIPE }}>
  .surface {
    max-width: 720px;
    margin: 0 auto;
    padding-block: 0.25rem;
  }

  .surface-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 1.4rem minmax(0, 1fr);
    align-items: baseline;
    gap: 0 0.7rem;
    margin: 0 0 0.55rem;
    padding: 0 0.2rem 0.5rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  /* The arrow column is hidden in the header — only the two labels show. */
  .surface-col-label:first-child {
    grid-column: 1;
  }
  .surface-col-label:last-child {
    grid-column: 3;
  }

  .surface-col-label {
    margin: 0;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
  }

  .surface-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 1.4rem minmax(0, 1fr);
    align-items: center;
    gap: 0 0.7rem;
    margin: 0;
    padding: 0.7rem 0.2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
  }

  .surface-row:last-child {
    border-bottom: none;
  }

  .surface-events {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    margin: 0;
    min-width: 0;
  }

  .surface-event {
    margin: 0;
    padding: 0.18rem 0.5rem;
    border-radius: 0.35rem;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    line-height: 1.3;
    color: color-mix(in srgb, var(--stripe) 30%, var(--sl-color-white));
    background: color-mix(in srgb, var(--stripe) 12%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--stripe) 30%, transparent);
    white-space: nowrap;
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .surface-arrow {
    grid-column: 2;
    justify-self: center;
    margin: 0;
    font-size: 1rem;
    line-height: 1;
    color: color-mix(in srgb, var(--stripe) 55%, var(--sl-color-gray-2));
  }

  .surface-action {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0;
    min-width: 0;
  }

  .surface-action-text {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.4;
    color: var(--sl-color-white);
  }

  .surface-note {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.35;
    color: var(--sl-color-gray-3);
  }

  /* On narrow viewports stack each row: events, then arrow, then action. */
  @media (max-width: 520px) {
    .surface-head {
      display: none;
    }

    .surface-row {
      grid-template-columns: 1fr;
      gap: 0.35rem 0;
      padding: 0.85rem 0.2rem;
    }

    .surface-arrow {
      grid-column: 1;
      justify-self: start;
      transform: rotate(90deg);
    }
  }
</style>
