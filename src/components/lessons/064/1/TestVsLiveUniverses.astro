---
import Figure from '../../../figures/Figure.astro';

// Test mode vs. live mode drawn as two disjoint universes: the SAME parallel
// object set in each column, split by a hard central wall that says "nothing
// crosses". The point is sameness of shape + total separation — a test-mode
// object and its live-mode twin share a name but never share an ID or identity.
//   - LEFT  (Test universe, amber): dev / CI / staging.
//   - RIGHT (Live universe, green): production only.
// Each row names an object and shows its tell-tale prefix differing per world.
const TEST = '#f5a524'; // amber — the "test" world
const LIVE = '#17c964'; // green — the "live", money-moving world

type Obj = { label: string; testEx: string; liveEx: string };

const objects: Obj[] = [
  { label: 'API keys', testEx: 'sk_test_…', liveEx: 'sk_live_…' },
  { label: 'Customers', testEx: 'cus_… (test)', liveEx: 'cus_… (live)' },
  { label: 'Subscriptions', testEx: 'sub_… (test)', liveEx: 'sub_… (live)' },
  { label: 'Prices', testEx: 'price_… (test)', liveEx: 'price_… (live)' },
  { label: 'Webhooks', testEx: 'whsec_… (test)', liveEx: 'whsec_… (live)' },
];
---

<Figure>
  <div
    class="uni"
    role="img"
    aria-label="Two disjoint Stripe universes split by a wall labelled 'nothing crosses'. The test universe (used by dev, CI, and staging) and the live universe (used by production only) each hold the same object types — API keys, Customers, Subscriptions, Prices, and Webhooks — but no object exists in both. Their IDs differ: for example a test key is sk_test_ while the matching live key is sk_live_."
  >
    <section class="uni-col uni-col--test">
      <header class="uni-head">
        <span class="uni-name">Test universe</span>
        <span class="uni-tag uni-tag--test">dev · CI · staging</span>
      </header>
      <ul class="uni-list">
        {objects.map((o) => (
          <li class="uni-item">
            <span class="uni-dot uni-dot--test" aria-hidden="true"></span>
            <span class="uni-body">
              <span class="uni-label">{o.label}</span>
              <code class="uni-ex">{o.testEx}</code>
            </span>
          </li>
        ))}
      </ul>
    </section>

    <div class="uni-wall" aria-hidden="true">
      <span class="uni-wall-pill">nothing crosses</span>
    </div>

    <section class="uni-col uni-col--live">
      <header class="uni-head">
        <span class="uni-name">Live universe</span>
        <span class="uni-tag uni-tag--live">production only</span>
      </header>
      <ul class="uni-list">
        {objects.map((o) => (
          <li class="uni-item">
            <span class="uni-dot uni-dot--live" aria-hidden="true"></span>
            <span class="uni-body">
              <span class="uni-label">{o.label}</span>
              <code class="uni-ex">{o.liveEx}</code>
            </span>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <Fragment slot="caption">
    Two disjoint worlds &mdash; <strong>same shapes, zero shared objects.</strong>{' '}
    Every object type exists in both, but a test-mode object and its live twin
    share only a name; their IDs differ &mdash; which is exactly why your code
    resolves Prices by <code>lookup_key</code>, the one handle you author
    identically in both.
  </Fragment>
</Figure>

<style define:vars={{ test: TEST, live: LIVE }}>
  .uni {
    display: flex;
    align-items: stretch;
    gap: 0;
    max-width: 720px;
    margin: 0 auto;
    padding-block: 0.25rem;
  }

  .uni-col {
    flex: 1 1 0;
    min-width: 0;
    margin: 0;
    padding: 0.85rem 1.1rem;
    border-radius: 0.6rem;
  }

  .uni-col--test {
    background: color-mix(in srgb, var(--test) 9%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--test) 30%, transparent);
  }

  .uni-col--live {
    background: color-mix(in srgb, var(--live) 9%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--live) 30%, transparent);
  }

  /* The hard wall between the two worlds — a solid divider carrying the
     "nothing crosses" pill, vertically centred. */
  .uni-wall {
    position: relative;
    flex: 0 0 auto;
    align-self: stretch;
    width: 2px;
    margin: 0.4rem 1.2rem;
    background: repeating-linear-gradient(
      to bottom,
      var(--sl-color-gray-4) 0,
      var(--sl-color-gray-4) 6px,
      transparent 6px,
      transparent 11px
    );
  }

  .uni-wall-pill {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
    background: var(--sl-color-bg-sidebar, var(--sl-color-black));
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.35rem;
    padding: 0.18rem 0.4rem;
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  .uni-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.5rem;
    margin: 0 0 0.7rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .uni-name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--sl-color-white);
  }

  .uni-tag {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.12rem 0.45rem;
    border-radius: 0.35rem;
    margin: 0;
  }

  .uni-tag--test {
    color: color-mix(in srgb, var(--test) 55%, var(--sl-color-white));
    background: color-mix(in srgb, var(--test) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--test) 40%, transparent);
  }

  .uni-tag--live {
    color: color-mix(in srgb, var(--live) 55%, var(--sl-color-white));
    background: color-mix(in srgb, var(--live) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--live) 40%, transparent);
  }

  .uni-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .uni-item {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin: 0;
  }

  .uni-dot {
    flex: 0 0 auto;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: 0.42rem;
    border-radius: 50%;
  }

  .uni-dot--test {
    background: var(--test);
  }

  .uni-dot--live {
    background: var(--live);
  }

  .uni-body {
    display: flex;
    flex-direction: column;
    gap: 0.16rem;
    min-width: 0;
  }

  .uni-label {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .uni-ex {
    margin: 0;
    padding: 0;
    background: transparent;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.76rem;
    line-height: 1.3;
    color: var(--sl-color-gray-3);
    word-break: break-word;
  }

  /* Stack the two worlds on narrow viewports; the wall goes horizontal. */
  @media (max-width: 560px) {
    .uni {
      flex-direction: column;
    }

    .uni-wall {
      width: auto;
      height: 2px;
      margin: 0.8rem 1.2rem;
      background: repeating-linear-gradient(
        to right,
        var(--sl-color-gray-4) 0,
        var(--sl-color-gray-4) 6px,
        transparent 6px,
        transparent 11px
      );
    }

    .uni-wall-pill {
      writing-mode: horizontal-tb;
    }
  }
</style>
