---
// Static three-phase round-trip strip for the Customer Portal lesson.
// Plain HTML + CSS (flex rows + CSS-chevron arrows between the cards).
// Same visual language as lesson 2's CheckoutTopologyStrip: the app owns the
// two ends (accent-tinted), Stripe owns the middle (neutral) — so the eye
// reads "the app is at both ends, never in the middle".
//
// Layout: a top row of three equal-height cards with chevron arrows between
// them (align-items: stretch keeps the cards the same height even when one
// wraps to more lines), and a parallel row of three sub-labels beneath, each
// column-aligned under its card via a shared grid.
---

<div class="prt-strip">
	<div class="prt-row prt-cards">
		<div class="prt-card prt-app">
			<span class="prt-btn">Manage billing</span>
		</div>

		<div class="prt-arrow" aria-hidden="true"></div>

		<div class="prt-card prt-stripe">
			<span class="prt-head">Stripe Portal</span>
			<span class="prt-detail">plan · card · invoices · cancel</span>
		</div>

		<div class="prt-arrow" aria-hidden="true"></div>

		<div class="prt-card prt-app">
			<span class="prt-head">Your app</span>
			<span class="prt-detail">back at <code>return_url</code></span>
		</div>
	</div>

	<div class="prt-row prt-subs">
		<span class="prt-sub">App initiates</span>
		<span class="prt-sub">Stripe hosts</span>
		<span class="prt-sub">App receives the return</span>
	</div>
</div>

<style>
	.prt-strip {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0.5rem 0.25rem;
		max-width: 620px;
		margin-inline: auto;
		margin-block: 0;
	}

	.prt-row {
		display: grid;
		/* card · arrow · card · arrow · card — fixed arrow tracks so the
		   cards row and the subs row share an identical column system. */
		grid-template-columns: 1fr 24px 1fr 24px 1fr;
		align-items: stretch;
		gap: 0.5rem;
		margin: 0;
	}

	/* Sub-labels reuse the exact same tracks, skipping the arrow columns. */
	.prt-subs {
		align-items: start;
	}

	.prt-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.3rem;
		min-width: 0;
		min-height: 76px;
		box-sizing: border-box;
		padding: 0.85rem 0.6rem;
		border-radius: 0.6rem;
		border: 1px solid var(--sl-color-gray-4);
		text-align: center;
		margin: 0;
	}

	/* App-owned ends: accent tint so the eye reads "the app is here". */
	.prt-app {
		background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}

	/* Stripe in the middle: deliberately neutral/distinct. */
	.prt-stripe {
		background: var(--sl-color-bg);
	}

	.prt-head {
		font-weight: 600;
		font-size: 0.95rem;
		line-height: 1.2;
		color: var(--sl-color-white);
		margin: 0;
	}

	.prt-detail {
		font-size: 0.78rem;
		line-height: 1.25;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	.prt-detail code {
		background: transparent;
		padding: 0;
		font-size: 0.95em;
		color: var(--sl-color-gray-2);
	}

	/* The "Manage billing" button, styled as a faux button. */
	.prt-btn {
		display: inline-block;
		font-weight: 600;
		font-size: 0.9rem;
		line-height: 1.2;
		padding: 0.4rem 0.8rem;
		border-radius: 0.45rem;
		color: var(--sl-color-white);
		background: var(--sl-color-accent);
		margin: 0;
	}

	.prt-sub {
		font-size: 0.8rem;
		line-height: 1.2;
		font-weight: 500;
		text-align: center;
		color: var(--sl-color-gray-2);
		margin: 0;
	}

	/* Place each sub-label under its card by jumping the arrow tracks. */
	.prt-subs .prt-sub:nth-child(1) { grid-column: 1; }
	.prt-subs .prt-sub:nth-child(2) { grid-column: 3; }
	.prt-subs .prt-sub:nth-child(3) { grid-column: 5; }

	/* CSS chevron arrow between cards — centered on the shared card height. */
	.prt-arrow {
		align-self: center;
		width: 24px;
		height: 2px;
		background: var(--sl-color-gray-3);
		position: relative;
		margin: 0;
	}

	.prt-arrow::after {
		content: '';
		position: absolute;
		right: -1px;
		top: 50%;
		width: 8px;
		height: 8px;
		border-top: 2px solid var(--sl-color-gray-3);
		border-right: 2px solid var(--sl-color-gray-3);
		transform: translateY(-50%) rotate(45deg);
	}

	/* On narrow viewports stack the phases vertically; the arrows become
	   down-chevrons so the sequence still reads top-to-bottom. */
	@media (max-width: 520px) {
		.prt-strip {
			max-width: 280px;
		}

		.prt-row,
		.prt-subs {
			grid-template-columns: 1fr;
			justify-items: center;
		}

		.prt-card {
			width: 100%;
		}

		.prt-subs .prt-sub:nth-child(1),
		.prt-subs .prt-sub:nth-child(2),
		.prt-subs .prt-sub:nth-child(3) {
			grid-column: 1;
		}

		.prt-arrow {
			justify-self: center;
			width: 2px;
			height: 20px;
		}

		.prt-arrow::after {
			right: 50%;
			top: auto;
			bottom: -1px;
			transform: translateX(50%) rotate(135deg);
		}
	}
</style>
