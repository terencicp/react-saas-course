---
import Figure from '../../../figures/Figure.astro';

// The (access, tier) plane drawn as a 2-row × 3-column grid so the student sees
// the two axes vary INDEPENDENTLY:
//   - Vertical axis  = access  (granted / denied) — decided by hasActiveAccess(status).
//   - Horizontal axis = tier   (free / pro / team) — decided by entitlement.plan.
// Moving DOWN a column (losing access) is a different motion than moving ACROSS
// a row (changing tier). The granted×pro cell is the one that trips people up: a
// past_due Pro org keeps its PRO features during dunning grace — a failed payment
// is the access axis talking, never the tier axis.
const GRANT = '#16a34a'; // green — access granted row
const DENY = '#dc2626'; // red — access denied row

type Cell = { body: string; muted?: boolean; spotlight?: boolean };

const tiers = ['free', 'pro', 'team'];

// Row order: granted on top, denied below — same reading order as the prose.
const grantRow: Cell[] = [
  { body: 'Free org, healthy — free features only.' },
  {
    body: 'past_due Pro org — keeps Pro features during dunning grace.',
    spotlight: true,
  },
  { body: 'active Team org — full Team features.' },
];

const denyRow: Cell[] = [
  { body: 'n/a — free is the floor, nothing is gated behind access.', muted: true },
  { body: 'canceled ex-Pro org — no access, regardless of past tier.' },
  { body: 'incomplete Team Checkout — no access; never truly subscribed.' },
];
---

<Figure>
  <div
    class="avt"
    role="img"
    aria-label="A grid with access on the vertical axis (granted on top, denied below) and tier on the horizontal axis (free, pro, team). Granted free: a healthy free org with free features only. Granted pro: a past_due Pro org that keeps its Pro features during dunning grace. Granted team: an active Team org with full Team features. Denied free: not applicable, free is the floor with nothing gated behind access. Denied pro: a canceled ex-Pro org with no access regardless of past tier. Denied team: an incomplete Team Checkout with no access, never truly subscribed. Losing access moves down a column; changing tier moves across a row."
  >
    {/* Top axis label */}
    <div class="avt-axis avt-axis--tier" aria-hidden="true">
      Tier &mdash; <code>entitlement.plan</code> &rarr;
    </div>

    <div class="avt-grid">
      {/* Corner + tier column headers */}
      <div class="avt-corner" aria-hidden="true"></div>
      {tiers.map((t) => (
        <div class="avt-colhead">
          <code>{t}</code>
        </div>
      ))}

      {/* Granted row */}
      <div class="avt-rowhead avt-rowhead--grant">
        <span class="avt-rowhead-state">Access: granted</span>
        <span class="avt-rowhead-sub">hasActiveAccess → true</span>
      </div>
      {grantRow.map((c) => (
        <div
          class:list={[
            'avt-cell',
            'avt-cell--grant',
            { 'avt-cell--muted': c.muted },
            { 'avt-cell--spotlight': c.spotlight },
          ]}
        >
          {c.spotlight && <span class="avt-pin" aria-hidden="true">tier unchanged</span>}
          <span class="avt-cell-body" set:html={c.body.replace(/(past_due|Pro)/g, '<strong>$1</strong>')} />
        </div>
      ))}

      {/* Denied row */}
      <div class="avt-rowhead avt-rowhead--deny">
        <span class="avt-rowhead-state">Access: denied</span>
        <span class="avt-rowhead-sub">hasActiveAccess → false</span>
      </div>
      {denyRow.map((c) => (
        <div
          class:list={[
            'avt-cell',
            'avt-cell--deny',
            { 'avt-cell--muted': c.muted },
          ]}
        >
          <span class="avt-cell-body">{c.body}</span>
        </div>
      ))}
    </div>

    {/* Left axis label */}
    <div class="avt-axis avt-axis--access" aria-hidden="true">
      <span>Access &mdash; <code>hasActiveAccess</code> &darr;</span>
    </div>
  </div>

  <Fragment slot="caption">
    Access and tier are independent axes: a failed payment moves you <em>down</em> the
    access axis, never <em>across</em> the tier axis.
  </Fragment>
</Figure>

<style define:vars={{ grant: GRANT, deny: DENY }}>
  .avt {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.4rem;
    align-items: stretch;
    max-width: 720px;
    margin: 0 auto;
    padding-block: 0.2rem;
  }

  /* Top tier-axis label spans the grid column, sits above it. */
  .avt-axis--tier {
    grid-column: 2;
    grid-row: 1;
    align-self: end;
    margin: 0 0 0.1rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
    text-align: center;
  }

  /* Left access-axis label runs vertically alongside the grid. */
  .avt-axis--access {
    grid-column: 1;
    grid-row: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
  }

  .avt-axis--access span {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  .avt-axis code {
    background: transparent;
    padding: 0;
    font-size: 0.72rem;
    text-transform: none;
    letter-spacing: normal;
    color: var(--sl-color-gray-1);
  }

  .avt-grid {
    grid-column: 2;
    grid-row: 2;
    display: grid;
    grid-template-columns: minmax(7.5rem, auto) repeat(3, 1fr);
    gap: 0.4rem;
    margin: 0;
  }

  .avt-corner {
    margin: 0;
  }

  .avt-colhead {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0.35rem 0.4rem;
  }

  .avt-colhead code {
    background: var(--sl-color-gray-6, var(--sl-color-gray-5));
    color: var(--sl-color-white);
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.12rem 0.55rem;
    border-radius: 0.35rem;
  }

  .avt-rowhead {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    margin: 0;
    padding: 0.5rem 0.7rem;
    border-radius: 0.5rem;
  }

  .avt-rowhead--grant {
    background: color-mix(in srgb, var(--grant) 14%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--grant) 34%, transparent);
  }

  .avt-rowhead--deny {
    background: color-mix(in srgb, var(--deny) 12%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--deny) 32%, transparent);
  }

  .avt-rowhead-state {
    margin: 0;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .avt-rowhead-sub {
    margin: 0;
    font-size: 0.66rem;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    color: var(--sl-color-gray-2);
  }

  .avt-cell {
    position: relative;
    display: flex;
    align-items: center;
    min-width: 0;
    margin: 0;
    padding: 0.6rem 0.7rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--sl-color-white);
  }

  .avt-cell--grant {
    background: color-mix(in srgb, var(--grant) 8%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--grant) 22%, transparent);
  }

  .avt-cell--deny {
    background: color-mix(in srgb, var(--deny) 7%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--deny) 20%, transparent);
  }

  .avt-cell--muted {
    background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent);
    box-shadow: inset 0 0 0 1px var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    font-style: italic;
  }

  /* The one cell people get wrong — past_due Pro keeps Pro features. */
  .avt-cell--spotlight {
    background: color-mix(in srgb, var(--grant) 16%, transparent);
    box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--grant) 60%, transparent);
  }

  .avt-cell-body {
    margin: 0;
  }

  .avt-cell-body :global(strong) {
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .avt-pin {
    position: absolute;
    top: -0.55rem;
    right: 0.5rem;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-white);
    background: var(--grant);
    border-radius: 0.3rem;
    padding: 0.1rem 0.36rem;
  }

  @media (max-width: 600px) {
    .avt-grid {
      grid-template-columns: minmax(6rem, auto) repeat(3, 1fr);
      gap: 0.3rem;
    }

    .avt-cell,
    .avt-rowhead-state {
      font-size: 0.72rem;
    }
  }
</style>
