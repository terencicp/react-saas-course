---
// StatusBanners — Chapter 064 Lesson 5, "Surfacing status: the banner above the app".
//
// Three status-keyed banner MOCKS, one per tab, so the student sees the copy and
// the CTA destination side by side as the status escalates. These are plain HTML
// + CSS (a UI mock, deliberately not a diagram engine) — NOT the wired banner
// component (that ships later). The teaching is the SHAPE: each banner is a
// horizontal bar above the app, keyed by status, whose CTA deep-links to the
// exact place the customer fixes the problem.
//
// The tone escalates with the status, and the colour carries the meaning:
//   - past_due     → amber / warning  → gentle nudge, card failed mid-dunning,
//                    CTA goes to the Portal (a live subscription to repair).
//   - winding down → neutral / info   → cancelled but still `active`, CTA undoes
//                    the cancel via the Portal.
//   - canceled     → red / terminal   → access is over, CTA starts a FRESH
//                    subscription via Checkout, not the Portal.
//
// Each banner is a <div role="status"> live region — the prose just below the
// figure references this, so a screen reader announces the message politely.
// Plain inline-ish scoped CSS via Starlight theme vars so it flips light/dark.

import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

type Tone = 'warn' | 'info' | 'danger';

type Banner = {
  label: string;
  tone: Tone;
  status: string;
  message: string;
  cta: string;
  destination: 'Portal' | 'Checkout';
  caption: string;
};

const banners: Banner[] = [
  {
    label: 'past_due',
    tone: 'warn',
    status: 'past_due',
    message: 'Your payment failed — update your card to keep Pro.',
    cta: 'Update payment method',
    destination: 'Portal',
    caption:
      'Card failed, dunning in progress — keep them working, point them at the Portal.',
  },
  {
    label: 'winding down',
    tone: 'info',
    status: 'active + cancelAtPeriodEnd',
    message: 'Your subscription ends on Aug 14 — reactivate to keep your features.',
    cta: 'Keep my subscription',
    destination: 'Portal',
    caption: 'Cancelled but still active; the CTA undoes the cancel via the Portal.',
  },
  {
    label: 'canceled',
    tone: 'danger',
    status: 'canceled',
    message: 'Your subscription was canceled — re-subscribe to restore access.',
    cta: 'Re-subscribe',
    destination: 'Checkout',
    caption:
      'Access is over; the CTA starts a fresh subscription via Checkout, not the Portal.',
  },
];

// Inline SVG glyph per tone — an icon-ish accent on the leading edge of the bar.
const icons: Record<Tone, string> = {
  // alert-triangle — something needs attention but isn't an emergency
  warn: '<path d="M12 3.2 1.8 20.5h20.4L12 3.2Z"/><path d="M12 9.5v4.2"/><circle cx="12" cy="17" r="0.1"/>',
  // info — a non-urgent heads-up
  info: '<circle cx="12" cy="12" r="9"/><path d="M12 11v5"/><circle cx="12" cy="8" r="0.1"/>',
  // x-octagon — terminal, access is over
  danger:
    '<path d="M8.2 3h7.6L21 8.2v7.6L15.8 21H8.2L3 15.8V8.2L8.2 3Z"/><path d="M9 9l6 6M15 9l-6 6"/>',
};
---

<TabbedContent>
  {
    banners.map((b) => (
      <TabbedItem label={b.label} caption={b.caption}>
        <div class="sb not-content">
          <div class:list={['sb-bar', `sb-bar--${b.tone}`]} role="status">
            <span class="sb-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[b.tone]}
              />
            </span>

            <span class="sb-msg">{b.message}</span>

            <button class="sb-cta" type="button">
              {b.cta}
            </button>
          </div>

          <p class="sb-route" aria-hidden="true">
            CTA destination: <span class="sb-route-dest">{b.destination}</span>
          </p>
        </div>
      </TabbedItem>
    ))
  }
</TabbedContent>

<style>
  .sb {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  /* The banner itself — a horizontal bar that would sit above the app content. */
  .sb-bar {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    margin: 0;
    padding: 0.7rem 0.85rem;
    border-radius: 0.6rem;
    border: 1px solid var(--sb-edge);
    background: var(--sb-bg);
    color: var(--sb-text);
  }

  .sb-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    color: var(--sb-accent);
  }

  .sb-msg {
    flex: 1 1 auto;
    min-width: 0;
    font-size: 0.86rem;
    line-height: 1.4;
    font-weight: 500;
    color: var(--sl-color-white);
  }

  /* The call to action — every banner carries one, named, never generic. */
  .sb-cta {
    box-sizing: border-box;
    appearance: none;
    cursor: pointer;
    flex: 0 0 auto;
    white-space: nowrap;
    margin: 0;
    padding: 0.4rem 0.85rem;
    border-radius: 0.45rem;
    border: 1px solid transparent;
    background: var(--sb-accent);
    color: #fff;
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .sb-cta:hover {
    filter: brightness(1.08);
  }

  /* Footnote naming where the CTA goes — Portal vs Checkout is the lesson. */
  .sb-route {
    margin: 0;
    padding-left: 0.1rem;
    font-size: 0.7rem;
    color: var(--sl-color-gray-3);
  }

  .sb-route-dest {
    font-weight: 700;
    color: var(--sl-color-gray-1);
  }

  /* amber / warning — card failed, dunning grace, gentle nudge */
  .sb-bar--warn {
    --sb-accent: #d97706; /* amber-600 */
    --sb-edge: color-mix(in srgb, #d97706 45%, transparent);
    --sb-bg: color-mix(in srgb, #d97706 12%, var(--sl-color-bg, transparent));
  }

  /* neutral / info — winding down, still active, heads-up */
  .sb-bar--info {
    --sb-accent: #2563eb; /* blue-600 */
    --sb-edge: color-mix(in srgb, #2563eb 42%, transparent);
    --sb-bg: color-mix(in srgb, #2563eb 11%, var(--sl-color-bg, transparent));
  }

  /* red / terminal — canceled, access is over, last call */
  .sb-bar--danger {
    --sb-accent: #dc2626; /* red-600 */
    --sb-edge: color-mix(in srgb, #dc2626 45%, transparent);
    --sb-bg: color-mix(in srgb, #dc2626 12%, var(--sl-color-bg, transparent));
  }

  @media (max-width: 560px) {
    .sb-bar {
      flex-wrap: wrap;
    }

    .sb-cta {
      margin-left: auto;
    }
  }
</style>
