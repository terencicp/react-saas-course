---
// offset-shift-duplicate — Chapter 038 Lesson 6 ("Cursor pagination"),
// the CORRECTNESS/STABILITY half of "where offset breaks". A 5-step
// DiagramSequence walking the insert-shift duplicate bug on a small page of 3.
//
// The list is invoices newest-first under `desc(createdAt)`: higher number =
// newer = sorts first. Page size 3, so page 1 = the newest 3 and page 2 is the
// next 3 via `offset 3`. Between the two page loads a brand-new invoice (#106)
// is created and, being newest, lands at the very TOP — which slides every row
// down one position. That single shift drags #103 (the last row of page 1) into
// page 2's window, so the user sees #103 twice.
//
// Pedagogical USP: the SHIFT is made literally visible. The list is a vertical
// column top-anchored in the stage, and step 1 has 6 rows while steps 2–4 have
// 7 (the inserted #106 on top). Scrubbing step 1 → step 2 therefore drops all
// six original rows down exactly one slot — that downward jump IS the argument.
//
// Colour convention (pinned to the chapter-037/038 figure family, light-pinned
// so the hand-picked tints survive dark mode):
//   BLUE   (#2563eb) = a page window — the rows a page returns (the anchor hue),
//   AMBER  (#d97706) = the freshly inserted row #106 (attention, "just arrived";
//                      same accent the lesson's AnnotatedCode uses for its
//                      watch-out branch),
//   RED    (#dc2626) = the duplicated row #103 (the bug),
//   neutral slate    = inert rows, the position gutter, the "skipped" zone.
//
// Pure HTML + CSS inside DiagramStep bodies. A scoped <style> block (Astro
// scopes it, and the slotted markup authored here carries that scope) plus a
// `margin: 0` reset on every rule defeats Starlight's prose-margin selector.
// Height-capped: ~28px rows, ≤7 rows, well under the ceiling.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

// Each step is a list of rows; a row has its invoice number and a state that
// drives its tint. States:
//   'plain'  — inert neutral row
//   'win1'   — inside page 1's window (blue)
//   'win2'   — inside page 2's window (blue)
//   'new'    — the freshly inserted #106 (amber)
//   'skip'   — in the offset-3 skipped zone (muted)
//   'dup'    — the duplicated row #103 (red)
// `tag` is an optional short chip on the right edge of the row.
type State = "plain" | "win1" | "win2" | "new" | "skip" | "dup";
type Row = { n: number; state: State; tag?: string };

// The window/zone label that floats above the first row of a banded group.
type Band = { atPos: number; span: number; label: string; tone: "blue" | "amber" | "red" };
type Step = { rows: Row[]; bands: Band[]; caption: string };

const baseList = [105, 104, 103, 102, 101, 100];
const afterInsert = [106, 105, 104, 103, 102, 101, 100];

const steps: Step[] = [
  // ---- step 1 — page 1 loads (newest 3) ----
  {
    rows: baseList.map((n, i) => ({ n, state: i < 3 ? "win1" : "plain" })),
    bands: [{ atPos: 1, span: 3, label: "page 1 — returned", tone: "blue" }],
    caption: "Page 1 loads: the three newest invoices, #105 #104 #103. The user reads them.",
  },
  // ---- step 2 — #106 is created and lands on top ----
  {
    rows: afterInsert.map((n) => ({
      n,
      state: n === 106 ? "new" : "plain",
      tag: n === 106 ? "new" : undefined,
    })),
    bands: [],
    caption:
      "Between clicks, a new invoice #106 is created. Newest-first, it lands at the very top — and pushes every row below it down one position.",
  },
  // ---- step 3 — page 2 asks for rows 4–6 by position ----
  // window is exactly the 3 rows at positions 4,5,6 (offset 3, limit 3);
  // positions 1–3 are skipped, position 7 (#100) is the row *after* page 2.
  {
    rows: afterInsert.map((n, i) => ({
      n,
      state: i < 3 ? "skip" : i < 6 ? "win2" : "plain",
    })),
    bands: [
      { atPos: 1, span: 3, label: "skipped (offset 3)", tone: "amber" },
      { atPos: 4, span: 3, label: "page 2 will return these", tone: "blue" },
    ],
    caption:
      "The user clicks ‘next’. Page 2 asks for rows 4–6 by position: offset 3, limit 3. Position 4 is now #103.",
  },
  // ---- step 4 — the collision: #103 slid from pos 3 into pos 4 ----
  {
    rows: afterInsert.map((n, i) =>
      n === 103
        ? ({ n, state: "dup", tag: "also page 1" } as Row)
        : ({ n, state: i < 3 ? "skip" : i < 6 ? "win2" : "plain" } as Row),
    ),
    bands: [{ atPos: 4, span: 3, label: "page 2's window", tone: "blue" }],
    caption:
      "But #103 was the last row of page 1. The shift pushed it from position 3 into position 4 — squarely inside page 2's window.",
  },
];

// The total slot count the gutter/stage is sized for (the inserted-row steps).
const SLOTS = afterInsert.length;
---

<DiagramSequence>
  {
    steps.map((step) => (
      <DiagramStep caption={step.caption}>
        <div class="osd not-content">
          <ol class="osd-list" role="list" style={`--slots: ${SLOTS}`}>
            {step.rows.map((row, i) => {
              const pos = i + 1;
              const band = step.bands.find((b) => b.atPos === pos);
              return (
                <li class="osd-row-wrap">
                  {band && (
                    <span class={`osd-band osd-band--${band.tone}`}>{band.label}</span>
                  )}
                  <div class="osd-row">
                    <span class="osd-pos">{pos}</span>
                    <div class={`osd-cell osd-cell--${row.state}`}>
                      <span class="osd-id">#{row.n}</span>
                      {row.tag && (
                        <span class={`osd-tag osd-tag--${row.state}`}>{row.tag}</span>
                      )}
                    </div>
                  </div>
                </li>
              );
            })}
          </ol>
        </div>
      </DiagramStep>
    ))
  }

  {/* ---- step 5 — the user's combined view: two pages, #103 twice ---- */}
  <DiagramStep caption="Result: the user sees #103 twice — once at the bottom of page 1, once at the top of page 2. (A delete above them would skip a row instead.)">
    <div class="osd not-content">
      <div class="osd-pages" style={`--slots: ${SLOTS}`}>
        <div class="osd-page">
          <span class="osd-page-head">Page 1</span>
          {[105, 104, 103].map((n) => (
            <div class={`osd-cell osd-cell--${n === 103 ? "dup" : "win1"}`}>
              <span class="osd-id">#{n}</span>
              {n === 103 && <span class="osd-tag osd-tag--dup">duplicate</span>}
            </div>
          ))}
        </div>

        <div class="osd-page">
          <span class="osd-page-head">Page 2</span>
          {[103, 102, 101].map((n) => (
            <div class={`osd-cell osd-cell--${n === 103 ? "dup" : "win2"}`}>
              <span class="osd-id">#{n}</span>
              {n === 103 && <span class="osd-tag osd-tag--dup">duplicate</span>}
            </div>
          ))}
        </div>
      </div>
    </div>
  </DiagramStep>
</DiagramSequence>

<style>
  /* Stage island: a centred, height-capped column. color-scheme:light pins the
     hand-picked tints so they don't invert in dark mode. The list is
     top-anchored so the step-1 → step-2 transition reads as a DOWNWARD shift. */
  .osd {
    box-sizing: border-box;
    width: 100%;
    max-width: 440px;
    margin-inline: auto;
    padding: 2px;
    color-scheme: light;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* the vertical list — one row per slot, top-aligned. min-height reserves the
     full SLOTS-tall column even on step 1 (6 rows) so the stage never jumps. */
  .osd-list {
    box-sizing: border-box;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 0;
    margin: 0;
    min-height: calc(var(--slots) * 28px + (var(--slots) - 1) * 7px);
  }

  .osd-row-wrap {
    box-sizing: border-box;
    position: relative;
    margin: 0;
  }

  /* the [pos | cell] row. The position gutter is a fixed narrow column so the
     cells line up; the cell flexes to fill the rest. */
  .osd-row {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 20px 1fr;
    align-items: center;
    column-gap: 9px;
    margin: 0;
  }

  /* position number in the left gutter — muted, it's chrome until steps 3–4. */
  .osd-pos {
    box-sizing: border-box;
    font-size: 11px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    text-align: right;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  /* a single invoice row-cell. */
  .osd-cell {
    box-sizing: border-box;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 0 10px;
    border-radius: 6px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    margin: 0;
  }

  .osd-id {
    box-sizing: border-box;
    font-size: 13px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
    color: var(--sl-color-gray-1);
    margin: 0;
  }

  /* ---- cell states ------------------------------------------------------ */

  /* page windows — saturated BLUE fill, white id. Identical in both pages so
     the eye reads them as "the same kind of thing: rows a page returned". */
  .osd-cell--win1,
  .osd-cell--win2 {
    border-color: #2563eb;
    background: #2563eb;
    box-shadow: 0 0 0 1px color-mix(in srgb, #2563eb 30%, transparent);
  }
  .osd-cell--win1 .osd-id,
  .osd-cell--win2 .osd-id {
    color: #fff;
  }

  /* the freshly inserted #106 — AMBER, "just arrived". */
  .osd-cell--new {
    border-color: #d97706;
    background: color-mix(in srgb, #d97706 16%, var(--sl-color-bg));
    box-shadow: 0 0 0 1px color-mix(in srgb, #d97706 35%, transparent);
  }
  .osd-cell--new .osd-id {
    color: #9a3412;
  }

  /* the offset-3 skipped zone — muted/greyed, faintly struck so it reads as
     "stepped over". Not discarded like the perf figure; just passed by. */
  .osd-cell--skip {
    border-color: var(--sl-color-gray-4);
    background: repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 6px,
        color-mix(in srgb, var(--sl-color-gray-2) 22%, transparent) 6px,
        color-mix(in srgb, var(--sl-color-gray-2) 22%, transparent) 7px
      ),
      var(--sl-color-gray-6);
    opacity: 0.62;
  }

  /* the duplicated #103 — RED, the bug. */
  .osd-cell--dup {
    border-color: #dc2626;
    background: #dc2626;
    box-shadow: 0 0 0 1px color-mix(in srgb, #dc2626 35%, transparent);
  }
  .osd-cell--dup .osd-id {
    color: #fff;
  }

  /* ---- the right-edge chip on a row ------------------------------------- */
  .osd-tag {
    box-sizing: border-box;
    flex: 0 0 auto;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.3;
    padding: 1px 7px;
    border-radius: 999px;
    white-space: nowrap;
    margin: 0;
  }
  .osd-tag--new {
    color: #9a3412;
    background: #fff;
    border: 1px solid color-mix(in srgb, #d97706 45%, transparent);
  }
  .osd-tag--dup {
    color: #fff;
    background: color-mix(in srgb, #000 22%, #dc2626);
    border: 1px solid color-mix(in srgb, #fff 35%, transparent);
  }

  /* ---- the band label floating above a windowed/zoned group ------------- */
  .osd-band {
    box-sizing: border-box;
    position: absolute;
    left: 29px; /* clears the 20px gutter + 9px gap so it sits over the cells */
    top: -8px;
    z-index: 2;
    font-size: 9.5px;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.2;
    padding: 1px 6px;
    border-radius: 5px;
    white-space: nowrap;
    margin: 0;
  }
  .osd-band--blue {
    color: #fff;
    background: #2563eb;
  }
  .osd-band--amber {
    color: #fff;
    background: #b45309;
  }
  .osd-band--red {
    color: #fff;
    background: #dc2626;
  }

  /* ---- step 5: the two stacked page groups ----------------------------- */
  .osd-pages {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 16px;
    /* match the single-list column height so the stage doesn't resize. */
    min-height: calc(var(--slots) * 28px + (var(--slots) - 1) * 7px);
    justify-content: center;
    margin: 0;
  }
  .osd-page {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 9px 10px 10px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 9px;
    background: color-mix(in srgb, var(--sl-color-gray-6) 60%, transparent);
    margin: 0;
  }
  .osd-page-head {
    box-sizing: border-box;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
    margin: 0 0 1px;
  }
  /* in the page groups the cells span the full width (no gutter column). */
  .osd-page .osd-cell {
    width: 100%;
  }
</style>
