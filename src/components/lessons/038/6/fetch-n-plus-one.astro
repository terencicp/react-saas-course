---
// fetch-n-plus-one — Chapter 038 Lesson 6 ("Cursor pagination"), the
// "knowing there's a next page" trick made a single-glance picture.
//
// One horizontal strip of `pageSize + 1` cells (pageSize = 5, so 6 cells):
//   - cells 1..5 are the saturated BLUE page window, bracketed underneath as
//     "returned (the page)" — the rows the caller actually gets back.
//   - cell 6 is the PROBE: dashed border, muted/tinted fill, faded. Its sole
//     job is to exist; its presence is the "there is a next page" signal. It's
//     bracketed/labelled "probe" with a caption-strip below: "fetched, then
//     sliced off — its existence means there's a next page".
//   - a short GREEN arrow rises from the LAST RETURNED cell (#5, not the probe)
//     to a "next cursor" tag, hammering the load-bearing point from the prose:
//     the next cursor is the key of the last row you RETURN, never the probe.
//
// Colour convention (pinned to the chapter-037/038 figure family, light-pinned
// so the hand-picked tints survive dark mode):
//   BLUE  (#2563eb) = the page window — the rows returned (the anchor hue,
//                     identical to the two sibling figures in this lesson),
//   GREEN (#16a34a) = the win / the cursor — here the "next cursor" derived
//                     from the last returned row,
//   neutral slate   = the probe (inert, fetched-but-discarded) and chrome.
//
// Pure HTML + CSS + one inline SVG arrow. A `not-content` wrapper plus a
// `margin: 0` reset on every rule defeats Starlight's prose-margin selector.
// Single row, height trivial — well under the ceiling. No leader lines, so the
// figure stays expandable.

import Figure from "../../../figures/Figure.astro";

const PAGE_SIZE = 5;
// indices 0..PAGE_SIZE are the returned rows; index PAGE_SIZE is the probe.
const cells = Array.from({ length: PAGE_SIZE + 1 }, (_, i) => ({
  i,
  // human-facing 1-based row number shown in the cell
  n: i + 1,
  isProbe: i === PAGE_SIZE,
  isLastReturned: i === PAGE_SIZE - 1,
}));
---

<Figure
  caption="Fetch pageSize + 1. If the probe row comes back, there's a next page — slice it off and hand back the first pageSize. One extra row replaces a whole count query, and the next cursor is the key of the last row you return, never the probe."
>
  <div class="fno not-content">
    {/* ============ the strip ============ */}
    <div class="fno-strip" role="img" aria-label="A row of pageSize + 1 cells: five returned, one probe">
      {cells.map((c) => (
        <div class={`fno-col ${c.isProbe ? "fno-col--probe" : "fno-col--page"}`}>
          {/* the next-cursor tag + arrow, anchored to the last RETURNED cell */}
          {c.isLastReturned && (
            <div class="fno-cursor">
              <span class="fno-cursor-tag">next cursor</span>
              <svg
                class="fno-cursor-arrow"
                viewBox="0 0 24 24"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <defs>
                  <marker
                    id="fno-arrow-head"
                    viewBox="0 0 10 10"
                    refX="8"
                    refY="5"
                    markerWidth="7"
                    markerHeight="7"
                    orient="auto-start-reverse"
                  >
                    <path d="M0,0 L10,5 L0,10 z" fill="#16a34a"></path>
                  </marker>
                </defs>
                {/* straight down from the tag onto the cell's top edge */}
                <path
                  d="M12,2 L12,22"
                  fill="none"
                  stroke="#16a34a"
                  stroke-width="3"
                  stroke-linecap="round"
                  vector-effect="non-scaling-stroke"
                  marker-end="url(#fno-arrow-head)"
                ></path>
              </svg>
            </div>
          )}

          <div class={`fno-cell ${c.isProbe ? "fno-cell--probe" : "fno-cell--page"}`}>
            <span class="fno-id">row {c.n}</span>
          </div>
        </div>
      ))}
    </div>

    {/* ============ brackets + labels under the strip ============ */}
    <div class="fno-brackets">
      <div class="fno-bracket fno-bracket--page" style={`--from: 0; --span: ${PAGE_SIZE}`}>
        <span class="fno-bracket-line fno-bracket-line--page"></span>
        <span class="fno-bracket-label fno-bracket-label--page">returned (the page)</span>
        <span class="fno-bracket-sub">handed back: {PAGE_SIZE} rows</span>
      </div>
      <div class="fno-bracket fno-bracket--probe" style={`--from: ${PAGE_SIZE}; --span: 1`}>
        <span class="fno-bracket-line fno-bracket-line--probe"></span>
        <span class="fno-bracket-label fno-bracket-label--probe">probe</span>
        <span class="fno-bracket-sub fno-bracket-sub--probe">sliced off — “there’s a next page”</span>
      </div>
    </div>
  </div>
</Figure>

<style>
  /* The figure: a strip of cells, brackets underneath. Short and wide, single
     row. color-scheme:light pins the hand-picked tints so they don't invert in
     dark mode. */
  .fno {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 9px;
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
    padding: 4px 2px 2px;
    color-scheme: light;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* the strip: pageSize + 1 equal columns. The bracket row below declares the
     same grid so each bracket lines up under exactly the cells it covers. */
  .fno-strip {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    width: 100%;
    margin: 0;
  }

  /* a column = the optional cursor stack on top + the cell. The cursor stack
     has reserved height in EVERY column (transparent when empty) so the cells
     share one baseline; only the last-returned column paints into it. */
  .fno-col {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0;
    margin: 0;
  }

  /* the next-cursor tag + the down-arrow, stacked above the last returned cell. */
  .fno-cursor {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    margin: 0;
  }
  .fno-cursor-tag {
    box-sizing: border-box;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.2;
    white-space: nowrap;
    color: #15803d;
    background: #f0fdf4;
    border: 1px solid color-mix(in srgb, #16a34a 45%, transparent);
    border-radius: 999px;
    padding: 1px 8px;
    margin: 0;
  }
  /* the short vertical arrow from the tag down onto the cell's top edge. */
  .fno-cursor-arrow {
    box-sizing: border-box;
    width: 14px;
    height: 16px;
    overflow: visible;
    margin: 0;
  }

  /* reserve the cursor-stack height in columns that DON'T carry it, so every
     cell sits on the same line. ~16px tag + ~16px arrow + gaps ≈ 34px. */
  .fno-col:not(:has(.fno-cursor)) {
    padding-top: 34px;
  }

  /* a single row-cell. */
  .fno-cell {
    box-sizing: border-box;
    width: 100%;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 7px;
    margin: 0;
  }
  .fno-id {
    box-sizing: border-box;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
    white-space: nowrap;
    margin: 0;
  }

  /* the page window — saturated BLUE, white id (the shared anchor hue). */
  .fno-cell--page {
    border: 1px solid #2563eb;
    background: #2563eb;
    box-shadow: 0 0 0 1px color-mix(in srgb, #2563eb 30%, transparent);
  }
  .fno-cell--page .fno-id {
    color: #fff;
  }

  /* the probe — dashed border, muted tinted fill, faded. Fetched-but-discarded:
     it reads as "not really part of the page". */
  .fno-cell--probe {
    border: 1.5px dashed var(--sl-color-gray-3);
    background: repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 6px,
        color-mix(in srgb, var(--sl-color-gray-2) 20%, transparent) 6px,
        color-mix(in srgb, var(--sl-color-gray-2) 20%, transparent) 7px
      ),
      var(--sl-color-gray-6);
    opacity: 0.7;
  }
  .fno-cell--probe .fno-id {
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }

  /* ---- brackets under the strip -------------------------------------- */

  /* same 6-col grid so each bracket spans exactly its cells via grid-column. */
  .fno-brackets {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    column-gap: 8px;
    width: 100%;
    margin: 0;
  }

  /* a bracket spans `--span` columns starting at column `--from` (1-based grid
     line = --from + 1). */
  .fno-bracket {
    box-sizing: border-box;
    grid-column: calc(var(--from) + 1) / span var(--span);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    min-width: 0;
    margin: 0;
  }

  /* the horizontal bracket line with little up-ticks at each end. */
  .fno-bracket-line {
    box-sizing: border-box;
    width: 100%;
    height: 6px;
    border: 1.5px solid #2563eb;
    border-top: none;
    border-radius: 0 0 4px 4px;
    margin: 0;
  }
  .fno-bracket-line--probe {
    border-color: var(--sl-color-gray-3);
    border-style: dashed;
    border-top: none;
  }

  .fno-bracket-label {
    box-sizing: border-box;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 1.2;
    text-align: center;
    white-space: nowrap;
    margin: 1px 0 0;
  }
  .fno-bracket-label--page {
    color: #1d4ed8;
  }
  .fno-bracket-label--probe {
    color: var(--sl-color-gray-2);
  }

  .fno-bracket-sub {
    box-sizing: border-box;
    font-size: 9.5px;
    font-weight: 600;
    line-height: 1.25;
    text-align: center;
    color: var(--sl-color-gray-3);
    margin: 0;
  }
  /* the probe's caption-strip can be longer than its single column — let it
     spill symmetrically without forcing the column wider. */
  .fno-bracket-sub--probe {
    white-space: nowrap;
    overflow: visible;
  }

  /* On narrow figure cards, shrink the cells and labels so the single row still
     fits without wrapping; the grid keeps the brackets aligned regardless. The
     probe caption-strip can't stay on one line in a ~46px column, so let it wrap
     within a fixed box centred on its column instead of overflowing the card. */
  @media (max-width: 480px) {
    .fno-strip,
    .fno-brackets {
      gap: 5px;
      column-gap: 5px;
    }
    .fno-cell {
      height: 38px;
    }
    .fno-id {
      font-size: 10.5px;
    }
    .fno-bracket-label {
      font-size: 10px;
    }
    .fno-bracket-sub {
      font-size: 8.5px;
    }
    .fno-bracket-sub--probe {
      white-space: normal;
      width: 76px;
      /* the probe is the last (right-edge) column; a centred wrap box would spill
         into the card's right padding, so nudge it left into the available space.
         The line + label stay centred under the cell; only the strip shifts. */
      transform: translateX(-14px);
    }
  }
</style>
