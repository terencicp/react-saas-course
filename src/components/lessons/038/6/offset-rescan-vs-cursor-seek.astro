---
// offset-rescan-vs-cursor-seek — Chapter 038 Lesson 6 ("Cursor pagination"),
// the PERFORMANCE half of "where offset breaks". One-glance contrast of the two
// access patterns over the SAME ordered list, on a SHARED left-to-right scale:
//
//   TOP "Offset" — a strip of 14 row-cells. The leading 10 are tinted RED and
//     struck through (a diagonal line + reduced opacity) under a bracket reading
//     "scanned, then discarded"; a faint dotted "walk" rule threads through them
//     left→right to reinforce that every one was visited in order. The next 3
//     cells are the BLUE page window, labelled "the page you wanted". Story: to
//     reach the blue window, every red cell was built and thrown away.
//
//   BOTTOM "Cursor" — the SAME 14 cells in the SAME positions, but the leading
//     10 are plain neutral slate (simply not visited — NOT struck). A single bold
//     GREEN arrow arcs OVER those leading cells (an inline SVG path, curving
//     above the strip rather than threading through it) and lands on the start of
//     the identical 3-cell window, labelled "seek straight to the boundary". No
//     discarded cells.
//
// Colour convention (pinned to the chapter-037/038 family, light-pinned so the
// hand-picked tints survive dark mode):
//   RED   = the cost being avoided (the offset scan-and-discard),
//   BLUE  = the thing itself / neutral anchor (the page window, identical in both
//           rows so the eye reads the shared scale),
//   GREEN = the win (the cursor's single seek),
//   neutral slate = inert (the cursor row's un-visited leading cells, chrome).
//
// Pure HTML + CSS + one inline SVG arc. A `not-content` wrapper plus a `margin: 0`
// reset on every rule defeat Starlight's prose-margin selector (which otherwise
// shoves the lower strip down and shrinks it). Short, wide, height-capped well
// under the ceiling. No leader lines, so the figure stays expandable.

import Figure from "../../../figures/Figure.astro";

// 14 cells; the page window is the 3 cells at indices 10,11,12 (0-based). The
// 14th cell (index 13) trails after the window so the strip doesn't end exactly
// on the window edge — it reads as "…and the list continues".
const TOTAL = 14;
const WINDOW_START = 10; // first cell of the page window
const WINDOW_LEN = 3; // the page you actually wanted

const cells = Array.from({ length: TOTAL }, (_, i) => {
  const inWindow = i >= WINDOW_START && i < WINDOW_START + WINDOW_LEN;
  const beforeWindow = i < WINDOW_START;
  return { i, inWindow, beforeWindow };
});
---

<Figure
  caption="Offset walks and discards every row before the page; a cursor seeks straight to the boundary. The deeper the page sits, the more offset builds and throws away — the cursor's cost stays flat."
>
  <div class="oc not-content">
    {/* ============ TOP · OFFSET — scan and discard ============ */}
    <div class="oc-track">
      <div class="oc-side">
        <span class="oc-tag oc-tag--cost">Offset</span>
      </div>

      <div class="oc-strip-wrap">
        <div class="oc-strip" role="img" aria-label="Offset re-scans every row before the page">
          {/* the dotted 'walk' rule that threads through the discarded cells */}
          <span class="oc-walk" aria-hidden="true"></span>
          {cells.map((c) => (
            <span
              class={`oc-cell ${
                c.inWindow
                  ? "oc-cell--window"
                  : c.beforeWindow
                    ? "oc-cell--discard"
                    : "oc-cell--trail"
              }`}
            ></span>
          ))}
        </div>

        {/* brackets under the offset strip */}
        <div class="oc-brackets">
          <div
            class="oc-bracket oc-bracket--cost"
            style={`--from: 0; --span: ${WINDOW_START}`}
          >
            <span class="oc-bracket-line"></span>
            <span class="oc-bracket-label oc-bracket-label--cost">scanned, then discarded</span>
          </div>
          <div
            class="oc-bracket oc-bracket--page"
            style={`--from: ${WINDOW_START}; --span: ${WINDOW_LEN}`}
          >
            <span class="oc-bracket-line oc-bracket-line--page"></span>
            <span class="oc-bracket-label oc-bracket-label--page">the page you wanted</span>
          </div>
        </div>
      </div>
    </div>

    {/* ============ BOTTOM · CURSOR — seek to the boundary ============ */}
    <div class="oc-track oc-track--cursor">
      <div class="oc-side">
        <span class="oc-tag oc-tag--win">Cursor</span>
      </div>

      <div class="oc-strip-wrap">
        <div class="oc-strip" role="img" aria-label="A cursor seeks straight to the page boundary">
          {/* the seek arc: an SVG curving OVER the un-visited leading cells.
              viewBox is 100 wide × 64 tall and stretched with
              preserveAspectRatio="none", so x maps linearly across the strip
              (x≈72 = the window's left edge) while y runs 0 (above the cells)
              to 64. The cells occupy roughly y 30..64; the arc apexes near y 6,
              well clear of them, and lands on the window's top-left corner. */}
          <svg
            class="oc-seek"
            viewBox="0 0 100 64"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <defs>
              <marker
                id="oc-seek-head"
                viewBox="0 0 10 10"
                refX="8"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
              >
                <path d="M0,0 L10,5 L0,10 z" fill="#16a34a"></path>
              </marker>
            </defs>
            {/* far-left start near the cell mid-line → high apex → down onto the
                window's top-left corner. */}
            <path
              d="M2,47 C18,9 56,9 72,31"
              fill="none"
              stroke="#16a34a"
              stroke-width="3"
              stroke-linecap="round"
              vector-effect="non-scaling-stroke"
              marker-end="url(#oc-seek-head)"
            ></path>
          </svg>

          {cells.map((c) => (
            <span
              class={`oc-cell ${
                c.inWindow
                  ? "oc-cell--window"
                  : c.beforeWindow
                    ? "oc-cell--skip"
                    : "oc-cell--trail"
              }`}
            ></span>
          ))}
        </div>

        {/* one label under the cursor strip, anchored at the start of the strip */}
        <div class="oc-brackets">
          <div class="oc-seek-label">
            <span class="oc-seek-label-text">seek straight to the boundary</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Figure>

<style>
  /* The whole figure: two stacked tracks, each [left tag | strip]. Both strips
     are the same CSS grid so their cells line up column-for-column across rows
     — that shared scale is the entire point. Height-capped; short and wide. */
  .oc {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 30px;
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
    padding: 4px 2px;
    color-scheme: light;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* one track = the left tag column + the strip-and-labels column. */
  .oc-track {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 64px 1fr;
    align-items: start;
    column-gap: 12px;
    margin: 0;
  }

  .oc-side {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    /* line the tag up with the vertical centre of the cell strip (cells are
       34px tall here), independent of the labels below. */
    height: 34px;
    margin: 0;
  }

  /* the small muted heading on the left of each row. */
  .oc-tag {
    box-sizing: border-box;
    display: inline-block;
    padding: 3px 9px;
    border-radius: 7px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.2;
    white-space: nowrap;
    margin: 0;
  }
  .oc-tag--cost {
    color: #b91c1c;
    background: #fef2f2;
    border: 1px solid color-mix(in srgb, #dc2626 45%, transparent);
  }
  .oc-tag--win {
    color: #15803d;
    background: #f0fdf4;
    border: 1px solid color-mix(in srgb, #16a34a 45%, transparent);
  }

  .oc-strip-wrap {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 7px;
    min-width: 0;
    margin: 0;
  }

  /* The strip: 14 equal columns. Both rows declare the identical grid so the
     window cells sit at the exact same x in each row. `position: relative` is
     the containing block for the walk rule (top) and the seek arc (bottom). */
  .oc-strip {
    position: relative;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: repeat(14, 1fr);
    gap: 4px;
    width: 100%;
    margin: 0;
  }

  /* a single row-cell. The aspect-ratio keeps them tidy little tiles while the
     grid does the horizontal scaling. */
  .oc-cell {
    box-sizing: border-box;
    height: 34px;
    border-radius: 5px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    margin: 0;
  }

  /* OFFSET leading cells — scanned then discarded: red tint, diagonal strike,
     dimmed. The repeating-linear-gradient is the strike-through line. */
  .oc-cell--discard {
    border-color: color-mix(in srgb, #dc2626 35%, var(--sl-color-gray-4));
    background:
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 5px,
        color-mix(in srgb, #dc2626 55%, transparent) 5px,
        color-mix(in srgb, #dc2626 55%, transparent) 6.2px
      ),
      color-mix(in srgb, #dc2626 13%, var(--sl-color-bg));
    opacity: 0.85;
  }

  /* CURSOR leading cells — simply not visited: plain neutral, no strike. */
  .oc-cell--skip {
    border-color: var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
  }

  /* the page window — identical BLUE accent in BOTH rows (the shared anchor). */
  .oc-cell--window {
    border-color: #2563eb;
    background: #2563eb;
    box-shadow: 0 0 0 1px color-mix(in srgb, #2563eb 35%, transparent);
  }

  /* the single trailing cell after the window — the list continues. */
  .oc-cell--trail {
    border-color: var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    opacity: 0.6;
  }

  /* the dotted 'walk' rule threading through the offset discard zone. It spans
     from the strip's left edge to the right edge of the last discarded cell.
     Width = (10 cols + 9 gaps-worth) of the 14-col + 13-gap track. We size it in
     % of the strip: the discard zone is the first 10 of 14 columns plus the 9
     internal gaps; approximated with a calc that lands at the window's left edge. */
  .oc-walk {
    position: absolute;
    top: 50%;
    left: 0;
    /* right edge = left edge of the 11th column (the window start) minus a hair.
       Each column-unit + its trailing gap repeats across the track; 10/14 of the
       cell width plus 10/14 of the gaps is a close, robust approximation. */
    width: calc((100% - 13 * 4px) * 10 / 14 + 9.5 * 4px);
    height: 0;
    border-top: 2px dotted color-mix(in srgb, #dc2626 70%, transparent);
    transform: translateY(-50%);
    margin: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* the seek arc SVG — overlays the cursor strip, arcing above the leading cells.
     30px of headroom above the 34px strip makes a 64px-tall box, matching the
     viewBox's 64 units 1:1 vertically so the apex clears the cells cleanly. */
  .oc-seek {
    position: absolute;
    top: -30px;
    left: 0;
    width: 100%;
    height: calc(100% + 30px);
    overflow: visible;
    pointer-events: none;
    z-index: 2;
  }

  /* ---- the brackets under the offset strip --------------------------- */

  /* the bracket row is the same 14-col grid, so a bracket can occupy exactly the
     columns its zone covers via grid-column. */
  .oc-brackets {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: repeat(14, 1fr);
    column-gap: 4px;
    width: 100%;
    margin: 0;
  }

  /* a bracket spans `--span` columns starting at column `--from` (1-based grid
     line = --from + 1). */
  .oc-bracket {
    box-sizing: border-box;
    grid-column: calc(var(--from) + 1) / span var(--span);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    min-width: 0;
    margin: 0;
  }

  /* the horizontal bracket line with little down-ticks at each end. */
  .oc-bracket-line {
    box-sizing: border-box;
    width: 100%;
    height: 6px;
    border: 1.5px solid color-mix(in srgb, #dc2626 60%, transparent);
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    margin: 0;
  }
  .oc-bracket-line--page {
    border-color: #2563eb;
  }

  .oc-bracket-label {
    box-sizing: border-box;
    font-size: 10.5px;
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    white-space: nowrap;
    margin: 0;
  }
  .oc-bracket-label--cost {
    color: #b91c1c;
  }
  .oc-bracket-label--page {
    color: #1d4ed8;
  }

  /* ---- the seek label under the cursor strip ------------------------- */

  .oc-seek-label {
    box-sizing: border-box;
    /* sit under the leading (un-visited) zone, where the arc travels. */
    grid-column: 1 / span 9;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
  }
  .oc-seek-label-text {
    box-sizing: border-box;
    font-size: 10.5px;
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    white-space: nowrap;
    color: #15803d;
    margin: 0;
  }

  /* On very narrow figure cards, drop the cells a touch and let labels breathe
     without overlapping; the grid scale keeps the rows aligned regardless. */
  @media (max-width: 480px) {
    .oc-track {
      grid-template-columns: 52px 1fr;
      column-gap: 8px;
    }
    .oc-cell {
      height: 28px;
    }
    .oc-side {
      height: 28px;
    }
    .oc-bracket-label,
    .oc-seek-label-text {
      font-size: 9.5px;
    }
  }
</style>
