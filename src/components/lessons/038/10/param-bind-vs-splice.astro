---
// param-bind-vs-splice (diagram id: param-bind-vs-splice, Chapter 038 Lesson 10
// — "The raw SQL escape hatch"). The lesson's one diagram, and it carries the
// single highest-stakes concept: a bound parameter travels BESIDE the query,
// never INSIDE it. The same fragment — sql`… where email = ${input}` — is traced
// down two tracks, and the contrast that IS the lesson is purely spatial:
//   TOP (the `sql` tag, parameterized): the source splits into TWO boxes — a SQL
//     string holding `… where email = $1` (a placeholder, NOT the value) and a
//     separate params box holding `[ input ]`. Both feed the driver. The value
//     sits OUTSIDE the executable string.
//   BOTTOM (`sql.raw` / plain literal, spliced): the source splices into ONE box,
//     and a malicious value lands INSIDE the executable SQL — the injected
//     `'; drop table invoices; --` is rendered in danger-red, sitting in the very
//     string the driver runs.
// Where `input` ends up — its own box vs. inside the string — is the whole point.
//
// Layout (plain HTML+CSS per diagrams/INDEX.md "annotated illustration"): two
// stacked horizontal tracks. Each track repeats the identical source pill on the
// left (same fragment, two fates) so each row reads as a clean self-contained
// flow — no fragile cross-track connectors. House style follows the chapter-038
// family (fts-lexeme-flow, AggregateHelpers): a `.not-content` wrapper + a
// <style> block (`.not-content` strips Starlight's injected prose margin-top, the
// load-bearing HTML+CSS gotcha), sl-color theme tokens for chrome, monospace
// spans for code (no <code> pill so cells stay aligned), and saturated mid-tone
// fills with white text where the colour is the signal — green for the safe
// track tint, red-600 for the danger track + the injected fragment, and one
// accent (indigo) for the bound-value chip so the eye follows `input` from the
// source to wherever it lands. Short, wide, height-capped well under the 800px
// ceiling. No leader lines, so the Figure stays expandable.

import Figure from '../../../figures/Figure.astro';

// The accent for the interpolated value `${input}` — the thing the eye tracks
// from the source pill to its destination. Indigo-600 reads on both white and
// near-black page backgrounds and is distinct from the green/red track tints.
const VALUE_FILL = '#4f46e5'; // indigo-600
// The safe path — the value is bound beside the query.
const OK_FILL = '#16a34a'; // green-600
// The danger path — the value is spliced into the executable string.
const BAD_FILL = '#dc2626'; // red-600

// The shared fragment, shown in each source pill. The `${…}` and the value chip
// are separated so the chip can carry the accent fill in both tracks.
const SRC_PREFIX = 'sql`… where email = ';
const SRC_SUFFIX = '`';
---

<Figure
	caption="Parameterized values ride alongside the query as `$1`; raw concatenation puts the value — and anything it spells — into the executable SQL."
>
	<div class="pbs not-content">
		{/* ============ TOP — the `sql` tag: parameterized (safe) ============ */}
		<div
			class="pbs-track pbs-track--ok"
			role="img"
			aria-label="With the sql tag, the fragment becomes a SQL string holding the placeholder dollar-one plus a separate params array holding the value; both are sent to the driver, so the value never enters the executable string."
		>
			<div class="pbs-track-head">
				<span class="pbs-track-title">The <span class="pbs-mono">sql</span> tag</span>
				<span class="pbs-track-tag pbs-track-tag--ok">parameterized</span>
			</div>

			<div class="pbs-flow">
				{/* source */}
				<div class="pbs-source">
					<span class="pbs-src-code"
						>{SRC_PREFIX}<span class="pbs-value pbs-value--accent">{'${input}'}</span>{
							SRC_SUFFIX
						}</span
					>
				</div>

				<span class="pbs-arrow" aria-hidden="true">&rarr;</span>

				{/* split into two outputs: SQL string + params */}
				<div class="pbs-split">
					<div class="pbs-box pbs-box--neutral">
						<span class="pbs-box-label">SQL string</span>
						<span class="pbs-box-code"
							>&hellip; where email = <span class="pbs-ph">$1</span></span
						>
					</div>
					<div class="pbs-box pbs-box--params">
						<span class="pbs-box-label">params</span>
						<span class="pbs-box-code"
							>[ <span class="pbs-value pbs-value--accent">input</span> ]</span
						>
					</div>
				</div>

				<span class="pbs-arrows-join" aria-hidden="true">
					<span class="pbs-arrow">&rarr;</span>
					<span class="pbs-arrow">&rarr;</span>
				</span>

				{/* driver */}
				<div class="pbs-driver">driver</div>
			</div>

			<p class="pbs-micro">
				The value is bound <strong>beside</strong> the query &mdash; it never enters
				the executable string.
			</p>
		</div>

		{/* ====== BOTTOM — sql.raw / plain literal: spliced (danger) ====== */}
		<div
			class="pbs-track pbs-track--bad"
			role="img"
			aria-label="With sql.raw or a plain template literal, the value is spliced straight into one SQL string; a malicious value like quote semicolon drop table invoices dash dash lands inside the executable SQL the driver runs."
		>
			<div class="pbs-track-head">
				<span class="pbs-track-title"
					><span class="pbs-mono">sql.raw</span> / plain literal</span
				>
				<span class="pbs-track-tag pbs-track-tag--bad">spliced</span>
			</div>

			<div class="pbs-flow">
				{/* source */}
				<div class="pbs-source">
					<span class="pbs-src-code"
						>{SRC_PREFIX}<span class="pbs-value pbs-value--accent">{'${input}'}</span>{
							SRC_SUFFIX
						}</span
					>
				</div>

				<span class="pbs-arrow" aria-hidden="true">&rarr;</span>

				{/* splice: one SQL string with the injected text landing inside it */}
				<div class="pbs-split pbs-split--single">
					<div class="pbs-box pbs-box--danger">
						<span class="pbs-box-label">SQL string</span>
						<span class="pbs-box-code"
							>&hellip; where email = <span class="pbs-inject"
								>&#39;&#39;; drop table invoices; --&#39;</span
							></span
						>
					</div>
				</div>

				<span class="pbs-arrows-join pbs-arrows-join--single" aria-hidden="true">
					<span class="pbs-arrow">&rarr;</span>
				</span>

				{/* driver */}
				<div class="pbs-driver">driver</div>
			</div>

			<p class="pbs-micro">
				The value is spliced <strong>into</strong> the string &mdash; the driver
				executes whatever it spells.
			</p>
		</div>
	</div>
</Figure>

<style define:vars={{ VALUE_FILL, OK_FILL, BAD_FILL }}>
	.pbs {
		display: flex;
		flex-direction: column;
		gap: 16px;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	/* Each track is a tinted panel: the tint (green vs red) is the at-a-glance
	   safe/danger signal before any word is read. */
	.pbs-track {
		display: flex;
		flex-direction: column;
		gap: 10px;
		box-sizing: border-box;
		padding: 12px 14px;
		border-radius: 12px;
		margin: 0;
	}

	.pbs-track--ok {
		background: color-mix(in srgb, var(--OK_FILL) 7%, var(--sl-color-bg));
		border: 1px solid color-mix(in srgb, var(--OK_FILL) 28%, var(--sl-color-hairline));
	}

	.pbs-track--bad {
		background: color-mix(in srgb, var(--BAD_FILL) 7%, var(--sl-color-bg));
		border: 1px solid color-mix(in srgb, var(--BAD_FILL) 28%, var(--sl-color-hairline));
	}

	/* Track header: the name of the path + a coloured verdict pill. */
	.pbs-track-head {
		display: flex;
		align-items: center;
		gap: 9px;
		margin: 0;
	}

	.pbs-track-title {
		font-size: 13px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-text);
		margin: 0;
	}

	.pbs-track-tag {
		display: inline-flex;
		align-items: center;
		box-sizing: border-box;
		padding: 2px 9px;
		border-radius: 999px;
		font-size: 10.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: #ffffff;
		line-height: 1.4;
		margin: 0;
	}

	.pbs-track-tag--ok {
		background: var(--OK_FILL);
	}

	.pbs-track-tag--bad {
		background: var(--BAD_FILL);
	}

	/* The horizontal flow: source -> arrow -> outputs -> arrows -> driver. */
	.pbs-flow {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		margin: 0;
	}

	/* The source pill — identical in both tracks: same fragment, two fates. */
	.pbs-source {
		display: flex;
		align-items: center;
		box-sizing: border-box;
		flex: 0 1 auto;
		padding: 9px 11px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg);
		margin: 0;
	}

	.pbs-src-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12.5px;
		line-height: 1.3;
		color: var(--sl-color-text);
		white-space: nowrap;
		margin: 0;
	}

	/* The interpolated value — the thing the eye tracks. Same accent fill in the
	   source pill and in the params box, so `input` is visually the same token in
	   both places. */
	.pbs-value--accent {
		display: inline-block;
		box-sizing: border-box;
		padding: 0 5px;
		border-radius: 5px;
		background: var(--VALUE_FILL);
		color: #ffffff;
		font-weight: 700;
		margin: 0;
	}

	/* The output column: two boxes side by side (top track) or one (bottom). */
	.pbs-split {
		display: flex;
		align-items: stretch;
		gap: 8px;
		margin: 0;
	}

	.pbs-split--single {
		/* a single box, but keep the same vertical rhythm as the two-box split */
	}

	.pbs-box {
		display: flex;
		flex-direction: column;
		gap: 5px;
		box-sizing: border-box;
		padding: 8px 11px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg);
		margin: 0;
	}

	.pbs-box--params {
		/* faint accent so the params box reads as "where the value went" */
		background: color-mix(in srgb, var(--VALUE_FILL) 8%, var(--sl-color-bg));
		border-color: color-mix(in srgb, var(--VALUE_FILL) 32%, var(--sl-color-hairline));
	}

	.pbs-box--danger {
		background: color-mix(in srgb, var(--BAD_FILL) 9%, var(--sl-color-bg));
		border-color: color-mix(in srgb, var(--BAD_FILL) 40%, var(--sl-color-hairline));
	}

	.pbs-box-label {
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3);
		line-height: 1.2;
		margin: 0;
	}

	.pbs-box-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12.5px;
		line-height: 1.35;
		color: var(--sl-color-text);
		white-space: nowrap;
		margin: 0;
	}

	/* `$1` — a placeholder, NOT the value. A small bordered chip so it reads as a
	   slot the value will later fill. */
	.pbs-ph {
		display: inline-block;
		box-sizing: border-box;
		padding: 0 5px;
		border-radius: 5px;
		border: 1px dashed color-mix(in srgb, var(--sl-color-text) 45%, transparent);
		color: var(--sl-color-text);
		font-weight: 700;
		margin: 0;
	}

	/* The injected fragment — rendered in danger-red so it reads as sitting INSIDE
	   the executable SQL. This is the whole danger picture. */
	.pbs-inject {
		display: inline-block;
		box-sizing: border-box;
		padding: 0 5px;
		border-radius: 5px;
		background: var(--BAD_FILL);
		color: #ffffff;
		font-weight: 700;
		margin: 0;
	}

	.pbs-arrow {
		flex: none;
		font-size: 17px;
		line-height: 1;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* The two arrows from the split boxes into the driver, stacked so each box
	   gets its own line. A single arrow on the danger track. */
	.pbs-arrows-join {
		display: flex;
		flex-direction: column;
		justify-content: space-around;
		align-self: stretch;
		gap: 4px;
		flex: none;
		margin: 0;
	}

	.pbs-driver {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		box-sizing: border-box;
		flex: 0 0 auto;
		padding: 12px 16px;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-text);
		font-size: 13px;
		font-weight: 700;
		line-height: 1.2;
		margin: 0;
	}

	.pbs-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.92em;
		font-weight: 700;
		margin: 0;
	}

	.pbs-micro {
		font-size: 11px;
		line-height: 1.35;
		font-style: italic;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	.pbs-micro strong {
		font-style: normal;
		font-weight: 700;
		color: var(--sl-color-text);
	}

	/* Narrow viewports: let the flow wrap (it already does), shrink the source so
	   it doesn't force a horizontal overflow, and stack the split boxes. */
	@media (max-width: 640px) {
		.pbs-src-code,
		.pbs-box-code {
			white-space: normal;
		}

		.pbs-split {
			flex-direction: column;
		}

		.pbs-arrows-join {
			flex-direction: row;
		}
	}
</style>
