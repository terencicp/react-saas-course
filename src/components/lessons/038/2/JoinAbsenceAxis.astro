---
// join-absence-axis (diagram id: join-absence-axis, Chapter 038 Lesson 2 —
// "Joining tables"). The lesson's anchor visual: the four join shapes laid out
// against ONE shared example, so the student maps shape -> absence behavior at a
// glance. NOT a Venn diagram. The whole point is to make "what happens to the
// row with no match" visible per shape.
//
// The shared example (also narrated in the prose just above the figure):
//   invoices (left)   A -> org X,  B -> org X,  C -> no org (null FK)
//   organizations (right)  X (matched by A,B),  Y (matched by nobody)
// So C is the unmatched LEFT row and Y is the unmatched RIGHT row. Every panel
// answers the same two questions: what happens to C, and what happens to Y?
//
// Layout (plain HTML+CSS per diagrams/INDEX.md "annotated illustration"):
//   - A top "source tables" strip: two small chip-stacks side by side
//     (invoices | organizations) plus a tiny legend.
//   - Below it, four result panels in a wrapping flex row. Each panel is a mini
//     two-column result table (invoice cell | org cell) showing exactly which
//     combined rows that shape returns, with a muted/hatched swatch wherever a
//     null lands, and a one-line micro-note.
//
// Emphasis (per the lesson's "weight by frequency" thesis): innerJoin and
// leftJoin render at full saturation; rightJoin and fullJoin are de-emphasized
// (lower opacity + grey chrome) to signal "recognition only".
//
// House style follows ch 036/037 HTML+CSS figures: inline style strings joined
// with '; ', `margin: 0` resets on every element to defeat Starlight's injected
// prose margin-top, box-sizing: border-box, Starlight theme vars for chrome, and
// saturated 600-range fills with white text where the colour is the signal
// (html-css.md theme-adaptation). No leader lines -> Figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const mono =
	'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Two distinct saturated hues so the two sides of every combined row read apart
// at a glance: invoices = blue (the left table, the table you start from),
// organizations = teal (the right table joined in).
const INVOICE_FILL = '#2563eb'; // blue-600
const ORG_FILL = '#0d9488'; // teal-600

// A muted, hatched swatch standing in for `null` (no match). Repeating-gradient
// hatch + a muted gray reads as "absent" without competing with the saturated
// matched cells. Theme-aware via Starlight gray vars.
const nullCell = [
	'background-image: repeating-linear-gradient(45deg, var(--sl-color-gray-5) 0, var(--sl-color-gray-5) 4px, transparent 4px, transparent 8px)',
	'background-color: var(--sl-color-gray-6)',
	'color: var(--sl-color-gray-2)',
	'border: 1px dashed var(--sl-color-gray-4)',
].join('; ');

// ----- Source-strip chips -----------------------------------------------------

const chipBase = [
	'margin: 0',
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 0.6rem',
	'padding: 0.3rem 0.55rem',
	'border-radius: 6px',
	'font-size: 0.8125rem',
	'line-height: 1.2',
	'border: 1px solid var(--sl-color-hairline)',
	'background: var(--sl-color-bg)',
];

// A small saturated badge for a matched id/value (white text on the side's hue).
const badge = (fill: string) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'display: inline-block',
		'padding: 0.05rem 0.45rem',
		'border-radius: 4px',
		'font-weight: 700',
		'font-size: 0.8125rem',
		'color: #ffffff',
		`background: ${fill}`,
		mono,
	].join('; ');

// The muted "null" pill used inline inside a source chip (C's org value).
const nullPill = [
	'margin: 0',
	'box-sizing: border-box',
	'display: inline-block',
	'padding: 0.05rem 0.5rem',
	'border-radius: 4px',
	'font-weight: 600',
	'font-size: 0.75rem',
	nullCell,
	mono,
].join('; ');

const fieldLabel = [
	'margin: 0',
	mono,
	'font-size: 0.6875rem',
	'color: var(--sl-color-gray-3)',
].join('; ');

const tableTitle = [
	'margin: 0 0 0.4rem',
	mono,
	'font-size: 0.8125rem',
	'font-weight: 600',
	'color: var(--sl-color-white)',
].join('; ');

const tableCard = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.6rem',
	'border-radius: 8px',
	'background: var(--sl-color-gray-7)',
	'border: 1px solid var(--sl-color-hairline)',
	'min-width: 9.5rem',
].join('; ');

// ----- Result panels ----------------------------------------------------------

// A single combined result row: { invoice, org } where either may be null.
// `inv`/`org` hold the matched label (e.g. 'A', 'X') or null for the gap cell.
type ResultRow = { inv: string | null; org: string | null };

type Panel = {
	title: string;
	rows: ResultRow[];
	note: string;
	// `true` -> the daily-driver shapes, rendered at full saturation.
	// `false` -> rightJoin/fullJoin, de-emphasised to "recognition only".
	primary: boolean;
};

const panels: Panel[] = [
	{
		title: 'innerJoin',
		rows: [
			{ inv: 'A', org: 'X' },
			{ inv: 'B', org: 'X' },
		],
		note: 'C and Y dropped',
		primary: true,
	},
	{
		title: 'leftJoin',
		rows: [
			{ inv: 'A', org: 'X' },
			{ inv: 'B', org: 'X' },
			{ inv: 'C', org: null },
		],
		note: 'C kept, org is null',
		primary: true,
	},
	{
		title: 'rightJoin',
		rows: [
			{ inv: 'A', org: 'X' },
			{ inv: 'B', org: 'X' },
			{ inv: null, org: 'Y' },
		],
		note: 'Y kept, invoice is null',
		primary: false,
	},
	{
		title: 'fullJoin',
		rows: [
			{ inv: 'A', org: 'X' },
			{ inv: 'B', org: 'X' },
			{ inv: 'C', org: null },
			{ inv: null, org: 'Y' },
		],
		note: 'both kept',
		primary: false,
	},
];

// Each result row is two equal cells. A matched cell carries the side's hue and
// white text; a gap cell uses the hatched null swatch and reads "null".
const resultCell = (label: string | null, fill: string) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'flex: 1 1 0',
		'min-width: 0',
		'text-align: center',
		'padding: 0.22rem 0.3rem',
		'border-radius: 5px',
		'font-size: 0.78125rem',
		'font-weight: 600',
		'line-height: 1.25',
		mono,
		label === null
			? nullCell
			: `color: #ffffff; background: ${fill}; border: 1px solid transparent`,
	].join('; ');

const panelCard = (primary: boolean) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'width: 11.5rem',
		'padding: 0.6rem',
		'border-radius: 8px',
		primary
			? 'background: var(--sl-color-gray-7); border: 1px solid var(--sl-color-hairline)'
			: 'background: transparent; border: 1px dashed var(--sl-color-gray-4); opacity: 0.62',
	].join('; ');

const panelTitle = (primary: boolean) =>
	[
		'margin: 0 0 0.45rem',
		mono,
		'font-size: 0.8125rem',
		'font-weight: 700',
		primary ? 'color: var(--sl-color-white)' : 'color: var(--sl-color-gray-3)',
	].join('; ');

const panelHead = [
	'margin: 0 0 0.3rem',
	'box-sizing: border-box',
	'display: flex',
	'gap: 0.35rem',
].join('; ');

const headCell = (fill: string) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'flex: 1 1 0',
		'min-width: 0',
		'text-align: center',
		'font-size: 0.625rem',
		'font-weight: 600',
		mono,
		`color: ${fill}`,
		'letter-spacing: 0.02em',
	].join('; ');

const rowWrap = [
	'margin: 0 0 0.3rem',
	'box-sizing: border-box',
	'display: flex',
	'gap: 0.35rem',
].join('; ');

const noteStyle = (primary: boolean) =>
	[
		'margin: 0.45rem 0 0',
		'font-size: 0.6875rem',
		'font-style: italic',
		'line-height: 1.3',
		primary ? 'color: var(--sl-color-gray-2)' : 'color: var(--sl-color-gray-3)',
	].join('; ');

// ----- Legend -----------------------------------------------------------------

const legendWrap = [
	'margin: 0',
	'box-sizing: border-box',
	'display: flex',
	'flex-direction: column',
	'gap: 0.4rem',
	'justify-content: center',
].join('; ');

const legendRow = [
	'margin: 0',
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'gap: 0.45rem',
	'font-size: 0.6875rem',
	'color: var(--sl-color-gray-2)',
].join('; ');

const legendSwatch = (style: string) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'width: 1.6rem',
		'height: 0.9rem',
		'border-radius: 4px',
		'flex: none',
		style,
	].join('; ');
---

<Figure
	caption="Inner and left are the daily tools; right and full are here so you recognize them. Every shape is one answer to: what happens to the row with no match?"
>
	<div
		style="margin: 0; box-sizing: border-box; display: flex; flex-direction: column; gap: 1.1rem; width: 100%;"
	>
		{/* ---- Source tables strip ---- */}
		<div
			style="margin: 0; box-sizing: border-box; display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; column-gap: 1rem; row-gap: 0.8rem;"
		>
			{/* invoices (left table) */}
			<div style={tableCard}>
				<div style={tableTitle}>invoices</div>
				<div style="margin: 0; display: flex; flex-direction: column; gap: 0.35rem;">
					{
						[
							{ id: 'A', org: 'X' },
							{ id: 'B', org: 'X' },
							{ id: 'C', org: null },
						].map((r) => (
							<div style={chipBase.join('; ')}>
								<span style={badge(INVOICE_FILL)}>{r.id}</span>
								<span style="margin: 0; display: flex; align-items: center; gap: 0.3rem;">
									<span style={fieldLabel}>org</span>
									{r.org === null ? (
										<span style={nullPill}>null</span>
									) : (
										<span style={badge(ORG_FILL)}>{r.org}</span>
									)}
								</span>
							</div>
						))
					}
				</div>
			</div>

			{/* organizations (right table) */}
			<div style={tableCard}>
				<div style={tableTitle}>organizations</div>
				<div style="margin: 0; display: flex; flex-direction: column; gap: 0.35rem;">
					{
						[
							{ id: 'X', refBy: 'A, B' },
							{ id: 'Y', refBy: null },
						].map((r) => (
							<div style={chipBase.join('; ')}>
								<span style={badge(ORG_FILL)}>{r.id}</span>
								<span style="margin: 0; display: flex; align-items: center; gap: 0.3rem;">
									<span style={fieldLabel}>used&nbsp;by</span>
									{r.refBy === null ? (
										<span style={nullPill}>none</span>
									) : (
										<span style={`${fieldLabel}; color: var(--sl-color-text)`}>{r.refBy}</span>
									)}
								</span>
							</div>
						))
					}
				</div>
			</div>

			{/* legend */}
			<div style={legendWrap}>
				<div style={legendRow}>
					<span style={legendSwatch(`background: ${INVOICE_FILL}`)}></span>
					<span style="margin: 0;">matched value</span>
				</div>
				<div style={legendRow}>
					<span style={legendSwatch(nullCell)}></span>
					<span style="margin: 0;">null (no match)</span>
				</div>
			</div>
		</div>

		{/* ---- Four result panels ---- */}
		<div
			style="margin: 0; box-sizing: border-box; display: flex; flex-wrap: wrap; justify-content: center; column-gap: 8px; row-gap: 20px;"
		>
			{
				panels.map((p) => (
					<div style={panelCard(p.primary)}>
						<div style={panelTitle(p.primary)}>{p.title}</div>
						<div style={panelHead}>
							<span style={headCell(p.primary ? INVOICE_FILL : 'var(--sl-color-gray-3)')}>
								invoice
							</span>
							<span style={headCell(p.primary ? ORG_FILL : 'var(--sl-color-gray-3)')}>org</span>
						</div>
						{p.rows.map((r) => (
							<div style={rowWrap}>
								<span style={resultCell(r.inv, INVOICE_FILL)}>{r.inv ?? 'null'}</span>
								<span style={resultCell(r.org, ORG_FILL)}>{r.org ?? 'null'}</span>
							</div>
						))}
						<div style={noteStyle(p.primary)}>{p.note}</div>
					</div>
				))
			}
		</div>
	</div>
</Figure>
