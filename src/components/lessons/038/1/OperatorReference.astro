---
// Diagram: operator-reference (Chapter 038 Lesson 1 — "CRUD and the four chain
// methods"). A scannable two-column reference table mapping each drizzle-orm
// filter helper to the SQL operator it emits, so the student can read the whole
// vocabulary at a glance instead of memorising it.
//
// Shape: a CSS-grid styled table (left = helper call, right = emitted SQL) with
// a thin middle gutter carrying a "→" transform glyph, so the reading is
// "this helper produces this SQL". Colour is NOT load-bearing (a neutral
// reference): one accent tints the helper side only, to separate TS from SQL.
// Style follows the chapter house family (TwoRegistersTable, icon-conventions-
// table): sl-color tokens for chrome, monospace spans for code (no <code>
// pill — keeps cell widths predictable), display: contents rows, margin: 0
// everywhere to defeat Starlight's injected prose margin-top.

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tone for the helper (TS) side — readable in light and dark.
const HELPER_ACCENT = '#0d9488'; // teal-600 — the drizzle-orm helper call

type Row = {
	helper: string; // the drizzle-orm helper call
	sql: string; // the SQL operator/clause it emits
	note?: string; // optional muted qualifier after the SQL (case sensitivity)
};

const rows: Row[] = [
	{ helper: 'eq(col, v)', sql: 'col = v' },
	{ helper: 'ne(col, v)', sql: 'col <> v' },
	{ helper: 'gt / gte / lt / lte', sql: '> / >= / < / <=' },
	{ helper: 'inArray(col, [...])', sql: 'col IN (…)' },
	{ helper: 'notInArray(col, [...])', sql: 'col NOT IN (…)' },
	{ helper: 'isNull(col)', sql: 'col IS NULL' },
	{ helper: 'isNotNull(col)', sql: 'col IS NOT NULL' },
	{ helper: 'between(col, a, b)', sql: 'col BETWEEN a AND b' },
	{ helper: 'like(col, pattern)', sql: 'col LIKE pattern', note: 'case-sensitive' },
	{ helper: 'ilike(col, pattern)', sql: 'col ILIKE pattern', note: 'case-insensitive' },
];
---

<Figure caption="Each filter helper from drizzle-orm maps to one SQL operator — read the call, get the clause.">
	<div class="opref-root not-content">
		{/* Header row */}
		<div class="opref-row opref-header">
			<div class="opref-cell opref-helper opref-head-cell">
				<span class="opref-dot" aria-hidden="true"></span>
				drizzle-orm helper
			</div>
			<div class="opref-gutter" aria-hidden="true"></div>
			<div class="opref-cell opref-sql opref-head-cell">SQL it emits</div>
		</div>

		{/* Data rows */}
		{
			rows.map((r) => (
				<div class="opref-row">
					<div class="opref-cell opref-helper">
						<span class="opref-code">{r.helper}</span>
					</div>
					<div class="opref-gutter" aria-hidden="true">
						→
					</div>
					<div class="opref-cell opref-sql">
						<span class="opref-code">{r.sql}</span>
						{r.note && <span class="opref-note">{r.note}</span>}
					</div>
				</div>
			))
		}
	</div>
</Figure>

<style define:vars={{ HELPER_ACCENT }}>
	.opref-root {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 28px minmax(0, 1fr);
		row-gap: 1px;
		padding: 14px 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	.opref-row {
		display: contents;
	}

	.opref-cell {
		padding: 8px 12px;
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 8px;
		margin: 0;
		min-width: 0;
	}

	.opref-helper {
		background: color-mix(in srgb, var(--HELPER_ACCENT) 8%, transparent);
		border-left: 2px solid color-mix(in srgb, var(--HELPER_ACCENT) 55%, transparent);
		justify-content: flex-end;
		text-align: right;
	}

	.opref-sql {
		background: color-mix(in srgb, currentColor 4%, transparent);
		border-left: 2px solid color-mix(in srgb, currentColor 16%, transparent);
		justify-content: flex-start;
	}

	.opref-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 13px;
		line-height: 1.4;
		color: var(--sl-color-white);
		margin: 0;
		word-break: break-word;
	}

	.opref-note {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11px;
		line-height: 1.4;
		color: var(--sl-color-gray-3);
		margin: 0;
		white-space: nowrap;
	}

	.opref-gutter {
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 14px;
		color: color-mix(in srgb, var(--HELPER_ACCENT) 75%, var(--sl-color-gray-3));
		margin: 0;
		user-select: none;
	}

	/* Header row — small, uppercase, muted labels over each side. */
	.opref-head-cell {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-text);
		padding-top: 6px;
		padding-bottom: 8px;
		gap: 8px;
	}

	.opref-header .opref-helper {
		flex-direction: row;
		align-items: center;
		background: color-mix(in srgb, var(--HELPER_ACCENT) 12%, transparent);
		border-left-color: color-mix(in srgb, var(--HELPER_ACCENT) 70%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.opref-header .opref-sql {
		background: color-mix(in srgb, currentColor 6%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.opref-dot {
		display: inline-block;
		width: 8px;
		height: 8px;
		border-radius: 999px;
		background: var(--HELPER_ACCENT);
		margin: 0;
		flex: none;
	}

	/* On narrow viewports the gutter glyph rotates to point down and each row
	   stacks helper-over-SQL, so it never crushes the two code columns. */
	@media (max-width: 560px) {
		.opref-root {
			grid-template-columns: 1fr;
			row-gap: 0;
		}
		.opref-helper {
			justify-content: flex-start;
			text-align: left;
			padding-top: 10px;
			padding-bottom: 4px;
		}
		.opref-gutter {
			display: none;
		}
		.opref-sql {
			padding-bottom: 10px;
			border-left: 2px solid color-mix(in srgb, currentColor 16%, transparent);
		}
		.opref-header .opref-sql {
			display: none;
		}
	}
</style>
