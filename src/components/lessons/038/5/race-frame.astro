---
// RaceFrame — one frame of the read-then-write race timeline, used inside
// <DiagramSequence> in Ch038 L5 ("Upserts and RETURNING").
//
// The whole figure's job is to make the *interleaving* of two concurrent
// requests visible in TIME. Two horizontal lanes — Request A (top) and
// Request B (bottom) — run across a shared left-to-right time axis (T1..T4).
// Each request does the naive find-or-create: a SELECT (is the membership
// there?) followed by an INSERT. Because both SELECTs land in the window
// before either INSERT, both lanes see "absent" and both decide to insert —
// and B's insert collides with the row A just wrote.
//
// `step` (1..4) advances one lane by one action and dims the other lane's
// prior actions, so the active moment is obvious:
//   1  A reads  → absent (neutral). B waiting.
//   2  B reads  → absent (neutral). Both reads now done; both saw nothing.
//   3  A inserts → ok (green). A real row now exists. B still holds stale absent.
//   4  B inserts → collision (red). Duplicate / unique-violation crash.
//
// Pure HTML + CSS with inline styles so it survives DiagramSequence's stacked
// grid (inactive steps stay in layout via visibility:hidden — no leader lines,
// which are positioned from document.body and break in the stack). Every step
// reserves the same rows (time ruler, two lanes, footnote slot) so the stage
// never reflows as the reader scrubs. `not-content` + margin resets defeat
// Starlight's prose-margin selectors.

interface Props {
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const NEUTRAL = "var(--sl-color-gray-2)"; // a read — no judgement yet
const OK = "#16a34a"; // green-600 — the write that succeeds
const ERR = "#dc2626"; // red-600 — the write that collides

// ---- the actions, placed on the time grid ------------------------------
// Each lane is a 4-column grid (T1..T4). An action sits in one column and is
// revealed at the step matching its time.

type Kind = "read" | "ok" | "err";

interface Action {
  // 1-based time column it occupies (also the step at which it appears)
  at: 1 | 2 | 3 | 4;
  verb: string; // SELECT / INSERT
  table: string; // memberships
  result: string; // absent / row created / collision
  kind: Kind;
}

const laneA: Action[] = [
  { at: 1, verb: "SELECT", table: "memberships", result: "absent", kind: "read" },
  { at: 3, verb: "INSERT", table: "memberships", result: "row created", kind: "ok" },
];

const laneB: Action[] = [
  { at: 2, verb: "SELECT", table: "memberships", result: "absent", kind: "read" },
  { at: 4, verb: "INSERT", table: "memberships", result: "collision", kind: "err" },
];

function kindColor(kind: Kind): string {
  return kind === "ok" ? OK : kind === "err" ? ERR : NEUTRAL;
}

// ---- per-step headline -------------------------------------------------

const headlines: Record<Props["step"], { kicker: string; line: string }> = {
  1: {
    kicker: "Request A reads first",
    line: "No membership exists yet, so the database answers: absent.",
  },
  2: {
    kicker: "Request B reads a heartbeat later",
    line: "Before A has written anything — so it sees absent too. Both reads are done; both saw nothing.",
  },
  3: {
    kicker: "Request A inserts",
    line: "A real membership row now exists in the table. B is still holding its stale absent.",
  },
  4: {
    kicker: "Request B inserts the row it decided was missing",
    line: "It collides with A's. Either a duplicate slips in, or the unique constraint rejects it and the request crashes.",
  },
};

const headline = headlines[step];

// ---- styles ------------------------------------------------------------

const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 14px",
  "width: 100%",
  "max-width: 760px",
  "margin-inline: auto",
].join("; ");

// Headline strip — a kicker + a one-line summary.
const headRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: baseline",
  "gap: 6px 12px",
].join("; ");

const stepNum = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

const kicker = [
  reset,
  sans,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const headLine = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.35",
  "color: var(--sl-color-gray-2)",
  "flex-basis: 100%",
].join("; ");

// The lanes live in a 2-column outer grid: a fixed label gutter + the time
// track. The time ruler shares the same track template so its ticks line up
// with the action columns.
const labelGutter = "108px";
const trackCols = "repeat(4, minmax(0, 1fr))";

const board = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
  "width: 100%",
  "padding: 12px 12px 10px",
  "border-radius: 12px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
].join("; ");

const rowGrid = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  `grid-template-columns: ${labelGutter} ${trackCols}`,
  "align-items: center",
  "gap: 8px",
].join("; ");

// Time ruler row — an arrowed axis label in the gutter, ticks across the track.
const axisLabel = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.08em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
].join("; ");

function tick(t: number): string {
  const isNow = t === step;
  const isPast = t < step;
  const color = isNow
    ? "var(--sl-color-white)"
    : isPast
      ? "var(--sl-color-gray-3)"
      : "var(--sl-color-gray-4)";
  return [
    reset,
    mono,
    "box-sizing: border-box",
    "justify-self: center",
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "min-width: 24px",
    "padding: 1px 7px",
    "font-size: 10px",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "border-radius: 999px",
    `color: ${color}`,
    isNow
      ? "background: color-mix(in srgb, var(--ds-accent, hsl(217,91%,60%)) 22%, transparent); border: 1px solid color-mix(in srgb, var(--ds-accent, hsl(217,91%,60%)) 55%, transparent)"
      : "background: transparent; border: 1px solid transparent",
  ].join("; ");
}

// Lane label — "Request A" / "Request B" with a small colored dot.
function laneLabel(active: boolean, dot: string): string {
  return [
    reset,
    sans,
    "box-sizing: border-box",
    "display: inline-flex",
    "align-items: center",
    "gap: 7px",
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.1",
    active ? "color: var(--sl-color-white)" : "color: var(--sl-color-gray-3)",
    "transition: color 0.14s",
  ].join("; ");
}

function laneDot(color: string, active: boolean): string {
  return [
    reset,
    "box-sizing: border-box",
    "flex: 0 0 auto",
    "width: 9px",
    "height: 9px",
    "border-radius: 50%",
    `background: ${color}`,
    active ? "opacity: 1" : "opacity: 0.5",
  ].join("; ");
}

// An action chip. State across the scrub:
//   future  — its time hasn't arrived: invisible, but occupies its cell so the
//             lane keeps a constant width as the reader moves forward.
//   active  — introduced at exactly this step: full color + ring + slight lift.
//   past    — a prior step introduced it: legible but dimmed (the reads stay
//             readable on purpose — the point is that both saw "absent").
type ChipState = "future" | "active" | "past";

function chipState(at: number): ChipState {
  if (at > step) return "future";
  if (at === step) return "active";
  return "past";
}

function chip(a: Action, state: ChipState): string {
  const c = kindColor(a.kind);
  const base = [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 4px",
    "padding: 7px 9px",
    "border-radius: 9px",
    "transition: opacity 0.16s, transform 0.16s, box-shadow 0.16s",
  ];
  if (state === "future") {
    return [
      ...base,
      "visibility: hidden",
      "border: 1px solid transparent",
      "background: transparent",
    ].join("; ");
  }
  const isActive = state === "active";
  return [
    ...base,
    `border: 1.5px solid color-mix(in srgb, ${c} ${isActive ? 70 : 34}%, var(--sl-color-gray-5))`,
    `background: color-mix(in srgb, ${c} ${isActive ? 16 : 7}%, var(--sl-color-gray-6))`,
    isActive
      ? `box-shadow: 0 0 0 3px color-mix(in srgb, ${c} 18%, transparent); transform: translateY(-1px)`
      : "box-shadow: none",
    isActive ? "opacity: 1" : "opacity: 0.55",
  ].join("; ");
}

const chipQuery = (active: boolean) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "font-size: 11.5px",
    "font-weight: 700",
    "line-height: 1.15",
    "white-space: nowrap",
    active ? "color: var(--sl-color-text)" : "color: var(--sl-color-gray-2)",
  ].join("; ");

const chipTable = [
  reset,
  mono,
  "font-size: 10px",
  "font-weight: 500",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The result pill inside a chip — grey for a read, green for ok, red for crash.
function resultPill(kind: Kind, active: boolean): string {
  const c = kindColor(kind);
  const muted = kind === "read";
  return [
    reset,
    sans,
    "box-sizing: border-box",
    "align-self: flex-start",
    "display: inline-flex",
    "align-items: center",
    "gap: 4px",
    "margin-top: 1px",
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "text-transform: uppercase",
    "line-height: 1.1",
    "padding: 2px 7px",
    "border-radius: 999px",
    muted
      ? `color: ${active ? "var(--sl-color-gray-2)" : "var(--sl-color-gray-3)"}`
      : `color: ${c}`,
    muted
      ? "background: var(--sl-color-gray-5); border: 1px solid var(--sl-color-gray-4)"
      : `background: color-mix(in srgb, ${c} 15%, transparent); border: 1px solid color-mix(in srgb, ${c} 42%, transparent)`,
  ].join("; ");
}

// Glyph that leads the result pill: arrow for a read result, check / cross for
// the writes.
function glyph(kind: Kind): string {
  return kind === "ok" ? "✓" : kind === "err" ? "✕" : "→";
}

// Footnote slot — reserved on every step, populated at step 4 so the stage
// keeps a constant height as the reader scrubs.
const footSlot = [
  reset,
  "box-sizing: border-box",
  "width: 100%",
  "min-height: 20px",
  "display: flex",
  "align-items: center",
].join("; ");

const footNote = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "gap: 8px",
  "font-size: 11.5px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");

const footMark = [
  reset,
  "flex: 0 0 auto",
  "width: 7px",
  "height: 7px",
  "border-radius: 50%",
  `background: ${ERR}`,
].join("; ");

// Map an action list to a 4-cell row keyed by time column.
function cells(actions: Action[]): (Action | null)[] {
  const out: (Action | null)[] = [null, null, null, null];
  for (const a of actions) out[a.at - 1] = a;
  return out;
}

const aCells = cells(laneA);
const bCells = cells(laneB);

// Whether a lane is the one acting *now* (drives the label emphasis).
const aActive = step === 1 || step === 3;
const bActive = step === 2 || step === 4;
---

<div class="not-content rf" style={root}>
  {/* headline strip */}
  <div style={headRow}>
    <span style={stepNum}>STEP {step} / 4</span>
    <span style={kicker}>{headline.kicker}</span>
    <span style={headLine}>{headline.line}</span>
  </div>

  <div style={board}>
    {/* time ruler */}
    <div style={rowGrid}>
      <span style={axisLabel}>
        time
        <svg width="34" height="8" viewBox="0 0 34 8" fill="none" aria-hidden="true">
          <path
            d="M0 4 H30 M26 1 L31 4 L26 7"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </span>
      <span style={tick(1)}>T1</span>
      <span style={tick(2)}>T2</span>
      <span style={tick(3)}>T3</span>
      <span style={tick(4)}>T4</span>
    </div>

    {/* Request A lane */}
    <div style={rowGrid}>
      <span style={laneLabel(aActive, "var(--sl-color-blue, #3b82f6)")}>
        <span style={laneDot("#3b82f6", aActive)}></span>
        Request A
      </span>
      {
        aCells.map((a) => {
          if (!a) return <span></span>;
          const st = chipState(a.at);
          const isActive = st === "active";
          return (
            <div style={chip(a, st)}>
              <span style={chipQuery(isActive)}>
                {a.verb} <span style={chipTable}>{a.table}</span>
              </span>
              <span style={resultPill(a.kind, isActive)}>
                {glyph(a.kind)} {a.result}
              </span>
            </div>
          );
        })
      }
    </div>

    {/* Request B lane */}
    <div style={rowGrid}>
      <span style={laneLabel(bActive, "var(--sl-color-purple, #a855f7)")}>
        <span style={laneDot("#a855f7", bActive)}></span>
        Request B
      </span>
      {
        bCells.map((a) => {
          if (!a) return <span></span>;
          const st = chipState(a.at);
          const isActive = st === "active";
          return (
            <div style={chip(a, st)}>
              <span style={chipQuery(isActive)}>
                {a.verb} <span style={chipTable}>{a.table}</span>
              </span>
              <span style={resultPill(a.kind, isActive)}>
                {glyph(a.kind)} {a.result}
              </span>
            </div>
          );
        })
      }
    </div>
  </div>

  {/* footnote slot — populated at step 4 */}
  <div style={footSlot}>
    {
      step === 4 && (
        <span style={footNote}>
          <span style={footMark} />
          B's decision was made on data that's now stale — A's row already
          exists.
        </span>
      )
    }
  </div>
</div>

<style>
  /* On narrow viewports the four time-columns get crushed; shrink the label
     gutter and tighten gaps so the lanes still read. Laptop viewports — the
     design target — show the full four-column track comfortably. */
  @media (max-width: 560px) {
    .rf [style*="grid-template-columns"] {
      grid-template-columns: 80px repeat(4, minmax(0, 1fr)) !important;
      gap: 5px !important;
    }
  }
</style>
