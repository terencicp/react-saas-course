---
// AggregateHelpers (diagram id: aggregate-helpers, Chapter 038 Lesson 4 —
// "Aggregations and grouping"). A scannable reference catalog of the drizzle-orm
// aggregate helpers: the helper call, the SQL it emits, the TypeScript type it
// returns, and a one-line note. This is reference, not a concept — the student
// reads the whole family in one place, then meets each as the lesson needs it.
//
// Four columns: Helper | SQL | Returns in TS | Note. Helper and SQL render as
// inline monospace; the return type renders monospace too, with the `string |
// null` cells (sum / sumDistinct / avg) made visually LOUD — that string/null
// asymmetry is the lesson's single highest-value watch-out, and the prose right
// after the table promises it earns "bold ink." The `numeric`-precision note is
// likewise bolded.
//
// House style follows the chapter family (OperatorReference, TemporalTypesTable):
// a CSS grid acting as a styled table inside a <Figure>, sl-color theme tokens
// for chrome, monospace spans for code (no <code> pill — keeps cells aligned),
// `display: contents` rows, margin: 0 everywhere to defeat Starlight's injected
// prose margin-top, and a stacked card layout on narrow viewports. Colour is not
// load-bearing; the one accent only flags the string/null return cells.

import Figure from '../../../figures/Figure.astro';

// Warm accent for the string|null return cells — the trap the lesson pays off.
const TRAP_ACCENT = '#d97706'; // amber-600 — readable in light and dark

type Returns =
	| { kind: 'plain'; text: string } // a normal mono return type
	| { kind: 'trap'; text: string }; // string | null — flag it loud

type Row = {
	helper: string; // the drizzle-orm helper call
	sql: string; // the SQL it emits
	returns: Returns; // the inferred TypeScript type
	note?: string; // optional one-line qualifier
	noteBold?: boolean; // render the note in bold (the numeric-precision beat)
};

const rows: Row[] = [
	{
		helper: 'count()',
		sql: 'count(*)',
		returns: { kind: 'plain', text: 'number' },
		note: 'every row',
	},
	{
		helper: 'count(col)',
		sql: 'count(col)',
		returns: { kind: 'plain', text: 'number' },
		note: 'rows where col is non-null',
	},
	{
		helper: 'countDistinct(col)',
		sql: 'count(distinct col)',
		returns: { kind: 'plain', text: 'number' },
		note: 'distinct non-null values',
	},
	{
		helper: 'sum(col)',
		sql: 'sum(col)',
		returns: { kind: 'trap', text: 'string | null' },
		note: 'numeric precision preserved',
		noteBold: true,
	},
	{
		helper: 'sumDistinct(col)',
		sql: 'sum(distinct col)',
		returns: { kind: 'trap', text: 'string | null' },
	},
	{
		helper: 'avg(col)',
		sql: 'avg(col)',
		returns: { kind: 'trap', text: 'string | null' },
	},
	{
		helper: 'min(col) / max(col)',
		sql: 'min / max',
		returns: { kind: 'plain', text: "the column's own type" },
		note: 'preserves type',
	},
];
---

<Figure caption="The drizzle-orm aggregate helpers, all imported from drizzle-orm. The amber return cells hand you a string and a null over an empty set — the trap the lesson pays off.">
	<div class="agg-root not-content">
		{/* Header row */}
		<div class="agg-row agg-header">
			<div class="agg-cell agg-head-cell">Helper</div>
			<div class="agg-cell agg-head-cell">SQL</div>
			<div class="agg-cell agg-head-cell">Returns in TS</div>
			<div class="agg-cell agg-head-cell">Note</div>
		</div>

		{/* Data rows */}
		{
			rows.map((r) => (
				<div class="agg-row">
					<div class="agg-cell agg-helper" data-label="Helper">
						<span class="agg-code">{r.helper}</span>
					</div>
					<div class="agg-cell agg-sql" data-label="SQL">
						<span class="agg-code agg-code-muted">{r.sql}</span>
					</div>
					<div class="agg-cell agg-returns" data-label="Returns in TS">
						<span class={`agg-code ${r.returns.kind === 'trap' ? 'agg-trap' : ''}`}>
							{r.returns.text}
						</span>
					</div>
					<div class="agg-cell agg-note-cell" data-label="Note">
						{r.note && (
							<span class={`agg-note ${r.noteBold ? 'agg-note-strong' : ''}`}>
								{r.note}
							</span>
						)}
					</div>
				</div>
			))
		}
	</div>
</Figure>

<style define:vars={{ TRAP_ACCENT }}>
	.agg-root {
		display: grid;
		grid-template-columns: max-content max-content max-content minmax(0, 1fr);
		row-gap: 1px;
		column-gap: 0;
		padding: 0;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	.agg-row {
		display: contents;
	}

	.agg-cell {
		padding: 9px 16px;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		align-items: center;
		background: color-mix(in srgb, currentColor 3%, transparent);
	}

	.agg-head-cell {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		padding-top: 8px;
		padding-bottom: 8px;
		background: color-mix(in srgb, currentColor 6%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 16%, transparent);
	}

	.agg-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12.5px;
		line-height: 1.4;
		color: var(--sl-color-white);
		margin: 0;
		white-space: nowrap;
	}

	/* The SQL column is the "produced" side — slightly muted so the helper reads
	   as the key and the SQL as its output. */
	.agg-code-muted {
		color: var(--sl-color-gray-2);
	}

	/* The string|null return cells — the lesson's trap. Loud and bold. */
	.agg-returns .agg-trap {
		color: var(--TRAP_ACCENT);
		font-weight: 700;
	}

	.agg-note {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 12px;
		line-height: 1.4;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* The numeric-precision note — bold, since it is the payoff line. */
	.agg-note-strong {
		font-weight: 700;
		color: var(--sl-color-text);
	}

	/* Narrow viewport: collapse to a stacked card layout, one row per helper. */
	@media (max-width: 640px) {
		.agg-root {
			grid-template-columns: 1fr;
			row-gap: 12px;
		}

		.agg-row.agg-header {
			display: none;
		}

		.agg-row {
			display: block;
			padding: 10px 12px;
			border-radius: 8px;
			background: color-mix(in srgb, currentColor 4%, transparent);
			margin: 0;
		}

		.agg-cell {
			background: transparent;
			padding: 3px 0;
			gap: 6px;
			align-items: baseline;
		}

		.agg-cell[data-label]::before {
			content: attr(data-label) ' — ';
			font-size: 10.5px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--sl-color-gray-3);
			flex-shrink: 0;
		}

		/* Drop the empty Note cell on cards so it doesn't print a bare label. */
		.agg-note-cell:not(:has(.agg-note)) {
			display: none;
		}

		.agg-code {
			white-space: normal;
			word-break: break-word;
		}
	}
</style>
