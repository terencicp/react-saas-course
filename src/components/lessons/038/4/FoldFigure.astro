---
// fold-figure (diagram id: fold-figure, Chapter 038 Lesson 4 — "Aggregations and
// grouping"). The lesson's anchor visual, referenced by name across §2–§5. Goal:
// make "aggregate = collapse many rows into one number; groupBy = collapse WITHIN
// buckets" visible BEFORE any API is introduced. The whole lesson then reads as
// labels on a model the student already pictures.
//
// Layout (plain HTML+CSS per diagrams/INDEX.md "annotated illustration"):
//   left column  = a short stack of 6 raw invoice rows, each a status pill + an
//                  amount, tinted by its status.
//   middle       = a wide arrow labelled `groupBy(status)` — the fold itself.
//   right column = 3 collapsed rows, one per distinct status, each carrying the
//                  group key + its `count` and `sum`.
// Horizontal left->right, wraps to a vertical stack on a narrow card, capped well
// under the ~400px height budget from the outline.
//
// Binding signal: STATUS COLOUR. Every left row and the right row it folds into
// share one hue, so the eye performs the grouping without any extra connectors —
// keeps the core picture uncluttered. `where`/`having` are named in the caption
// (they thin the left/right stacks) rather than drawn as gates, to stay simple.
//
// House style follows the ch 038 L2 JoinAbsenceAxis figure: inline style strings
// joined with '; ', `margin: 0` on every element to defeat Starlight's injected
// prose margin-top, box-sizing: border-box, Starlight theme vars for chrome, and
// saturated 600-range fills with white text where the colour is the signal
// (html-css.md theme-adaptation). No leader lines -> Figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const mono =
	'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// One hue per status. draft = neutral grey (theme-aware), sent = blue-600,
// paid = green-600. These carry across both columns as the fold's binding signal.
type StatusKey = 'draft' | 'sent' | 'paid';
const STATUS_FILL: Record<StatusKey, string> = {
	draft: 'var(--sl-color-gray-3)',
	sent: '#2563eb',
	paid: '#16a34a',
};
// Faint per-status tint for the left rows: a translucent wash + a coloured left
// edge, enough to group by eye without competing with the saturated pills.
const STATUS_TINT: Record<StatusKey, string> = {
	draft: 'var(--sl-color-gray-6)',
	sent: 'rgba(37, 99, 235, 0.12)',
	paid: 'rgba(22, 163, 74, 0.12)',
};

// ----- Source rows (left column) ---------------------------------------------

type Row = { status: StatusKey; amount: string };
const rows: Row[] = [
	{ status: 'draft', amount: '$200' },
	{ status: 'draft', amount: '$150' },
	{ status: 'sent', amount: '$900' },
	{ status: 'sent', amount: '$300' },
	{ status: 'sent', amount: '$400' },
	{ status: 'paid', amount: '$1,200' },
];

// ----- Collapsed groups (right column) ---------------------------------------

type Group = { status: StatusKey; count: number; sum: string };
const groups: Group[] = [
	{ status: 'draft', count: 2, sum: '$350' },
	{ status: 'sent', count: 3, sum: '$1,600' },
	{ status: 'paid', count: 1, sum: '$1,200' },
];

// ----- Shared chrome ----------------------------------------------------------

const columnLabel = [
	'margin: 0 0 0.55rem',
	mono,
	'font-size: 0.6875rem',
	'font-weight: 600',
	'letter-spacing: 0.04em',
	'text-transform: uppercase',
	'color: var(--sl-color-gray-3)',
	'text-align: center',
].join('; ');

const stack = [
	'margin: 0',
	'box-sizing: border-box',
	'display: flex',
	'flex-direction: column',
	'gap: 0.35rem',
].join('; ');

// A status pill: full-saturation chip, white text on its hue.
const pill = (status: StatusKey) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'display: inline-block',
		'min-width: 3.1rem',
		'text-align: center',
		'padding: 0.08rem 0.45rem',
		'border-radius: 999px',
		'font-size: 0.75rem',
		'font-weight: 700',
		'line-height: 1.35',
		'color: #ffffff',
		`background: ${STATUS_FILL[status]}`,
		mono,
	].join('; ');

// A left-column raw invoice row: pill + amount, tinted by status.
const sourceRow = (status: StatusKey) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'justify-content: space-between',
		'gap: 0.6rem',
		'padding: 0.3rem 0.5rem',
		'border-radius: 7px',
		`background: ${STATUS_TINT[status]}`,
		`border-left: 3px solid ${STATUS_FILL[status]}`,
		'border-top: 1px solid var(--sl-color-hairline)',
		'border-right: 1px solid var(--sl-color-hairline)',
		'border-bottom: 1px solid var(--sl-color-hairline)',
	].join('; ');

const amount = [
	'margin: 0',
	mono,
	'font-size: 0.8125rem',
	'font-weight: 600',
	'color: var(--sl-color-text)',
].join('; ');

// A right-column collapsed group row: the key pill + count + sum stats.
const groupRow = (status: StatusKey) =>
	[
		'margin: 0',
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'gap: 0.55rem',
		'padding: 0.4rem 0.55rem',
		'border-radius: 8px',
		'background: var(--sl-color-gray-7)',
		`border-left: 3px solid ${STATUS_FILL[status]}`,
		'border-top: 1px solid var(--sl-color-hairline)',
		'border-right: 1px solid var(--sl-color-hairline)',
		'border-bottom: 1px solid var(--sl-color-hairline)',
	].join('; ');

const stat = [
	'margin: 0',
	'box-sizing: border-box',
	'display: flex',
	'flex-direction: column',
	'align-items: flex-start',
	'gap: 0.05rem',
	'line-height: 1.1',
].join('; ');

const statLabel = [
	'margin: 0',
	mono,
	'font-size: 0.625rem',
	'font-weight: 600',
	'color: var(--sl-color-gray-3)',
].join('; ');

const statValue = [
	'margin: 0',
	mono,
	'font-size: 0.8125rem',
	'font-weight: 700',
	'color: var(--sl-color-text)',
].join('; ');

const statDivider = [
	'margin: 0',
	'align-self: stretch',
	'width: 1px',
	'background: var(--sl-color-hairline)',
].join('; ');

// ----- Middle fold arrow ------------------------------------------------------

const arrowWrap = [
	'margin: 0',
	'box-sizing: border-box',
	'display: flex',
	'flex-direction: column',
	'align-items: center',
	'justify-content: center',
	'gap: 0.4rem',
	'flex: 0 0 auto',
].join('; ');

const arrowLabel = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.1rem 0.5rem',
	'border-radius: 6px',
	'background: var(--sl-color-bg)',
	'border: 1px solid var(--sl-color-hairline)',
	mono,
	'font-size: 0.75rem',
	'font-weight: 700',
	'color: var(--sl-color-text-accent)',
	'white-space: nowrap',
].join('; ');

// The arrow shaft + head. A flat horizontal bar with a CSS triangle tip reads as
// "flows right" without an SVG; it rotates to point down once the row wraps via
// the figure being narrow — but we keep it simple and horizontal here.
const arrowShaft = [
	'margin: 0',
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
].join('; ');

const arrowBar = [
	'margin: 0',
	'width: 2.4rem',
	'height: 3px',
	'border-radius: 2px',
	'background: var(--sl-color-gray-3)',
].join('; ');

const arrowHead = [
	'margin: 0',
	'width: 0',
	'height: 0',
	'border-top: 6px solid transparent',
	'border-bottom: 6px solid transparent',
	'border-left: 9px solid var(--sl-color-gray-3)',
].join('; ');

// Each column is a fixed, comfortable width so left and right read as parallel
// stacks; they wrap below one another on a narrow card rather than scrolling.
const columnCard = [
	'margin: 0',
	'box-sizing: border-box',
	'flex: 0 1 auto',
].join('; ');
---

<Figure expandable={true}>
	<div
		style="margin: 0; box-sizing: border-box; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; column-gap: 1.1rem; row-gap: 1rem; width: 100%;"
	>
		{/* ---- Left: raw rows ---- */}
		<div style={columnCard}>
			<div style={columnLabel}>rows</div>
			<div style={stack}>
				{
					rows.map((r) => (
						<div style={sourceRow(r.status)}>
							<span style={pill(r.status)}>{r.status}</span>
							<span style={amount}>{r.amount}</span>
						</div>
					))
				}
			</div>
		</div>

		{/* ---- Middle: the fold ---- */}
		<div style={arrowWrap}>
			<span style={arrowLabel}>groupBy(status)</span>
			<div style={arrowShaft}>
				<span style={arrowBar} />
				<span style={arrowHead} />
			</div>
		</div>

		{/* ---- Right: one row per group ---- */}
		<div style={columnCard}>
			<div style={columnLabel}>one row per group</div>
			<div style={stack}>
				{
					groups.map((g) => (
						<div style={groupRow(g.status)}>
							<span style={pill(g.status)}>{g.status}</span>
							<span style={statDivider} />
							<span style={stat}>
								<span style={statLabel}>count</span>
								<span style={statValue}>{g.count}</span>
							</span>
							<span style={stat}>
								<span style={statLabel}>sum</span>
								<span style={statValue}>{g.sum}</span>
							</span>
						</div>
					))
				}
			</div>
		</div>
	</div>

	<Fragment slot="caption">
		Rows fold into one row per group. <code>where</code> thins the left stack
		before the fold; <code>having</code> thins the right stack after it.
	</Fragment>
</Figure>
