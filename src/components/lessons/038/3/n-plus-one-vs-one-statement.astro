---
// N+1 vs. one statement (diagram id: n-plus-one-vs-one-statement, Chapter 038
// Lesson 3 — "Nested reads with the relational API"). The section anchor for
// "One statement, no N+1." A scrubbable three-step DiagramSequence whose whole
// point is the ROUND-TRIP COUNT: watching N arrows fan out and then collapse to
// one is the lesson.
//
//   Step 1 "Fetch the parents": the server box on the left, ONE arrow to
//     Postgres on the right (the `select … from invoices`). A neutral/blue
//     "1 round trip so far" badge. Nothing is wrong yet — this is the innocent
//     first query.
//   Step 2 "Loop per parent": the SAME server box, but now a FAN of arrows
//     (five drawn + an ellipsis row standing in for "× N") each carrying a
//     per-invoice line-items query out to Postgres. A RED "1 + N round trips"
//     badge — this is the step that must feel expensive. This is the N+1.
//   Step 3 "RQB — one statement": the server box again, exactly ONE arrow to
//     Postgres, labelled "one statement, nested JSON". A GREEN "1 round trip"
//     badge — the win. The fan has collapsed back to a single line at any depth.
//
// Colour convention (pinned light, mirrors the chapter-037/038 family):
//   BLUE  = neutral/in-progress (the first innocent query, the DB box),
//   RED   = the cost being avoided (the N-arrow fan-out, 1 + N badge),
//   GREEN = the win (RQB's single statement, 1-round-trip badge),
//   neutral slate = inert chrome (the server box, the DB cylinder shell).
// House style: DiagramSequence provides the outer card (never wrap in Figure);
// pinned `color-scheme: light` so the hand-picked tints survive dark mode;
// inline style strings only; box-sizing: border-box + margin: 0 throughout to
// defeat Starlight's injected prose margins. Horizontal, height-capped. No
// leader lines, so the figure stays expandable.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// inert chrome — neutral slate, carries no meaning.
const CHROME_BORDER = '#cbd5e1'; // slate-300
const OWN = '#334155'; // slate-700 — the server you own (neutral-strong)
const OWN_BG = '#e2e8f0'; // slate-200 wash

// BLUE — the database, and the neutral "in progress" first query.
const BLUE = '#2563eb'; // blue-600
const BLUE_INK = '#1e3a8a'; // blue-900
const BLUE_BG = '#dbeafe'; // blue-100 wash

// RED — the avoided cost (the N-query fan-out).
const RED = '#dc2626'; // red-600
const RED_INK = '#b91c1c'; // red-700
const RED_BG = '#fef2f2'; // red-50 wash

// GREEN — the win (one statement).
const GREEN = '#16a34a'; // green-600
const GREEN_INK = '#15803d'; // green-700
const GREEN_BG = '#f0fdf4'; // green-50 wash

// ---- outer stage ---------------------------------------------------------
const stage = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 14px',
  'margin: 0',
  'padding: 6px 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
  'min-height: 230px',
].join('; ');

// the horizontal row holding server | arrows | database.
const row = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: row',
  'align-items: center',
  'justify-content: center',
  'gap: 16px',
  'margin: 0',
  'width: 100%',
].join('; ');

// ---- the server box (left) -----------------------------------------------
const serverBox = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 4px',
  'margin: 0',
  'padding: 13px 15px',
  'border-radius: 12px',
  `border: 1.5px solid ${OWN}`,
  `background: ${OWN_BG}`,
  'text-align: center',
  'min-width: 124px',
].join('; ');

const boxTitle = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 13px',
    'font-weight: 800',
    'line-height: 1.2',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

const boxSub = (ink: string, font = mono) =>
  [
    'margin: 0',
    `font-family: ${font}`,
    'font-size: 10.5px',
    'font-weight: 600',
    'line-height: 1.25',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

// ---- the database cylinder (right) ---------------------------------------
// A box with an elliptical "lid" drawn via a tall border-radius + top band so
// it reads as a Postgres cylinder without any SVG.
const dbCylinder = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 3px',
  'margin: 0',
  'padding: 16px 16px 13px',
  'border-radius: 50% / 16px',
  `border: 1.5px solid ${BLUE}`,
  `background: ${BLUE_BG}`,
  'text-align: center',
  'min-width: 116px',
].join('; ');

const dbTitle = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 13px',
  'font-weight: 800',
  'line-height: 1.2',
  `color: ${BLUE_INK}`,
  'white-space: nowrap',
].join('; ');

const dbSub = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 600',
  'line-height: 1.2',
  `color: ${BLUE_INK}`,
  'white-space: nowrap',
].join('; ');

// ---- arrows --------------------------------------------------------------
// A single straight arrow: a coloured rule with a triangular head, an optional
// label rides above it.
const arrowCol = (grow = false) =>
  [
    'box-sizing: border-box',
    grow ? 'flex: 1 1 auto' : 'flex: 0 0 auto',
    'display: flex',
    'flex-direction: column',
    'align-items: center',
    'justify-content: center',
    'gap: 5px',
    'margin: 0',
    grow ? 'min-width: 96px' : '',
  ]
    .filter(Boolean)
    .join('; ');

const arrowRule = (color: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'flex-direction: row',
    'align-items: center',
    'justify-content: center',
    'width: 100%',
    'min-width: 56px',
    'margin: 0',
  ].join('; ');

const arrowLine = (color: string, dashed = false) =>
  [
    'flex: 1 1 auto',
    'height: 0',
    'margin: 0',
    dashed
      ? `border-top: 2px dashed ${color}`
      : `border-top: 2.5px solid ${color}`,
  ].join('; ');

const arrowHead = (color: string) =>
  [
    'flex: 0 0 auto',
    'width: 0',
    'height: 0',
    'margin: 0 0 0 -1px',
    'border-top: 5px solid transparent',
    'border-bottom: 5px solid transparent',
    `border-left: 8px solid ${color}`,
  ].join('; ');

const arrowLabel = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 10px',
    'font-weight: 700',
    'line-height: 1.25',
    'text-align: center',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

// the per-parent fan (step 2): a vertical stack of short arrows.
const fanStack = [
  'box-sizing: border-box',
  'flex: 1 1 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: stretch',
  'justify-content: center',
  'gap: 5px',
  'margin: 0',
  'min-width: 120px',
].join('; ');

const fanLabel = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 9.5px',
    'font-weight: 700',
    'line-height: 1.2',
    'text-align: center',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

const ellipsisRow = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 16px',
  'font-weight: 900',
  'line-height: 0.6',
  'letter-spacing: 0.12em',
  'text-align: center',
  `color: ${RED}`,
].join('; ');

// ---- the round-trip badge (under the row) --------------------------------
const badge = (accent: string, bg: string, ink: string) =>
  [
    'box-sizing: border-box',
    'display: inline-flex',
    'align-items: center',
    'gap: 8px',
    'margin: 0',
    'padding: 7px 16px',
    'border-radius: 999px',
    `border: 1.5px solid ${accent}`,
    `background: ${bg}`,
    `color: ${ink}`,
    `font-family: ${sans}`,
    'font-size: 13px',
    'font-weight: 800',
    'line-height: 1.2',
    'letter-spacing: 0.01em',
    'white-space: nowrap',
  ].join('; ');

const badgeCount = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 15px',
    'font-weight: 900',
    'line-height: 1',
    `color: ${ink}`,
  ].join('; ');

// the five drawn fan arrows (the 6th row is the ellipsis → "× N").
const fanRows = [
  'invoice #1',
  'invoice #2',
  'invoice #3',
  'invoice #4',
  'invoice #5',
] as const;
---

<DiagramSequence>
  {/* ============ Step 1 — fetch the parent rows (one query) ============ */}
  <DiagramStep caption="Naive read, step one: fetch the parent rows. One query for all the invoices — nothing looks wrong yet.">
    <div style={stage}>
      <div style={row}>
        <div style={serverBox}>
          <span style={boxTitle(INK)}>Your server</span>
          <code style={boxSub(INK_SOFT)}>db.select()</code>
        </div>

        <div style={arrowCol(true)}>
          <span style={arrowLabel(BLUE_INK)}>select &hellip; from invoices</span>
          <span style={arrowRule(BLUE)}>
            <span style={arrowLine(BLUE)}></span>
            <span style={arrowHead(BLUE)}></span>
          </span>
        </div>

        <div style={dbCylinder}>
          <span style={dbTitle}>Postgres</span>
          <span style={dbSub}>100 invoices</span>
        </div>
      </div>

      <span style={badge(BLUE, BLUE_BG, BLUE_INK)}>
        <span style={badgeCount(BLUE_INK)}>1</span>
        round trip so far
      </span>
    </div>
  </DiagramStep>

  {/* ============ Step 2 — the loop: one query per parent (N+1) ============ */}
  <DiagramStep caption="Naive read, step two: the loop. For every invoice, a separate query for its line items — N more round trips, each with its own latency. This is the N+1.">
    <div style={stage}>
      <div style={row}>
        <div style={serverBox}>
          <span style={boxTitle(INK)}>Your server</span>
          <code style={boxSub(INK_SOFT)}>rows.map(&hellip;)</code>
        </div>

        <div style={fanStack}>
          <span style={fanLabel(RED_INK)}>one query per invoice</span>
          {fanRows.map((r) => (
            <span style={arrowRule(RED)}>
              <span style={arrowLine(RED)}></span>
              <span style={arrowHead(RED)}></span>
            </span>
          ))}
          <span style={ellipsisRow} aria-hidden="true">&middot;&middot;&middot;</span>
          <span style={fanLabel(RED_INK)}>&times; N</span>
        </div>

        <div style={dbCylinder}>
          <span style={dbTitle}>Postgres</span>
          <span style={dbSub}>line items</span>
        </div>
      </div>

      <span style={badge(RED, RED_BG, RED_INK)}>
        <span style={badgeCount(RED_INK)}>1 + N</span>
        round trips
      </span>
    </div>
  </DiagramStep>

  {/* ============ Step 3 — RQB: one statement, any depth ============ */}
  <DiagramStep caption="RQB: describe the tree and Drizzle emits a single statement with subqueries that aggregate each relation into JSON. One round trip, at any depth — the N+1 never arises.">
    <div style={stage}>
      <div style={row}>
        <div style={serverBox}>
          <span style={boxTitle(INK)}>Your server</span>
          <code style={boxSub(INK_SOFT)}>db.query &#8230; with</code>
        </div>

        <div style={arrowCol(true)}>
          <span style={arrowLabel(GREEN_INK)}>one statement, nested JSON</span>
          <span style={arrowRule(GREEN)}>
            <span style={arrowLine(GREEN)}></span>
            <span style={arrowHead(GREEN)}></span>
          </span>
        </div>

        <div style={dbCylinder}>
          <span style={dbTitle}>Postgres</span>
          <span style={dbSub}>invoices + items</span>
        </div>
      </div>

      <span style={badge(GREEN, GREEN_BG, GREEN_INK)}>
        <span style={badgeCount(GREEN_INK)}>1</span>
        round trip
      </span>
    </div>
  </DiagramStep>
</DiagramSequence>
