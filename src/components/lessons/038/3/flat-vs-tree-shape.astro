---
// flat-vs-tree-shape — Chapter 038 Lesson 3 ("Nested reads with the relational
// API"), the BEFORE-any-new-API picture: a join returns a flat, duplicated
// RECTANGLE, but the detail page wants a nested TREE. The figure makes that
// shape mismatch visceral so the reader WANTS the tree before RQB is named.
//
// Layout (two columns, a 2-column CSS grid, a connector overlaid in the gap):
//
//   LEFT  "What the join returns" — the flat leftJoin result for ONE invoice
//         that has 3 line items, drawn as a 4-column grid table:
//           invoice.id | invoice.total | lineItem.description | org.name
//         The invoice.id, invoice.total and org.name cells hold the SAME value
//         repeated down all 3 rows, tinted amber so the duplication is loud.
//         Only lineItem.description changes (Design / Build / QA). A caption
//         strip underneath spells the arithmetic: 1 invoice × 3 line items = 3
//         rows, invoice + org repeated.
//
//   MID   a thin arrow pointing left→right, label "RQB returns the right shape
//         directly".
//
//   RIGHT "What the page wants" — the same data as a nested object tree rendered
//         as indented monospace rows. The `organization { … }` object and the
//         `lineItems: [ … ]` array get a blue (project-accent) left-rail + faint
//         tint so the nesting reads. Each value appears EXACTLY once — no
//         duplication, the visual opposite of the left panel.
//
// Amber on the left = the cost (repeated columns the app must regroup by hand);
// the project accent (blue, the TS / query-builder side, consistent with the
// chapter) on the right = the shape you want. Pure HTML + CSS; `not-content`
// wrapper + a `margin: 0` reset on every rule defeat Starlight's prose-margin
// selector (which would otherwise shove lower rows down and shrink them).
// Starlight theme variables keep it native in light and dark. No leader lines,
// so the figure stays expandable.

import Figure from "../../../figures/Figure.astro";

// The flat join result: 3 rows for one invoice with 3 line items. `dup: true`
// marks the columns whose value is copied onto every row (invoice + org).
const flatColumns = [
  { key: "invoice.id", dup: true },
  { key: "invoice.total", dup: true },
  { key: "lineItem.description", dup: false },
  { key: "org.name", dup: true },
] as const;

const flatRows = [
  { id: "inv_1", total: "$300.00", description: "Design", org: "Acme" },
  { id: "inv_1", total: "$300.00", description: "Build", org: "Acme" },
  { id: "inv_1", total: "$300.00", description: "QA", org: "Acme" },
] as const;

// The nested tree, as ordered indented rows. `tone` paints the accent rail:
//   "object" → the organization { … } line, "array" → the lineItems block.
// `depth` sets the indent; `lead` is the bracket/structural glyph trail.
const treeRows = [
  { depth: 0, text: "invoice {", tone: null },
  { depth: 1, text: 'id: "inv_1"', tone: null },
  { depth: 1, text: 'total: "$300.00"', tone: null },
  { depth: 1, text: 'organization { name: "Acme" }', tone: "object" },
  { depth: 1, text: "lineItems: [", tone: "array" },
  { depth: 2, text: '{ description: "Design" }', tone: "array" },
  { depth: 2, text: '{ description: "Build" }', tone: "array" },
  { depth: 2, text: '{ description: "QA" }', tone: "array" },
  { depth: 1, text: "]", tone: "array" },
  { depth: 0, text: "}", tone: null },
] as const;
---

<Figure
  caption="Same invoice, two shapes. The join returns a flat rectangle — the invoice and organization columns copied onto every line-item row, which the app must regroup by hand. The detail page wants the tree on the right, where each value appears exactly once. RQB returns that tree directly."
>
  <div class="ft not-content">
    {/* ---- LEFT · the flat join result ------------------------------- */}
    <div class="ft-panel ft-panel--flat">
      <div class="ft-title">What the join returns</div>

      <div class="ft-table" role="table" aria-label="Flat join result">
        {/* header row */}
        <div class="ft-trow ft-trow--head" role="row">
          {flatColumns.map((c) => (
            <code class={`ft-th ${c.dup ? "ft-th--dup" : ""}`} role="columnheader">
              {c.key}
            </code>
          ))}
        </div>

        {/* body rows: the dup columns repeat their value down every row */}
        {flatRows.map((r) => (
          <div class="ft-trow" role="row">
            <code class="ft-td ft-td--dup" role="cell">{r.id}</code>
            <code class="ft-td ft-td--dup" role="cell">{r.total}</code>
            <code class="ft-td" role="cell">{r.description}</code>
            <code class="ft-td ft-td--dup" role="cell">{r.org}</code>
          </div>
        ))}
      </div>

      <div class="ft-strip">
        <span class="ft-strip-x">1 invoice × 3 line items = 3 rows</span>
        <span class="ft-strip-note">invoice + org repeated</span>
      </div>
    </div>

    {/* ---- MIDDLE · the divider + directional label ------------------- */}
    <div class="ft-mid" aria-hidden="true">
      <div class="ft-arrow">
        <span class="ft-arrow-line"></span>
        <span class="ft-arrow-head"></span>
      </div>
      <span class="ft-arrow-label">
        RQB returns the<br />right shape directly
      </span>
    </div>

    {/* ---- RIGHT · the nested tree the page wants --------------------- */}
    <div class="ft-panel ft-panel--tree">
      <div class="ft-title">What the page wants</div>

      <div class="ft-tree">
        {treeRows.map((row) => (
          <div
            class={`ft-line ${row.tone ? `ft-line--${row.tone}` : ""}`}
            style={`--depth: ${row.depth}`}
          >
            <code class="ft-code">{row.text}</code>
          </div>
        ))}
      </div>
    </div>
  </div>
</Figure>

<style>
  /* Two panels side by side with a narrow centre column for the arrow. The grid
     keeps the panels equal and the arrow centred; it collapses to a stack on
     narrow viewports. Capped well under the 800px height ceiling. */
  .ft {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 6px;
    width: 100%;
    max-width: 760px;
    margin-inline: auto;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- a panel (flat | tree) ----------------------------------------- */

  .ft-panel {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
    padding: 14px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
    margin: 0;
  }

  .ft-title {
    font-size: 11.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* ---- LEFT · the flat table ----------------------------------------- */

  .ft-table {
    display: flex;
    flex-direction: column;
    border-radius: 9px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-4);
    margin: 0;
  }

  /* Every row is the same 4-column grid so cells align column-for-column. The
     description column is given a touch more room than the value columns. */
  .ft-trow {
    display: grid;
    grid-template-columns: 0.85fr 1fr 1.25fr 0.95fr;
    margin: 0;
  }

  .ft-trow--head {
    border-bottom: 1px solid var(--sl-color-gray-4);
  }

  /* A header cell — the column name, monospace, small. */
  .ft-th {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 6px 8px;
    color: var(--sl-color-gray-2);
    background: var(--sl-color-gray-6);
    border-right: 1px solid var(--sl-color-gray-5);
    margin: 0;
  }
  .ft-th:last-child {
    border-right: 0;
  }

  /* A body cell — the value. */
  .ft-td {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11.5px;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 7px 8px;
    color: var(--sl-color-text);
    background: var(--sl-color-bg);
    border-top: 1px solid var(--sl-color-gray-5);
    border-right: 1px solid var(--sl-color-gray-5);
    margin: 0;
  }
  .ft-td:last-child {
    border-right: 0;
  }
  .ft-trow:nth-child(2) .ft-td {
    /* first body row sits directly under the header rule, no double border */
    border-top: 0;
  }

  /* The duplicated columns — invoice + org, copied onto every row. Amber tint
     (the chapter's constraint/cost colour) makes the repetition visceral. */
  .ft-th--dup {
    color: #b45309;
    background: color-mix(in srgb, #d97706 15%, var(--sl-color-gray-6));
  }
  .ft-td--dup {
    color: color-mix(in srgb, #b45309 80%, var(--sl-color-text));
    background: color-mix(in srgb, #d97706 13%, transparent);
  }

  /* The arithmetic strip under the table. */
  .ft-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 3px 8px;
    margin: 0;
  }

  .ft-strip-x {
    font-size: 11.5px;
    font-weight: 700;
    color: var(--sl-color-text);
    margin: 0;
  }

  .ft-strip-note {
    font-size: 11px;
    font-weight: 600;
    color: #b45309;
    margin: 0;
  }

  /* ---- MIDDLE · arrow + label ---------------------------------------- */

  .ft-mid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 0 2px;
    margin: 0;
  }

  .ft-arrow {
    display: flex;
    align-items: center;
    margin: 0;
  }

  .ft-arrow-line {
    width: 30px;
    height: 3px;
    border-radius: 3px;
    background: var(--sl-color-text-accent);
    margin: 0;
  }

  .ft-arrow-head {
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 9px solid var(--sl-color-text-accent);
    margin: 0 0 0 -1px;
  }

  .ft-arrow-label {
    font-size: 10.5px;
    font-weight: 700;
    line-height: 1.3;
    text-align: center;
    color: var(--sl-color-text-accent);
    margin: 0;
  }

  /* ---- RIGHT · the nested tree --------------------------------------- */

  .ft-tree {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    padding: 10px 12px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    margin: 0;
  }

  /* One row of the tree. `--depth` drives the indent via a left pad; accented
     rows (object / array) carry a blue rail + faint tint so the nesting reads. */
  .ft-line {
    box-sizing: border-box;
    padding: 1.5px 0 1.5px calc(8px + var(--depth, 0) * 16px);
    border-left: 2px solid transparent;
    margin: 0;
  }

  .ft-line--object,
  .ft-line--array {
    border-left-color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 8%, transparent);
  }

  .ft-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.5;
    white-space: nowrap;
    color: var(--sl-color-text);
    background: transparent;
    padding: 0;
    margin: 0;
  }

  /* Tint the structural glyphs/keys on accented rows so they read as "the shape". */
  .ft-line--object .ft-code,
  .ft-line--array .ft-code {
    color: color-mix(in srgb, var(--sl-color-text-accent) 55%, var(--sl-color-text));
  }

  /* ---- narrow viewports: stack the panels, arrow turns downward ------- */
  @media (max-width: 560px) {
    .ft {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .ft-mid {
      flex-direction: row;
      gap: 10px;
    }
    .ft-arrow {
      transform: rotate(90deg);
    }
    .ft-arrow-label {
      text-align: left;
    }
    .ft-code {
      white-space: normal;
    }
  }
</style>
