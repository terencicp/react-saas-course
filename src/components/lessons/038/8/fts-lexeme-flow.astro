---
// fts-lexeme-flow (diagram id: fts-lexeme-flow, Chapter 038 Lesson 8 —
// "Full-text search in Postgres"). The lesson's anchor visual for the mental
// model: BOTH the stored document and the search term pass through their OWN
// normalizer and arrive as the SAME lexemes, and only then meet at `@@`. The
// sameness of the two lexeme-chip boxes IS the lesson — they reached identical
// lexemes by different paths (a tsvector vs a tsquery), which is why a plural
// matches a singular, why "the" disappears, why exact-substring surprises.
//
// Layout (plain HTML+CSS per diagrams/INDEX.md "annotated illustration"):
//   Two parallel rows flowing left -> right, converging on a central `@@`.
//     TOP row (stored document):
//       "The cats are running"  ->  to_tsvector('english', …)  ->  [cat][run]
//     BOTTOM row (search term):
//       "running cat"           ->  websearch_to_tsquery('english', …) -> [cat][run]
//   Both chip boxes feed arrows into a central `@@` node (large, accent), and to
//   its right a green-check result chip ("match — both lexemes present").
//
// House style follows the chapter-038 family (AggregateHelpers,
// offset-rescan-vs-cursor-seek): a `not-content` wrapper + a <style> block (the
// `.not-content` class strips Starlight's injected prose margin-top, the load-
// bearing gotcha for HTML+CSS figures), sl-color theme tokens for chrome,
// monospace spans for code (no <code> pill so cells stay aligned), and saturated
// mid-tone fills with white text where the colour is the signal — here the
// lexeme chips (teal) and the `@@` node + check (the match accent). Short, wide,
// height-capped well under the 800px ceiling. The converging arrows are drawn
// with one inline SVG so the two lines genuinely meet the `@@` node; no leader
// lines, so the Figure stays expandable.

import Figure from '../../../figures/Figure.astro';

// The lexeme chips carry the meaning — saturated teal, white text, identical in
// both rows. Teal-600 reads on both white and near-black page backgrounds.
const LEXEME_FILL = '#0d9488'; // teal-600
// The match operator and the success check — a warm accent so `@@` reads as the
// place everything converges, distinct from the teal lexemes it compares.
const MATCH_ACCENT = '#7c3aed'; // violet-600
const OK_FILL = '#16a34a'; // green-600

// Each row: a raw-text box, a normalizer box, and a lexeme-chip box. The two
// rows differ only in their raw input and their normalizer function — the chips
// are deliberately identical.
type Row = {
	tag: string; // who this row is
	raw: string; // the raw text, shown in quotes
	fn: string; // the normalizer call (monospace)
	micro: string; // microlabel under the chip box
};

const rows: { top: Row; bottom: Row } = {
	top: {
		tag: 'stored document',
		raw: 'The cats are running',
		fn: "to_tsvector('english', …)",
		micro: 'stop words dropped, words stemmed',
	},
	bottom: {
		tag: 'search term',
		raw: 'running cat',
		fn: "websearch_to_tsquery('english', …)",
		micro: 'user input, same normalization',
	},
};

// The shared lexemes both paths arrive at. `pos` is the optional position the
// tsvector remembers (cat:2 run:4) — shown small so it reads as a detail, not a
// distraction. The tsquery has no positions, so the bottom row omits them.
const lexemes = [
	{ word: 'cat', pos: 2 },
	{ word: 'run', pos: 4 },
];
---

<Figure
	caption="Both the stored text and the search term are normalized into lexemes, then compared with `@@`. The match works on meaning, not characters."
>
	<div class="fts not-content">
		{/* ---- The two normalization rows ---- */}
		<div class="fts-rows">
			{/* TOP — the stored document */}
			<div class="fts-row" role="img" aria-label="The stored text 'The cats are running' becomes the lexemes cat and run via to_tsvector">
				<div class="fts-stage fts-raw">
					<span class="fts-stage-tag">{rows.top.tag}</span>
					<span class="fts-quote">&ldquo;{rows.top.raw}&rdquo;</span>
				</div>
				<span class="fts-arrow" aria-hidden="true">&rarr;</span>
				<div class="fts-stage fts-norm">
					<span class="fts-norm-label">normalizer</span>
					<span class="fts-code">{rows.top.fn}</span>
				</div>
				<span class="fts-arrow" aria-hidden="true">&rarr;</span>
				<div class="fts-stage fts-out">
					<div class="fts-chips">
						{
							lexemes.map((l) => (
								<span class="fts-chip">
									{l.word}
									<sub class="fts-pos">:{l.pos}</sub>
								</span>
							))
						}
					</div>
					<span class="fts-micro">{rows.top.micro}</span>
				</div>
			</div>

			{/* BOTTOM — the search term, mirroring the top */}
			<div class="fts-row" role="img" aria-label="The search text 'running cat' becomes the same lexemes cat and run via websearch_to_tsquery">
				<div class="fts-stage fts-raw">
					<span class="fts-stage-tag">{rows.bottom.tag}</span>
					<span class="fts-quote">&ldquo;{rows.bottom.raw}&rdquo;</span>
				</div>
				<span class="fts-arrow" aria-hidden="true">&rarr;</span>
				<div class="fts-stage fts-norm">
					<span class="fts-norm-label">normalizer</span>
					<span class="fts-code">{rows.bottom.fn}</span>
				</div>
				<span class="fts-arrow" aria-hidden="true">&rarr;</span>
				<div class="fts-stage fts-out">
					<div class="fts-chips">
						{
							lexemes.map((l) => (
								<span class="fts-chip">{l.word}</span>
							))
						}
					</div>
					<span class="fts-micro">{rows.bottom.micro}</span>
				</div>
			</div>

			{/* Converging connectors: two lines from each chip box meeting the @@
			    node. SVG so the lines genuinely meet a single point. It spans the
			    gutter between the chip boxes and the @@ column. */}
			<svg class="fts-converge" viewBox="0 0 60 120" preserveAspectRatio="none" aria-hidden="true">
				<path d="M 0 26 C 34 26 26 60 60 60" class="fts-line" />
				<path d="M 0 94 C 34 94 26 60 60 60" class="fts-line" />
			</svg>
		</div>

		{/* ---- The match column: @@ then the result ---- */}
		<div class="fts-match">
			<span class="fts-at" title="tsvector @@ tsquery">@@</span>
			<span class="fts-arrow fts-arrow--result" aria-hidden="true">&rarr;</span>
			<span class="fts-result">
				<span class="fts-check" aria-hidden="true">&#10003;</span>
				match
			</span>
		</div>
	</div>
</Figure>

<style define:vars={{ LEXEME_FILL, MATCH_ACCENT, OK_FILL }}>
	.fts {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		column-gap: 0;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	/* The two rows + the converging SVG, stacked. The SVG sits in the right
	   gutter, overlapping nothing — position: relative on the container, the SVG
	   absolutely placed against its right edge. */
	.fts-rows {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 18px;
		margin: 0;
		/* leave room on the right for the converging connectors */
		padding-right: 60px;
	}

	.fts-row {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 0;
	}

	/* Each stage is a bordered card on the standard Figure background. */
	.fts-stage {
		display: flex;
		flex-direction: column;
		gap: 5px;
		box-sizing: border-box;
		padding: 9px 12px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg);
		margin: 0;
	}

	.fts-raw {
		flex: 1 1 0;
		min-width: 0;
	}

	.fts-norm {
		flex: 1 1 0;
		min-width: 0;
		/* the normalizer is the "machine" — a faint tinted panel sets it apart
		   from the plain raw-text and output cards */
		background: color-mix(in srgb, var(--MATCH_ACCENT) 7%, var(--sl-color-bg));
		border-color: color-mix(in srgb, var(--MATCH_ACCENT) 30%, var(--sl-color-hairline));
	}

	.fts-out {
		flex: 0 0 auto;
	}

	/* Small uppercase tag naming which side a row is. */
	.fts-stage-tag,
	.fts-norm-label {
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3);
		margin: 0;
		line-height: 1.2;
	}

	.fts-quote {
		font-size: 14px;
		line-height: 1.35;
		color: var(--sl-color-text);
		margin: 0;
	}

	.fts-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12.5px;
		line-height: 1.35;
		color: var(--sl-color-white);
		margin: 0;
		/* Wrap only at the existing space (after the comma) so the call never
		   breaks mid-word into "en glish"; the box is sized to take two lines. */
		overflow-wrap: normal;
		word-break: normal;
	}

	/* The lexeme chips — identical in both rows, this sameness IS the lesson. */
	.fts-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin: 0;
	}

	.fts-chip {
		display: inline-flex;
		align-items: baseline;
		box-sizing: border-box;
		padding: 3px 10px;
		border-radius: 999px;
		background: var(--LEXEME_FILL);
		color: #ffffff;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 13px;
		font-weight: 700;
		line-height: 1.3;
		margin: 0;
	}

	.fts-pos {
		font-size: 9px;
		font-weight: 600;
		opacity: 0.8;
		margin: 0 0 0 1px;
	}

	.fts-micro {
		font-size: 10.5px;
		line-height: 1.3;
		font-style: italic;
		color: var(--sl-color-gray-3);
		margin: 0;
		max-width: 13rem;
	}

	.fts-arrow {
		flex: none;
		font-size: 18px;
		line-height: 1;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* The converging connectors overlay the right gutter of the rows block. */
	.fts-converge {
		position: absolute;
		top: 0;
		right: 0;
		width: 60px;
		height: 100%;
		overflow: visible;
		margin: 0;
	}

	.fts-line {
		fill: none;
		stroke: var(--MATCH_ACCENT);
		stroke-width: 2;
		opacity: 0.55;
	}

	/* The match column: the big @@ node, an arrow, and the result chip. */
	.fts-match {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 0;
		padding-left: 6px;
	}

	.fts-at {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		box-sizing: border-box;
		width: 56px;
		height: 56px;
		border-radius: 14px;
		background: var(--MATCH_ACCENT);
		color: #ffffff;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 24px;
		font-weight: 800;
		line-height: 1;
		margin: 0;
		box-shadow: 0 2px 10px color-mix(in srgb, var(--MATCH_ACCENT) 35%, transparent);
	}

	.fts-arrow--result {
		font-size: 16px;
	}

	.fts-result {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		box-sizing: border-box;
		padding: 6px 12px;
		border-radius: 9px;
		background: color-mix(in srgb, var(--OK_FILL) 14%, var(--sl-color-bg));
		border: 1px solid color-mix(in srgb, var(--OK_FILL) 45%, var(--sl-color-hairline));
		color: var(--sl-color-text);
		font-size: 13px;
		font-weight: 600;
		line-height: 1.2;
		margin: 0;
		white-space: nowrap;
	}

	.fts-check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		border-radius: 999px;
		background: var(--OK_FILL);
		color: #ffffff;
		font-size: 11px;
		font-weight: 800;
		line-height: 1;
		margin: 0;
	}

	/* Narrow viewports: stack each row's stages vertically, move the match column
	   below the rows, and drop the SVG connectors (they only make sense in the
	   horizontal layout). The arrows rotate to point downward. */
	@media (max-width: 720px) {
		.fts {
			grid-template-columns: 1fr;
			justify-items: center;
			row-gap: 14px;
		}

		.fts-rows {
			padding-right: 0;
			width: 100%;
			max-width: 22rem;
		}

		.fts-converge {
			display: none;
		}

		.fts-row {
			flex-direction: column;
			gap: 6px;
		}

		.fts-row .fts-arrow {
			transform: rotate(90deg);
		}

		.fts-stage {
			width: 100%;
			align-items: center;
			text-align: center;
		}

		.fts-micro {
			max-width: none;
			text-align: center;
		}

		.fts-match {
			padding-left: 0;
		}
	}
</style>
