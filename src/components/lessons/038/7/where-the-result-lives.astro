---
// where-the-result-lives — Chapter 038 Lesson 7 ("Subqueries and CTEs"), the
// lesson's ANCHOR picture, pointed back to by every later section. Goal: make
// "same intermediate result, three homes" visible BEFORE any syntax. One small
// intermediate-result chip — a 3-row mini-table titled `paid-plan org ids` — is
// rendered IDENTICALLY in all three panels (same accent, same rows) so the eye
// recognises it as the ONE thing being relocated; only its POSITION differs.
//
// Layout (plain HTML+CSS per diagrams/INDEX.md "annotated illustration"): a
// horizontal three-panel strip (3-col CSS grid, collapses to a stack on a narrow
// card), capped well under the ~360px height budget from the outline. Each panel
// is a bordered card: small heading, the query-box body holding the chip in its
// distinct home, and a one-line caption underneath.
//
//   Panel 1 "App code"        — chip sits BETWEEN two stacked query boxes
//                               (query 1 ↓ chip ↓ query 2). Two round-trips.
//   Panel 2 "Inline subquery" — chip nested INSIDE a single box's `where … in`.
//   Panel 3 "CTE"             — chip NAMED and lifted to the TOP, in a
//                               `with paid_orgs as (…)` header band, arrow down
//                               into the main `select …` body.
//
// Binding signal: the chip's accent (project blue, the "thing itself" colour used
// across the ch 038 figures). Query-box chrome stays neutral (Starlight gray
// vars). House style mirrors the L3 flat-vs-tree-shape / L6 figures: `not-content`
// wrapper + `margin: 0` reset on every rule to defeat Starlight's injected prose
// margin-top, Starlight theme variables for native light/dark, arrows as a line +
// CSS-triangle head. No leader lines, so the figure stays expandable.

import Figure from '../../../figures/Figure.astro';

// The one intermediate result, rendered the same in every panel.
const CHIP_TITLE = 'paid-plan org ids';
const CHIP_ROWS = ['org_3', 'org_7', 'org_9'] as const;
---

<Figure>
	<div class="wrl not-content">
		{/* ============ Panel 1 · App code ============ */}
		<div class="wrl-panel">
			<div class="wrl-head">App code</div>

			<div class="wrl-body">
				<div class="wrl-qbox">
					<span class="wrl-qlabel">query 1</span>
					<code class="wrl-qline">select id from organizations …</code>
				</div>

				<span class="wrl-flow" aria-hidden="true"></span>

				{/* the intermediate result, standing on its own between the two reads */}
				<div class="wrl-chip">
					<span class="wrl-chip-title">{CHIP_TITLE}</span>
					<div class="wrl-chip-rows">
						{CHIP_ROWS.map((id) => <code class="wrl-chip-cell">{id}</code>)}
					</div>
				</div>

				<span class="wrl-flow" aria-hidden="true"></span>

				<div class="wrl-qbox">
					<span class="wrl-qlabel">query 2</span>
					<code class="wrl-qline">select * from invoices …</code>
				</div>
			</div>

			<p class="wrl-cap">Two round-trips. Reads straight.</p>
		</div>

		{/* ============ Panel 2 · Inline subquery ============ */}
		<div class="wrl-panel">
			<div class="wrl-head">Inline subquery</div>

			<div class="wrl-body">
				{/* one statement; the chip is tucked into the where … in (…) line */}
				<div class="wrl-qbox wrl-qbox--full">
					<span class="wrl-qlabel">one statement</span>
					<code class="wrl-qline">select * from invoices</code>
					<code class="wrl-qline">where organization_id in (</code>

					<div class="wrl-chip wrl-chip--nested">
						<span class="wrl-chip-title">{CHIP_TITLE}</span>
						<div class="wrl-chip-rows">
							{CHIP_ROWS.map((id) => <code class="wrl-chip-cell">{id}</code>)}
						</div>
					</div>

					<code class="wrl-qline">)</code>
				</div>
			</div>

			<p class="wrl-cap">One statement. Used once.</p>
		</div>

		{/* ============ Panel 3 · CTE ============ */}
		<div class="wrl-panel">
			<div class="wrl-head">CTE</div>

			<div class="wrl-body">
				{/* one statement; the chip is named and lifted to the top */}
				<div class="wrl-qbox wrl-qbox--full">
					{/* the named header band holding the chip */}
					<div class="wrl-with">
						<code class="wrl-qline wrl-qline--with">with paid_orgs as (</code>
						<div class="wrl-chip wrl-chip--named">
							<span class="wrl-chip-title">{CHIP_TITLE}</span>
							<div class="wrl-chip-rows">
								{CHIP_ROWS.map((id) => <code class="wrl-chip-cell">{id}</code>)}
							</div>
						</div>
						<code class="wrl-qline wrl-qline--with">)</code>
					</div>

					<span class="wrl-flow wrl-flow--in" aria-hidden="true"></span>

					<code class="wrl-qline">select * from invoices</code>
					<code class="wrl-qline">join paid_orgs …</code>
				</div>
			</div>

			<p class="wrl-cap">Named. Reusable.</p>
		</div>
	</div>

	<Fragment slot="caption">
		The same intermediate result — <code>paid-plan org ids</code> — living in
		three different homes. The rows it returns are identical; only the reader's
		experience changes.
	</Fragment>
</Figure>

<style>
	/* Three equal panels in a row; collapses to a stack on a narrow card. Capped
	   well under the 360px height budget. */
	.wrl {
		box-sizing: border-box;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		align-items: stretch;
		gap: 12px;
		width: 100%;
		max-width: 760px;
		margin-inline: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	/* ---- a panel ------------------------------------------------------- */

	.wrl-panel {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 9px;
		min-width: 0;
		padding: 12px 12px 11px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg);
		margin: 0;
	}

	.wrl-head {
		font-size: 11.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		margin: 0;
	}

	/* the stack of boxes/chip/arrows inside a panel; grows to fill so all three
	   panels share a height and the captions line up at the bottom. */
	.wrl-body {
		box-sizing: border-box;
		display: flex;
		flex: 1 1 auto;
		flex-direction: column;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
		margin: 0;
	}

	/* ---- a monospace query box ----------------------------------------- */

	.wrl-qbox {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 7px 9px 8px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		margin: 0;
	}

	/* the inline-subquery / CTE panels hold one tall box that owns the chip. */
	.wrl-qbox--full {
		gap: 4px;
	}

	.wrl-qlabel {
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
		margin: 0 0 1px;
	}

	.wrl-qline {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.35;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		color: var(--sl-color-text);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	/* ---- the intermediate-result chip (identical in every panel) ------- */

	.wrl-chip {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-self: center;
		width: fit-content;
		min-width: 96px;
		padding: 5px 7px 6px;
		border-radius: 8px;
		border: 1.5px solid var(--chip-accent);
		background: color-mix(in srgb, var(--chip-accent) 12%, var(--sl-color-bg));
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--chip-accent) 14%, transparent);
		margin: 0;
		/* the chip's one accent — the binding signal across all three panels. */
		--chip-accent: #2563eb;
	}

	/* nested inside the inline-subquery box: indented to read as part of the
	   where … in (…) line, and a touch tighter. */
	.wrl-chip--nested {
		align-self: flex-start;
		margin: 1px 0 1px 14px;
	}

	/* the CTE chip sits inside its named header band, full width of it. */
	.wrl-chip--named {
		align-self: stretch;
		width: auto;
		margin: 3px 0;
	}

	.wrl-chip-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 9.5px;
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: 0.01em;
		white-space: nowrap;
		color: color-mix(in srgb, var(--chip-accent) 70%, var(--sl-color-text));
		margin: 0 0 4px;
	}

	.wrl-chip-rows {
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
		margin: 0;
	}

	.wrl-chip-cell {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 11px;
		font-weight: 700;
		line-height: 1.25;
		white-space: nowrap;
		padding: 1px 6px;
		border-radius: 5px;
		color: #ffffff;
		background: var(--chip-accent);
		margin: 0;
	}

	/* ---- the CTE named header band ------------------------------------- */

	.wrl-with {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 6px 7px 7px;
		border-radius: 7px;
		border: 1px dashed color-mix(in srgb, #2563eb 55%, var(--sl-color-gray-4));
		background: color-mix(in srgb, #2563eb 6%, transparent);
		margin: 0;
	}

	.wrl-qline--with {
		color: color-mix(in srgb, #2563eb 65%, var(--sl-color-text));
		font-weight: 700;
	}

	/* ---- the little down-arrow connector ------------------------------- */

	/* a thin vertical shaft with a CSS-triangle head, centred between stacked
	   elements. Drawn with a pseudo-element so a single span makes the whole arrow. */
	.wrl-flow {
		position: relative;
		display: block;
		align-self: center;
		width: 0;
		height: 12px;
		border-left: 2px solid var(--sl-color-gray-3);
		margin: 0;
	}
	.wrl-flow::after {
		content: '';
		position: absolute;
		left: 50%;
		bottom: -1px;
		width: 0;
		height: 0;
		border-left: 4px solid transparent;
		border-right: 4px solid transparent;
		border-top: 6px solid var(--sl-color-gray-3);
		transform: translateX(-50%);
	}

	/* the arrow from the CTE header into the main select — a touch shorter. */
	.wrl-flow--in {
		height: 10px;
		border-color: color-mix(in srgb, #2563eb 50%, var(--sl-color-gray-3));
	}
	.wrl-flow--in::after {
		border-top-color: color-mix(in srgb, #2563eb 50%, var(--sl-color-gray-3));
	}

	/* ---- per-panel caption --------------------------------------------- */

	.wrl-cap {
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
		margin: 0;
	}

	/* ---- narrow cards: stack the three panels -------------------------- */
	@media (max-width: 600px) {
		.wrl {
			grid-template-columns: 1fr;
			gap: 10px;
		}
		.wrl-body {
			justify-content: flex-start;
		}
	}
</style>
