---
// Diagram: side-by-side comparison of the two error channels (return the
// expected vs. throw the unexpected).
//
// Five-row grid:
//   - Header row: bold channel names ("Return the expected" / "Throw the
//     unexpected"); the row-label column is empty here.
//   - Four content rows: each has a faint uppercase row label on the left
//     ("What it carries", "Who handles it", "Canonical site", "Example") and
//     two cells with the per-channel content.
//
// No asymmetric colour tint — the parallel structure of the two columns is
// the visual carrier. A subtle vertical divider separates the two channel
// columns; hair-thin horizontal rules separate the rows. Code spans render
// with a monospace span (no <code> pill) so the cell layout stays predictable.
//
// Responsive collapse under 700px: the grid switches to a single column and
// the channel names render inline above their content.

import Figure from '../../../figures/Figure.astro';

type Cell = {
	prose?: string;
	mono?: string; // a short monospace fragment rendered inline after the prose
};

type Row = {
	label: string;
	return: Cell;
	throwCh: Cell;
};

const rows: Row[] = [
	{
		label: 'What it carries',
		return: {
			prose:
				'A failure the caller is expected to handle as part of normal flow — validation, business-rule rejection, "not found" for an optional lookup, conflict, rate-limited.',
		},
		throwCh: {
			prose:
				'An operational failure the caller cannot reasonably recover from inside its own logic — database down, request canceled, invariant violated, disk full.',
		},
	},
	{
		label: 'Who handles it',
		return: {
			prose:
				'The immediate caller branches on the discriminant and renders a different message, retries, or falls back.',
			mono: 'error.code',
		},
		throwCh: {
			prose:
				"A framework boundary — error.tsx, the route handler's catch, the Server Action wrapper — decides on the user-visible response.",
		},
	},
	{
		label: 'Canonical site',
		return: {
			prose: 'A discriminated-union return shape.',
			mono: 'Result<T, E>',
		},
		throwCh: {
			prose: 'A thrown Error (or a custom Error subclass).',
			mono: 'throw new Error(...)',
		},
	},
	{
		label: 'Example',
		return: {
			prose:
				'parseInvoiceCsv returns err({ code: \'OUT_OF_RANGE\', column: \'total\' }) for a row whose total exceeds the column\'s max — the caller highlights that column for the user.',
		},
		throwCh: {
			prose:
				'parseInvoiceCsv throws when the disk read fails — no caller can do anything different about a temp file that vanished.',
		},
	},
];
---

<Figure caption="The two channels of failure, side by side.">
	<div class="tc-root">
		{/* Header row */}
		<div class="tc-row tc-header">
			<div class="tc-key" aria-hidden="true"></div>
			<div class="tc-cell tc-return tc-head-cell">Return the expected</div>
			<div class="tc-cell tc-throw tc-head-cell">Throw the unexpected</div>
		</div>

		{/* Data rows */}
		{
			rows.map((r, i) => (
				<div class={`tc-row${i === rows.length - 1 ? ' tc-row-last' : ''}`}>
					<div class="tc-key">{r.label}</div>
					<div class="tc-cell tc-return">
						{r.return.prose && <span class="tc-prose">{r.return.prose}</span>}
						{r.return.mono && <span class="tc-mono-inline">{r.return.mono}</span>}
					</div>
					<div class="tc-cell tc-throw">
						{r.throwCh.prose && <span class="tc-prose">{r.throwCh.prose}</span>}
						{r.throwCh.mono && <span class="tc-mono-inline">{r.throwCh.mono}</span>}
					</div>
				</div>
			))
		}
	</div>
</Figure>

<style>
	.tc-root {
		display: grid;
		grid-template-columns: minmax(120px, max-content) 1fr 1fr;
		padding: 4px 8px;
		margin: 0;
	}

	.tc-row {
		display: contents;
	}

	.tc-key,
	.tc-cell {
		padding: 12px 14px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 13px;
		line-height: 1.5;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 6px;
	}

	/* Faint uppercase row label on the left */
	.tc-key {
		font-size: 10.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3);
		text-align: right;
		align-items: flex-end;
		justify-content: center;
		padding-right: 18px;
	}

	/* Subtle vertical divider between the two channel columns */
	.tc-return {
		border-right: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}

	/* Hair-thin horizontal rule between rows */
	.tc-row .tc-key,
	.tc-row .tc-cell {
		border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
	}

	.tc-row-last .tc-key,
	.tc-row-last .tc-cell {
		border-bottom: none;
	}

	/* Header row: bold, prominent — the parallel structure is what carries the comparison */
	.tc-head-cell {
		font-size: 14px;
		font-weight: 700;
		color: var(--sl-color-text);
		padding-top: 14px;
		padding-bottom: 14px;
		flex-direction: row;
		align-items: center;
	}

	.tc-row.tc-header .tc-key {
		border-bottom: 1px solid color-mix(in srgb, currentColor 18%, transparent);
	}
	.tc-row.tc-header .tc-cell {
		border-bottom: 1px solid color-mix(in srgb, currentColor 18%, transparent);
	}

	.tc-prose {
		margin: 0;
	}

	.tc-mono-inline {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		color: var(--sl-color-text);
		background: color-mix(in srgb, currentColor 6%, transparent);
		padding: 1px 6px;
		border-radius: 4px;
		align-self: flex-start;
		margin: 0;
	}

	/* Responsive: stack into a single column under ~700px */
	@media (max-width: 700px) {
		.tc-root {
			grid-template-columns: 1fr;
		}

		.tc-row.tc-header {
			display: none;
		}

		.tc-key {
			text-align: left;
			align-items: flex-start;
			justify-content: flex-start;
			padding: 14px 14px 0;
			border-bottom: none;
		}

		.tc-row.tc-header .tc-key {
			display: none;
		}

		.tc-return {
			border-right: none;
		}

		.tc-cell::before {
			font-size: 10.5px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: var(--sl-color-gray-2);
			margin: 0 0 2px;
		}

		.tc-return::before {
			content: 'Return the expected';
		}

		.tc-throw::before {
			content: 'Throw the unexpected';
		}

		.tc-cell {
			padding: 4px 14px 12px;
		}
	}
</style>
