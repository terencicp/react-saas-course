---
// Diagram: cross-realm `instanceof Error` failure.
//
// Two cards side-by-side wrapped in a Figure:
//   - Left  ("Realm A — main thread"): a catch block whose `instanceof Error`
//     check evaluates to false.
//   - Right ("Realm B — worker thread"): a throw site that constructs a real
//     `Error`. The arrow between them is the postMessage / structured-clone
//     boundary.
//
// Below the two cards sits a single annotation badge naming the structural
// fact: each realm holds its own `Error` constructor.
//
// Pure HTML + CSS. The arrow is built from a flex divider — a horizontal
// rule with a chevron at the tip and a label above. On narrow viewports the
// layout stacks vertically and the divider rotates 90°.

import Figure from '../../../figures/Figure.astro';
---

<Figure>
	<div class="rb-stage">
		<div class="rb-row">
			{/* Left — Realm A — main thread */}
			<div class="rb-card rb-card--a">
				<div class="rb-card-header">
					<span class="rb-eyebrow">Realm A</span>
					<span class="rb-title">main thread</span>
				</div>
				<pre class="rb-snippet"><span class="rb-kw">catch</span> (err) {'{'}
  <span class="rb-kw">if</span> (err <span class="rb-kw">instanceof</span> <span class="rb-builtin">Error</span>) {'{'}
    <span class="rb-comment">/* false */</span>
  {'}'}
{'}'}</pre>
			</div>

			{/* Boundary divider */}
			<div class="rb-divider" aria-hidden="true">
				<span class="rb-divider-label">postMessage / structured clone</span>
				<div class="rb-divider-line">
					<span class="rb-divider-tip">&rarr;</span>
				</div>
			</div>

			{/* Right — Realm B — worker thread */}
			<div class="rb-card rb-card--b">
				<div class="rb-card-header">
					<span class="rb-eyebrow">Realm B</span>
					<span class="rb-title">worker thread</span>
				</div>
				<pre class="rb-snippet"><span class="rb-kw">throw</span> <span class="rb-kw">new</span> <span class="rb-builtin">Error</span>(<span class="rb-string">'boom'</span>)</pre>
			</div>
		</div>

		<div class="rb-annotation">
			Realm A's <code class="rb-inline-code">Error</code> constructor
			<span class="rb-neq">!==</span>
			Realm B's <code class="rb-inline-code">Error</code> constructor.
		</div>
	</div>
	<Fragment slot="caption">
		Each realm holds its own copy of every built-in constructor. <code>instanceof Error</code> checks identity against the catching side's <code>Error</code> — which isn't the constructor the throwing side used.
	</Fragment>
</Figure>

<style>
	.rb-stage {
		display: flex;
		flex-direction: column;
		gap: 18px;
		align-items: stretch;
		margin: 0;
		padding: 4px 4px 0;
	}

	.rb-row {
		display: flex;
		flex-direction: row;
		align-items: stretch;
		justify-content: center;
		gap: 0;
		margin: 0;
	}

	.rb-card {
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
		padding: 12px 14px 14px;
		border-radius: 10px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		margin: 0;
	}

	.rb-card--a {
		background: color-mix(in srgb, #0d9488 6%, var(--sl-color-bg));
		border-color: color-mix(in srgb, #0d9488 35%, transparent);
	}

	.rb-card--b {
		background: color-mix(in srgb, #7c3aed 6%, var(--sl-color-bg));
		border-color: color-mix(in srgb, #7c3aed 35%, transparent);
	}

	.rb-card-header {
		display: flex;
		flex-direction: column;
		gap: 2px;
		margin: 0;
	}

	.rb-eyebrow {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	.rb-title {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-white);
		margin: 0;
	}

	.rb-snippet {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		line-height: 1.5;
		color: var(--sl-color-gray-1);
		background: color-mix(in srgb, var(--sl-color-gray-6) 60%, var(--sl-color-bg));
		border: 1px solid var(--sl-color-hairline);
		border-radius: 6px;
		padding: 10px 12px;
		margin: 0;
		white-space: pre;
		overflow-x: auto;
	}

	.rb-kw {
		color: #c084fc;
	}

	.rb-builtin {
		color: #f59e0b;
	}

	.rb-string {
		color: #4ade80;
	}

	.rb-comment {
		color: var(--sl-color-gray-3);
		font-style: italic;
	}

	.rb-divider {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 6px;
		padding: 0 14px;
		min-width: 140px;
		margin: 0;
	}

	.rb-divider-label {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11px;
		color: var(--sl-color-gray-2);
		text-align: center;
		line-height: 1.3;
		margin: 0;
		max-width: 140px;
	}

	.rb-divider-line {
		position: relative;
		width: 100%;
		min-width: 80px;
		height: 2px;
		background: var(--sl-color-gray-4);
		border-radius: 1px;
		margin: 0;
	}

	.rb-divider-tip {
		position: absolute;
		right: -4px;
		top: 50%;
		transform: translateY(-50%);
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 18px;
		line-height: 1;
		color: var(--sl-color-gray-4);
		margin: 0;
	}

	.rb-annotation {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 12.5px;
		line-height: 1.4;
		color: var(--sl-color-gray-1);
		text-align: center;
		padding: 8px 14px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		border: 1px dashed var(--sl-color-hairline);
		margin: 0;
		align-self: center;
		max-width: 540px;
	}

	.rb-inline-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11.5px;
		padding: 1px 5px;
		border-radius: 3px;
		background: color-mix(in srgb, currentColor 10%, transparent);
		color: inherit;
	}

	.rb-neq {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		font-weight: 700;
		color: #dc2626;
		padding: 0 2px;
	}

	@media (max-width: 600px) {
		.rb-row {
			flex-direction: column;
			align-items: stretch;
			gap: 0;
		}

		.rb-divider {
			flex-direction: column;
			padding: 8px 0;
			min-width: 0;
		}

		.rb-divider-line {
			width: 2px;
			min-width: 0;
			height: 48px;
		}

		.rb-divider-tip {
			right: 50%;
			top: auto;
			bottom: -10px;
			transform: translateX(50%) rotate(90deg);
		}
	}
</style>
