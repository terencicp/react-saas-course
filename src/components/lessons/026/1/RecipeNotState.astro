---
// recipe-not-state — Chapter 026 Lesson 1, "Extracting custom hooks".
//
// Kills the #1 beginner misconception: that calling the same custom hook in two
// components shares ONE piece of state. A custom hook shares CODE (the wiring
// recipe), never STATE — each call site gets its own useState cell.
//
// Topology (one source fans to two independent instances) — same family as
// ProducerConsumerSplit, so ArrowDiagram + leader-line is the right tool:
//
//   Row 1 (centered): the ONE useDebounced recipe — the shared definition.
//   Row 2 (two side-by-side): <SearchField /> and <FilterField />, each box
//          holding its OWN labeled [value, setValue] cell. NO arrow between
//          them — that absence is the whole point.
//
//   Two "calls" arrows fan from the recipe down to each component box, same
//   neutral theme color (each instance is produced by the one recipe). The two
//   state cells get the SAME visual treatment but distinct ids and zero
//   connection — visually one recipe, two stores.
//
// Wrapped in <Figure expandable={false}> because ArrowDiagram's LeaderLines are
// positioned from document.body and don't survive being relocated into the
// Figure lightbox <dialog>. Pure HTML boxes; arrows drawn by leader-line.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Neutral "calls" color — the same on both arrows so neither instance looks
// privileged; each is simply produced by the one recipe. A mid-tone slate that
// reads on light and dark backgrounds.
const CALLS_COLOR = '#64748b'; // slate-500

const arrows = [
	{
		from: 'rns-recipe',
		to: 'rns-search',
		label: 'calls',
		color: CALLS_COLOR,
		startSocket: 'bottom' as const,
		endSocket: 'top' as const,
		startSocketGravity: [-120, 60] as [number, number],
		endSocketGravity: [0, -55] as [number, number],
		labelOffset: [0, -2] as [number, number],
	},
	{
		from: 'rns-recipe',
		to: 'rns-filter',
		label: 'calls',
		color: CALLS_COLOR,
		startSocket: 'bottom' as const,
		endSocket: 'top' as const,
		startSocketGravity: [120, 60] as [number, number],
		endSocketGravity: [0, -55] as [number, number],
		labelOffset: [0, -2] as [number, number],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="rns-stage not-content">
			{/* Row 1 — the one shared recipe (the hook definition) */}
			<div class="rns-row">
				<div class="rns-box rns-recipe" id="rns-recipe">
					<span class="rns-eyebrow">one definition</span>
					<code class="rns-recipe-sig">useDebounced(value, delay)</code>
					<span class="rns-recipe-sub">
						a <code>useState</code> + a <code>useEffect</code> timer
					</span>
				</div>
			</div>

			{/* Row 2 — two sibling components, each with its OWN state cell.
			    No connector runs between them: independent stores. */}
			<div class="rns-row rns-row-instances">
				<div class="rns-box rns-component" id="rns-search">
					<code class="rns-component-name">&lt;SearchField /&gt;</code>
					<div class="rns-cell">
						<code class="rns-cell-code">[searchValue, setSearchValue]</code>
						<span class="rns-cell-note">its own state</span>
					</div>
				</div>

				<div class="rns-box rns-component" id="rns-filter">
					<code class="rns-component-name">&lt;FilterField /&gt;</code>
					<div class="rns-cell">
						<code class="rns-cell-code">[filterValue, setFilterValue]</code>
						<span class="rns-cell-note">its own state</span>
					</div>
				</div>
			</div>
		</div>
	</ArrowDiagram>

	<Fragment slot="caption">
		One hook definition, two independent state cells. Custom hooks share
		code, not state — typing in one field never touches the other's value.
	</Fragment>
</Figure>

<style>
	.rns-stage {
		display: flex;
		flex-direction: column;
		gap: 60px;
		align-items: stretch;
		padding: 6px 8px 8px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.rns-row {
		display: flex;
		justify-content: center;
		align-items: stretch;
		gap: 48px;
		margin: 0;
	}

	.rns-row-instances {
		gap: 56px;
	}

	.rns-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 5px;
		padding: 12px 16px;
		border-radius: 11px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
		text-align: center;
		margin: 0;
		min-width: 0;
	}

	/* ── the recipe: the one saturated source (React cyan) ── */
	.rns-recipe {
		max-width: 360px;
		padding: 13px 20px;
		background: color-mix(in srgb, #0891b2 11%, var(--sl-color-bg));
		border-color: color-mix(in srgb, #0891b2 48%, transparent);
		box-shadow: 0 1px 4px rgba(8, 145, 178, 0.18);
	}

	.rns-eyebrow {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.rns-recipe-sig {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	.rns-recipe-sub {
		font-size: 0.7rem;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	.rns-recipe-sub :global(code) {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.66rem;
		background: transparent;
		padding: 0;
		color: inherit;
	}

	/* ── the two instances: identical treatment, distinct stores ── */
	.rns-component {
		flex: 0 1 auto;
		max-width: 270px;
		gap: 8px;
	}

	.rns-component-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	/* the private state cell each component owns */
	.rns-cell {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1px;
		width: 100%;
		padding: 7px 10px;
		border-radius: 8px;
		border: 1px dashed color-mix(in srgb, #0891b2 40%, var(--sl-color-gray-4));
		background: color-mix(in srgb, #0891b2 6%, var(--sl-color-bg));
		margin: 0;
	}

	.rns-cell-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.72rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}

	.rns-cell-note {
		font-size: 0.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	@media (max-width: 560px) {
		.rns-row-instances {
			flex-direction: column;
			align-items: center;
			gap: 16px;
		}

		.rns-component {
			width: 100%;
			max-width: 300px;
		}
	}
</style>
