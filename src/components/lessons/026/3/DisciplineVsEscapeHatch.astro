---
// discipline-vs-escape-hatch — Chapter 026 Lesson 3, "Memoization as escape hatch".
//
// The recalibration of the whole lesson, made visual: same surface area, opposite
// defaults. Two equal-width columns side by side.
//
//   ┌ 2020 — discipline ───────┐   ┌ 2026 — escape hatch ─────┐
//   │ ▦ useMemo everywhere      │   │ ✓ reach only on a cause   │
//   │ ▦ useCallback everywhere  │   │                           │
//   │ ▦ memo every leaf         │   │      (mostly empty)       │
//   │ ▦ dynamic() for "heavy"   │   │                           │
//   │ ▦ <Suspense> around all   │   │                           │
//   └───────────────────────────┘   └───────────────────────────┘
//
// The LEFT column is a dense, crowded stack of five chips in a muted amber tint
// (reads as "noise / ceremony"). The RIGHT column carries a SINGLE chip near the
// top in saturated green (reads as "intentional"), and the rest is deliberate
// whitespace. The two columns are pinned to the SAME width and the SAME height
// (align-items: stretch makes the short right column match the tall left one),
// so the contrast in *fill* is the message: the right column's emptiness IS the
// recalibration.
//
// Plain HTML + CSS, inline styles only, devtools-inspectable — matches the
// course's other annotated-illustration figures (EffectAuditShelf / ReactRights-
// Panel): a `not-content` wrapper, a `margin: 0` reset on every inner node to
// defeat Starlight's prose-margin selector, theme-aware Starlight gray variables
// for chrome, and saturated 600-range fills (read in light + dark) where color
// carries meaning — amber for "noise", green for "intentional". No graph engine —
// per the diagram index, an annotated illustration is plain HTML+CSS.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--sl-font-system-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

const NOISE = "#d97706"; // amber-600 — the "ceremony / noise" color, reads in both themes
const KEEP = "#16a34a"; // green-600 — the "intentional reach" color, reads in both themes

// LEFT column — the 2020 discipline: a wrapper for everything. `code` is the API
// or primitive (monospace); `where` is the blanket scope it was applied to.
const discipline = [
  { code: "useMemo", where: "on every derived value" },
  { code: "useCallback", where: "on every handler" },
  { code: "memo", where: "on every leaf component" },
  { code: "dynamic()", where: 'for anything "heavy"' },
  { code: "<Suspense>", where: "around everything" },
];

// ---- styles -------------------------------------------------------------

// Two columns side by side, EQUAL width (flex: 1 1 0 + equal flex-basis), and
// align-items: stretch so both share the taller column's height. Wraps on a
// narrow figure card so the right column drops below the left instead of
// overflowing.
const root = [
  reset,
  sans,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "gap: 16px",
  "width: 100%",
  "max-width: 720px",
  "margin: 0 auto",
  "box-sizing: border-box",
].join("; ");

// A column card. `accent` picks the color of the chrome (amber vs green).
const column = (color: string) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "flex: 1 1 280px", // equal flex-basis → equal width when both fit one row
    "min-width: 0",
    "border-radius: 12px",
    "box-sizing: border-box",
    "overflow: hidden",
    "border: 1px solid color-mix(in srgb, " + color + " 45%, transparent)",
    "background: color-mix(in srgb, " + color + " 7%, transparent)",
  ].join("; ");

// Column heading bar — the era + its stance.
const headBar = (color: string) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "gap: 2px",
    "padding: 9px 13px",
    "box-sizing: border-box",
    "border-bottom: 1px solid color-mix(in srgb, " + color + " 30%, transparent)",
    "background: color-mix(in srgb, " + color + " 11%, transparent)",
  ].join("; ");

const headEra = (color: string) =>
  [
    reset,
    sans,
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.06em",
    "text-transform: uppercase",
    "line-height: 1.2",
    "color: " + color,
  ].join("; ");

const headStance = [
  reset,
  sans,
  "font-size: 13.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

// The body that holds the chips. flex: 1 lets it absorb the column's extra
// height; on the RIGHT that produces the intentional empty space below the chip.
const body = [
  reset,
  "display: flex",
  "flex-direction: column",
  "flex: 1 1 auto",
  "gap: 8px",
  "padding: 12px",
  "box-sizing: border-box",
].join("; ");

// One chip — a small rounded pill. `color` tints its border/fill.
const chip = (color: string) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "gap: 9px",
    "padding: 8px 11px",
    "border-radius: 8px",
    "box-sizing: border-box",
    "border: 1px solid color-mix(in srgb, " + color + " 40%, transparent)",
    "background: color-mix(in srgb, " + color + " 14%, transparent)",
  ].join("; ");

// The icon tile at the start of each chip.
const chipIcon = (color: string) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "flex: none",
    "width: 22px",
    "height: 22px",
    "border-radius: 6px",
    "background: " + color,
    "color: #ffffff",
  ].join("; ");

// The chip's text: a monospace API token + a quiet scope label.
const chipTextWrap = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: baseline",
  "gap: 1px 7px",
  "min-width: 0",
].join("; ");

const chipCode = [
  reset,
  mono,
  "flex: none",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: var(--sl-color-white)",
].join("; ");

const chipWhere = [
  reset,
  sans,
  "flex: 1 1 auto",
  "min-width: 0",
  "font-size: 11.5px",
  "font-weight: 400",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// On the RIGHT, the single green chip carries a fuller justification, so its
// text stacks (cause on its own line) rather than sitting inline.
const reachTextWrap = [reset, "display: flex", "flex-direction: column", "gap: 1px", "min-width: 0"].join("; ");

const reachTitle = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.25",
  "color: var(--sl-color-white)",
].join("; ");

const reachSub = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-weight: 400",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// A faint "(empty by default)" watermark filling the RIGHT column's whitespace,
// so the void reads as intentional rather than as a broken/cut-off layout.
const emptyNote = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "flex: 1 1 auto",
  "min-height: 64px",
  "font-size: 12px",
  "font-style: italic",
  "font-weight: 500",
  "line-height: 1.3",
  "text-align: center",
  "color: var(--sl-color-gray-4)",
].join("; ");

// Shared SVG attrs for the chip glyphs.
const iconAttrs = {
  width: "13",
  height: "13",
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "2.5",
  "stroke-linecap": "round" as const,
  "stroke-linejoin": "round" as const,
  "aria-hidden": "true",
  style: "margin: 0; display: block;",
};
---

<div class="not-content" style={root}>
  {/* LEFT — 2020: memoization as discipline. A crowded amber stack. */}
  <div style={column(NOISE)}>
    <div style={headBar(NOISE)}>
      <span style={headEra(NOISE)}>2020</span>
      <span style={headStance}>memoization as discipline</span>
    </div>
    <div style={body}>
      {
        discipline.map((d) => (
          <div style={chip(NOISE)}>
            <span style={chipIcon(NOISE)}>
              {/* wrapping-paper / package glyph — "wrap everything" */}
              <svg {...iconAttrs}>
                <rect x="3" y="8" width="18" height="13" rx="1" />
                <path d="M3 12h18" />
                <path d="M12 8v13" />
                <path d="M12 8c-1.5-3-5-3-5-1s3.5 1 5 1Z" />
                <path d="M12 8c1.5-3 5-3 5-1s-3.5 1-5 1Z" />
              </svg>
            </span>
            <span style={chipTextWrap}>
              <span style={chipCode}>{d.code}</span>
              <span style={chipWhere}>{d.where}</span>
            </span>
          </div>
        ))
      }
    </div>
  </div>

  {/* RIGHT — 2026: escape hatch. A single green chip, the rest intentional void. */}
  <div style={column(KEEP)}>
    <div style={headBar(KEEP)}>
      <span style={headEra(KEEP)}>2026</span>
      <span style={headStance}>escape hatch</span>
    </div>
    <div style={body}>
      <div style={chip(KEEP)}>
        <span style={chipIcon(KEEP)}>
          {/* check glyph — "the one intentional, justified reach" */}
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#ffffff"
            stroke-width="3.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            style="margin: 0; display: block;"
          >
            <polyline points="4 12 10 18 20 6" />
          </svg>
        </span>
        <span style={reachTextWrap}>
          <span style={reachTitle}>reach only on a measured or contractual cause</span>
          <span style={reachSub}>+ a one-line comment naming it</span>
        </span>
      </div>
      <div style={emptyNote}>everything else: no wrapper</div>
    </div>
  </div>
</div>
