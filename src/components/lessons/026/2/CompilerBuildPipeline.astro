---
// One frame of the React Compiler build pipeline, scrubbed inside a
// <DiagramSequence>. The lesson's load-bearing point is that the compiler is a
// BUILD-TIME tool: it runs once during the build, and what ships is ordinary
// memoized React — no runtime engine. The sequence makes that timeline visible.
//
// Layout, fixed for the whole sequence so nothing jumps as you scrub:
//   - A top RAIL of four phase chips — the pipeline left to right:
//       Your source → SWC selects → Babel transforms → Shipped output
//     The active phase is filled (blue-600 / white); the rest are muted. The
//     rail never changes shape, so the reader always knows where in the build
//     they are.
//   - A DETAIL panel below the rail that swaps per step and tells that phase's
//     story (file boxes, annotated body, the shipped box).
//
// `step` (1–4) selects the frame; source order in the MDX = scrub order.
//
// Pure HTML + CSS like the chapter's other figures: `not-content` wrapper,
// theme gray variables for chrome, saturated mid-tones (blue-600 for the
// pipeline/selection, green-600 for the auto-inserted "memoized" tags) with
// white text so the colors read in light and dark, and a `margin: 0` reset on
// every inner element to defeat Starlight's prose-margin selector.

interface Props {
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = 'margin: 0';
const mono =
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = 'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';

const ACCENT = '#2563eb'; // blue-600  — the pipeline + "selected" signal
const MEMO = '#16a34a'; // green-600 — the auto-inserted memoization signal

// ---- the fixed pipeline rail -------------------------------------------

const PHASES = [
  { key: 1, label: 'Your source' },
  { key: 2, label: 'SWC selects' },
  { key: 3, label: 'Babel transforms' },
  { key: 4, label: 'Shipped output' },
] as const;

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  'display: flex',
  'flex-direction: column',
  'gap: 16px',
  'width: 100%',
  'max-width: 660px',
  'margin-left: auto',
  'margin-right: auto',
  'box-sizing: border-box',
  sans,
].join('; ');

// The rail: a row of phase chips separated by chevrons. Wraps gracefully on a
// narrow card (row-gap > column-gap so wrapped rows stay separated).
const rail = [
  reset,
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'justify-content: center',
  'column-gap: 4px',
  'row-gap: 8px',
].join('; ');

const phaseChip = (active: boolean) => {
  const base = [
    reset,
    sans,
    'box-sizing: border-box',
    'padding: 6px 12px',
    'border-radius: 8px',
    'font-size: 12.5px',
    'line-height: 1.15',
    'white-space: nowrap',
  ];
  if (active) {
    return [
      ...base,
      'font-weight: 700',
      `background: ${ACCENT}`,
      `border: 1.5px solid ${ACCENT}`,
      'color: var(--sl-color-white)',
    ].join('; ');
  }
  return [
    ...base,
    'font-weight: 500',
    'background: var(--sl-color-bg)',
    'border: 1.5px solid var(--sl-color-gray-5)',
    'color: var(--sl-color-gray-3)',
  ].join('; ');
};

const chevron = [
  reset,
  'font-size: 13px',
  'line-height: 1',
  'color: var(--sl-color-gray-4)',
].join('; ');

// The detail panel — a dashed-bordered stage the per-step content sits in.
const stage = [
  reset,
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'gap: 14px',
  'padding: 16px',
  'border-radius: 10px',
  'border: 1px dashed var(--sl-color-hairline)',
  'background: var(--sl-color-gray-6)',
  'box-sizing: border-box',
  'min-height: 168px',
].join('; ');

// A file "box" — a titled card holding a code fragment or note.
type FileTone = 'plain' | 'selected' | 'skipped';

const fileBox = (tone: FileTone) => {
  const base = [
    reset,
    'display: flex',
    'flex-direction: column',
    'box-sizing: border-box',
    'width: 286px',
    'max-width: 100%',
    'border-radius: 9px',
    'overflow: hidden',
  ];
  if (tone === 'selected') {
    return [
      ...base,
      `border: 2px solid ${ACCENT}`,
      'background: var(--sl-color-bg)',
      `box-shadow: 0 0 0 4px color-mix(in srgb, ${ACCENT} 14%, transparent)`,
    ].join('; ');
  }
  if (tone === 'skipped') {
    return [
      ...base,
      'border: 1.5px dashed var(--sl-color-gray-4)',
      'background: var(--sl-color-gray-6)',
      'opacity: 0.55',
    ].join('; ');
  }
  return [
    ...base,
    'border: 1.5px solid var(--sl-color-gray-5)',
    'background: var(--sl-color-bg)',
  ].join('; ');
};

const fileHeader = (tone: FileTone) => {
  const base = [
    reset,
    mono,
    'display: flex',
    'align-items: center',
    'gap: 6px',
    'padding: 6px 10px',
    'font-size: 11.5px',
    'font-weight: 600',
    'line-height: 1.2',
    'border-bottom: 1px solid var(--sl-color-hairline)',
  ];
  if (tone === 'selected') {
    return [
      ...base,
      `background: color-mix(in srgb, ${ACCENT} 12%, var(--sl-color-bg))`,
      `color: color-mix(in srgb, ${ACCENT} 78%, var(--sl-color-text))`,
    ].join('; ');
  }
  if (tone === 'skipped') {
    return [
      ...base,
      'background: var(--sl-color-gray-6)',
      'color: var(--sl-color-gray-3)',
      'text-decoration: line-through',
    ].join('; ');
  }
  return [
    ...base,
    'background: var(--sl-color-gray-6)',
    'color: var(--sl-color-text-accent)',
  ].join('; ');
};

// A status chip pinned to a file box header (selected / skipped).
const fileChip = (tone: 'selected' | 'skipped') => {
  const sel = tone === 'selected';
  return [
    reset,
    sans,
    'margin-left: auto',
    'padding: 1px 7px',
    'border-radius: 999px',
    'font-size: 9px',
    'font-weight: 700',
    'letter-spacing: 0.04em',
    'text-transform: uppercase',
    'line-height: 1.4',
    'white-space: nowrap',
    sel ? `background: ${ACCENT}` : 'background: var(--sl-color-gray-5)',
    sel ? 'color: var(--sl-color-white)' : 'color: var(--sl-color-gray-2)',
    sel ? `border: 1px solid ${ACCENT}` : 'border: 1px solid var(--sl-color-gray-4)',
  ].join('; ');
};

const codeBody = [
  reset,
  mono,
  'padding: 9px 10px',
  'font-size: 11px',
  'line-height: 1.55',
  'white-space: pre',
  'overflow-x: auto',
  'color: var(--sl-color-text)',
].join('; ');

// A code line that may carry a green "memoized" tag (step 3).
const codeLine = [
  reset,
  mono,
  'display: flex',
  'align-items: center',
  'gap: 8px',
  'font-size: 11px',
  'line-height: 1.7',
  'white-space: pre',
].join('; ');

const memoTag = [
  reset,
  sans,
  'display: inline-flex',
  'align-items: center',
  'gap: 3px',
  'padding: 0 6px',
  'border-radius: 999px',
  'font-size: 9px',
  'font-weight: 700',
  'letter-spacing: 0.03em',
  'text-transform: uppercase',
  'line-height: 1.5',
  'white-space: nowrap',
  `background: color-mix(in srgb, ${MEMO} 16%, var(--sl-color-bg))`,
  `color: color-mix(in srgb, ${MEMO} 72%, var(--sl-color-text))`,
  `border: 1px solid color-mix(in srgb, ${MEMO} 45%, transparent)`,
].join('; ');

// The empty-line spacer that keeps the green-tagged lines aligned with the
// plain code box (so the body height is constant across steps).
const plainLine = [reset, mono, 'font-size: 11px', 'line-height: 1.7', 'white-space: pre'].join(
  '; ',
);

// The shipped-output box (step 4).
const shippedBox = [
  reset,
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 8px',
  'box-sizing: border-box',
  'width: 320px',
  'max-width: 100%',
  'padding: 22px 18px',
  'border-radius: 10px',
  `border: 2px solid ${ACCENT}`,
  `background: color-mix(in srgb, ${ACCENT} 10%, var(--sl-color-bg))`,
].join('; ');

const shippedTitle = [
  reset,
  sans,
  'font-size: 15px',
  'font-weight: 700',
  'line-height: 1.2',
  'text-align: center',
  `color: color-mix(in srgb, ${ACCENT} 72%, var(--sl-color-text))`,
].join('; ');

const shippedNote = [
  reset,
  sans,
  'display: inline-flex',
  'align-items: center',
  'gap: 4px',
  'padding: 2px 9px',
  'border-radius: 999px',
  'font-size: 10.5px',
  'font-weight: 600',
  'line-height: 1.4',
  'background: var(--sl-color-gray-6)',
  'color: var(--sl-color-gray-2)',
  'border: 1px solid var(--sl-color-gray-5)',
].join('; ');

// The source fragment, shared by steps 1 and 2 (rendered as plain text).
const SOURCE = `const CartSummary = ({ items }) => {
  const total = items.reduce(
    (sum, i) => sum + i.price, 0);
  return <button onClick={() =>
    checkout(total)}>Pay {total}</button>;
};`;
---

<div class="not-content" style={root}>
  {/* Fixed pipeline rail — the active phase is the only thing that changes. */}
  <div style={rail}>
    {
      PHASES.map((p, i) => (
        <>
          <span style={phaseChip(p.key === step)}>{p.label}</span>
          {i < PHASES.length - 1 && (
            <span style={chevron} aria-hidden="true">
              {'›'}
            </span>
          )}
        </>
      ))
    }
  </div>

  {/* Per-step detail panel. */}
  <div style={stage}>
    {
      (step === 1 || step === 2) && (
        <>
          <div style={fileBox(step === 2 ? 'selected' : 'plain')}>
            <div style={fileHeader(step === 2 ? 'selected' : 'plain')}>
              <span>CartSummary.tsx</span>
              {step === 2 && <span style={fileChip('selected')}>selected</span>}
            </div>
            <pre style={codeBody} set:html={SOURCE.replace(/</g, '&lt;')} />
          </div>

          <div style={fileBox(step === 2 ? 'skipped' : 'plain')}>
            <div style={fileHeader(step === 2 ? 'skipped' : 'plain')}>
              <span>format-currency.ts</span>
              {step === 2 && <span style={fileChip('skipped')}>skipped</span>}
            </div>
            <pre
              style={codeBody}
              set:html={'export const format = (n) =>\n  `$${n.toFixed(2)}`;'}
            />
          </div>
        </>
      )
    }

    {
      step === 3 && (
        <div style={fileBox('selected')}>
          <div style={fileHeader('selected')}>
            <span>CartSummary.tsx</span>
            <span style={fileChip('selected')}>transformed</span>
          </div>
          <div style={`${reset}; padding: 9px 10px;`}>
            <div style={plainLine} set:html={'const CartSummary = ({ items }) =&gt; {'} />
            <div style={codeLine}>
              <span set:html={'  const total = …'} />
              <span style={memoTag}>{'✨'} memoized</span>
            </div>
            <div style={plainLine} set:html={'  return (' } />
            <div style={codeLine}>
              <span set:html={'    &lt;button onClick={…}&gt;'} />
              <span style={memoTag}>{'✨'} memoized</span>
            </div>
            <div style={plainLine} set:html={'  );'} />
            <div style={plainLine} set:html={'};'} />
          </div>
        </div>
      )
    }

    {
      step === 4 && (
        <div style={shippedBox}>
          <span style={shippedTitle}>Ordinary memoized React</span>
          <span style={shippedNote}>same runtime behavior</span>
        </div>
      )
    }
  </div>
</div>
