---
// Two-message-types boundary — makes the rich/lossy asymmetry spatial.
//
// LEFT box ("App world") is deliberately fuller: the UIMessage shape plus four
// pills for the kinds of things `parts` can hold (text / reasoning / tool call /
// metadata). RIGHT box ("Model world") is deliberately sparser: ModelMessage is
// just role + text, so it carries one or two pills only and reads emptier.
//
// The SEAM between them carries the two converters as stacked, labeled arrows —
// convertToModelMessages() points right (collapse to lossy), toUIMessageStream-
// Response() points left (stream parts back) — with a "server" tag pinning the
// conversion to the server side.
//
// Pure HTML + CSS in the chapter's house style: a `not-content` wrapper, style
// arrays joined with "; ", theme gray variables for chrome, two saturated mid-
// tones (rich = teal, lossy = slate), and a `margin: 0` reset on every inner
// element to defeat Starlight's prose-margin selector.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Rich vs. lossy accent. App world (rich) = teal-600; Model world (lossy) =
// slate-500. Both read on light + dark; the muted slate makes the right box
// feel intentionally plainer than the saturated teal on the left.
const RICH = "#0d9488"; // teal-600 — the rich, app-owned shape
const LOSSY = "#64748b"; // slate-500 — the lossy, model-only shape

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 0",
  "row-gap: 18px",
  "width: 100%",
  "max-width: 760px",
  "box-sizing: border-box",
  sans,
].join("; ");

// A world box. `accent` tints the title + border; `fill` is how saturated the
// header band reads. The left box gets more body content, so it grows taller —
// `align-items: stretch` on the row keeps the seam column matching its height.
const box = (accent: string) =>
  [
    reset,
    "flex: 1 1 240px",
    "min-width: 220px",
    "display: flex",
    "flex-direction: column",
    "gap: 10px",
    "padding: 14px 16px 16px",
    "border-radius: 12px",
    "border: 1px solid " + `color-mix(in srgb, ${accent} 45%, var(--sl-color-gray-4))`,
    "background: var(--sl-color-gray-6)",
    "box-sizing: border-box",
  ].join("; ");

const title = (accent: string) =>
  [
    reset,
    sans,
    "font-size: 15px",
    "font-weight: 700",
    "line-height: 1.1",
    "color: " + `color-mix(in srgb, ${accent} 72%, var(--sl-color-white))`,
  ].join("; ");

const subtitle = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "letter-spacing: 0.01em",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The message-shape line, rendered monospace so it reads as a type literal.
const shape = (accent: string) =>
  [
    reset,
    mono,
    "display: block",
    "width: fit-content",
    "padding: 4px 9px",
    "border-radius: 7px",
    "border: 1px solid " + `color-mix(in srgb, ${accent} 35%, transparent)`,
    "background: " + `color-mix(in srgb, ${accent} 12%, transparent)`,
    "color: " + `color-mix(in srgb, ${accent} 80%, var(--sl-color-white))`,
    "font-size: 12.5px",
    "font-weight: 600",
    "line-height: 1.2",
  ].join("; ");

// "parts can hold:" / "all flattened to:" caption above the pill row.
const partsLabel = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
  "margin: 4px 0 0",
].join("; ");

const pillRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "gap: 6px",
].join("; ");

// A "kind of part" pill. The app world carries several (text / reasoning /
// tool call / metadata); the model world carries one or two so the asymmetry
// is literal.
const pill = (accent: string) =>
  [
    reset,
    sans,
    "display: inline-block",
    "padding: 3px 9px",
    "border-radius: 999px",
    "border: 1px solid " + `color-mix(in srgb, ${accent} 40%, var(--sl-color-gray-4))`,
    "background: " + `color-mix(in srgb, ${accent} 16%, transparent)`,
    "color: " + `color-mix(in srgb, ${accent} 70%, var(--sl-color-white))`,
    "font-size: 11.5px",
    "font-weight: 600",
    "line-height: 1.2",
    "white-space: nowrap",
  ].join("; ");

// ---- the seam (center column) ------------------------------------------

// The seam column holds the two arrows and the server tag. On wide viewports it
// sits between the boxes; when the row wraps it drops below, still legible.
const seam = [
  reset,
  "flex: 0 1 188px",
  "min-width: 168px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 10px",
  "padding: 0 6px",
  "box-sizing: border-box",
].join("; ");

const serverTag = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "padding: 3px 10px",
  "border-radius: 999px",
  "border: 1px dashed var(--sl-color-gray-3)",
  "background: var(--sl-color-bg-sidebar)",
  "color: var(--sl-color-gray-2)",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1",
  "white-space: nowrap",
].join("; ");

// One arrow: a labeled bar with a head. `dir` is "right" | "left"; `accent`
// tints it to the world it produces (collapse-to-lossy = slate, parts-back =
// teal). The bar is a thin line, the head a CSS triangle on the pointing end.
const arrowWrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 3px",
  "width: 100%",
].join("; ");

const arrowLabel = (accent: string) =>
  [
    reset,
    mono,
    "font-size: 11px",
    "font-weight: 600",
    "line-height: 1.2",
    "text-align: center",
    "color: " + `color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
    "white-space: nowrap",
  ].join("; ");

const arrowSub = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 600",
  "line-height: 1.1",
  "text-align: center",
  "color: var(--sl-color-gray-3)",
].join("; ");

const arrowLine = (accent: string, dir: "right" | "left") => {
  const head =
    dir === "right"
      ? `border-width: 5px 0 5px 8px; border-color: transparent transparent transparent ${accent}; margin-left: -1px;`
      : `border-width: 5px 8px 5px 0; border-color: transparent ${accent} transparent transparent; margin-right: -1px;`;
  return { head, dir, accent };
};

const RIGHT = arrowLine(LOSSY, "right");
const LEFT = arrowLine(RICH, "left");

const lineBar = (accent: string) =>
  [
    reset,
    "flex: 1 1 auto",
    "height: 2px",
    "background: " + `color-mix(in srgb, ${accent} 60%, var(--sl-color-gray-4))`,
  ].join("; ");

const triangle = [reset, "width: 0", "height: 0", "border-style: solid"].join(
  "; ",
);

const trackRow = [
  reset,
  "display: flex",
  "align-items: center",
  "width: 100%",
].join("; ");
---

<div class="not-content" style={root}>
  {/* LEFT — App world (rich) */}
  <div style={box(RICH)}>
    <p style={title(RICH)}>App world</p>
    <p style={subtitle}>stored in the DB · rendered in React</p>
    <code style={shape(RICH)}>{"{ id, role, parts }"}</code>
    <p style={partsLabel}>parts can hold:</p>
    <div style={pillRow}>
      <span style={pill(RICH)}>text</span>
      <span style={pill(RICH)}>reasoning</span>
      <span style={pill(RICH)}>tool call</span>
      <span style={pill(RICH)}>metadata</span>
    </div>
  </div>

  {/* SEAM — the two converters live on the server */}
  <div style={seam}>
    <div style={arrowWrap}>
      <span style={arrowLabel(LOSSY)}>convertToModelMessages()</span>
      <div style={trackRow}>
        <div style={lineBar(LOSSY)}></div>
        <div style={`${triangle}; ${RIGHT.head}`}></div>
      </div>
      <span style={arrowSub}>collapse to lossy</span>
    </div>

    <span style={serverTag}>server</span>

    <div style={arrowWrap}>
      <span style={arrowSub}>stream parts back</span>
      <div style={trackRow}>
        <div style={`${triangle}; ${LEFT.head}`}></div>
        <div style={lineBar(RICH)}></div>
      </div>
      <span style={arrowLabel(RICH)}>toUIMessageStreamResponse()</span>
    </div>
  </div>

  {/* RIGHT — Model world (lossy) */}
  <div style={box(LOSSY)}>
    <p style={title(LOSSY)}>Model world</p>
    <p style={subtitle}>all the model ever reads</p>
    <code style={shape(LOSSY)}>{"role + text"}</code>
    <p style={partsLabel}>all flattened to:</p>
    <div style={pillRow}>
      <span style={pill(LOSSY)}>text</span>
    </div>
  </div>
</div>
