---
// useObject fills in field by field — one card, three populated states.
//
// This is the BODY of a single DiagramSequence step. The same card is rendered
// three times (filled = 1, 2, 3); scrubbing the slider plays "the DeepPartial
// builds up": description lands first, then quantity, then unitAmount.
//
// The card mocks the rendered output of the LineItemExtractor component from the
// lesson — a heading and three labeled rows (Description / Qty / Unit amount).
// Each row holds a FIXED-HEIGHT value slot: when the field has streamed in it
// shows the value, otherwise a skeleton bar occupies the exact same space, so
// the card never resizes between steps. Filled rows also flip a small dot from
// "pending" (hollow) to "landed" (solid accent), and the most-recently-arrived
// row gets a soft highlight so the eye tracks what just filled in.
//
// `filled` (1..3) is the only prop — how many of the three fields have arrived.
//
// Pure HTML + CSS in the chapter's house style: style arrays joined with "; ",
// theme gray variables for chrome, a margin reset on inner elements, and a
// single saturated accent (violet — distinct from TwoMessageTypes' teal/slate).

interface Props {
  filled: 1 | 2 | 3;
}

const { filled } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const ACCENT = "#7c3aed"; // violet-600 — "this field has landed"

// The three fields, in stream order. `skeletonWidth` keeps each skeleton bar a
// plausible length so the placeholder reads like real content is coming.
const fields = [
  { label: "Description", value: "Annual support plan", skeletonWidth: "70%" },
  { label: "Qty", value: "1", skeletonWidth: "22%" },
  { label: "Unit amount", value: "$2,400.00", skeletonWidth: "42%" },
] as const;

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "justify-content: center",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// The card itself — fixed-ish width so all three steps frame identically.
const card = [
  reset,
  "width: 100%",
  "max-width: 380px",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "padding: 16px 18px 18px",
  "border-radius: 14px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "box-shadow: 0 1px 3px color-mix(in srgb, var(--sl-color-black) 12%, transparent)",
  "box-sizing: border-box",
].join("; ");

const cardHead = [
  reset,
  "display: flex",
  "align-items: baseline",
  "justify-content: space-between",
  "gap: 10px",
  "padding-bottom: 10px",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
].join("; ");

const heading = [
  reset,
  sans,
  "font-size: 15px",
  "font-weight: 700",
  "line-height: 1.1",
  "color: var(--sl-color-white)",
].join("; ");

// "2 / 3 fields" progress tag in the header.
const progress = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 3px 8px",
  "border-radius: 999px",
  "border: 1px solid " + `color-mix(in srgb, ${ACCENT} 35%, var(--sl-color-gray-4))`,
  "background: " + `color-mix(in srgb, ${ACCENT} 12%, transparent)`,
  "color: " + `color-mix(in srgb, ${ACCENT} 75%, var(--sl-color-white))`,
  "white-space: nowrap",
].join("; ");

// One row. When `isLatest`, give it a soft accent wash so the just-arrived field
// pops; pending rows read flat.
const row = (isFilled: boolean, isLatest: boolean) =>
  [
    reset,
    "display: grid",
    "grid-template-columns: 16px 96px 1fr",
    "align-items: center",
    "gap: 10px",
    "padding: 8px 10px",
    "border-radius: 9px",
    "background: " +
      (isLatest
        ? `color-mix(in srgb, ${ACCENT} 12%, transparent)`
        : "transparent"),
    "border: 1px solid " +
      (isLatest
        ? `color-mix(in srgb, ${ACCENT} 30%, transparent)`
        : "transparent"),
    "box-sizing: border-box",
  ].join("; ");

// Status dot: solid accent once the field has landed, hollow while pending.
const dot = (isFilled: boolean) =>
  [
    reset,
    "width: 9px",
    "height: 9px",
    "border-radius: 999px",
    "justify-self: center",
    isFilled
      ? "background: " + ACCENT
      : "background: transparent",
    isFilled
      ? "border: 1px solid " + ACCENT
      : "border: 1.5px solid var(--sl-color-gray-4)",
  ].join("; ");

const fieldLabel = (isFilled: boolean) =>
  [
    reset,
    sans,
    "font-size: 12px",
    "font-weight: 600",
    "line-height: 1.2",
    "color: " +
      (isFilled ? "var(--sl-color-gray-2)" : "var(--sl-color-gray-3)"),
  ].join("; ");

const fieldValue = [
  reset,
  mono,
  "font-size: 13.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: var(--sl-color-white)",
].join("; ");

// Skeleton bar — same height as a value line so the row never changes height.
const skeleton = (width: string) =>
  [
    reset,
    "display: block",
    "height: 11px",
    "width: " + width,
    "border-radius: 5px",
    "background: " +
      "repeating-linear-gradient(90deg, var(--sl-color-gray-5) 0 12px, var(--sl-color-gray-4) 12px 24px)",
  ].join("; ");
---

<div class="not-content" style={root}>
  <div style={card}>
    <div style={cardHead}>
      <p style={heading}>Line item</p>
      <span style={progress}>{filled} / 3 fields</span>
    </div>

    {
      fields.map((field, index) => {
        const isFilled = index < filled;
        const isLatest = index === filled - 1;
        return (
          <div style={row(isFilled, isLatest)}>
            <span style={dot(isFilled)}></span>
            <span style={fieldLabel(isFilled)}>{field.label}</span>
            {isFilled ? (
              <span style={fieldValue}>{field.value}</span>
            ) : (
              <span style={skeleton(field.skeletonWidth)}></span>
            )}
          </div>
        );
      })
    }
  </div>
</div>
