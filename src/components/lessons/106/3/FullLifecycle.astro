---
// The full client↔server message lifecycle — the keystone visual of the chapter.
//
// This is the BODY of a single DiagramSequence step. The SAME board is rendered
// seven times (step = 1..7); scrubbing the slider walks one user message through
// every seam — load, mount, type & send, POST, generate, render, persist — and
// then loops back to load. Only the *highlighted* seam changes between steps;
// the skeleton is byte-for-byte identical across all seven so the grid stack
// sizes once and never reflows as the reader scrubs.
//
// Layout: a fixed two-column board.
//   LEFT  — Browser: page.tsx (Server Component shell) → <Chat> (Client Component)
//           → input (useState) → parts render.
//   RIGHT — Server: /api/chat route → authedRoute guards → convertToModelMessages
//           → streamText → toUIMessageStreamResponse + onFinish save.
//   BOTTOM — a DB cylinder spanning the width; the load read and the persist
//           write both touch it.
// Arrows wire the two columns: send (browser → server), stream (server → browser),
// the DB read (DB → page.tsx), the DB write (server → DB), and the loop-back.
//
// `step` (1..7) is the only prop — which seam is currently lit. Everything not on
// the active seam is dimmed; the active node(s) and arrow brighten + get a ring.
//
// Pure HTML + CSS in the chapter's house style: a `not-content` wrapper, style
// arrays joined with "; ", theme gray variables for chrome, a `margin: 0` reset
// on every inner element, and the chapter's established side accents — browser =
// sky-blue, server = violet (matching ServerClientBoundary.astro).

interface Props {
  step: 1 | 2 | 3 | 4 | 5 | 6 | 7;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const BROWSER = "#0284c7"; // sky-600 — the browser side
const SERVER = "#7c3aed"; // violet-600 — the server side
const DB = "#0d9488"; // teal-600 — the database

// ---- which nodes / arrows are lit at each step --------------------------
//
// Node ids:
//   page   — app/chat/page.tsx (Server Component shell)
//   chat   — <Chat> Client Component + useChat
//   input  — the useState input box
//   parts  — the parts render
//   route  — /api/chat route handler
//   guards — authedRoute guards
//   gen    — convertToModelMessages → streamText
//   finish — toUIMessageStreamResponse + onFinish save
//   db     — the database cylinder
//
// Arrow ids:
//   read   — DB → page (load)
//   prop   — page → chat (messages prop)
//   typed  — input → chat (sendMessage)
//   post   — chat → route (POST)
//   guard  — route → guards
//   stream — gen → parts (stream back)
//   gen2finish — gen → finish (internal)
//   write  — finish → DB (persist)
//   loop   — finish/DB → page (next load)
const litNodes: Record<number, string[]> = {
  1: ["page", "db"],
  2: ["chat"],
  3: ["input", "chat"],
  4: ["chat", "route", "guards"],
  5: ["gen", "parts"],
  6: ["parts", "chat"],
  7: ["finish", "db", "page"],
};

const litArrows: Record<number, string[]> = {
  1: ["read", "prop"],
  2: [],
  3: ["typed"],
  4: ["post", "guard"],
  5: ["stream"],
  6: ["stream"],
  7: ["write", "loop"],
};

const nodeOn = (id: string) => litNodes[step]?.includes(id) ?? false;
const arrowOn = (id: string) => litArrows[step]?.includes(id) ?? false;

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 14px",
  "width: 100%",
  "max-width: 860px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// The two-column board. align-items: stretch keeps the zones equal height so the
// center rail (the cross-arrows) lines up regardless of which side is taller.
const board = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "gap: 12px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// A tinted side zone (browser / server). The label band names the side.
const zone = (accent: string) =>
  [
    reset,
    "flex: 1 1 280px",
    "min-width: 250px",
    "display: flex",
    "flex-direction: column",
    "gap: 8px",
    "padding: 12px",
    "border-radius: 14px",
    "border: 1px solid " +
      `color-mix(in srgb, ${accent} 32%, var(--sl-color-gray-4))`,
    "background: " + `color-mix(in srgb, ${accent} 6%, var(--sl-color-gray-6))`,
    "box-sizing: border-box",
  ].join("; ");

const zoneLabel = (accent: string) =>
  [
    reset,
    sans,
    "align-self: flex-start",
    "padding: 3px 10px",
    "border-radius: 999px",
    "border: 1px solid " + `color-mix(in srgb, ${accent} 45%, transparent)`,
    "background: " + `color-mix(in srgb, ${accent} 13%, transparent)`,
    "color: " + `color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
    "font-size: 10.5px",
    "font-weight: 700",
    "letter-spacing: 0.05em",
    "text-transform: uppercase",
    "line-height: 1",
    "white-space: nowrap",
  ].join("; ");

// A node box. `on` brightens it (full opacity, accent ring, accent-tinted bg);
// off nodes dim back so the active seam reads at a glance.
const node = (accent: string, on: boolean) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "gap: 3px",
    "padding: 9px 11px",
    "border-radius: 9px",
    "border: 1px solid " +
      (on
        ? accent
        : `color-mix(in srgb, ${accent} 22%, var(--sl-color-gray-4))`),
    "background: " +
      (on
        ? `color-mix(in srgb, ${accent} 15%, var(--sl-color-bg))`
        : "var(--sl-color-bg)"),
    "box-shadow: " +
      (on ? `0 0 0 2px color-mix(in srgb, ${accent} 28%, transparent)` : "none"),
    "opacity: " + (on ? "1" : "0.42"),
    "transition: opacity 0.15s, box-shadow 0.15s",
    "box-sizing: border-box",
  ].join("; ");

const nodeName = (accent: string, on: boolean) =>
  [
    reset,
    mono,
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.2",
    "color: " +
      (on
        ? `color-mix(in srgb, ${accent} 82%, var(--sl-color-white))`
        : "var(--sl-color-gray-2)"),
  ].join("; ");

const nodeSub = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// A small connector arrow drawn INSIDE a zone (between two stacked nodes).
const downRail = (accent: string, on: boolean) =>
  [
    reset,
    "align-self: center",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "line-height: 0.7",
    "font-size: 14px",
    "opacity: " + (on ? "1" : "0.3"),
    "color: " +
      (on
        ? accent
        : `color-mix(in srgb, ${accent} 50%, var(--sl-color-gray-3))`),
    "transition: opacity 0.15s",
  ].join("; ");

const railLabel = (accent: string, on: boolean) =>
  [
    reset,
    mono,
    "font-size: 9.5px",
    "font-weight: 600",
    "line-height: 1.2",
    "color: " +
      (on ? `color-mix(in srgb, ${accent} 75%, var(--sl-color-white))` : "var(--sl-color-gray-3)"),
    "white-space: nowrap",
  ].join("; ");

// ---- center rail: the cross-column arrows (POST up, stream down) ---------

const rail = [
  reset,
  "flex: 0 1 130px",
  "min-width: 120px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 18px",
  "padding: 4px 0",
  "box-sizing: border-box",
].join("; ");

// One horizontal cross-arrow. `dir` "right" (browser → server) or "left"
// (server → browser). `on` brightens it.
const crossArrow = (accent: string, dir: "right" | "left", on: boolean) => ({
  wrap: [
    reset,
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "gap: 3px",
    "width: 100%",
    "opacity: " + (on ? "1" : "0.32"),
    "transition: opacity 0.15s",
  ].join("; "),
  label: [
    reset,
    mono,
    "font-size: 9.5px",
    "font-weight: 600",
    "line-height: 1.2",
    "text-align: center",
    "color: " +
      (on
        ? `color-mix(in srgb, ${accent} 80%, var(--sl-color-white))`
        : "var(--sl-color-gray-3)"),
    "white-space: nowrap",
  ].join("; "),
  track: [reset, "display: flex", "align-items: center", "width: 100%"].join(
    "; ",
  ),
  bar: [
    reset,
    "flex: 1 1 auto",
    "height: 2px",
    "background: " +
      (on
        ? accent
        : `color-mix(in srgb, ${accent} 45%, var(--sl-color-gray-4))`),
  ].join("; "),
  head:
    dir === "right"
      ? [
          reset,
          "width: 0",
          "height: 0",
          "border-style: solid",
          "border-width: 5px 0 5px 8px",
          `border-color: transparent transparent transparent ${on ? accent : `color-mix(in srgb, ${accent} 45%, var(--sl-color-gray-4))`}`,
          "margin-left: -1px",
        ].join("; ")
      : [
          reset,
          "width: 0",
          "height: 0",
          "border-style: solid",
          "border-width: 5px 8px 5px 0",
          `border-color: transparent ${on ? accent : `color-mix(in srgb, ${accent} 45%, var(--sl-color-gray-4))`} transparent transparent`,
          "margin-right: -1px",
        ].join("; "),
});

const postArrow = crossArrow(BROWSER, "right", arrowOn("post"));
const streamArrow = crossArrow(SERVER, "left", arrowOn("stream"));

// ---- the database cylinder (spans the board bottom) ---------------------

const dbRow = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 6px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// The two vertical connectors from the board down to the DB: read (DB → page,
// left) and write (server → DB, right). Drawn as a row of two labeled stems so
// they sit under their respective columns.
const dbStems = [
  reset,
  "display: flex",
  "justify-content: space-between",
  "align-items: flex-end",
  "width: 100%",
  "max-width: 620px",
  "padding: 0 30px",
  "box-sizing: border-box",
].join("; ");

const stem = (accent: string, on: boolean, dir: "up" | "down") =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "gap: 2px",
    "opacity: " + (on ? "1" : "0.3"),
    "transition: opacity 0.15s",
    "color: " +
      (on ? `color-mix(in srgb, ${accent} 78%, var(--sl-color-white))` : "var(--sl-color-gray-3)"),
  ].join("; ");

const stemLabel = [
  reset,
  mono,
  "font-size: 9.5px",
  "font-weight: 600",
  "line-height: 1.2",
  "white-space: nowrap",
].join("; ");

const stemArrow = [reset, "font-size: 13px", "line-height: 0.8"].join("; ");

const cylinder = (on: boolean) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "gap: 8px",
    "width: 100%",
    "max-width: 360px",
    "padding: 12px 18px",
    "border-radius: 999px",
    "border: 1px solid " +
      (on ? DB : `color-mix(in srgb, ${DB} 25%, var(--sl-color-gray-4))`),
    "background: " +
      (on
        ? `color-mix(in srgb, ${DB} 15%, var(--sl-color-bg))`
        : "var(--sl-color-bg)"),
    "box-shadow: " +
      (on ? `0 0 0 2px color-mix(in srgb, ${DB} 28%, transparent)` : "none"),
    "opacity: " + (on ? "1" : "0.5"),
    "transition: opacity 0.15s, box-shadow 0.15s",
    "box-sizing: border-box",
  ].join("; ");

const cylName = (on: boolean) =>
  [
    reset,
    mono,
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.2",
    "color: " +
      (on ? `color-mix(in srgb, ${DB} 82%, var(--sl-color-white))` : "var(--sl-color-gray-2)"),
  ].join("; ");

const cylSub = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 500",
  "color: var(--sl-color-gray-3)",
].join("; ");

// "next load" loop pill — only meaningful (lit) on the final, persist step.
const loopPill = (on: boolean) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "gap: 5px",
    "padding: 4px 11px",
    "border-radius: 999px",
    "border: 1px dashed " +
      (on ? SERVER : `color-mix(in srgb, ${SERVER} 30%, var(--sl-color-gray-4))`),
    "background: " +
      (on ? `color-mix(in srgb, ${SERVER} 10%, transparent)` : "transparent"),
    "color: " +
      (on ? `color-mix(in srgb, ${SERVER} 78%, var(--sl-color-white))` : "var(--sl-color-gray-3)"),
    "font-size: 10.5px",
    "font-weight: 700",
    "opacity: " + (on ? "1" : "0.35"),
    "transition: opacity 0.15s",
    "white-space: nowrap",
  ].join("; ");
---

<div class="not-content" style={root}>
  <div style={board}>
    {/* ---- BROWSER column --------------------------------------------- */}
    <div style={zone(BROWSER)}>
      <span style={zoneLabel(BROWSER)}>Browser</span>

      <div style={node(BROWSER, nodeOn("page"))}>
        <code style={nodeName(BROWSER, nodeOn("page"))}>page.tsx</code>
        <span style={nodeSub}>Server Component shell</span>
      </div>

      <div style={downRail(BROWSER, arrowOn("prop"))}>
        <span style={railLabel(BROWSER, arrowOn("prop"))}>messages prop</span>
        <span>↓</span>
      </div>

      <div style={node(BROWSER, nodeOn("chat"))}>
        <code style={nodeName(BROWSER, nodeOn("chat"))}>{"<Chat>"} · useChat</code>
        <span style={nodeSub}>Client Component</span>
      </div>

      <div style={downRail(BROWSER, arrowOn("typed"))}>
        <span style={railLabel(BROWSER, arrowOn("typed"))}>sendMessage</span>
        <span>↑</span>
      </div>

      <div style={node(BROWSER, nodeOn("input"))}>
        <code style={nodeName(BROWSER, nodeOn("input"))}>input · useState</code>
        <span style={nodeSub}>plain controlled form</span>
      </div>

      <div style={node(BROWSER, nodeOn("parts"))}>
        <code style={nodeName(BROWSER, nodeOn("parts"))}>parts render</code>
        <span style={nodeSub}>walks message.parts · status</span>
      </div>
    </div>

    {/* ---- CENTER rail: the cross-column arrows ----------------------- */}
    <div style={rail}>
      <div style={postArrow.wrap}>
        <span style={postArrow.label}>POST UIMessage[]</span>
        <div style={postArrow.track}>
          <div style={postArrow.bar}></div>
          <div style={postArrow.head}></div>
        </div>
      </div>

      <div style={streamArrow.wrap}>
        <span style={streamArrow.label}>stream parts</span>
        <div style={streamArrow.track}>
          <div style={streamArrow.head}></div>
          <div style={streamArrow.bar}></div>
        </div>
      </div>
    </div>

    {/* ---- SERVER column ---------------------------------------------- */}
    <div style={zone(SERVER)}>
      <span style={zoneLabel(SERVER)}>Server</span>

      <div style={node(SERVER, nodeOn("route"))}>
        <code style={nodeName(SERVER, nodeOn("route"))}>/api/chat</code>
        <span style={nodeSub}>route handler</span>
      </div>

      <div style={downRail(SERVER, arrowOn("guard"))}>
        <span>↓</span>
      </div>

      <div style={node(SERVER, nodeOn("guards"))}>
        <code style={nodeName(SERVER, nodeOn("guards"))}>authedRoute guards</code>
        <span style={nodeSub}>identity · role · rate limit · quota</span>
      </div>

      <div style={downRail(SERVER, false)}>
        <span>↓</span>
      </div>

      <div style={node(SERVER, nodeOn("gen"))}>
        <code style={nodeName(SERVER, nodeOn("gen"))}>convertToModelMessages</code>
        <span style={nodeSub}>→ streamText</span>
      </div>

      <div style={downRail(SERVER, false)}>
        <span>↓</span>
      </div>

      <div style={node(SERVER, nodeOn("finish"))}>
        <code style={nodeName(SERVER, nodeOn("finish"))}
          >toUIMessageStreamResponse</code
        >
        <span style={nodeSub}>+ onFinish save</span>
      </div>
    </div>
  </div>

  {/* ---- DATABASE row (spans the board bottom) ----------------------- */}
  <div style={dbRow}>
    <div style={dbStems}>
      <div style={stem(DB, arrowOn("read"), "up")}>
        <span style={stemLabel}>read</span>
        <span style={stemArrow}>↑</span>
      </div>
      <div style={stem(DB, arrowOn("write"), "down")}>
        <span style={stemLabel}>save UIMessage[]</span>
        <span style={stemArrow}>↓</span>
      </div>
    </div>

    <div style={cylinder(nodeOn("db"))}>
      <span style={cylName(nodeOn("db"))}>database</span>
      <span style={cylSub}>conversation as UIMessage[]</span>
    </div>

    <span style={loopPill(arrowOn("loop"))}>↺ next load resumes from page.tsx</span>
  </div>
</div>
