---
// Server / Client boundary — the chat page is a Server Component that reads the
// saved conversation from the DB and hands it to the Client Component as ONE
// prop. The whole point is spatial: the durable read happens server-side, and
// the *only* thing that crosses the boundary is the `messages` prop — there is
// no client fetch.
//
// Layout: a left-to-right flow of four cells.
//   1. page.tsx        — Server Component, runs on the server
//   2. getChat(chatId) — Drizzle, org-scoped, reads UIMessage[] from the DB
//   3. the boundary    — a thin vertical divider labelled `messages`, "the only
//                        thing that crosses"
//   4. <Chat>          — Client Component, mounts useChat({ messages })
//
// Cells 1+2 sit in a tinted SERVER zone, cell 4 in a CLIENT zone, and cell 3 is
// the divider where the two meet — so the architectural split reads as a place,
// not just a label. Arrows connect 1 → 2 → (boundary) → 4.
//
// Pure HTML + CSS in the chapter's house style: a `not-content` wrapper, style
// arrays joined with "; ", theme gray variables for chrome, and a `margin: 0`
// reset on every inner element to defeat Starlight's prose-margin selector.
// Accents are picked to NOT collide with TwoMessageTypes.astro (teal / slate):
// server = violet, client = sky-blue.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const SERVER = "#7c3aed"; // violet-600 — server side
const CLIENT = "#0284c7"; // sky-600 — client side

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "gap: 14px",
  "width: 100%",
  "max-width: 820px",
  "box-sizing: border-box",
  sans,
].join("; ");

// A tinted zone (server or client) groups the cells that live on one side. The
// label band sits at the top so the reader can name the side at a glance.
const zone = (accent: string) =>
  [
    reset,
    "flex: 1 1 300px",
    "min-width: 270px",
    "display: flex",
    "flex-direction: column",
    "gap: 10px",
    "padding: 12px",
    "border-radius: 14px",
    "border: 1px solid " +
      `color-mix(in srgb, ${accent} 40%, var(--sl-color-gray-4))`,
    "background: " + `color-mix(in srgb, ${accent} 7%, var(--sl-color-gray-6))`,
    "box-sizing: border-box",
  ].join("; ");

const zoneLabel = (accent: string) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "gap: 6px",
    "align-self: flex-start",
    "padding: 3px 10px",
    "border-radius: 999px",
    "border: 1px solid " + `color-mix(in srgb, ${accent} 45%, transparent)`,
    "background: " + `color-mix(in srgb, ${accent} 14%, transparent)`,
    "color: " + `color-mix(in srgb, ${accent} 78%, var(--sl-color-white))`,
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.05em",
    "text-transform: uppercase",
    "line-height: 1",
    "white-space: nowrap",
  ].join("; ");

// A code cell (page.tsx / getChat / <Chat>). `accent` tints its title + border.
const cell = (accent: string) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "gap: 6px",
    "padding: 11px 13px",
    "border-radius: 10px",
    "border: 1px solid " +
      `color-mix(in srgb, ${accent} 38%, var(--sl-color-gray-4))`,
    "background: var(--sl-color-bg)",
    "box-sizing: border-box",
  ].join("; ");

const cellHead = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "gap: 7px",
].join("; ");

const cellName = (accent: string) =>
  [
    reset,
    mono,
    "font-size: 13px",
    "font-weight: 700",
    "line-height: 1.2",
    "color: " + `color-mix(in srgb, ${accent} 80%, var(--sl-color-white))`,
  ].join("; ");

// Small tag pinned next to the cell name (e.g. "Server Component", "Drizzle").
const tag = (accent: string) =>
  [
    reset,
    sans,
    "display: inline-block",
    "padding: 2px 8px",
    "border-radius: 999px",
    "border: 1px solid " +
      `color-mix(in srgb, ${accent} 35%, var(--sl-color-gray-4))`,
    "background: " + `color-mix(in srgb, ${accent} 12%, transparent)`,
    "color: " + `color-mix(in srgb, ${accent} 70%, var(--sl-color-white))`,
    "font-size: 10.5px",
    "font-weight: 600",
    "line-height: 1.2",
    "white-space: nowrap",
  ].join("; ");

const cellSub = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.35",
  "color: var(--sl-color-gray-2)",
].join("; ");

// A down-arrow between the two cells inside the server zone.
const downArrow = [
  reset,
  sans,
  "align-self: center",
  "font-size: 16px",
  "line-height: 0.7",
  "color: " + `color-mix(in srgb, ${SERVER} 60%, var(--sl-color-gray-3))`,
].join("; ");

// ---- the boundary (center column) --------------------------------------

// The divider is a thin vertical rule with the `messages` prop label clipped to
// it and a right-pointing arrow head, so the prop visibly *crosses* from the
// server zone into the client zone.
const boundary = [
  reset,
  "flex: 0 1 150px",
  "min-width: 140px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 8px",
  "padding: 0 4px",
  "box-sizing: border-box",
].join("; ");

const dividerRule = [
  reset,
  "width: 0",
  "height: 46px",
  "border-left: 2px dashed " +
    `color-mix(in srgb, ${CLIENT} 55%, var(--sl-color-gray-4))`,
].join("; ");

const propPill = [
  reset,
  mono,
  "display: inline-block",
  "padding: 4px 11px",
  "border-radius: 8px",
  "border: 1px solid " + `color-mix(in srgb, ${CLIENT} 45%, transparent)`,
  "background: " + `color-mix(in srgb, ${CLIENT} 13%, var(--sl-color-bg))`,
  "color: " + `color-mix(in srgb, ${CLIENT} 82%, var(--sl-color-white))`,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "white-space: nowrap",
].join("; ");

const crossLabel = [
  reset,
  sans,
  "max-width: 150px",
  "font-size: 10.5px",
  "font-weight: 600",
  "line-height: 1.25",
  "text-align: center",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The crossing arrow: a thin horizontal track with a head pointing right (into
// the client zone).
const crossRow = [
  reset,
  "display: flex",
  "align-items: center",
  "width: 100%",
].join("; ");

const crossBar = [
  reset,
  "flex: 1 1 auto",
  "height: 2px",
  "background: " + `color-mix(in srgb, ${CLIENT} 60%, var(--sl-color-gray-4))`,
].join("; ");

const crossHead = [
  reset,
  "width: 0",
  "height: 0",
  "border-style: solid",
  "border-width: 5px 0 5px 8px",
  `border-color: transparent transparent transparent ${CLIENT}`,
  "margin-left: -1px",
].join("; ");
---

<div class="not-content" style={root}>
  {/* SERVER zone — page.tsx reads the conversation in-process */}
  <div style={zone(SERVER)}>
    <span style={zoneLabel(SERVER)}>Server · runs on the server</span>

    <div style={cell(SERVER)}>
      <div style={cellHead}>
        <code style={cellName(SERVER)}>app/chat/page.tsx</code>
        <span style={tag(SERVER)}>Server Component</span>
      </div>
      <p style={cellSub}>Renders on the server. No browser, no fetch.</p>
    </div>

    <span style={downArrow}>↓</span>

    <div style={cell(SERVER)}>
      <div style={cellHead}>
        <code style={cellName(SERVER)}>getChat(chatId)</code>
        <span style={tag(SERVER)}>Drizzle · org-scoped</span>
      </div>
      <p style={cellSub}>
        Reads <code style={mono + "; font-size: 11.5px"}>UIMessage[]</code> straight
        from the DB.
      </p>
    </div>
  </div>

  {/* BOUNDARY — the one prop that crosses */}
  <div style={boundary}>
    <div style={dividerRule}></div>
    <span style={propPill}>messages</span>
    <span style={crossLabel}>the only thing that crosses</span>
    <div style={crossRow}>
      <div style={crossBar}></div>
      <div style={crossHead}></div>
    </div>
  </div>

  {/* CLIENT zone — the hook hydrates from the prop */}
  <div style={zone(CLIENT)}>
    <span style={zoneLabel(CLIENT)}>Client · runs in the browser</span>

    <div style={cell(CLIENT)}>
      <div style={cellHead}>
        <code style={cellName(CLIENT)}>{"<Chat>"}</code>
        <span style={tag(CLIENT)}>Client Component · 'use client'</span>
      </div>
      <p style={cellSub}>
        Mounts <code style={mono + "; font-size: 11.5px"}
          >useChat({"{ messages }"})</code
        > — the history hydrates, the live stream takes over.
      </p>
    </div>
  </div>
</div>
