---
// The submit lifecycle timeline (diagram id: submit-lifecycle-timeline, Chapter
// 044 L3). The temporal payoff of the lesson: a five-step scrubbable
// DiagramSequence that makes the central claim LITERALLY visible — `state` and
// `isPending` are not three independent values, they are a small state machine
// moving over a single submit. The reader scrubs idle -> submit -> server -> a
// failure result -> a successful resubmit, and watches WHEN each return value
// flips and what the UI does as a result.
//
// Fixed two-zone horizontal motif so the grid stack never reflows as the reader
// scrubs:
//   - LEFT  the FORM — a mock new-invoice form. A constant "Customer email" and
//           "Total" input row, a submit button whose label/enabled state tracks
//           `isPending`, and a field-error line that only appears on the failure
//           beat. The input values carry the story: typed before submit, KEPT on
//           failure, BLANK after the successful resubmit (uncontrolled reset).
//   - RIGHT the HOOK RETURNS — a slate readout card titled with the current phase
//           pill, then two mono rows: `state` and `isPending`, each tinted by its
//           current value (amber while pending / null, green when settled ok,
//           red on the failure result).
//   - a one-line verdict under the row, fixed footprint.
//
// The five beats (idle -> submit -> server -> failure -> resubmit-success):
//   1  Idle. state = null, isPending = false. Button enabled "Save invoice".
//   2  Submit clicked. React serializes FormData and calls the bound action;
//      isPending flips true, the button disables and reads "Saving…".
//   3  Action runs on the server, POST in flight. Still isPending = true; state
//      unchanged because the action hasn't returned.
//   4  Result returns (failure). isPending flips false; state = { ok: false }.
//      The field error renders and the typed values persist.
//   5  Resubmit succeeds. isPending flips true then false; state = { ok: true }.
//      Errors clear; the uncontrolled form resets to blank.
//
// House style follows this arc's UseSuspendLifecycle / StaleFrameSequence: fixed
// slate ink, color-scheme pinned light so the hand-picked amber/green/red tints
// survive dark mode, `margin: 0` on every inner element to defeat Starlight's
// injected prose margins. Every step is the same shape so the grid stack never
// reflows. Per the diagram index this is a temporal sequence the reader scrubs —
// a DiagramSequence — and the panels are plain HTML+CSS.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary card edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)
const FIELD_BG = '#f8fafc'; // input field wash (slate-50)
const DIM_INK = '#94a3b8'; // greyed ink (slate-400)

const GREEN = '#16a34a'; // green-600 — settled, ok, enabled
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const AMBER = '#d97706'; // amber-600 — in flight / not yet settled
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const RED = '#dc2626'; // red-600 — the failure result + field error
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const BLUE = '#2563eb'; // blue-600 — the active phase accent
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all five steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The two-zone row: [form] [hook returns]. `wrap` keeps it horizontal on a
// laptop and lets it stack only on a genuinely narrow viewport.
const row = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 12px; margin: 0; width: 100%; max-width: 620px;`;

// --- shared zone-card chrome -------------------------------------------------
const zoneBase = `box-sizing: border-box; display: flex; flex-direction: column; gap: 9px; flex: 1 1 268px; min-width: 250px; min-height: 196px; margin: 0; padding: 11px 12px 12px; border-radius: 12px; background: ${SURFACE}; border: 1.5px solid ${BORDER};`;

// The eyebrow header line of each zone — a tiny label + a status pill on the right.
const zoneHead = `display: flex; align-items: center; justify-content: space-between; gap: 8px; margin: 0;`;
const zoneEyebrow = (accent: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${accent};`;
// A small status pill (the current phase, on the readout card).
const pill = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 2px 8px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.3; white-space: nowrap;`;
const dot = (c: string) => `display: inline-block; flex: 0 0 auto; width: 6px; height: 6px; margin: 0; border-radius: 50%; background: ${c};`;

// --- the FORM zone (left) ----------------------------------------------------
// A field row: a faint label, then the "input" box holding the typed value.
const fieldRow = `display: flex; flex-direction: column; gap: 3px; margin: 0;`;
const fieldLabel = `margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT};`;
// The input box. `invalid` tints the edge red (the email after a failed parse).
const inputBox = (invalid: boolean) =>
	`box-sizing: border-box; display: flex; align-items: center; margin: 0; padding: 5px 8px; min-height: 26px; border-radius: 6px; background: ${FIELD_BG}; font-family: ${mono}; font-size: 11.5px; font-weight: 600; line-height: 1.2; ` +
	(invalid ? `border: 1.5px solid ${RED}; color: ${INK};` : `border: 1px solid ${BORDER}; color: ${INK};`);
// The placeholder-style ghost text shown when an input is blank (after reset).
const inputGhost = `font-family: ${mono}; font-size: 11.5px; font-weight: 500; color: ${DIM_INK};`;
// The field-error line under the email input — only present on the failure beat.
const fieldError = `display: flex; align-items: center; gap: 6px; margin: 0; padding: 4px 8px; border-radius: 6px; background: ${RED_BG}; border: 1px solid ${RED}; font-family: ${sans}; font-size: 10.5px; font-weight: 600; line-height: 1.25; color: ${RED_INK};`;
// A fixed-height slot the error line lives in, so the form is the same footprint
// whether or not the error is showing.
const errorSlot = `display: flex; align-items: center; min-height: 24px; margin: 0;`;

// The submit button — its look tracks `isPending`. Pending = amber + disabled.
const submitBtn = (pending: boolean) =>
	`box-sizing: border-box; display: inline-flex; align-items: center; justify-content: center; gap: 6px; align-self: flex-start; margin: 4px 0 0; padding: 6px 14px; border-radius: 8px; font-family: ${sans}; font-size: 12px; font-weight: 700; line-height: 1.2; white-space: nowrap; ` +
	(pending
		? `border: 1.5px solid ${AMBER}; background: ${AMBER_BG}; color: ${AMBER_INK}; cursor: not-allowed;`
		: `border: 1.5px solid ${BLUE}; background: ${BLUE}; color: #ffffff; cursor: pointer;`);
// A tiny spinner glyph that rides next to "Saving…" while pending.
const spinner = `display: inline-block; flex: 0 0 auto; width: 9px; height: 9px; margin: 0; border-radius: 50%; border: 2px solid ${AMBER}; border-top-color: transparent;`;

// --- the HOOK-RETURNS zone (right) -------------------------------------------
// A readout row: a mono variable name on the left, its value pill on the right.
const readoutRow = `display: flex; align-items: center; gap: 8px; margin: 0; padding: 8px 10px; border-radius: 8px; background: ${PANEL_BG}; border: 1px solid ${BORDER};`;
const varName = `margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.2; color: ${INK};`;
// The value chip — mono, tinted by what the value currently is.
const valChip = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; margin: 0 0 0 auto; padding: 2px 9px; border: 1px solid ${edge}; border-radius: 6px; background: ${bg}; color: ${ink}; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.3; white-space: nowrap;`;
// A small note under the two readout rows, naming what just changed this beat.
const readoutNote = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 600; line-height: 1.35; color: ${INK_SOFT};`;

// The one-line verdict under the row. `tone` picks the ink; fixed min-height so
// the footprint is stable across steps.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.4; color: ${tone}; max-width: 560px; text-align: center; min-height: 32px;`;
const codeInline = `font-family: ${mono}; font-weight: 700;`;
---

<DiagramSequence>
	{/* ---- Step 1: Idle — nothing has happened yet ---- */}
	<DiagramStep caption="Idle. state = null and isPending = false. The button reads 'Save invoice' and is enabled; the user has filled the fields but not submitted.">
		<div style={stage}>
			<div style={row}>
				{/* form */}
				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>new-invoice-form</span>
						<span style={pill(BORDER, PANEL_BG, INK_SOFT)}>idle</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Customer email</span>
						<span style={inputBox(false)}>ada@</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Total</span>
						<span style={inputBox(false)}>240.00</span>
					</div>
					<div style={errorSlot}></div>
					<button type="button" style={submitBtn(false)} disabled>Save invoice</button>
				</div>

				{/* hook returns */}
				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(BLUE_INK)}>useActionState returns</span>
						<span style={pill(INK_SOFT, '#ffffff', INK_SOFT)}>phase 1 · idle</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>state</span>
						<span style={valChip(BORDER, '#ffffff', INK_SOFT)}>null</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>isPending</span>
						<span style={valChip(BORDER, '#ffffff', INK_SOFT)}>false</span>
					</div>
					<p style={readoutNote}>No result yet &mdash; the initial state. Nothing is in flight.</p>
				</div>
			</div>
			<p style={verdict(INK_SOFT)}>
				Before any submit, <code style={codeInline}>state</code> is the initial <code style={codeInline}>null</code> and the form sits idle.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Submit clicked — React serializes FormData, isPending -> true ---- */}
	<DiagramStep caption="Submit clicked. React serializes the named inputs into FormData and calls the bound action. isPending flips to true, so the button disables and reads 'Saving…'.">
		<div style={stage}>
			<div style={row}>
				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>new-invoice-form</span>
						<span style={pill(AMBER, AMBER_BG, AMBER_INK)}>submitting</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Customer email</span>
						<span style={inputBox(false)}>ada@</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Total</span>
						<span style={inputBox(false)}>240.00</span>
					</div>
					<div style={errorSlot}></div>
					<button type="button" style={submitBtn(true)} disabled>
						<span style={spinner} aria-hidden="true"></span>
						Saving&hellip;
					</button>
				</div>

				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(BLUE_INK)}>useActionState returns</span>
						<span style={pill(AMBER, AMBER_BG, AMBER_INK)}>phase 2 · submit</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>state</span>
						<span style={valChip(BORDER, '#ffffff', INK_SOFT)}>null</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>isPending</span>
						<span style={valChip(AMBER, AMBER_BG, AMBER_INK)}>
							<span style={dot(AMBER)} aria-hidden="true"></span>
							true
						</span>
					</div>
					<p style={readoutNote}><strong>isPending &rarr; true.</strong> That one flip disables the button.</p>
				</div>
			</div>
			<p style={verdict(AMBER_INK)}>
				The submit fires the bound <code style={codeInline}>formAction</code>; <code style={codeInline}>isPending</code> turns true and the button goes quiet.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: Action runs on the server — POST in flight, state unchanged ---- */}
	<DiagramStep caption="The action runs on the server — the POST is in flight. isPending is still true, and state has not changed yet because the action hasn't returned its Result.">
		<div style={stage}>
			<div style={row}>
				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>new-invoice-form</span>
						<span style={pill(AMBER, AMBER_BG, AMBER_INK)}>in flight</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Customer email</span>
						<span style={inputBox(false)}>ada@</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Total</span>
						<span style={inputBox(false)}>240.00</span>
					</div>
					<div style={errorSlot}></div>
					<button type="button" style={submitBtn(true)} disabled>
						<span style={spinner} aria-hidden="true"></span>
						Saving&hellip;
					</button>
				</div>

				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(BLUE_INK)}>useActionState returns</span>
						<span style={pill(AMBER, AMBER_BG, AMBER_INK)}>phase 3 · server</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>state</span>
						<span style={valChip(BORDER, '#ffffff', INK_SOFT)}>null</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>isPending</span>
						<span style={valChip(AMBER, AMBER_BG, AMBER_INK)}>
							<span style={dot(AMBER)} aria-hidden="true"></span>
							true
						</span>
					</div>
					<p style={readoutNote}>POST in flight. <code style={codeInline}>state</code> waits &mdash; the action hasn't returned.</p>
				</div>
			</div>
			<p style={verdict(AMBER_INK)}>
				While the action runs, only <code style={codeInline}>isPending</code> is true; <code style={codeInline}>state</code> holds its old value until a <code style={codeInline}>Result</code> comes back.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Result returns (failure) — isPending -> false, state = { ok: false } ---- */}
	<DiagramStep caption="The Result returns a failure. isPending flips back to false and state becomes { ok: false, error }. The field error renders, and the values the user typed stay in the inputs.">
		<div style={stage}>
			<div style={row}>
				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>new-invoice-form</span>
						<span style={pill(RED, RED_BG, RED_INK)}>rejected</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Customer email</span>
						<span style={inputBox(true)}>ada@</span>
					</div>
					<div style={errorSlot}>
						<span style={fieldError}>
							<span style={dot(RED)} aria-hidden="true"></span>
							Enter a valid email address.
						</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Total</span>
						<span style={inputBox(false)}>240.00</span>
					</div>
					<button type="button" style={submitBtn(false)} disabled>Save invoice</button>
				</div>

				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(BLUE_INK)}>useActionState returns</span>
						<span style={pill(RED, RED_BG, RED_INK)}>phase 4 · failure</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>state</span>
						<span style={valChip(RED, RED_BG, RED_INK)}>{'{ ok: false, error }'}</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>isPending</span>
						<span style={valChip(BORDER, '#ffffff', INK_SOFT)}>false</span>
					</div>
					<p style={readoutNote}><strong>state</strong> now carries the failure; the typed values persist.</p>
				</div>
			</div>
			<p style={verdict(RED_INK)}>
				Failure: <code style={codeInline}>isPending</code> is false again, <code style={codeInline}>state.ok === false</code> draws the field error, and nothing the user typed is lost.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 5: Resubmit succeeds — state = { ok: true }, errors clear, form resets ---- */}
	<DiagramStep caption="The user fixes the email and resubmits. isPending flips true then false again; state becomes { ok: true, data }. The old error clears and the uncontrolled form resets to blank.">
		<div style={stage}>
			<div style={row}>
				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>new-invoice-form</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							saved
						</span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Customer email</span>
						<span style={inputBox(false)}><span style={inputGhost}>customer@example.com</span></span>
					</div>
					<div style={fieldRow}>
						<span style={fieldLabel}>Total</span>
						<span style={inputBox(false)}><span style={inputGhost}>0.00</span></span>
					</div>
					<div style={errorSlot}></div>
					<button type="button" style={submitBtn(false)} disabled>Save invoice</button>
				</div>

				<div style={zoneBase}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(BLUE_INK)}>useActionState returns</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>phase 5 · success</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>state</span>
						<span style={valChip(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							{'{ ok: true, data }'}
						</span>
					</div>
					<div style={readoutRow}>
						<span style={varName}>isPending</span>
						<span style={valChip(BORDER, '#ffffff', INK_SOFT)}>false</span>
					</div>
					<p style={readoutNote}>Success: <code style={codeInline}>ok === false</code> blocks stop rendering, so the error is gone.</p>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>
				Success swaps <code style={codeInline}>state</code> to <code style={codeInline}>{'{ ok: true }'}</code>: the error vanishes on its own and the uncontrolled form clears, ready for the next entry.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
