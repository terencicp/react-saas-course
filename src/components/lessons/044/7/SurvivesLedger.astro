---
// The "honest ledger" for lesson 7: what survives a no-JavaScript / pre-hydration
// form submit and what degrades. Two color-coded columns, both visible at once
// (not tabs) so the reader can hold both sides of the rule in view:
//   left  — green — everything the *platform* (browser + server) provides survives
//   right — amber — everything *React-the-runtime* provides needs the JS bundle
//
// Each column is a self-contained tinted card: a header (icon + title) over a
// vertical list of rows. A row is a short feature label (inline-code where apt)
// plus a muted note recalling where it came from. No cross-column row alignment
// is implied, so the two cards flow independently and stack on a narrow card.

interface Row {
  // The feature label, split into code spans and plain-text spans so we can
  // render inline <code> without an MDX round-trip.
  parts: { text: string; code?: boolean }[];
  note: string;
}

const survives: Row[] = [
  {
    parts: [{ text: "<form action={…}>", code: true }, { text: " submit" }],
    note: "Native POST to the build-registered action URL",
  },
  {
    parts: [{ text: "Constraint Validation API" }],
    note: "required, type=\"email\", pattern, min/max — fire in the browser before submit; the only validation layer that survives no-JS",
  },
  {
    parts: [{ text: "redirect()", code: true }, { text: " from the action" }],
    note: "Server returns a 303; the browser navigates",
  },
  {
    parts: [{ text: "revalidatePath()", code: true }],
    note: "The next request reads fresh data; the redirected page is current",
  },
  {
    parts: [{ text: "Server Component re-render" }],
    note: "After the redirect: the updated invoice list, rendered server-side",
  },
];

const needsJs: Row[] = [
  {
    parts: [{ text: "useActionState", code: true }, { text: " inline render" }],
    note: "The Result is still produced — but nothing renders it without the hook",
  },
  {
    parts: [{ text: "useFormStatus", code: true }, { text: " pending UI" }],
    note: "No spinner, no disabled submit — pending stays false forever",
  },
  {
    parts: [{ text: "useOptimistic", code: true }, { text: " instant update" }],
    note: "Pure JS; no-JS users wait for the real round-trip",
  },
  {
    parts: [{ text: "Automatic form reset" }],
    note: "React owns it — and it's moot here anyway, the redirect replaced the page",
  },
  {
    parts: [{ text: "Inline field errors" }],
    note: "Same root cause: no React to read state and render under the input",
  },
];

// Two color families that read in both themes: a saturated mid-tone for the
// accent (header text, icon ring, the left edge of each row) plus a faint tint
// for the column fill. Green = platform/survives, amber = React-runtime/needs-JS.
const GREEN = "#16a34a";
const AMBER = "#d97706";

const column = (accent: string) =>
  [
    "margin: 0",
    "flex: 1 1 280px",
    "min-width: 0",
    "box-sizing: border-box",
    "border-radius: 12px",
    `border: 1px solid color-mix(in srgb, ${accent} 38%, transparent)`,
    `background: color-mix(in srgb, ${accent} 7%, var(--sl-color-bg, transparent))`,
    "padding: 12px 12px 6px",
    "display: flex",
    "flex-direction: column",
    "gap: 6px",
  ].join("; ");

const headerRow =
  "margin: 0; display: flex; align-items: center; gap: 8px; padding: 0 2px 8px;";

const headerRule = (accent: string) =>
  `margin: 0 -12px; border: 0; border-top: 1px solid color-mix(in srgb, ${accent} 26%, transparent); height: 0;`;

const iconWrap = (accent: string) =>
  [
    "margin: 0",
    "flex: 0 0 auto",
    "width: 24px",
    "height: 24px",
    "border-radius: 7px",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    `background: color-mix(in srgb, ${accent} 18%, transparent)`,
    `color: ${accent}`,
    "font-size: 14px",
    "font-weight: 700",
    "line-height: 1",
  ].join("; ");

const headerTitle = (accent: string) =>
  [
    "margin: 0",
    "font-size: 13px",
    "font-weight: 700",
    "letter-spacing: 0.01em",
    "line-height: 1.2",
    `color: ${accent}`,
  ].join("; ");

const headerSub =
  "margin: 1px 0 0; font-size: 11px; font-weight: 500; opacity: 0.6; line-height: 1.2;";

const rowStyle = (accent: string) =>
  [
    "margin: 0",
    "padding: 6px 8px 6px 10px",
    "border-radius: 7px",
    `border-left: 3px solid color-mix(in srgb, ${accent} 70%, transparent)`,
    "background: color-mix(in srgb, var(--sl-color-bg-sidebar, currentColor) 60%, transparent)",
    "display: flex",
    "flex-direction: column",
    "gap: 2px",
  ].join("; ");

const labelStyle =
  "margin: 0; font-size: 12.5px; font-weight: 600; line-height: 1.3;";

const codeSpan = (accent: string) =>
  [
    "font-family: var(--sl-font-mono, ui-monospace, monospace)",
    "font-size: 11.5px",
    "font-weight: 600",
    `color: ${accent}`,
    "background: transparent",
    "padding: 0",
    "white-space: nowrap",
  ].join("; ");

const noteStyle =
  "margin: 0; font-size: 10.5px; line-height: 1.35; opacity: 0.66;";

const columns: { accent: string; icon: string; title: string; sub: string; rows: Row[] }[] = [
  {
    accent: GREEN,
    icon: "✓",
    title: "Works without JavaScript",
    sub: "The platform handles it",
    rows: survives,
  },
  {
    accent: AMBER,
    icon: "✕",
    title: "Needs JavaScript",
    sub: "The React runtime handles it",
    rows: needsJs,
  },
];
---

<div
  style="margin: 0; width: 100%; display: flex; flex-direction: row; flex-wrap: wrap; gap: 14px; align-items: stretch; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {
    columns.map((col) => (
      <div style={column(col.accent)}>
        <div style={headerRow}>
          <div style={iconWrap(col.accent)} aria-hidden="true">
            {col.icon}
          </div>
          <div style="margin: 0; min-width: 0;">
            <p style={headerTitle(col.accent)}>{col.title}</p>
            <p style={headerSub}>{col.sub}</p>
          </div>
        </div>
        <hr style={headerRule(col.accent)} />
        {col.rows.map((row) => (
          <div style={rowStyle(col.accent)}>
            <p style={labelStyle}>
              {row.parts.map((part) =>
                part.code ? (
                  <span style={codeSpan(col.accent)}>{part.text}</span>
                ) : (
                  <span>{part.text}</span>
                ),
              )}
            </p>
            <p style={noteStyle}>{row.note}</p>
          </div>
        ))}
      </div>
    ))
  }
</div>
