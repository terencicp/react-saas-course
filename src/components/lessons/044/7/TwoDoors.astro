---
// One frame of the "one Server Action, two front doors" walk, used inside
// <DiagramSequence>. Two horizontal lanes — the JavaScript-enhanced door on top,
// the native-browser door below — converge on a single shared FormData -> action
// chain (the "one room"), then split again into two different responses.
//
// `step` (1..4) selects which nodes are lit:
//   1 — the two mechanism nodes (React intercepts / browser native POST)
//   2 — the shared FormData node (both lanes have merged)
//   3 — the shared createInvoice node (the room)
//   4 — the two response nodes (inline re-render / 303 navigation)

interface Props {
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const arrow = "▸";

// Shared chrome for every rounded box.
const boxBase = [
  "margin: 0",
  "padding: 6px 9px",
  "border-radius: 8px",
  "min-width: 0",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 1px",
  "box-sizing: border-box",
  "transition: opacity 200ms ease, transform 200ms ease, border-color 200ms ease, background-color 200ms ease, box-shadow 200ms ease",
].join("; ");

// JS lane uses sky; no-JS lane uses violet; the shared center uses amber.
const dimSky = `${boxBase}; border: 1px solid color-mix(in srgb, #38bdf8 30%, transparent); background: color-mix(in srgb, #38bdf8 6%, transparent); opacity: 0.4;`;
const dimViolet = `${boxBase}; border: 1px solid color-mix(in srgb, #a78bfa 32%, transparent); background: color-mix(in srgb, #a78bfa 6%, transparent); opacity: 0.4;`;
const dimShared = `${boxBase}; border: 1px solid color-mix(in srgb, #f59e0b 32%, transparent); background: color-mix(in srgb, #f59e0b 6%, transparent); opacity: 0.4;`;

// The two "click" entry nodes are never the focus of a step — keep them present
// but muted so each lane reads as starting from the same click.
const clickBox = `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 18%, transparent); background: color-mix(in srgb, currentColor 6%, transparent); opacity: 0.6;`;

// Active (lit) box per region — saturated fill, matching border, lifted.
const onSky = `${boxBase}; border: 1.5px solid #0ea5e9; background: color-mix(in srgb, #0ea5e9 22%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #0ea5e9 18%, transparent); transform: translateY(-1px); opacity: 1;`;
const onViolet = `${boxBase}; border: 1.5px solid #8b5cf6; background: color-mix(in srgb, #8b5cf6 24%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #8b5cf6 18%, transparent); transform: translateY(-1px); opacity: 1;`;
const onShared = `${boxBase}; border: 1.5px solid #f59e0b; background: color-mix(in srgb, #f59e0b 24%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 18%, transparent); transform: translateY(-1px); opacity: 1;`;

// Which node is lit this step.
const jsMech = step === 1 ? onSky : dimSky; // React intercepts
const noJsMech = step === 1 ? onViolet : dimViolet; // browser native POST
const formData = step === 2 ? onShared : dimShared;
const action = step === 3 ? onShared : dimShared;
const jsResp = step === 4 ? onSky : dimSky; // Result -> inline re-render
const noJsResp = step === 4 ? onViolet : dimViolet; // 303 -> navigation

// Connector opacity tracks the step so the active hand-off reads as flowing.
const mergeLit = step >= 2;
const splitLit = step === 4;
const connStroke = (lit: boolean) => (lit ? 0.55 : 0.28);
const connWidth = (lit: boolean) => (lit ? 1.8 : 1.4);

// Lane titles/sublabels may wrap to two lines on a narrow card rather than
// forcing the single-row strip to overflow. The short shared code labels stay
// on one line.
const titleStyle =
  "margin: 0; font-size: 12px; font-weight: 600; line-height: 1.2;";
const subStyle =
  "margin: 2px 0 0; font-size: 9.5px; opacity: 0.62; line-height: 1.2;";
const codeTitle =
  "margin: 0; font-size: 12px; font-weight: 600; line-height: 1.2; white-space: nowrap; font-family: var(--sl-font-mono, ui-monospace, monospace);";

const arrowStyle = [
  "margin: 0",
  "color: currentColor",
  "opacity: 0.32",
  "font-size: 12px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");

// Lane label chip at the far left of each row.
const laneLabel = (color: string) =>
  [
    "margin: 0",
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.02em",
    "line-height: 1.15",
    "text-transform: uppercase",
    "text-align: right",
    "white-space: nowrap",
    `color: ${color}`,
    "flex: 0 0 auto",
  ].join("; ");
---

<div
  style="margin: 0; width: 100%; display: flex; flex-direction: column; gap: 10px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* Main strip: left lanes -> converge -> shared room -> diverge -> right lanes.
      Kept on a single row (nowrap) — the converge/diverge metaphor breaks if it wraps. */}
  <div
    style="margin: 0; width: 100%; display: flex; flex-direction: row; align-items: center; justify-content: center; flex-wrap: nowrap; column-gap: 2px; min-width: 0;"
  >
    {/* LEFT: two stacked lanes, each [label] [click] -> [mechanism] */}
    <div
      style="margin: 0; display: grid; grid-template-columns: auto auto auto auto; grid-template-rows: 1fr 1fr; align-items: center; column-gap: 4px; row-gap: 26px; flex: 0 0 auto;"
    >
      {/* JS lane */}
      <div style={laneLabel("#0ea5e9")}>With<br />JavaScript</div>
      <div style={clickBox}>
        <div style={titleStyle}>Click</div>
        <div style={subStyle}>submit fired</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={jsMech}>
        <div style={titleStyle}>React intercepts</div>
        <div style={subStyle}>background POST</div>
      </div>

      {/* No-JS lane */}
      <div style={laneLabel("#8b5cf6")}>Without JS /<br />pre-hydration</div>
      <div style={clickBox}>
        <div style={titleStyle}>Click</div>
        <div style={subStyle}>submit fired</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={noJsMech}>
        <div style={titleStyle}>Browser native POST</div>
        <div style={subStyle}>built-in form handling</div>
      </div>
    </div>

    {/* Converge connector: both lanes curve into the shared FormData row */}
    <svg
      viewBox="0 0 44 120"
      width="40"
      height="116"
      preserveAspectRatio="none"
      role="img"
      aria-label="Both doors converge on the same FormData."
      style="margin: 0; display: block; flex: 0 0 auto;"
    >
      <path
        d={"M 0 26 Q 26 26 26 60 L 40 60"}
        fill="none"
        stroke="#f59e0b"
        stroke-opacity={connStroke(mergeLit)}
        stroke-width={connWidth(mergeLit)}
      />
      <path
        d={"M 0 94 Q 26 94 26 60 L 40 60"}
        fill="none"
        stroke="#f59e0b"
        stroke-opacity={connStroke(mergeLit)}
        stroke-width={connWidth(mergeLit)}
      />
      <path
        d={"M 43 60 L 35 56 L 35 64 Z"}
        fill="#f59e0b"
        fill-opacity={connStroke(mergeLit) + 0.1}
      />
    </svg>

    {/* CENTER: the single shared room — FormData -> createInvoice */}
    <div
      style="margin: 0; display: flex; flex-direction: row; align-items: center; flex-wrap: nowrap; gap: 4px; flex: 0 0 auto; align-self: center;"
    >
      <div style={formData}>
        <div style={codeTitle}>FormData</div>
        <div style={subStyle}>name attrs -> keys</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={action}>
        <div style={codeTitle}>createInvoice</div>
        <div style={subStyle}>the one action body</div>
      </div>
    </div>

    {/* Diverge connector: the room splits back into the two responses */}
    <svg
      viewBox="0 0 44 120"
      width="40"
      height="116"
      preserveAspectRatio="none"
      role="img"
      aria-label="The doors diverge into two different responses."
      style="margin: 0; display: block; flex: 0 0 auto;"
    >
      <path
        d={"M 0 60 L 18 60 Q 18 26 44 26"}
        fill="none"
        stroke="#f59e0b"
        stroke-opacity={connStroke(splitLit)}
        stroke-width={connWidth(splitLit)}
      />
      <path
        d={"M 0 60 L 18 60 Q 18 94 44 94"}
        fill="none"
        stroke="#f59e0b"
        stroke-opacity={connStroke(splitLit)}
        stroke-width={connWidth(splitLit)}
      />
    </svg>

    {/* RIGHT: two stacked response lanes */}
    <div
      style="margin: 0; display: grid; grid-template-columns: auto; grid-template-rows: 1fr 1fr; align-items: center; row-gap: 26px; flex: 0 0 auto;"
    >
      <div style={jsResp}>
        <div style={titleStyle}>Result -> inline re-render</div>
        <div style={subStyle}>banner / fields / reset, no nav</div>
      </div>
      <div style={noJsResp}>
        <div style={titleStyle}>303 redirect -> navigation</div>
        <div style={subStyle}>browser loads a fresh page</div>
      </div>
    </div>
  </div>
</div>
