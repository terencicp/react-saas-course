---
// Diagram: server truth / client optimism boundary (diagram id:
// server-truth-client-optimism-boundary, Chapter 044 Lesson 5 — "Instant UI
// with useOptimistic"). It sits right before the "add comment" code and its
// whole job is to make the data-flow LOOP spatial, because that loop — not the
// hook signature — is the section's hard concept: where does `actualState` come
// from, and why does the optimistic comment fall away at exactly the right
// moment? The answer is the boundary plus the revalidate refresh, drawn once.
//
// Three boxes, left -> right, with the client/server split marked by a dashed
// vertical divider and two zone eyebrows (SERVER over box 1, CLIENT over boxes
// 2-3):
//   1  SERVER COMPONENT (server side) — reads `comments` from the DB: the truth.
//   2  `comments` PROP (on the boundary) — the serialized array crossing over.
//   3  CLIENT COMPONENT (client side) — useOptimistic(comments, …): borrows the
//      future.
//
// Three arrows carry DIRECTION (this is a flow over time, so arrows earn their
// cost over color-matching):
//   - box1 -> box2  "props cross the boundary"  (gap 1; arrow mid-height, label
//     dropped into the bottom lane so it clears the box title/body)
//   - box2 -> box3  "seeds actualState"         (gap 2; same lowered label)
//   - box3 -> box1  "revalidatePath → fresh render"  arcs OVER THE TOP so the
//     loop is visible and the return path crosses no text. top->top sockets with
//     strong negative-Y gravity; the stage reserves top padding for the arc.
//
// House style mirrors this chapter's NameThreePlaces.astro: pinned
// `color-scheme: light` so the hand-picked slate/blue/green tints survive dark
// mode; inline style strings + `box-sizing: border-box` + `margin: 0` to defeat
// Starlight's injected prose margins; horizontal and height-capped. ArrowDiagram
// uses leader-line, so the wrapping <Figure> MUST set `expandable={false}`
// (done in the MDX).

import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text / chrome
const SURFACE = '#ffffff';
const DIVIDER = '#94a3b8'; // slate-400 — the dashed server/client divider

// server zone — slate (the neutral, settled "truth" side)
const SERVER_BG = '#f1f5f9'; // slate-100
const SERVER_BORDER = '#cbd5e1'; // slate-300
const SERVER_INK = '#475569'; // slate-600

// the wire/payload box — amber, "in transit across the boundary"
const WIRE = '#d97706'; // amber-600
const WIRE_BG = '#fffbeb'; // amber-50
const WIRE_BORDER = '#fcd34d'; // amber-300
const WIRE_INK = '#92400e'; // amber-800

// client zone — blue (the side that borrows the future)
const CLIENT = '#2563eb'; // blue-600
const CLIENT_BG = '#eff6ff'; // blue-50
const CLIENT_BORDER = '#bfdbfe'; // blue-200
const CLIENT_INK = '#1e40af'; // blue-800

// arrow colors — forward flow blue, the return/revalidate loop green
const ARROW_FWD = '#0ea5e9'; // sky-500
const ARROW_BACK = '#16a34a'; // green-600

// ---- styles --------------------------------------------------------------
const stage = [
  'box-sizing: border-box',
  'position: relative',
  'margin: 0',
  // reserve vertical room ABOVE the boxes for the return arrow's arc, and a
  // little below so the figure breathes.
  'padding: 64px 6px 10px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// the dashed server/client divider, absolutely positioned to run between
// column 1 and column 2. left % is tuned to the 3-col grid below.
const divider = [
  'box-sizing: border-box',
  'position: absolute',
  'top: 30px',
  'bottom: 4px',
  'left: 33.5%',
  'width: 0',
  `border-left: 2px dashed ${DIVIDER}`,
  'margin: 0',
  'pointer-events: none',
].join('; ');

// the two zone eyebrows that float just under the top padding, naming each side
// of the divider.
const zoneRow = [
  'box-sizing: border-box',
  'position: absolute',
  'top: 36px',
  'left: 6px',
  'right: 6px',
  'display: flex',
  'justify-content: space-between',
  'margin: 0',
  'pointer-events: none',
].join('; ');
const zoneLabel = (ink: string, align: 'left' | 'right') =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 10px',
    'font-weight: 800',
    'letter-spacing: 0.1em',
    'text-transform: uppercase',
    'line-height: 1',
    `color: ${ink}`,
    align === 'left' ? 'padding-left: 2px' : 'padding-right: 2px',
  ].join('; ');

// three columns sized to content, centered, with generous gaps so each forward
// arrow has air to live in.
const flow = [
  'box-sizing: border-box',
  'display: grid',
  'grid-template-columns: repeat(3, minmax(0, 1fr))',
  'align-items: stretch',
  'gap: 40px',
  'margin: 0',
].join('; ');

// shared box chrome.
const box = (border: string, bg: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'flex-direction: column',
    'gap: 8px',
    'margin: 0',
    'padding: 13px 14px 14px',
    'border-radius: 14px',
    `border: 1.5px solid ${border}`,
    `background: ${bg}`,
    'min-width: 0',
    // extra height opens a clean lane below the body text where the forward
    // arrow labels sit (see their labelOffset) instead of overlapping the title.
    'min-height: 118px',
  ].join('; ');

const boxHead = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 7px',
  'margin: 0',
].join('; ');

const boxKicker = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 9px',
    'font-weight: 800',
    'letter-spacing: 0.06em',
    'text-transform: uppercase',
    'line-height: 1',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

const boxTitle = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 13.5px',
    'font-weight: 700',
    'line-height: 1.2',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

const boxBody = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 11.5px',
    'font-weight: 500',
    'line-height: 1.4',
    `color: ${ink}`,
  ].join('; ');

const codeInline = (ink: string) =>
  [
    `font-family: ${mono}`,
    'font-weight: 700',
    'font-size: 0.94em',
    `color: ${ink}`,
  ].join('; ');

// a small "DB" chip on the server box.
const chip = (edge: string, bg: string, ink: string) =>
  [
    'display: inline-flex',
    'align-items: center',
    'gap: 5px',
    'align-self: flex-start',
    'margin: 0',
    'padding: 2px 8px',
    `border: 1px solid ${edge}`,
    'border-radius: 999px',
    `background: ${bg}`,
    `color: ${ink}`,
    `font-family: ${mono}`,
    'font-size: 10px',
    'font-weight: 700',
    'line-height: 1.3',
    'white-space: nowrap',
  ].join('; ');
---

<div style={stage}>
  <span style={divider} aria-hidden="true"></span>
  <div style={zoneRow} aria-hidden="true">
    <span style={zoneLabel(SERVER_INK, 'left')}>Server</span>
    <span style={zoneLabel(CLIENT_INK, 'right')}>Client</span>
  </div>

  <ArrowDiagram
    arrows={[
      {
        from: 'stcb-server',
        to: 'stcb-prop',
        label: 'props cross the boundary',
        color: ARROW_FWD,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [50, 0],
        endSocketGravity: [-50, 0],
        labelOffset: [0, 44],
      },
      {
        from: 'stcb-prop',
        to: 'stcb-client',
        label: 'seeds actualState',
        color: ARROW_FWD,
        startSocket: 'right',
        endSocket: 'left',
        startSocketGravity: [50, 0],
        endSocketGravity: [-50, 0],
        labelOffset: [0, 44],
      },
      {
        from: 'stcb-client',
        to: 'stcb-server',
        label: 'revalidatePath → fresh render',
        color: ARROW_BACK,
        startSocket: 'top',
        endSocket: 'top',
        startSocketGravity: [0, -56],
        endSocketGravity: [0, -56],
        labelOffset: [0, -8],
      },
    ]}
  >
    <div style={flow}>
      {/* ---- Box 1: SERVER COMPONENT (server side) -------------------- */}
      <div style={box(SERVER_BORDER, SERVER_BG)} id="stcb-server">
        <div style={boxHead}>
          <span style={boxKicker(SERVER_INK)}>Server Component</span>
        </div>
        <span style={chip(SERVER_BORDER, SURFACE, SERVER_INK)}>DB</span>
        <p style={boxBody(INK)}>
          Reads <span style={codeInline(INK)}>comments</span> from the database &mdash;
          <strong> the truth</strong>.
        </p>
      </div>

      {/* ---- Box 2: comments PROP (on the boundary) ------------------- */}
      <div style={box(WIRE_BORDER, WIRE_BG)} id="stcb-prop">
        <div style={boxHead}>
          <span style={boxKicker(WIRE_INK)}>On the boundary</span>
        </div>
        <span style={boxTitle(WIRE_INK)}>comments</span>
        <p style={boxBody(INK)}>
          The serialized array, passed as a prop from server to client.
        </p>
      </div>

      {/* ---- Box 3: CLIENT COMPONENT (client side) ------------------- */}
      <div style={box(CLIENT_BORDER, CLIENT_BG)} id="stcb-client">
        <div style={boxHead}>
          <span style={boxKicker(CLIENT_INK)}>Client Component</span>
        </div>
        <span style={boxTitle(CLIENT_INK)}>useOptimistic(comments, …)</span>
        <p style={boxBody(INK)}>
          Seeds <span style={codeInline(INK)}>actualState</span> &mdash;
          <strong> borrows the future</strong> for one render.
        </p>
      </div>
    </div>
  </ArrowDiagram>
</div>
