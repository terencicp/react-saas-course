---
// Diagram: optimistic lifecycle timeline (diagram id:
// optimistic-lifecycle-timeline, Chapter 044 Lesson 5 — "Instant UI with
// useOptimistic"). The lesson outline tags this as the LOAD-BEARING asset: the
// whole concept of `useOptimistic` *is* this sequence of states over time, so a
// scrub through the beats earns its weight. Each beat answers the three
// questions the prose poses, in one consistent frame:
//   1  what the user SEES — a small "comment list" box (rows A, B, and the
//      in-flight C),
//   2  what `actualState` HOLDS — the server-confirmed truth, as a chip,
//   3  whether an optimistic OVERLAY is applied — an on/off indicator.
//
// The pedagogical payoff (per the outline + prose): "rollback" is not a special
// operation. It is the natural consequence of re-rendering against an
// `actualState` that, on failure, never moved. The scrub makes that visible:
// the list is `[A, B, C]` while the overlay is on, then on FAILURE snaps back to
// `[A, B]` simply because actualState was `[A, B]` the entire time.
//
// `DiagramSequence` is a single LINEAR scrub (no real fork), so success is steps
// 4 and failure is step 5, framed in its caption as "rewind to step 2, this
// time the action fails" — exactly as the outline specifies.
//
// House style mirrors this lesson's sibling figure (ServerTruthClientOptimism-
// Boundary.astro): pinned `color-scheme: light` so the hand-picked slate / amber
// / blue tints survive dark mode; inline style strings + `box-sizing:
// border-box` + `margin: 0` to defeat Starlight's injected prose margins;
// height-capped, consistent panel geometry so the grid-stack stage (which sizes
// to the tallest step) never reflows as the reader scrubs.
//
// Color semantics, kept coherent with the sibling figure:
//   - solid rows (A, B, real C) = confirmed server truth        -> slate / ink
//   - the in-flight C            = the borrowed future          -> amber, dashed
//   - `actualState` chip         = the server-truth side        -> slate
//   - overlay ON                 = optimistic overlay applied   -> amber
//   - error banner (step 5)      = the failure the user reads   -> red

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text / chrome
const SURFACE = '#ffffff';

// confirmed / server-truth side — slate (the neutral, settled side)
const TRUTH_BG = '#f8fafc'; // slate-50 — list panel surface
const TRUTH_BORDER = '#e2e8f0'; // slate-200
const ROW_BG = '#ffffff';
const ROW_BORDER = '#cbd5e1'; // slate-300
const ROW_INK = '#334155'; // slate-700

// the in-flight / optimistic overlay — amber, "borrowed future"
const OPT = '#d97706'; // amber-600
const OPT_BG = '#fffbeb'; // amber-50
const OPT_BORDER = '#f59e0b'; // amber-500 (used dashed)
const OPT_INK = '#92400e'; // amber-800

// the failure the user reads — red
const ERR = '#dc2626'; // red-600
const ERR_BG = '#fef2f2'; // red-50
const ERR_BORDER = '#fca5a5'; // red-300
const ERR_INK = '#991b1b'; // red-800

// ---- shared styles -------------------------------------------------------
// The outer panel: a two-column frame. Left = the rendered list (the hero).
// Right = the "behind the scenes" status (actualState + overlay). Fixed
// min-height so every step is the same height and the stage never jumps.
const panel = [
  'box-sizing: border-box',
  'margin: 0',
  'display: grid',
  'grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr)',
  'gap: 14px',
  'align-items: stretch',
  'min-height: 188px',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// the list box (what the user sees on screen).
const listBox = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 7px',
  'margin: 0',
  'padding: 12px 13px 13px',
  'border-radius: 12px',
  `border: 1.5px solid ${TRUTH_BORDER}`,
  `background: ${TRUTH_BG}`,
  'min-width: 0',
].join('; ');

const listKicker = [
  'margin: 0 0 1px',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'letter-spacing: 0.08em',
  'text-transform: uppercase',
  'line-height: 1',
  `color: ${INK_SOFT}`,
].join('; ');

// a confirmed row.
const row = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 8px',
  'margin: 0',
  'padding: 8px 10px',
  'border-radius: 8px',
  `border: 1px solid ${ROW_BORDER}`,
  `background: ${ROW_BG}`,
  'min-width: 0',
].join('; ');

// the in-flight row: amber, dashed, dimmed.
const rowPending = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 8px',
  'margin: 0',
  'padding: 8px 10px',
  'border-radius: 8px',
  `border: 1.5px dashed ${OPT_BORDER}`,
  `background: ${OPT_BG}`,
  'opacity: 0.78',
  'min-width: 0',
].join('; ');

const rowDot = (bg: string) =>
  [
    'flex: 0 0 auto',
    'width: 18px',
    'height: 18px',
    'border-radius: 50%',
    `background: ${bg}`,
    'color: #fff',
    'display: inline-flex',
    'align-items: center',
    'justify-content: center',
    `font-family: ${sans}`,
    'font-size: 10px',
    'font-weight: 800',
    'line-height: 1',
  ].join('; ');

const rowLabel = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 12.5px',
    'font-weight: 600',
    'line-height: 1.2',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

// the "sending…" tag on the in-flight row.
const sendingTag = [
  'margin: 0 0 0 auto',
  'padding: 1px 7px',
  'border-radius: 999px',
  `border: 1px solid ${OPT_BORDER}`,
  `background: ${SURFACE}`,
  `color: ${OPT_INK}`,
  `font-family: ${mono}`,
  'font-size: 9.5px',
  'font-weight: 700',
  'line-height: 1.4',
  'white-space: nowrap',
].join('; ');

// the right-hand status column.
const statusCol = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 9px',
  'margin: 0',
  'min-width: 0',
].join('; ');

// a status card (actualState; overlay).
const statusCard = (border: string, bg: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'flex-direction: column',
    'gap: 5px',
    'margin: 0',
    'padding: 9px 11px 10px',
    'border-radius: 10px',
    `border: 1.5px solid ${border}`,
    `background: ${bg}`,
    'min-width: 0',
  ].join('; ');

const statusKicker = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 9px',
    'font-weight: 800',
    'letter-spacing: 0.07em',
    'text-transform: uppercase',
    'line-height: 1',
    `color: ${ink}`,
  ].join('; ');

const statusValue = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 13px',
    'font-weight: 700',
    'line-height: 1.25',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

const statusNote = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 10.5px',
    'font-weight: 500',
    'line-height: 1.35',
    `color: ${ink}`,
  ].join('; ');

// the error banner (step 5 only), spanning the list box's place.
const errorBanner = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 8px',
  'margin: 0',
  'padding: 8px 10px',
  'border-radius: 8px',
  `border: 1px solid ${ERR_BORDER}`,
  `background: ${ERR_BG}`,
  `color: ${ERR_INK}`,
  `font-family: ${sans}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'line-height: 1.3',
].join('; ');

const errorDot = [
  'flex: 0 0 auto',
  'width: 16px',
  'height: 16px',
  'border-radius: 50%',
  `background: ${ERR}`,
  'color: #fff',
  'display: inline-flex',
  'align-items: center',
  'justify-content: center',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 800',
  'line-height: 1',
].join('; ');

const codeInline = (ink: string) =>
  [
    `font-family: ${mono}`,
    'font-weight: 700',
    'font-size: 0.92em',
    `color: ${ink}`,
  ].join('; ');

// ---- per-step data -------------------------------------------------------
// Rows shown in each list box. `kind`: 'solid' (confirmed truth) or 'pending'
// (the in-flight optimistic overlay).
type Row = { letter: string; kind: 'solid' | 'pending' };
type Overlay = { on: boolean; note: string };

const STEPS: {
  rows: Row[];
  showErrorBanner?: boolean;
  actual: string; // the actualState value
  actualNote: string; // one-line gloss under actualState
  overlay: Overlay;
}[] = [
  // 1 — Idle
  {
    rows: [
      { letter: 'A', kind: 'solid' },
      { letter: 'B', kind: 'solid' },
    ],
    actual: '[A, B]',
    actualNote: 'The list renders this prop directly.',
    overlay: { on: false, note: 'Nothing in flight.' },
  },
  // 2 — Click submit
  {
    rows: [
      { letter: 'A', kind: 'solid' },
      { letter: 'B', kind: 'solid' },
      { letter: 'C', kind: 'pending' },
    ],
    actual: '[A, B]',
    actualNote: "Unchanged — the server hasn't moved.",
    overlay: { on: true, note: 'C laid over the truth.' },
  },
  // 3 — Action in flight
  {
    rows: [
      { letter: 'A', kind: 'solid' },
      { letter: 'B', kind: 'solid' },
      { letter: 'C', kind: 'pending' },
    ],
    actual: '[A, B]',
    actualNote: 'Still the old truth.',
    overlay: { on: true, note: 'Borrowed future on screen.' },
  },
  // 4 — Success
  {
    rows: [
      { letter: 'A', kind: 'solid' },
      { letter: 'B', kind: 'solid' },
      { letter: 'C', kind: 'solid' },
    ],
    actual: '[A, B, C]',
    actualNote: 'revalidatePath refreshed the prop.',
    overlay: { on: false, note: 'Discarded — truth caught up.' },
  },
  // 5 — Failure (rewind to step 2)
  {
    rows: [
      { letter: 'A', kind: 'solid' },
      { letter: 'B', kind: 'solid' },
    ],
    showErrorBanner: true,
    actual: '[A, B]',
    actualNote: 'Never moved — the write failed.',
    overlay: { on: false, note: 'Discarded — C vanishes.' },
  },
];

interface Props {
  /** Which beat to render, 1-based (1..5). */
  step: number;
}
const { step } = Astro.props;
const s = STEPS[step - 1];
---

{/* Renders ONE panel chosen by the 1-based `step` prop, so the MDX can drop one
    per <DiagramStep> and keep captions + the slider in the lesson. */}

<div style={panel} aria-hidden="true" data-olt-panel={step}>
  {/* ---- left: the rendered comment list (or, on failure, list + banner) -- */}
  <div style={listBox}>
    <p style={listKicker}>Comment list (on screen)</p>
    {s.rows.map((r) =>
      r.kind === 'solid' ? (
        <div style={row}>
          <span style={rowDot(ROW_INK)}>{r.letter}</span>
          <span style={rowLabel(ROW_INK)}>Comment {r.letter}</span>
        </div>
      ) : (
        <div style={rowPending}>
          <span style={rowDot(OPT)}>{r.letter}</span>
          <span style={rowLabel(OPT_INK)}>Comment {r.letter}</span>
          <span style={sendingTag}>sending…</span>
        </div>
      ),
    )}
    {s.showErrorBanner && (
      <div style={errorBanner}>
        <span style={errorDot}>!</span>
        <span>state.ok === false &mdash; error banner shown</span>
      </div>
    )}
  </div>

  {/* ---- right: the behind-the-scenes status ----------------------------- */}
  <div style={statusCol}>
    <div style={statusCard(ROW_BORDER, SURFACE)}>
      <p style={statusKicker(INK_SOFT)}>actualState (server truth)</p>
      <p style={statusValue(INK)}>{s.actual}</p>
      <p style={statusNote(INK_SOFT)}>{s.actualNote}</p>
    </div>

    {s.overlay.on ? (
      <div style={statusCard(OPT_BORDER, OPT_BG)}>
        <p style={statusKicker(OPT_INK)}>Optimistic overlay</p>
        <p style={statusValue(OPT_INK)}>ON</p>
        <p style={statusNote(OPT_INK)}>{s.overlay.note}</p>
      </div>
    ) : (
      <div style={statusCard(ROW_BORDER, TRUTH_BG)}>
        <p style={statusKicker(INK_SOFT)}>Optimistic overlay</p>
        <p style={statusValue(INK_SOFT)}>off</p>
        <p style={statusNote(INK_SOFT)}>{s.overlay.note}</p>
      </div>
    )}
  </div>
</div>
