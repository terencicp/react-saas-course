---
// Diagram: name, three places (diagram id: name-three-places, Chapter 044
// Lesson 1 — "Uncontrolled inputs and the FormData contract"). The lesson's
// anchor visual. Its whole job is to make ONE idea spatial: the input's `name`,
// the `FormData` key, and the schema's key are a single string that never
// changes shape. The pedagogical relationship is pure CORRESPONDENCE ("this
// string is that string"), so — per the ArrowDiagram doc — identity is carried
// by color matching, NOT by crossing arrows. Three matched-color tokens
// (email = blue, role = orange, company = violet) repeat down all three panels;
// a single neutral arrow arcs over the top to show the flow direction once.
//
// Three panels, left -> right:
//   FORM      three uncontrolled `<input>`s, name token tinted.
//   FORMDATA  the produced multimap, same tint on each key.
//   SCHEMA    the Zod object keys, same tint.
//
// The arrow is anchored at the panel HEADERS (block-level, pattern 1) so it
// leaves the top edge of the Form card and lands on the top edge of the Schema
// card, bowing up into the reserved space above the panels — it crosses no
// text. It carries `color` slate (neutral chrome) so it does not compete with
// the three identity colors, which are the real signal.
//
// House style mirrors ch 043 L1 (the-round-trip.astro): pinned
// `color-scheme: light` so the hand-picked tints survive dark mode; inline
// style strings + `box-sizing: border-box` + `margin: 0` throughout to defeat
// Starlight's injected prose margins; horizontal, height-capped. ArrowDiagram
// uses leader-line, so the wrapping <Figure> MUST set `expandable={false}`
// (done in the MDX). The `.match-*` / `.code-line` classes live in a scoped
// <style> block, exactly as the outline specifies.

import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary code ink
const INK_SOFT = '#64748b'; // slate-500 — muted (quotes, punctuation, title)
const SURFACE = '#ffffff';
const PANEL_BORDER = '#e2e8f0'; // slate-200 — neutral chrome
const PANEL_BG = '#f8fafc'; // slate-50 — panel wash
const ARROW = '#64748b'; // slate-500 — neutral flow arrow (not an identity color)

// the three identity colors — one per shared name. Used both for the token
// dot in each panel header legend and the .match-* tints in the <style> block.
const BLUE = '#0ea5e9';
const ORANGE = '#f97316';
const VIOLET = '#9333ea';

// ---- styles --------------------------------------------------------------
const stage = [
  'box-sizing: border-box',
  'margin: 0',
  // reserve vertical room ABOVE the panels for the arrow's arc.
  'padding: 56px 4px 4px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// three columns sized to their content, centered, with a generous gap so the
// (single) arrow has air and the panels read as distinct stages of one flow.
// max-content (not 1fr) lets each panel hug its code so lines never clip.
const flow = [
  'box-sizing: border-box',
  'display: grid',
  'grid-template-columns: repeat(3, max-content)',
  'justify-content: center',
  'gap: 26px',
  'align-items: start',
  'margin: 0',
].join('; ');

const panel = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 11px',
  'margin: 0',
  'padding: 14px 15px 16px',
  'border-radius: 14px',
  `border: 1.5px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
  'min-width: 0',
].join('; ');

const panelHead = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 7px',
  'margin: 0',
  'padding-bottom: 2px',
].join('; ');

const panelNum = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: inline-flex',
  'align-items: center',
  'justify-content: center',
  'width: 18px',
  'height: 18px',
  'border-radius: 999px',
  `border: 1.5px solid ${INK_SOFT}`,
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 800',
  'line-height: 1',
  `color: ${INK_SOFT}`,
].join('; ');

const panelTitle = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 800',
  'letter-spacing: 0.06em',
  'text-transform: uppercase',
  'line-height: 1.2',
  `color: ${INK_SOFT}`,
  'white-space: nowrap',
].join('; ');

// the monospace code body inside each panel.
const codeBody = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 6px',
  'margin: 0',
].join('; ');

// punctuation / string-literal ink (the parts that are NOT the shared name).
const dim = `color: ${INK_SOFT};`;
---

<div style={stage}>
  <ArrowDiagram
    arrows={[
      {
        from: 'ntp-form-head',
        to: 'ntp-schema-head',
        label: 'one set of strings',
        color: ARROW,
        startSocket: 'top',
        endSocket: 'top',
        startSocketGravity: [0, -78],
        endSocketGravity: [0, -78],
        labelOffset: [0, -6],
      },
    ]}
  >
    <div style={flow}>
      {/* ---- Panel 1: FORM ------------------------------------------------ */}
      <div style={panel}>
        <div style={panelHead} id="ntp-form-head">
          <span style={panelNum}>1</span>
          <span style={panelTitle}>Form</span>
        </div>
        <div style={codeBody}>
          <div class="code-line">
            <span style={dim}>&lt;input name=&quot;</span><span class="match-blue">email</span><span style={dim}>&quot; /&gt;</span>
          </div>
          <div class="code-line">
            <span style={dim}>&lt;input name=&quot;</span><span class="match-orange">role</span><span style={dim}>&quot; /&gt;</span>
          </div>
          <div class="code-line">
            <span style={dim}>&lt;input name=&quot;</span><span class="match-violet">company</span><span style={dim}>&quot; /&gt;</span>
          </div>
        </div>
      </div>

      {/* ---- Panel 2: FORMDATA ------------------------------------------- */}
      <div style={panel}>
        <div style={panelHead} id="ntp-formdata-head">
          <span style={panelNum}>2</span>
          <span style={panelTitle}>FormData</span>
        </div>
        <div style={codeBody}>
          <div class="code-line">
            <span class="match-blue">email</span><span style={dim}> &rarr; &apos;ada@…&apos;</span>
          </div>
          <div class="code-line">
            <span class="match-orange">role</span><span style={dim}> &rarr; &apos;admin&apos;</span>
          </div>
          <div class="code-line">
            <span class="match-violet">company</span><span style={dim}> &rarr; &apos;Acme&apos;</span>
          </div>
        </div>
      </div>

      {/* ---- Panel 3: SCHEMA --------------------------------------------- */}
      <div style={panel}>
        <div style={panelHead} id="ntp-schema-head">
          <span style={panelNum}>3</span>
          <span style={panelTitle}>Schema</span>
        </div>
        <div style={codeBody}>
          <div class="code-line"><span style={dim}>{'{'}</span></div>
          <div class="code-line">
            <span style={dim}>{'  '}</span><span class="match-blue">email</span><span style={dim}>: …,</span>
          </div>
          <div class="code-line">
            <span style={dim}>{'  '}</span><span class="match-orange">role</span><span style={dim}>: …,</span>
          </div>
          <div class="code-line">
            <span style={dim}>{'  '}</span><span class="match-violet">company</span><span style={dim}>: …,</span>
          </div>
          <div class="code-line"><span style={dim}>{'}'}</span></div>
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>

<style define:vars={{ mono, blue: BLUE, orange: ORANGE, violet: VIOLET, surface: SURFACE }}>
  .code-line {
    box-sizing: border-box;
    margin: 0;
    font-family: var(--mono);
    font-size: 12.5px;
    font-weight: 600;
    line-height: 1.45;
    white-space: pre;
    width: max-content;
  }

  /* the shared-name tokens: translucent tint + 1px inset ring of the matching
     color, so the identity reads at a glance across all three panels. */
  .match-blue,
  .match-orange,
  .match-violet {
    border-radius: 4px;
    padding: 0 3px;
    margin: 0;
    font-weight: 800;
  }

  .match-blue {
    color: var(--blue);
    background: color-mix(in srgb, var(--blue) 16%, var(--surface));
    box-shadow: inset 0 0 0 1px var(--blue);
  }

  .match-orange {
    color: var(--orange);
    background: color-mix(in srgb, var(--orange) 16%, var(--surface));
    box-shadow: inset 0 0 0 1px var(--orange);
  }

  .match-violet {
    color: var(--violet);
    background: color-mix(in srgb, var(--violet) 16%, var(--surface));
    box-shadow: inset 0 0 0 1px var(--violet);
  }
</style>
