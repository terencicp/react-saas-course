---
// Submit lifecycle strip — one frame of the seven-beat <form action={fn}>
// handshake, rendered inside a <DiagramSequence>. Scrubbing the slider walks
// click → validate → serialize → call (POST) → Server Action → Result +
// revalidate → reset, lighting exactly one node per step and marking every
// prior node done. The keystone the figure makes visible is OWNERSHIP: which
// beats belong to the browser, which to React on the client, and which to the
// student's Server Action — so the takeaway "you write neither the POST nor the
// FormData construction" reads straight off the colours.
//
// Ownership is carried two ways, both robust to the strip wrapping in a narrow
// content column: (1) a persistent owner tint on every node's border + label —
// blue = Browser, violet = React (client), teal = Server — dim when idle and
// saturated when on/done; (2) a legend above that maps colour → owner and
// highlights the active owner. React owns nodes 3, 4 AND 7 (non-contiguous), so
// colour, not a positional band, is what ties node 7 back to 3-4.
//
// The strip is a wrapping row of pills joined by light chevrons. Order is read
// left-to-right, top-to-bottom, reinforced by the done-checks always sitting on
// the earlier nodes — so the sequence stays unambiguous even when it wraps onto
// two or three rows in a narrow column (respecting the height cap). Pure
// HTML + CSS, matching the chapter's other DiagramSequence figures: a
// `not-content` wrapper, theme gray variables for idle chrome, and `margin: 0`
// on every inner element to defeat Starlight's prose-margin selector.

interface Props {
  step: 1 | 2 | 3 | 4 | 5 | 6 | 7;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Three owner families, each distinct in both light and dark themes.
type Owner = "browser" | "react" | "server";
const OWNER_COLOR: Record<Owner, string> = {
  browser: "#2563eb", // blue-600
  react: "#7c3aed", // violet-600 — "React owns it"
  server: "#0d9488", // teal-600
};
const OWNER_LABEL: Record<Owner, string> = {
  browser: "Browser",
  react: "React (client)",
  server: "Server",
};

// The seven beats, in submit order. `label` is the short monospace pill text.
const NODES: { label: string; owner: Owner }[] = [
  { label: "click", owner: "browser" },
  { label: "validate", owner: "browser" },
  { label: "serialize", owner: "react" },
  { label: "call (POST)", owner: "react" },
  { label: "Server Action (ch. 43)", owner: "server" },
  { label: "Result + revalidate", owner: "server" },
  { label: "reset", owner: "react" },
];

const activeOwner = NODES[step - 1].owner;

// --- node chrome ---------------------------------------------------------
// A pill is idle (grey), done (filled muted owner tint + check), or on
// (saturated owner tint + glow). Done/on share the owner colour so the
// progress fill reads as "this owner handled it".

const pillBase = [
  reset,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "border-radius: 999px",
  "padding: 6px 11px",
  "white-space: nowrap",
  mono,
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "transition: border-color 0.14s, background-color 0.14s, color 0.14s, box-shadow 0.14s",
].join("; ");

const idlePill = `${pillBase}; border: 1.5px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6); color: var(--sl-color-gray-3);`;

const donePill = (c: string) =>
  `${pillBase}; border: 1.5px solid color-mix(in srgb, ${c} 55%, var(--sl-color-gray-4)); background: color-mix(in srgb, ${c} 10%, transparent); color: color-mix(in srgb, ${c} 72%, var(--sl-color-text));`;

const onPill = (c: string) =>
  `${pillBase}; border: 1.5px solid ${c}; background: color-mix(in srgb, ${c} 16%, transparent); color: color-mix(in srgb, ${c} 82%, var(--sl-color-text)); box-shadow: 0 0 0 4px color-mix(in srgb, ${c} 16%, transparent);`;

const pillFor = (index: number) => {
  const c = OWNER_COLOR[NODES[index].owner];
  const n = index + 1;
  if (n === step) return onPill(c);
  if (n < step) return donePill(c);
  return idlePill;
};

// Chevron separator between consecutive pills. It flows (and wraps) with the
// pills and lights once the sequence has crossed it.
const chevron = (afterIndex: number) => {
  const passed = step > afterIndex + 1; // arrow into node (afterIndex+2)
  const c = passed ? OWNER_COLOR[NODES[afterIndex + 1].owner] : "var(--sl-color-gray-4)";
  return [
    "margin: 0 6px",
    sans,
    "flex: 0 0 auto",
    "font-size: 14px",
    "font-weight: 700",
    "line-height: 1",
    "user-select: none",
    `color: ${c}`,
    "transition: color 0.14s",
  ].join("; ");
};

// --- legend --------------------------------------------------------------
const legendSwatch = (owner: Owner) =>
  [
    reset,
    "display: inline-block",
    "width: 10px",
    "height: 10px",
    "border-radius: 3px",
    "flex: 0 0 auto",
    `background: color-mix(in srgb, ${OWNER_COLOR[owner]} 80%, transparent)`,
    `border: 1px solid ${OWNER_COLOR[owner]}`,
  ].join("; ");

const legendItem = (owner: Owner) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "gap: 6px",
    "font-size: 11.5px",
    "font-weight: 600",
    "letter-spacing: 0.01em",
    "color: " + (activeOwner === owner ? OWNER_COLOR[owner] : "var(--sl-color-gray-3)"),
    "transition: color 0.14s",
  ].join("; ");

const owners: Owner[] = ["browser", "react", "server"];
---

<div
  class="sls-root not-content"
  style={`${reset}; ${sans} width: 100%; max-width: 640px; margin-left: auto; margin-right: auto; display: flex; flex-direction: column; gap: 14px;`}
  data-step={step}
>
  {/* Legend — colour → owner, the active owner highlighted */}
  <div
    style={`${reset}; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 8px 18px;`}
  >
    {owners.map((owner) => (
      <span style={legendItem(owner)}>
        <span style={legendSwatch(owner)} aria-hidden="true"></span>
        {OWNER_LABEL[owner]}
      </span>
    ))}
  </div>

  {/* The seven-node strip — each pill carries its leading chevron as one
      non-breaking unit, so the strip wraps cleanly (chevron never orphaned,
      none dangling) left-to-right, top-to-bottom. */}
  <div class="sls-lane" style={`${reset}; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 9px 0;`}>
    {NODES.map((node, i) => {
      const n = i + 1;
      const isDone = n < step;
      const isOn = n === step;
      return (
        <span style={`${reset}; display: inline-flex; align-items: center; flex: 0 0 auto;`}>
          {i > 0 && (
            <span style={chevron(i - 1)} aria-hidden="true">&rsaquo;</span>
          )}
          <span style={pillFor(i)}>
            {isDone && (
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true" style={`${reset}; display: block; flex: 0 0 auto;`}>
                <path d="M2.5 6.5 L5 9 L9.5 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            )}
            {isOn && (
              <span
                aria-hidden="true"
                style={`${reset}; display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex: 0 0 auto;`}
              ></span>
            )}
            {node.label}
          </span>
        </span>
      );
    })}
  </div>
</div>
