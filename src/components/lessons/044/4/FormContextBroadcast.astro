---
// Diagram: form context broadcast (diagram id: form-context-broadcast,
// Chapter 044 Lesson 4 — "useFormStatus and the SubmitButton"). The lesson's
// single figure and its core mental model: a `<form>` broadcasts its in-flight
// state on an implicit React context to everything nested INSIDE it; a
// descendant `<SubmitButton>` tunes in via `useFormStatus().pending`. The
// OWNING component (`CreateInvoiceForm`) renders the form but sits OUTSIDE that
// subtree — it learns the same fact a different way, via
// `useActionState().isPending`, on a SEPARATE channel that never goes through
// the form's context.
//
// Layout, left -> right (horizontal, height-capped per the laptop-short
// constraint):
//   LEFT  — the OWNER box "CreateInvoiceForm". Two anchorable sub-rows: the
//           component name strip, and an `useActionState() -> isPending` row.
//           A footer line `renders the <form> below` makes the structural
//           relation explicit (owner renders the form, but is not inside it)
//           WITHOUT spending a third arrow in the gap.
//   RIGHT — a large `<form>` container box (the context source). A tinted
//           header strip "form context · broadcasts to descendants" is the
//           origin of the broadcast; below it two NESTED child boxes stacked
//           vertically: `<Input>` and `<SubmitButton>` (the latter annotated
//           with `useFormStatus()`).
//
// Two semantic arrows, two distinct colors:
//   GREEN  `pending`  — the descendant channel. From the form-context header
//                       DOWN to the `<SubmitButton>` box. Lives entirely inside
//                       the form box (the form publishes, the nested button
//                       receives). Left-side arc so it never crosses the
//                       `<Input>` text.
//   BLUE   `isPending` — the owner's separate path. A short loop WITHIN the
//                        owner box: from the component-name strip down to its
//                        own `useActionState -> isPending` row. Drawn as a
//                        loop-back into the LEFT margin (sockets on the same
//                        side) so it reads "the owner holds this in place,"
//                        clearly NOT reaching into the form. Split endpoints
//                        (two sub-rows) keep it a real two-anchor line, which
//                        leader-line renders far more reliably than a true
//                        self-loop on one element.
//
// The two colors carry the whole point: two different ways to learn the SAME
// fact, from two DIFFERENT positions. The caption states the "same fact"
// relationship the colors don't.
//
// House style mirrors ch 044 L1 (NameThreePlaces.astro): pinned
// `color-scheme: light` so the hand-picked tints survive dark mode; inline
// style strings + `box-sizing: border-box` + `margin: 0` throughout to defeat
// Starlight's injected prose margins. ArrowDiagram uses leader-line, so the
// wrapping <Figure> MUST set `expandable={false}` (done in the MDX).

import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text / chrome
const SURFACE = '#ffffff';
const PANEL_BORDER = '#e2e8f0'; // slate-200 — neutral chrome
const PANEL_BG = '#f8fafc'; // slate-50 — owner panel wash

// the two channel colors — one per hook/position.
const GREEN = '#16a34a'; // descendant channel — useFormStatus().pending
const BLUE = '#2563eb'; // owner channel — useActionState().isPending

// ---- styles --------------------------------------------------------------
const stage = [
  'box-sizing: border-box',
  'margin: 0',
  // a touch of side padding so the blue loop-back has air in the left margin.
  'padding: 10px 18px 6px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// two columns: owner (sized to content) and the form box (a bit wider). A
// generous gap gives the (single, internal) arrows air and reads the two as
// distinct positions in the tree.
const flow = [
  'box-sizing: border-box',
  'display: grid',
  'grid-template-columns: max-content max-content',
  'justify-content: center',
  'align-items: center',
  'gap: 64px',
  'margin: 0',
].join('; ');

// ---- owner box -----------------------------------------------------------
const ownerBox = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 9px',
  'margin: 0',
  'padding: 14px 16px',
  'border-radius: 14px',
  `border: 1.5px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG}`,
].join('; ');

const ownerName = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'gap: 7px',
  'align-self: flex-start',
  'margin: 0',
  'padding: 5px 10px',
  'border-radius: 8px',
  `border: 1.5px solid ${PANEL_BORDER}`,
  `background: ${SURFACE}`,
].join('; ');

const ownerNameText = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 12.5px',
  'font-weight: 800',
  `color: ${INK}`,
  'line-height: 1.2',
].join('; ');

const ownerTag = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'letter-spacing: 0.05em',
  'text-transform: uppercase',
  `color: ${INK_SOFT}`,
  'line-height: 1',
].join('; ');

// the `useActionState -> isPending` row — the blue arrow's landing point.
const ownerHookRow = [
  'box-sizing: border-box',
  'align-self: flex-start',
  'margin: 0',
  'padding: 5px 10px',
  'border-radius: 8px',
  `border: 1.5px dashed ${BLUE}`,
  `background: color-mix(in srgb, ${BLUE} 7%, ${SURFACE})`,
  `font-family: ${mono}`,
  'font-size: 11.5px',
  'font-weight: 700',
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

// footer note: the structural relation (owner renders the form, is outside it).
const ownerFoot = [
  'margin: 2px 0 0',
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 600',
  'font-style: italic',
  `color: ${INK_SOFT}`,
  'line-height: 1.25',
].join('; ');

// ---- form box (the context source) ---------------------------------------
const formBox = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 10px',
  'margin: 0',
  'padding: 12px 14px 14px',
  'border-radius: 16px',
  `border: 2px solid ${GREEN}`,
  `background: color-mix(in srgb, ${GREEN} 5%, ${SURFACE})`,
].join('; ');

const formLabel = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: baseline',
  'gap: 8px',
  'margin: 0 0 1px',
].join('; ');

const formTag = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 12.5px',
  'font-weight: 800',
  `color: ${GREEN}`,
  'line-height: 1.2',
].join('; ');

const formTagNote = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 700',
  `color: ${INK_SOFT}`,
  'line-height: 1.2',
].join('; ');

// the context header strip — the origin of the green broadcast.
const ctxStrip = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 7px',
  'margin: 0',
  'padding: 6px 11px',
  'border-radius: 9px',
  `border: 1.5px solid ${GREEN}`,
  `background: color-mix(in srgb, ${GREEN} 13%, ${SURFACE})`,
].join('; ');

const ctxDot = [
  'flex: 0 0 auto',
  'width: 7px',
  'height: 7px',
  'border-radius: 999px',
  `background: ${GREEN}`,
  'margin: 0',
].join('; ');

const ctxText = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 10.5px',
  'font-weight: 800',
  'letter-spacing: 0.02em',
  `color: ${GREEN}`,
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

// the nested-children rail, indented to read as "inside the form".
const childRail = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 8px',
  'margin: 0',
  'padding-left: 16px',
  `border-left: 2px solid color-mix(in srgb, ${GREEN} 35%, ${SURFACE})`,
].join('; ');

const childBox = [
  'box-sizing: border-box',
  'margin: 0',
  'padding: 6px 11px',
  'border-radius: 9px',
  `border: 1.5px solid ${PANEL_BORDER}`,
  `background: ${SURFACE}`,
  `font-family: ${mono}`,
  'font-size: 12px',
  'font-weight: 800',
  `color: ${INK}`,
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

// the SubmitButton child — the green arrow's landing point. Highlighted as the
// receiver, with its hook annotated inline.
const submitBox = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 2px',
  'margin: 0',
  'padding: 6px 11px',
  'border-radius: 9px',
  `border: 1.5px solid ${GREEN}`,
  `background: color-mix(in srgb, ${GREEN} 9%, ${SURFACE})`,
].join('; ');

const submitName = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 12px',
  'font-weight: 800',
  `color: ${INK}`,
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

const submitHook = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 10px',
  'font-weight: 700',
  `color: ${GREEN}`,
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

// the blue token inside the owner hook row.
const blueTok = `color: ${BLUE}; font-weight: 800;`;
const dim = `color: ${INK_SOFT};`;
---

<div style={stage}>
  <ArrowDiagram
    arrows={[
      {
        // GREEN — descendant channel: form context -> SubmitButton.
        from: 'fcb-ctx',
        to: 'fcb-submit',
        label: 'pending',
        color: GREEN,
        startSocket: 'left',
        endSocket: 'left',
        startSocketGravity: [-34, 0],
        endSocketGravity: [-34, 0],
        labelOffset: [-6, 0],
      },
      {
        // BLUE — owner channel: a loop WITHIN the owner (name -> hook row),
        // bowing into the left margin, never touching the form.
        from: 'fcb-owner-name',
        to: 'fcb-owner-hook',
        label: 'isPending',
        color: BLUE,
        startSocket: 'left',
        endSocket: 'left',
        startSocketGravity: [-30, 0],
        endSocketGravity: [-30, 0],
        labelOffset: [-8, 0],
      },
    ]}
  >
    <div style={flow}>
      {/* ---- OWNER (outside the form) ----------------------------------- */}
      <div style={ownerBox}>
        <div style={ownerName} id="fcb-owner-name">
          <span style={ownerNameText}>CreateInvoiceForm</span>
          <span style={ownerTag}>owner</span>
        </div>
        <div style={ownerHookRow} id="fcb-owner-hook">
          <span style={dim}>useActionState() &rarr; </span><span style={blueTok}>isPending</span>
        </div>
        <p style={ownerFoot}>renders the <code style={`font-family: ${mono}; font-style: normal; font-weight: 700;`}>&lt;form&gt;</code>, but is not inside it</p>
      </div>

      {/* ---- FORM (the context source) --------------------------------- */}
      <div style={formBox}>
        <div style={formLabel}>
          <span style={formTag}>&lt;form&gt;</span>
          <span style={formTagNote}>context source</span>
        </div>
        <div style={ctxStrip} id="fcb-ctx">
          <span style={ctxDot}></span>
          <span style={ctxText}>form context &middot; broadcasts to descendants</span>
        </div>
        <div style={childRail}>
          <div style={childBox}>&lt;Input&gt;</div>
          <div style={submitBox} id="fcb-submit">
            <span style={submitName}>&lt;SubmitButton&gt;</span>
            <span style={submitHook}>useFormStatus()</span>
          </div>
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>
