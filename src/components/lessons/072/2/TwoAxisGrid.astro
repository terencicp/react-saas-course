---
// TwoAxisGrid — Chapter 072 Lesson 2, "Picking the right invalidation call".
//
// The lesson's conceptual hinge: the four Next.js invalidation calls are not a
// flat list to memorize, they are the four corners of a 2x2 grid spanned by two
// binary axes. The diagram makes that orthogonality visible so the decision tree
// later feels inevitable rather than arbitrary.
//
//   Columns  → axis 2 (tiebreaker): Tag | Path
//   Rows     → axis 1 (primary):    Read-your-writes | Eventual
//
// The two rows are painted as distinct colour bands (read-your-writes = violet,
// eventual = teal) because axis 1 is the one that carries ~80% of decisions —
// the band makes "which row am I in?" the dominant read. Each cell names its
// call in prominent monospace; router.refresh() carries a small annotation
// because it is the no-tag corner and the lesson's top misconception.
//
// Engine: plain HTML + CSS grid — the diagrams index's pick for a layout concept
// rendered with real CSS, devtools-inspectable. `.not-content` plus a `margin: 0`
// reset on every descendant defeat Starlight's prose-margin injection. The
// <Figure> wrapper and caption come from the MDX call site.

const ALT =
	"A two-by-two grid mapping the four cache-invalidation calls onto two binary axes. " +
	"Columns are the secondary axis, tag versus path. Rows are the primary axis, read-your-writes versus eventual. " +
	"Top row, read-your-writes: the tag cell is updateTag(tag); the path cell is router.refresh(), which carries no tag and re-renders the whole route. " +
	"Bottom row, eventual: the tag cell is revalidateTag(tag, 'max'); the path cell is revalidatePath(path).";
---

<div class="tag not-content" role="img" aria-label={ALT}>
	{/* ── Header row: corner + the two column (axis-2) headers ───────────────── */}
	<div class="tag-corner">
		<span class="tag-corner-axis2">axis 2 &rarr;</span>
		<span class="tag-corner-axis1">&darr; axis 1</span>
	</div>
	<div class="tag-colhead">Tag<span class="tag-colhead-sub">names one entity</span></div>
	<div class="tag-colhead">Path<span class="tag-colhead-sub">names a route</span></div>

	{/* ── Row 1 — read-your-writes ───────────────────────────────────────────── */}
	<div class="tag-rowhead" data-band="ryw">
		<span class="tag-rowhead-title">Read-your-writes</span>
		<span class="tag-rowhead-sub">someone is watching</span>
	</div>
	<div class="tag-cell" data-band="ryw">
		<code class="tag-call">updateTag(tag)</code>
		<span class="tag-note">expires now, next render is fresh</span>
	</div>
	<div class="tag-cell" data-band="ryw">
		<code class="tag-call">router.refresh()</code>
		<span class="tag-note">no tag &mdash; re-renders the whole route</span>
	</div>

	{/* ── Row 2 — eventual ───────────────────────────────────────────────────── */}
	<div class="tag-rowhead" data-band="eventual">
		<span class="tag-rowhead-title">Eventual</span>
		<span class="tag-rowhead-sub">nobody is waiting</span>
	</div>
	<div class="tag-cell" data-band="eventual">
		<code class="tag-call">revalidateTag(tag, 'max')</code>
		<span class="tag-note">marks stale, next reader refreshes</span>
	</div>
	<div class="tag-cell" data-band="eventual">
		<code class="tag-call">revalidatePath(path)</code>
		<span class="tag-note">coarse fallback when no tag fits</span>
	</div>
</div>

<style>
	.tag {
		margin: 0;
		box-sizing: border-box;
		display: grid;
		grid-template-columns: minmax(118px, 0.85fr) 1fr 1fr;
		grid-auto-rows: auto;
		gap: 8px;
		width: 100%;
		max-width: 620px;
		margin-left: auto;
		margin-right: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.tag * {
		box-sizing: border-box;
		margin: 0;
	}

	/* ── The empty top-left corner, carrying tiny axis labels ───────────────── */
	.tag-corner {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		align-items: flex-start;
		gap: 2px;
		padding: 0 4px 6px;
	}
	.tag-corner-axis2,
	.tag-corner-axis1 {
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-4, #94a3b8);
		line-height: 1.2;
	}

	/* ── Column headers (axis 2: tag vs path) ───────────────────────────────── */
	.tag-colhead {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		padding: 6px 8px;
		text-align: center;
		font-size: 13px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		border-bottom: 2px solid var(--sl-color-gray-5, #d0d5dd);
	}
	.tag-colhead-sub {
		font-size: 9.5px;
		font-weight: 600;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── Row headers (axis 1: the two bands) ────────────────────────────────── */
	.tag-rowhead {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 3px;
		padding: 12px 12px;
		border-radius: 11px;
		border: 1.5px solid color-mix(in srgb, var(--tag-accent) 55%, var(--sl-color-hairline));
		background: color-mix(in srgb, var(--tag-accent) 16%, var(--sl-color-bg));
	}
	.tag-rowhead-title {
		font-size: 12.5px;
		font-weight: 800;
		line-height: 1.2;
		color: color-mix(in srgb, var(--tag-accent) 32%, var(--sl-color-white));
	}
	.tag-rowhead-sub {
		font-size: 9.5px;
		font-weight: 600;
		font-style: italic;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── A coordinate cell — its call name is the prominent thing ───────────── */
	.tag-cell {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		padding: 12px 14px;
		min-width: 0;
		border-radius: 11px;
		border: 1.5px solid color-mix(in srgb, var(--tag-accent) 38%, var(--sl-color-hairline));
		background: color-mix(in srgb, var(--tag-accent) 7%, var(--sl-color-bg));
	}
	.tag-call {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.25;
		color: color-mix(in srgb, var(--tag-accent) 24%, var(--sl-color-white));
		background: transparent;
		padding: 0;
		border: 0;
		word-break: break-word;
		white-space: normal;
	}
	.tag-note {
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── The two bands: a colour per axis-1 value ───────────────────────────── */
	[data-band="ryw"] {
		--tag-accent: #7c3aed;
	}
	[data-band="eventual"] {
		--tag-accent: #0d9488;
	}

	/* ── Narrow viewports: drop the row-header column, label each band inline ── */
	@media (max-width: 540px) {
		.tag {
			grid-template-columns: 1fr 1fr;
			gap: 6px;
		}
		.tag-corner {
			display: none;
		}
		.tag-colhead {
			grid-column: span 1;
		}
		.tag-rowhead {
			grid-column: 1 / -1;
		}
		.tag-rowhead {
			flex-direction: row;
			align-items: baseline;
			gap: 8px;
		}
	}
</style>
