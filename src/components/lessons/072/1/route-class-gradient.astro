---
// route-class-gradient (diagram id: route-class-gradient, Chapter 072 L1).
// The three route classes drawn as one left→right gradient: at the left end
// everything renders at request time, at the right end everything renders at
// build time, with "partially cached" as the middle that mixes the two.
//
// Three equal columns, each a heading + subheading + example route chips above
// a single "render band" that encodes WHEN the route's content is produced:
//
//   Col 1 "Fully dynamic" — one SOLID amber band, label "dynamic / per request".
//     Routes /dashboard, /invoices, /settings. Every read at request time.
//   Col 2 "Partially cached" — the teaching moment: a NEUTRAL static shell band
//     with a carved-out TEAL "cached read" hole punched inside it, echoing the
//     PPR shell-and-holes picture the student already met in Ch032. Route
//     /invoices/[id].
//   Col 3 "Fully static" — one SOLID slate band, label "static / at build".
//     Routes /pricing, /(marketing), /docs. Prerendered, identical bytes.
//
// A thin gradient rail beneath the columns spells out the axis the columns sit
// on: "all request-time"  ←———→  "all build-time".
//
// Encoding: horizontal position = where the route lands on the request→build
// gradient; band fill = when content is produced. Amber = dynamic, teal =
// cached, slate = static/build-time — the chapter-wide tints lifted verbatim
// from Ch032's strips so cached/dynamic read continuously across the chapter.
//
// Hand-authored markup → wrapped in <Figure>. Pure HTML + CSS, inline style
// strings only. color-scheme pinned light so the semantic tints survive dark
// mode; margin:0 on every inner node to defeat Starlight's injected prose
// margin-top. Columns wrap on narrow viewports (flex-wrap).

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette — fixed, color-scheme pinned light (lifted verbatim from Ch032's
// strips so cached/dynamic/static read continuously across the chapter).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// STATIC / SHELL — slate (build-time, no per-request work).
const SLATE = '#475569'; // slate-600
const SLATE_BG = '#f1f5f9'; // slate-100 wash
const SLATE_EDGE = '#cbd5e1'; // slate-300
const SLATE_INK = '#334155'; // slate-700

// CACHED — teal.
const TEAL = '#0d9488'; // teal-600
const TEAL_BG = '#f0fdfa'; // teal-50 wash
const TEAL_INK = '#0f766e'; // teal-700

// DYNAMIC — amber.
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 wash
const AMBER_INK = '#b45309'; // amber-700

// ---- shared atoms ----------------------------------------------------------

// Outer stage: pinned light, slate ink.
const stage = `margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK}; max-width: 760px; margin-left: auto; margin-right: auto;`;

// The three columns row. Wraps on narrow viewports; equal flex basis.
const cols = `display: flex; align-items: stretch; flex-wrap: wrap; column-gap: 12px; row-gap: 16px; margin: 0; width: 100%;`;
const col = `box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; flex: 1 1 200px; min-width: 0; margin: 0;`;

// Column head block.
const colHead = `display: flex; flex-direction: column; gap: 2px; margin: 0;`;
const colTitle = `margin: 0; font-family: ${sans}; font-size: 14px; font-weight: 800; line-height: 1.2;`;
const colSub = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.3; color: ${INK_SOFT};`;

// Route chips row under each head.
const chips = `display: flex; flex-wrap: wrap; gap: 5px; margin: 0;`;
const chip = (edge: string, ink: string) =>
	`box-sizing: border-box; margin: 0; padding: 2px 7px; border: 1px solid ${edge}; border-radius: 6px; background: ${SURFACE}; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.4; color: ${ink}; white-space: nowrap;`;

// The render band — a fixed-height block whose fill encodes when content is made.
const BAND_H = '108px';

// Solid band (dynamic, static).
const band = (edge: string, bg: string) =>
	`box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; height: ${BAND_H}; margin: 0; padding: 10px; border: 1.5px solid ${edge}; border-radius: 10px; background: ${bg};`;

// The partial band: a static shell wrapper with a cached hole carved inside.
const shellBand = `box-sizing: border-box; display: flex; flex-direction: column; align-items: stretch; justify-content: flex-start; gap: 6px; height: ${BAND_H}; margin: 0; padding: 8px; border: 1.5px solid ${SLATE_EDGE}; border-radius: 10px; background: ${SLATE_BG};`;
const shellLabel = `display: flex; align-items: center; justify-content: center; gap: 5px; margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 800; line-height: 1.2; color: ${SLATE_INK}; text-transform: uppercase; letter-spacing: 0.03em;`;
const hole = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; flex: 1 1 auto; margin: 0; padding: 6px; border: 1.5px solid ${TEAL}; border-radius: 7px; background: ${TEAL_BG};`;

// Band label + sublabel.
const bandLabel = (ink: string) =>
	`display: flex; align-items: center; justify-content: center; margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 800; line-height: 1.2; text-align: center; color: ${ink};`;
const bandSub = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.3; text-align: center; color: ${ink};`;
const holeName = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 800; line-height: 1.2; color: ${TEAL_INK};`;
const holeSub = `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; line-height: 1.2; color: ${TEAL_INK};`;
const dot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 7px; height: 7px; margin: 0; border-radius: 50%; background: ${c};`;

// ---- the gradient rail beneath the columns ---------------------------------
const railWrap = `display: flex; flex-direction: column; gap: 4px; margin: 16px 0 0; width: 100%;`;
const rail = `height: 8px; margin: 0; border-radius: 999px; background: linear-gradient(90deg, ${AMBER} 0%, ${TEAL} 50%, ${SLATE} 100%);`;
const railEnds = `display: flex; align-items: baseline; justify-content: space-between; margin: 0;`;
const railEnd = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 800; line-height: 1.2; color: ${INK_SOFT}; text-transform: uppercase; letter-spacing: 0.04em;`;
---

<Figure caption="Every route lands somewhere on the request-time to build-time gradient. The middle is Partial Prerendering: a static shell with a cached read punched into it.">
	<div style={stage}>
		<div style={cols}>
			{/* ============ COL 1 — FULLY DYNAMIC ============ */}
			<div style={col}>
				<div style={colHead}>
					<span style={colTitle}>Fully dynamic</span>
					<span style={colSub}>Rendered per request</span>
				</div>
				<div style={chips}>
					<span style={chip(AMBER_INK, AMBER_INK)}>/dashboard</span>
					<span style={chip(AMBER_INK, AMBER_INK)}>/invoices</span>
					<span style={chip(AMBER_INK, AMBER_INK)}>/settings</span>
				</div>
				<div style={band(AMBER, AMBER_BG)}>
					<span style={bandLabel(AMBER_INK)}>
						<span style={dot(AMBER)} aria-hidden="true"></span>&nbsp;dynamic
					</span>
					<span style={bandSub(AMBER_INK)}>every read at request time</span>
				</div>
			</div>

			{/* ============ COL 2 — PARTIALLY CACHED ============ */}
			<div style={col}>
				<div style={colHead}>
					<span style={colTitle}>Partially cached</span>
					<span style={colSub}>Static shell, cached holes</span>
				</div>
				<div style={chips}>
					<span style={chip(SLATE_EDGE, INK)}>/invoices/[id]</span>
				</div>
				<div style={shellBand}>
					<span style={shellLabel}>shell &middot; static</span>
					<div style={hole}>
						<span style={holeName}>cached read</span>
						<span style={holeSub}>the invoice subtree</span>
					</div>
				</div>
			</div>

			{/* ============ COL 3 — FULLY STATIC ============ */}
			<div style={col}>
				<div style={colHead}>
					<span style={colTitle}>Fully static</span>
					<span style={colSub}>Prerendered at build</span>
				</div>
				<div style={chips}>
					<span style={chip(SLATE_EDGE, INK)}>/pricing</span>
					<span style={chip(SLATE_EDGE, INK)}>/(marketing)</span>
					<span style={chip(SLATE_EDGE, INK)}>/docs</span>
				</div>
				<div style={band(SLATE, SLATE_BG)}>
					<span style={bandLabel(SLATE_INK)}>
						<span style={dot(SLATE)} aria-hidden="true"></span>&nbsp;static
					</span>
					<span style={bandSub(SLATE_INK)}>whole page at build time</span>
				</div>
			</div>
		</div>

		{/* ============ THE GRADIENT RAIL ============ */}
		<div style={railWrap} aria-hidden="true">
			<div style={rail}></div>
			<div style={railEnds}>
				<span style={railEnd}>all request-time</span>
				<span style={railEnd}>all build-time</span>
			</div>
		</div>
	</div>
</Figure>
