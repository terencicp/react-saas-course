---
// data-cache-mirror (diagram id: data-cache-mirror, Chapter 072 L1).
// The org-scoped cache tag is the cache-layer MIRROR of the org-scoped data
// layer. Two visually-parallel panels make that symmetry obvious:
//
//   Left  "Data layer"  — tenantDb(orgId)      → rows for org A only
//   Right "Cache layer" — org:A:invoices (tag)  → cached reads for org A only
//
// A single "shared key · orgId" pill sits BETWEEN the two panels, wired up to
// both with short connector stubs, so the reader sees literally one orgId
// feeding both sides. Both panels carry the same teal "org A" tint (the
// chapter-wide cached/org color), reinforcing that it is the SAME scope shape
// running through both layers.
//
// Each panel: heading → a mono code chip (the scoping call/tag) → a down arrow
// → an outcome box scoped to "org A only". The arrow encodes "this scope
// produces exactly this slice — and nothing from other orgs."
//
// Hand-authored markup → wrapped in <Figure>. Pure HTML + CSS, inline style
// strings only. color-scheme pinned light so the teal tint survives dark mode;
// margin:0 on every inner node to defeat Starlight's injected prose margin-top.
// Panels stack on narrow viewports (flex-wrap), with the shared-key pill
// dropping between them.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette — pinned light. Teal = the org-A / cache color carried across Ch072.
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

const TEAL = '#0d9488'; // teal-600 — org A boundary
const TEAL_BG = '#f0fdfa'; // teal-50 wash
const TEAL_EDGE = '#5eead4'; // teal-300
const TEAL_INK = '#0f766e'; // teal-700

// ---- shared atoms ----------------------------------------------------------

const stage = `margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK}; max-width: 720px; margin-left: auto; margin-right: auto;`;

// The two-panel row + the bridge between them. Wraps on narrow viewports.
const row = `display: flex; align-items: stretch; flex-wrap: wrap; justify-content: center; gap: 0; margin: 0; width: 100%;`;

// A panel — equal flex basis, its own teal-tinted card.
const panel = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 10px; flex: 1 1 230px; min-width: 0; margin: 0; padding: 16px 14px; border: 1.5px solid ${TEAL_EDGE}; border-radius: 12px; background: ${TEAL_BG};`;

const panelHead = `display: flex; flex-direction: column; align-items: center; gap: 2px; margin: 0;`;
const panelTitle = `margin: 0; font-family: ${sans}; font-size: 14px; font-weight: 800; line-height: 1.2; color: ${INK};`;
const panelSub = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.3; color: ${INK_SOFT};`;

// The mono code chip (scoping call / cache tag).
const chip = `box-sizing: border-box; display: inline-flex; align-items: center; margin: 0; padding: 7px 11px; border: 1.5px solid ${TEAL}; border-radius: 8px; background: ${SURFACE}; font-family: ${mono}; font-size: 13px; font-weight: 800; line-height: 1.3; color: ${TEAL_INK}; white-space: nowrap; max-width: 100%; overflow: hidden; text-overflow: ellipsis;`;

// Down arrow between chip and outcome.
const arrow = `margin: 0; font-size: 16px; line-height: 1; color: ${TEAL}; font-weight: 800;`;

// Outcome box — the slice this scope produces.
const outcome = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 3px; margin: 0; padding: 9px 12px; border: 1.5px dashed ${TEAL}; border-radius: 8px; background: ${SURFACE}; width: 100%; max-width: 220px;`;
const outcomeMain = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 800; line-height: 1.25; text-align: center; color: ${INK};`;
const outcomeTag = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 800; line-height: 1; letter-spacing: 0.04em; text-transform: uppercase; color: ${TEAL_INK};`;

// ---- the bridge: shared key · orgId ----------------------------------------
// A center column carrying a connector stub + the shared-key pill + a stub.
const bridge = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; flex: 0 0 auto; margin: 0; padding: 0 6px; align-self: center;`;
const stub = `width: 22px; height: 0; margin: 0; border-top: 2px dashed ${TEAL};`;
const keyPill = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 1px; margin: 0; padding: 8px 12px; border: 1.5px solid ${TEAL}; border-radius: 999px; background: ${TEAL}; box-shadow: 0 1px 4px rgba(13, 148, 136, 0.35);`;
const keyLabel = `margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; line-height: 1; letter-spacing: 0.05em; text-transform: uppercase; color: ${TEAL_BG};`;
const keyValue = `margin: 0; font-family: ${mono}; font-size: 14px; font-weight: 800; line-height: 1.1; color: ${SURFACE};`;
---

<Figure caption="One scope shape runs through both layers — tenantDb(orgId) on reads, org:${orgId}:invoices on the cache. The same orgId keys both sides, so a mutation in one org's scope invalidates only that org's cached reads.">
	<div style={stage}>
		<div style={row}>
			{/* ============ LEFT — DATA LAYER ============ */}
			<div style={panel}>
				<div style={panelHead}>
					<span style={panelTitle}>Data layer</span>
					<span style={panelSub}>org-scoped reads &amp; writes</span>
				</div>
				<code style={chip}>{"tenantDb(orgId)"}</code>
				<span style={arrow} aria-hidden="true">&darr;</span>
				<div style={outcome}>
					<span style={outcomeMain}>rows for</span>
					<span style={outcomeTag}>org A only</span>
				</div>
			</div>

			{/* ============ BRIDGE — SHARED KEY ============ */}
			<div style={bridge}>
				<div style={stub} aria-hidden="true"></div>
				<div style={keyPill}>
					<span style={keyLabel}>shared key</span>
					<span style={keyValue}>orgId</span>
				</div>
				<div style={stub} aria-hidden="true"></div>
			</div>

			{/* ============ RIGHT — CACHE LAYER ============ */}
			<div style={panel}>
				<div style={panelHead}>
					<span style={panelTitle}>Cache layer</span>
					<span style={panelSub}>org-scoped tags</span>
				</div>
				<code style={chip}>{"org:A:invoices"}</code>
				<span style={arrow} aria-hidden="true">&darr;</span>
				<div style={outcome}>
					<span style={outcomeMain}>cached reads for</span>
					<span style={outcomeTag}>org A only</span>
				</div>
			</div>
		</div>
	</div>
</Figure>
