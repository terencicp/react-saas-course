---
// One Client leaf's two-render lifecycle (diagram id: two-render-lifecycle,
// Chapter 030 L2). A four-step scrubbable DiagramSequence that follows a single
// <MarkPaidButton /> across the server/client boundary, making "runs twice,
// same output both times" visible and temporal so the hydration contract in the
// next paragraph reads as inevitable.
//
// The frame is the chapter's spine metaphor: a persistent two-lane split —
// SERVER (cool/blue) on the left, BROWSER (warm/amber) on the right. Only the
// subject and its status move; the frame never reflows.
//
//   Step 1  Server render — the component runs on the server and produces a
//           plain HTML <button>. No JS yet. The browser lane waits.
//   Step 2  Ship & paint — the same HTML <button> sits on the browser, visible
//           but dead; its JS is still downloading. The server lane is done.
//   Step 3  Hydrate — React re-runs the SAME component in the browser over that
//           HTML and attaches the click handler. The button goes live (green).
//   Step 4  Click works — the (now interactive) button is pressed and reads
//           "Paid". Same component, rendered twice: once for HTML, once for
//           behaviour.
//
// Style follows the chapter-arc house pattern (see 024/2 StaleFrameSequence):
// inline styles from a named palette, color-scheme pinned light so the cool/warm
// tints survive dark mode, margin:0 on every inner element to defeat Starlight's
// injected prose margins, and every step the same shape so the grid stack never
// jumps height as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const BORDER = '#cbd5e1'; // ordinary chip edge (slate-300)
const DIM_INK = '#94a3b8'; // dim/idle ink (slate-400)
const SURFACE = '#ffffff';

// Server = cool / blue (chapter colour language)
const BLUE = '#2563eb'; // blue-600
const BLUE_BG = '#eff6ff'; // blue-50 lane wash
const BLUE_EDGE = '#bfdbfe'; // blue-200 lane edge
const BLUE_INK = '#1e40af'; // blue-800

// Browser/client = warm / amber (chapter colour language)
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 lane wash
const AMBER_EDGE = '#fde68a'; // amber-200 lane edge
const AMBER_INK = '#92400e'; // amber-800

// "Alive / interactive" accent — green, distinct from the warm browser tint so
// the moment of hydration reads as a state change, not just an environment.
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all four steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The phase eyebrow above the split: "step N / 4 — Phase name", with a thin
// progress meter so the four-step temporality is legible at a glance.
const phaseRow = `display: flex; align-items: center; gap: 10px; margin: 0; width: 100%; max-width: 560px;`;
const phaseLabel = `display: flex; align-items: baseline; gap: 7px; margin: 0; white-space: nowrap;`;
const phaseStep = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: ${INK_SOFT};`;
const phaseName = `margin: 0; font-family: ${sans}; font-size: 14px; font-weight: 700; color: ${INK};`;
const meter = `position: relative; flex: 1; height: 4px; border-radius: 2px; background: ${BLUE_EDGE}; overflow: hidden;`;
const meterFill = (pct: number) =>
	`position: absolute; inset: 0 auto 0 0; width: ${pct}%; border-radius: 2px; background: ${BLUE};`;

// The split frame: two lanes side by side, joined by a center wire/gap. Fixed
// width so the boundary stays put as the subject crosses it.
const split = `display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin: 0; width: 100%; max-width: 560px; border-radius: 12px; overflow: hidden; border: 1px solid ${BORDER};`;

// A single lane. `side` = 'server' | 'browser'; `live` brightens the active side
// and dims the inactive one so attention follows the subject across the wire.
const lane = (side: 'server' | 'browser', live: boolean) => {
	const bg = side === 'server' ? BLUE_BG : AMBER_BG;
	const base = `display: flex; flex-direction: column; align-items: center; gap: 9px; margin: 0; padding: 12px 12px 14px; min-height: 150px; background: ${bg};`;
	const edge =
		side === 'server'
			? `border-right: 1px dashed ${BORDER};`
			: '';
	const dim = live ? '' : 'opacity: 0.5; filter: saturate(0.6);';
	return base + edge + dim;
};

// The lane header: an environment label with a tiny dot in the side's colour.
const laneHead = (side: 'server' | 'browser') => {
	const c = side === 'server' ? BLUE_INK : AMBER_INK;
	return `display: inline-flex; align-items: center; gap: 6px; margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: ${c};`;
};
const laneDot = (side: 'server' | 'browser') =>
	`display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin: 0; background: ${side === 'server' ? BLUE : AMBER};`;

// The subject chip — the <MarkPaidButton /> component box, before it renders.
const subjectChip = `display: inline-flex; align-items: center; margin: 0; padding: 7px 11px; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2; color: ${BLUE_INK}; background: ${SURFACE}; border: 1.5px solid ${BLUE}; border-radius: 8px; white-space: nowrap;`;

// The "renders to" arrow inside a lane (vertical).
const innerArrow = `margin: 0; font-family: ${sans}; font-size: 16px; font-weight: 700; line-height: 1; color: ${INK_SOFT};`;

// The produced HTML element — a literal-looking <button> tag chip.
const htmlTag = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${INK_SOFT};`;

// The rendered button itself (what the user would see). `state` drives its look:
//   'html'  — painted but dead (neutral, server-sent HTML)
//   'live'  — hydrated, interactive (green ring)
//   'done'  — pressed / "Paid" result (filled green)
const renderedButton = (state: 'html' | 'live' | 'done') => {
	const base = `display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 8px 14px; font-family: ${sans}; font-size: 13px; font-weight: 700; line-height: 1; border-radius: 8px; white-space: nowrap;`;
	if (state === 'done')
		return base + `color: #ffffff; background: ${GREEN}; border: 1.5px solid ${GREEN}; box-shadow: inset 0 2px 4px rgba(0,0,0,0.18); transform: translateY(1px);`;
	if (state === 'live')
		return base + `color: ${GREEN_INK}; background: ${SURFACE}; border: 1.5px solid ${GREEN}; box-shadow: 0 0 0 3px ${GREEN_BG};`;
	// html: present but visibly inert
	return base + `color: ${INK}; background: ${SURFACE}; border: 1.5px solid ${BORDER};`;
};

// A status pill under the button. `tone` selects the colour family.
const pill = (tone: 'muted' | 'live' | 'done') => {
	const map = {
		muted: [INK_SOFT, '#f1f5f9', BORDER],
		live: [GREEN_INK, GREEN_BG, GREEN],
		done: [GREEN_INK, GREEN_BG, GREEN],
	} as const;
	const [fg, bg, bd] = map[tone];
	return `display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 3px 9px; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.3; color: ${fg}; background: ${bg}; border: 1px solid ${bd}; border-radius: 999px; white-space: nowrap;`;
};

// The "JS downloading" hint — a tiny indeterminate-looking track in step 2.
const jsHint = `display: inline-flex; align-items: center; gap: 7px; margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; color: ${AMBER_INK};`;
const jsTrack = `position: relative; width: 64px; height: 4px; border-radius: 2px; background: ${AMBER_EDGE}; overflow: hidden;`;
const jsTrackFill = (pct: number) =>
	`position: absolute; inset: 0 auto 0 0; width: ${pct}%; border-radius: 2px; background: ${AMBER};`;

// A small "2nd render" annotation that ties step 3 to the contract.
const reRenderTag = `display: inline-flex; align-items: center; margin: 0; padding: 2px 8px; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.3; color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN}; border-radius: 999px; white-space: nowrap;`;

// A faint placeholder line for an empty lane ("waiting…").
const wait = `margin: auto 0; font-family: ${sans}; font-size: 11px; font-weight: 600; font-style: italic; color: ${DIM_INK};`;

// Small reusable inline-code chip for the prose under the subject.
const annot = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT}; text-align: center;`;
---

<DiagramSequence>
	{/* ---- Step 1: Server render — component runs on the server, emits HTML ---- */}
	<DiagramStep caption="On the server, the button renders to plain HTML — no JavaScript involved yet.">
		<div style={stage}>
			<div style={phaseRow}>
				<div style={phaseLabel}>
					<span style={phaseStep}>Step 1 / 4</span>
					<span style={phaseName}>Server render</span>
				</div>
				<div style={meter}><div style={meterFill(8)}></div></div>
			</div>

			<div style={split}>
				<div style={lane('server', true)}>
					<span style={laneHead('server')}><span style={laneDot('server')}></span>Server</span>
					<span style={subjectChip}>&lt;MarkPaidButton /&gt;</span>
					<span style={innerArrow} aria-hidden="true">&darr;</span>
					<span style={htmlTag}>&lt;button&gt;Mark as paid&lt;/button&gt;</span>
					<p style={annot}>runs once, emits HTML</p>
				</div>
				<div style={lane('browser', false)}>
					<span style={laneHead('browser')}><span style={laneDot('browser')}></span>Browser</span>
					<span style={wait}>waiting for HTML…</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Ship & paint — HTML on the browser, visible but dead ---- */}
	<DiagramStep caption="The HTML paints immediately. The user sees the button before its JavaScript arrives — but clicking does nothing.">
		<div style={stage}>
			<div style={phaseRow}>
				<div style={phaseLabel}>
					<span style={phaseStep}>Step 2 / 4</span>
					<span style={phaseName}>Ship &amp; paint</span>
				</div>
				<div style={meter}><div style={meterFill(38)}></div></div>
			</div>

			<div style={split}>
				<div style={lane('server', false)}>
					<span style={laneHead('server')}><span style={laneDot('server')}></span>Server</span>
					<span style={wait}>done — HTML sent</span>
				</div>
				<div style={lane('browser', true)}>
					<span style={laneHead('browser')}><span style={laneDot('browser')}></span>Browser</span>
					<button type="button" style={renderedButton('html')} disabled>Mark as paid</button>
					<span style={pill('muted')}>not interactive yet</span>
					<div style={jsHint}>
						<span style={jsTrack}><span style={jsTrackFill(45)}></span></span>
						JS downloading…
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: Hydrate — same component re-runs in the browser, attaches ---- */}
	<DiagramStep caption="React re-runs the same component in the browser, matches it to the HTML, and attaches the click handler. This is hydration.">
		<div style={stage}>
			<div style={phaseRow}>
				<div style={phaseLabel}>
					<span style={phaseStep}>Step 3 / 4</span>
					<span style={phaseName}>Hydrate</span>
				</div>
				<div style={meter}><div style={meterFill(70)}></div></div>
			</div>

			<div style={split}>
				<div style={lane('server', false)}>
					<span style={laneHead('server')}><span style={laneDot('server')}></span>Server</span>
					<span style={wait}>done — HTML sent</span>
				</div>
				<div style={lane('browser', true)}>
					<span style={laneHead('browser')}><span style={laneDot('browser')}></span>Browser</span>
					<span style={reRenderTag}>same component, 2nd render</span>
					<button type="button" style={renderedButton('live')}>Mark as paid</button>
					<span style={pill('live')}>interactive · onClick attached</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Click works — interactivity is live ---- */}
	<DiagramStep caption="Now interactivity is live. The same component rendered twice — once for instant HTML, once for behaviour.">
		<div style={stage}>
			<div style={phaseRow}>
				<div style={phaseLabel}>
					<span style={phaseStep}>Step 4 / 4</span>
					<span style={phaseName}>Click works</span>
				</div>
				<div style={meter}><div style={meterFill(100)}></div></div>
			</div>

			<div style={split}>
				<div style={lane('server', false)}>
					<span style={laneHead('server')}><span style={laneDot('server')}></span>Server</span>
					<span style={wait}>done — HTML sent</span>
				</div>
				<div style={lane('browser', true)}>
					<span style={laneHead('browser')}><span style={laneDot('browser')}></span>Browser</span>
					<button type="button" style={renderedButton('done')} aria-pressed="true">Paid</button>
					<span style={pill('done')}>&check; marked paid</span>
					<p style={annot}>one component, rendered twice</p>
				</div>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
