---
// Boundary depth (diagram id: boundary-depth, Chapter 030 L2). The chapter's
// "push the boundary down" argument rendered as area: the SAME invoice
// component tree drawn twice, side by side. The shaded (amber / client) region
// is the JavaScript that ships to the browser.
//
//   LEFT  — 'use client' at the page. The boundary line sits across the top,
//           above InvoicesPage, so the WHOLE tree is inside the client region
//           and every box is amber. Caption: "ships: whole tree + formatting
//           deps".
//   RIGHT — 'use client' at the leaf. The boundary line sits low, just above
//           MarkPaidButton, so only that one leaf is amber; every ancestor is
//           the cool/plain server style. Caption: "ships: one button".
//
// The visual rhetoric is L1's ServerBrowserSplit asymmetry restated: a large
// amber area on the left vs. a single amber chip on the right == less shading
// is less bundle. Server = cool/blue, client = warm/amber, matching the
// chapter colour language (see 030/2 TwoRenderLifecycle and 030/1
// ServerBrowserSplit).
//
// Pure HTML + CSS, no JS. color-scheme pinned light so the cool/warm tints
// survive dark mode; margin:0 on every inner element defeats Starlight's
// injected prose margins; the <style> block carries only the responsive stack
// for narrow viewports.

import Figure from '../../../figures/Figure.astro';

// Palette (chapter colour language) ------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff';

// Server = cool / blue
const BLUE = '#2563eb'; // blue-600
const BLUE_BG = '#eff6ff'; // blue-50 wash
const BLUE_EDGE = '#bfdbfe'; // blue-200 edge
const BLUE_INK = '#1e40af'; // blue-800

// Client = warm / amber (the colour that means "ships JS")
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 wash
const AMBER_FILL = '#fef3c7'; // amber-100 — the shaded "ships" fill
const AMBER_EDGE = '#fcd34d'; // amber-300 edge
const AMBER_INK = '#92400e'; // amber-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage: the two panels side by side. Fixed max width so both panels
// share a coordinate system and the boundary lines read as "high" vs "low".
const stage = `display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A panel = its title, the framed tree, and the "ships" strip beneath.
const panel = `display: flex; flex-direction: column; gap: 9px; margin: 0; min-width: 0;`;

const panelTitle = (side: 'page' | 'leaf') => {
	const c = side === 'page' ? AMBER_INK : BLUE_INK;
	const bd = side === 'page' ? AMBER_EDGE : BLUE_EDGE;
	const bg = side === 'page' ? AMBER_BG : BLUE_BG;
	return `display: inline-flex; align-items: center; gap: 7px; align-self: center; margin: 0; padding: 5px 11px; font-family: ${sans}; font-size: 12px; font-weight: 800; color: ${c}; background: ${bg}; border: 1px solid ${bd}; border-radius: 999px; white-space: nowrap;`;
};

// The directive chip inside the title pill.
const titleCode = (side: 'page' | 'leaf') =>
	`margin: 0; font-family: ${mono}; font-size: 11.5px; font-weight: 800; color: ${side === 'page' ? AMBER : BLUE};`;

// The framed area holding the tree. Relative so the boundary line can be an
// absolutely-positioned overlay at a precise height. Same height both sides so
// the two boundary lines are directly comparable.
const frame = `position: relative; margin: 0; padding: 26px 14px 14px; border: 1px solid ${BLUE_EDGE}; border-radius: 12px; background: ${SURFACE}; box-sizing: border-box;`;

// A node box. `fill` selects server (plain/blue) vs client (amber, "ships").
// Nesting is real DOM nesting so devtools shows the true hierarchy.
const node = (fill: 'server' | 'client', extra = '') => {
	const isClient = fill === 'client';
	const bg = isClient ? AMBER_FILL : SURFACE;
	const bd = isClient ? AMBER : BLUE_EDGE;
	return `position: relative; display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 9px 10px; background: ${bg}; border: 1.5px solid ${bd}; border-radius: 9px; box-sizing: border-box; ${extra}`;
};

// The label that sits at the top of each node box.
const label = (fill: 'server' | 'client') => {
	const c = fill === 'client' ? AMBER_INK : BLUE_INK;
	return `display: inline-flex; align-items: center; gap: 6px; margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.1; color: ${c};`;
};

// A tiny dot in the node's colour, echoing the lane dots in TwoRenderLifecycle.
const dot = (fill: 'server' | 'client') =>
	`display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin: 0; background: ${fill === 'client' ? AMBER : BLUE};`;

// "× many" hint shown on the row level to imply a list without drawing N rows.
const manyHint = `margin: 0 0 0 auto; font-family: ${sans}; font-size: 9.5px; font-weight: 700; letter-spacing: 0.04em; color: ${INK_SOFT}; text-transform: uppercase;`;

// The "ships" strip under each panel.
const shipsStrip = (side: 'page' | 'leaf') => {
	const heavy = side === 'page';
	const c = heavy ? AMBER_INK : BLUE_INK;
	const bd = heavy ? AMBER_EDGE : BLUE_EDGE;
	const bg = heavy ? AMBER_BG : BLUE_BG;
	return `display: flex; align-items: baseline; gap: 6px; margin: 0; padding: 7px 11px; border: 1px solid ${bd}; border-radius: 9px; background: ${bg}; color: ${c};`;
};
const shipsKey = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.85;`;
const shipsVal = `margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 700; line-height: 1.25;`;
---

<Figure
	caption="The boundary at the page (left) ships the whole tree to the browser; pushed to the leaf (right), almost nothing ships. The shaded area is the client bundle."
>
	<div class="not-content bd-stage" style={stage}>
		{/* ============================ LEFT: 'use client' at the page ========= */}
		<div class="bd-panel" style={panel}>
			<span style={panelTitle('page')}>
				<span style={titleCode('page')}>'use client'</span> at the page
			</span>

			<div class="bd-frame" style={frame}>
				{/* Boundary line across the very top — the whole tree is below it. */}
				<div class="bd-boundary bd-boundary--high" aria-hidden="true">
					<span class="bd-boundary-pill bd-boundary-pill--client">client boundary</span>
				</div>

				{/* Whole tree is inside the client region: every box amber. */}
				<div style={node('client')}>
					<span style={label('client')}><span style={dot('client')}></span>InvoicesPage</span>
					<div style={node('client')}>
						<span style={label('client')}><span style={dot('client')}></span>InvoiceList</span>
						<div style={node('client', 'gap: 7px;')}>
							<span style={label('client')}>
								<span style={dot('client')}></span>InvoiceRow
								<span style={manyHint}>&times; many</span>
							</span>
							<div style={node('client')}>
								<span style={label('client')}><span style={dot('client')}></span>MarkPaidButton</span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div style={shipsStrip('page')}>
				<span style={shipsKey}>ships</span>
				<span style={shipsVal}>whole tree + formatting deps</span>
			</div>
		</div>

		{/* ============================ RIGHT: 'use client' at the leaf ======== */}
		<div class="bd-panel" style={panel}>
			<span style={panelTitle('leaf')}>
				<span style={titleCode('leaf')}>'use client'</span> at the leaf
			</span>

			<div class="bd-frame" style={frame}>
				{/* Boundary line low, just above the leaf — only it is below. */}
				<div class="bd-boundary bd-boundary--low" aria-hidden="true">
					<span class="bd-boundary-pill bd-boundary-pill--client">client boundary</span>
				</div>

				{/* Ancestors are all server (plain/blue); only the leaf is amber. */}
				<div style={node('server')}>
					<span style={label('server')}><span style={dot('server')}></span>InvoicesPage</span>
					<div style={node('server')}>
						<span style={label('server')}><span style={dot('server')}></span>InvoiceList</span>
						<div style={node('server', 'gap: 7px;')}>
							<span style={label('server')}>
								<span style={dot('server')}></span>InvoiceRow
								<span style={manyHint}>&times; many</span>
							</span>
							<div style={node('client')}>
								<span style={label('client')}><span style={dot('client')}></span>MarkPaidButton</span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div style={shipsStrip('leaf')}>
				<span style={shipsKey}>ships</span>
				<span style={shipsVal}>one button</span>
			</div>
		</div>
	</div>
</Figure>

<style>
	/* The boundary overlay: a dashed horizontal rule across the frame with a
	   "client boundary" pill straddling it. --high sits near the top of the
	   frame (whole tree below it); --low sits near the bottom (only the leaf
	   below it). Both are positioned relative to the .bd-frame. */
	.bd-boundary {
		position: absolute;
		left: 8px;
		right: 8px;
		height: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
		z-index: 2;
	}

	.bd-boundary::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		top: 50%;
		height: 0;
		transform: translateY(-50%);
		border-top: 2px dashed #d97706; /* amber-600 — the client edge */
	}

	.bd-boundary--high {
		top: 13px;
	}

	.bd-boundary--low {
		/* in the gap just above the single leaf box (the last element in the
		   frame), so only MarkPaidButton sits below the line */
		bottom: 86px;
	}

	.bd-boundary-pill {
		position: relative;
		margin: 0;
		padding: 2px 9px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 10px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border-radius: 999px;
		white-space: nowrap;
		z-index: 1;
	}

	.bd-boundary-pill--client {
		color: #92400e; /* amber-800 */
		background: #fffbeb; /* amber-50 — breaks the dashed line behind it */
		border: 1px solid #fcd34d; /* amber-300 */
	}

	/* Narrow viewports: stack the two panels vertically so neither tree
	   gets crushed. The boundary lines stay high/low within each frame. */
	@media (max-width: 560px) {
		.bd-stage {
			grid-template-columns: 1fr !important;
			gap: 22px !important;
		}
	}
</style>
