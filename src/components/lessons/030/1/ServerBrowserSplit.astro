---
// server-browser-split — the spine diagram of Lesson 30.1.
//
// One durable, horizontal picture the student recalls to anchor every later
// capability to a side of the server/client boundary. Two zones split by a
// labelled vertical divider ("the boundary"):
//
//   LEFT  "Server" — the wide, capability-full "home" side, accent-tinted.
//         A lead chip ("Server Component — runs here, once, per request")
//         over a row of capability chips: `await db`, `process.env`, `fs`,
//         "ships 0 KB JS".
//   RIGHT "Browser" — a narrow, passive, muted side with a single chip,
//         "receives output only".
//
// The asymmetry IS the lesson: the server side is wide and full; the browser
// side is narrow and just receives. A single arrow crossing the boundary
// (server -> browser) carries the one-way "you get the output, not the code"
// direction.
//
// Pure HTML + CSS. `not-content` wrapper + a `margin: 0` reset on every inner
// element defeat Starlight's prose-margin selector. Starlight theme variables
// (accent for the server "home" side, grays for the muted browser side) keep
// it native in both light and dark; the <style> block only carries the
// responsive stack for narrow viewports.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Two zones + a thin divider column between them. Server gets the lion's
// share of the width; the browser is deliberately narrow.
const root = [
  reset,
  "display: grid",
  "grid-template-columns: 2.5fr auto 1fr",
  "align-items: stretch",
  "gap: 0",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

const zoneBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "padding: 16px 18px",
  "border-radius: 12px",
  "box-sizing: border-box",
  "min-width: 0",
].join("; ");

// Server side — the affirmative "home" side, accent-tinted.
const serverZone = [
  zoneBase,
  "border: 1px solid color-mix(in srgb, var(--sl-color-text-accent) 45%, transparent)",
  "background: color-mix(in srgb, var(--sl-color-text-accent) 9%, transparent)",
].join("; ");

// Browser side — muted / secondary, clearly the lighter side.
const browserZone = [
  zoneBase,
  "border: 1px solid var(--sl-color-gray-5)",
  "background: color-mix(in srgb, var(--sl-color-gray-5) 18%, transparent)",
  "justify-content: flex-start",
].join("; ");

const zoneHeader = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "font-size: 17px",
  "font-weight: 700",
  "letter-spacing: 0.01em",
  "line-height: 1",
].join("; ");

const serverHeader = [zoneHeader, "color: var(--sl-color-text-accent)"].join(
  "; ",
);
const browserHeader = [zoneHeader, "color: var(--sl-color-gray-2)"].join("; ");

// Lead chip describing the Server Component itself — sits above the
// capability row.
const leadChip = [
  reset,
  sans,
  "padding: 8px 12px",
  "border-radius: 9px",
  "border: 1px solid color-mix(in srgb, var(--sl-color-text-accent) 40%, transparent)",
  "background: color-mix(in srgb, var(--sl-color-text-accent) 14%, transparent)",
  "color: var(--sl-color-text)",
  "font-size: 13px",
  "font-weight: 600",
  "line-height: 1.3",
].join("; ");

// Row of small capability chips on the server side.
const capRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "column-gap: 8px",
  "row-gap: 8px",
].join("; ");

const capChipBase = [
  reset,
  "padding: 6px 10px",
  "border-radius: 999px",
  "border: 1px solid color-mix(in srgb, var(--sl-color-text-accent) 35%, transparent)",
  "background: var(--sl-color-bg)",
  "color: var(--sl-color-text)",
  "font-size: 12.5px",
  "line-height: 1",
  "white-space: nowrap",
].join("; ");

const capChipCode = [capChipBase, mono, "font-weight: 600"].join("; ");
const capChipText = [capChipBase, sans, "font-weight: 600"].join("; ");

// The browser's single chip — passive, muted.
const recvChip = [
  reset,
  sans,
  "padding: 8px 12px",
  "border-radius: 9px",
  "border: 1px dashed var(--sl-color-gray-4)",
  "background: var(--sl-color-bg)",
  "color: var(--sl-color-gray-2)",
  "font-size: 13px",
  "font-weight: 600",
  "line-height: 1.3",
].join("; ");

const dividerLabel = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "text-transform: uppercase",
  "letter-spacing: 0.08em",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

const serverCaps = [
  { kind: "code", text: "await db" },
  { kind: "code", text: "process.env" },
  { kind: "code", text: "fs" },
  { kind: "text", text: "ships 0 KB JS" },
];
---

<Figure
  caption="The boundary every Next.js app is built around. A Server Component lives on the left; the browser, on the right, only ever receives what it produced."
>
  <div class="not-content sbs-root" style={root}>
    {/* LEFT — Server */}
    <div class="sbs-zone" style={serverZone}>
      <div style={serverHeader}>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="3" width="20" height="6" rx="1.5"></rect>
          <rect x="2" y="13" width="20" height="6" rx="1.5"></rect>
          <line x1="6" y1="6" x2="6.01" y2="6"></line>
          <line x1="6" y1="16" x2="6.01" y2="16"></line>
        </svg>
        <span>Server</span>
      </div>
      <div style={leadChip}>Server Component — runs here, once, per request</div>
      <div style={capRow}>
        {
          serverCaps.map((c) => (
            <span style={c.kind === "code" ? capChipCode : capChipText}>
              {c.text}
            </span>
          ))
        }
      </div>
    </div>

    {/* MIDDLE — the boundary divider, with a one-way arrow crossing it */}
    <div class="sbs-divider" aria-hidden="true">
      <div class="sbs-divider-line"></div>
      <div class="sbs-divider-pill" style={dividerLabel}>the boundary</div>
      <div class="sbs-arrow">
        <span class="sbs-arrow-stem"></span>
        <span class="sbs-arrow-head"></span>
      </div>
    </div>

    {/* RIGHT — Browser */}
    <div class="sbs-zone" style={browserZone}>
      <div style={browserHeader}>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <line x1="2" y1="9" x2="22" y2="9"></line>
          <line x1="6" y1="6.5" x2="6.01" y2="6.5"></line>
          <line x1="9" y1="6.5" x2="9.01" y2="6.5"></line>
        </svg>
        <span>Browser</span>
      </div>
      <div style={recvChip}>receives output only</div>
    </div>
  </div>
</Figure>

<style>
  /* The boundary column: a centered vertical hairline, a "the boundary"
     pill straddling it, and a short one-way arrow pointing server -> browser. */
  .sbs-divider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 92px;
    margin: 0;
  }

  .sbs-divider-line {
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: repeating-linear-gradient(
      to bottom,
      var(--sl-color-gray-4) 0,
      var(--sl-color-gray-4) 5px,
      transparent 5px,
      transparent 11px
    );
  }

  .sbs-divider-pill {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, calc(-50% - 30px)) rotate(-90deg);
    transform-origin: center;
    padding: 3px 8px;
    border-radius: 999px;
    background: var(--sl-color-bg-sidebar);
  }

  /* One-way arrow crossing the boundary, sitting below the pill. */
  .sbs-arrow {
    position: absolute;
    top: 50%;
    left: 50%;
    display: flex;
    align-items: center;
    transform: translate(-50%, calc(-50% + 18px));
  }

  .sbs-arrow-stem {
    display: block;
    width: 34px;
    height: 2px;
    background: color-mix(in srgb, var(--sl-color-text-accent) 70%, transparent);
  }

  .sbs-arrow-head {
    display: block;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 8px solid
      color-mix(in srgb, var(--sl-color-text-accent) 70%, transparent);
  }

  /* Narrow viewports: stack the two zones vertically, turn the boundary
     horizontal, and point the arrow downward. */
  @media (max-width: 640px) {
    .sbs-root {
      grid-template-columns: 1fr !important;
      grid-template-rows: auto auto auto;
    }

    .sbs-divider {
      width: 100%;
      height: 64px;
    }

    .sbs-divider-line {
      top: 50%;
      bottom: auto;
      left: 8px;
      right: 8px;
      width: auto;
      height: 2px;
      transform: translateY(-50%);
      background: repeating-linear-gradient(
        to right,
        var(--sl-color-gray-4) 0,
        var(--sl-color-gray-4) 5px,
        transparent 5px,
        transparent 11px
      );
    }

    .sbs-divider-pill {
      transform: translate(-50%, calc(-50% - 18px)) !important;
    }

    .sbs-arrow {
      transform: translate(-50%, calc(-50% + 14px)) rotate(90deg);
    }
  }
</style>
