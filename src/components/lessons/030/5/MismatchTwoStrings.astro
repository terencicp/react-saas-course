---
// mismatch-two-strings — the "same code, two strings" picture for Lesson 30.5.
//
// One render expression, run on two machines, producing two different strings.
// The pedagogical job is to make "different inputs -> different HTML" visible in
// a single glance, so the rest of the lesson reads as fixes for a concrete,
// seen-it failure rather than an abstract warning.
//
// Horizontal band: a cool-tinted "Server render" lane on the LEFT, a warm-tinted
// "Browser render" lane on the RIGHT, an "is not equal to" divider between them.
// Each lane shows the IDENTICAL source line at the top (driving home "byte-for-
// byte the same code") and beneath it the rendered output string, with the one
// differing token highlighted in the lane's own colour:
//
//   Server (UTC, one instant)        Browser (user's zone, a beat later)
//   <span>Paid {formatRelative…}</…>  <span>Paid {formatRelative…}</…>
//   Paid [3] minutes ago             Paid [2] minutes ago
//
// Chapter colour language: server = cool tint, browser = warm tint (carried
// over from L1's spine and L4's lanes). Pure HTML + CSS; the `not-content`
// wrapper + a `margin: 0` reset on every inner element defeat Starlight's
// prose-margin selector. The <style> block carries only the responsive stack
// for narrow viewports.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Cool = server, warm = browser. Mix bases keep both tints theme-aware
// (legible on white and near-black page backgrounds alike).
const cool = "#0d9488"; // teal — the cool "server" signal
const warm = "#d97706"; // amber — the warm "browser / client" signal

// Three columns: server lane | the "not equal" divider | browser lane.
const root = [
  reset,
  "display: grid",
  "grid-template-columns: 1fr auto 1fr",
  "align-items: stretch",
  "column-gap: 0",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// The two lanes share a base; tint diverges.
const laneBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "padding: 16px 18px",
  "border-radius: 12px",
  "box-sizing: border-box",
  "min-width: 0",
].join("; ");

const serverLane = [
  laneBase,
  `border: 1px solid color-mix(in srgb, ${cool} 50%, transparent)`,
  `background: color-mix(in srgb, ${cool} 9%, transparent)`,
].join("; ");

const browserLane = [
  laneBase,
  `border: 1px solid color-mix(in srgb, ${warm} 50%, transparent)`,
  `background: color-mix(in srgb, ${warm} 9%, transparent)`,
].join("; ");

// Lane header: icon + title + a one-line "which machine / which instant" sub.
const laneHeader = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "line-height: 1.1",
].join("; ");

const titleBase = [
  reset,
  "font-size: 15px",
  "font-weight: 700",
  "letter-spacing: 0.01em",
  "line-height: 1.1",
].join("; ");

const serverTitle = [titleBase, `color: ${cool}`].join("; ");
const browserTitle = [titleBase, `color: ${warm}`].join("; ");

const sub = [
  reset,
  "font-size: 11.5px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The shared source line — identical in both lanes, neutral styling so the
// eye reads "same code", and the difference is clearly downstream of it.
const sourceLine = [
  reset,
  mono,
  "padding: 8px 11px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-bg)",
  "color: var(--sl-color-text)",
  "font-size: 12.5px",
  "line-height: 1.4",
  "white-space: nowrap",
  "overflow-x: auto",
].join("; ");

// "renders to" cue between the source line and its output.
const rendersCue = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "text-transform: uppercase",
  "letter-spacing: 0.07em",
  "color: var(--sl-color-gray-3)",
  "line-height: 1",
].join("; ");

// The rendered output — a faux DOM text node. Mono, sits in a "screen" card
// tinted to the lane so output reads as "what this machine produced".
const outputBase = [
  reset,
  mono,
  "padding: 10px 12px",
  "border-radius: 8px",
  "font-size: 14px",
  "font-weight: 600",
  "line-height: 1.3",
  "white-space: nowrap",
].join("; ");

const serverOutput = [
  outputBase,
  `border: 1px solid color-mix(in srgb, ${cool} 45%, transparent)`,
  `background: color-mix(in srgb, ${cool} 13%, transparent)`,
  "color: var(--sl-color-text)",
].join("; ");

const browserOutput = [
  outputBase,
  `border: 1px solid color-mix(in srgb, ${warm} 45%, transparent)`,
  `background: color-mix(in srgb, ${warm} 13%, transparent)`,
  "color: var(--sl-color-text)",
].join("; ");

// The single differing token, highlighted in the lane's colour so the eye
// lands on exactly what disagrees between the two strings. The fill is a fixed
// saturated hex in both themes, so the text is fixed white for contrast.
const diffBase = [
  reset,
  "padding: 1px 5px",
  "border-radius: 5px",
  "font-weight: 800",
  "color: #fff",
].join("; ");

const serverDiff = [diffBase, `background: ${cool}`].join("; ");
const browserDiff = [diffBase, `background: ${warm}`].join("; ");

// The shared source expression, broken so the highlighted call is visible
// without the JSX braces tripping the MDX parser (rendered via {strings}).
const src = "<span>Paid {formatRelative(paidAt)}</span>";
---

<Figure
  caption="Same code, two machines, two strings — React refuses to adopt the mismatch."
>
  <div class="m2s-root not-content" style={root}>
    {/* LEFT — Server render (cool) */}
    <div class="m2s-lane" style={serverLane}>
      <div style={laneHeader}>
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke={cool}
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="3" width="20" height="6" rx="1.5"></rect>
          <rect x="2" y="13" width="20" height="6" rx="1.5"></rect>
          <line x1="6" y1="6" x2="6.01" y2="6"></line>
          <line x1="6" y1="16" x2="6.01" y2="16"></line>
        </svg>
        <span style={serverTitle}>Server render</span>
      </div>
      <div style={sub}>UTC, one instant</div>
      <code style={sourceLine}>{src}</code>
      <div style={rendersCue}>&darr; renders to</div>
      <div style={serverOutput}>
        Paid <span style={serverDiff}>3</span> minutes ago
      </div>
    </div>

    {/* MIDDLE — the "not equal" verdict */}
    <div class="m2s-divider" aria-hidden="true">
      <div class="m2s-divider-line"></div>
      <div class="m2s-neq">&ne;</div>
    </div>

    {/* RIGHT — Browser render (warm) */}
    <div class="m2s-lane" style={browserLane}>
      <div style={laneHeader}>
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke={warm}
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <line x1="2" y1="9" x2="22" y2="9"></line>
          <line x1="6" y1="6.5" x2="6.01" y2="6.5"></line>
          <line x1="9" y1="6.5" x2="9.01" y2="6.5"></line>
        </svg>
        <span style={browserTitle}>Browser render</span>
      </div>
      <div style={sub}>user&rsquo;s zone, a beat later</div>
      <code style={sourceLine}>{src}</code>
      <div style={rendersCue}>&darr; renders to</div>
      <div style={browserOutput}>
        Paid <span style={browserDiff}>2</span> minutes ago
      </div>
    </div>
  </div>
</Figure>

<style>
  /* The divider column: a centered vertical hairline with a "not equal"
     verdict badge sitting on it, midway down. */
  .m2s-divider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    margin: 0;
  }

  .m2s-divider-line {
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: repeating-linear-gradient(
      to bottom,
      var(--sl-color-gray-4) 0,
      var(--sl-color-gray-4) 5px,
      transparent 5px,
      transparent 11px
    );
  }

  .m2s-neq {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-text);
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }

  /* Narrow viewports: stack the two lanes vertically and turn the divider
     horizontal so the "not equal" verdict still sits between them. */
  @media (max-width: 600px) {
    .m2s-root {
      grid-template-columns: 1fr !important;
      grid-template-rows: auto auto auto;
    }

    .m2s-divider {
      width: 100%;
      height: 48px;
    }

    .m2s-divider-line {
      top: 50%;
      bottom: auto;
      left: 8px;
      right: 8px;
      width: auto;
      height: 2px;
      transform: translateY(-50%);
      background: repeating-linear-gradient(
        to right,
        var(--sl-color-gray-4) 0,
        var(--sl-color-gray-4) 5px,
        transparent 5px,
        transparent 11px
      );
    }
  }
</style>
