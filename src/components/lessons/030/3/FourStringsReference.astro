---
// four-strings-reference — the headline disambiguation artifact of Lesson 30.3.
//
// One scannable contrast that separates the four boundary-related strings the
// lesson introduced — the durable thing the student recalls on sight. Four rows,
// one per string, encoded along TWO axes the prose keeps blurring:
//
//   SIDE   (colour) — client = warm amber (the lesson's directive-highlight /
//          MagicVsExplicit tint); server = cool accent (the ServerBrowserSplit
//          tint). A left stripe + tinted "String" cell carry the side.
//   KIND   (a badge column) — "directive" (about where code runs / what the
//          client can call) vs "guard" (about what a module is forbidden to
//          reach). This is the must-kill confusion: within one colour, the two
//          strings do OPPOSITE jobs, so KIND must be readable, not just implied.
//
// Rows are grouped directives-first, guards-second to match the caption ("Two
// are directives…; two are guards…"). Columns mirror the lesson outline:
// String / Kind / What it marks / Direction / Failure if misused / Canonical file.
//
// Pure HTML + CSS, a real <table> for semantic structure and column alignment;
// inline styles so it's devtools-inspectable, per the html-css convention. The
// <style> block carries only theme-keyed row tints, the accent stripe, and the
// stack-to-cards responsive fallback (wrap-don't-scroll). Wrapped in <Figure>.

import Figure from '../../../figures/Figure.astro';

// Warm "client" tint — same amber the lesson highlights `'use client'` with and
// the colour MagicVsExplicit uses for the client side.
const CLIENT = '#fbbf24';
// Cool "server" tint — the accent the chapter's ServerBrowserSplit uses for the
// server "home" side.
const SERVER = 'var(--sl-color-text-accent)';

const rows = [
	{
		side: 'client',
		kind: 'directive',
		string: "'use client'",
		marks: 'A component that runs in the browser',
		direction: 'Pulls the file and its imports toward the client',
		failure: [{ t: 'Typo → silently treated as a Server Component; crashes at render' }],
		file: '_components/mark-paid-button.tsx',
	},
	{
		side: 'server',
		kind: 'directive',
		string: "'use server'",
		marks: 'A function the client can call (a Server Action)',
		direction: 'Exposes a server function to the browser',
		failure: [{ t: "Forgotten on a called action → it isn't callable" }],
		file: 'app/invoices/_actions.ts',
	},
	{
		side: 'server',
		kind: 'guard',
		string: "import 'server-only'",
		marks: 'A module that must never reach the browser',
		direction: 'Blocks the file from crossing to the client',
		failure: [{ t: 'Omitted → a server module can leak into the client bundle' }],
		file: 'db/index.ts, lib/auth.ts',
	},
	{
		side: 'client',
		kind: 'guard',
		string: "import 'client-only'",
		marks: 'A module that must never run on the server',
		direction: 'Blocks the file from crossing to the server',
		failure: [{ t: 'Omitted → crashes server-side with ' }, { code: 'window is not defined' }],
		file: 'a window-reading browser helper',
	},
];

const sans =
	'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';
const mono =
	'font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)';

const head = [
	'margin: 0',
	'padding: 9px 10px',
	'text-align: left',
	'vertical-align: bottom',
	'font-size: 11px',
	'font-weight: 700',
	'text-transform: uppercase',
	'letter-spacing: 0.05em',
	'color: var(--sl-color-gray-2)',
	'border-bottom: 1px solid var(--sl-color-gray-5)',
].join('; ');

const cell = [
	'margin: 0',
	'padding: 11px 10px',
	'vertical-align: top',
	'font-size: 12.5px',
	'line-height: 1.4',
	'color: var(--sl-color-text)',
].join('; ');

// Fixed column widths so long cells wrap inside their track instead of forcing
// the table wider than the figure card. Sums to 100%.
const colWidths = ['16%', '10%', '20%', '17%', '20%', '17%'];
---

<Figure
	caption="The four boundary strings, by job. Two are directives (where code runs / what the client can call); two are guards (what a module is forbidden to reach)."
>
	<div class="fsr-scroll not-content">
		<table class="fsr-table" style={`${sans}; margin: 0; border-collapse: collapse; width: 100%; min-width: 640px; table-layout: fixed;`}>
			<colgroup>
				{colWidths.map((w) => <col style={`width: ${w}`} />)}
			</colgroup>
			<thead>
				<tr>
					<th scope="col" style={head}>String</th>
					<th scope="col" style={head}>Kind</th>
					<th scope="col" style={head}>What it marks</th>
					<th scope="col" style={head}>Direction</th>
					<th scope="col" style={head}>Failure</th>
					<th scope="col" style={head}>Canonical file</th>
				</tr>
			</thead>
			<tbody>
				{
					rows.map((r) => (
						<tr class={`fsr-row fsr-${r.side}`}>
							<td class="fsr-string-cell" style={`${cell}; padding-left: 14px;`}>
								<code class="fsr-string" style={`${mono}; font-size: 12.5px; font-weight: 700;`}>
									{r.string}
								</code>
							</td>
							<td style={cell} data-label="Kind">
								<span class={`fsr-kind fsr-kind-${r.kind}`} style={sans}>
									{r.kind}
								</span>
							</td>
							<td style={cell} data-label="What it marks">{r.marks}</td>
							<td style={`${cell}; color: var(--sl-color-gray-2);`} data-label="Direction">
								{r.direction}
							</td>
							<td style={`${cell}; color: var(--sl-color-gray-2);`} data-label="Failure if misused">
								{
									r.failure.map((seg) =>
										'code' in seg ? (
											<code class="fsr-inline-code" style={`${mono}; font-size: 12px;`}>
												{seg.code}
											</code>
										) : (
											<span>{seg.t}</span>
										),
									)
								}
							</td>
							<td style={cell} data-label="Canonical file">
								<code class="fsr-file" style={`${mono}; font-size: 12px;`}>{r.file}</code>
							</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</Figure>

<style define:vars={{ client: CLIENT, server: SERVER }}>
	/* Horizontal scroll is a deliberate, last-resort affordance for the wide
	   table on mid widths; the responsive block below stacks it to cards on
	   genuinely narrow viewports so nothing is silently clipped. */
	.fsr-scroll {
		margin: 0;
		overflow-x: auto;
	}

	/* Fixed layout means cells must wrap rather than push the table wider. */
	.fsr-table td {
		overflow-wrap: anywhere;
	}

	/* Side colour: a left accent stripe + a faint row wash, warm for the two
	   client strings, cool for the two server strings. */
	.fsr-row td {
		border-bottom: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
	}
	.fsr-row:last-child td {
		border-bottom: none;
	}

	.fsr-client {
		background: color-mix(in srgb, var(--client) 7%, transparent);
	}
	.fsr-server {
		background: color-mix(in srgb, var(--server) 6%, transparent);
	}

	/* The stripe lives on the first cell so it reads as a per-side rail. */
	.fsr-client .fsr-string-cell {
		box-shadow: inset 3px 0 0 var(--client);
	}
	.fsr-server .fsr-string-cell {
		box-shadow: inset 3px 0 0 color-mix(in srgb, var(--server) 80%, transparent);
	}

	/* The string itself is tinted by side — the anchor the eye lands on. */
	.fsr-client .fsr-string {
		color: color-mix(in srgb, var(--client) 78%, var(--sl-color-text) 22%);
		background: transparent;
		padding: 0;
	}
	.fsr-server .fsr-string {
		color: color-mix(in srgb, var(--server) 88%, var(--sl-color-text) 12%);
		background: transparent;
		padding: 0;
	}

	.fsr-file {
		background: transparent;
		padding: 0;
		color: var(--sl-color-gray-2);
		overflow-wrap: anywhere;
	}

	.fsr-inline-code {
		background: color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent);
		padding: 1px 5px;
		border-radius: 5px;
		color: var(--sl-color-text);
	}

	/* The Kind badge — the orthogonal axis. A filled badge = "directive" (an
	   active job: runs / is callable); an outlined badge = "guard" (a
	   prohibition). Shape, not just colour, carries the distinction. */
	.fsr-kind {
		display: inline-block;
		padding: 2px 9px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		white-space: nowrap;
	}
	.fsr-kind-directive {
		color: var(--sl-color-bg);
		background: color-mix(in srgb, var(--sl-color-text) 72%, transparent);
		border: 1px solid transparent;
	}
	.fsr-kind-guard {
		color: var(--sl-color-gray-2);
		background: transparent;
		border: 1px dashed var(--sl-color-gray-3);
	}

	/* Narrow viewports: turn the table into a stack of cards so no column is
	   clipped behind a hidden scrollbar. Each row becomes a labelled card. */
	@media (max-width: 760px) {
		.fsr-scroll {
			overflow-x: visible;
		}
		.fsr-table {
			min-width: 0 !important;
			width: 100%;
		}
		.fsr-table thead {
			position: absolute;
			width: 1px;
			height: 1px;
			overflow: hidden;
			clip: rect(0 0 0 0);
			white-space: nowrap;
		}
		.fsr-table,
		.fsr-table tbody,
		.fsr-table tr,
		.fsr-table td {
			display: block;
			width: 100%;
			box-sizing: border-box;
		}
		.fsr-row {
			margin: 0 0 12px;
			border: 1px solid var(--sl-color-gray-5);
			border-radius: 10px;
			overflow: hidden;
		}
		.fsr-row td {
			border-bottom: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent) !important;
			padding: 8px 14px;
		}
		.fsr-row td:last-child {
			border-bottom: none !important;
		}
		/* Re-attach the side rail to the whole card on narrow layouts. */
		.fsr-client .fsr-string-cell,
		.fsr-server .fsr-string-cell {
			box-shadow: none;
		}
		.fsr-client {
			border-left: 4px solid var(--client);
		}
		.fsr-server {
			border-left: 4px solid color-mix(in srgb, var(--server) 80%, transparent);
		}
		/* Prefix each stacked cell with its column name. */
		.fsr-table td::before {
			content: attr(data-label);
			display: block;
			margin: 0 0 2px;
			font-size: 10px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: var(--sl-color-gray-3);
		}
		.fsr-string-cell::before {
			content: '' !important;
			display: none !important;
		}
	}
</style>
