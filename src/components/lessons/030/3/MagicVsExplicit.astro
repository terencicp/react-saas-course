---
// Diagram (id: magic-vs-explicit, Chapter 030 L3).
//
// Two tabs making "legible at a glance" literally visual — the payoff for the
// "explicit over magic" section. Both tabs render the SAME mock file card
// (filename header + greyed body lines that hold the real answer); they differ
// only at the top line:
//
//   Tab 1 "Magic (inferred)"  — where the directive would be, a cog/gear icon
//      and an "inferred" note. The top tells you nothing; the answer is buried
//      in the (greyed) body. A "?" pill asks "client or server?".
//   Tab 2 "Explicit (directive)" — the same card, but the first line is a
//      bright, glowing `'use client';` in the chapter's warm/client tint, and a
//      resolved "client" pill. The side is readable instantly, top-left.
//
// Pure HTML+CSS, no interactivity. TabbedContent provides its own card, so this
// is NOT wrapped in <Figure>. Colour language: client = warm amber (the theme's
// --mark-orange-* tokens), server = cool accent blue — matching the chapter.

import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';
import { Icon } from 'astro-icon/components';

// Warm "client" tint — anchored to the theme's orange mark token so it matches
// the directive highlight colour used in the lesson's code blocks.
const CLIENT = '#fbbf24';

// The greyed-out body lines, shared by both tabs. These hold the actual signal
// (a hook, an event handler) that the "magic" version would force you to read.
const bodyLines = [
	{ indent: 0, width: '62%' },
	{ indent: 0, width: '0%', blank: true },
	{ indent: 0, width: '78%' },
	{ indent: 1, width: '54%' },
	{ indent: 1, width: '70%' },
	{ indent: 0, width: '34%' },
];
---

<TabbedContent>
	<TabbedItem
		label="Magic (inferred)"
		caption="Which side is this on? You'd have to read the whole file and run the rules in your head."
	>
		<div class="mve-card">
			<div class="mve-titlebar">
				<span class="mve-dots" aria-hidden="true">
					<i></i><i></i><i></i>
				</span>
				<span class="mve-filename">mark-paid-button.tsx</span>
				<span class="mve-side mve-side-unknown">? client or server</span>
			</div>

			{/* The "answer line" — but inferred, so there is nothing to read. */}
			<div class="mve-firstline mve-firstline-magic">
				<Icon name="lucide:cog" class="mve-cog" aria-hidden="true" />
				<span class="mve-magic-note">boundary inferred — not written down</span>
			</div>

			<div class="mve-body" aria-hidden="true">
				{
					bodyLines.map((l) =>
						l.blank ? (
							<div class="mve-blank"></div>
						) : (
							<div class="mve-codeline" style={`margin-left:${l.indent * 18}px`}>
								<span class="mve-bar" style={`width:${l.width}`}></span>
							</div>
						),
					)
				}
			</div>
		</div>
	</TabbedItem>

	<TabbedItem
		label="Explicit (directive)"
		caption="The first line answers the question before you read anything else."
	>
		<div class="mve-card">
			<div class="mve-titlebar">
				<span class="mve-dots" aria-hidden="true">
					<i></i><i></i><i></i>
				</span>
				<span class="mve-filename">mark-paid-button.tsx</span>
				<span class="mve-side mve-side-client">client</span>
			</div>

			{/* The directive — a bright, glowing first line. The answer, up top. */}
			<div class="mve-firstline mve-firstline-explicit">
				<span class="mve-directive">'use client';</span>
			</div>

			<div class="mve-body" aria-hidden="true">
				{
					bodyLines.map((l) =>
						l.blank ? (
							<div class="mve-blank"></div>
						) : (
							<div class="mve-codeline" style={`margin-left:${l.indent * 18}px`}>
								<span class="mve-bar" style={`width:${l.width}`}></span>
							</div>
						),
					)
				}
			</div>
		</div>
	</TabbedItem>
</TabbedContent>

<style define:vars={{ client: CLIENT }}>
	.mve-card {
		max-width: 460px;
		margin: 0 auto;
		border-radius: 10px;
		border: 1px solid color-mix(in srgb, currentColor 16%, transparent);
		background: var(--sl-color-bg);
		overflow: hidden;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
	}

	/* Editor title bar with traffic-light dots, filename, and a side pill. */
	.mve-titlebar {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 8px 12px;
		border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
		background: color-mix(in srgb, currentColor 4%, transparent);
	}

	.mve-dots {
		display: inline-flex;
		gap: 5px;
		flex: none;
	}
	.mve-dots i {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: color-mix(in srgb, currentColor 22%, transparent);
	}

	.mve-filename {
		font-size: 12px;
		color: var(--sl-color-gray-2);
		white-space: nowrap;
	}

	/* The side pill, top-right: the question the diagram is about. */
	.mve-side {
		margin-left: auto;
		flex: none;
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.02em;
		padding: 2px 9px;
		border-radius: 999px;
		white-space: nowrap;
	}

	.mve-side-unknown {
		color: var(--sl-color-gray-3);
		border: 1px dashed color-mix(in srgb, currentColor 38%, transparent);
		background: transparent;
	}

	.mve-side-client {
		color: color-mix(in srgb, var(--client) 88%, #000 12%);
		border: 1px solid color-mix(in srgb, var(--client) 60%, transparent);
		background: color-mix(in srgb, var(--client) 18%, transparent);
	}

	/* The first line — the "answer line", styled per variant. */
	.mve-firstline {
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 11px 14px;
		min-height: 22px;
	}

	/* Magic: a cog where the answer should be, dimmed, with a faint note. */
	.mve-firstline-magic {
		background: color-mix(in srgb, currentColor 3%, transparent);
	}
	.mve-cog {
		width: 16px;
		height: 16px;
		color: var(--sl-color-gray-3);
		flex: none;
	}
	.mve-magic-note {
		font-size: 12px;
		font-style: italic;
		color: var(--sl-color-gray-3);
	}

	/* Explicit: a bright, glowing directive line. */
	.mve-firstline-explicit {
		background: color-mix(in srgb, var(--client) 12%, transparent);
		box-shadow: inset 3px 0 0 var(--client);
	}
	.mve-directive {
		font-size: 13px;
		font-weight: 700;
		color: color-mix(in srgb, var(--client) 82%, var(--sl-color-text) 18%);
		text-shadow: 0 0 14px color-mix(in srgb, var(--client) 55%, transparent);
	}

	/* The greyed body — the real signal you'd have to read in the magic case. */
	.mve-body {
		display: flex;
		flex-direction: column;
		gap: 9px;
		padding: 12px 14px 16px;
	}
	.mve-codeline {
		display: flex;
	}
	.mve-bar {
		display: block;
		height: 8px;
		border-radius: 4px;
		background: color-mix(in srgb, currentColor 13%, transparent);
	}
	.mve-blank {
		height: 4px;
	}
</style>
