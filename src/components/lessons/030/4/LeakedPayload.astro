---
// leaked-payload — the "you can see the secret in the open" gut-punch for
// Lesson 30.4's silent-leak section.
//
// The prose just said: the payload is an ordinary network response, and the
// over-wide prop is sitting in it in plain text. This figure makes that
// concrete by faking a DevTools Network panel showing the RSC response body
// for the leaked-row version of `<MarkPaidButton invoice={invoice} />`.
//
// What it draws:
//   - Faux panel chrome: a request line, then a tab strip
//     "Headers / Preview / Response" with "Response" active.
//   - A monospace response body with a line-number gutter, holding a short
//     fragment of an RSC (React Flight) payload: the MarkPaidButton element
//     with its full props object spilled out — id, status, total, AND the
//     fields that should never have left the server (internalNotes, the joined
//     customer record).
//   - The `internalNotes` line highlighted in the chapter's warm "this is in
//     the browser now" tint, with a callout pointing at it:
//     "shipped to the browser — readable by the user, never read by the button."
//
// Chapter colour language: client / browser = warm (#d97706, the amber from
// L1's spine and RscLanes). The leaked field carries that warm tint precisely
// because it has now crossed onto the warm side.
//
// Pure HTML + CSS. The `not-content` wrapper + a `margin: 0` reset on every
// inner element defeat Starlight's prose-margin selector (which reaches into
// flex/grid children). The <style> block carries the highlight band, the
// callout connector, and the responsive stack — things inline styles can't do.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Warm = the client / browser side. The leaked field has crossed onto it.
const warm = "#d97706"; // amber — the "browser / client" signal

// Outer DevTools-ish panel: a framed card with its own muted chrome, distinct
// from the Figure card it sits inside.
const panel = [
  reset,
  sans,
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 10px",
  "overflow: hidden",
  "background: var(--sl-color-bg)",
  "width: 100%",
  "box-sizing: border-box",
  "box-shadow: 0 1px 2px color-mix(in srgb, currentColor 8%, transparent)",
].join("; ");

// Top strip: the faux request line (method + URL + status).
const requestLine = [
  reset,
  mono,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "flex-wrap: wrap",
  "padding: 8px 12px",
  "font-size: 12px",
  "background: var(--sl-color-gray-6, var(--sl-color-bg-sidebar))",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
].join("; ");

const method = [
  reset,
  "font-weight: 700",
  "color: var(--sl-color-text)",
  "letter-spacing: 0.02em",
].join("; ");

const url = [reset, "color: var(--sl-color-gray-2)"].join("; ");

const status200 = [
  reset,
  "margin-left: auto",
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "color: var(--sl-color-gray-2)",
  "font-size: 11px",
].join("; ");

// Tab strip: Headers / Preview / Response, Response active.
const tabStrip = [
  reset,
  sans,
  "display: flex",
  "align-items: stretch",
  "gap: 0",
  "padding: 0 6px",
  "background: var(--sl-color-bg)",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
].join("; ");

const tabBase = [
  reset,
  "padding: 8px 12px",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "border-bottom: 2px solid transparent",
  "white-space: nowrap",
].join("; ");

const tabActive = [
  reset,
  "padding: 8px 12px",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1",
  "color: var(--sl-color-text)",
  `border-bottom: 2px solid ${warm}`,
  "white-space: nowrap",
].join("; ");

// The response body shell. A line-number gutter on the left, code on the right.
const body = [
  reset,
  mono,
  "font-size: 12.5px",
  "line-height: 1.7",
  "color: var(--sl-color-text)",
  "background: var(--sl-color-bg)",
  "overflow-x: auto",
].join("; ");

// Comment / annotation tokens inside the payload (the "// full row" hint).
const dim = "color: var(--sl-color-gray-3)";
// Key tokens (the JSON-ish property names).
const key = `color: ${warm}`;
const keyMuted = "color: var(--sl-color-gray-2)";
// String values.
const str = "color: var(--sl-color-text)";

// The callout that points at the highlighted line.
const callout = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 7px",
  "padding: 7px 11px",
  "border-radius: 8px",
  `border: 1px solid color-mix(in srgb, ${warm} 55%, transparent)`,
  `background: color-mix(in srgb, ${warm} 12%, transparent)`,
  "color: var(--sl-color-text)",
  "font-size: 12px",
  "font-weight: 600",
  "line-height: 1.3",
].join("; ");

const calloutStrong = [reset, `color: ${warm}`, "font-weight: 700"].join("; ");
---

<Figure
  caption="The leaked row, as it arrives in the browser. The button only ever reads `id` — but `internalNotes` made the trip too, in plain text, where anyone with DevTools open can read it."
>
  <div class="leak not-content" style={panel}>
    {/* Faux request line */}
    <div style={requestLine}>
      <span style={method}>GET</span>
      <span style={url}>/invoices/inv_8b21?_rsc=1a2f9</span>
      <span style={status200}>
        <span
          aria-hidden="true"
          style="width: 7px; height: 7px; border-radius: 50%; background: #16a34a; display: inline-block;"
        ></span>
        200 OK
      </span>
    </div>

    {/* Faux tab strip — Response active */}
    <div style={tabStrip}>
      <span style={tabBase}>Headers</span>
      <span style={tabBase}>Preview</span>
      <span style={tabActive}>Response</span>
    </div>

    {/* Response body: gutter + RSC payload fragment */}
    <div style={body}>
      <div class="leak-grid">
        {/* gutter */}
        <div class="leak-gutter" aria-hidden="true">
          <span>1</span>
          <span>2</span>
          <span>3</span>
          <span>4</span>
          <span class="leak-gutter-hot">5</span>
          <span>6</span>
          <span>7</span>
          <span>8</span>
        </div>

        {/* code lines */}
        <div class="leak-code">
          <div class="leak-line">
            <span style={dim}>// renders &lt;MarkPaidButton&gt; — props serialized below</span>
          </div>
          <div class="leak-line">
            <span style={keyMuted}>3:["$","$L7",null,{'{'}</span>
          </div>
          <div class="leak-line leak-indent">
            <span style={key}>"id"</span><span style={dim}>:</span> <span style={str}>"inv_8b21"</span><span style={dim}>,</span>
          </div>
          <div class="leak-line leak-indent">
            <span style={key}>"status"</span><span style={dim}>:</span> <span style={str}>"sent"</span><span style={dim}>,</span> <span style={key}>"total"</span><span style={dim}>:</span> <span style={str}>48200</span><span style={dim}>,</span>
          </div>
          <div class="leak-line leak-indent leak-hot">
            <span style={key}>"internalNotes"</span><span style={dim}>:</span> <span style={str}>"customer disputes charge — do not auto-remind"</span><span style={dim}>,</span>
          </div>
          <div class="leak-line leak-indent">
            <span style={key}>"customer"</span><span style={dim}>:</span> {'{'} <span style={str}>"name"</span><span style={dim}>:</span> <span style={str}>"Acme Ltd"</span><span style={dim}>,</span> <span style={str}>"email"</span><span style={dim}>:</span> <span style={str}>"ap@acme.io"</span> {'}'}<span style={dim}>,</span>
          </div>
          <div class="leak-line leak-indent">
            <span style={key}>"createdAt"</span><span style={dim}>:</span> <span style={str}>"2026-05-31T09:14:00Z"</span>
          </div>
          <div class="leak-line">
            <span style={keyMuted}>{'}'}]</span>
          </div>
        </div>
      </div>
    </div>

    {/* Callout pointing at the highlighted line */}
    <div class="leak-callout-wrap">
      <span class="leak-connector" aria-hidden="true"></span>
      <div style={callout}>
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke={warm}
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        <span>
          <span style={calloutStrong}>Shipped to the browser.</span> Readable by
          the user. Never read by the button.
        </span>
      </div>
    </div>
  </div>
</Figure>

<style>
  /* Gutter + code as two columns sharing one baseline grid. */
  .leak-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: stretch;
    margin: 0;
    min-width: max-content;
  }

  .leak-gutter {
    display: flex;
    flex-direction: column;
    padding: 10px 0 12px;
    margin: 0;
    text-align: right;
    color: var(--sl-color-gray-4);
    user-select: none;
    background: var(--sl-color-gray-6, var(--sl-color-bg-sidebar));
    border-right: 1px solid var(--sl-color-gray-5);
  }

  .leak-gutter span {
    margin: 0;
    padding: 0 10px;
    line-height: 1.7;
  }

  /* The gutter number for the leaked line, warm to match the highlight band. */
  .leak-gutter-hot {
    color: #fff !important;
    font-weight: 700;
    background: #d97706;
  }

  .leak-code {
    padding: 10px 14px 12px;
    margin: 0;
    min-width: 0;
  }

  .leak-line {
    margin: 0;
    line-height: 1.7;
    white-space: pre;
  }

  .leak-indent {
    padding-left: 1.6em;
  }

  /* The leaked field's highlight band: a warm wash spanning the code column,
     with a thick warm rule on the left edge so the eye lands on it instantly. */
  .leak-hot {
    background: color-mix(in srgb, #d97706 15%, transparent);
    box-shadow: inset 3px 0 0 #d97706;
    border-radius: 0 4px 4px 0;
    /* bleed to the column edges so the band reads as a full-width row */
    margin: 1px -14px;
    padding-top: 1px;
    padding-bottom: 1px;
    padding-right: 14px;
    padding-left: calc(1.6em + 14px);
  }

  /* Callout sits under the body, nudged toward the highlighted line, with a
     short vertical connector rising from it. */
  .leak-callout-wrap {
    position: relative;
    display: flex;
    justify-content: flex-start;
    padding: 16px 14px 14px;
    margin: 0;
    background: var(--sl-color-bg);
  }

  .leak-connector {
    position: absolute;
    left: 34px;
    top: 0;
    width: 2px;
    height: 16px;
    background: color-mix(in srgb, #d97706 60%, transparent);
  }

  /* Narrow viewports: the response body can scroll horizontally (it's a code
     stream, panning is the expected affordance), and the callout wraps under
     it naturally. Keep the panel chrome intact. */
  @media (max-width: 560px) {
    .leak-callout-wrap {
      padding-left: 12px;
      padding-right: 12px;
    }
    .leak-connector {
      left: 26px;
    }
  }
</style>
