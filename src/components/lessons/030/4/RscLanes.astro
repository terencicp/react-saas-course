---
// rsc-lanes — the "what physically crosses the wire" locator for Lesson 30.4.
//
// One server render, two transports. The pedagogical job is to place *where in
// a single request* serialization happens, so the rest of the lesson reads as
// rules about a concrete, visible artifact rather than abstract magic.
//
// Horizontal band: a cool-tinted "Server" box on the LEFT, a warm-tinted
// "Browser" box on the RIGHT, and TWO stacked horizontal lanes flowing
// left -> right between them:
//
//   Lane 1  "HTML"        -> painted immediately
//   Lane 2  "RSC payload" -> reconciles the React tree
//
// A callout bracket is pinned under the RSC-payload lane reading
// "Client Component props are serialized here — this lesson." — the one fact
// the lesson turns into a set of rules.
//
// Chapter colour language: server = cool tint, browser = warm tint (the warm
// "client" side from L1's spine, here applied to the browser box). Pure
// HTML + CSS; the `not-content` wrapper + a `margin: 0` reset on every inner
// element defeat Starlight's prose-margin selector. The <style> block carries
// only the responsive stack for narrow viewports.

import Figure from "../../../figures/Figure.astro";

const reset = "margin: 0";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Cool = server, warm = browser. Defined as mix bases so both tints stay
// theme-aware (legible on white and near-black page backgrounds alike).
const cool = "#0d9488"; // teal — the cool "server" signal
const warm = "#d97706"; // amber — the warm "browser / client" signal

// Three columns: server endpoint | the two lanes | browser endpoint.
const root = [
  reset,
  "display: grid",
  "grid-template-columns: auto 1fr auto",
  "align-items: stretch",
  "column-gap: 0",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// The two endpoint boxes share a base; tint diverges.
const endpointBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 8px",
  "padding: 14px 16px",
  "border-radius: 12px",
  "box-sizing: border-box",
  "text-align: center",
  "min-width: 96px",
].join("; ");

const serverBox = [
  endpointBase,
  `border: 1px solid color-mix(in srgb, ${cool} 55%, transparent)`,
  `background: color-mix(in srgb, ${cool} 12%, transparent)`,
].join("; ");

const browserBox = [
  endpointBase,
  `border: 1px solid color-mix(in srgb, ${warm} 55%, transparent)`,
  `background: color-mix(in srgb, ${warm} 12%, transparent)`,
].join("; ");

const endpointTitleBase = [
  reset,
  "font-size: 15px",
  "font-weight: 700",
  "letter-spacing: 0.01em",
  "line-height: 1.1",
].join("; ");

const serverTitle = [endpointTitleBase, `color: ${cool}`].join("; ");
const browserTitle = [endpointTitleBase, `color: ${warm}`].join("; ");

const endpointSub = [
  reset,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
  "max-width: 92px",
].join("; ");

// "One render" tag, sitting under the lanes block, tying the two lanes to a
// single origin render on the server.
const originTag = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "text-transform: uppercase",
  "letter-spacing: 0.06em",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

// A single lane: left label chip, a flow track with arrowhead, right annotation.
const laneBase = [
  reset,
  "display: grid",
  "grid-template-columns: auto 1fr auto",
  "align-items: center",
  "column-gap: 10px",
].join("; ");

const laneLabelBase = [
  reset,
  "padding: 6px 11px",
  "border-radius: 8px",
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1",
  "white-space: nowrap",
  "box-sizing: border-box",
  "text-align: center",
].join("; ");

// Lane 1 (HTML) — muted/neutral: it's the already-familiar transport.
const htmlLabel = [
  laneLabelBase,
  sans,
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-bg)",
  "color: var(--sl-color-text)",
].join("; ");

// Lane 2 (RSC payload) — the focus lane, warm-edged to read as "this one".
const rscLabel = [
  laneLabelBase,
  mono,
  `border: 1px solid color-mix(in srgb, ${warm} 60%, transparent)`,
  `background: color-mix(in srgb, ${warm} 12%, transparent)`,
  "color: var(--sl-color-text)",
].join("; ");

const annotationBase = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 600",
  "line-height: 1.2",
  "white-space: nowrap",
].join("; ");

const htmlAnnotation = [annotationBase, "color: var(--sl-color-gray-2)"].join(
  "; ",
);
const rscAnnotation = [annotationBase, `color: ${warm}`].join("; ");

// The callout pinned under the RSC lane — the single sentence the lesson is
// built on. Warm-tinted to bracket the focus lane.
const callout = [
  reset,
  sans,
  "padding: 8px 12px",
  "border-radius: 9px",
  `border: 1px solid color-mix(in srgb, ${warm} 50%, transparent)`,
  `background: color-mix(in srgb, ${warm} 10%, transparent)`,
  "color: var(--sl-color-text)",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.3",
].join("; ");

const calloutEmphasis = [reset, `color: ${warm}`, "font-weight: 700"].join(
  "; ",
);
---

<Figure
  caption="One server render, two transports. The HTML paints the page; the RSC payload rebuilds the tree — and carries every Client Component prop, serialized, in the open."
>
  <div class="rsc-lanes not-content" style={root}>
    {/* LEFT — Server endpoint (cool) */}
    <div class="rsc-endpoint" style={serverBox}>
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke={cool}
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="2" y="3" width="20" height="6" rx="1.5"></rect>
        <rect x="2" y="13" width="20" height="6" rx="1.5"></rect>
        <line x1="6" y1="6" x2="6.01" y2="6"></line>
        <line x1="6" y1="16" x2="6.01" y2="16"></line>
      </svg>
      <span style={serverTitle}>Server</span>
      <span style={endpointSub}>renders the tree once</span>
    </div>

    {/* MIDDLE — the two lanes + an origin tag */}
    <div class="rsc-lanes-mid">
      <div class="rsc-lane" style={laneBase}>
        <span style={htmlLabel}>HTML</span>
        <span class="rsc-track rsc-track--neutral" aria-hidden="true"></span>
        <span style={htmlAnnotation}>&rarr; painted immediately</span>
      </div>

      <div class="rsc-lane" style={laneBase}>
        <span style={rscLabel}>RSC payload</span>
        <span class="rsc-track rsc-track--focus" aria-hidden="true"></span>
        <span style={rscAnnotation}>&rarr; reconciles the React tree</span>
      </div>

      {/* Callout bracket pinned under the RSC-payload lane */}
      <div class="rsc-callout-wrap" aria-hidden="true">
        <span class="rsc-callout-bracket rsc-callout-bracket--focus"></span>
      </div>
      <div class="rsc-callout-row">
        <div style={callout}>
          <span style={calloutEmphasis}>Client Component props</span> are
          serialized here &mdash; this lesson.
        </div>
      </div>

      <div class="rsc-origin">
        <span style={originTag}>one render &rarr; two transports</span>
      </div>
    </div>

    {/* RIGHT — Browser endpoint (warm) */}
    <div class="rsc-endpoint" style={browserBox}>
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke={warm}
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="2" y="4" width="20" height="16" rx="2"></rect>
        <line x1="2" y1="9" x2="22" y2="9"></line>
        <line x1="6" y1="6.5" x2="6.01" y2="6.5"></line>
        <line x1="9" y1="6.5" x2="9.01" y2="6.5"></line>
      </svg>
      <span style={browserTitle}>Browser</span>
      <span style={endpointSub}>receives both</span>
    </div>
  </div>
</Figure>

<style>
  /* The lanes block stacks: lane 1, lane 2, the callout bracket + row, then the
     origin tag. Generous row gap keeps labels/annotations from colliding. */
  .rsc-lanes-mid {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
    padding: 0 18px;
    margin: 0;
  }

  .rsc-lane {
    margin: 0;
  }

  /* The flow track: a horizontal line ending in an arrowhead, drawn with a
     gradient body + a CSS triangle so it reads as motion from server -> browser. */
  .rsc-track {
    position: relative;
    display: block;
    height: 2px;
    margin: 0 14px 0 0; /* room for the arrowhead on the right */
    border-radius: 2px;
  }

  .rsc-track::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -12px;
    width: 0;
    height: 0;
    transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
  }

  .rsc-track--neutral {
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--sl-color-gray-3) 30%, transparent),
      var(--sl-color-gray-3)
    );
  }
  .rsc-track--neutral::after {
    border-left: 9px solid var(--sl-color-gray-3);
  }

  .rsc-track--focus {
    background: linear-gradient(
      to right,
      color-mix(in srgb, #d97706 35%, transparent),
      #d97706
    );
  }
  .rsc-track--focus::after {
    border-left: 9px solid #d97706;
  }

  /* The callout bracket: a short vertical tick + horizontal underline sitting
     directly beneath the RSC-payload lane's label/track, pointing the callout
     row at lane 2 specifically (not lane 1). */
  .rsc-callout-wrap {
    position: relative;
    height: 10px;
    margin: -6px 0 0;
  }

  .rsc-callout-bracket {
    position: absolute;
    left: 0;
    right: 14px;
    top: 0;
    height: 8px;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
  }

  .rsc-callout-bracket--focus {
    border-left: 2px solid color-mix(in srgb, #d97706 55%, transparent);
    border-right: 2px solid color-mix(in srgb, #d97706 55%, transparent);
    border-bottom: 2px solid color-mix(in srgb, #d97706 55%, transparent);
  }

  .rsc-callout-row {
    display: flex;
    margin: 0;
  }

  .rsc-origin {
    display: flex;
    justify-content: center;
    margin: 2px 0 0;
  }

  /* Narrow viewports: stack server -> lanes -> browser vertically. The lanes
     stay horizontal internally; only the three-column endpoint frame collapses. */
  @media (max-width: 640px) {
    .rsc-lanes {
      grid-template-columns: 1fr !important;
      grid-template-rows: auto auto auto;
      row-gap: 12px;
    }

    .rsc-endpoint {
      flex-direction: row !important;
      gap: 10px !important;
      justify-content: center;
    }

    .rsc-endpoint span {
      max-width: none !important;
    }

    .rsc-lanes-mid {
      padding: 0 !important;
    }
  }
</style>
