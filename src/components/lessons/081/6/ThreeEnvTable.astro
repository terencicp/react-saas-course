---
// ThreeEnvTable — Chapter 081 Lesson 6 ("Where secrets live and how they
// rotate"), the figure for Rule 4 ("three environments, three separate sets of
// secrets").
//
// Pedagogical goal: make "three sets" concrete instead of abstract. Each row is
// one familiar service; the three columns are the three environments (Local,
// Preview, Production). Reading a row across shows the SAME secret name carrying
// a different VALUE per environment, and reading down the Production column
// shows the live values exist in exactly one place. That last read is the rule
// in one image, so the Production column is the only column that draws the eye:
// saturated emerald header + emphasised cells, while Local/Preview cells stay
// muted (these are throwaway test/dev values, deliberately low-contrast).
//
// Plain HTML <table> inside <Figure> per the diagram index's 3-column
// comparison guidance. Inline style strings on every primitive so a reader can
// copy the source and see exactly what styled it. `margin: 0` on every element
// (via `reset`) defeats Starlight's injected prose margins; `not-content` on the
// root table defeats the article-level table reset (borders, zebra striping)
// that would otherwise fight these styles. Colours echo the lifecycle strip in
// the same lesson so the two figures read as a set.

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const reset = "margin: 0";

type Row = {
  /** The service this row describes. */
  service: string;
  /** The flavour of the key in each environment, left to right. */
  local: string;
  preview: string;
  production: string;
};

// Four representative services the student already wired across the course.
// Local and Preview share the safe/throwaway flavour; only Production is live.
const rows: Row[] = [
  { service: "Stripe", local: "test key", preview: "test key", production: "live key" },
  { service: "Resend", local: "sandbox", preview: "sandbox", production: "production" },
  {
    service: "Postgres",
    local: "local / branch DB",
    preview: "preview branch DB",
    production: "production DB",
  },
  {
    service: "Upstash",
    local: "dev instance",
    preview: "preview instance",
    production: "production instance",
  },
];

// ---- styles --------------------------------------------------------------

const tableStyle = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "border-collapse: separate",
  "border-spacing: 6px",
  "table-layout: fixed",
].join("; ");

// Shared base for every cell.
const cellBase = [
  reset,
  "box-sizing: border-box",
  "padding: 9px 12px",
  "border-radius: 8px",
  "text-align: center",
  "vertical-align: middle",
  "line-height: 1.2",
];

// Column-header cells. The Production header is the saturated emerald that the
// eye should land on; the two non-prod headers are neutral slate.
const headEnv = (accent: boolean) =>
  [
    ...cellBase,
    "font-size: 13px",
    "font-weight: 800",
    "letter-spacing: 0.02em",
    "text-transform: uppercase",
    "color: #ffffff",
    accent ? "background: #059669" : "background: #475569",
  ].join("; ");

// Top-left empty corner cell — invisible, just holds the grid shape.
const corner = [...cellBase, "background: transparent"].join("; ");

// Row-label cell (the service name).
const serviceCell = [
  ...cellBase,
  "text-align: left",
  "font-size: 14px",
  "font-weight: 700",
  "color: var(--sl-color-white)",
  "background: var(--sl-color-gray-6, rgba(127,127,127,0.12))",
].join("; ");

// Non-production value cells: muted, low-contrast — these are throwaway values.
const mutedCell = [
  ...cellBase,
  "font-size: 13px",
  "font-weight: 500",
  "color: var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6, rgba(127,127,127,0.12))",
].join("; ");

// Production value cells: tinted emerald + bold, so the live column stands out.
const liveCell = [
  ...cellBase,
  "font-size: 13px",
  "font-weight: 700",
  "color: var(--sl-color-white)",
  "background: rgba(5, 150, 105, 0.16)",
  "box-shadow: inset 0 0 0 1px rgba(5, 150, 105, 0.5)",
].join("; ");
---

<table class="not-content" style={tableStyle}>
  <thead>
    <tr>
      <th scope="col" style={corner}></th>
      <th scope="col" style={headEnv(false)}>Local</th>
      <th scope="col" style={headEnv(false)}>Preview</th>
      <th scope="col" style={headEnv(true)}>Production</th>
    </tr>
  </thead>
  <tbody>
    {
      rows.map((r) => (
        <tr>
          <th scope="row" style={serviceCell}>
            {r.service}
          </th>
          <td style={mutedCell}>{r.local}</td>
          <td style={mutedCell}>{r.preview}</td>
          <td style={liveCell}>{r.production}</td>
        </tr>
      ))
    }
  </tbody>
</table>
