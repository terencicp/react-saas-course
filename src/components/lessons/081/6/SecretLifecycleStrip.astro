---
// SecretLifecycleStrip — Chapter 081 Lesson 6 ("Where secrets live and how they
// rotate"), the spine figure in the lesson introduction.
//
// Pedagogical goal: give the student a mental skeleton — the whole life of one
// secret as a one-way timeline, so each of the five rules below has a "home"
// stage. The diagram says LINEAR: born in a provider dashboard, declared,
// stored, scoped, guarded at commit, rotated on an event, retired. No
// branching, no parallelism; the left-to-right read IS the lesson.
//
// Plain HTML + CSS per the diagram index's "sequential phase strip (timeline
// without parallelism)" row. Inline style strings on every primitive so a
// reader can copy the source and see exactly what styled it. `margin: 0` on
// every element defeats Starlight's injected prose margin-top (the gotcha that
// otherwise shifts and shrinks later siblings in a flex row); `not-content` on
// the root does the same for the article-level reset.
//
// Each stage is a saturated mid-tone box with white text (so the colour itself
// carries the signal and the contrast holds in both light and dark themes) plus
// a muted one-line subtitle naming where that stage happens. A hue ramp from
// teal (created) through to slate (retired) reinforces "a secret cools toward
// the grave" without making any single box the focus. The chevrons between
// boxes are drawn from borders in currentColor, so they read as neutral chrome
// in either theme.
//
// Seven boxes in one row is tight: small font, tight padding, and min-width: 0
// let cells shrink before the row wraps, which keeps the linear read intact at
// laptop width. flex-wrap is the graceful fallback only at very narrow widths.

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const reset = "margin: 0";

type Stage = {
  /** The stage heading (one word). */
  title: string;
  /** One-line subtitle: where this stage happens. */
  sub: string;
  /** Saturated fill (Tailwind 600-range) for the box. */
  color: string;
};

// Authored left-to-right in chronological order. Hue ramps teal -> blue ->
// indigo -> violet -> amber (the commit-time gate, a "stop and check") ->
// rose (the rotation event) -> slate (retired/dead).
const stages: Stage[] = [
  { title: "Created", sub: "provider dashboard", color: "#0d9488" },
  { title: "Declared", sub: "env.ts schema", color: "#2563eb" },
  { title: "Stored", sub: "platform secret store", color: "#4f46e5" },
  { title: "Scoped", sub: "local / preview / prod", color: "#7c3aed" },
  { title: "Guarded", sub: "commit-time scan", color: "#d97706" },
  { title: "Rotated", sub: "on an event", color: "#e11d48" },
  { title: "Retired", sub: "revoked at provider", color: "#475569" },
];

// ---- styles --------------------------------------------------------------

// The row: a centred flex line of boxes and chevrons. Wraps only as a last
// resort at very narrow widths; the column-gap/row-gap split keeps wrapped
// rows from visually touching.
const row = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "justify-content: center",
  "flex-wrap: wrap",
  "column-gap: 4px",
  "row-gap: 14px",
].join("; ");

// One stage box: saturated fill, white text, heading over muted subtitle. The
// flex basis + min-width: 0 lets seven boxes share the row and shrink together
// instead of one long subtitle stealing width from its neighbours.
const box = (color: string) =>
  [
    reset,
    "box-sizing: border-box",
    "flex: 1 1 0",
    "min-width: 92px",
    "max-width: 150px",
    "padding: 9px 10px",
    "border-radius: 9px",
    `background: ${color}`,
    "color: #ffffff",
    "display: flex",
    "flex-direction: column",
    "justify-content: center",
    "gap: 2px",
    "text-align: center",
  ].join("; ");

const titleStyle = [
  reset,
  "box-sizing: border-box",
  "font-size: 14px",
  "font-weight: 800",
  "letter-spacing: 0.01em",
  "line-height: 1.15",
].join("; ");

const subStyle = [
  reset,
  "box-sizing: border-box",
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: rgba(255, 255, 255, 0.85)",
].join("; ");

// The connector between two boxes: a right-pointing chevron drawn from borders
// so it needs no font glyph and inherits the row's currentColor (theme-aware).
const chevronWrap = [
  reset,
  "box-sizing: border-box",
  "flex: 0 0 auto",
  "display: flex",
  "align-items: center",
  "color: currentColor",
  "opacity: 0.45",
].join("; ");

const chevron = [
  reset,
  "box-sizing: border-box",
  "width: 0",
  "height: 0",
  "border-top: 5px solid transparent",
  "border-bottom: 5px solid transparent",
  "border-left: 6px solid currentColor",
].join("; ");
---

<div class="not-content" style={row}>
  {
    stages.map((stage, i) => (
      <>
        <div style={box(stage.color)}>
          <p style={titleStyle}>{stage.title}</p>
          <p style={subStyle}>{stage.sub}</p>
        </div>
        {i < stages.length - 1 && (
          <div style={chevronWrap} aria-hidden="true">
            <span style={chevron} />
          </div>
        )}
      </>
    ))
  }
</div>
