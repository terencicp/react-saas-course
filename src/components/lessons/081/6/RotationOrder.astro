---
// RotationOrder — Chapter 081 Lesson 6 ("Where secrets live and how they
// rotate"), the figure for Rule 5 ("rotation is a documented operation").
//
// Pedagogical goal: make the *overlap window* visible. Rotation is an ordering
// problem, and the one mistake (revoke-first) creates an instant with no valid
// key. By rendering the live credential in two places at once — the Provider
// box and the Vercel box — and colouring old vs. new vs. revoked, the reader
// can literally watch both keys be valid through the middle steps, which is the
// safety margin the whole rule exists to buy. Scrub steps 1->5 and the eye
// tracks the new (green) pill appearing in Vercel *before* the old (grey) pill
// is struck out (red) at the provider.
//
// This is the canonical DiagramSequence use (step-by-step ops execution), so it
// IS its own card — never wrapped in <Figure>. Each <DiagramStep> renders the
// same two-box stage with a different credential state, plus a per-step caption.
//
// Plain HTML + CSS with inline style strings on every primitive so a reader can
// copy the source and see exactly what styled it. `margin: 0` everywhere (via
// `reset`) defeats Starlight's injected prose margins. Colours echo the other
// two figures in this lesson (emerald = live/new, slate = old/neutral, rose =
// revoked) so the three read as a set. Every step renders the same number of
// pill rows (empty placeholders hold the slot) so the two boxes keep a constant
// height and the DiagramSequence stage never jumps as the reader scrubs.

import DiagramSequence from "../../../../components/figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../components/figures/diagram-sequence/DiagramStep.astro";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, monospace)";
const reset = "margin: 0";

// A credential pill's visual state.
type PillState = "old" | "new" | "revoked" | "empty";

type Pill = { label: string; state: PillState };
type StageState = {
  /** Pills inside the Provider box, top to bottom. */
  provider: Pill[];
  /** Pills inside the Vercel box, top to bottom. */
  vercel: Pill[];
  /** Optional health badge under the Vercel box. */
  health?: "verified" | null;
};

// Each step is one frozen state of the two boxes. Two pill rows per box in
// every step (an `empty` placeholder where there is no pill) so the boxes hold
// a constant height across the whole sequence.
const steps: { state: StageState; caption: string }[] = [
  {
    // 1 — new generated at provider, nothing in Vercel yet.
    state: {
      provider: [
        { label: "old key", state: "old" },
        { label: "new key", state: "new" },
      ],
      vercel: [
        { label: "old key", state: "old" },
        { label: "", state: "empty" },
      ],
    },
    caption:
      "Generate new at provider. Create the new secret in the provider dashboard. The old one is still active — nothing has changed for the running app yet.",
  },
  {
    // 2 — new added to Vercel; both valid in both places. The overlap begins.
    state: {
      provider: [
        { label: "old key", state: "old" },
        { label: "new key", state: "new" },
      ],
      vercel: [
        { label: "old key", state: "old" },
        { label: "new key", state: "new" },
      ],
    },
    caption:
      "Add to Vercel. Add (or overwrite) the new value in Vercel, with the sensitive flag, for every environment that needs it. Both are valid right now — this overlap is the safety margin.",
  },
  {
    // 3 — redeploy on the new value; Vercel verified healthy.
    state: {
      provider: [
        { label: "old key", state: "old" },
        { label: "new key", state: "new" },
      ],
      vercel: [
        { label: "old key", state: "old" },
        { label: "new key", state: "new" },
      ],
      health: "verified",
    },
    caption:
      "Redeploy and verify. Redeploy and confirm the app is healthy on the new value. Only proceed once you've verified — this is the gate.",
  },
  {
    // 4 — old revoked at the provider. App already runs on the new value.
    state: {
      provider: [
        { label: "old key", state: "revoked" },
        { label: "new key", state: "new" },
      ],
      vercel: [
        { label: "old key", state: "old" },
        { label: "new key", state: "new" },
      ],
      health: "verified",
    },
    caption:
      "Revoke old at provider. Now revoke the old secret at the provider. The app is already running on the new one, so revoking the old one is invisible to users.",
  },
  {
    // 5 — settled: only the new key remains live, everywhere.
    state: {
      provider: [
        { label: "new key", state: "new" },
        { label: "", state: "empty" },
      ],
      vercel: [
        { label: "new key", state: "new" },
        { label: "", state: "empty" },
      ],
      health: "verified",
    },
    caption:
      "Record it. Update .env.local from the password manager and note the rotation in the runbook — date, secret, who triggered it.",
  },
];

// ---- styles --------------------------------------------------------------

// Two boxes side by side with a thin gap; centred, capped so it never sprawls.
const stageRow = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 560px",
  "margin: 0 auto",
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "justify-content: center",
  "gap: 16px",
].join("; ");

// One labelled box (Provider / Vercel). Neutral chrome so the pills carry the
// colour signal; subtle tint distinguishes the two without competing.
const boxStyle = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "flex: 1 1 0",
    "min-width: 0",
    "display: flex",
    "flex-direction: column",
    "gap: 8px",
    "padding: 12px",
    "border-radius: 10px",
    "background: var(--sl-color-gray-6, rgba(127,127,127,0.1))",
    `border: 1px solid ${accent}`,
  ].join("; ");

const boxTitle = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "font-size: 12px",
    "font-weight: 800",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "text-align: center",
    `color: ${accent}`,
  ].join("; ");

// A single credential pill. Colour and decoration encode its state.
const pillBase = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "gap: 6px",
  "padding: 7px 8px",
  "border-radius: 7px",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.1",
  "min-height: 32px",
];

const pillStyle = (state: PillState) => {
  if (state === "empty") {
    return [...pillBase, "background: transparent", "border: 1px dashed transparent"].join(
      "; ",
    );
  }
  if (state === "new") {
    return [
      ...pillBase,
      "background: rgba(5, 150, 105, 0.16)",
      "box-shadow: inset 0 0 0 1px rgba(5, 150, 105, 0.55)",
      "color: var(--sl-color-white)",
    ].join("; ");
  }
  if (state === "revoked") {
    return [
      ...pillBase,
      "background: rgba(225, 29, 72, 0.12)",
      "box-shadow: inset 0 0 0 1px rgba(225, 29, 72, 0.5)",
      "color: var(--sl-color-gray-2)",
      "text-decoration: line-through",
      "text-decoration-color: #e11d48",
      "text-decoration-thickness: 2px",
    ].join("; ");
  }
  // old / neutral
  return [
    ...pillBase,
    "background: var(--sl-color-gray-5, rgba(127,127,127,0.18))",
    "box-shadow: inset 0 0 0 1px var(--sl-color-hairline)",
    "color: var(--sl-color-gray-2)",
  ].join("; ");
};

// Small status dot before a pill's label, so the state reads even in greyscale.
const dotStyle = (state: PillState) => {
  const color =
    state === "new" ? "#059669" : state === "revoked" ? "#e11d48" : "#64748b";
  return [
    reset,
    "box-sizing: border-box",
    "flex: 0 0 auto",
    "width: 7px",
    "height: 7px",
    "border-radius: 50%",
    `background: ${color}`,
  ].join("; ");
};

// The "app healthy" badge under the Vercel box.
const healthBadge = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "gap: 5px",
  "margin: 2px auto 0",
  "padding: 3px 9px",
  "border-radius: 999px",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "color: #059669",
  "background: rgba(5, 150, 105, 0.14)",
].join("; ");

// Reserve the health badge's vertical slot in every step so adding it in later
// steps doesn't change the Vercel box height.
const healthSlot = [
  reset,
  "box-sizing: border-box",
  "min-height: 22px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
].join("; ");

const providerAccent = "#7c3aed"; // violet — the provider side
const vercelAccent = "#2563eb"; // blue — the platform side
---

<DiagramSequence>
  {
    steps.map((step) => (
      <DiagramStep caption={step.caption}>
        <div class="not-content" style={stageRow}>
          <div style={boxStyle(providerAccent)}>
            <p style={boxTitle(providerAccent)}>Provider</p>
            {step.state.provider.map((pill) => (
              <div style={pillStyle(pill.state)}>
                {pill.state !== "empty" && (
                  <span style={dotStyle(pill.state)} aria-hidden="true" />
                )}
                {pill.label}
              </div>
            ))}
            <div style={healthSlot} aria-hidden="true" />
          </div>

          <div style={boxStyle(vercelAccent)}>
            <p style={boxTitle(vercelAccent)}>Vercel</p>
            {step.state.vercel.map((pill) => (
              <div style={pillStyle(pill.state)}>
                {pill.state !== "empty" && (
                  <span style={dotStyle(pill.state)} aria-hidden="true" />
                )}
                {pill.label}
              </div>
            ))}
            <div style={healthSlot}>
              {step.state.health === "verified" && (
                <span style={healthBadge}>✓ app healthy</span>
              )}
            </div>
          </div>
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>
