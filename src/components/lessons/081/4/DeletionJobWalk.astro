---
// DeletionJobWalk — Chapter 081 Lesson 4 ("Retention and the right to be
// forgotten"), the centerpiece of the deletion-on-request section.
//
// Pedagogical goal: the `delete-user` job is an ORDERED, COMPLETE graph walk,
// and both the order and the completeness are the lesson — a flat list buries
// exactly the step someone forgets. So the reader scrubs one stage at a time
// through a stable six-node pipeline, the current stage lit, the stages already
// walked ticked "done", the rest dim "pending". Reading the picture, "the job
// marches left-to-right and only finalizes after every stage — including the
// three external vendors — is behind it" is spatial, not asserted.
//
// Structure mirrors the docs' render-pipeline example (049/1): a horizontal
// strip of labeled nodes inside each <DiagramStep>, generated once from a data
// array so the strip is authored a single time and only `active` changes
// frame-to-frame. The fifth node (External vendors) carries an amber tint, not
// the blue accent — it's the stage erasure most often silently skips, and the
// one that reaches OUTSIDE your database, so the colour itself flags it.
//
// Pure HTML + CSS per the diagrams guide (a sequential phase strip, not a
// graph). `not-content` + margin:0 reset Starlight's injected prose chrome.
// Theme-aware color-mix accents read on light and dark. DiagramSequence supplies
// the outer card + per-step captions, so this is NOT wrapped in <Figure>.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

type Stage = {
  /** Short node headline. */
  label: string;
  /** One-word role under the headline. */
  sub: string;
  /** What this stage touches — shown in the detail panel under the strip. */
  detail: string;
  /** The shape (or note) this stage applies, as a small pill in the detail. */
  shape: string;
  /** The per-step caption. */
  caption: string;
  /** Stage that reaches outside the database — tinted amber, not blue. */
  external?: boolean;
};

// The six stages of the `delete-user` task, in the order they must run.
const stages: Stage[] = [
  {
    label: "Internal hard-deletes",
    sub: "owned alone",
    detail: "Sessions, personal API keys, notification preferences, profile-owned rows.",
    shape: "hard delete · FK cascade",
    caption:
      "Internal hard-deletes. The rows the user owns alone — sessions, personal API keys, notification preferences, profile-owned rows. The user row's onDelete: 'cascade' does much of this automatically; the cascade is part of the graph, not separate from it.",
  },
  {
    label: "Shared rows",
    sub: "soft + anon",
    detail: "Memberships, the PII fields on retained invoices, comments on shared documents.",
    shape: "soft-delete + anonymize",
    caption:
      "Soft-delete + anonymize the shared rows. Memberships, the PII on retained invoices, comments on shared docs — each gets the shape the catalog assigned. The rows survive; the personal data and the active-view visibility do not.",
  },
  {
    label: "Audit log",
    sub: "anonymize",
    detail: "Null actorUserId via the onDelete: 'set null' FK; scrub any PII the payload held.",
    shape: "anonymize",
    caption:
      "Anonymize the audit log. Null the actorUserId through the onDelete: 'set null' foreign key and scrub payload PII via the owner-role path. Last lesson's resolution, reused exactly — the forensic record survives, the link to the person is cut.",
  },
  {
    label: "Object storage",
    sub: "blobs",
    detail: "The user's export files and uploads — or let a lifecycle rule expire them.",
    shape: "delete · or delegate",
    caption:
      "Delete the object-storage blobs. The user's export files and uploads. Or, where a lifecycle rule already covers them, let storage expire them — delegate when you can.",
  },
  {
    label: "External vendors",
    sub: "processors",
    detail: "Delete the Stripe customer, the Resend audience contact, the PostHog person.",
    shape: "3 retried steps",
    external: true,
    caption:
      "Call the external vendors. Delete the Stripe customer, the Resend audience contact, the PostHog person — three discrete steps, each retried on its own. Erasure isn't done until the PII is gone from every processor, not just your database.",
  },
  {
    label: "Finalize",
    sub: "complete",
    detail: "Flip the user row to deleted, write account.deletion-completed, send the email.",
    shape: "report success",
    caption:
      "Finalize. Flip the user row to its deleted state, write the account.deletion-completed audit entry — a system-actor row (actorUserId: null, a system.* action), since the job, not the user, writes it — with a summary payload ({ tablesPurged, externalsPurged, durationMs }), and send the confirmation email. Now — and only now — the job reports success.",
  },
];

const BLUE = "#3b82f6"; // matches DiagramSequence's own accent
const AMBER = "#d97706"; // the external-vendor stage: reaches outside the DB

// Done / active / pending relative to the active index, for progress styling.
const stateOf = (i: number, active: number): "done" | "active" | "pending" =>
  i < active ? "done" : i === active ? "active" : "pending";

const tickIcon = `<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;display:block;"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
---

<DiagramSequence>
  {
    stages.map((step, active) => (
      <DiagramStep caption={step.caption}>
        <div class="dj not-content">
          <div
            class="dj-strip"
            role="img"
            aria-label={`Deletion job, stage ${active + 1} of ${stages.length}: ${step.label}.`}
          >
            {stages.map((node, i) => {
              const st = stateOf(i, active);
              return (
                <>
                  <div
                    class:list={[
                      "dj-node",
                      `is-${st}`,
                      node.external && "is-external",
                    ]}
                  >
                    <span class="dj-marker">
                      {st === "done" ? (
                        <span class="dj-dot dj-dot--done">
                          <Fragment set:html={tickIcon} />
                        </span>
                      ) : st === "active" ? (
                        <span class="dj-dot dj-dot--active" />
                      ) : (
                        <span class="dj-dot dj-dot--pending" />
                      )}
                    </span>
                    <span class="dj-label">{node.label}</span>
                    <span class="dj-sub">{node.sub}</span>
                  </div>
                  {i < stages.length - 1 && (
                    <span
                      class:list={["dj-arrow", { "is-on": i < active }]}
                      aria-hidden="true"
                    >
                      <svg viewBox="0 0 34 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="1" y1="7" x2="26" y2="7" />
                        <polyline points="21 2.5 27.5 7 21 11.5" />
                      </svg>
                    </span>
                  )}
                </>
              );
            })}
          </div>

          <div class:list={["dj-detail", { "is-external": step.external }]}>
            <span class="dj-detail-text">{step.detail}</span>
            <span class="dj-shape">{step.shape}</span>
          </div>
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>

<style define:vars={{ "dj-blue": BLUE, "dj-amber": AMBER }}>
  .dj {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    font-family: var(
      --sl-font-system,
      ui-sans-serif,
      system-ui,
      -apple-system,
      sans-serif
    );
  }

  /* The horizontal pipeline. Wraps (never scrolls) on narrow viewports. */
  .dj-strip {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 3px;
  }

  .dj-node {
    margin: 0;
    flex: 1 1 0;
    min-width: 88px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 4px;
    padding: 10px 7px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    text-align: center;
    transition:
      border-color 0.14s,
      background-color 0.14s,
      color 0.14s,
      box-shadow 0.14s,
      opacity 0.14s;
  }
  .dj-node.is-pending {
    opacity: 0.55;
  }
  .dj-node.is-done {
    border-color: color-mix(in srgb, var(--dj-blue) 30%, var(--sl-color-gray-4));
    color: var(--sl-color-gray-2);
  }
  .dj-node.is-active {
    border: 1.5px solid var(--dj-blue);
    background: color-mix(in srgb, var(--dj-blue) 12%, transparent);
    color: color-mix(in srgb, var(--dj-blue) 82%, var(--sl-color-text));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--dj-blue) 14%, transparent);
  }
  /* The external-vendor stage carries amber when lit — it reaches outside the DB. */
  .dj-node.is-external.is-active {
    border-color: var(--dj-amber);
    background: color-mix(in srgb, var(--dj-amber) 13%, transparent);
    color: color-mix(in srgb, var(--dj-amber) 82%, var(--sl-color-text));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--dj-amber) 15%, transparent);
  }

  .dj-marker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0;
  }
  .dj-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 17px;
    height: 17px;
    border-radius: 999px;
    margin: 0;
    flex: 0 0 auto;
  }
  .dj-dot--pending {
    width: 10px;
    height: 10px;
    background: var(--sl-color-bg);
    border: 2px solid var(--sl-color-gray-4);
  }
  .dj-dot--active {
    background: var(--dj-blue);
    border: 3px solid color-mix(in srgb, var(--dj-blue) 28%, transparent);
  }
  .dj-node.is-external .dj-dot--active {
    background: var(--dj-amber);
    border-color: color-mix(in srgb, var(--dj-amber) 28%, transparent);
  }
  .dj-dot--done {
    background: color-mix(in srgb, var(--dj-blue) 80%, var(--sl-color-gray-3));
    color: #fff;
  }

  .dj-label {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
  }
  .dj-sub {
    margin: 0;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.2;
    opacity: 0.85;
  }

  /* Connectors. Edges left of the active node light up, so the strip reads as
     progress through the walk, not just a static chain. */
  .dj-arrow {
    margin: 0;
    flex: 0 0 auto;
    align-self: center;
    display: inline-flex;
    color: var(--sl-color-gray-4);
    transition: color 0.14s;
  }
  .dj-arrow.is-on {
    color: color-mix(in srgb, var(--dj-blue) 70%, var(--sl-color-text));
  }
  .dj-arrow svg {
    width: 22px;
    height: 14px;
  }

  /* Detail panel under the strip — fixed min-height so every frame matches and
     the grid-stacked sequence never changes height between steps. */
  .dj-detail {
    margin: 0;
    box-sizing: border-box;
    min-height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    padding: 12px 15px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--dj-blue) 35%, var(--sl-color-hairline));
    background: color-mix(in srgb, var(--dj-blue) 7%, var(--sl-color-bg));
  }
  .dj-detail.is-external {
    border-color: color-mix(in srgb, var(--dj-amber) 38%, var(--sl-color-hairline));
    background: color-mix(in srgb, var(--dj-amber) 8%, var(--sl-color-bg));
  }
  .dj-detail-text {
    margin: 0;
    font-size: 13px;
    line-height: 1.45;
    color: var(--sl-color-text);
    min-width: 0;
    flex: 1 1 220px;
  }
  .dj-shape {
    margin: 0;
    flex: 0 0 auto;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--dj-blue) 82%, var(--sl-color-text));
    background: color-mix(in srgb, var(--dj-blue) 13%, transparent);
    border: 1px solid color-mix(in srgb, var(--dj-blue) 35%, transparent);
    border-radius: 999px;
    padding: 3px 10px;
    white-space: nowrap;
  }
  .dj-detail.is-external .dj-shape {
    color: color-mix(in srgb, var(--dj-amber) 82%, var(--sl-color-text));
    background: color-mix(in srgb, var(--dj-amber) 14%, transparent);
    border-color: color-mix(in srgb, var(--dj-amber) 38%, transparent);
  }

  /* On the narrowest viewports the nodes stack; rotate the connectors so the
     flow still reads top-to-bottom. */
  @media (max-width: 620px) {
    .dj-strip {
      flex-direction: column;
      align-items: stretch;
    }
    .dj-node {
      flex-direction: row;
      justify-content: flex-start;
      gap: 8px;
      text-align: left;
    }
    .dj-arrow {
      align-self: center;
      transform: rotate(90deg);
    }
  }
</style>
