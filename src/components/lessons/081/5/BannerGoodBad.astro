---
/**
 * banner-good-bad — Chapter 081 Lesson 5, "Nothing fires pre-consent".
 *
 * The bad/good contrast pair, requested as a TabbedContent two-panel before/after.
 * Sibling to BannerAnatomy in this folder; same HTML+CSS banner mock vocabulary so
 * the two figures read as one family.
 *
 * The whole teaching payload is VISUAL ASYMMETRY:
 *   - "Dark pattern" tab — "Accept all" is a big, brightly-filled primary button;
 *     "Reject all" is a tiny, faint, low-contrast text link shoved off to the side.
 *     This is the design the CNIL/EDPB fine.
 *   - "Compliant" tab — the same three actions at equal weight, size, and one-click
 *     prominence. This is the bar.
 *
 * Per the diagram index this is an annotated illustration → HTML + CSS. All chrome
 * uses Starlight CSS vars so it survives both themes. The one accent is a warm
 * "primary" fill (#d97706) the dark-pattern banner uses to over-emphasise Accept;
 * the compliant banner deliberately gives that emphasis to no single button.
 *
 * TabbedContent provides its own figure card, so this component must NOT wrap it in
 * <Figure>. Per-tab captions carry the verdict for each banner.
 */
import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';
---

<TabbedContent syncKey="banner-good-bad">
	<TabbedItem
		label="Dark pattern"
		icon="error"
		caption="Accept is loud, Reject is hidden — this asymmetry is what the CNIL and EDPB fine."
	>
		<div class="bgb">
			<div class="bgb-bar bgb-bar--bad">
				<p class="bgb-copy">
					We use cookies to improve your experience. By continuing you agree to our
					use of cookies.
				</p>
				<div class="bgb-buttons">
					<button type="button" class="bgb-link" tabindex="-1">Reject all</button>
					<button type="button" class="bgb-btn bgb-btn--primary" tabindex="-1">
						Accept all
					</button>
				</div>
			</div>
		</div>
	</TabbedItem>

	<TabbedItem
		label="Compliant"
		icon="approve-check"
		caption="Reject is exactly as easy as Accept — same size, same prominence, one click. This is the bar."
	>
		<div class="bgb">
			<div class="bgb-bar bgb-bar--good">
				<p class="bgb-copy">
					We use cookies to measure and improve the product. You choose what's on.
				</p>
				<div class="bgb-buttons">
					<button type="button" class="bgb-btn" tabindex="-1">Reject all</button>
					<button type="button" class="bgb-btn bgb-btn--manage" tabindex="-1">
						Manage preferences
					</button>
					<button type="button" class="bgb-btn" tabindex="-1">Accept all</button>
				</div>
			</div>
		</div>
	</TabbedItem>
</TabbedContent>

<style>
	.bgb {
		--bgb-primary: #d97706; /* the over-emphasised "primary" fill */
		--bgb-good: #0d9488; /* the compliant bar accent */
		--bgb-bad: #dc2626; /* the dark-pattern bar accent */
		width: 100%;
		margin: 0;
		/* Keep both panels the same height so the tab swap doesn't jump. */
		min-height: 7.5rem;
		display: flex;
		align-items: center;
	}

	/* ── The banner bar (shared shell) ──────────────────────────────────────── */
	.bgb-bar {
		position: relative;
		width: 100%;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1.25rem;
		padding: 1rem 1.1rem;
		border: 2px solid var(--sl-color-gray-4);
		border-radius: 12px;
		background: var(--sl-color-bg);
		margin: 0;
	}
	.bgb-bar--good {
		border-color: var(--bgb-good);
		box-shadow: 0 6px 18px -10px color-mix(in srgb, var(--bgb-good) 60%, transparent);
	}
	.bgb-bar--bad {
		border-color: var(--bgb-bad);
		box-shadow: 0 6px 18px -10px color-mix(in srgb, var(--bgb-bad) 60%, transparent);
	}

	.bgb-copy {
		flex: 1 1 14rem;
		min-width: 0;
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.4;
		color: var(--sl-color-white);
	}

	.bgb-buttons {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
		margin: 0;
	}

	/* The neutral, equal-weight button — used for all three on the compliant
	   banner. Identical baseline so nothing reads as "the" choice. */
	.bgb-btn {
		margin: 0;
		font: inherit;
		font-size: 0.85rem;
		font-weight: 600;
		padding: 0.5rem 0.95rem;
		border-radius: 8px;
		cursor: default;
		white-space: nowrap;
		border: 1px solid var(--sl-color-gray-3);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
	}
	.bgb-btn--manage {
		/* still equal weight — just the third option, visually a peer */
		border-color: var(--sl-color-gray-3);
	}

	/* ── The dark pattern: Accept shouts, Reject whispers ───────────────────── */
	/* Big, bright, filled — the eye lands here and nowhere else. */
	.bgb-btn--primary {
		border: 1px solid var(--bgb-primary);
		background: var(--bgb-primary);
		color: #fff;
		font-size: 0.95rem;
		font-weight: 700;
		padding: 0.65rem 1.5rem;
		box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--bgb-primary) 70%, transparent);
	}
	/* Tiny, faint, low-contrast text link — easy to miss, hard to want. */
	.bgb-link {
		margin: 0;
		font: inherit;
		font-size: 0.72rem;
		font-weight: 400;
		padding: 0;
		border: 0;
		background: none;
		cursor: default;
		white-space: nowrap;
		color: var(--sl-color-gray-4);
		text-decoration: underline;
		text-underline-offset: 2px;
	}
</style>
