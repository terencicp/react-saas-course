---
/**
 * pre-consent-timeline — Chapter 081 Lesson 5, "Nothing fires pre-consent".
 *
 * The lesson's centerpiece: the pre-consent boundary is a TIMING problem, and the
 * proof is the order of the frames. Six frames, scrubbed with the slider. Every
 * frame holds the SAME picture and only changes two load-bearing readouts:
 *
 *   1. The consent state (useConsent() flags) — top strip.
 *   2. The mock NETWORK TAB — the panel that stays empty for the first four
 *      frames and only fills with the analytics bundle + requests at frame 5/6.
 *
 * The network panel staying clean until AFTER "Accept all" (frame 3) is the whole
 * aha: nothing analytics-shaped exists on the wire until load -> choose -> import
 * -> fire has run in that exact order. A vertical "consent line" on the phase
 * spine marks the instant the user chose, so the reader can see every analytics
 * row sits to the right of it.
 *
 * Plain HTML + CSS (scoped) over a per-frame diagram engine, matching the sibling
 * IdempotencyReplay (046/3): the fixed spine + fixed network-tab chrome must stay
 * pinned across frames so scrubbing animates one picture, and a mock browser
 * devtools panel (rows appearing/greying) is trivial in CSS and awkward elsewhere.
 *
 * Palette mirrors the chapter's components: blue #0ea5e9 for the live/analytics
 * accent, neutral Starlight grays for the spine, green #22c55e to mark "consent
 * granted". All chrome is theme-aware via Starlight CSS vars.
 *
 * DiagramSequence provides its own card and must NOT be wrapped in <Figure>.
 */
import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// The six phases of the timeline, in order. The `consent` flag marks the frame
// where the user's choice lands — the spine draws its marker just before it.
const phases = [
	{ key: 'load', label: 'Page loads' },
	{ key: 'banner', label: 'Banner shown' },
	{ key: 'click', label: '“Accept all” clicked' },
	{ key: 'action', label: 'Server Action' },
	{ key: 'import', label: 'Import + opt-in' },
	{ key: 'fire', label: 'First event fires' },
];

// Per-frame data. `active` indexes into `phases`. `state` is the useConsent()
// readout. `rows` are the mock network-tab entries — empty array = clean wire.
type NetRow = { name: string; type: string; status: string; live?: boolean };
type Frame = {
	active: number;
	analytics: boolean;
	marketing: boolean;
	stateLabel: string;
	rows: NetRow[];
	netNote: string;
	netClean: boolean;
	caption: string;
};

const frames: Frame[] = [
	{
		active: 0,
		analytics: false,
		marketing: false,
		stateLabel: 'unset',
		rows: [],
		netNote: 'Clean — the analytics module was never even imported.',
		netClean: true,
		caption:
			'<strong>Page loads.</strong> <code>useConsent()</code> is <code>unset</code> — both flags false. The network tab is clean: no analytics bundle, no requests, because the module was never imported.',
	},
	{
		active: 1,
		analytics: false,
		marketing: false,
		stateLabel: 'unset',
		rows: [],
		netNote: 'Still clean. The server read the cookie, so the banner renders with no flash.',
		netClean: true,
		caption:
			'<strong>Banner shown.</strong> The server already read the <code>consent_choice</code> cookie and saw <code>unset</code>, so it rendered the banner with no flash. Still nothing analytics-shaped on the wire.',
	},
	{
		active: 2,
		analytics: false,
		marketing: false,
		stateLabel: 'unset',
		rows: [],
		netNote: 'Up to this instant — still clean. This click is the first non-essential action.',
		netClean: true,
		caption:
			'<strong>User clicks “Accept all”.</strong> The first non-essential action in the whole timeline. Up to this exact instant, the network tab is <em>still</em> clean.',
	},
	{
		active: 3,
		analytics: true,
		marketing: true,
		stateLabel: 'all',
		rows: [
			{ name: 'saveConsent', type: 'fetch', status: '200' },
		],
		netNote: 'Only the Server Action call. It writes the cookie + audit row; the provider flips to all. No analytics yet.',
		netClean: false,
		caption:
			'<strong>Server Action runs.</strong> <code>saveConsent</code> writes the <code>consent_choice</code> cookie and the <code>consent.recorded</code> audit row, then returns the new choice. The provider flips to <code>all</code> — but the only request on the wire is the action itself.',
	},
	{
		active: 4,
		analytics: true,
		marketing: true,
		stateLabel: 'all',
		rows: [
			{ name: 'saveConsent', type: 'fetch', status: '200' },
			{ name: 'analytics.[hash].js', type: 'script', status: '200', live: true },
		],
		netNote: 'Now — and only now — the analytics bundle appears, after the click.',
		netClean: false,
		caption:
			'<strong>Provider dynamically imports the analytics module</strong> (<code>import(\'./analytics\')</code>) and calls <code>opt_in_capturing()</code>. <em>Now</em> the SDK bundle appears in the network tab — for the first time, and after the click.',
	},
	{
		active: 5,
		analytics: true,
		marketing: true,
		stateLabel: 'all',
		rows: [
			{ name: 'saveConsent', type: 'fetch', status: '200' },
			{ name: 'analytics.[hash].js', type: 'script', status: '200' },
			{ name: 'e (pageview)', type: 'xhr', status: '200', live: true },
		],
		netNote: 'The pageview captures — after consent, never before.',
		netClean: false,
		caption:
			'<strong>First event fires.</strong> The pageview captures now — after consent, never before. The order is the entire compliance story: <strong>load → choose → import → fire.</strong>',
	},
];

// The consent decision lands at the "click" phase (index 2): the spine draws its
// vertical "consent granted" line on the boundary just after it.
const consentAfter = 2;
---

<DiagramSequence>
	{
		frames.map((frame) => (
			<DiagramStep>
				<div class="pct">
					{/* ── Top readout: what useConsent() returns this frame ───────── */}
					<div class="pct-state">
						<span class="pct-state-label">
							<code>useConsent()</code>
						</span>
						<span class={`pct-flag${frame.analytics ? ' is-on' : ''}`}>
							analytics: <strong>{String(frame.analytics)}</strong>
						</span>
						<span class={`pct-flag${frame.marketing ? ' is-on' : ''}`}>
							marketing: <strong>{String(frame.marketing)}</strong>
						</span>
						<span class={`pct-statepill${frame.stateLabel === 'unset' ? ' is-unset' : ' is-all'}`}>
							{frame.stateLabel}
						</span>
					</div>

					{/* ── Phase spine: the six steps, current one lit, consent line ── */}
					<ol class="pct-spine" aria-hidden="true">
						{phases.map((phase, i) => (
							<>
								<li
									class={`pct-node${i === frame.active ? ' is-active' : ''}${
										i < frame.active ? ' is-done' : ''
									}`}
								>
									<span class="pct-dot" />
									<span class="pct-node-label">{phase.label}</span>
								</li>
								{i === consentAfter && (
									<li class={`pct-gate${frame.active > consentAfter ? ' is-passed' : ''}`}>
										<span class="pct-gate-line" />
										<span class="pct-gate-tag">consent</span>
									</li>
								)}
							</>
						))}
					</ol>

					{/* ── Mock network tab: clean until after the click ───────────── */}
					<div class={`pct-net${frame.netClean ? ' is-clean' : ''}`}>
						<div class="pct-net-bar">
							<span class="pct-net-title">Network</span>
							<span class="pct-net-cols">
								<span>Name</span>
								<span>Type</span>
								<span>Status</span>
							</span>
						</div>
						<div class="pct-net-body">
							{frame.rows.length === 0 ? (
								<div class="pct-net-empty">No requests — the wire is clean.</div>
							) : (
								frame.rows.map((row) => (
									<div class={`pct-net-row${row.live ? ' is-new' : ''}`}>
										<span class="pct-net-name">{row.name}</span>
										<span class="pct-net-type">{row.type}</span>
										<span class="pct-net-status">{row.status}</span>
									</div>
								))
							)}
						</div>
						<div class="pct-net-note">{frame.netNote}</div>
					</div>
				</div>
				<Fragment slot="caption" set:html={frame.caption} />
			</DiagramStep>
		))
	}
</DiagramSequence>

<style>
	.pct {
		--pct-accent: #0ea5e9;
		--pct-go: #22c55e;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		font-size: 0.875rem;
		line-height: 1.35;
	}

	/* ── State readout strip ──────────────────────────────────────────────── */
	.pct-state {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
	}
	.pct-state-label {
		color: var(--sl-color-gray-2);
	}
	.pct-state-label code {
		font-size: 0.85em;
	}
	.pct-flag {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.78rem;
	}
	.pct-flag strong {
		color: var(--sl-color-gray-3);
		font-weight: 700;
	}
	.pct-flag.is-on {
		border-color: var(--pct-accent);
		background: color-mix(in srgb, var(--pct-accent) 16%, var(--sl-color-gray-6));
		color: var(--sl-color-white);
	}
	.pct-flag.is-on strong {
		color: var(--pct-accent);
	}
	.pct-statepill {
		margin-left: auto;
		padding: 0.2rem 0.6rem;
		border-radius: 6px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.78rem;
		font-weight: 700;
	}
	.pct-statepill.is-unset {
		background: var(--sl-color-gray-5);
		color: var(--sl-color-gray-1);
	}
	.pct-statepill.is-all {
		background: color-mix(in srgb, var(--pct-go) 22%, var(--sl-color-gray-6));
		color: var(--pct-go);
		border: 1px solid var(--pct-go);
	}

	/* ── Phase spine ──────────────────────────────────────────────────────── */
	.pct-spine {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		align-items: flex-start;
		gap: 0.25rem;
	}
	.pct-node {
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 0.4rem;
		position: relative;
	}
	/* Connector line between dots. */
	.pct-node::before {
		content: '';
		position: absolute;
		top: 6px;
		left: -50%;
		width: 100%;
		height: 2px;
		background: var(--sl-color-gray-5);
		z-index: 0;
	}
	.pct-node:first-child::before {
		display: none;
	}
	.pct-dot {
		position: relative;
		z-index: 1;
		width: 14px;
		height: 14px;
		border-radius: 999px;
		background: var(--sl-color-gray-5);
		border: 2px solid var(--sl-color-gray-4);
		flex: none;
	}
	.pct-node-label {
		font-size: 0.72rem;
		color: var(--sl-color-gray-3);
		line-height: 1.2;
	}
	.pct-node.is-done .pct-dot {
		background: var(--sl-color-gray-3);
		border-color: var(--sl-color-gray-3);
	}
	.pct-node.is-done .pct-node-label {
		color: var(--sl-color-gray-2);
	}
	.pct-node.is-active .pct-dot {
		background: var(--pct-accent);
		border-color: var(--pct-accent);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--pct-accent) 28%, transparent);
	}
	.pct-node.is-active .pct-node-label {
		color: var(--sl-color-white);
		font-weight: 700;
	}

	/* The vertical "consent granted" gate marker sitting between two phases. */
	.pct-gate {
		flex: 0 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.3rem;
		align-self: stretch;
		padding: 0 0.1rem;
	}
	.pct-gate-line {
		width: 2px;
		flex: 1 1 auto;
		min-height: 22px;
		background: repeating-linear-gradient(
			to bottom,
			var(--sl-color-gray-4) 0,
			var(--sl-color-gray-4) 4px,
			transparent 4px,
			transparent 8px
		);
	}
	.pct-gate-tag {
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-weight: 700;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}
	.pct-gate.is-passed .pct-gate-line {
		background: repeating-linear-gradient(
			to bottom,
			var(--pct-go) 0,
			var(--pct-go) 4px,
			transparent 4px,
			transparent 8px
		);
	}
	.pct-gate.is-passed .pct-gate-tag {
		color: var(--pct-go);
	}

	/* ── Mock network tab ─────────────────────────────────────────────────── */
	.pct-net {
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 10px;
		overflow: hidden;
		background: var(--sl-color-bg);
	}
	.pct-net-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.4rem 0.7rem;
		background: var(--sl-color-gray-6);
		border-bottom: 1px solid var(--sl-color-gray-4);
	}
	.pct-net-title {
		font-weight: 700;
		font-size: 0.78rem;
		color: var(--sl-color-white);
	}
	.pct-net-cols {
		display: grid;
		grid-template-columns: 1fr 5rem 4rem;
		gap: 0.5rem;
		flex: 1 1 auto;
		max-width: 26rem;
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		color: var(--sl-color-gray-3);
	}
	.pct-net-cols span:nth-child(2),
	.pct-net-cols span:nth-child(3) {
		text-align: left;
	}
	.pct-net-body {
		min-height: 5.2rem;
		display: flex;
		flex-direction: column;
	}
	.pct-net-empty {
		flex: 1 1 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.2rem 0.7rem;
		color: var(--sl-color-gray-3);
		font-style: italic;
		font-size: 0.82rem;
	}
	.pct-net.is-clean .pct-net-empty {
		color: var(--pct-go);
		font-style: normal;
		font-weight: 600;
	}
	.pct-net-row {
		display: grid;
		grid-template-columns: 1fr 5rem 4rem;
		gap: 0.5rem;
		align-items: center;
		padding: 0.4rem 0.7rem;
		border-bottom: 1px solid var(--sl-color-hairline);
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 0.76rem;
		color: var(--sl-color-gray-2);
	}
	.pct-net-row:last-child {
		border-bottom: none;
	}
	.pct-net-name {
		color: var(--sl-color-white);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.pct-net-status {
		color: var(--pct-go);
	}
	/* The just-appeared analytics-shaped row — the whole point. */
	.pct-net-row.is-new {
		background: color-mix(in srgb, var(--pct-accent) 12%, var(--sl-color-bg));
		border-left: 3px solid var(--pct-accent);
		padding-left: calc(0.7rem - 3px);
	}
	.pct-net-row.is-new .pct-net-name {
		color: var(--pct-accent);
	}
	.pct-net-note {
		padding: 0.5rem 0.7rem;
		border-top: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		color: var(--sl-color-gray-2);
		font-size: 0.78rem;
	}

	/* Narrow screens: stack the spine labels tighter, drop the type column. */
	@media (max-width: 38rem) {
		.pct-node-label {
			font-size: 0.62rem;
		}
		.pct-net-cols {
			grid-template-columns: 1fr 4rem;
		}
		.pct-net-cols span:nth-child(2) {
			display: none;
		}
		.pct-net-row {
			grid-template-columns: 1fr 4rem;
		}
		.pct-net-type {
			display: none;
		}
	}
</style>
