---
// key-scope-ladder — Chapter 081 Lesson 2, "The abusable-endpoint matrix".
//
// The one principle behind every per-category key choice: the key is the
// smallest scope that contains the abuse without affecting legitimate use. The
// seven per-category strategies aren't seven rules — they're points the senior
// tunes to on ONE axis.
//
// Layout — four full-width bands stacked vertically, broadest scope at top,
// narrowest at the bottom. A subtle width taper plus a color gradient (cool/
// broad → warm/narrow) make "broad → narrow" read at a glance. Each band names
// its scope on the left and carries two callouts on the right: what abuse the
// scope CATCHES (green) and what legitimate traffic it RISKS tripping (amber).
// A vertical "broad → narrow" axis rail sits on the left of the stack.
//
// margin:0 resets defeat Starlight's injected prose margins; `not-content` opts
// the body out of prose styling. Band fills are saturated mid-tones with white
// text so they hold up in both light and dark themes.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";

type Band = {
	scope: string;
	hue: string; // band accent fill
	width: number; // % of the column — the taper
	catches: string;
	risks: string;
};

const bands: Band[] = [
	{
		scope: 'per-IP',
		hue: '#2563eb',
		width: 100,
		catches: 'anonymous floods, botnets sharing few addresses',
		risks: "whole offices and campuses behind one NAT'd address",
	},
	{
		scope: 'per-org',
		hue: '#0d9488',
		width: 88,
		catches: 'one tenant spending broadly — mail, storage, compute',
		risks: "a large customer's legitimate burst",
	},
	{
		scope: 'per-user',
		hue: '#ca8a04',
		width: 76,
		catches: 'one account abusing a metered or authed action',
		risks: "a power user's heavy-but-honest session",
	},
	{
		scope: 'per-resource',
		hue: '#dc2626',
		width: 64,
		catches: 'hammering one specific record',
		risks: 'nothing broad — but an attacker who rotates resources slips past',
	},
];

const ALT =
	'A vertical ladder of four key-scope bands, broadest at the top and narrowest at the bottom, along a "broad to narrow" axis. ' +
	'per-IP (broadest) catches anonymous floods and botnets sharing few addresses, but risks tripping whole offices and campuses behind one NAT address. ' +
	'per-org catches one tenant spending broadly on mail, storage, or compute, but risks tripping a large customer\'s legitimate burst. ' +
	'per-user catches one account abusing a metered or authed action, but risks tripping a power user\'s heavy-but-honest session. ' +
	'per-resource (narrowest) catches hammering one specific record and trips almost no legitimate traffic, but an attacker who rotates resources slips past it. ' +
	'The right key is the narrowest scope that still contains the abuse.';
---

<Figure caption="One axis, not seven rules: the key is the narrowest scope that still contains the abuse.">
	<div class="ksl not-content" role="img" aria-label={ALT}>
		<div class="ksl-axis" aria-hidden="true">
			<span class="ksl-axis-cap">broad</span>
			<span class="ksl-axis-line"></span>
			<span class="ksl-axis-cap">narrow</span>
		</div>

		<div class="ksl-stack">
			{
				bands.map((b) => (
					<div class="ksl-band" style={`width: ${b.width}%; --hue: ${b.hue};`}>
						<div class="ksl-scope">{b.scope}</div>
						<div class="ksl-callouts">
							<p class="ksl-callout ksl-catches">
								<span class="ksl-tag ksl-tag-catch">catches</span>
								{b.catches}
							</p>
							<p class="ksl-callout ksl-risks">
								<span class="ksl-tag ksl-tag-risk">risks tripping</span>
								{b.risks}
							</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</Figure>

<style define:vars={{ sans }}>
	.ksl {
		box-sizing: border-box;
		display: flex;
		align-items: stretch;
		gap: 14px;
		max-width: 640px;
		margin: 0 auto;
		padding: 8px 4px 4px;
		font-family: var(--sans);
		color: var(--sl-color-white);
	}

	.ksl :global(*) {
		margin: 0;
		box-sizing: border-box;
	}

	/* ── the "broad → narrow" axis rail down the left edge ── */
	.ksl-axis {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		padding-top: 4px;
		flex: 0 0 auto;
	}
	.ksl-axis-cap {
		font-size: 9.5px;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9aa3b1);
	}
	.ksl-axis-line {
		flex: 1;
		width: 2px;
		border-radius: 2px;
		background: linear-gradient(
			to bottom,
			color-mix(in srgb, #2563eb 70%, transparent),
			color-mix(in srgb, #dc2626 70%, transparent)
		);
	}

	/* ── the band stack ── */
	.ksl-stack {
		display: flex;
		flex: 1;
		min-width: 0;
		flex-direction: column;
		gap: 9px;
	}

	.ksl-band {
		display: flex;
		align-items: stretch;
		gap: 12px;
		padding: 9px 12px;
		border-radius: 10px;
		border: 1px solid color-mix(in srgb, var(--hue) 55%, transparent);
		background: color-mix(in srgb, var(--hue) 12%, var(--sl-color-bg-sidebar));
		/* taper anchors to the left so the axis rail aligns with every band top */
		align-self: flex-start;
	}

	.ksl-scope {
		display: flex;
		align-items: center;
		flex: 0 0 88px;
		padding: 4px 10px;
		border-radius: 7px;
		background: var(--hue);
		color: #fff;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.ksl-callouts {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		min-width: 0;
	}

	.ksl-callout {
		display: flex;
		align-items: baseline;
		gap: 7px;
		font-size: 12px;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #c0c7d1);
	}

	.ksl-tag {
		flex: 0 0 auto;
		padding: 1.5px 7px;
		border-radius: 999px;
		font-size: 9px;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		line-height: 1.5;
		white-space: nowrap;
	}
	.ksl-tag-catch {
		color: #fff;
		background: #16a34a;
	}
	.ksl-tag-risk {
		color: #fff;
		background: #d97706;
	}

	@media (max-width: 480px) {
		.ksl-band {
			flex-direction: column;
			gap: 7px;
			width: 100% !important;
		}
		.ksl-scope {
			flex: 0 0 auto;
			align-self: flex-start;
		}
	}
</style>
