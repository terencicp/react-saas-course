---
// header-enforcement-flow — Chapter 081 Lesson 1, "Headers that block live attacks".
//
// The lesson's foundational frame: a security header is a one-way instruction.
// The SERVER computes a policy string and attaches it to the response (policy
// *declared*); the BROWSER reads it and applies the rule to the page (policy
// *enforced*). The instruction only ever flows one direction. This figure makes
// that single arrow concrete — and makes the header tangible by rendering the
// middle box as a tiny mock of two real HTTP header lines riding on the response.
//
// Built with <ArrowDiagram> (LeaderLine) because the middle box is custom HTML
// (a stack of monospace header lines), which D2/Mermaid plain-label boxes can't
// render verbatim. The arrows are positioned from document.body, so the wrapping
// <Figure> MUST be expandable={false}: relocating the body into the lightbox
// breaks the leader lines.
//
// Sockets are right→left between the three boxes in one horizontal row. Two
// labels sit in the gaps; labelOffset lifts them above the wire. The "Browser"
// box carries an inline "policy enforced" badge so the enforcement step reads as
// happening *inside* the browser, not on a wire.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark). The accent
// (#0ea5e9 blue) is used as-is in both themes — a mid-tone that reads on either
// background. A margin:0 reset defeats Starlight's injected prose margins.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Mid-tone accent reused verbatim in light + dark.
const FLOW_BLUE = '#0ea5e9';

const arrows = [
	// Server attaches the header to the outgoing response.
	{
		from: 'flow-server',
		to: 'flow-response',
		label: 'attaches header',
		color: FLOW_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -34],
	},
	// The response carries the policy to the browser — declared, not yet enforced.
	{
		from: 'flow-response',
		to: 'flow-browser',
		label: 'policy declared',
		color: FLOW_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -34],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="hef not-content">
			<div class="hef-box" id="flow-server">
				<span class="hef-title">Server</span>
				<span class="hef-under">computes a policy string</span>
			</div>

			<div class="hef-box hef-response" id="flow-response">
				<span class="hef-under hef-response-tag">Response</span>
				<code class="hef-line">Content-Security-Policy: …</code>
				<code class="hef-line">Strict-Transport-Security: …</code>
			</div>

			<div class="hef-box hef-browser" id="flow-browser">
				<span class="hef-title">Browser</span>
				<span class="hef-badge">policy enforced</span>
				<span class="hef-under">applies the rule to the page</span>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		The header is a one-way instruction. The server declares the policy on the
		response; the browser is the only thing that enforces it.
	</Fragment>
</Figure>

<style>
	.hef {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: space-between;
		gap: clamp(48px, 9vw, 92px);
		margin: 0;
		padding: 16px 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.hef-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		flex: 0 1 auto;
		padding: 12px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	.hef-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.hef-under {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The middle box is a mock of the response itself: a small label plus two
	   real header lines, so the header reads as a string riding on the response. */
	.hef-response {
		align-items: flex-start;
		gap: 5px;
		padding: 12px 14px;
		border-style: dashed;
		text-align: left;
	}

	.hef-response-tag {
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: 0.6rem;
	}

	.hef-line {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.66rem;
		line-height: 1.25;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
		padding: 0;
		background: none;
		border: none;
	}

	/* The enforcement step happens *inside* the browser — the badge makes that
	   spatial, so the arrows only ever carry "declared", never "enforced". */
	.hef-browser {
		border-color: color-mix(in srgb, #0ea5e9 55%, var(--sl-color-gray-5, #cbd5e1));
	}

	.hef-badge {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.1;
		white-space: nowrap;
		color: #0369a1;
		background: color-mix(in srgb, #0ea5e9 16%, transparent);
		border: 1px solid color-mix(in srgb, #0ea5e9 45%, transparent);
		border-radius: 999px;
		padding: 2px 8px;
		margin: 1px 0 0;
	}

	:global([data-theme='dark']) .hef-badge {
		color: #7dd3fc;
	}

	/* Narrow viewports: stack the three boxes; the right→left sockets degrade to
	   vertical arcs between stacked boxes — readable, labels still float in gaps. */
	@media (max-width: 720px) {
		.hef {
			flex-direction: column;
			gap: 58px;
		}
		.hef-box {
			width: min(20rem, 100%);
		}
		.hef-response {
			align-items: center;
			text-align: center;
		}
	}
</style>
