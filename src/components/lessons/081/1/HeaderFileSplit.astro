---
// header-file-split — Chapter 081 Lesson 1, "Headers that block live attacks".
//
// The one-glance summary of the lesson's architectural spine: which file ships
// which header, and why. Two side-by-side cards.
//
//   next.config.ts — the five CONSTANT headers, computed once at build, identical
//                     on every response.
//   proxy.ts       — the single PER-REQUEST header (CSP), rebuilt every request
//                     because it carries a fresh nonce.
//
// Built as hand-authored HTML/CSS inside a <Figure> (no leader lines, so the
// default expandable lightbox is fine — the spec calls for a styled two-column
// layout, NOT an ArrowDiagram). The right card reuses the orange "per-request /
// nonce" accent the lesson uses for HSTS-guard and nonce emphasis; the left card
// stays in the neutral static/blue tone, so colour echoes the constant/dynamic
// split itself.
//
// A trailing note inside the proxy card makes the one wrinkle explicit:
// frame-ancestors is a DIRECTIVE inside this CSP string, not a separate header,
// so it physically rides in proxy.ts even though it does the X-Frame-Options job.
//
// Chrome is theme-aware via Starlight gray/bg/white vars; the two accents
// (#0ea5e9 blue, #f97316 orange) are mid-tones used verbatim in light + dark.
// margin:0 resets defeat Starlight's injected prose margins.

import Figure from '../../../figures/Figure.astro';

const configHeaders = [
	'Strict-Transport-Security',
	'X-Content-Type-Options',
	'Referrer-Policy',
	'Permissions-Policy',
	'X-Frame-Options',
];
---

<Figure caption="Constant headers ship from build-time config; the per-request CSP ships from the proxy because its nonce is regenerated on every request.">
	<div class="hfs not-content">
		<div class="hfs-card hfs-config">
			<div class="hfs-head">
				<code class="hfs-file">next.config.ts</code>
				<span class="hfs-sub">computed once at build · identical on every response</span>
			</div>
			<ul class="hfs-list">
				{configHeaders.map((h) => (
					<li class="hfs-item"><code>{h}</code></li>
				))}
			</ul>
		</div>

		<div class="hfs-card hfs-proxy">
			<div class="hfs-head">
				<code class="hfs-file">proxy.ts</code>
				<span class="hfs-sub">rebuilt per request · carries a fresh nonce</span>
			</div>
			<ul class="hfs-list">
				<li class="hfs-item">
					<code>Content-Security-Policy</code>
					<span class="hfs-tag">with the nonce</span>
				</li>
			</ul>
			<p class="hfs-note">
				<code>frame-ancestors</code> is a <em>directive inside</em> this CSP — not a
				separate header.
			</p>
		</div>
	</div>
</Figure>

<style>
	.hfs {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(16px, 3vw, 28px);
		margin: 0;
		padding: 6px 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.hfs-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 16px 18px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}

	/* Left = constant/static (blue); right = per-request/nonce (orange). The
	   colour echoes the build-time vs per-request split it's illustrating. */
	.hfs-config {
		border-top: 3px solid color-mix(in srgb, #0ea5e9 70%, var(--sl-color-gray-5, #cbd5e1));
	}

	.hfs-proxy {
		border-top: 3px solid color-mix(in srgb, #f97316 70%, var(--sl-color-gray-5, #cbd5e1));
	}

	.hfs-head {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding-bottom: 10px;
		border-bottom: 1px dashed var(--sl-color-gray-5, #cbd5e1);
	}

	.hfs-file {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: none;
		border: none;
		padding: 0;
		margin: 0;
	}

	.hfs-sub {
		font-size: 0.68rem;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.hfs-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 7px;
		margin: 0;
		padding: 0;
	}

	.hfs-item {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
		margin: 0;
		padding: 0;
	}

	.hfs-item code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.74rem;
		line-height: 1.3;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 30%, transparent);
		border-radius: 5px;
		padding: 2px 7px;
		margin: 0;
	}

	.hfs-tag {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.1;
		white-space: nowrap;
		color: #c2410c;
		background: color-mix(in srgb, #f97316 16%, transparent);
		border: 1px solid color-mix(in srgb, #f97316 45%, transparent);
		border-radius: 999px;
		padding: 2px 8px;
		margin: 0;
	}

	:global([data-theme='dark']) .hfs-tag {
		color: #fdba74;
	}

	.hfs-note {
		font-size: 0.7rem;
		line-height: 1.4;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.hfs-note code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.68rem;
		color: var(--sl-color-white, #1e293b);
		background: none;
		padding: 0;
	}

	/* Narrow viewports: stack the two cards. */
	@media (max-width: 640px) {
		.hfs {
			grid-template-columns: 1fr;
		}
	}
</style>
