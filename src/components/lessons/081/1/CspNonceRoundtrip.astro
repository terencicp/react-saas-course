---
// csp-nonce-roundtrip — Chapter 081 Lesson 1, "Headers that block live attacks".
//
// The pedagogical centerpiece. A five-step scrubbable DiagramSequence that walks
// ONE request through the nonce round trip and makes the lesson's one genuinely
// tricky idea spatial: it is the SAME token, in three places, regenerated every
// request. The literal value `abc123` is surfaced wherever the nonce currently
// lives, tinted the same green so its identity across stages is unmissable.
//
//   Stage row (constant every step): four labeled boxes joined by arrows —
//     Request -> proxy.ts -> Server Component -> Browser. The active box(es)
//     light up blue per step; the rest sit dim. Below the row, a fixed-shape
//     "detail" panel shows the artifact for that step (a code line, the two
//     outbound chips, the stamped <script>, or the allowed/blocked payoff).
//
//     Step 1  Request arrives at the proxy. No nonce exists yet.
//     Step 2  proxy.ts generates one random nonce -> `abc123` appears.
//     Step 3  proxy emits two things carrying the SAME nonce: the response CSP
//             and a forwarded `x-nonce` request header. Both green-tinted.
//     Step 4  a Server Component reads `x-nonce` via headers() and stamps it on
//             the inline <script> it renders.
//     Step 5  the payoff: browser compares. nonce matches -> allowed (green
//             check); injected <script> with no nonce -> refused (red cross).
//
// Style follows this chapter-arc's sibling sequences (StaleFrameSequence): a
// fixed slate palette with color-scheme pinned light so the hand-picked
// green/red/amber tints survive dark mode, and `margin: 0` on every inner
// element to defeat Starlight's injected prose margins. Every step is the same
// shape — stage row, then a same-height detail panel — so the grid stack never
// reflows as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const BORDER = '#cbd5e1'; // ordinary edge (slate-300)
const DIM_BG = '#f1f5f9'; // inactive stage-box wash (slate-100)
const DIM_INK = '#94a3b8'; // inactive stage-box ink (slate-400)
const PANEL_BG = '#f8fafc'; // detail panel wash (slate-50)
const CHIP_BG = '#ffffff'; // ordinary chip surface

const BLUE = '#2563eb'; // blue-600 — the active stage accent
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const GREEN = '#16a34a'; // green-600 — the nonce, and the allowed script
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const RED = '#dc2626'; // red-600 — the refused injected script
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all five steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 0; padding: 4px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The stage row: the four boxes joined by arrows. Wraps on narrow viewports.
const row = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 6px; margin: 0;`;

// A single stage box. `active` lights it up blue; otherwise it sits dim.
const box = (active: boolean) =>
	`display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; margin: 0; padding: 8px 12px; border-radius: 9px; min-width: 96px; ` +
	(active
		? `border: 1.5px solid ${BLUE}; background: ${BLUE_BG}; box-shadow: 0 1px 3px rgba(37, 99, 235, 0.25);`
		: `border: 1px solid ${BORDER}; background: ${DIM_BG};`);
const boxName = (active: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.15; white-space: nowrap; color: ${active ? BLUE_INK : DIM_INK};`;
const boxRole = (active: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; white-space: nowrap; color: ${active ? BLUE : DIM_INK};`;

// The little arrow between stage boxes.
const arrow = `display: flex; align-items: center; margin: 0; font-size: 13px; font-weight: 700; color: ${INK_SOFT};`;

// A green nonce chip that rides INSIDE a stage box (step 2).
const nonceBadge = `display: inline-flex; align-items: center; margin: 1px 0 0; padding: 1px 7px; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.3; color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN}; border-radius: 999px; white-space: nowrap;`;

// The detail panel below the row — fixed min-height so the stack never reflows.
const panel = `display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; margin: 0; padding: 12px; width: 100%; max-width: 460px; min-height: 96px; border: 1px solid ${BORDER}; border-radius: 12px; background: ${PANEL_BG};`;
const panelLabel = `align-self: flex-start; margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;

// A plain monospace code line inside the panel.
const codeLine = `margin: 0; font-family: ${mono}; font-size: 11.5px; font-weight: 600; line-height: 1.4; color: ${INK}; text-align: center; word-break: break-word;`;

// A labeled chip showing one emitted header — direction tag on the left, value
// (with a green nonce) on the right. `tone` picks request vs response accent.
const headerChip = `display: flex; flex-direction: column; gap: 3px; margin: 0; padding: 8px 10px; width: 100%; border-radius: 9px; background: ${CHIP_BG}; border: 1px solid ${BORDER};`;
const chipTag = (tone: string) =>
	`display: inline-block; align-self: flex-start; margin: 0; padding: 1px 6px; font-family: ${mono}; font-size: 8.5px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #ffffff; background: ${tone}; border-radius: 4px;`;
const chipValue = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; line-height: 1.4; color: ${INK}; word-break: break-word;`;
const tokenInk = `color: ${GREEN_INK}; font-weight: 800; background: ${GREEN_BG}; border-radius: 3px; padding: 0 2px;`;

// A verdict row in the payoff step: a script line plus an allowed/blocked pill.
const verdictRow = (ok: boolean) =>
	`display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 10px; width: 100%; border-radius: 8px; ` +
	(ok
		? `background: ${GREEN_BG}; border: 1px solid ${GREEN};`
		: `background: ${RED_BG}; border: 1px solid ${RED};`);
const verdictScript = (ok: boolean) =>
	`flex: 1 1 auto; margin: 0; font-family: ${mono}; font-size: 10.5px; font-weight: 600; line-height: 1.3; color: ${ok ? GREEN_INK : RED_INK}; word-break: break-word;`;
const verdictPill = (ok: boolean) =>
	`display: inline-flex; flex: 0 0 auto; align-items: center; gap: 3px; margin: 0; padding: 1px 8px; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.4; border-radius: 999px; white-space: nowrap; ` +
	(ok
		? `color: ${GREEN_INK}; background: #ffffff; border: 1px solid ${GREEN};`
		: `color: ${RED_INK}; background: #ffffff; border: 1px solid ${RED};`);
---

<DiagramSequence>
	{/* ---- Step 1: request arrives, no nonce yet ---- */}
	<DiagramStep caption="A request arrives at the proxy. No nonce exists yet.">
		<div style={stage}>
			<div style={row}>
				<div style={box(true)}>
					<span style={boxRole(true)}>incoming</span>
					<span style={boxName(true)}>Request</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(true)}>
					<span style={boxRole(true)}>request gate</span>
					<span style={boxName(true)}>proxy.ts</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>renders</span>
					<span style={boxName(false)}>Server Component</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>enforces</span>
					<span style={boxName(false)}>Browser</span>
				</div>
			</div>
			<div style={panel}>
				<span style={panelLabel}>at the gate</span>
				<p style={codeLine}>A bare request hits <strong>proxy.ts</strong> — no token attached anywhere.</p>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: proxy generates one random nonce ---- */}
	<DiagramStep caption="The proxy generates one random nonce for this request.">
		<div style={stage}>
			<div style={row}>
				<div style={box(false)}>
					<span style={boxRole(false)}>incoming</span>
					<span style={boxName(false)}>Request</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(true)}>
					<span style={boxRole(true)}>request gate</span>
					<span style={boxName(true)}>proxy.ts</span>
					<span style={nonceBadge}>nonce = abc123</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>renders</span>
					<span style={boxName(false)}>Server Component</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>enforces</span>
					<span style={boxName(false)}>Browser</span>
				</div>
			</div>
			<div style={panel}>
				<span style={panelLabel}>one fresh token, per request</span>
				<p style={codeLine}>Buffer.from(crypto.randomUUID()).toString('base64')</p>
				<p style={codeLine}>&rarr; <span style={tokenInk}>abc123</span> <span style={`font-family:${sans};font-size:10px;color:${INK_SOFT};font-weight:600;`}>(illustrative value)</span></p>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: proxy emits the CSP and the forwarded x-nonce ---- */}
	<DiagramStep caption="The proxy sets two things: the nonce inside the response CSP, and a forwarded x-nonce request header.">
		<div style={stage}>
			<div style={row}>
				<div style={box(false)}>
					<span style={boxRole(false)}>incoming</span>
					<span style={boxName(false)}>Request</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(true)}>
					<span style={boxRole(true)}>request gate</span>
					<span style={boxName(true)}>proxy.ts</span>
					<span style={nonceBadge}>nonce = abc123</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>renders</span>
					<span style={boxName(false)}>Server Component</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>enforces</span>
					<span style={boxName(false)}>Browser</span>
				</div>
			</div>
			<div style={panel}>
				<span style={panelLabel}>same token, two directions</span>
				<div style={headerChip}>
					<span style={chipTag(BLUE)}>response header &rarr; browser</span>
					<p style={chipValue}>Content-Security-Policy: … script-src 'self' '<span style={tokenInk}>nonce-abc123</span>' …</p>
				</div>
				<div style={headerChip}>
					<span style={chipTag(GREEN_INK)}>request header &rarr; app</span>
					<p style={chipValue}>x-nonce: <span style={tokenInk}>abc123</span></p>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Server Component reads x-nonce and stamps the script ---- */}
	<DiagramStep caption="A Server Component reads x-nonce via headers() and stamps it on the inline scripts it renders.">
		<div style={stage}>
			<div style={row}>
				<div style={box(false)}>
					<span style={boxRole(false)}>incoming</span>
					<span style={boxName(false)}>Request</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>request gate</span>
					<span style={boxName(false)}>proxy.ts</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(true)}>
					<span style={boxRole(true)}>renders</span>
					<span style={boxName(true)}>Server Component</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>enforces</span>
					<span style={boxName(false)}>Browser</span>
				</div>
			</div>
			<div style={panel}>
				<span style={panelLabel}>reads the token, stamps the script</span>
				<p style={codeLine}>const nonce = (await headers()).get('x-nonce')&nbsp;&rarr;&nbsp;<span style={tokenInk}>abc123</span></p>
				<div style={headerChip}>
					<span style={chipTag(GREEN_INK)}>rendered markup</span>
					<p style={chipValue}>&lt;script nonce="<span style={tokenInk}>abc123</span>"&gt;…&lt;/script&gt;</p>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 5: payoff — browser compares, allows vs refuses ---- */}
	<DiagramStep caption="The browser compares. Nonce matches → the script runs. An injected script with no nonce → refused.">
		<div style={stage}>
			<div style={row}>
				<div style={box(false)}>
					<span style={boxRole(false)}>incoming</span>
					<span style={boxName(false)}>Request</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>request gate</span>
					<span style={boxName(false)}>proxy.ts</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(false)}>
					<span style={boxRole(false)}>renders</span>
					<span style={boxName(false)}>Server Component</span>
				</div>
				<span style={arrow} aria-hidden="true">&rarr;</span>
				<div style={box(true)}>
					<span style={boxRole(true)}>enforces</span>
					<span style={boxName(true)}>Browser</span>
				</div>
			</div>
			<div style={panel}>
				<span style={panelLabel}>CSP lists 'nonce-abc123' — match or refuse</span>
				<div style={verdictRow(true)}>
					<p style={verdictScript(true)}>&lt;script nonce="<span style={tokenInk}>abc123</span>"&gt;…&lt;/script&gt;</p>
					<span style={verdictPill(true)}>&#10003; runs</span>
				</div>
				<div style={verdictRow(false)}>
					<p style={verdictScript(false)}>&lt;script&gt;stealCookies()&lt;/script&gt;</p>
					<span style={verdictPill(false)}>&#10007; refused</span>
				</div>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
