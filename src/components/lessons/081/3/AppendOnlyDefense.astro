---
// AppendOnlyDefense — Chapter 081 Lesson 3 ("What belongs in the audit log").
//
// Re-anchors the append-only guarantee through the audit-pass lens: three
// INDEPENDENT layers wrapping the auditLogs table, and ONE deliberate arrow
// piercing all three from the side — the privileged owner-role write that
// retention / legal retraction uses (next lesson). The point is spatial: the
// exception is ARCHITECTED (it comes in cleanly through every layer as its own
// route), not a hole in any one wall.
//
//   ┌─ App discipline (outermost) ────────────────────────────┐
//   │  ┌─ RLS policy ───────────────────────────────────────┐ │
//   │  │  ┌─ Column shape ──────────────────────────────┐   │ │
//   │  │  │            ┌──────────────┐                  │←──┼─┼── owner role
//   │  │  │            │  auditLogs   │ ◀════════════════╪═══╪═╪══  (retention /
//   │  │  │            │ append-only  │                  │   │ │    legal only)
//   │  │  │            └──────────────┘                  │   │ │
//   │  │  └─────────────────────────────────────────────┘   │ │
//   │  └────────────────────────────────────────────────────┘ │
//   └─────────────────────────────────────────────────────────┘
//
// The three layers run outer→inner in the prose's "what the app sees first"
// order: discipline (the app never asks) wraps the DB policy (the DB refuses)
// wraps the column shape (nothing to mutate) wraps the table. The owner-role
// arrow is the one element coloured AMBER — distinct from the cool layer chrome
// — and it crosses every border to read as a sanctioned, separate route.
//
// Pure HTML+CSS per the diagrams guide (nested hierarchy + a colour-coded
// callout arrow — the html-css.md sweet spot, devtools-inspectable). Modeled on
// this chapter family's 080/3 DefenseInDepthRings. `not-content` + a margin:0
// reset on every node defeats Starlight's injected prose margins. Goes inside
// <Figure>, supplied here with its caption.
//
// Colour language: cool neutral greys/blues for the three equal, independent
// layers (no layer is "the strong one" — that's the whole belt-and-suspenders
// point); AMBER (#d97706) for the single owner-role exception; the central
// table gets a solid sidebar fill so it reads as the protected core.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const AMBER = '#d97706'; // the one deliberate exception — the owner-role write

// Three independent layers, outermost → innermost (table is the core).
const layers = [
	{
		num: '3',
		title: 'App discipline',
		desc: 'only logAudit() inserts',
		note: 'the application never asks',
	},
	{
		num: '2',
		title: 'RLS policy',
		desc: 'USING (false) denies UPDATE / DELETE',
		note: 'the database refuses',
	},
	{
		num: '1',
		title: 'Column shape',
		desc: 'no updatedAt / deletedAt',
		note: 'nothing to mutate',
	},
];

const ALT =
	'Three concentric boxes wrapping a central auditLogs table. The outermost layer is App discipline — only logAudit() inserts, the application never asks. Inside it, the RLS policy layer — USING (false) denies UPDATE and DELETE, the database refuses. Inside that, the Column shape layer — no updatedAt or deletedAt, nothing to mutate. At the centre sits the append-only auditLogs table. One amber arrow enters from the side and pierces all three layers to reach the table, labelled "owner role — retention / legal only (next lesson)": the single architected exception, a separate privileged credential that runs outside the application policy.';
---

<Figure
	caption="Three independent layers, and one deliberate exception — the owner-role write is architected, not a gap."
>
	<div class="aod not-content" role="img" aria-label={ALT}>
		{/* Nested layers: outer → inner, the table at the core. */}
		<div class="aod-layer aod-layer--3">
			<span class="aod-legend">
				<span class="aod-num">layer 3</span>
				<span class="aod-title">App discipline</span>
				<code class="aod-desc">only logAudit() inserts</code>
				<span class="aod-note">the application never asks</span>
			</span>

			<div class="aod-layer aod-layer--2">
				<span class="aod-legend">
					<span class="aod-num">layer 2</span>
					<span class="aod-title">RLS policy</span>
					<code class="aod-desc">USING (false) denies UPDATE / DELETE</code>
					<span class="aod-note">the database refuses</span>
				</span>

				<div class="aod-layer aod-layer--1">
					<span class="aod-legend">
						<span class="aod-num">layer 1</span>
						<span class="aod-title">Column shape</span>
						<code class="aod-desc">no updatedAt / deletedAt</code>
						<span class="aod-note">nothing to mutate</span>
					</span>

					<div class="aod-core">
						<span class="aod-core-name">auditLogs</span>
						<span class="aod-core-tag">append-only</span>
					</div>
				</div>
			</div>
		</div>

		{/* The one sanctioned exception: a separate route that pierces all three. */}
		<div class="aod-pierce" aria-hidden="true">
			<span class="aod-pierce-line"></span>
			<span class="aod-pierce-head"></span>
		</div>
		<div class="aod-pierce-label">
			<span class="aod-pierce-role">owner role</span>
			<span class="aod-pierce-sub">retention / legal only</span>
			<span class="aod-pierce-fwd">(next lesson)</span>
		</div>
	</div>
</Figure>

<style define:vars={{ AMBER, sans, mono }}>
	.aod {
		position: relative;
		box-sizing: border-box;
		max-width: 620px;
		margin: 0 auto;
		padding: 18px 6px 8px;
		font-family: var(--sans);
		color: var(--sl-color-white);
	}

	.aod :global(*) {
		margin: 0;
		box-sizing: border-box;
	}

	/* ── The nested layers ─────────────────────────────────────────────── */
	.aod-layer {
		position: relative;
		border-radius: 16px;
		padding: 30px 18px 18px;
	}

	/* Outermost (3) → innermost (1): cool, equal-weight chrome. Each step
	   tightens the tint a touch so the nesting reads, but no layer dominates. */
	.aod-layer--3 {
		border: 1.5px solid var(--sl-color-gray-5, #353c4a);
		background: color-mix(in srgb, var(--sl-color-gray-6, #1a1f29) 35%, transparent);
	}
	.aod-layer--2 {
		border: 1.5px solid var(--sl-color-gray-4, #4d5666);
		background: color-mix(in srgb, var(--sl-color-gray-6, #1a1f29) 55%, transparent);
		margin-top: 14px;
	}
	.aod-layer--1 {
		border: 1.5px solid var(--sl-color-gray-3, #9aa3b1);
		background: color-mix(in srgb, var(--sl-color-gray-5, #353c4a) 45%, transparent);
		margin-top: 14px;
	}

	/* ── "Fieldset legend" pill straddling each layer's top border ─────── */
	.aod-legend {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 4px 9px;
		width: fit-content;
		max-width: calc(100% - 8px);
		margin-top: -42px;
		margin-left: 4px;
		padding: 4px 12px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-5, #353c4a);
		background: var(--sl-color-bg-sidebar);
		line-height: 1.3;
	}

	.aod-num {
		flex: 0 0 auto;
		font-size: 9.5px;
		font-weight: 800;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 1.5px 7px;
		border-radius: 999px;
		color: #fff;
		background: var(--sl-color-gray-3, #9aa3b1);
		line-height: 1.4;
	}

	.aod-title {
		font-size: 13px;
		font-weight: 700;
		color: var(--sl-color-white);
		white-space: nowrap;
	}

	.aod-desc {
		font-family: var(--mono);
		font-size: 11.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #c0c7d1);
		background: transparent;
		padding: 0;
		white-space: nowrap;
	}

	.aod-note {
		font-size: 10.5px;
		font-style: italic;
		color: var(--sl-color-gray-3, #9aa3b1);
		white-space: nowrap;
	}

	/* ── The protected core: the table itself ──────────────────────────── */
	.aod-core {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		width: fit-content;
		margin: 4px auto 2px;
		padding: 12px 30px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-4, #4d5666);
		background: var(--sl-color-bg-sidebar);
		box-shadow: 0 1px 0 var(--sl-color-gray-6, #1a1f29);
	}
	.aod-core-name {
		font-family: var(--mono);
		font-size: 15px;
		font-weight: 800;
		letter-spacing: 0.01em;
		color: var(--sl-color-white);
	}
	.aod-core-tag {
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9aa3b1);
	}

	/* ── The piercing arrow: the one sanctioned owner-role write ───────── */
	/* Centred vertically on the core, entering from the right edge and running
	   left into the table — crossing all three layer borders on the way. */
	.aod-pierce {
		position: absolute;
		/* Aligned a little below the box centre so the head meets the core's
		   vertical middle, not the gap above it. */
		top: 58%;
		right: 4px;
		/* Reaches from the right edge to the centre core. */
		left: 50%;
		transform: translateY(-50%);
		display: flex;
		align-items: center;
		pointer-events: none;
		z-index: 3;
	}
	.aod-pierce-line {
		flex: 1 1 auto;
		height: 0;
		border-top: 3px dashed var(--AMBER);
	}
	/* A left-pointing arrowhead at the table end. */
	.aod-pierce-head {
		flex: 0 0 auto;
		width: 0;
		height: 0;
		margin-left: -2px;
		border-top: 7px solid transparent;
		border-bottom: 7px solid transparent;
		border-right: 11px solid var(--AMBER);
		order: -1;
	}

	.aod-pierce-label {
		position: absolute;
		top: calc(58% + 16px);
		right: 4px;
		z-index: 3;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 1px;
		padding: 5px 10px;
		border-radius: 9px;
		border: 1px solid color-mix(in srgb, var(--AMBER) 60%, transparent);
		background: color-mix(in srgb, var(--AMBER) 12%, var(--sl-color-bg-sidebar));
		text-align: right;
	}
	.aod-pierce-role {
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 800;
		color: var(--AMBER);
		white-space: nowrap;
	}
	.aod-pierce-sub {
		font-size: 10.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #c0c7d1);
		white-space: nowrap;
	}
	.aod-pierce-fwd {
		font-size: 9.5px;
		font-style: italic;
		color: var(--sl-color-gray-3, #9aa3b1);
		white-space: nowrap;
	}

	/* Narrow viewports: the side-entering arrow has no room. Drop it to a
	   top-down pierce and let the label sit above, still amber and distinct. */
	@media (max-width: 560px) {
		.aod {
			padding-top: 104px;
		}
		.aod-pierce {
			top: 78px;
			bottom: auto;
			left: 50%;
			right: auto;
			width: 0;
			height: 26px;
			transform: none;
			flex-direction: column;
		}
		.aod-pierce-line {
			width: 0;
			height: auto;
			flex: 1 1 auto;
			border-top: 0;
			border-left: 3px dashed var(--AMBER);
		}
		.aod-pierce-head {
			margin-left: 0;
			margin-top: -2px;
			border-left: 7px solid transparent;
			border-right: 7px solid transparent;
			border-top: 11px solid var(--AMBER);
			border-bottom: 0;
			order: 0;
		}
		.aod-pierce-label {
			top: 4px;
			right: auto;
			left: 50%;
			transform: translateX(-50%);
			align-items: center;
			text-align: center;
		}
	}
</style>
