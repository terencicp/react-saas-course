---
// KillChain — Chapter 081 Lesson 8 ("Supply-chain defaults after Shai-Hulud"),
// the centerpiece of the "How a supply-chain attack actually runs" section.
//
// Pedagogical goal: make the threat legible BEFORE any defense, and make ONE
// fact unmissable — the attacker's code executes at INSTALL time (stage 3,
// `postinstall`), after resolution and before a single line of the student's
// code runs or any test fires. That timing is the whole reason the lesson exists
// as its own thing: the commit-time gate (Gitleaks, L6) and the runtime gate
// (env schema, L7) are nowhere near this blast radius.
//
// Structure mirrors the chapter/course family strip grammar (049/1 render-
// pipeline, 080/1 webhook-seam, 081/4 DeletionJobWalk): a stable horizontal row
// of five labeled nodes inside each <DiagramStep>, generated once from a data
// array so only `active` changes frame-to-frame. The current stage is lit
// (`is-on`), stages already crossed are dimmed (`is-done`), and SVG connectors
// light as they're crossed. The accent is RED — this is a threat walk, not a
// happy path.
//
// Under the strip, a single "machine" indicator (the student's laptop + CI)
// flips from quiet to EXECUTING the moment the `postinstall` stage lights at
// step 3, and stays hot for the exfiltration + self-replication stages. The
// indicator is the spatial proof of "their code is already running on your
// machine" — the sentence the rest of the lesson is footnotes to.
//
// Pure HTML + CSS per the diagrams guide (a sequential phase strip, not a
// graph). `not-content` + margin:0 reset Starlight's injected prose chrome;
// theme-aware color-mix accents read on light and dark. DiagramSequence supplies
// the outer card + per-step captions, so this is NOT wrapped in <Figure>.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

type Stage = {
	/** Short node headline. */
	label: string;
	/** One-line mechanism under the headline. */
	sub: string;
	/** Does the attacker's code RUN on the student's machine at this stage? */
	executing: boolean;
	/** One-line readout for the "machine" indicator panel under the strip. */
	machine: string;
	/** The rich per-step caption (HTML). */
	caption: string;
};

// The five stages of the typosquat-to-exfiltration kill chain, in order. Code
// execution starts at index 2 (`postinstall`) and stays on from there.
const stages: Stage[] = [
	{
		label: "Publish",
		sub: "registry",
		executing: false,
		machine: "Nothing on your machine yet — the package is live on the registry, minutes old.",
		caption:
			"<strong>Publish.</strong> The attacker publishes the malicious version — a typosquat name (<code>axois</code> for <code>axios</code>), or a hijacked patch pushed to a <em>real</em> package with a phished maintainer token. It's now live on the registry, minutes old.",
	},
	{
		label: "Resolve",
		sub: "pnpm install",
		executing: false,
		machine: "Resolution runs. Still no foreign code executing — pnpm is just picking a version.",
		caption:
			"<strong>Resolve.</strong> You — or an AI agent writing a <code>package.json</code> — run <code>pnpm install</code>. Resolution picks the brand-new version because it satisfies the range. <em>Broken later by the 24-hour quarantine.</em>",
	},
	{
		label: "postinstall",
		sub: "runs unsandboxed",
		executing: true,
		machine: "The attacker's code is now running — full filesystem + network access, on your laptop and in CI.",
		caption:
			"<strong><code>postinstall</code> runs.</strong> The package's <code>postinstall</code> script runs <em>automatically</em> during install — on your laptop and in CI — with full filesystem and network access. <strong>No code of yours has run yet.</strong> <em>Broken later by the install-script gate.</em>",
	},
	{
		label: "Exfiltrate",
		sub: "secrets leave",
		executing: true,
		machine: "Still executing — it's reading files and opening connections off the machine.",
		caption:
			"<strong>Exfiltrate.</strong> The script reads <code>.env.local</code> and CI secrets and ships them off the machine.",
	},
	{
		label: "Self-replicate",
		sub: "the worm",
		executing: true,
		machine: "Still executing — using your stolen token to publish itself elsewhere.",
		caption:
			"<strong>Self-replicate.</strong> The Shai-Hulud variant goes further: it uses the stolen npm token to re-publish itself into other packages the victim maintains. That's the worm.",
	},
];

const ACCENT = "#dc2626"; // red-600 — this is a threat walk, not a happy path
---

<DiagramSequence>
	{
		stages.map((stage, active) => (
			<DiagramStep>
				<div class="kc not-content">
					<div
						class="kc-strip"
						role="img"
						aria-label="A supply-chain kill chain in five stages: Publish, Resolve, postinstall runs, Exfiltrate, Self-replicate. Active stage highlighted; the postinstall stage onward executes attacker code on your machine."
					>
						{stages.map((node, i) => {
							const isOn = i === active;
							const isDone = i < active;
							return (
								<>
									<div class:list={["kc-node", { "is-on": isOn, "is-done": isDone }]}>
										<span class="kc-node-label">{node.label}</span>
										<span class="kc-node-sub">{node.sub}</span>
									</div>
									{i < stages.length - 1 && (
										<span class:list={["kc-arrow", { "is-on": i < active }]} aria-hidden="true">
											<svg
												viewBox="0 0 34 14"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<line x1="1" y1="7" x2="26" y2="7" />
												<polyline points="21 2.5 27.5 7 21 11.5" />
											</svg>
										</span>
									)}
								</>
							);
						})}
					</div>

					{/* The "machine" indicator: quiet until `postinstall`, then EXECUTING. */}
					<div class:list={["kc-machine", { "is-executing": stage.executing }]}>
						<span class="kc-machine-icon" aria-hidden="true">
							{stage.executing ? (
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="2" width="12" height="12" rx="2" />
									<polyline points="5 6 7 8 5 10" />
									<line x1="9" y1="10" x2="11.5" y2="10" />
								</svg>
							) : (
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="2" width="12" height="12" rx="2" />
									<line x1="5" y1="13" x2="11" y2="13" />
									<line x1="8" y1="10.5" x2="8" y2="13" />
								</svg>
							)}
						</span>
						<span class="kc-machine-text">
							<span class="kc-machine-state">
								{stage.executing ? "Your laptop + CI — EXECUTING attacker code" : "Your laptop + CI — quiet"}
							</span>
							<span class="kc-machine-note">{stage.machine}</span>
						</span>
					</div>
				</div>
				<Fragment slot="caption" set:html={stage.caption} />
			</DiagramStep>
		))
	}
</DiagramSequence>

<style define:vars={{ accent: ACCENT }}>
	.kc {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* The horizontal kill-chain strip. Wraps (never scrolls) on narrow viewports. */
	.kc-strip {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
	}

	.kc-node {
		margin: 0;
		flex: 1 1 0;
		min-width: 110px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		padding: 11px 10px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s,
			opacity 0.14s;
	}
	/* Stages already crossed: tinted but receded — a path already walked. */
	.kc-node.is-done {
		border-color: color-mix(in srgb, var(--accent) 30%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--accent) 6%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 42%, var(--sl-color-gray-3));
		opacity: 0.8;
	}
	.kc-node.is-on {
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
		opacity: 1;
	}

	.kc-node-label {
		margin: 0;
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.2;
	}
	.kc-node-sub {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.2;
		opacity: 0.9;
	}

	/* Connectors between stages. Edges already crossed light up so the strip reads
	   as the attack moving through, not a static row. */
	.kc-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.kc-arrow.is-on {
		color: var(--accent);
	}
	.kc-arrow svg {
		width: 26px;
		height: 13px;
	}

	/* The "machine" indicator under the strip — the spatial proof of WHEN the
	   attacker's code runs. Quiet (neutral) until `postinstall`, then it flips to
	   EXECUTING (red) and holds. Fixed min-height so every frame matches and the
	   grid-stacked sequence never changes height between steps. */
	.kc-machine {
		margin: 0;
		box-sizing: border-box;
		min-height: 72px;
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 12px 16px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-2);
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s;
	}
	.kc-machine.is-executing {
		border: 1px solid var(--accent);
		border-style: solid;
		background: color-mix(in srgb, var(--accent) 9%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 70%, var(--sl-color-text));
	}

	.kc-machine-icon {
		flex: 0 0 auto;
		display: inline-flex;
		width: 28px;
		height: 28px;
		align-items: center;
		justify-content: center;
		border-radius: 7px;
		background: var(--sl-color-gray-5);
		color: var(--sl-color-gray-2);
	}
	.kc-machine-icon svg {
		width: 17px;
		height: 17px;
	}
	.kc-machine.is-executing .kc-machine-icon {
		background: var(--accent);
		color: #fff;
	}

	.kc-machine-text {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}
	.kc-machine-state {
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		line-height: 1.2;
	}
	.kc-machine-note {
		font-size: 13px;
		line-height: 1.35;
		color: var(--sl-color-gray-3);
	}
	.kc-machine.is-executing .kc-machine-note {
		color: color-mix(in srgb, var(--accent) 55%, var(--sl-color-gray-2));
	}

	/* On the narrowest viewports the stages stack; rotate the connectors so the
	   flow still reads top-to-bottom. */
	@media (max-width: 640px) {
		.kc-strip {
			flex-direction: column;
			align-items: stretch;
		}
		.kc-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
