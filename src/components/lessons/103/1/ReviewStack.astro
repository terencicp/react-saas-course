---
// The review stack -- five severity bands, top (highest stakes) to bottom.
//
// The whole teach is the ORDER, so all five bands must be visible at once (NOT a
// DiagramSequence). Severity is encoded pre-attentively by a hot->cool fill ramp:
// layer 1 a hot red, layer 5 a muted slate, with orange/amber/teal between. The
// eye reads the gradient as "spend attention from the top" before reading a word.
//
// Each band is a flex row: a LEFT zone with a big layer number + bold name, and a
// RIGHT zone with a one-phrase "what a miss costs" in lighter, smaller text. White
// text on the four saturated bands; the muted bottom band keeps dark theme text.
// Tiny "attention first / last" markers cap the stack so the gradient's meaning is
// explicit, not just implied.
//
// Pure HTML + CSS in the chapter's house style: a `not-content` wrapper, style
// arrays joined with "; ", and a `margin: 0` reset on EVERY inner element to defeat
// Starlight's prose-margin selector. `box-sizing: border-box` throughout; the whole
// stack is compressed vertically (small per-band padding) to stay well under 800px.
//
// Non-ASCII glyphs use \u escapes (en-dash –, arrows ↑/↓, middot
// ·) so the on-disk source is pure ASCII -- the dev-server transform was seen
// to mojibake literal multi-byte UTF-8 in this file.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const NDASH = "–"; // en-dash for the "#1-#7" / "#1-#15" ranges

// One band per layer. `fill` carries the severity signal; `text` is the on-fill
// color (white on the saturated bands, a dark theme gray on the muted bottom one).
// `light` is true for the bottom band only, where dark text reads better.
const bands = [
  {
    n: 1,
    name: "Correctness & security",
    cost: "Cross-tenant leak, double-charge, breach",
    fill: "#dc2626", // red-600 -- a miss here is a breach
    light: false,
  },
  {
    n: 2,
    name: `Architectural principles (#1${NDASH}#7)`,
    cost: "Structure rots; the next change costs double",
    fill: "#ea580c", // orange-600
    light: false,
  },
  {
    n: 3,
    name: `SaaS patterns (#1${NDASH}#15)`,
    cost: "An invariant the codebase bought, re-broken",
    fill: "#d97706", // amber-600
    light: false,
  },
  {
    n: 4,
    name: "Tests & contract integrity",
    cost: "A test that passes while the behavior is broken",
    fill: "#0d9488", // teal-600
    light: false,
  },
  {
    n: 5,
    name: "Style & naming polish",
    cost: "A confusing name, fixed later",
    fill: "#64748b", // slate-500 -- last; the cheapest miss
    light: false,
  },
];

// Caps: an arrow + label at each end so the hot->cool ramp's direction is stated.
const capTop = `↑ Attention first · severity high`;
const capBottom = `↓ Attention last · severity low`;

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 6px",
  "width: 100%",
  "max-width: 720px",
  "margin-left: auto",
  "margin-right: auto",
  sans,
  "box-sizing: border-box",
].join("; ");

const cap = (align: "start" | "end") =>
  [
    reset,
    sans,
    "display: flex",
    "align-items: center",
    "gap: 6px",
    "align-self: " + (align === "start" ? "flex-start" : "flex-end"),
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.06em",
    "text-transform: uppercase",
    "color: var(--sl-color-gray-3)",
    "line-height: 1",
  ].join("; ");

const band = (fill: string, light: boolean) =>
  [
    reset,
    "display: flex",
    "flex-wrap: wrap",
    "align-items: center",
    "column-gap: 14px",
    "row-gap: 2px",
    "padding: 11px 16px",
    "border-radius: 9px",
    "background: " + fill,
    "color: " + (light ? "#0f172a" : "var(--sl-color-white)"),
    "box-sizing: border-box",
  ].join("; ");

// Left zone: big number + bold name, kept together so they wrap as a unit.
const leftZone = [
  reset,
  "display: flex",
  "align-items: baseline",
  "gap: 11px",
  "flex: 1 1 270px",
  "min-width: 0",
].join("; ");

const number = (light: boolean) =>
  [
    reset,
    sans,
    "font-size: 30px",
    "font-weight: 800",
    "line-height: 1",
    "letter-spacing: -0.02em",
    "flex: 0 0 auto",
    "opacity: " + (light ? "0.85" : "0.92"),
  ].join("; ");

const nameStyle = [
  reset,
  sans,
  "font-size: 15px",
  "font-weight: 700",
  "line-height: 1.2",
].join("; ");

// Right zone: the "what a miss costs" phrase, lighter + smaller, allowed to wrap
// within its own zone on narrow widths.
const costStyle = (light: boolean) =>
  [
    reset,
    sans,
    "flex: 1 1 230px",
    "min-width: 0",
    "font-size: 13px",
    "font-weight: 500",
    "line-height: 1.25",
    "text-align: right",
    "color: " + (light ? "#334155" : "rgba(255, 255, 255, 0.88)"),
  ].join("; ");
---

<div class="not-content" style={root}>
  <div style={cap("start")}>{capTop}</div>
  {
    bands.map((b) => (
      <div style={band(b.fill, b.light)}>
        <div style={leftZone}>
          <span style={number(b.light)}>{b.n}</span>
          <span style={nameStyle}>{b.name}</span>
        </div>
        <div style={costStyle(b.light)}>{b.cost}</div>
      </div>
    ))
  }
  <div style={cap("end")}>{capBottom}</div>
</div>
