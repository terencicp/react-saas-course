---
// ReviewInboxMock — Chapter 103 Lesson 2 ("The comment that lands"), the spine
// figure for the "A comment is a message with a severity header" section.
//
// Pedagogical goal: make the core mental model literal in one glance — the
// author triages a review comment on its FIRST TOKEN, the severity pill, before
// reading a word of the body. To stage that, the four severity pills are the
// only thing with colour and contrast; the comment bodies are deliberately
// muted, lorem-style, truncated placeholder so the eye slides off them. The
// reader is not meant to read the bodies. That's the point.
//
// Plain HTML + CSS per the diagram index's "color-coded segments" row, and the
// lesson's explicit ask for a devtools-inspectable hand-built mock. Inline
// style strings on every primitive so a reader can copy the source and see
// exactly what styled it. `margin: 0` on every element defeats Starlight's
// injected prose margin-top (otherwise it shifts/shrinks later rows in the
// stack); `not-content` on the root does the same for the article-level reset.
//
// Each pill is a saturated mid-tone (Tailwind 600-range) with white text so the
// colour itself carries the signal and the contrast holds in both themes. The
// `question:` pill is a neutral slate — it deliberately reads as "no verdict",
// which matches its meaning. Pills share a fixed width so they form a clean
// left column: a literal "header" the eye scans top-to-bottom.

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const reset = "margin: 0";

type Row = {
  /** The severity label, with trailing colon, exactly as the course uses it. */
  label: string;
  /** Saturated fill (Tailwind 600-range) for the pill. */
  color: string;
};

// Top-to-bottom in the lesson's prescribed order: blocking (red), suggestion
// (blue), question (slate/grey — "no verdict"), praise (green).
const rows: Row[] = [
  { label: "blocking:", color: "#dc2626" },
  { label: "suggestion:", color: "#2563eb" },
  { label: "question:", color: "#64748b" },
  { label: "praise:", color: "#16a34a" },
];

// Muted lorem-style body lines — one per row, varied length so the truncation
// reads as real comment bodies. The reader is NOT meant to parse these; they
// exist only to be greyed out next to the pill they belong to.
const bodies: string[] = [
  "this query goes straight to the table, so it isn't scoped to the org and can read",
  "you map then filter in two passes here; a single reduce would do it in one and",
  "is there a reason this internal-only path skips the wrapper? if it's reachable from a",
  "good call keeping the helper on the internal path even where it was tempting to skip,",
];

// ---- styles --------------------------------------------------------------

// The outer panel: a thin-bordered card with the standard sidebar background,
// holding the vertical stack of comment rows.
const panel = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 560px",
  "margin: 0 auto",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 10px",
  "overflow: hidden",
  "background: var(--sl-color-bg)",
].join("; ");

// One comment row: pill on the left, greyed truncated body on the right. A thin
// divider between rows sells the "inbox / list" reading.
const rowStyle = (last: boolean) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: row",
    "align-items: center",
    "gap: 12px",
    "padding: 13px 16px",
    last ? "border-bottom: none" : "border-bottom: 1px solid var(--sl-color-gray-6)",
  ].join("; ");

// The severity pill: saturated fill, white monospace-ish label, fixed width so
// all four pills align into a clean left column the eye scans first.
const pill = (color: string) =>
  [
    reset,
    "box-sizing: border-box",
    "flex: 0 0 auto",
    "width: 104px",
    "padding: 4px 0",
    "border-radius: 6px",
    `background: ${color}`,
    "color: #ffffff",
    "font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, monospace)",
    "font-size: 13px",
    "font-weight: 700",
    "text-align: center",
    "letter-spacing: 0.01em",
  ].join("; ");

// The comment body: low-contrast, single line, ellipsis-truncated. min-width: 0
// lets the flex child shrink so the text actually clips with an ellipsis
// instead of forcing the row wider than the panel.
const body = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 auto",
  "min-width: 0",
  "color: var(--sl-color-gray-4)",
  "font-size: 13.5px",
  "line-height: 1.3",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");
---

<div class="not-content" style={panel}>
  {
    rows.map((r, i) => (
      <div style={rowStyle(i === rows.length - 1)}>
        <span style={pill(r.color)}>{r.label}</span>
        <span style={body}>{bodies[i]}</span>
      </div>
    ))
  }
</div>
