---
// One frame of the crash-and-resume sequence, used inside <DiagramSequence>.
// A "worker" box sits on top of a horizontal step-strip:
//   Step A --[checkpoint A]-- Step B --[checkpoint B]
// `state` selects which frame to render; every box / marker derives its look
// from the named state so the six steps share one visual vocabulary.
//
// Box states:  idle | running | done | cached | aborted
// Worker:      running | dead | fresh
// Checkpoint:  dim | lit

interface Props {
  state: "start" | "checkpoint-a" | "step-b" | "crash" | "resume" | "done";
}

const { state } = Astro.props;

type Box = "idle" | "running" | "done" | "cached" | "aborted";
type Worker = "running" | "dead" | "fresh";
type Mark = "dim" | "lit";

// Per-frame configuration: what each element looks like in this step.
const frames: Record<
  Props["state"],
  {
    worker: Worker;
    workerLabel: string;
    stepA: Box;
    stepB: Box;
    cpA: Mark;
    cpB: Mark;
  }
> = {
  start: {
    worker: "running",
    workerLabel: "Worker · running",
    stepA: "running",
    stepB: "idle",
    cpA: "dim",
    cpB: "dim",
  },
  "checkpoint-a": {
    worker: "running",
    workerLabel: "Worker · running",
    stepA: "done",
    stepB: "idle",
    cpA: "lit",
    cpB: "dim",
  },
  "step-b": {
    worker: "running",
    workerLabel: "Worker · running",
    stepA: "done",
    stepB: "running",
    cpA: "lit",
    cpB: "dim",
  },
  crash: {
    worker: "dead",
    workerLabel: "Worker · dead",
    stepA: "done",
    stepB: "aborted",
    cpA: "lit",
    cpB: "dim",
  },
  resume: {
    worker: "fresh",
    workerLabel: "New worker · running",
    stepA: "cached",
    stepB: "running",
    cpA: "lit",
    cpB: "dim",
  },
  done: {
    worker: "running",
    workerLabel: "Worker · running",
    stepA: "done",
    stepB: "done",
    cpA: "lit",
    cpB: "lit",
  },
};

const frame = frames[state];

// Shared chrome for the rounded work-step boxes.
const boxBase = [
  "margin: 0",
  "padding: 10px 14px",
  "border-radius: 9px",
  "min-width: 132px",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 2px",
  "position: relative",
  "transition: opacity 200ms ease, border-color 200ms ease, background-color 200ms ease, box-shadow 200ms ease",
].join("; ");

const GREEN = "#22c55e";
const AMBER = "#f59e0b";
const RED = "#ef4444";

// Work-box look per state.
const stepStyle = (s: Box): string => {
  switch (s) {
    case "idle":
      return `${boxBase}; border: 1px dashed color-mix(in srgb, currentColor 26%, transparent); background: color-mix(in srgb, currentColor 3%, transparent); opacity: 0.5;`;
    case "running":
      return `${boxBase}; border: 1.5px solid ${AMBER}; background: color-mix(in srgb, ${AMBER} 18%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, ${AMBER} 16%, transparent); opacity: 1;`;
    case "done":
      return `${boxBase}; border: 1.5px solid ${GREEN}; background: color-mix(in srgb, ${GREEN} 16%, transparent); opacity: 1;`;
    case "cached":
      return `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 28%, transparent); background: color-mix(in srgb, currentColor 5%, transparent); opacity: 0.5;`;
    case "aborted":
      return `${boxBase}; border: 1.5px solid ${RED}; background: color-mix(in srgb, ${RED} 14%, transparent); opacity: 1;`;
  }
};

// Status line under a step title.
const statusFor = (s: Box): { text: string; color: string } => {
  switch (s) {
    case "idle":
      return { text: "waiting", color: "color-mix(in srgb, currentColor 55%, transparent)" };
    case "running":
      return { text: "executing", color: AMBER };
    case "done":
      return { text: "done", color: GREEN };
    case "cached":
      return { text: "skipped — cached", color: "color-mix(in srgb, currentColor 60%, transparent)" };
    case "aborted":
      return { text: "aborted", color: RED };
  }
};

const stepATitle = "Step A — write page 1";
const stepBTitle = "Step B — write page 2";
const stepAStatus = statusFor(frame.stepA);
const stepBStatus = statusFor(frame.stepB);

const titleStyle =
  "margin: 0; font-size: 13px; font-weight: 600; line-height: 1.25;";
const statusStyle = (color: string) =>
  `margin: 0; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${color};`;

// Worker box look.
const workerStyle = (w: Worker): string => {
  const base =
    "margin: 0; padding: 8px 16px; border-radius: 9px; display: inline-flex; align-items: center; gap: 8px; font-size: 12.5px; font-weight: 600; line-height: 1.2; position: relative; transition: opacity 200ms ease, border-color 200ms ease, background-color 200ms ease;";
  if (w === "dead") {
    return `${base} border: 1.5px solid ${RED}; background: color-mix(in srgb, ${RED} 12%, transparent); color: color-mix(in srgb, currentColor 55%, transparent); opacity: 0.85;`;
  }
  // running and fresh both render lit; "fresh" gets a small "new" badge instead.
  return `${base} border: 1.5px solid #38bdf8; background: color-mix(in srgb, #38bdf8 16%, transparent); opacity: 1;`;
};

const dotStyle = (w: Worker): string => {
  const color = w === "dead" ? RED : "#38bdf8";
  return `width: 8px; height: 8px; border-radius: 999px; background: ${color}; flex: 0 0 auto;`;
};

// Checkpoint flag look.
const cpStyle = (m: Mark): string => {
  const base =
    "margin: 0; display: flex; flex-direction: column; align-items: center; gap: 3px; transition: opacity 200ms ease; flex: 0 0 auto;";
  return m === "lit"
    ? `${base} opacity: 1;`
    : `${base} opacity: 0.32;`;
};

const cpBadgeStyle = (m: Mark): string => {
  const base =
    "display: inline-flex; align-items: center; gap: 5px; padding: 4px 9px; border-radius: 999px; font-size: 11px; font-weight: 600; line-height: 1;";
  return m === "lit"
    ? `${base} border: 1.5px solid ${GREEN}; background: color-mix(in srgb, ${GREEN} 16%, transparent); color: ${GREEN};`
    : `${base} border: 1px dashed color-mix(in srgb, currentColor 30%, transparent); background: transparent; color: color-mix(in srgb, currentColor 60%, transparent);`;
};

const cpLabelStyle = (m: Mark): string =>
  `font-size: 10px; line-height: 1; color: color-mix(in srgb, currentColor ${m === "lit" ? "70%" : "45%"}, transparent);`;

const connectorStyle =
  "flex: 0 0 18px; height: 0; border-top: 2px dotted color-mix(in srgb, currentColor 28%, transparent);";

const fontFamily =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);";
---

<div style={`margin: 0; display: flex; flex-direction: column; align-items: center; gap: 18px; ${fontFamily}`}>
  {/* Worker box on top */}
  <div style={workerStyle(frame.worker)}>
    <span style={dotStyle(frame.worker)}></span>
    <span>{frame.workerLabel}</span>
    {frame.worker === "dead" && (
      <span
        aria-hidden="true"
        style={`position: absolute; right: -14px; top: -14px; font-size: 22px; line-height: 1; filter: drop-shadow(0 0 2px color-mix(in srgb, ${RED} 60%, transparent));`}
      >
        ⚡
      </span>
    )}
    {frame.worker === "fresh" && (
      <span
        style="margin-left: 2px; padding: 2px 6px; border-radius: 999px; font-size: 9.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; border: 1px solid #38bdf8; color: #38bdf8;"
        >new</span>
    )}
  </div>

  {/* Step strip: A -- cpA -- B -- cpB */}
  <div style="margin: 0; display: flex; flex-direction: row; align-items: center; justify-content: center; flex-wrap: wrap; gap: 6px;">
    {/* Step A */}
    <div style={stepStyle(frame.stepA)}>
      <div style={titleStyle}>{stepATitle}</div>
      <div style={statusStyle(stepAStatus.color)}>{stepAStatus.text}</div>
    </div>

    <div style={connectorStyle}></div>

    {/* Checkpoint A */}
    <div style={cpStyle(frame.cpA)}>
      <span style={cpBadgeStyle(frame.cpA)}>
        <span aria-hidden="true">{frame.cpA === "lit" ? "🚩" : "⚐"}</span>
        checkpoint
      </span>
      <span style={cpLabelStyle(frame.cpA)}>after page 1</span>
    </div>

    <div style={connectorStyle}></div>

    {/* Step B */}
    <div style={stepStyle(frame.stepB)}>
      <div style={titleStyle}>{stepBTitle}</div>
      <div style={statusStyle(stepBStatus.color)}>{stepBStatus.text}</div>
    </div>

    <div style={connectorStyle}></div>

    {/* Checkpoint B */}
    <div style={cpStyle(frame.cpB)}>
      <span style={cpBadgeStyle(frame.cpB)}>
        <span aria-hidden="true">{frame.cpB === "lit" ? "🚩" : "⚐"}</span>
        checkpoint
      </span>
      <span style={cpLabelStyle(frame.cpB)}>after page 2</span>
    </div>
  </div>
</div>
