---
// One frame of the trigger lifecycle, used inside <DiagramSequence>.
// Five stages laid out as a horizontal strip:
//   User → Server Action → Queue → Worker → Dashboard
// A dashed divider splits the "request path" (User, Server Action) from the
// "task's own world" (Worker) — the two never touch directly.
//
// `active` highlights one stage; every other box is dimmed.
// `payload` places the travelling payload chip: on the queue, on the worker,
//   or nowhere yet. It is the only thing that crosses the divider.
// `handle` draws the dashed "handle returns now" arrow back to the user.

interface Props {
  active: "action" | "queue" | "worker" | "dashboard";
  payload?: "queue" | "worker" | null;
  handle?: boolean;
}

const { active, payload = null, handle = false } = Astro.props;

const arrow = "▸";

// Shared chrome for the rounded card boxes.
const boxBase = [
  "margin: 0",
  "padding: 7px 10px",
  "border-radius: 8px",
  "min-width: 0",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 1px",
  "transition: opacity 200ms ease, transform 200ms ease, border-color 200ms ease, background-color 200ms ease, box-shadow 200ms ease",
].join("; ");

// Per-stage accent colours so each box keeps its identity even when dimmed.
const accents: Record<Props["active"], string> = {
  action: "#38bdf8", // sky — the request side
  queue: "#a78bfa", // violet — the buffer
  worker: "#34d399", // emerald — the task's own world
  dashboard: "#f472b6", // pink — observability
};

const userColor = "#94a3b8"; // slate — the human, off to the side

const dimBox = (color: string) =>
  `${boxBase}; border: 1px solid color-mix(in srgb, ${color} 30%, transparent); background: color-mix(in srgb, ${color} 5%, transparent); opacity: 0.4;`;

const activeBox = (color: string) =>
  `${boxBase}; border: 1.5px solid ${color}; background: color-mix(in srgb, ${color} 20%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, ${color} 16%, transparent); transform: translateY(-1px); opacity: 1;`;

const styleFor = (id: Props["active"]) =>
  active === id ? activeBox(accents[id]) : dimBox(accents[id]);

const titleStyle =
  "margin: 0; font-size: 12.5px; font-weight: 600; line-height: 1.2; white-space: nowrap;";
const subtitleStyle =
  "margin: 2px 0 0; font-size: 10px; opacity: 0.65; line-height: 1.2; white-space: nowrap;";

const arrowStyle = [
  "margin: 0",
  "color: currentColor",
  "opacity: 0.35",
  "font-size: 13px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");

// The payload chip — a small monospace pill that travels with the run.
const payloadChipStyle = [
  "margin: 0",
  "padding: 2px 7px",
  "border-radius: 999px",
  "font-family: var(--sl-font-mono, ui-monospace, monospace)",
  "font-size: 10px",
  "font-weight: 600",
  "white-space: nowrap",
  "border: 1px solid color-mix(in srgb, #f59e0b 55%, transparent)",
  "background: color-mix(in srgb, #f59e0b 18%, transparent)",
  "color: color-mix(in srgb, #f59e0b 90%, currentColor)",
].join("; ");

const payloadSlotStyle =
  "height: 20px; display: flex; align-items: center; justify-content: center; margin-top: 5px;";
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 4px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* Main horizontal strip */}
  <div
    style="margin: 0; display: flex; flex-direction: row; align-items: stretch; justify-content: center; flex-wrap: nowrap; gap: 4px; min-width: 0;"
  >
    {/* User — the human, separated from the machinery */}
    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={active === "action" ? activeBox(userColor) : dimBox(userColor)}>
        <div style={titleStyle}>User</div>
        <div style={subtitleStyle}>clicks “Export”</div>
      </div>
      <div style={payloadSlotStyle}></div>
    </div>

    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={arrowStyle}>{arrow}</div>
      <div style={payloadSlotStyle}></div>
    </div>

    {/* Server Action */}
    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={styleFor("action")}>
        <div style={titleStyle}>Server Action</div>
        <div style={subtitleStyle}>.trigger(payload)</div>
      </div>
      <div style={payloadSlotStyle}></div>
    </div>

    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={arrowStyle}>{arrow}</div>
      <div style={payloadSlotStyle}></div>
    </div>

    {/* Queue */}
    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={styleFor("queue")}>
        <div style={titleStyle}>Queue</div>
        <div style={subtitleStyle}>run enqueued</div>
      </div>
      <div style={payloadSlotStyle}>
        {payload === "queue" && <span style={payloadChipStyle}>{"{ organizationId, … }"}</span>}
      </div>
    </div>

    {/* Divider: request path | task's own world */}
    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto; align-self: stretch; padding: 0 2px;">
      <div
        style="flex: 1 1 auto; width: 0; border-left: 1.5px dashed color-mix(in srgb, currentColor 35%, transparent);"
      >
      </div>
    </div>

    {/* Worker — its own world, no request */}
    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={styleFor("worker")}>
        <div style={titleStyle}>Worker</div>
        <div style={subtitleStyle}>separate process</div>
      </div>
      <div style={payloadSlotStyle}>
        {payload === "worker" && <span style={payloadChipStyle}>{"{ organizationId, … }"}</span>}
      </div>
    </div>

    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={arrowStyle}>{arrow}</div>
      <div style={payloadSlotStyle}></div>
    </div>

    {/* Dashboard */}
    <div style="display: flex; flex-direction: column; align-items: center; flex: 0 0 auto;">
      <div style={styleFor("dashboard")}>
        <div style={titleStyle}>Dashboard</div>
        <div style={subtitleStyle}>status · logs</div>
      </div>
      <div style={payloadSlotStyle}></div>
    </div>
  </div>

  {/* Handle-returns-now arrow: from the Server Action back to the User */}
  <div style="height: 22px; display: flex; align-items: center; justify-content: flex-start; margin: 0;">
    {
      handle && (
        <div style="display: flex; align-items: center; gap: 6px; opacity: 1;">
          <svg
            viewBox="0 0 120 16"
            width="120"
            height="16"
            role="img"
            aria-label="The handle returns to the user immediately."
            style="display: block; flex: 0 0 auto;"
          >
            <path
              d="M 116 8 L 6 8"
              fill="none"
              stroke="#38bdf8"
              stroke-width="1.6"
              stroke-dasharray="4 3"
            />
            <path d="M 2 8 L 10 4 L 10 12 Z" fill="#38bdf8" />
          </svg>
          <span
            style="font-size: 10.5px; font-weight: 600; color: color-mix(in srgb, #38bdf8 90%, currentColor); white-space: nowrap;"
          >
            handle returns to the user — now, in ms
          </span>
        </div>
      )
    }
  </div>

  {/* Footer legend: the two worlds */}
  <div
    style="display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 2px; font-size: 10px; opacity: 0.7;"
  >
    <span style="display: inline-flex; align-items: center; gap: 5px;">
      <span
        style="width: 14px; border-top: 1.5px dashed color-mix(in srgb, currentColor 50%, transparent); display: inline-block;"
      ></span>
      request path ends here · the worker's world begins
    </span>
  </div>
</div>
