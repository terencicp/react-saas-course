---
// One frame of the concurrency-lane comparison, used inside <DiagramSequence>.
//
// mode="shared": a single lane with all nine runs queued single-file
//   (A1 A2 A3 B1 B2 B3 C1 C2 C3). Only the front run is executing; everyone
//   else waits behind it. One busy tenant blocks the rest.
//
// mode="keyed": three independent lanes, one per org (the concurrencyKey
//   splits the limit). The front run of each lane executes at once —
//   sequential within an org, parallel across orgs.
//
// Each org keeps a stable accent colour so the same run reads as "the same
// run" across both frames.

interface Props {
  mode: "shared" | "keyed";
}

const { mode } = Astro.props;

// Per-org accent colours. A/B/C each get their own identity.
const orgs = [
  { id: "A", color: "#38bdf8" }, // sky
  { id: "B", color: "#a78bfa" }, // violet
  { id: "C", color: "#34d399" }, // emerald
] as const;

const colorOf: Record<string, string> = Object.fromEntries(
  orgs.map((o) => [o.id, o.color]),
);

// The full single-file order for the shared lane.
const sharedOrder = orgs.flatMap((o) => [1, 2, 3].map((n) => `${o.id}${n}`));

// A single run "chip". `state` is "running" (front of its lane), "queued"
// (waiting behind), so the eye can find what is executing right now.
// `compact` shrinks the chip so the nine-wide shared lane fits the card.
const chip = (
  label: string,
  state: "running" | "queued",
  compact = false,
) => {
  const org = label[0];
  const color = colorOf[org];
  const base = [
    "margin: 0",
    "padding: 4px 0",
    compact ? "width: 32px" : "width: 40px",
    "border-radius: 7px",
    "text-align: center",
    "font-family: var(--sl-font-mono, ui-monospace, monospace)",
    compact ? "font-size: 11px" : "font-size: 12px",
    "font-weight: 700",
    "line-height: 1",
    "flex: 0 0 auto",
    "transition: opacity 200ms ease, box-shadow 200ms ease",
  ];
  if (state === "running") {
    return base
      .concat([
        `border: 1.5px solid ${color}`,
        `background: color-mix(in srgb, ${color} 28%, transparent)`,
        `color: color-mix(in srgb, ${color} 92%, currentColor)`,
        `box-shadow: 0 0 0 3px color-mix(in srgb, ${color} 18%, transparent)`,
      ])
      .join("; ");
  }
  return base
    .concat([
      `border: 1px dashed color-mix(in srgb, ${color} 45%, transparent)`,
      `background: color-mix(in srgb, ${color} 7%, transparent)`,
      `color: color-mix(in srgb, ${color} 70%, currentColor)`,
      "opacity: 0.85",
    ])
    .join("; ");
};

const laneStyle = [
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 6px",
  "padding: 8px 10px",
  "border-radius: 10px",
  "border: 1px solid color-mix(in srgb, currentColor 12%, transparent)",
  "background: color-mix(in srgb, currentColor 3%, transparent)",
  "min-width: 0",
].join("; ");

const laneLabelStyle = [
  "margin: 0",
  "font-size: 11px",
  "font-weight: 600",
  "opacity: 0.7",
  "white-space: nowrap",
  "flex: 0 0 auto",
  "min-width: 58px",
].join("; ");

const arrowStyle = [
  "color: currentColor",
  "opacity: 0.3",
  "font-size: 12px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");

const tagStyle = (color: string) =>
  [
    "margin: 0",
    "padding: 2px 8px",
    "border-radius: 999px",
    "font-size: 10px",
    "font-weight: 700",
    "white-space: nowrap",
    "flex: 0 0 auto",
    `border: 1px solid color-mix(in srgb, ${color} 50%, transparent)`,
    `background: color-mix(in srgb, ${color} 14%, transparent)`,
    `color: color-mix(in srgb, ${color} 90%, currentColor)`,
  ].join("; ");

const runningPill =
  "margin: 0; padding: 1px 7px; border-radius: 999px; font-size: 9.5px; font-weight: 700; white-space: nowrap; border: 1px solid color-mix(in srgb, currentColor 22%, transparent); background: color-mix(in srgb, currentColor 6%, transparent); opacity: 0.75; flex: 0 0 auto;";
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 10px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {
    mode === "shared" ? (
      <div style="display: flex; flex-direction: column; gap: 7px;">
        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
          <span style={tagStyle("#94a3b8")}>queue: export · concurrencyLimit: 1</span>
          <span style="font-size: 10.5px; opacity: 0.6;">one shared lane</span>
        </div>
        <div style={`${laneStyle} gap: 3px; padding: 8px 8px;`}>
          {sharedOrder.map((label, i) => (
            <span style={chip(label, i === 0 ? "running" : "queued", true)}>{label}</span>
          ))}
        </div>
        <div style="display: flex; align-items: center; gap: 12px; padding-left: 2px; font-size: 10px; opacity: 0.7; flex-wrap: wrap;">
          <span style="display: inline-flex; align-items: center; gap: 5px;">
            <span style="width: 22px; height: 14px; border-radius: 5px; border: 1.5px solid currentColor; opacity: 0.55; display: inline-block;" />
            running now
          </span>
          <span style="display: inline-flex; align-items: center; gap: 5px;">
            <span style="width: 22px; height: 14px; border-radius: 5px; border: 1px dashed currentColor; opacity: 0.45; display: inline-block;" />
            waiting behind it
          </span>
        </div>
      </div>
    ) : (
      <div style="display: flex; flex-direction: column; gap: 7px;">
        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
          <span style={tagStyle("#94a3b8")}>queue: export · concurrencyLimit: 1</span>
          <span style={tagStyle("#a78bfa")}>concurrencyKey: organizationId</span>
        </div>
        {orgs.map((org) => (
          <div style={laneStyle}>
            <span style={`${laneLabelStyle} color: color-mix(in srgb, ${org.color} 85%, currentColor); opacity: 1;`}>
              org {org.id}
            </span>
            {[1, 2, 3].map((n, i) => (
              <>
                {i > 0 && <span style={arrowStyle}>▸</span>}
                <span style={chip(`${org.id}${n}`, i === 0 ? "running" : "queued")}>
                  {org.id}
                  {n}
                </span>
              </>
            ))}
            <span style={runningPill}>1 running</span>
          </div>
        ))}
        <div style="padding-left: 2px; font-size: 10px; opacity: 0.7;">
          A1, B1, C1 all run at once — each org drains its own three in order.
        </div>
      </div>
    )
  }
</div>
