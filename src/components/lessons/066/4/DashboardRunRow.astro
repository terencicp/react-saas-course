---
// A static mock of a single Trigger.dev dashboard run detail, used to make
// "observability for free" tangible. It is not interactive — it shows what the
// platform renders for one `notify-org-members` run without any wiring:
//   - a status pill (Completed, green)
//   - the task id + the durable run id
//   - the payload, exactly as it was triggered
//   - the run's duration and attempt count
//   - every log line the run emitted
//
// Styled to read as a compact dashboard card. Colours use Starlight CSS
// variables (theme-aware chrome) plus a green accent for the success signal,
// in the same spirit as the other 066/4 mocks.

const accent = "#34d399"; // emerald — the success signal
const mono = "var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

// The run's metadata header fields.
const meta = [
  { label: "Run", value: "run_4kq8x2vh7" },
  { label: "Duration", value: "1.2s" },
  { label: "Attempt", value: "1 of 1" },
];

// The payload, rendered as syntax-coloured key/value pairs.
const payload = [
  { key: "organizationId", value: '"018f…4a5b"' },
  { key: "eventType", value: '"invoice.paid"' },
];

// The log lines the run streamed, each with its own timestamp offset.
const logs = [
  { t: "+0.0s", msg: "Notifying members of 018f…4a5b" },
  { t: "+0.3s", msg: "Loaded 4 members" },
  { t: "+1.1s", msg: "Sent 4 emails" },
  { t: "+1.2s", msg: "Done" },
];

const cardStyle = [
  "margin: 0",
  "width: 100%",
  "max-width: 560px",
  "box-sizing: border-box",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 10px",
  "overflow: hidden",
  "background: var(--sl-color-bg)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
].join("; ");

const headerStyle = [
  "margin: 0",
  "display: flex",
  "align-items: center",
  "flex-wrap: wrap",
  "gap: 10px",
  "padding: 12px 14px",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-bg-sidebar)",
].join("; ");

const pillStyle = [
  "margin: 0",
  "display: inline-flex",
  "align-items: center",
  "gap: 6px",
  "padding: 3px 10px",
  "border-radius: 999px",
  "font-size: 12px",
  "font-weight: 600",
  `border: 1px solid color-mix(in srgb, ${accent} 55%, transparent)`,
  `background: color-mix(in srgb, ${accent} 16%, transparent)`,
  `color: color-mix(in srgb, ${accent} 80%, currentColor)`,
  "white-space: nowrap",
].join("; ");

const taskIdStyle = [
  "margin: 0",
  "font-family: " + mono,
  "font-size: 13px",
  "font-weight: 600",
  "color: var(--sl-color-white)",
].join("; ");

const metaItemLabel = "margin: 0; font-size: 10px; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.6; line-height: 1.3;";
const metaItemValue = `margin: 0; font-family: ${mono}; font-size: 12px; line-height: 1.3; color: var(--sl-color-gray-2);`;

const sectionLabel = [
  "margin: 0 0 6px",
  "font-size: 10px",
  "text-transform: uppercase",
  "letter-spacing: 0.04em",
  "font-weight: 600",
  "opacity: 0.55",
].join("; ");

const payloadBoxStyle = [
  "margin: 0",
  "padding: 10px 12px",
  "border-radius: 8px",
  "background: var(--sl-color-bg-sidebar)",
  "border: 1px solid var(--sl-color-gray-5)",
  `font-family: ${mono}`,
  "font-size: 12px",
  "line-height: 1.6",
].join("; ");

const logRowStyle = [
  "margin: 0",
  "display: flex",
  "gap: 10px",
  "align-items: baseline",
  `font-family: ${mono}`,
  "font-size: 12px",
  "line-height: 1.7",
].join("; ");

const logTimeStyle = "margin: 0; flex: 0 0 auto; opacity: 0.45; min-width: 38px;";
const logMsgStyle = "margin: 0; color: var(--sl-color-gray-2);";
---

<div style={cardStyle}>
  {/* Header: status pill, task id, and the run's metadata */}
  <div style={headerStyle}>
    <span style={pillStyle}>
      <span
        style={`width: 7px; height: 7px; border-radius: 999px; background: ${accent}; display: inline-block;`}
      ></span>
      Completed
    </span>
    <span style={taskIdStyle}>notify-org-members</span>

    <div style="margin: 0; display: flex; gap: 18px; margin-left: auto;">
      {
        meta.map((m) => (
          <div style="margin: 0; display: flex; flex-direction: column;">
            <span style={metaItemLabel}>{m.label}</span>
            <span style={metaItemValue}>{m.value}</span>
          </div>
        ))
      }
    </div>
  </div>

  {/* Body: the payload, then the log stream */}
  <div style="margin: 0; padding: 14px;">
    <div style="margin: 0 0 14px;">
      <div style={sectionLabel}>Payload</div>
      <div style={payloadBoxStyle}>
        <span style="opacity: 0.5;">{"{"}</span>
        {
          payload.map((p, i) => (
            <div style="margin: 0; padding-left: 14px;">
              <span style="color: color-mix(in srgb, #38bdf8 80%, currentColor);">{p.key}</span>
              <span style="opacity: 0.5;">: </span>
              <span style="color: color-mix(in srgb, #34d399 80%, currentColor);">{p.value}</span>
              {i < payload.length - 1 && <span style="opacity: 0.5;">,</span>}
            </div>
          ))
        }
        <span style="opacity: 0.5;">{"}"}</span>
      </div>
    </div>

    <div style="margin: 0;">
      <div style={sectionLabel}>Logs</div>
      <div
        style="margin: 0; padding: 10px 12px; border-radius: 8px; background: var(--sl-color-bg-sidebar); border: 1px solid var(--sl-color-gray-5);"
      >
        {
          logs.map((l) => (
            <div style={logRowStyle}>
              <span style={logTimeStyle}>{l.t}</span>
              <span style={logMsgStyle}>{l.msg}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>
