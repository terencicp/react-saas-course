---
// One frame of the deploy-ordering sequence, used inside <DiagramSequence>.
// A left-to-right temporal strip turns the abstract "callee before caller"
// rule into a picture: two cells joined by a "then" arrow, read left → right.
//
//   [ Trigger.dev workers ] --then--> [ Next.js app on Vercel ]
//     the callee (task)                 the caller (Server Action)
//
// `step` selects which frame to render:
//   "task-first" — cell 1 active (callee landing), cell 2 dimmed (not live yet)
//   "app-next"   — cell 1 done (callee live),       cell 2 active (caller going live)
//
// Each cell carries a role tag ("callee" / "caller") and a small CLI chip
// (`trigger deploy` / `vercel deploy`). The arrow between them is the temporal
// "then". Pure inline-styled HTML so it stays native in light and dark — the
// look derives entirely from the named step, matching CrashResumeFrame's idiom.

interface Props {
  step: "task-first" | "app-next";
}

const { step } = Astro.props;

type Cell = "active" | "done" | "pending";

const frames: Record<
  Props["step"],
  { taskCell: Cell; appCell: Cell }
> = {
  "task-first": { taskCell: "active", appCell: "pending" },
  "app-next": { taskCell: "done", appCell: "active" },
};

const frame = frames[step];

const PURPLE = "#7c3aed"; // Trigger.dev workers (matches the chapter's task color)
const BLUE = "#2563eb"; // Next.js app on Vercel
const GREEN = "#22c55e"; // a cell that has gone live

// A cell's chrome, tinted by its accent and dimmed when it is not yet live.
const cellStyle = (state: Cell, accent: string): string => {
  const base =
    "margin: 0; padding: 14px 18px; border-radius: 12px; min-width: 196px; flex: 1 1 196px; max-width: 248px; display: flex; flex-direction: column; gap: 8px; position: relative; transition: opacity 220ms ease, border-color 220ms ease, background-color 220ms ease, box-shadow 220ms ease;";
  switch (state) {
    case "active":
      return `${base} border: 2px solid ${accent}; background: color-mix(in srgb, ${accent} 15%, transparent); box-shadow: 0 0 0 4px color-mix(in srgb, ${accent} 14%, transparent); opacity: 1;`;
    case "done":
      return `${base} border: 1.5px solid ${GREEN}; background: color-mix(in srgb, ${GREEN} 13%, transparent); opacity: 1;`;
    case "pending":
      return `${base} border: 1.5px dashed color-mix(in srgb, currentColor 26%, transparent); background: color-mix(in srgb, currentColor 3%, transparent); opacity: 0.45;`;
  }
};

// The status pill under each cell title.
const statusFor = (state: Cell): { text: string; color: string } => {
  switch (state) {
    case "active":
      return { text: "deploying now", color: "#0ea5e9" };
    case "done":
      return { text: "live", color: GREEN };
    case "pending":
      return { text: "not live yet", color: "color-mix(in srgb, currentColor 55%, transparent)" };
  }
};

const taskStatus = statusFor(frame.taskCell);
const appStatus = statusFor(frame.appCell);

const roleStyle = (accent: string): string =>
  `margin: 0; align-self: flex-start; padding: 2px 8px; border-radius: 999px; font-size: 10px; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; border: 1px solid color-mix(in srgb, ${accent} 55%, transparent); color: ${accent}; background: color-mix(in srgb, ${accent} 8%, transparent);`;

const titleStyle =
  "margin: 0; font-size: 14px; font-weight: 700; line-height: 1.3; color: var(--sl-color-text);";

const subStyle =
  "margin: 0; font-size: 12px; font-weight: 500; line-height: 1.3; color: var(--sl-color-gray-3);";

const statusPillStyle = (color: string, dim: boolean): string =>
  `margin: 0; align-self: flex-start; display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; font-weight: 700; line-height: 1; color: ${color}; opacity: ${dim ? "0.85" : "1"};`;

const dotStyle = (color: string): string =>
  `width: 7px; height: 7px; border-radius: 999px; background: ${color}; flex: 0 0 auto;`;

const chipStyle = (state: Cell): string => {
  const base =
    "margin: 0; align-self: flex-start; display: inline-flex; align-items: center; gap: 6px; padding: 4px 9px; border-radius: 7px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 11.5px; font-weight: 600; line-height: 1; transition: opacity 220ms ease;";
  return state === "pending"
    ? `${base} border: 1px dashed color-mix(in srgb, currentColor 28%, transparent); background: transparent; color: color-mix(in srgb, currentColor 60%, transparent);`
    : `${base} border: 1px solid color-mix(in srgb, currentColor 22%, transparent); background: color-mix(in srgb, currentColor 7%, transparent); color: var(--sl-color-text);`;
};

// The "then" arrow between the two cells. Brightens once both ends matter.
const arrowActive = frame.appCell === "active";
const arrowColor = arrowActive ? PURPLE : "color-mix(in srgb, currentColor 30%, transparent)";

const fontFamily =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);";
---

<div
  style={`margin: 0 auto; max-width: 640px; display: flex; flex-direction: row; align-items: stretch; justify-content: center; gap: 4px; flex-wrap: wrap; ${fontFamily}`}
>
  {/* Cell 1 — the callee: the Trigger.dev task version */}
  <div style={cellStyle(frame.taskCell, PURPLE)}>
    <span style={roleStyle(PURPLE)}>callee</span>
    <div style={titleStyle}>Task version on Trigger.dev workers</div>
    <div style={subStyle}>the task the app will call</div>
    <span style={statusPillStyle(taskStatus.color, frame.taskCell === "pending")}>
      <span style={dotStyle(taskStatus.color)}></span>
      {taskStatus.text}
    </span>
    <code style={chipStyle(frame.taskCell)}>
      <span aria-hidden="true" style="opacity: 0.6;">$</span>
      trigger deploy
    </code>
  </div>

  {/* The temporal "then" arrow */}
  <div
    aria-hidden="true"
    style="flex: 0 0 56px; align-self: center; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; margin: 0;"
  >
    <span
      style={`font-size: 10px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1; color: ${arrowActive ? PURPLE : "color-mix(in srgb, currentColor 50%, transparent)"}; transition: color 220ms ease;`}
    >then</span>
    <svg width="48" height="14" viewBox="0 0 48 14" fill="none" style="display: block;">
      <path
        d="M2 7 H40"
        stroke={arrowColor}
        stroke-width="2.5"
        stroke-linecap="round"
        style="transition: stroke 220ms ease;"
      ></path>
      <path
        d="M36 2 L44 7 L36 12"
        stroke={arrowColor}
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"
        style="transition: stroke 220ms ease;"
      ></path>
    </svg>
  </div>

  {/* Cell 2 — the caller: the Next.js app */}
  <div style={cellStyle(frame.appCell, BLUE)}>
    <span style={roleStyle(BLUE)}>caller</span>
    <div style={titleStyle}>Next.js app on Vercel</div>
    <div style={subStyle}>Server Action that triggers the task</div>
    <span style={statusPillStyle(appStatus.color, frame.appCell === "pending")}>
      <span style={dotStyle(appStatus.color)}></span>
      {appStatus.text}
    </span>
    <code style={chipStyle(frame.appCell)}>
      <span aria-hidden="true" style="opacity: 0.6;">$</span>
      vercel deploy
    </code>
  </div>
</div>
