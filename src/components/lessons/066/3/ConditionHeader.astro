---
// ConditionHeader — Chapter 066 Lesson 3 ("When Trigger.dev earns its weight").
//
// The visual chrome for each step of the `five-conditions` <DiagramSequence>.
// The five conditions are taught in ESCALATION ORDER (cheapest-breaking first),
// so each step needs to advertise (a) which number it is and (b) where it sits
// in the run of five. This header gives every step the same recognizable shape:
//
//   [icon]  CONDITION 3 OF 5            ● ● ◉ ○ ○   <- progress dots
//           Automatic retries with backoff          <- the condition name
//
// The active dot is filled; passed dots are filled-muted; future dots are
// hollow. That single strip is what carries the "we're climbing a ladder, one
// rung at a time" framing the prose sets up — without adding vertical height.
//
// Plain presentational component: no client JS. The <DiagramSequence> parent
// owns the scrubbing; this is just the per-step banner that swaps with the body.
//
// Theme-aware: uses Starlight accent/gray vars so it flips light/dark. The icon
// is a Lucide glyph passed by name from the MDX.

import { Icon } from 'astro-icon/components';

interface Props {
	/** Which condition this is, 1-based. */
	step: number;
	/** Lucide icon name, e.g. "lucide:timer-off". */
	icon: string;
	/** The condition name — the bold heading. */
	title: string;
}

const { step, icon, title } = Astro.props;
const total = 5;
const dots = Array.from({ length: total }, (_, i) => i + 1);
---

<header class="cond not-content">
	<div class="cond-top">
		<span class="cond-icon" aria-hidden="true">
			<Icon name={icon} />
		</span>
		<span class="cond-eyebrow">Condition {step} of {total}</span>

		<ol class="cond-dots" aria-hidden="true">
			{
				dots.map((d) => (
					<li
						class:list={[
							'cond-dot',
							d === step && 'is-active',
							d < step && 'is-past',
						]}
					/>
				))
			}
		</ol>
	</div>

	<h3 class="cond-title">{title}</h3>
</header>

<style>
	.cond {
		margin: 0 0 0.75rem;
	}

	.cond-top {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.cond-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		flex: none;
		border-radius: 0.5rem;
		background: var(--sl-color-accent-low);
		color: var(--sl-color-accent-high);
	}

	.cond-icon :global(svg) {
		width: 1.15rem;
		height: 1.15rem;
	}

	.cond-eyebrow {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	.cond-dots {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0 0 0 auto;
		padding: 0;
		list-style: none;
	}

	.cond-dot {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		border: 1.5px solid var(--sl-color-gray-4);
		background: transparent;
	}

	.cond-dot.is-past {
		border-color: var(--sl-color-accent-low);
		background: var(--sl-color-accent-low);
	}

	.cond-dot.is-active {
		border-color: var(--sl-color-accent);
		background: var(--sl-color-accent);
		box-shadow: 0 0 0 3px var(--sl-color-accent-low);
	}

	.cond-title {
		margin: 0.55rem 0 0;
		font-size: 1.15rem;
		line-height: 1.25;
	}
</style>
