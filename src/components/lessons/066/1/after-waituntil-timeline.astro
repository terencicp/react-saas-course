---
// after-waituntil-timeline — Chapter 066 Lesson 1 ("Inline, then after()").
// Makes the one genuinely slippery thing about after() visual: "same
// invocation, but past the response, bounded by the same wall."
//
// A single horizontal time axis read left → right:
//
//   [ solid segment ]│[ hatched segment ]‖
//    action body     │  after() callback  maxDuration
//    user is waiting  ↑                    (hard wall)
//                response sent
//                user sees success
//
// The LEFT segment is solid + saturated (the work the user waits through:
// DB transaction + email send). The bold marker between the two is the
// conceptual pivot — the moment the response ships — so it is the loudest
// element. The RIGHT segment is a lighter diagonal-hatch fill so it reads as
// "after the response, the user is NOT waiting." A dashed vertical wall at the
// far right is maxDuration: the after() tail ends on the SAME wall as the
// request, the whole point of the figure.
//
// Pure HTML + CSS, scoped <style>. `not-content` + a margin:0 reset on every
// inner element defeat Starlight's prose-margin selector. Saturated mid-tones
// with white text + Starlight gray variables keep it native in light and dark.
// No leader lines, so the figure stays expandable.

import Figure from "../../../figures/Figure.astro";
---

<Figure
  caption="The response ships at the marker; the after() callback runs to its right, on the same invocation, still bounded by the same maxDuration wall."
>
  <div class="tl not-content">
    {/* ---- phase labels, above each segment ----------------------------- */}
    <div class="tl-heads">
      <div class="tl-head tl-head--work">
        Action body runs
        <span class="tl-head-sub">DB transaction + email send</span>
      </div>
      <div class="tl-head tl-head--after">
        <code class="tl-code">after()</code> callback runs
        <span class="tl-head-sub">
          <code class="tl-code tl-code--dim">waitUntil</code> keeps the box alive
        </span>
      </div>
    </div>

    {/* ---- the track: two contiguous segments + the response marker ------ */}
    <div class="tl-track">
      <div class="tl-seg tl-seg--work">
        <span class="tl-seg-tag">user is waiting</span>
      </div>

      {/* the pivot — the moment the response ships. Loudest element. */}
      <div class="tl-marker">
        <span class="tl-marker-dot" aria-hidden="true"></span>
      </div>

      <div class="tl-seg tl-seg--after">
        <span class="tl-seg-tag tl-seg-tag--muted">user is NOT waiting</span>
      </div>

      {/* the hard wall — the after() tail ends on the same maxDuration line. */}
      <div class="tl-wall" aria-hidden="true"></div>
    </div>

    {/* ---- callout under the marker: the conceptual pivot --------------- */}
    <div class="tl-callouts">
      <div class="tl-callout tl-callout--marker">
        <span class="tl-callout-kicker">response sent</span>
        user sees success
      </div>
      <div class="tl-callout tl-callout--wall">
        <code class="tl-code">maxDuration</code>
        <span class="tl-callout-sub">hard wall — same for the whole invocation</span>
      </div>
    </div>

    {/* ---- time axis ---------------------------------------------------- */}
    <div class="tl-axis" aria-hidden="true">
      <span class="tl-axis-line"></span>
      <span class="tl-axis-label">time</span>
    </div>
  </div>
</Figure>

<style>
  /* Horizontal strip, capped well under the 800px ceiling, centred. */
  .tl {
    --tl-work: #4f46e5; /* indigo-600 — "user is waiting", saturated + solid */
    --tl-after: var(--sl-color-gray-3);
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- phase heads, sized to match the segments below ------------------ */

  .tl-heads {
    display: grid;
    /* work segment | marker gutter | after segment | wall gutter */
    grid-template-columns: 52fr 0fr 48fr 0fr;
    margin: 0 0 8px;
  }

  .tl-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-text);
    padding: 0 8px;
    margin: 0;
  }

  .tl-head--work {
    grid-column: 1;
  }

  .tl-head--after {
    grid-column: 3;
    color: var(--sl-color-gray-2);
  }

  .tl-head-sub {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  /* ---- the track ------------------------------------------------------- */

  .tl-track {
    display: grid;
    grid-template-columns: 52fr 0fr 48fr 0fr;
    align-items: center;
    height: 58px;
    margin: 0;
  }

  .tl-seg {
    position: relative;
    box-sizing: border-box;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: 0;
  }

  /* LEFT — solid, saturated. The work the user waits through. */
  .tl-seg--work {
    grid-column: 1;
    background: var(--tl-work);
    border-radius: 8px 0 0 8px;
  }

  /* RIGHT — lighter diagonal hatch. After the response; the user is not here. */
  .tl-seg--after {
    grid-column: 3;
    border: 1px dashed color-mix(in srgb, var(--tl-after) 70%, transparent);
    border-left: none;
    border-radius: 0 8px 8px 0;
    background: repeating-linear-gradient(
      135deg,
      color-mix(in srgb, var(--tl-after) 12%, transparent),
      color-mix(in srgb, var(--tl-after) 12%, transparent) 7px,
      transparent 7px,
      transparent 14px
    );
  }

  .tl-seg-tag {
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--sl-color-text-invert, #fff);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
    margin: 0;
  }

  .tl-seg-tag--muted {
    color: var(--sl-color-gray-2);
    text-shadow: none;
  }

  /* ---- the response marker — the loudest element, the pivot ----------- */

  .tl-marker {
    grid-column: 2;
    position: relative;
    z-index: 2;
    width: 0;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
  }

  .tl-marker::before {
    content: "";
    position: absolute;
    top: -7px;
    bottom: -7px;
    left: 50%;
    transform: translateX(-50%);
    width: 5px;
    border-radius: 3px;
    background: var(--sl-color-text-accent);
    box-shadow: 0 0 0 2px var(--sl-color-bg-sidebar);
    margin: 0;
  }

  .tl-marker-dot {
    position: absolute;
    top: -7px;
    left: 50%;
    width: 13px;
    height: 13px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: var(--sl-color-text-accent);
    box-shadow: 0 0 0 2px var(--sl-color-bg-sidebar);
    margin: 0;
  }

  /* ---- the maxDuration wall — the after() tail ends on the same line --- */

  .tl-wall {
    grid-column: 4;
    position: relative;
    width: 0;
    height: 100%;
    margin: 0;
  }

  .tl-wall::before {
    content: "";
    position: absolute;
    top: -10px;
    bottom: -10px;
    left: 0;
    width: 0;
    border-left: 3px dashed var(--sl-color-red, #dc2626);
    margin: 0;
  }

  /* ---- callouts under the track --------------------------------------- */

  .tl-callouts {
    display: grid;
    grid-template-columns: 52fr 0fr 48fr 0fr;
    margin: 9px 0 0;
  }

  .tl-callout {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    margin: 0;
  }

  /* the pivot callout sits at the marker boundary (end of col 1). */
  .tl-callout--marker {
    grid-column: 1;
    align-items: flex-end;
    text-align: right;
    padding-right: 6px;
    font-size: 13px;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .tl-callout-kicker {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-text-accent);
    margin: 0;
  }

  /* the wall callout sits at the right edge (end of col 3). */
  .tl-callout--wall {
    grid-column: 3;
    align-items: flex-end;
    text-align: right;
    padding-right: 2px;
    font-size: 12.5px;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .tl-callout-sub {
    font-size: 10.5px;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  /* ---- time axis ------------------------------------------------------- */

  .tl-axis {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 14px 0 0;
  }

  .tl-axis-line {
    flex: 1;
    height: 0;
    border-top: 1.5px solid var(--sl-color-gray-4);
    position: relative;
    margin: 0;
  }

  .tl-axis-line::after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    border-left: 7px solid var(--sl-color-gray-4);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
  }

  .tl-axis-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: lowercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  /* ---- inline code chips inside the figure ----------------------------- */

  .tl-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.92em;
    font-weight: 700;
    background: transparent;
    padding: 0;
    margin: 0;
    color: inherit;
  }

  .tl-code--dim {
    font-weight: 600;
    color: var(--sl-color-gray-3);
  }

  /* Narrow viewports: shrink type; the strip still reads as one row. */
  @media (max-width: 520px) {
    .tl-head {
      font-size: 12px;
    }
    .tl-head-sub {
      font-size: 10.5px;
    }
    .tl-seg-tag {
      font-size: 10px;
    }
    .tl-callout--marker,
    .tl-callout--wall {
      font-size: 11.5px;
    }
  }
</style>
