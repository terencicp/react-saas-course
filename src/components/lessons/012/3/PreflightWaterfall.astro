---
// DevTools "Network" panel waterfall for the preflight dance, rendered as
// one of four temporal variants of the SAME two-row request list. Used
// inside four <DiagramStep> slots so the lesson's slider scrubs through
// the preflight made visible:
//
//   Step 1 — the OPTIONS preflight row appears, still (pending).
//   Step 2 — the OPTIONS resolves: 204, 38 ms, the timing bar fills.
//   Step 3 — the real POST fires: a second row appears, (pending).
//   Step 4 — the POST returns 200, 120 ms. Two rows for one fetch.
//
// Layout mirrors the Chromium Network panel mock in
// src/components/lessons/010/3/NetworkPanelOverview.astro so the two
// lessons share a visual language. The colour palette is copied from
// there verbatim. Pure HTML + CSS, no script.
//
// Both request rows are ALWAYS present in the grid; in steps 1-2 the POST
// row is rendered as an invisible spacer (visibility: hidden) so the panel
// height never jumps as the reader scrubs — the DiagramSequence stage
// sizes to the tallest step, and every step here is the same height.
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

interface Props {
  step?: 1 | 2 | 3 | 4;
}

const { step = 1 } = Astro.props;

// --- Palette (copied from NetworkPanelOverview for cross-lesson parity) ---
const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BORDER = "#3a3a3a";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const STATUS_OK = "#86efac"; // 2xx
const METHOD_OPTIONS = "#7dd3fc"; // cyan — the preflight method
const METHOD_POST = "#c4b5fd"; // violet — the real request method
const WATERFALL_OPTIONS = "#38bdf8"; // cyan bar — preflight timing
const WATERFALL_POST = "#22c55e"; // green bar — real request timing
const WATERFALL_TRACK = "#2a2a2a";
const PENDING = "#9ca3af";

const reset = "margin: 0";

const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 12px; line-height: 1.5;";
const uiFont = "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);";

// Shared column template across header + rows so they line up exactly.
const COLS =
  "grid-template-columns: minmax(0, 1.6fr) 86px 96px 72px minmax(0, 1.4fr);";

const headerCell = [
  reset,
  "padding: 4px 10px",
  "font-size: 10px",
  uiFont,
  `color: ${TEXT_MUTED}`,
  "text-transform: uppercase",
  "letter-spacing: 0.04em",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG_ALT}`,
  "white-space: nowrap",
].join("; ");

const cellBase = [
  reset,
  codeFont,
  `color: ${TEXT_BRIGHT}`,
  "padding: 6px 10px",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
  "display: flex",
  "align-items: center",
].join("; ");

// A status pill — green when settled, grey-outline when pending.
const pillBase = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "padding: 1px 8px",
  "border-radius: 999px",
  "font-size: 11px",
  "font-weight: 700",
  uiFont,
  "letter-spacing: 0.02em",
  "line-height: 1.6",
].join("; ");

const pillOk = `${pillBase}; background: rgba(34, 197, 94, 0.16); color: ${STATUS_OK}; border: 1px solid rgba(34, 197, 94, 0.4);`;
const pillPending = `${pillBase}; background: rgba(156, 163, 175, 0.12); color: ${PENDING}; border: 1px solid rgba(156, 163, 175, 0.35);`;

// Spinner ring inside the pending pill.
const spinner = [
  reset,
  "display: inline-block",
  "width: 9px",
  "height: 9px",
  "border-radius: 50%",
  `border: 1.5px solid rgba(156, 163, 175, 0.35)`,
  `border-top-color: ${PENDING}`,
  "flex: 0 0 auto",
].join("; ");

// Method text colour helpers.
const methodCell = (color: string, dim: boolean) =>
  `${cellBase}; color: ${color}; font-weight: 700;${dim ? " opacity: 0.55;" : ""}`;

// A timing bar inside the waterfall column. `offset` and `width` are
// percentages of the column; `pending` draws a partial, striped bar.
const barTrack = [
  reset,
  "position: relative",
  "height: 9px",
  "width: 100%",
  `background: ${WATERFALL_TRACK}`,
  "border-radius: 2px",
  "overflow: hidden",
].join("; ");

const barFill = (offset: number, width: number, color: string, pending: boolean) =>
  [
    reset,
    "position: absolute",
    "top: 0",
    "bottom: 0",
    `left: ${offset}%`,
    `width: ${width}%`,
    pending
      ? `background: repeating-linear-gradient(45deg, ${color}66 0 5px, ${color}33 5px 10px)`
      : `background: ${color}`,
    "border-radius: 2px",
  ].join("; ");

const waterfallCell = `${reset}; padding: 6px 10px; display: flex; align-items: center;`;

// Time-text colour.
const timeCell = (dim: boolean) =>
  `${cellBase}; color: ${TEXT_MUTED}; justify-content: flex-end;${dim ? " opacity: 0.55;" : ""}`;

const nameCell = (dim: boolean) => `${cellBase};${dim ? " opacity: 0.55;" : ""}`;

// Per-step row state.
const optionsSettled = step >= 2; // OPTIONS has resolved (204)
const optionsDim = step >= 3; // dim the settled OPTIONS once POST appears
const postVisible = step >= 3; // the POST row exists
const postSettled = step >= 4; // POST has resolved (200)

const captionTextByStep: Record<number, string> = {
  1: "Your code calls fetch. DevTools shows a single row appear — the preflight OPTIONS, still pending.",
  2: "The server answers the preflight with 204 and the Access-Control-Allow-* headers. The OPTIONS resolves.",
  3: "The headers authorized the request, so the browser now fires the real POST. A second row appears.",
  4: "The POST returns 200 with the body. Two rows for one fetch call — that's the preflight made visible.",
};
---

<div class="not-content pw-root" style={`${reset}; ${uiFont} width: 100%; max-width: 680px; margin-left: auto; margin-right: auto;`} data-step={step}>
  {/* DevTools "Network" panel card */}
  <div
    style={`${reset}; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2);`}
  >
    {/* Mini toolbar so the card reads as the Network panel */}
    <div
      style={`${reset}; padding: 7px 10px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG_ALT};`}
    >
      <span style={`${reset}; display: inline-block; width: 9px; height: 9px; border-radius: 50%; background: #f87171;`} aria-hidden="true"></span>
      <span style={`${reset}; font-size: 11px; color: ${TEXT_BRIGHT}; ${uiFont} border-bottom: 2px solid #60a5fa; padding-bottom: 3px;`}>Network</span>
      <span style={`${reset}; font-size: 11px; color: ${TEXT_DIM}; ${uiFont}`}>Fetch/XHR</span>
      <span style={`${reset}; margin-left: auto; font-size: 11px; color: ${TEXT_MUTED}; ${uiFont}`}>app.acme.com → api.acme.com</span>
    </div>

    {/* Column headers */}
    <div style={`${reset}; display: grid; ${COLS}`}>
      <div style={headerCell}>Name</div>
      <div style={headerCell}>Method</div>
      <div style={headerCell}>Status</div>
      <div style={headerCell}>Time</div>
      <div style={headerCell}>Waterfall</div>
    </div>

    {/* Rows — always two slots, POST hidden (but space-reserved) until step 3 */}
    <div style={`${reset};`}>
      {/* Row 1 — the OPTIONS preflight */}
      <div style={`${reset}; display: grid; ${COLS} border-bottom: 1px solid rgba(58,58,58,0.5);`}>
        <div style={nameCell(optionsDim)}>invoices</div>
        <div style={methodCell(METHOD_OPTIONS, optionsDim)}>OPTIONS</div>
        <div style={cellBase}>
          {optionsSettled ? (
            <span style={`${pillOk}${optionsDim ? " opacity: 0.6;" : ""}`}>204</span>
          ) : (
            <span style={pillPending}><span style={spinner} aria-hidden="true"></span>pending</span>
          )}
        </div>
        <div style={timeCell(optionsDim)}>{optionsSettled ? "38 ms" : "—"}</div>
        <div style={waterfallCell}>
          <div style={`${barTrack}${optionsDim ? " opacity: 0.6;" : ""}`}>
            <div style={barFill(2, optionsSettled ? 16 : 9, WATERFALL_OPTIONS, !optionsSettled)}></div>
          </div>
        </div>
      </div>

      {/* Row 2 — the real POST. Hidden but space-reserved before step 3. */}
      <div
        style={`${reset}; display: grid; ${COLS}${postVisible ? "" : " visibility: hidden;"}`}
        aria-hidden={postVisible ? undefined : "true"}
      >
        <div style={nameCell(false)}>invoices</div>
        <div style={methodCell(METHOD_POST, false)}>POST</div>
        <div style={cellBase}>
          {postSettled ? (
            <span style={pillOk}>200</span>
          ) : (
            <span style={pillPending}><span style={spinner} aria-hidden="true"></span>pending</span>
          )}
        </div>
        <div style={timeCell(false)}>{postSettled ? "120 ms" : "—"}</div>
        <div style={waterfallCell}>
          <div style={barTrack}>
            {/* POST bar starts after the OPTIONS (offset ~20%). */}
            <div style={barFill(20, postSettled ? 60 : 12, WATERFALL_POST, !postSettled)}></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* One-fetch tag under the panel ties the two rows together. */}
  <div
    style={`${reset}; margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 12px; ${uiFont} color: var(--sl-color-gray-3);`}
  >
    <span aria-hidden="true" style={`${reset}; display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: ${postVisible ? WATERFALL_POST : WATERFALL_OPTIONS};`}></span>
    <span style={reset}>
      {step < 3
        ? "One fetch(POST) call — the preflight round trip happens first."
        : "Still one fetch(POST) call — two rows on the wire."}
    </span>
  </div>
</div>

<style>
  @media (max-width: 560px) {
    .pw-root {
      font-size: 11px;
    }
  }
</style>
