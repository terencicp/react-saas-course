---
// Annotated anatomy of one URL: the example string rendered horizontally in
// monospace, with color-coded underline segments beneath each WHATWG field and
// leader lines down to labels naming them. `host` splits into hostname + port;
// an `origin` bracket spans protocol + host above the string.
//
// Geometry is derived from a fixed monospace advance of 9.6px/char starting at
// x = 30, so every underline hugs its character span exactly. All <text> string
// content is wrapped in JS expressions ({'...'}) so remark-smartypants can't
// curl the quotes or rewrite the slashes.

import Figure from '../../../figures/Figure.astro';

// Quiet accent tints from the highlight palette — readable on both themes.
const PROTOCOL = '#a78bfa'; // violet
const HOST = '#60a5fa'; // blue
const PATHNAME = '#34d399'; // green
const SEARCH = '#fbbf24'; // orange
const HASH = '#9ca3af'; // muted
const LEADER = '#9ca3af'; // fixed mid-gray for subordinate lines

const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";
const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// Per-character advance and the x of the string's first glyph.
const W = 9.6;
const X0 = 30;
const xAt = (i: number) => X0 + i * W;

// Baseline of the URL string and the y where underlines sit just below it.
const TEXT_Y = 92;
const UNDER_Y = 102;

// Character-index spans for each field (start inclusive, end exclusive),
// matching 'https://api.acme.com:8443/v1/invoices?status=paid&limit=20#row-7'.
const span = {
  protocol: [0, 6], // https:
  host: [8, 25], // api.acme.com:8443
  hostname: [8, 20], // api.acme.com
  port: [21, 25], // 8443
  pathname: [25, 37], // /v1/invoices
  search: [37, 58], // ?status=paid&limit=20
  hash: [58, 64], // #row-7
  origin: [0, 25], // https://api.acme.com:8443
} as const;

// Mid-x of a span, for centering a leader/label under it.
const mid = ([a, b]: readonly [number, number]) => (xAt(a) + xAt(b)) / 2;
// Left/right edges of a span's underline.
const left = (s: readonly [number, number]) => xAt(s[0]);
const right = (s: readonly [number, number]) => xAt(s[1]);
---

<Figure
  caption="The WHATWG URL model: one string, six named fields, with origin as the read-only shorthand spanning protocol and host."
>
  <svg
    viewBox="0 0 658 212"
    role="img"
    aria-label="The URL https://api.acme.com:8443/v1/invoices?status=paid&limit=20#row-7 broken into its WHATWG fields: protocol (https:), host (api.acme.com:8443) which splits into hostname (api.acme.com) and port (8443), pathname (/v1/invoices), search (?status=paid&limit=20), and hash (#row-7). A bracket above marks origin as protocol plus host."
    xmlns="http://www.w3.org/2000/svg"
    style="width: 100%; height: auto; display: block;"
  >
    {/* ---------- origin bracket above protocol + host ---------- */}
    <g stroke={HOST} stroke-width="1.5" fill="none">
      <path
        d={`M ${left(span.origin)} 46 V 38 H ${right(span.origin)} V 46`}
      />
    </g>
    <text
      x={mid(span.origin)}
      y="30"
      font-family={mono}
      font-size="13"
      font-weight="700"
      fill={HOST}
      text-anchor="middle">{'origin'}</text>
    <text
      x={mid(span.origin)}
      y="62"
      font-family={sans}
      font-size="11"
      fill={LEADER}
      text-anchor="middle">{'read-only · protocol + host'}</text>

    {/* ---------- the URL string, each field in its own color ---------- */}
    <text
      x={X0}
      y={TEXT_Y}
      font-family={mono}
      font-size="16"
      text-anchor="start"
    ><tspan fill={PROTOCOL}>{'https:'}</tspan><tspan fill="currentColor">{'//'}</tspan><tspan fill={HOST}>{'api.acme.com:8443'}</tspan><tspan fill={PATHNAME}>{'/v1/invoices'}</tspan><tspan fill={SEARCH}>{'?status=paid&limit=20'}</tspan><tspan fill={HASH}>{'#row-7'}</tspan></text>

    {/* ---------- color-coded underline segments ---------- */}
    <g stroke-width="3" stroke-linecap="round">
      <line x1={left(span.protocol)} y1={UNDER_Y} x2={right(span.protocol)} y2={UNDER_Y} stroke={PROTOCOL} />
      <line x1={left(span.host)} y1={UNDER_Y} x2={right(span.host)} y2={UNDER_Y} stroke={HOST} />
      <line x1={left(span.pathname)} y1={UNDER_Y} x2={right(span.pathname)} y2={UNDER_Y} stroke={PATHNAME} />
      <line x1={left(span.search)} y1={UNDER_Y} x2={right(span.search)} y2={UNDER_Y} stroke={SEARCH} />
      <line x1={left(span.hash)} y1={UNDER_Y} x2={right(span.hash)} y2={UNDER_Y} stroke={HASH} />
    </g>

    {/* ---------- leader lines + field labels (staggered to avoid overlap) ---------- */}
    <g stroke={LEADER} stroke-width="1" fill="none">
      {/* protocol & search — shallow row */}
      <line x1={mid(span.protocol)} y1={UNDER_Y + 3} x2={mid(span.protocol)} y2="124" />
      <line x1={mid(span.search)} y1={UNDER_Y + 3} x2={mid(span.search)} y2="124" />
      {/* pathname & hash — deep row */}
      <line x1={mid(span.pathname)} y1={UNDER_Y + 3} x2={mid(span.pathname)} y2="162" />
      <line x1={mid(span.hash)} y1={UNDER_Y + 3} x2={mid(span.hash)} y2="162" />
    </g>
    <g font-family={mono} font-size="13" text-anchor="middle">
      <text x={mid(span.protocol)} y="138" fill={PROTOCOL}>{'protocol'}</text>
      <text x={mid(span.pathname)} y="176" fill={PATHNAME}>{'pathname'}</text>
      <text x={mid(span.search)} y="138" fill={SEARCH}>{'search'}</text>
      <text x={mid(span.hash)} y="176" fill={HASH}>{'hash'}</text>
    </g>

    {/* ---------- host label + its hostname / port sub-split ---------- */}
    {/* host leader drops to a label, then a sub-bracket fans into hostname + port */}
    <g stroke={LEADER} stroke-width="1" fill="none">
      <line x1={mid(span.host)} y1={UNDER_Y + 3} x2={mid(span.host)} y2="124" />
    </g>
    <text
      x={mid(span.host)}
      y="138"
      font-family={mono}
      font-size="13"
      fill={HOST}
      text-anchor="middle">{'host'}</text>

    {/* sub-bracket under the host label spanning hostname + port */}
    <g stroke={HOST} stroke-width="1.25" fill="none" opacity="0.85">
      <path
        d={`M ${left(span.hostname)} 150 V 156 H ${right(span.host)} V 150`}
      />
      {/* divider tick between hostname and port */}
      <line x1={(right(span.hostname) + left(span.port)) / 2} y1="156" x2={(right(span.hostname) + left(span.port)) / 2} y2="168" />
    </g>
    <g font-family={mono} font-size="12" text-anchor="middle">
      <text x={mid(span.hostname)} y="182" fill={HOST}>{'hostname'}</text>
      <text x={mid(span.port)} y="182" fill={HOST}>{'port'}</text>
    </g>
    <g font-family={mono} font-size="11" fill={LEADER} text-anchor="middle">
      <text x={mid(span.hostname)} y="200">{'api.acme.com'}</text>
      <text x={mid(span.port)} y="200">{'8443'}</text>
    </g>
  </svg>
</Figure>
