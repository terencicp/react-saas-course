---
// LayeredDefenseGates — Chapter 056 Lesson 3, "When RLS earns its cost".
//
// The lesson's mental-model anchor: a tenant read must clear TWO independent
// gates before it reaches a row, and the gates fail in different ways — so
// "RLS instead of the helper" reads as obviously wrong here, it would mean
// deleting a gate.
//
//   Request ─▶ [Gate 1: Application scope · tenantDb(orgId)]
//           ─▶ [Gate 2: Database policy · RLS]
//           ─▶ Rows
//
// Gate 1 is tinted blue (the course's always-on application default); Gate 2
// is tinted violet (the conditional, per-table database layer). Two distinct
// tints make "two independent layers" a spatial fact rather than a claim.
//
// Pure HTML + CSS per the diagrams guide (a conceptual stack with color-coded
// segments and callout sublabels — not a graph engine). A CSS-grid row of
// blocks separated by thin connector arrows, collapsing to a vertical stack on
// narrow viewports (arrows rotate to point down). `not-content` + a margin:0
// reset on every node defeats Starlight's injected prose margins. Goes inside
// <Figure>, which supplies the card chrome + caption.

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones (project palette) reused verbatim in light + dark; the
// colour itself is the signal — blue = application layer, violet = database
// layer. Tints are derived with color-mix so they track the page background.
const BLUE = '#3178c6'; // application scope — the always-on default
const VIOLET = '#7c3aed'; // database policy — RLS, the conditional layer

// Small shield glyph for each gate header — a gate you must pass through.
const shieldIcon = (accent: string) =>
	`<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="${accent}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin:0;flex:0 0 auto;"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg>`;
---

<Figure>
	<div class="ldg not-content">
		{/* ---- Request ---- */}
		<div class="ldg-pill">Request</div>

		<div class="ldg-arrow" aria-hidden="true"></div>

		{/* ---- Gate 1: application scope ---- */}
		<div class="ldg-gate" style={`--gate: ${BLUE};`}>
			<div class="ldg-gate-head">
				<Fragment set:html={shieldIcon(BLUE)} />
				<span class="ldg-gate-title">Application scope</span>
			</div>
			<code class="ldg-gate-code">tenantDb(orgId)</code>
			<span class="ldg-badge">always on</span>
			<span class="ldg-gate-note">missing filter doesn&rsquo;t compile</span>
		</div>

		<div class="ldg-arrow" aria-hidden="true"></div>

		{/* ---- Gate 2: database policy ---- */}
		<div class="ldg-gate" style={`--gate: ${VIOLET};`}>
			<div class="ldg-gate-head">
				<Fragment set:html={shieldIcon(VIOLET)} />
				<span class="ldg-gate-title">Database policy</span>
			</div>
			<code class="ldg-gate-code">RLS</code>
			<span class="ldg-badge">per-table</span>
			<span class="ldg-gate-note">refuses cross-org rows on every path</span>
		</div>

		<div class="ldg-arrow" aria-hidden="true"></div>

		{/* ---- Rows ---- */}
		<div class="ldg-pill ldg-pill-data">Rows</div>
	</div>
	<Fragment slot="caption">
		A request must clear <em>both</em> gates to read a row. Remove either one
		and the other still holds the line — which is why deleting the helper
		because &ldquo;RLS has it covered&rdquo; is deleting a gate.
	</Fragment>
</Figure>

<style>
	.ldg {
		display: grid;
		grid-template-columns: auto 18px minmax(0, 1fr) 18px minmax(0, 1fr) 18px auto;
		align-items: stretch;
		gap: 0;
		padding: 18px 8px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* Neutral terminals — the request that enters and the rows that come out. */
	.ldg-pill {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: center;
		align-self: center;
		padding: 9px 14px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent);
		color: var(--sl-color-white, #1e293b);
		font-size: 13px;
		font-weight: 700;
		white-space: nowrap;
		margin: 0;
	}

	.ldg-pill-data {
		border-radius: 10px;
	}

	/* A gate — the load-bearing block. `--gate` carries its accent colour. */
	.ldg-gate {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 7px;
		min-width: 0;
		padding: 13px 14px;
		border-radius: 12px;
		border: 1.5px solid color-mix(in srgb, var(--gate) 60%, transparent);
		background: color-mix(in srgb, var(--gate) 11%, transparent);
		text-align: center;
		margin: 0;
	}

	.ldg-gate-head {
		display: flex;
		align-items: center;
		gap: 6px;
		margin: 0;
	}

	.ldg-gate-title {
		font-size: 14px;
		font-weight: 700;
		line-height: 1.15;
		color: color-mix(in srgb, var(--gate) 72%, var(--sl-color-text));
		margin: 0;
	}

	/* The mono identifier (tenantDb / RLS). Override Starlight's inline-code
	   pill so it reads as a clean monospace label inside the gate. */
	.ldg-gate-code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 13px;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		border: 0;
		padding: 0;
		margin: 0;
	}

	.ldg-badge {
		display: inline-flex;
		align-items: center;
		padding: 2px 9px;
		border-radius: 999px;
		background: var(--gate);
		color: #ffffff;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.02em;
		white-space: nowrap;
		margin: 0;
	}

	.ldg-gate-note {
		font-size: 11.5px;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #475569);
		margin: 2px 0 0;
	}

	/* Horizontal connector arrows between blocks. */
	.ldg-arrow {
		position: relative;
		align-self: center;
		width: 100%;
		height: 2px;
		background: color-mix(in srgb, currentColor 34%, transparent);
		margin: 0;
	}

	.ldg-arrow::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1px;
		width: 0;
		height: 0;
		border-top: 5px solid transparent;
		border-bottom: 5px solid transparent;
		border-left: 7px solid color-mix(in srgb, currentColor 44%, transparent);
		transform: translateY(-50%);
	}

	/* Narrow viewports: a 7-track horizontal grid would crush, so collapse to
	   one column and rotate the connector arrows to point downward. */
	@media (max-width: 720px) {
		.ldg {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 0;
		}

		.ldg-pill,
		.ldg-gate {
			width: 100%;
			max-width: 320px;
		}

		.ldg-arrow {
			width: 2px;
			height: 20px;
			margin: 8px 0;
		}

		.ldg-arrow::after {
			top: auto;
			right: 50%;
			bottom: -1px;
			border-top: 7px solid color-mix(in srgb, currentColor 44%, transparent);
			border-bottom: none;
			border-left: 5px solid transparent;
			border-right: 5px solid transparent;
			transform: translateX(50%);
		}
	}
</style>
