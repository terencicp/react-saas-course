---
// registry-to-surface — a horizontal three-box flow showing how the single
// tenant-table list drives what the scoped client will let you reach.
//
//   TENANT_TABLES (the registry, one source of truth)
//     -> tenantDb(orgId) (typed factory: maps the registry into the query surface)
//       -> scoped query surface (what compiles): invoices/customers/member allowed,
//          a non-registered table like `user` is a type error.
//
// The pedagogical goal is to make the type machinery read as plumbing: a list of
// names flows into a factory, and the factory's surface is exactly those names.
// Static figure — no interactivity.
//
// Pure HTML + CSS in the house style: a `not-content` wrapper, Starlight gray
// variables for dim chrome, saturated green/red mid-tones for the allow/deny
// signal (so they read in both light and dark themes), SVG connector arrows, and
// a `margin: 0` reset on every inner element to defeat Starlight's prose-margin
// selector. On narrow widths the row wraps to a column.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const GREEN = "#16a34a"; // green-600 — allowed, in the registry
const RED = "#dc2626"; // red-600   — denied, not in the registry

// ---- shared styles ------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: row",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 6px",
  "row-gap: 16px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// Each box is a roughly-equal flex column. min-width keeps it readable but lets
// the row wrap to a column on narrow figure cards.
const box = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 200px",
  "min-width: 190px",
  "max-width: 280px",
  "border: 1px solid var(--sl-color-gray-4)",
  "border-radius: 11px",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "padding: 13px 14px 14px",
  "display: flex",
  "flex-direction: column",
  "gap: 9px",
].join("; ");

const heading = `${reset}; ${mono}; font-size: 14px; font-weight: 700; line-height: 1.25; color: var(--sl-color-white);`;

const subtitle = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "line-height: 1.25",
  "color: var(--sl-color-gray-3)",
].join("; ");

const headBlock = `${reset}; display: flex; flex-direction: column; gap: 3px; padding-bottom: 9px; border-bottom: 1px solid var(--sl-color-gray-5);`;

// Body note (plain prose inside a box).
const note = `${reset}; ${sans}; font-size: 12px; line-height: 1.4; color: var(--sl-color-gray-2);`;

// A monospace pill for a table name inside the registry box.
const pill = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 5px 9px",
  "border-radius: 7px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-white)",
  "white-space: nowrap",
].join("; ");

const pillRow = `${reset}; display: flex; flex-direction: row; flex-wrap: wrap; gap: 6px;`;

// Allowed / denied rows in the surface box.
const surfaceList = `${reset}; display: flex; flex-direction: column; gap: 7px;`;

const surfaceRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 8px",
  "padding: 6px 9px",
  "border-radius: 8px",
].join("; ");

const allowRow = `${surfaceRow}; border: 1px solid color-mix(in srgb, ${GREEN} 45%, transparent); background: color-mix(in srgb, ${GREEN} 12%, transparent);`;
const denyRow = `${surfaceRow}; border: 1px solid color-mix(in srgb, ${RED} 45%, transparent); background: color-mix(in srgb, ${RED} 12%, transparent);`;

const surfaceCode = `${reset}; ${mono}; font-size: 12.5px; font-weight: 600; line-height: 1.2; flex: 1 1 auto; min-width: 0;`;

const denyNote = `${reset}; ${sans}; font-size: 10px; font-weight: 600; line-height: 1.25; color: color-mix(in srgb, ${RED} 80%, var(--sl-color-text)); margin-top: 4px;`;

// The check / cross glyph sits in a fixed-size badge so the rows align.
const badge = (c: string) =>
  [
    reset,
    "flex: 0 0 auto",
    "width: 17px",
    "height: 17px",
    "border-radius: 50%",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    `background: ${c}`,
  ].join("; ");

// Connector cell between two boxes: a horizontal arrow that collapses to a
// rotated down-arrow when the row wraps. We keep it simple — a flex item that
// shrinks to nothing if it can't fit, so wrapping reads cleanly.
const arrowCell = [
  reset,
  "flex: 0 0 auto",
  "align-self: center",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "padding: 0 1px",
].join("; ");
---

<div class="not-content" style={root}>
  {/* Box 1 — the registry */}
  <div style={box}>
    <div style={headBlock}>
      <span style={heading}>TENANT_TABLES</span>
      <span style={subtitle}>the registry — one source of truth</span>
    </div>
    <div style={pillRow}>
      <span style={pill}>invoices</span>
      <span style={pill}>customers</span>
      <span style={pill}>member</span>
    </div>
  </div>

  {/* arrow 1 -> 2 */}
  <div style={arrowCell}>
    <svg
      width="34"
      height="16"
      viewBox="0 0 34 16"
      role="img"
      aria-label="feeds"
      style="margin: 0; display: block;"
    >
      <line
        x1="0"
        y1="8"
        x2="24"
        y2="8"
        stroke="var(--sl-color-gray-3)"
        stroke-width="2"></line>
      <path d="M 34 8 L 23 3 L 23 13 Z" fill="var(--sl-color-gray-3)"></path>
    </svg>
  </div>

  {/* Box 2 — the typed factory */}
  <div style={box}>
    <div style={headBlock}>
      <span style={heading}>tenantDb(orgId)</span>
      <span style={subtitle}>typed factory</span>
    </div>
    <p style={note}>
      Maps the registry into the <code
        style={`${mono}; background: transparent; padding: 0; font-size: 12px; color: var(--sl-color-white);`}
        >query</code
      > surface — one key per registered table, and no others.
    </p>
  </div>

  {/* arrow 2 -> 3 */}
  <div style={arrowCell}>
    <svg
      width="34"
      height="16"
      viewBox="0 0 34 16"
      role="img"
      aria-label="produces"
      style="margin: 0; display: block;"
    >
      <line
        x1="0"
        y1="8"
        x2="24"
        y2="8"
        stroke="var(--sl-color-gray-3)"
        stroke-width="2"></line>
      <path d="M 34 8 L 23 3 L 23 13 Z" fill="var(--sl-color-gray-3)"></path>
    </svg>
  </div>

  {/* Box 3 — the scoped query surface */}
  <div style={box}>
    <div style={headBlock}>
      <span style={heading}>scoped query surface</span>
      <span style={subtitle}>what compiles</span>
    </div>
    <div style={surfaceList}>
      <div style={allowRow}>
        <span style={badge(GREEN)}>
          <svg
            width="10"
            height="10"
            viewBox="0 0 12 12"
            aria-hidden="true"
            style="margin: 0; display: block;"
          >
            <path
              d="M2 6.5 L5 9.2 L10 3"
              fill="none"
              stroke="#fff"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <span style={surfaceCode}>query.invoices</span>
      </div>
      <div style={allowRow}>
        <span style={badge(GREEN)}>
          <svg
            width="10"
            height="10"
            viewBox="0 0 12 12"
            aria-hidden="true"
            style="margin: 0; display: block;"
          >
            <path
              d="M2 6.5 L5 9.2 L10 3"
              fill="none"
              stroke="#fff"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <span style={surfaceCode}>query.customers</span>
      </div>
      <div style={allowRow}>
        <span style={badge(GREEN)}>
          <svg
            width="10"
            height="10"
            viewBox="0 0 12 12"
            aria-hidden="true"
            style="margin: 0; display: block;"
          >
            <path
              d="M2 6.5 L5 9.2 L10 3"
              fill="none"
              stroke="#fff"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <span style={surfaceCode}>query.member</span>
      </div>
      <div style={denyRow}>
        <span style={badge(RED)}>
          <svg
            width="10"
            height="10"
            viewBox="0 0 12 12"
            aria-hidden="true"
            style="margin: 0; display: block;"
          >
            <path
              d="M3 3 L9 9 M9 3 L3 9"
              fill="none"
              stroke="#fff"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
        </span>
        <div style={`${reset}; display: flex; flex-direction: column; min-width: 0;`}>
          <span style={surfaceCode}>query.user</span>
          <span style={denyNote}>not in registry &rarr; type error</span>
        </div>
      </div>
    </div>
  </div>
</div>
