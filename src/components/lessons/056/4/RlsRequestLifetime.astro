---
// RlsRequestLifetime — Chapter 056 Lesson 4 ("Wiring RLS on audit_logs"),
// the centerpiece DiagramSequence for the "Reading the request lifetime end to
// end" section.
//
// Goal: make the *timing* of the `app.org_id` session variable something the
// reader SEES rather than takes on faith — it is set only AFTER the transaction
// opens, cleared BY the commit, and the connection returns to the pool carrying
// nothing. The final step (clean return) is the whole reason the figure exists,
// and is the direct antidote to the SET-vs-SET-LOCAL pooled-connection footgun.
//
// Composition (same fixed picture across all six steps so scrubbing animates one
// diagram, not six):
//   1. A horizontal STAGE STRIP of the stack — the five boxes the write travels
//      through. Exactly the active stage(s) light up per step.
//        Server Action → withTenant (tx) → Connection → Postgres + policy → Pool
//   2. A persistent `app.org_id` STATE CHIP — the load-bearing element. Its value
//      and colour change across the steps: unset → unset → org A → org A →
//      cleared → empty. Following this one chip is the point of the figure.
//   3. A per-step OPERATION line showing the concrete call / SQL that runs.
//
// DiagramSequence supplies the outer card + per-step captions, so this is NOT
// wrapped in <Figure>. Pure HTML+CSS, scoped, devtools-inspectable.
//
// Colour language: the org-A tenant identity is the orange the AnnotatedCode
// blocks use for `set_config`/`current_setting` (#d97706); green (#16a34a) marks
// the WITH CHECK pass; red/grey marks the "unset / cleared / fail-closed" empty
// states. Neutral greys carry the inactive stack.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The five stack stages, in order. `key` is matched against each step's set of
// active stages to drive the highlight.
const stages = [
  { key: "action", label: "Server Action" },
  { key: "withtenant", label: "withTenant", sub: "transaction" },
  { key: "conn", label: "Connection", sub: "pooled" },
  { key: "pg", label: "Postgres", sub: "+ policy" },
  { key: "pool", label: "Pool" },
];

// Per-step config.
//   active   — the lit stage keys for this step.
//   varState — drives the app.org_id chip: "none" (unset/empty), "set" (holds
//              org A), "cleared" (the moment COMMIT discards it).
//   op       — the concrete call / SQL running this step (rendered mono).
//   opKind   — tints the op line: "neutral", "pass" (green, WITH CHECK ok),
//              "clear" (the commit), "closed" (fail-closed empty).
type Step = {
  active: string[];
  varState: "none" | "set" | "cleared";
  varValue: string;
  varNote: string;
  op: string;
  opKind: "neutral" | "pass" | "clear" | "closed";
};

const steps: Step[] = [
  {
    active: ["action"],
    varState: "none",
    varValue: "unset",
    varNote: "not set yet",
    op: "requireOrgUser() → trusted orgId",
    opKind: "neutral",
  },
  {
    active: ["withtenant", "conn"],
    varState: "none",
    varValue: "unset",
    varNote: "transaction open, variable still unset",
    op: "checkout connection · BEGIN",
    opKind: "neutral",
  },
  {
    active: ["withtenant", "conn", "pg"],
    varState: "set",
    varValue: "org A",
    varNote: "transaction-local",
    op: "set_config('app.org_id', orgId, true)",
    opKind: "neutral",
  },
  {
    active: ["pg"],
    varState: "set",
    varValue: "org A",
    varNote: "WITH CHECK compares against this",
    op: "INSERT INTO audit_logs … → WITH CHECK passes",
    opKind: "pass",
  },
  {
    active: ["conn", "pg"],
    varState: "cleared",
    varValue: "cleared",
    varNote: "discarded by COMMIT",
    op: "COMMIT → SET LOCAL value discarded",
    opKind: "clear",
  },
  {
    active: ["pool"],
    varState: "none",
    varValue: "unset",
    varNote: "connection carries nothing",
    op: "next request starts fail-closed → 0 rows",
    opKind: "closed",
  },
];

// Per-step captions, rich (inline code), kept beside the step data and rendered
// through the `caption` slot.
const captions = [
  `<strong>Server Action starts.</strong> <code>requireOrgUser()</code> returns a <em>trusted</em> <code>orgId</code> — from the server-validated session, never a URL, route param, or client-passed field.`,
  `<strong><code>withTenant(orgId, …)</code> opens a transaction.</strong> It checks a connection out of the pool and begins an explicit transaction. The variable isn't set yet — the transaction has to exist first, because the variable will be scoped to it.`,
  `<strong><code>set_config('app.org_id', orgId, true)</code> runs.</strong> The policy now has a tenant identity — scoped to this transaction only, by virtue of the <code>true</code> (local) argument.`,
  `<strong><code>INSERT INTO audit_logs …</code></strong> The policy's <code>WITH CHECK</code> verifies <code>organization_id = app.org_id</code>. The values match, so the row is written. (Had they not matched, the insert would be refused.)`,
  `<strong><code>COMMIT</code>.</strong> The transaction commits — and the <code>SET LOCAL</code> value is automatically cleared as part of the commit. Nothing about <code>app.org_id</code> survives.`,
  `<strong>Connection returns to the pool — clean.</strong> It carries <em>no</em> <code>app.org_id</code>. The next request that borrows it starts fail-closed: an unset variable means <code>current_setting('app.org_id', true)</code> is NULL, the comparison is NULL, and NULL excludes every row. This spotless return is exactly what plain <code>SET</code> (without <code>LOCAL</code>) would have broken.`,
];
---

<DiagramSequence>
  {
    steps.map((step, idx) => (
      <DiagramStep>
        <div class="rrl not-content" style={sans}>
          {/* Stage strip — the fixed stack the write travels through. */}
          <div class="rrl-strip">
            {stages.map((stage, i) => (
              <>
                {i > 0 && (
                  <svg
                    class="rrl-arrow"
                    viewBox="0 0 24 12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <line x1="2" y1="6" x2="18" y2="6" />
                    <polyline points="14 2 19 6 14 10" />
                  </svg>
                )}
                <div
                  class:list={[
                    "rrl-stage",
                    { "is-active": step.active.includes(stage.key) },
                  ]}
                >
                  <span class="rrl-stage-label">{stage.label}</span>
                  {stage.sub && <span class="rrl-stage-sub">{stage.sub}</span>}
                </div>
              </>
            ))}
          </div>

          {/* The concrete operation running this step. */}
          <div class={`rrl-op rrl-op--${step.opKind}`}>{step.op}</div>

          {/* The load-bearing variable chip — the thread the reader follows. */}
          <div class={`rrl-var rrl-var--${step.varState}`}>
            <span class="rrl-var-key">app.org_id</span>
            <span class="rrl-var-eq" aria-hidden="true">=</span>
            <span class="rrl-var-val">{step.varValue}</span>
            <span class="rrl-var-note">{step.varNote}</span>
          </div>
        </div>
        <Fragment slot="caption">
          <span set:html={captions[idx]} />
        </Fragment>
      </DiagramStep>
    ))
  }
</DiagramSequence>

<style>
  .rrl {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  /* ── Stage strip ──────────────────────────────────────────────────── */
  .rrl-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 0.4rem;
  }
  .rrl-arrow {
    flex: 0 0 auto;
    width: 22px;
    height: 12px;
    align-self: center;
    color: var(--sl-color-gray-4);
  }
  .rrl-stage {
    flex: 0 1 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    min-width: 6.5rem;
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 10px;
    background: var(--sl-color-gray-6);
    text-align: center;
    transition:
      border-color 0.14s,
      background-color 0.14s,
      box-shadow 0.14s;
  }
  .rrl-stage-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--sl-color-gray-2);
    line-height: 1.15;
  }
  .rrl-stage-sub {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    line-height: 1.1;
  }
  /* The active stage(s) for this step. */
  .rrl-stage.is-active {
    border-color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 14%, var(--sl-color-gray-6));
    box-shadow: 0 0 0 1px var(--sl-color-text-accent);
  }
  .rrl-stage.is-active .rrl-stage-label {
    color: var(--sl-color-white);
  }
  .rrl-stage.is-active .rrl-stage-sub {
    color: var(--sl-color-gray-2);
  }

  /* ── Operation line ───────────────────────────────────────────────── */
  .rrl-op {
    align-self: center;
    max-width: 100%;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      monospace
    );
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sl-color-gray-2);
    text-align: center;
  }
  .rrl-op--pass {
    border-color: color-mix(in srgb, #16a34a 45%, transparent);
    background: color-mix(in srgb, #16a34a 8%, var(--sl-color-bg));
    color: var(--sl-color-white);
  }
  .rrl-op--clear {
    border-color: color-mix(in srgb, #b91c1c 45%, transparent);
    background: color-mix(in srgb, #b91c1c 8%, var(--sl-color-bg));
    color: var(--sl-color-white);
  }
  .rrl-op--closed {
    border-style: dashed;
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-gray-3);
  }

  /* ── app.org_id state chip ────────────────────────────────────────── */
  .rrl-var {
    --rrl-set: #d97706; /* orange — the tenant identity, matches set_config accent */
    --rrl-empty: #b91c1c; /* red — unset / cleared / fail-closed */
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    align-self: center;
    max-width: 100%;
    padding: 0.55rem 0.85rem;
    border-radius: 10px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      monospace
    );
  }
  .rrl-var-key {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--sl-color-gray-2);
  }
  .rrl-var-eq {
    color: var(--sl-color-gray-3);
  }
  .rrl-var-val {
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.12rem 0.55rem;
    border-radius: 6px;
    line-height: 1.3;
  }
  .rrl-var-note {
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
  }

  /* Variable holds org A — orange, present. */
  .rrl-var--set {
    border-color: color-mix(in srgb, var(--rrl-set) 55%, transparent);
    background: color-mix(in srgb, var(--rrl-set) 9%, var(--sl-color-bg));
  }
  .rrl-var--set .rrl-var-val {
    background: color-mix(in srgb, var(--rrl-set) 22%, transparent);
    color: var(--sl-color-white);
    border: 1px solid color-mix(in srgb, var(--rrl-set) 55%, transparent);
  }

  /* Variable unset / empty — muted, dashed, "nothing here". */
  .rrl-var--none {
    border-style: dashed;
    border-color: var(--sl-color-gray-4);
  }
  .rrl-var--none .rrl-var-val {
    background: color-mix(in srgb, var(--sl-color-gray-4) 30%, transparent);
    color: var(--sl-color-gray-2);
    border: 1px dashed var(--sl-color-gray-4);
    text-decoration: line-through;
    text-decoration-color: var(--sl-color-gray-3);
  }

  /* Variable being discarded by the commit — red, the clearing moment. */
  .rrl-var--cleared {
    border-color: color-mix(in srgb, var(--rrl-empty) 50%, transparent);
    background: color-mix(in srgb, var(--rrl-empty) 8%, var(--sl-color-bg));
  }
  .rrl-var--cleared .rrl-var-val {
    background: color-mix(in srgb, var(--rrl-empty) 18%, transparent);
    color: var(--sl-color-white);
    border: 1px solid color-mix(in srgb, var(--rrl-empty) 55%, transparent);
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--rrl-empty) 80%, transparent);
  }

  @media (max-width: 34rem) {
    .rrl-arrow {
      transform: rotate(90deg);
    }
    .rrl-strip {
      flex-direction: column;
      align-items: stretch;
    }
    .rrl-stage {
      min-width: 0;
    }
  }
</style>
