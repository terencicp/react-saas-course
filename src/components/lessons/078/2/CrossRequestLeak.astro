---
/**
 * "Cross-request leak" illustration for Lesson 078.2
 * ("Primitives and the per-request provider").
 *
 * Makes the module-scope leak SPATIAL: one box, many requests.
 *
 *   Left  — two stacked request lanes ("Request A — tenant Acme",
 *           "Request B — tenant Globex"), each arrowing right into the SAME
 *           central store box. A's arrow is a *write*; B's is a *read*.
 *   Right — a single "Server process — module scope" box holding one
 *           "wizard store" instance that visibly carries A's draft
 *           (`email: ada@acme.com`).
 *
 * The payload is the convergence: both arrows land on one box, so B's read
 * picks up A's write. A red warning marker on B's read names the failure.
 *
 * Built in plain HTML/CSS (no engine) so the layout is devtools-inspectable,
 * per the course's HTML/CSS-diagram USP. Saturated red carries the leak signal
 * (survives both themes); Starlight gray variables carry the neutral chrome.
 */
---

<div class="leak">
  {/* ── Left: the two request lanes that both hit the same store ── */}
  <div class="lanes">
    <div class="lane lane--write">
      <div class="lane__head">
        <span class="lane__id">Request A</span>
        <span class="lane__tenant">tenant Acme</span>
      </div>
      <div class="lane__action lane__action--write">
        writes <code>email: ada@acme.com</code>
      </div>
    </div>

    <div class="lane lane--read">
      <div class="lane__head">
        <span class="lane__id">Request B</span>
        <span class="lane__tenant">tenant Globex</span>
      </div>
      <div class="lane__action lane__action--read">
        reads the wizard store
      </div>
    </div>
  </div>

  {/* ── Middle: two arrows converging on the one box ── */}
  <div class="arrows">
    <div class="arrow arrow--write">
      <span class="arrow__label">write</span>
      <span class="arrow__line" aria-hidden="true">&#8594;</span>
    </div>
    <div class="arrow arrow--read">
      <span class="arrow__label">read</span>
      <span class="arrow__line" aria-hidden="true">&#8594;</span>
    </div>
  </div>

  {/* ── Right: the single shared store ── */}
  <div class="server">
    <div class="server__head">Server process &mdash; module scope</div>
    <div class="store">
      <div class="store__name"><code>wizard store</code></div>
      <div class="store__field">
        <span class="store__key">email:</span>
        <span class="store__val">ada@acme.com</span>
      </div>
      <div class="store__field store__field--muted">
        <span class="store__key">name:</span>
        <span class="store__val">Ada Acme</span>
      </div>
    </div>
    <div class="warn">
      <span class="warn__icon" aria-hidden="true">&#9888;</span>
      <span>Request B reads Acme&rsquo;s draft</span>
    </div>
  </div>
</div>

<style>
  .leak {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin: 0;
  }

  /* ── Request lanes ── */
  .lanes {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin: 0;
  }

  .lane {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.7rem 0.85rem;
    margin: 0;
    min-width: 12.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-black);
  }

  .lane__head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0;
  }

  .lane__id {
    font-weight: 600;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-white);
  }

  .lane__tenant {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }

  .lane__action {
    margin: 0;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
  }

  .lane__action code {
    background: transparent;
    padding: 0;
    font-size: 0.72rem;
    color: var(--sl-color-gray-1);
    white-space: nowrap;
  }

  .lane__action--write {
    color: #f87171;
  }

  .lane__action--write code {
    color: #fca5a5;
  }

  /* ── Converging arrows ── */
  .arrows {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.4rem;
    margin: 0;
  }

  .arrow {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin: 0;
    color: #dc2626;
  }

  .arrow__label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #f87171;
  }

  .arrow__line {
    font-size: 1.5rem;
    line-height: 1;
    color: #ef4444;
  }

  /* ── The shared server-process box ── */
  .server {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 0.85rem;
    margin: 0;
    min-width: 14rem;
    border: 1.5px solid var(--sl-color-gray-4);
    border-radius: 0.6rem;
    background: var(--sl-color-gray-7, var(--sl-color-black));
  }

  .server__head {
    margin: 0;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--sl-color-gray-2);
    text-align: center;
  }

  .store {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.7rem;
    margin: 0;
    border: 1.5px solid color-mix(in oklab, #f87171 50%, var(--sl-color-gray-5));
    border-radius: 0.45rem;
    background: color-mix(in oklab, #f87171 9%, var(--sl-color-black));
  }

  .store__name {
    margin: 0 0 0.15rem;
    text-align: center;
  }

  .store__name code {
    background: transparent;
    padding: 0;
    font-weight: 600;
    font-size: var(--sl-text-xs);
    color: #fca5a5;
  }

  .store__field {
    display: flex;
    gap: 0.4rem;
    margin: 0;
    padding: 0.25rem 0.4rem;
    border-radius: 0.3rem;
    background: var(--sl-color-black);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.72rem;
  }

  .store__field--muted {
    opacity: 0.7;
  }

  .store__key {
    color: var(--sl-color-gray-3);
  }

  .store__val {
    color: #fca5a5;
    font-weight: 600;
  }

  .store__field--muted .store__val {
    color: var(--sl-color-gray-2);
    font-weight: 400;
  }

  /* ── Leak warning marker ── */
  .warn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
    padding: 0.4rem 0.55rem;
    border: 1px solid color-mix(in oklab, #dc2626 55%, transparent);
    border-radius: 0.4rem;
    background: color-mix(in oklab, #dc2626 16%, transparent);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    color: #fca5a5;
  }

  .warn__icon {
    font-size: 0.95rem;
    line-height: 1;
    color: #f87171;
  }
</style>
