---
// submit-handoff — Chapter 078 Lesson 3, "The routed wizard, end to end".
//
// The submit boundary made spatial: three responsibilities, three owners,
// no overlap. Reads strictly left→right so the student sees the store STOP
// at the database line.
//
//   WizardStore ──full payload──▶ createCustomer (Server Action) ──on Result.ok──▶ redirect + reset()
//   (assembled draft)             (parse → insert → Result)                        (closes the loop)
//
// The middle box is the only one that touches the database — it carries a
// slightly heavier, accent-tinted border so the eye lands on it as the
// persistence owner. The first box is client-only (the store), the third is
// the client again (navigation + reset). The line that matters is between
// box 1 and box 2: the store hands off and goes no further.
//
// Built with <ArrowDiagram> (LeaderLine) because each box is two-line custom
// HTML (a code/title line + a muted under-label) and the two arrows need
// distinct direction labels ("full payload", "on Result.ok") that D2/Mermaid
// plain-label boxes wouldn't carry as cleanly. Arrows are positioned from
// document.body, so the wrapping <Figure> MUST be expandable={false}.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark). A margin:0
// reset on every node defeats Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const arrows = [
	// The handoff: store → action. The draft leaves the client as a full payload.
	{
		from: 'sh-store',
		to: 'sh-action',
		label: 'full payload',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -24],
	},
	// The return path: action → client, only once the Result is ok.
	{
		from: 'sh-action',
		to: 'sh-redirect',
		label: 'on Result.ok',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -24],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="sh not-content">
			{/* ── Owner 1: the store holds the draft and stops here ── */}
			<div class="sh-box" id="sh-store">
				<span class="sh-tag">client</span>
				<span class="sh-title"><code>WizardStore</code></span>
				<span class="sh-under">the assembled draft (four slices)</span>
			</div>

			{/* ── Owner 2: the Server Action — the only box at the database line ── */}
			<div class="sh-box sh-box--action" id="sh-action">
				<span class="sh-tag sh-tag--server">server</span>
				<span class="sh-title"><code>createCustomer</code> Server Action</span>
				<span class="sh-under">parse → insert → Result</span>
			</div>

			{/* ── Owner 3: back on the client — redirect closes the loop ── */}
			<div class="sh-box" id="sh-redirect">
				<span class="sh-tag">client</span>
				<span class="sh-title"
					><code>router.push('/customers/[id]')</code> + <code>reset()</code></span
				>
				<span class="sh-under">redirect closes the loop</span>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		Three responsibilities, three owners: the store holds the draft, the action
		persists it, the redirect closes the loop.
	</Fragment>
</Figure>

<style>
	.sh {
		display: flex;
		flex-wrap: nowrap;
		align-items: stretch;
		justify-content: space-between;
		gap: 88px;
		margin: 0;
		padding: 18px 6px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.sh-box {
		box-sizing: border-box;
		display: flex;
		flex: 1 1 0;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 5px;
		padding: 14px 16px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	/* The Server Action is the focal box — the only one at the database line.
	   A heavier, accent-tinted border lands the eye here as the persistence owner. */
	.sh-box--action {
		border-color: var(--sl-color-text-accent, #3b82f6);
		border-width: 2px;
		background: var(--sl-color-accent-low, transparent);
	}

	.sh-tag {
		font-size: 0.58rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.sh-tag--server {
		color: var(--sl-color-text-accent, #3b82f6);
	}

	.sh-title {
		font-size: 0.86rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.sh-title code {
		background: transparent;
		padding: 0;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		color: inherit;
	}

	.sh-under {
		font-size: 0.7rem;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: stack the three boxes. The right→left sockets degrade to
	   vertical arcs between stacked boxes — readable, and the labels still float
	   in the gaps. */
	@media (max-width: 720px) {
		.sh {
			flex-direction: column;
			align-items: center;
			gap: 52px;
		}
		.sh-box {
			width: min(20rem, 100%);
			flex: 0 0 auto;
		}
	}
</style>
