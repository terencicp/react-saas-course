---
// navigation-frame — Chapter 078 Lesson 3, "The routed wizard, end to end".
//
// One frame of the scrubbable navigation sequence (navigation-sequence). It is
// the SAME four-segment phase strip the student met in "The screen" figure
// (step-1 Contact → step-4 Review), now with two additions per frame:
//   1. the current step is marked (accent border + filled dot on the connector),
//   2. a store-state band underneath shows what the WizardStore holds right now.
//
// Reusing the strip markup is the whole point: across the four DiagramSteps the
// student should read ONE screen evolving, not four unrelated pictures. The only
// things that change frame-to-frame are the `current` marker, the `band` text,
// and the `tag` (preserved / lost / discarded). Those are the three props.
//
// `state` switches the band's tone: "kept" (accent) vs "gone" (muted/dashed) so
// an empty `{ }` reads visibly as *cleared*, not just blank.
//
// Theme-aware via Starlight gray/white/accent vars (flip light/dark). A margin:0
// reset on nodes keeps Starlight's injected prose margins out of the frame.

interface Props {
	/** 1-based current step (1–4); marks the matching segment. */
	current: number;
	/** Store-state band contents, e.g. "{ contact: ✓ }" or "{ }". */
	band: string;
	/** Short status word shown as a pill: preserved | lost | discarded. */
	tag: string;
	/** Band tone: kept = accent (data present), gone = muted/dashed (cleared). */
	state: 'kept' | 'gone';
}

const { current, band, tag, state } = Astro.props;

const steps = [
	{ seg: 'step-1', label: 'Contact' },
	{ seg: 'step-2', label: 'Billing' },
	{ seg: 'step-3', label: 'Preferences' },
	{ seg: 'step-4', label: 'Review' },
];
---

<div class="nf not-content">
	{/* ── The four route segments — the same strip as "The screen" figure ── */}
	<div class="nf-strip">
		{
			steps.map((s, i) => (
				<div class:list={['nf-seg', { 'nf-seg--current': i + 1 === current }]}>
					<div class="nf-seg-route">{s.seg}</div>
					<div class="nf-seg-label">{s.label}</div>
					{i + 1 === current && <div class="nf-seg-here">you are here</div>}
				</div>
			))
		}
	</div>

	{/* ── Connectors: one filled under the current step, rest hollow ── */}
	<div class="nf-connectors">
		{
			steps.map((_, i) => (
				<div
					class:list={[
						'nf-conn',
						{ 'nf-conn--current': i + 1 === current },
					]}
				/>
			))
		}
	</div>

	{/* ── The store-state band spanning all four — the thing being watched ── */}
	<div class:list={['nf-band', `nf-band--${state}`]}>
		<span class="nf-band-name">
			one <code>WizardStore</code> instance, pinned on the shared layout
		</span>
		<span class="nf-band-state">
			<code class="nf-band-code">{band}</code>
			<span class:list={['nf-pill', `nf-pill--${state}`]}>{tag}</span>
		</span>
	</div>
</div>

<style>
	.nf {
		box-sizing: border-box;
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── Phase strip ── */
	.nf-strip {
		display: flex;
		gap: 10px;
		margin: 0;
	}

	.nf-seg {
		box-sizing: border-box;
		flex: 1;
		min-width: 0;
		border: 1px solid var(--sl-color-gray-4, #94a3b8);
		border-radius: 8px;
		background: var(--sl-color-bg, transparent);
		padding: 10px 8px;
		text-align: center;
		margin: 0;
		transition:
			border-color 0.15s ease,
			background 0.15s ease;
	}

	/* The current segment lights up: accent border + tinted fill. */
	.nf-seg--current {
		border-color: var(--sl-color-text-accent, #3b82f6);
		border-width: 2px;
		background: var(--sl-color-accent-low, transparent);
		padding: 9px 7px; /* compensate the +1px border so width holds */
	}

	.nf-seg-route {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.78rem;
		color: var(--sl-color-text-accent, #3b82f6);
		margin: 0;
	}

	.nf-seg-label {
		font-weight: 600;
		font-size: 0.9rem;
		color: var(--sl-color-white, #1e293b);
		margin: 4px 0 0;
	}

	.nf-seg-here {
		font-size: 0.56rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-text-accent, #3b82f6);
		margin: 3px 0 0;
	}

	/* ── Connectors ── */
	.nf-connectors {
		display: flex;
		justify-content: space-around;
		margin: 0;
	}

	.nf-conn {
		width: 2px;
		height: 14px;
		background: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	.nf-conn--current {
		width: 3px;
		background: var(--sl-color-text-accent, #3b82f6);
	}

	/* ── Store-state band ── */
	.nf-band {
		box-sizing: border-box;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 8px 14px;
		width: 100%;
		border: 1px solid var(--sl-color-text-accent, #3b82f6);
		border-radius: 8px;
		background: var(--sl-color-accent-low, transparent);
		padding: 12px 14px;
		margin: 0;
	}

	/* When the store is cleared, drain the band's color so empty reads as *gone*. */
	.nf-band--gone {
		border-color: var(--sl-color-gray-4, #94a3b8);
		border-style: dashed;
		background: var(--sl-color-bg, transparent);
	}

	.nf-band-name {
		font-size: 0.84rem;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.nf-band--gone .nf-band-name {
		color: var(--sl-color-gray-3, #64748b);
	}

	.nf-band-name code {
		background: transparent;
		padding: 0;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.8rem;
		color: inherit;
	}

	.nf-band-state {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin: 0;
	}

	.nf-band-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, rgba(148, 163, 184, 0.15));
		border-radius: 5px;
		padding: 2px 8px;
		margin: 0;
	}

	.nf-band--gone .nf-band-code {
		color: var(--sl-color-gray-3, #64748b);
	}

	/* Status pill: green-tinted for kept, muted for cleared. */
	.nf-pill {
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		border-radius: 999px;
		padding: 3px 9px;
		margin: 0;
	}

	.nf-pill--kept {
		color: var(--sl-color-green-high, #16a34a);
		background: var(--sl-color-green-low, rgba(34, 197, 94, 0.14));
	}

	.nf-pill--gone {
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, rgba(148, 163, 184, 0.18));
	}

	/* Narrow viewports: let the band wrap its two halves onto separate lines. */
	@media (max-width: 560px) {
		.nf-seg-route {
			font-size: 0.72rem;
		}
		.nf-seg-label {
			font-size: 0.82rem;
		}
		.nf-band {
			justify-content: center;
			text-align: center;
		}
	}
</style>
