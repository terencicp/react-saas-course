---
/**
 * "What does not clear the bar" reference table for Lesson 078.1.
 *
 * The negative-case companion to DefaultsMapTable: each row is a workload that
 * looks like it might want a global store, paired with the default that already
 * owns it — so Zustand never enters the picture. The teaching reflex the table
 * drills is "name the default out loud," which is why the right-hand column
 * always leads with a concrete tool, not a vague category.
 *
 * Shares DefaultsMapTable's styled-card treatment exactly: hairline row
 * dividers, comfortable padding, uppercase column heads, and monospace for the
 * literal API/library identifiers in the "Lives in" column.
 *
 * The "Lives in" cell is authored as an array of inline tokens so a literal API
 * or library name (useState, nuqs, auth()) renders as <code> while the
 * surrounding qualifier stays plain prose.
 */

interface Token {
  /** The token's text. */
  text: string;
  /** Render the token as inline <code> when it's a literal identifier. */
  code?: boolean;
}

interface Row {
  /** The workload that tempts a store. */
  workload: string;
  /** Where it actually lives — a mix of code tokens and prose. */
  livesIn: Token[];
}

const rows: Row[] = [
  {
    workload: "A single page's form state",
    livesIn: [
      { text: 'useState', code: true },
      { text: ', or ' },
      { text: 'React Hook Form', code: true },
      {
        text:
          ' once a form crosses the multi-field / multi-step threshold (Chapter 045).',
      },
    ],
  },
  {
    workload: 'Theme or locale the whole app reads',
    livesIn: [
      { text: 'React Context', code: true },
      {
        text:
          ' — reads are rare, so the whole-tree re-render costs nothing.',
      },
    ],
  },
  {
    workload: 'Filter, sort, search, cursor pagination',
    livesIn: [
      { text: 'nuqs', code: true },
      { text: ' plus ' },
      { text: 'Server Components', code: true },
      {
        text:
          ' — it belongs in the URL so it survives a refresh and a shared link.',
      },
    ],
  },
  {
    workload: 'Server data the client polls or optimistically updates',
    livesIn: [
      { text: 'TanStack Query', code: true },
      { text: ' — it owns the cache, the refetch, and the rollback.' },
    ],
  },
  {
    workload: 'Auth session or current user',
    livesIn: [
      { text: 'auth()', code: true },
      { text: ' in a Server Component, or the ' },
      { text: 'Better Auth', code: true },
      { text: ' client hook in a leaf.' },
    ],
  },
];
---

<div class="not-zustand">
  <table>
    <caption class="sr-only">
      Workloads that look like global state and the default that owns each one
      instead of Zustand
    </caption>
    <thead>
      <tr>
        <th scope="col">Workload</th>
        <th scope="col">Lives in — not Zustand</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            <th scope="row" class="workload">
              {row.workload}
            </th>
            <td class="lives-in">
              {row.livesIn.map((token) =>
                token.code ? <code>{token.text}</code> : <span>{token.text}</span>,
              )}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  table {
    width: 100%;
    margin: 0;
    border-collapse: collapse;
    font-size: var(--sl-text-sm);
    line-height: 1.45;
  }

  /* Accessible name only; the visible heading sits in the surrounding prose. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  thead th {
    text-align: left;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding: 0 1rem 0.6rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  /* The workload column carries the shorter labels; give the prose-heavy
   * "Lives in" column the larger share. */
  thead th:first-child {
    width: 40%;
  }

  tbody th,
  tbody td {
    padding: 0.75rem 1rem;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-hairline-shade);
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: 0;
  }

  /* The workload column: the row's identifier, in the white reading color. */
  .workload {
    text-align: left;
    font-weight: 400;
    color: var(--sl-color-white);
    line-height: 1.4;
  }

  /* The "Lives in" column: prose with monospace tokens for literal names. */
  .lives-in {
    color: var(--sl-color-gray-2);
  }

  .lives-in code {
    background: var(--sl-color-gray-6);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.95em;
    color: var(--sl-color-white);
  }
</style>
