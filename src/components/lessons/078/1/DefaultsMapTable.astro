---
/**
 * Defaults-map reference table for Lesson 078.1.
 *
 * A glance-back recall card: the five client-state defaults the student already
 * owns, each paired with the one shape of state it owns. The triggers later in
 * the lesson are defined entirely by contrast with these rows, so this is the
 * map the rest of the lesson reads against — kept compact and scannable, not
 * prose.
 *
 * The "Default" cell is rendered in monospace. Where a default is a literal
 * API name (`useState`, `useReducer`, `nuqs`) it reads as inline code; the two
 * conceptual defaults (lifted state + Context, TanStack Query) are plain
 * monospace labels.
 */

interface Row {
  /** The default's name. */
  name: string;
  /** Render the name as inline <code> when it's a literal API identifier. */
  code?: boolean;
  /** Optional gloss rendered under the name, e.g. "(URL state)". */
  sub?: string;
  /** What shape of state this default owns. */
  owns: string;
}

const rows: Row[] = [
  {
    name: 'useState',
    code: true,
    owns: 'Transient local UI state one component owns — a toggle, an input value, an open/closed flag.',
  },
  {
    name: 'useReducer',
    code: true,
    owns: 'Related local state with coordinated transitions — the threshold where three-plus useState values always update together.',
  },
  {
    name: 'Lifted state + React Context',
    owns: 'Narrowly shared state read by consumers under one provider in one subtree, written rarely.',
  },
  {
    name: 'nuqs',
    code: true,
    sub: 'URL state',
    owns: 'Shareable view state — filters, sort, search, cursor pagination — that belongs in the address bar.',
  },
  {
    name: 'TanStack Query',
    owns: 'Client-side server state, on its four triggers: polling, cross-view caching, optimistic-with-rollback, infinite scroll.',
  },
];
---

<div class="defaults-map">
  <table>
    <caption class="sr-only">
      The five client-state defaults and the shape of state each one owns
    </caption>
    <thead>
      <tr>
        <th scope="col">Default</th>
        <th scope="col">What it owns</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            <th scope="row" class="default">
              {row.code ? <code>{row.name}</code> : <span>{row.name}</span>}
              {row.sub && <span class="sub">{row.sub}</span>}
            </th>
            <td>{row.owns}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  table {
    width: 100%;
    margin: 0;
    border-collapse: collapse;
    font-size: var(--sl-text-sm);
    line-height: 1.45;
  }

  /* Accessible name only; the visible heading sits in the surrounding prose. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  thead th {
    text-align: left;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding: 0 1rem 0.6rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  /* The "Default" column gets a comfortable fixed share so the monospace
   * names sit in their own quiet gutter and the prose column does the reading. */
  thead th:first-child {
    width: 34%;
  }

  tbody th,
  tbody td {
    padding: 0.75rem 1rem;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-hairline-shade);
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: 0;
  }

  /* The default-name column: monospace, the row's identifier. */
  .default {
    text-align: left;
    font-weight: 400;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: var(--sl-color-white);
    line-height: 1.4;
  }

  .default code {
    background: var(--sl-color-gray-6);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.95em;
  }

  .default .sub {
    display: block;
    margin: 0.2rem 0 0;
    font-family: var(--sl-font, system-ui, sans-serif);
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }

  tbody td {
    color: var(--sl-color-gray-2);
  }
</style>
