---
/**
 * "One global store vs one store per feature" comparison illustration for
 * Lesson 078.1 ("When Zustand earns its weight").
 *
 * Two horizontal panels sitting side by side so the reader sees both shapes at
 * once — the contrast IS the lesson:
 *
 *   Left  — the anti-pattern. A single fat `useAppStore` crammed with a grid of
 *           unrelated slice chips, with every feature label funneling inward
 *           into that one box (convergent arrows). Rendered dimmed/desaturated
 *           to read as "do NOT do this."
 *   Right — the rule. Three small, separate store boxes, each sitting beside its
 *           own feature label, no arrows crossing between them. Full opacity.
 *
 * The visual payload: convergence + tangle on the left, small + separate on the
 * right. Built in plain fl/CSS (no engine) so a reader can devtools-inspect the
 * real layout, per the course's HTML/CSS-diagram USP.
 */

// Left panel — the twelve unrelated slices crammed into one module.
const slices = [
  'cart',
  'wizard',
  'palette',
  'theme',
  'modal',
  'toast',
  'sidebar',
  'notifications',
  'auth',
  'filters',
];

// The feature labels that all funnel into the single store on the left.
const funnelFeatures = ['Cart', 'Wizard', 'Palette', 'Theme', 'Modal', 'Toast'];

// Right panel — one named store per feature, each beside the feature it owns.
const perFeature = [
  { store: 'useCartStore', feature: 'Cart' },
  { store: 'useWizardStore', feature: 'Wizard' },
  { store: 'useCommandPaletteStore', feature: 'Command palette' },
];
---

<div class="compare">
  {/* ── Anti-pattern: one global store, everything funnels in ── */}
  <section class="panel panel--anti" aria-label="Anti-pattern: one global store">
    <header class="panel__head">
      <span class="tag tag--anti">Anti-pattern</span>
    </header>

    <div class="funnel">
      <ul class="features features--left">
        {
          funnelFeatures.slice(0, 3).map((f) => (
            <li class="feature">
              <span class="feature__label">{f}</span>
              <span class="feature__arrow">→</span>
            </li>
          ))
        }
      </ul>

      <div class="megastore">
        <div class="megastore__name"><code>useAppStore</code></div>
        <ul class="slices">
          {slices.map((s) => <li class="slice">{s}</li>)}
        </ul>
      </div>

      <ul class="features features--right">
        {
          funnelFeatures.slice(3).map((f) => (
            <li class="feature">
              <span class="feature__arrow">←</span>
              <span class="feature__label">{f}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <p class="panel__note">Every feature funnels into one module.</p>
  </section>

  {/* ── The rule: one small store per feature, no crossing ── */}
  <section class="panel panel--rule" aria-label="The rule: one store per feature">
    <header class="panel__head">
      <span class="tag tag--rule">The rule</span>
    </header>

    <ul class="pairs">
      {
        perFeature.map((p) => (
          <li class="pair">
            <div class="store">
              <code>{p.store}</code>
            </div>
            <span class="pair__link" />
            <span class="pair__feature">{p.feature}</span>
          </li>
        ))
      }
    </ul>

    <p class="panel__note">Each store touches exactly one feature.</p>
  </section>
</div>

<style>
  .compare {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: stretch;
    margin: 0;
  }

  .panel {
    flex: 1 1 320px;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1rem;
    margin: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.6rem;
    background: var(--sl-color-black);
  }

  /* The anti-pattern panel is visibly desaturated and dimmed. */
  .panel--anti {
    filter: grayscale(0.85);
    opacity: 0.78;
  }

  .panel__head {
    margin: 0;
  }

  .tag {
    display: inline-block;
    margin: 0;
    padding: 0.18rem 0.6rem;
    border-radius: 999px;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .tag--anti {
    background: color-mix(in oklab, #f87171 22%, transparent);
    color: #fca5a5;
    border: 1px solid color-mix(in oklab, #f87171 45%, transparent);
  }

  .tag--rule {
    background: color-mix(in oklab, #34d399 20%, transparent);
    color: #6ee7b7;
    border: 1px solid color-mix(in oklab, #34d399 45%, transparent);
  }

  /* ── Left panel: convergent funnel ── */
  .funnel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0;
  }

  .features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .feature {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
  }

  .feature__label {
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.35rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    white-space: nowrap;
  }

  .feature__arrow {
    color: var(--sl-color-gray-4);
    font-size: 1.1rem;
    line-height: 1;
  }

  .megastore {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.7rem;
    margin: 0;
    border: 1.5px solid color-mix(in oklab, #f87171 40%, var(--sl-color-gray-5));
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7, var(--sl-color-black));
  }

  .megastore__name {
    margin: 0;
    text-align: center;
  }

  .megastore__name code {
    background: transparent;
    padding: 0;
    color: #fca5a5;
    font-weight: 600;
    font-size: var(--sl-text-sm);
  }

  .slices {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.3rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .slice {
    margin: 0;
    padding: 0.18rem 0.3rem;
    border-radius: 0.25rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.7rem;
    text-align: center;
    white-space: nowrap;
  }

  /* ── Right panel: one store per feature, no crossing ── */
  .pairs {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pair {
    display: flex;
    align-items: center;
    gap: 0;
    margin: 0;
  }

  .store {
    flex: 0 0 auto;
    padding: 0.4rem 0.6rem;
    border: 1.5px solid color-mix(in oklab, #34d399 45%, var(--sl-color-gray-5));
    border-radius: 0.45rem;
    background: color-mix(in oklab, #34d399 10%, var(--sl-color-black));
  }

  .store code {
    background: transparent;
    padding: 0;
    color: #6ee7b7;
    font-weight: 600;
    font-size: var(--sl-text-xs);
    white-space: nowrap;
  }

  .pair__link {
    flex: 1 1 1rem;
    min-width: 0.75rem;
    height: 0;
    border-top: 1.5px dashed var(--sl-color-gray-4);
    margin: 0 0.1rem;
  }

  .pair__feature {
    flex: 0 0 auto;
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.35rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-size: var(--sl-text-xs);
    white-space: nowrap;
  }

  .panel__note {
    margin: 0;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-xs);
    text-align: center;
  }
</style>
