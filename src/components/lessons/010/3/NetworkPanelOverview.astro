---
// Annotated mock of the Chromium DevTools Network panel.
//
// Layout: a single dark "DevTools window" card with a tab strip on top
// (Network selected, other panel names dim), then a toolbar row with the
// Preserve log / Disable cache checkboxes and the Throttling dropdown,
// then a filter-chip strip (request-type filters), then a two-pane body:
// the request waterfall on the left and the per-request detail pane on
// the right (with its own sub-tab strip: Headers / Payload / Preview /
// Response / Initiator / Timing / Cookies).
//
// Four numbered circular callouts pin the load-bearing regions:
//   1. Preserve log + Disable cache checkboxes (toolbar)
//   2. Throttling dropdown (toolbar)
//   3. Request-type filter chips
//   4. Right-pane request-detail tabs (Headers / Payload / ... )
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BORDER = "#3a3a3a";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const ACCENT = "#60a5fa"; // selected tab + selected row
const STATUS_OK = "#86efac"; // 200
const STATUS_REDIR = "#fbbf24"; // 3xx
const STATUS_ERR = "#f87171"; // 4xx/5xx
const METHOD_GET = "#9cdcfe";
const METHOD_POST = "#c4b5fd";
const TYPE_DOC = "#fbbf24";
const TYPE_FETCH = "#86efac";
const TYPE_JS = "#fde68a";
const TYPE_CSS = "#93c5fd";
const TYPE_IMG = "#f9a8d4";
const TYPE_FONT = "#fca5a5";
const WATERFALL_BAR = "#60a5fa";
const WATERFALL_TIME = "#3b82f6";
const CALLOUT_BG = "#f59e0b";
const CALLOUT_TEXT = "#0b0b0b";

const reset = "margin: 0";

const calloutDot = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 22px",
  "height: 22px",
  "border-radius: 50%",
  `background: ${CALLOUT_BG}`,
  `color: ${CALLOUT_TEXT}`,
  "font-weight: 700",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "box-shadow: 0 0 0 2px rgba(0,0,0,0.5)",
  "flex: 0 0 auto",
].join("; ");

const tabBase = [
  reset,
  "padding: 6px 12px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "border-right: 1px solid " + PANEL_BORDER,
  "white-space: nowrap",
].join("; ");

const tabSelected = `${tabBase}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 4px;`;
const tabDim = `${tabBase}; color: ${TEXT_DIM}; background: ${PANEL_BG_ALT};`;

const subTabBase = [
  reset,
  "padding: 4px 10px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "white-space: nowrap",
].join("; ");
const subTabSelected = `${subTabBase}; color: ${TEXT_BRIGHT}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 2px;`;
const subTabDim = `${subTabBase}; color: ${TEXT_MUTED};`;

const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 11px; line-height: 1.5;";

const calloutLabel = [
  reset,
  "margin-left: 8px",
  "color: var(--sl-color-text)",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
].join("; ");

const calloutRow = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 4px",
].join("; ");

// Toolbar checkbox helpers.
const checkboxBox = (checked: boolean) => [
  reset,
  "display: inline-block",
  "width: 11px",
  "height: 11px",
  "border-radius: 2px",
  `border: 1px solid ${checked ? ACCENT : PANEL_BORDER}`,
  `background: ${checked ? ACCENT : "transparent"}`,
  "vertical-align: middle",
  "position: relative",
  "flex: 0 0 auto",
].join("; ");

const checkboxRow = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  `color: ${TEXT_BRIGHT}`,
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
].join("; ");

// Filter chips
const chipBase = [
  reset,
  "padding: 2px 8px",
  "border-radius: 10px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "white-space: nowrap",
  "border: 1px solid transparent",
].join("; ");
const chipSelected = `${chipBase}; color: ${TEXT_BRIGHT}; background: rgba(96,165,250,0.18); border-color: ${ACCENT};`;
const chipDim = `${chipBase}; color: ${TEXT_MUTED};`;

// Waterfall rows
type Row = {
  name: string;
  status: number;
  method: "GET" | "POST";
  type: string;
  typeColor: string;
  size: string;
  time: string;
  // Waterfall bar: [offsetPct, widthPct]
  bar: [number, number];
};

const rows: Row[] = [
  {
    name: "/",
    status: 200,
    method: "GET",
    type: "document",
    typeColor: TYPE_DOC,
    size: "14.2 kB",
    time: "84 ms",
    bar: [0, 18],
  },
  {
    name: "app.css",
    status: 200,
    method: "GET",
    type: "stylesheet",
    typeColor: TYPE_CSS,
    size: "9.1 kB",
    time: "42 ms",
    bar: [18, 10],
  },
  {
    name: "client.js",
    status: 200,
    method: "GET",
    type: "script",
    typeColor: TYPE_JS,
    size: "78.4 kB",
    time: "121 ms",
    bar: [22, 27],
  },
  {
    name: "/api/me",
    status: 401,
    method: "GET",
    type: "fetch",
    typeColor: TYPE_FETCH,
    size: "—",
    time: "63 ms",
    bar: [49, 13],
  },
  {
    name: "hero.webp",
    status: 200,
    method: "GET",
    type: "image",
    typeColor: TYPE_IMG,
    size: "26.8 kB",
    time: "55 ms",
    bar: [30, 14],
  },
  {
    name: "inter.woff2",
    status: 200,
    method: "GET",
    type: "font",
    typeColor: TYPE_FONT,
    size: "32.0 kB",
    time: "47 ms",
    bar: [32, 11],
  },
];

const SELECTED_IDX = 3; // /api/me row is selected (drives the right pane)

const cellBase = [
  reset,
  codeFont,
  `color: ${TEXT_BRIGHT}`,
  "padding: 3px 8px",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");

const headerCell = [
  reset,
  "padding: 4px 8px",
  "font-size: 10px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  `color: ${TEXT_MUTED}`,
  "text-transform: uppercase",
  "letter-spacing: 0.04em",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG_ALT}`,
  "white-space: nowrap",
].join("; ");

const statusColor = (status: number) => {
  if (status >= 200 && status < 300) return STATUS_OK;
  if (status >= 300 && status < 400) return STATUS_REDIR;
  return STATUS_ERR;
};

const methodColor = (m: string) => (m === "GET" ? METHOD_GET : METHOD_POST);
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 14px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* DevTools window mock */}
  <div
    style={`margin: 0; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2);`}
  >
    {/* Tab strip — panel names (Network selected) */}
    <div
      style={`margin: 0; display: flex; flex-direction: row; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER};`}
    >
      <div style={tabDim}>Elements</div>
      <div style={tabDim}>Console</div>
      <div style={tabDim}>Sources</div>
      <div style={tabSelected}>Network</div>
      <div style={tabDim}>Application</div>
      <div style={tabDim}>Performance</div>
    </div>

    {/* Toolbar row — record/clear, preserve log, disable cache, throttling */}
    <div
      style={`margin: 0; padding: 7px 10px; display: flex; flex-direction: row; align-items: center; gap: 14px; border-bottom: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; position: relative; flex-wrap: wrap;`}
    >
      {/* Record + clear icons (simple glyphs) */}
      <div style="margin: 0; display: inline-flex; align-items: center; gap: 8px;">
        <span style={`${reset}; display: inline-block; width: 9px; height: 9px; border-radius: 50%; background: ${STATUS_ERR};`} aria-hidden="true"></span>
        <span style={`${reset}; display: inline-block; width: 9px; height: 9px; border-radius: 50%; border: 1px solid ${TEXT_MUTED};`} aria-hidden="true"></span>
        <span style={`${reset}; display: inline-block; width: 10px; height: 1px; background: ${TEXT_MUTED};`} aria-hidden="true"></span>
      </div>

      {/* Preserve log + Disable cache — boxed together, callout 1 anchors here */}
      <div style="margin: 0; display: inline-flex; align-items: center; gap: 12px; position: relative;">
        <label style={checkboxRow}>
          <span style={checkboxBox(true)} aria-hidden="true"></span>
          Preserve log
        </label>
        <label style={checkboxRow}>
          <span style={checkboxBox(true)} aria-hidden="true"></span>
          Disable cache
        </label>

        {/* Callout 1 — Preserve log + Disable cache */}
        <div
          style="margin: 0; position: absolute; top: -14px; right: -14px;"
          aria-hidden="true"
        >
          <span style={calloutDot}>1</span>
        </div>
      </div>

      {/* Throttling dropdown — callout 2 */}
      <div style="margin: 0; display: inline-flex; align-items: center; gap: 6px; position: relative;">
        <span style={`${reset}; font-size: 11px; color: ${TEXT_MUTED}; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);`}>
          Throttling:
        </span>
        <span
          style={`${reset}; font-size: 11px; color: ${TEXT_BRIGHT}; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif); padding: 2px 22px 2px 8px; border: 1px solid ${PANEL_BORDER}; border-radius: 3px; background: ${PANEL_BG_ALT}; position: relative; display: inline-block;`}
        >
          Slow 4G
          <span style={`position: absolute; right: 6px; top: 50%; transform: translateY(-50%); color: ${TEXT_MUTED}; font-size: 9px;`} aria-hidden="true">▾</span>
        </span>

        {/* Callout 2 — Throttling dropdown */}
        <div
          style="margin: 0; position: absolute; top: -14px; right: -14px;"
          aria-hidden="true"
        >
          <span style={calloutDot}>2</span>
        </div>
      </div>
    </div>

    {/* Filter strip — request-type chips */}
    <div
      style={`margin: 0; padding: 7px 10px; display: flex; flex-direction: row; align-items: center; gap: 6px; border-bottom: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; position: relative; flex-wrap: wrap;`}
    >
      <span style={chipDim}>All</span>
      <span style={chipSelected}>Fetch/XHR</span>
      <span style={chipDim}>Doc</span>
      <span style={chipDim}>CSS</span>
      <span style={chipDim}>JS</span>
      <span style={chipDim}>Font</span>
      <span style={chipDim}>Img</span>
      <span style={chipDim}>Media</span>
      <span style={chipDim}>WS</span>
      <span style={chipDim}>Wasm</span>
      <span style={chipDim}>Other</span>

      {/* Callout 3 — Filter chips */}
      <div
        style="margin: 0; position: absolute; top: -10px; right: 8px;"
        aria-hidden="true"
      >
        <span style={calloutDot}>3</span>
      </div>
    </div>

    {/* Two-pane body: waterfall on the left, request detail on the right */}
    <div
      style="margin: 0; display: grid; grid-template-columns: 1.35fr 1fr; min-height: 260px;"
    >
      {/* Left pane: request list / waterfall */}
      <div
        style={`margin: 0; border-right: 1px solid ${PANEL_BORDER}; min-width: 0; display: grid; grid-template-rows: auto 1fr;`}
      >
        {/* Column headers */}
        <div
          style="margin: 0; display: grid; grid-template-columns: minmax(0, 1.4fr) 56px 64px minmax(0, 1.1fr) 64px 64px minmax(0, 1.2fr);"
        >
          <div style={headerCell}>Name</div>
          <div style={headerCell}>Status</div>
          <div style={headerCell}>Method</div>
          <div style={headerCell}>Type</div>
          <div style={headerCell}>Size</div>
          <div style={headerCell}>Time</div>
          <div style={headerCell}>Waterfall</div>
        </div>

        {/* Rows */}
        <div style="margin: 0;">
          {rows.map((row, i) => {
            const selected = i === SELECTED_IDX;
            const rowStyle = selected
              ? `margin: 0; display: grid; grid-template-columns: minmax(0, 1.4fr) 56px 64px minmax(0, 1.1fr) 64px 64px minmax(0, 1.2fr); background: rgba(96,165,250,0.18); border-left: 2px solid ${ACCENT};`
              : "margin: 0; display: grid; grid-template-columns: minmax(0, 1.4fr) 56px 64px minmax(0, 1.1fr) 64px 64px minmax(0, 1.2fr);";
            return (
              <div style={rowStyle}>
                <div style={cellBase}>{row.name}</div>
                <div style={`${cellBase}; color: ${statusColor(row.status)};`}>
                  {row.status}
                </div>
                <div style={`${cellBase}; color: ${methodColor(row.method)};`}>
                  {row.method}
                </div>
                <div style={`${cellBase}; color: ${row.typeColor};`}>{row.type}</div>
                <div style={`${cellBase}; color: ${TEXT_MUTED};`}>{row.size}</div>
                <div style={`${cellBase}; color: ${TEXT_MUTED};`}>{row.time}</div>
                <div style="margin: 0; padding: 3px 8px; position: relative;">
                  <div
                    style={`position: relative; height: 8px; background: ${PANEL_BG_ALT}; border-radius: 2px; overflow: hidden;`}
                  >
                    <div
                      style={`position: absolute; top: 0; bottom: 0; left: ${row.bar[0]}%; width: ${row.bar[1]}%; background: ${selected ? WATERFALL_TIME : WATERFALL_BAR}; border-radius: 2px;`}
                    ></div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      {/* Right pane: request detail */}
      <div style="margin: 0; padding: 0; position: relative; min-width: 0; display: flex; flex-direction: column;">
        {/* Sub-tab strip: Headers / Payload / Preview / Response / Initiator / Timing / Cookies */}
        <div
          style={`margin: 0; display: flex; flex-direction: row; align-items: stretch; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER}; position: relative; flex-wrap: wrap;`}
        >
          <div style={subTabSelected}>Headers</div>
          <div style={subTabDim}>Payload</div>
          <div style={subTabDim}>Preview</div>
          <div style={subTabDim}>Response</div>
          <div style={subTabDim}>Initiator</div>
          <div style={subTabDim}>Timing</div>
          <div style={subTabDim}>Cookies</div>

          {/* Callout 4 — Request-detail tabs */}
          <div
            style="margin: 0; position: absolute; top: -14px; right: -14px;"
            aria-hidden="true"
          >
            <span style={calloutDot}>4</span>
          </div>
        </div>

        {/* Content for the Headers sub-tab — General + Response headers */}
        <div style="margin: 0; padding: 10px 12px; display: flex; flex-direction: column; gap: 9px;">
          <div style="margin: 0;">
            <div
              style={`${reset}; ${codeFont}; color: ${TEXT_MUTED}; font-weight: 600; margin-bottom: 4px;`}
            >
              ▾ General
            </div>
            <div style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; padding-left: 10px;`}>
              <span style={`color: ${TEXT_MUTED};`}>Request URL:</span> https://app.example.com/api/me
            </div>
            <div style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; padding-left: 10px;`}>
              <span style={`color: ${TEXT_MUTED};`}>Request Method:</span>{" "}
              <span style={`color: ${METHOD_GET};`}>GET</span>
            </div>
            <div style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; padding-left: 10px;`}>
              <span style={`color: ${TEXT_MUTED};`}>Status Code:</span>{" "}
              <span style={`color: ${STATUS_ERR};`}>401 Unauthorized</span>
            </div>
          </div>

          <div style="margin: 0;">
            <div
              style={`${reset}; ${codeFont}; color: ${TEXT_MUTED}; font-weight: 600; margin-bottom: 4px;`}
            >
              ▾ Response Headers
            </div>
            <div style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; padding-left: 10px;`}>
              <span style={`color: ${TEXT_MUTED};`}>content-type:</span> application/json
            </div>
            <div style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; padding-left: 10px;`}>
              <span style={`color: ${TEXT_MUTED};`}>cache-control:</span> no-store
            </div>
            <div style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; padding-left: 10px;`}>
              <span style={`color: ${TEXT_MUTED};`}>www-authenticate:</span> Bearer
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Legend — numbered callouts mapped to regions */}
  <div
    style="margin: 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 24px; row-gap: 8px; font-size: 12px;"
  >
    <div style={calloutRow}>
      <span style={calloutDot}>1</span>
      <span style={calloutLabel}>
        <strong>Preserve log + Disable cache</strong> — keep the log across navigations, force every reload to hit the network.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>2</span>
      <span style={calloutLabel}>
        <strong>Throttling</strong> — simulate "Fast 4G", "Slow 4G", "3G", or "Offline" to test loading states.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>3</span>
      <span style={calloutLabel}>
        <strong>Request-type filters</strong> — drop the noise; Fetch/XHR for API calls, Doc for navigations.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>4</span>
      <span style={calloutLabel}>
        <strong>Request-detail tabs</strong> — Headers, Payload, Preview, Response, Initiator, Timing, Cookies.
      </span>
    </div>
  </div>
</div>
