---
// Annotated mock of the Chromium DevTools Application panel.
//
// Layout: a single dark "DevTools window" card with a tab strip on top
// (Application selected, other panel names dim), then a two-pane body —
// the section sidebar on the left (Manifest, Service Workers, Storage
// with its sub-items, Background Services) and the cookie inspector on
// the right (a "Clear site data" pill above a table of cookies with
// their full attribute set: Name, Value, Domain, Path, Expires, Size,
// HttpOnly, Secure, SameSite).
//
// Four numbered circular callouts pin the load-bearing regions the
// lesson prose enumerates:
//   1. Sidebar sections (Manifest / Service Workers / Storage tree /
//      Background Services).
//   2. The "Clear site data" button atop the Storage section.
//   3. The selected Cookies row in the sidebar — its right pane lists
//      every cookie with its attributes.
//   4. The cookie attribute columns (HttpOnly, Secure, SameSite,
//      Expires, Domain, Path).
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BG_ROW_ALT = "#252525";
const PANEL_BORDER = "#3a3a3a";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const ACCENT = "#60a5fa"; // selected tab + selected sidebar row
const DANGER = "#f87171"; // Clear site data button accent
const COOKIE_NAME = "#9cdcfe";
const COOKIE_VAL = "#ce9178";
const FLAG_TRUE = "#86efac"; // ✓ for HttpOnly/Secure when true
const FLAG_FALSE = "#6b7280"; // ✗ for HttpOnly/Secure when false
const SAMESITE_LAX = "#fbbf24";
const SAMESITE_STRICT = "#86efac";
const SAMESITE_NONE = "#f87171";
const CALLOUT_BG = "#f59e0b";
const CALLOUT_TEXT = "#0b0b0b";

const reset = "margin: 0";

const calloutDot = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 22px",
  "height: 22px",
  "border-radius: 50%",
  `background: ${CALLOUT_BG}`,
  `color: ${CALLOUT_TEXT}`,
  "font-weight: 700",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "box-shadow: 0 0 0 2px rgba(0,0,0,0.5)",
  "flex: 0 0 auto",
].join("; ");

const tabBase = [
  reset,
  "padding: 6px 12px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "border-right: 1px solid " + PANEL_BORDER,
  "white-space: nowrap",
].join("; ");

const tabSelected = `${tabBase}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 4px;`;
const tabDim = `${tabBase}; color: ${TEXT_DIM}; background: ${PANEL_BG_ALT};`;

const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 11px; line-height: 1.5;";

const calloutLabel = [
  reset,
  "margin-left: 8px",
  "color: var(--sl-color-text)",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
].join("; ");

const calloutRow = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 4px",
].join("; ");

// Sidebar entry styles.
const sidebarSectionHeader = [
  reset,
  "padding: 6px 10px 4px",
  "font-size: 10px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  `color: ${TEXT_DIM}`,
  "text-transform: uppercase",
  "letter-spacing: 0.06em",
  "white-space: nowrap",
].join("; ");

const sidebarEntryBase = [
  reset,
  "padding: 3px 10px 3px 22px",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  `color: ${TEXT_BRIGHT}`,
  "white-space: nowrap",
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "cursor: default",
].join("; ");

const sidebarEntryNested = [
  sidebarEntryBase,
  "padding-left: 38px",
].join("; ");

const sidebarEntryNestedSelected = [
  sidebarEntryNested,
  `background: rgba(96,165,250,0.22)`,
  `border-left: 2px solid ${ACCENT}`,
  "padding-left: 36px",
].join("; ");

const sidebarEntryDim = [
  sidebarEntryBase,
  `color: ${TEXT_MUTED}`,
].join("; ");

const sidebarEntryNestedDim = [
  sidebarEntryNested,
  `color: ${TEXT_MUTED}`,
].join("; ");

// Cookie table.
type Cookie = {
  name: string;
  value: string;
  domain: string;
  path: string;
  expires: string;
  size: number;
  httpOnly: boolean;
  secure: boolean;
  sameSite: "Lax" | "Strict" | "None";
  highlighted?: boolean;
};

const cookies: Cookie[] = [
  {
    name: "session",
    value: "eyJhbGciOiJIUzI1NiIsInR5...",
    domain: "app.example.com",
    path: "/",
    expires: "2026-06-04T09:12:43Z",
    size: 312,
    httpOnly: true,
    secure: true,
    sameSite: "Lax",
    highlighted: true,
  },
  {
    name: "csrf",
    value: "a91b3fde4c2e1f...",
    domain: "app.example.com",
    path: "/",
    expires: "Session",
    size: 64,
    httpOnly: false,
    secure: true,
    sameSite: "Strict",
  },
  {
    name: "theme",
    value: "dark",
    domain: ".example.com",
    path: "/",
    expires: "2027-01-01T00:00:00Z",
    size: 9,
    httpOnly: false,
    secure: false,
    sameSite: "Lax",
  },
  {
    name: "_analytics",
    value: "GA1.2.778431...",
    domain: ".example.com",
    path: "/",
    expires: "2026-11-28T00:00:00Z",
    size: 34,
    httpOnly: false,
    secure: true,
    sameSite: "None",
  },
];

const tableHeaderCell = [
  reset,
  "padding: 4px 8px",
  "font-size: 10px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  `color: ${TEXT_MUTED}`,
  "text-transform: uppercase",
  "letter-spacing: 0.04em",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  `background: ${PANEL_BG_ALT}`,
  "white-space: nowrap",
  "text-align: left",
].join("; ");

const tableCellBase = [
  reset,
  codeFont,
  `color: ${TEXT_BRIGHT}`,
  "padding: 4px 8px",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");

const sameSiteColor = (v: Cookie["sameSite"]) => {
  if (v === "Lax") return SAMESITE_LAX;
  if (v === "Strict") return SAMESITE_STRICT;
  return SAMESITE_NONE;
};

// Cookie table column template — fixed widths keep columns aligned across
// header + rows. Five short tail columns carry the auth-relevant flags.
const cookieCols =
  "minmax(0, 1.1fr) minmax(0, 1.6fr) minmax(0, 1.3fr) 44px minmax(0, 1.2fr) 48px 56px 52px 64px";
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 14px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* DevTools window mock */}
  <div
    style={`margin: 0; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2);`}
  >
    {/* Tab strip — panel names (Application selected) */}
    <div
      style={`margin: 0; display: flex; flex-direction: row; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER};`}
    >
      <div style={tabDim}>Elements</div>
      <div style={tabDim}>Console</div>
      <div style={tabDim}>Sources</div>
      <div style={tabDim}>Network</div>
      <div style={tabSelected}>Application</div>
      <div style={tabDim}>Performance</div>
    </div>

    {/* Two-pane body: sidebar on the left, cookie inspector on the right */}
    <div
      style="margin: 0; display: grid; grid-template-columns: 220px 1fr; min-height: 320px;"
    >
      {/* Left pane: section sidebar */}
      <div
        style={`margin: 0; border-right: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; position: relative; min-width: 0; padding: 4px 0 10px;`}
      >
        {/* Callout 1 — sidebar sections */}
        <div
          style="margin: 0; position: absolute; top: 6px; right: 6px;"
          aria-hidden="true"
        >
          <span style={calloutDot}>1</span>
        </div>

        {/* Application section */}
        <div style={sidebarSectionHeader}>Application</div>
        <div style={sidebarEntryDim}>
          <span style={`color: ${TEXT_DIM};`} aria-hidden="true">▸</span>
          <span>Manifest</span>
        </div>
        <div style={sidebarEntryDim}>
          <span style={`color: ${TEXT_DIM};`} aria-hidden="true">▸</span>
          <span>Service Workers</span>
        </div>

        {/* Storage section */}
        <div style={sidebarSectionHeader}>Storage</div>
        <div style={sidebarEntryBase}>
          <span style={`color: ${TEXT_MUTED};`} aria-hidden="true">▾</span>
          <span style="font-weight: 600;">Storage</span>
        </div>
        <div style={sidebarEntryNestedDim}>Local Storage</div>
        <div style={sidebarEntryNestedDim}>Session Storage</div>
        <div style={sidebarEntryNestedDim}>IndexedDB</div>

        {/* Cookies — expanded + selected. Callout 3 anchors here. */}
        <div style={`${sidebarEntryNested}; position: relative;`}>
          <span style={`color: ${TEXT_MUTED};`} aria-hidden="true">▾</span>
          <span style="font-weight: 600;">Cookies</span>
        </div>
        <div
          style={`${sidebarEntryNestedSelected}; padding-left: 54px; position: relative;`}
        >
          <span
            style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT};`}
          >https://app.example.com</span>

          {/* Callout 3 — Cookies row (selected, drives the right pane) */}
          <div
            style="margin: 0; position: absolute; top: 50%; right: -12px; transform: translateY(-50%);"
            aria-hidden="true"
          >
            <span style={calloutDot}>3</span>
          </div>
        </div>
        <div style={sidebarEntryNestedDim}>Cache Storage</div>

        {/* Background Services section */}
        <div style={sidebarSectionHeader}>Background services</div>
        <div style={sidebarEntryDim}>
          <span style={`color: ${TEXT_DIM};`} aria-hidden="true">▸</span>
          <span>Background Fetch</span>
        </div>
        <div style={sidebarEntryDim}>
          <span style={`color: ${TEXT_DIM};`} aria-hidden="true">▸</span>
          <span>Push Messaging</span>
        </div>
      </div>

      {/* Right pane: Cookies inspector */}
      <div
        style="margin: 0; padding: 0; display: flex; flex-direction: column; min-width: 0;"
      >
        {/* Right-pane header: origin label + Clear site data button */}
        <div
          style={`margin: 0; padding: 10px 14px; display: flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 12px; border-bottom: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; position: relative; flex-wrap: wrap;`}
        >
          <div
            style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; font-weight: 600;`}
          >
            <span style={`color: ${TEXT_MUTED};`}>Cookies for</span>{" "}
            https://app.example.com
          </div>

          {/* Clear site data button — callout 2 */}
          <div style="margin: 0; display: inline-flex; align-items: center; gap: 8px; position: relative;">
            <span
              style={`${reset}; font-size: 11px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif); color: ${DANGER}; padding: 4px 12px; border: 1px solid ${DANGER}; border-radius: 4px; background: rgba(248,113,113,0.08); display: inline-flex; align-items: center; gap: 6px;`}
            >
              <span aria-hidden="true">⌫</span>
              Clear site data
            </span>

            {/* Callout 2 — Clear site data */}
            <div
              style="margin: 0; position: absolute; top: -14px; right: -14px;"
              aria-hidden="true"
            >
              <span style={calloutDot}>2</span>
            </div>
          </div>
        </div>

        {/* Cookie table */}
        <div style="margin: 0; overflow-x: auto;">
          {/* Column headers row — callout 4 anchors here */}
          <div style="margin: 0; position: relative;">
            <div
              style={`margin: 0; display: grid; grid-template-columns: ${cookieCols};`}
            >
              <div style={tableHeaderCell}>Name</div>
              <div style={tableHeaderCell}>Value</div>
              <div style={tableHeaderCell}>Domain</div>
              <div style={tableHeaderCell}>Path</div>
              <div style={tableHeaderCell}>Expires</div>
              <div style={tableHeaderCell}>Size</div>
              <div style={tableHeaderCell}>HttpOnly</div>
              <div style={tableHeaderCell}>Secure</div>
              <div style={tableHeaderCell}>SameSite</div>
            </div>

            {/* Callout 4 — cookie attribute columns. Sits over the
                flag-column header trio so the label points at the
                auth-relevant attributes specifically. */}
            <div
              style="margin: 0; position: absolute; top: -12px; right: 20px;"
              aria-hidden="true"
            >
              <span style={calloutDot}>4</span>
            </div>
          </div>

          {/* Cookie rows */}
          {cookies.map((c, i) => {
            const baseBg = i % 2 === 0 ? PANEL_BG : PANEL_BG_ROW_ALT;
            const rowStyle = c.highlighted
              ? `margin: 0; display: grid; grid-template-columns: ${cookieCols}; background: rgba(96,165,250,0.18); border-left: 2px solid ${ACCENT};`
              : `margin: 0; display: grid; grid-template-columns: ${cookieCols}; background: ${baseBg};`;
            return (
              <div style={rowStyle}>
                <div style={`${tableCellBase}; color: ${COOKIE_NAME};`}>
                  {c.name}
                </div>
                <div style={`${tableCellBase}; color: ${COOKIE_VAL};`}>
                  {c.value}
                </div>
                <div style={`${tableCellBase}; color: ${TEXT_MUTED};`}>
                  {c.domain}
                </div>
                <div style={`${tableCellBase}; color: ${TEXT_MUTED};`}>
                  {c.path}
                </div>
                <div style={`${tableCellBase}; color: ${TEXT_MUTED};`}>
                  {c.expires}
                </div>
                <div
                  style={`${tableCellBase}; color: ${TEXT_MUTED}; text-align: right;`}
                >
                  {c.size}
                </div>
                <div
                  style={`${tableCellBase}; text-align: center; color: ${c.httpOnly ? FLAG_TRUE : FLAG_FALSE};`}
                >
                  {c.httpOnly ? "✓" : "—"}
                </div>
                <div
                  style={`${tableCellBase}; text-align: center; color: ${c.secure ? FLAG_TRUE : FLAG_FALSE};`}
                >
                  {c.secure ? "✓" : "—"}
                </div>
                <div
                  style={`${tableCellBase}; color: ${sameSiteColor(c.sameSite)};`}
                >
                  {c.sameSite}
                </div>
              </div>
            );
          })}
        </div>

        {/* Bottom hint — mirrors the Chromium status line on this view */}
        <div
          style={`margin: 0; padding: 6px 14px; border-top: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; ${codeFont}; color: ${TEXT_DIM}; flex: 1 1 auto; display: flex; align-items: flex-end;`}
        >
          {cookies.length} cookies — double-click any cell to edit, ⌫ to delete the row
        </div>
      </div>
    </div>
  </div>

  {/* Legend — numbered callouts mapped to regions */}
  <div
    style="margin: 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 24px; row-gap: 8px; font-size: 12px;"
  >
    <div style={calloutRow}>
      <span style={calloutDot}>1</span>
      <span style={calloutLabel}>
        <strong>Sidebar sections</strong> — Manifest, Service Workers, Storage (with its sub-items), Background Services.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>2</span>
      <span style={calloutLabel}>
        <strong>Clear site data</strong> — one button wipes every persistence surface for the current origin.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>3</span>
      <span style={calloutLabel}>
        <strong>Cookies row</strong> — selected origin under Storage drives the right pane.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>4</span>
      <span style={calloutLabel}>
        <strong>Attribute columns</strong> — <code style="background: transparent; padding: 0; color: inherit;">HttpOnly</code>, <code style="background: transparent; padding: 0; color: inherit;">Secure</code>, <code style="background: transparent; padding: 0; color: inherit;">SameSite</code>, Expires, Domain, Path.
      </span>
    </div>
  </div>
</div>
