---
// Annotated mock of the Chromium DevTools Elements panel.
//
// Layout: a single dark "DevTools window" card with a tab strip on top
// (Elements selected, other panel names dim), then a two-pane body — DOM
// tree on the left, Styles/Computed pane on the right. Four numbered
// circular callouts pin the load-bearing regions:
//   1. DOM tree
//   2. Styles pane with cascade-ordered rules (one struck-through)
//   3. Computed tab (sibling tab in the right pane)
//   4. :hov button atop the Styles pane
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BORDER = "#3a3a3a";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const ACCENT = "#60a5fa"; // selected tab + selected node
const PROP = "#9cdcfe"; // CSS property name
const VAL = "#ce9178"; // CSS value
const TAG = "#569cd6"; // HTML tag
const ATTR = "#9cdcfe"; // attribute name
const ATTR_VAL = "#ce9178"; // attribute value
const CALLOUT_BG = "#f59e0b";
const CALLOUT_TEXT = "#0b0b0b";

const reset = "margin: 0";

const calloutDot = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 22px",
  "height: 22px",
  "border-radius: 50%",
  `background: ${CALLOUT_BG}`,
  `color: ${CALLOUT_TEXT}`,
  "font-weight: 700",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "box-shadow: 0 0 0 2px rgba(0,0,0,0.5)",
  "flex: 0 0 auto",
].join("; ");

const tabBase = [
  reset,
  "padding: 6px 12px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "border-right: 1px solid " + PANEL_BORDER,
  "white-space: nowrap",
].join("; ");

const tabSelected = `${tabBase}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 4px;`;
const tabDim = `${tabBase}; color: ${TEXT_DIM}; background: ${PANEL_BG_ALT};`;

const subTabBase = [
  reset,
  "padding: 4px 10px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "white-space: nowrap",
].join("; ");
const subTabSelected = `${subTabBase}; color: ${TEXT_BRIGHT}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 2px;`;
const subTabDim = `${subTabBase}; color: ${TEXT_MUTED};`;

const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 11px; line-height: 1.55;";

const cssRow = `${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; white-space: nowrap;`;
const cssRowStruck = `${cssRow}; text-decoration: line-through; opacity: 0.55;`;

const selectorLine = `${reset}; ${codeFont}; color: ${TEXT_MUTED}; white-space: nowrap;`;

const indentStyle = (n: number) =>
  `${reset}; ${codeFont}; color: ${TEXT_BRIGHT}; white-space: nowrap; padding-left: ${n * 12}px;`;

const calloutLabel = [
  reset,
  "margin-left: 8px",
  "color: var(--sl-color-text)",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
].join("; ");

const calloutRow = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 4px",
].join("; ");
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 14px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* DevTools window mock */}
  <div
    style={`margin: 0; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2);`}
  >
    {/* Tab strip — panel names */}
    <div
      style={`margin: 0; display: flex; flex-direction: row; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER};`}
    >
      <div style={tabSelected}>Elements</div>
      <div style={tabDim}>Console</div>
      <div style={tabDim}>Sources</div>
      <div style={tabDim}>Network</div>
      <div style={tabDim}>Application</div>
      <div style={tabDim}>Performance</div>
    </div>

    {/* Two-pane body */}
    <div
      style="margin: 0; display: grid; grid-template-columns: 1.1fr 1fr; min-height: 280px;"
    >
      {/* Left pane: DOM tree */}
      <div
        style={`margin: 0; padding: 10px 12px; border-right: 1px solid ${PANEL_BORDER}; position: relative; min-width: 0;`}
      >
        {/* Callout 1 — DOM tree */}
        <div
          style="margin: 0; position: absolute; top: 8px; right: 8px;"
          aria-hidden="true"
        >
          <span style={calloutDot}>1</span>
        </div>

        <div style={indentStyle(0)}>
          <span style={`color: ${TEXT_MUTED};`}>{"<!DOCTYPE html>"}</span>
        </div>
        <div style={indentStyle(0)}>
          <span style={`color: ${TAG};`}>{"<html"}</span>
          <span style={`color: ${ATTR};`}>{" lang"}</span>
          <span style={`color: ${TEXT_BRIGHT};`}>{"="}</span>
          <span style={`color: ${ATTR_VAL};`}>{'"en"'}</span>
          <span style={`color: ${TAG};`}>{">"}</span>
        </div>
        <div style={indentStyle(1)}>
          <span style={`color: ${TAG};`}>{"<head>"}</span>
          <span style={`color: ${TEXT_DIM};`}>{" …"}</span>
          <span style={`color: ${TAG};`}>{"</head>"}</span>
        </div>
        <div style={indentStyle(1)}>
          <span style={`color: ${TAG};`}>{"<body>"}</span>
        </div>
        <div style={indentStyle(2)}>
          <span style={`color: ${TAG};`}>{"<header"}</span>
          <span style={`color: ${ATTR};`}>{" class"}</span>
          <span style={`color: ${TEXT_BRIGHT};`}>{"="}</span>
          <span style={`color: ${ATTR_VAL};`}>{'"site-nav"'}</span>
          <span style={`color: ${TAG};`}>{">…</"}</span>
          <span style={`color: ${TAG};`}>{"header>"}</span>
        </div>
        <div style={indentStyle(2)}>
          <span style={`color: ${TAG};`}>{"<main>"}</span>
        </div>
        <div style={indentStyle(3)}>
          <span style={`color: ${TAG};`}>{"<section"}</span>
          <span style={`color: ${ATTR};`}>{" class"}</span>
          <span style={`color: ${TEXT_BRIGHT};`}>{"="}</span>
          <span style={`color: ${ATTR_VAL};`}>{'"hero"'}</span>
          <span style={`color: ${TAG};`}>{">"}</span>
        </div>
        <div style={indentStyle(4)}>
          <span style={`color: ${TAG};`}>{"<h1>"}</span>
          <span style={`color: ${TEXT_BRIGHT};`}>{"Build for the web"}</span>
          <span style={`color: ${TAG};`}>{"</h1>"}</span>
        </div>
        {/* Selected row highlighted */}
        <div
          style={`${indentStyle(4)}; background: rgba(96,165,250,0.18); border-left: 2px solid ${ACCENT}; padding-left: ${4 * 12 - 2}px;`}
        >
          <span style={`color: ${TAG};`}>{"<button"}</span>
          <span style={`color: ${ATTR};`}>{" class"}</span>
          <span style={`color: ${TEXT_BRIGHT};`}>{"="}</span>
          <span style={`color: ${ATTR_VAL};`}>{'"cta"'}</span>
          <span style={`color: ${TAG};`}>{">"}</span>
          <span style={`color: ${TEXT_BRIGHT};`}>{"Get started"}</span>
          <span style={`color: ${TAG};`}>{"</button>"}</span>
        </div>
        <div style={indentStyle(3)}>
          <span style={`color: ${TAG};`}>{"</section>"}</span>
        </div>
        <div style={indentStyle(2)}>
          <span style={`color: ${TAG};`}>{"</main>"}</span>
        </div>
        <div style={indentStyle(1)}>
          <span style={`color: ${TAG};`}>{"</body>"}</span>
        </div>
        <div style={indentStyle(0)}>
          <span style={`color: ${TAG};`}>{"</html>"}</span>
        </div>
      </div>

      {/* Right pane: Styles / Computed */}
      <div style="margin: 0; padding: 0; position: relative; min-width: 0;">
        {/* Sub-tab strip: Styles / Computed / Layout / etc. */}
        <div
          style={`margin: 0; display: flex; flex-direction: row; align-items: stretch; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER}; position: relative;`}
        >
          <div style={subTabSelected}>Styles</div>
          <div style={subTabDim}>Computed</div>
          <div style={subTabDim}>Layout</div>
          <div style={subTabDim}>Event Listeners</div>

          {/* Callout 3 — Computed tab */}
          <div
            style="margin: 0; position: absolute; top: -28px; left: 60px;"
            aria-hidden="true"
          >
            <span style={calloutDot}>3</span>
          </div>
        </div>

        {/* Toolbar with :hov and filter */}
        <div
          style={`margin: 0; padding: 6px 10px; display: flex; flex-direction: row; align-items: center; gap: 8px; border-bottom: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; position: relative;`}
        >
          <span
            style={`${codeFont}; color: ${TEXT_MUTED}; padding: 2px 6px; border: 1px solid ${PANEL_BORDER}; border-radius: 3px; margin: 0;`}
          >
            Filter
          </span>
          <span
            style={`${codeFont}; color: ${TEXT_BRIGHT}; padding: 2px 6px; border: 1px solid ${ACCENT}; border-radius: 3px; margin: 0; background: rgba(96,165,250,0.12);`}
          >
            :hov
          </span>
          <span
            style={`${codeFont}; color: ${TEXT_MUTED}; padding: 2px 6px; border: 1px solid ${PANEL_BORDER}; border-radius: 3px; margin: 0;`}
          >
            .cls
          </span>
          <span
            style={`${codeFont}; color: ${TEXT_MUTED}; padding: 2px 6px; border: 1px solid ${PANEL_BORDER}; border-radius: 3px; margin: 0;`}
          >
            +
          </span>

          {/* Callout 4 — :hov button */}
          <div
            style="margin: 0; position: absolute; bottom: -10px; left: 56px;"
            aria-hidden="true"
          >
            <span style={calloutDot}>4</span>
          </div>
        </div>

        {/* Styles content — cascade-ordered rules */}
        <div style="margin: 0; padding: 10px 12px; position: relative;">
          {/* Callout 2 — Styles pane */}
          <div
            style="margin: 0; position: absolute; top: 8px; right: 8px;"
            aria-hidden="true"
          >
            <span style={calloutDot}>2</span>
          </div>

          {/* Inline element styles */}
          <div style={selectorLine}>element.style {"{"} {"}"}</div>

          {/* Rule 1 — wins */}
          <div style={selectorLine}>
            <span style={`color: ${TEXT_BRIGHT};`}>.cta</span> {"{"}
          </div>
          <div style={`${cssRow}; padding-left: 12px;`}>
            <span style={`color: ${PROP};`}>background-color</span>
            <span>: </span>
            <span style={`color: ${VAL};`}>oklch(0.62 0.18 250)</span>;
          </div>
          <div style={`${cssRow}; padding-left: 12px;`}>
            <span style={`color: ${PROP};`}>color</span>
            <span>: </span>
            <span style={`color: ${VAL};`}>#fff</span>;
          </div>
          <div style={`${cssRow}; padding-left: 12px;`}>
            <span style={`color: ${PROP};`}>padding</span>
            <span>: </span>
            <span style={`color: ${VAL};`}>12px 20px</span>;
          </div>
          <div style={selectorLine}>{"}"}</div>

          {/* Rule 2 — loses (struck-through) */}
          <div style={`${selectorLine}; margin-top: 6px;`}>
            <span style={`color: ${TEXT_BRIGHT};`}>button</span> {"{"}
          </div>
          <div style={`${cssRowStruck}; padding-left: 12px;`}>
            <span style={`color: ${PROP};`}>background-color</span>
            <span>: </span>
            <span style={`color: ${VAL};`}>#e5e7eb</span>;
          </div>
          <div style={`${cssRow}; padding-left: 12px;`}>
            <span style={`color: ${PROP};`}>border-radius</span>
            <span>: </span>
            <span style={`color: ${VAL};`}>6px</span>;
          </div>
          <div style={selectorLine}>{"}"}</div>
        </div>
      </div>
    </div>
  </div>

  {/* Legend — numbered callouts mapped to regions */}
  <div
    style="margin: 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 24px; row-gap: 8px; font-size: 12px;"
  >
    <div style={calloutRow}>
      <span style={calloutDot}>1</span>
      <span style={calloutLabel}>
        <strong>DOM tree</strong> — the live in-memory tree, after every JS mutation.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>2</span>
      <span style={calloutLabel}>
        <strong>Styles pane</strong> — rules in cascade order; overridden ones struck through.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>3</span>
      <span style={calloutLabel}>
        <strong>Computed tab</strong> — the resolved final value per property.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>4</span>
      <span style={calloutLabel}>
        <strong><code style="background: transparent; padding: 0; color: inherit;">:hov</code> button</strong> — force pseudo-states without using the mouse.
      </span>
    </div>
  </div>
</div>
