---
// Annotated mock of the Chromium DevTools Console panel.
//
// Layout: a single dark "DevTools window" card with a tab strip on top
// (Console selected, other panel names dim), then a toolbar row with the
// log-level filter dropdown and a filter input, then the main scrollback
// area showing a few level-tagged log entries plus a `console.table()`
// output rendered as a real columned table, and finally the prompt input
// row pinned at the bottom.
//
// Three numbered circular callouts pin the regions enumerated in the
// lesson prose:
//   1. Log-level filter dropdown (Verbose / Info / Warning / Error / All)
//   2. Prompt input at the bottom
//   3. `console.table()` output rendered as a real table
//
// `margin: 0` on every inner element to defeat the Starlight prose-margin
// selector that injects ~16px on every block-level descendant.

const PANEL_BG = "#1f1f1f";
const PANEL_BG_ALT = "#2a2a2a";
const PANEL_BORDER = "#3a3a3a";
const TEXT_MUTED = "#9ca3af";
const TEXT_DIM = "#6b7280";
const TEXT_BRIGHT = "#e5e7eb";
const ACCENT = "#60a5fa"; // selected tab + prompt caret

// Log-level accent colors.
const LEVEL_WARN_BG = "rgba(251, 191, 36, 0.10)";
const LEVEL_WARN_BORDER = "#b45309";
const LEVEL_WARN_TEXT = "#fbbf24";
const LEVEL_ERROR_BG = "rgba(248, 113, 113, 0.12)";
const LEVEL_ERROR_BORDER = "#b91c1c";
const LEVEL_ERROR_TEXT = "#f87171";
const LEVEL_INFO_TEXT = "#93c5fd";

// JS syntax tints (table cell values, expression preview).
const STRING_VAL = "#ce9178";
const NUMBER_VAL = "#b5cea8";
const KEYWORD = "#c586c0";
const IDENT = "#9cdcfe";

const CALLOUT_BG = "#f59e0b";
const CALLOUT_TEXT = "#0b0b0b";

const reset = "margin: 0";

const calloutDot = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 22px",
  "height: 22px",
  "border-radius: 50%",
  `background: ${CALLOUT_BG}`,
  `color: ${CALLOUT_TEXT}`,
  "font-weight: 700",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "box-shadow: 0 0 0 2px rgba(0,0,0,0.5)",
  "flex: 0 0 auto",
].join("; ");

const tabBase = [
  reset,
  "padding: 6px 12px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "border-right: 1px solid " + PANEL_BORDER,
  "white-space: nowrap",
].join("; ");

const tabSelected = `${tabBase}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG}; border-bottom: 2px solid ${ACCENT}; padding-bottom: 4px;`;
const tabDim = `${tabBase}; color: ${TEXT_DIM}; background: ${PANEL_BG_ALT};`;

const codeFont =
  "font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace; font-size: 11px; line-height: 1.5;";

const calloutLabel = [
  reset,
  "margin-left: 8px",
  "color: var(--sl-color-text)",
  "font-size: 12px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
].join("; ");

const calloutRow = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 4px",
].join("; ");

// Sample table data — small array of user-like objects.
type User = { id: number; name: string; email: string; role: string };
const users: User[] = [
  { id: 1, name: "Ada Lovelace", email: "ada@hooli.dev", role: "owner" },
  { id: 2, name: "Grace Hopper", email: "grace@hooli.dev", role: "admin" },
  { id: 3, name: "Linus Pauling", email: "linus@hooli.dev", role: "member" },
];

// Table cells.
const tableHeaderCell = [
  reset,
  "padding: 4px 10px",
  "font-size: 11px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  `color: ${TEXT_BRIGHT}`,
  "font-weight: 600",
  `background: ${PANEL_BG_ALT}`,
  `border: 1px solid ${PANEL_BORDER}`,
  "text-align: left",
  "white-space: nowrap",
].join("; ");

const tableIndexHeaderCell = [
  tableHeaderCell,
  `color: ${TEXT_MUTED}`,
  "text-align: right",
].join("; ");

const tableCellBase = [
  reset,
  codeFont,
  "padding: 3px 10px",
  `border: 1px solid ${PANEL_BORDER}`,
  "white-space: nowrap",
  "vertical-align: top",
].join("; ");

const tableIndexCell = [
  tableCellBase,
  `color: ${TEXT_MUTED}`,
  "text-align: right",
].join("; ");

// Log row helpers.
const logRow = [
  reset,
  "padding: 4px 10px",
  "display: flex",
  "align-items: flex-start",
  "gap: 8px",
  `border-bottom: 1px solid ${PANEL_BORDER}`,
].join("; ");

const logRowWarn = `${logRow}; background: ${LEVEL_WARN_BG}; border-left: 2px solid ${LEVEL_WARN_BORDER};`;
const logRowError = `${logRow}; background: ${LEVEL_ERROR_BG}; border-left: 2px solid ${LEVEL_ERROR_BORDER};`;
const logRowInfo = `${logRow};`;

const logSource = [
  reset,
  codeFont,
  `color: ${TEXT_DIM}`,
  "flex: 0 0 auto",
  "margin-left: auto",
  "padding-left: 12px",
].join("; ");

const logIcon = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 12px",
  "height: 12px",
  "border-radius: 50%",
  "font-size: 9px",
  "font-weight: 700",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "flex: 0 0 auto",
  "margin-top: 2px",
].join("; ");

const logBody = [
  reset,
  codeFont,
  "flex: 1 1 auto",
  "min-width: 0",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 14px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* DevTools window mock */}
  <div
    style={`margin: 0; background: ${PANEL_BG}; border: 1px solid ${PANEL_BORDER}; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 0 rgba(0,0,0,0.2);`}
  >
    {/* Tab strip — panel names (Console selected) */}
    <div
      style={`margin: 0; display: flex; flex-direction: row; background: ${PANEL_BG_ALT}; border-bottom: 1px solid ${PANEL_BORDER};`}
    >
      <div style={tabDim}>Elements</div>
      <div style={tabSelected}>Console</div>
      <div style={tabDim}>Sources</div>
      <div style={tabDim}>Network</div>
      <div style={tabDim}>Application</div>
      <div style={tabDim}>Performance</div>
    </div>

    {/* Toolbar row — clear, filter input, log-level dropdown */}
    <div
      style={`margin: 0; padding: 7px 10px; display: flex; flex-direction: row; align-items: center; gap: 12px; border-bottom: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; position: relative; flex-wrap: wrap;`}
    >
      {/* Clear button glyph */}
      <span
        style={`${reset}; display: inline-flex; align-items: center; justify-content: center; width: 14px; height: 14px; border: 1px solid ${TEXT_MUTED}; border-radius: 50%; color: ${TEXT_MUTED}; font-size: 12px; line-height: 1; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);`}
        aria-hidden="true"
      >
        &#xf8;
      </span>

      {/* Filter input */}
      <span
        style={`${reset}; ${codeFont}; color: ${TEXT_DIM}; padding: 2px 10px; border: 1px solid ${PANEL_BORDER}; border-radius: 3px; background: ${PANEL_BG_ALT}; min-width: 140px; display: inline-block;`}
      >
        Filter
      </span>

      {/* Log-level dropdown — callout 1 */}
      <div style="margin: 0; display: inline-flex; align-items: center; gap: 6px; position: relative;">
        <span
          style={`${reset}; font-size: 11px; color: ${TEXT_MUTED}; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);`}
        >
          Default levels:
        </span>
        <span
          style={`${reset}; font-size: 11px; color: ${TEXT_BRIGHT}; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif); padding: 2px 22px 2px 8px; border: 1px solid ${PANEL_BORDER}; border-radius: 3px; background: ${PANEL_BG_ALT}; position: relative; display: inline-block;`}
        >
          All levels
          <span
            style={`position: absolute; right: 6px; top: 50%; transform: translateY(-50%); color: ${TEXT_MUTED}; font-size: 9px;`}
            aria-hidden="true">▾</span
          >
        </span>

        {/* Callout 1 — log-level filter */}
        <div
          style="margin: 0; position: absolute; top: -14px; right: -14px;"
          aria-hidden="true"
        >
          <span style={calloutDot}>1</span>
        </div>
      </div>

      {/* Live evaluation hint chip */}
      <span
        style={`${reset}; font-size: 11px; color: ${TEXT_MUTED}; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif); padding: 2px 8px; border: 1px solid ${PANEL_BORDER}; border-radius: 3px; background: ${PANEL_BG_ALT};`}
      >
        Live expression
      </span>
    </div>

    {/* Scrollback — log entries + console.table output */}
    <div
      style={`margin: 0; min-height: 260px; display: flex; flex-direction: column;`}
    >
      {/* Log: a warn */}
      <div style={logRowWarn}>
        <span
          style={`${logIcon}; background: ${LEVEL_WARN_TEXT}; color: ${PANEL_BG};`}
          aria-hidden="true">!</span
        >
        <span style={logBody}>
          <span style={`color: ${LEVEL_WARN_TEXT};`}
            >[auth] token expires in 42 seconds — refreshing</span
          >
        </span>
        <span style={logSource}>auth.ts:118</span>
      </div>

      {/* Log: an error */}
      <div style={logRowError}>
        <span
          style={`${logIcon}; background: ${LEVEL_ERROR_TEXT}; color: ${PANEL_BG};`}
          aria-hidden="true">&#xd7;</span
        >
        <span style={logBody}>
          <span style={`color: ${LEVEL_ERROR_TEXT};`}
            >TypeError: Cannot read properties of null (reading 'email')</span
          >
        </span>
        <span style={logSource}>profile.tsx:24</span>
      </div>

      {/* Log: the table command echo */}
      <div style={logRowInfo}>
        <span
          style={`${logIcon}; background: transparent; color: ${TEXT_MUTED}; border: 1px solid ${TEXT_DIM};`}
          aria-hidden="true">&gt;</span
        >
        <span style={logBody}>
          <span style={`color: ${IDENT};`}>console</span><span
            style={`color: ${TEXT_BRIGHT};`}>.</span
          ><span style={`color: ${IDENT};`}>table</span><span
            style={`color: ${TEXT_BRIGHT};`}>(</span
          ><span style={`color: ${IDENT};`}>users</span><span
            style={`color: ${TEXT_BRIGHT};`}>)</span
          >
        </span>
        <span style={logSource}>VM:1</span>
      </div>

      {/* Log: the table output — callout 3 */}
      <div style={`${logRow}; position: relative; align-items: stretch;`}>
        <span
          style={`${logIcon}; background: transparent; color: ${TEXT_MUTED}; border: 1px solid ${TEXT_DIM};`}
          aria-hidden="true">&#x2190;</span
        >
        <span style={logBody}>
          <table
            style={`${reset}; border-collapse: collapse; ${codeFont}; color: ${TEXT_BRIGHT}; background: ${PANEL_BG};`}
          >
            <thead>
              <tr>
                <th style={tableIndexHeaderCell}>(index)</th>
                <th style={tableHeaderCell}>id</th>
                <th style={tableHeaderCell}>name</th>
                <th style={tableHeaderCell}>email</th>
                <th style={tableHeaderCell}>role</th>
              </tr>
            </thead>
            <tbody>
              {users.map((u, i) => (
                <tr>
                  <td style={tableIndexCell}>{i}</td>
                  <td
                    style={`${tableCellBase}; color: ${NUMBER_VAL}; text-align: right;`}
                    >{u.id}</td
                  >
                  <td style={`${tableCellBase}; color: ${STRING_VAL};`}>
                    "{u.name}"
                  </td>
                  <td style={`${tableCellBase}; color: ${STRING_VAL};`}>
                    "{u.email}"
                  </td>
                  <td style={`${tableCellBase}; color: ${STRING_VAL};`}>
                    "{u.role}"
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </span>
        <span style={logSource}>&nbsp;</span>

        {/* Callout 3 — console.table output */}
        <div
          style="margin: 0; position: absolute; top: 8px; right: 8px;"
          aria-hidden="true"
        >
          <span style={calloutDot}>3</span>
        </div>
      </div>

      {/* Spacer that pushes the prompt to the bottom on tall viewports */}
      <div style="margin: 0; flex: 1 1 auto;"></div>

      {/* Prompt input — callout 2 */}
      <div
        style={`margin: 0; padding: 6px 10px; display: flex; flex-direction: row; align-items: center; gap: 8px; border-top: 1px solid ${PANEL_BORDER}; background: ${PANEL_BG}; position: relative;`}
      >
        <span
          style={`${reset}; ${codeFont}; color: ${ACCENT}; font-weight: 700;`}
          aria-hidden="true">&gt;</span
        >
        <span style={`${reset}; ${codeFont}; color: ${TEXT_BRIGHT};`}>
          <span style={`color: ${IDENT};`}>$0</span><span
            style={`color: ${TEXT_BRIGHT};`}>.</span
          ><span style={`color: ${IDENT};`}>getBoundingClientRect</span><span
            style={`color: ${TEXT_BRIGHT};`}>()</span
          >
        </span>
        {/* Faded live-evaluation preview */}
        <span
          style={`${reset}; ${codeFont}; color: ${TEXT_DIM}; font-style: italic;`}
          >&laquo; DOMRect &#123; x: 24, y: 80, width: 132, height: 40, ... &#125;</span
        >
        {/* Blinking caret */}
        <span
          style={`${reset}; display: inline-block; width: 1px; height: 12px; background: ${ACCENT}; margin-left: 1px;`}
          aria-hidden="true"></span>

        {/* Callout 2 — prompt input */}
        <div
          style="margin: 0; position: absolute; top: -14px; right: -14px;"
          aria-hidden="true"
        >
          <span style={calloutDot}>2</span>
        </div>
      </div>
    </div>
  </div>

  {/* Legend — numbered callouts mapped to regions */}
  <div
    style="margin: 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 24px; row-gap: 8px; font-size: 12px;"
  >
    <div style={calloutRow}>
      <span style={calloutDot}>1</span>
      <span style={calloutLabel}>
        <strong>Log-level filter</strong> — drop everything but errors when a noisy page is talking to you.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>2</span>
      <span style={calloutLabel}>
        <strong>Prompt input</strong> — REPL inside the page; live-evaluation preview as you type.
      </span>
    </div>
    <div style={calloutRow}>
      <span style={calloutDot}>3</span>
      <span style={calloutLabel}>
        <strong><code style="background: transparent; padding: 0; color: inherit;">console.table()</code> output</strong> — array of objects rendered as a real columned table.
      </span>
    </div>
  </div>
</div>
</content>
</invoke>