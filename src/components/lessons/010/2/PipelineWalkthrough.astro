---
// One frame of the browser rendering pipeline, used inside <DiagramSequence>.
// Same visual vocabulary as PipelineOverview.astro: two input lanes (HTML, CSS)
// converge into the render tree, then a flat downstream chain to pixels.
//
// `active` selects which box is highlighted; every other box is dimmed.
// Stage IDs mirror the six lesson sections.

interface Props {
  active:
    | "dom"
    | "cssom"
    | "render-tree"
    | "layout"
    | "paint"
    | "composite";
}

const { active } = Astro.props;

const arrow = "▸";

// Shared chrome for the rounded card boxes.
const boxBase = [
  "margin: 0",
  "padding: 6px 8px",
  "border-radius: 7px",
  "min-width: 0",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 1px",
  "transition: opacity 200ms ease, transform 200ms ease, border-color 200ms ease, background-color 200ms ease",
].join("; ");

// Default (inactive) styles for the two visual regions — match PipelineOverview.
const inputBoxDim = `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 14%, transparent); background: color-mix(in srgb, currentColor 4%, transparent); opacity: 0.35;`;
const pipelineBoxDim = `${boxBase}; border: 1px solid color-mix(in srgb, #38bdf8 30%, transparent); background: color-mix(in srgb, #38bdf8 5%, transparent); opacity: 0.35;`;
const finalBoxDim = `${boxBase}; border: 1px solid color-mix(in srgb, #f472b6 30%, transparent); background: color-mix(in srgb, #f472b6 5%, transparent); opacity: 0.35;`;

// "Active" highlighted box — saturated fill, amber border, lifted.
const activeBox = `${boxBase}; border: 1.5px solid #f59e0b; background: color-mix(in srgb, #f59e0b 22%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 18%, transparent); transform: translateY(-1px); opacity: 1;`;

// Helpers to pick the right style per node.
const styleFor = (id: Props["active"], region: "input" | "pipeline" | "final") => {
  if (active === id) return activeBox;
  if (region === "input") return inputBoxDim;
  if (region === "pipeline") return pipelineBoxDim;
  return finalBoxDim;
};

const titleStyle =
  "margin: 0; font-size: 12px; font-weight: 600; line-height: 1.2; white-space: nowrap;";
const subtitleStyle =
  "margin: 2px 0 0; font-size: 10px; opacity: 0.6; line-height: 1.2; white-space: nowrap;";

const arrowStyle = [
  "margin: 0",
  "color: currentColor",
  "opacity: 0.35",
  "font-size: 13px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");

// The "Parse" boxes don't carry the highlight themselves — only the produced
// tree (DOM / CSSOM) does — but they share the muted-but-not-faded look so the
// flow still reads. Use a slightly lighter dim than fully-off siblings.
const parseSubdued = `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 18%, transparent); background: color-mix(in srgb, currentColor 6%, transparent); opacity: 0.6;`;
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 12px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* Main horizontal strip: lanes -> merge -> downstream pipeline */}
  <div
    style="margin: 0; display: flex; flex-direction: row; align-items: center; justify-content: center; flex-wrap: nowrap; gap: 4px; min-width: 0;"
  >
    {/* Left segment: two stacked input lanes (HTML on top, CSS on bottom) */}
    <div
      style="margin: 0; display: grid; grid-template-columns: auto auto auto auto auto; grid-template-rows: auto auto; column-gap: 4px; row-gap: 6px; align-items: center; flex: 0 0 auto;"
    >
      {/* Row 1: HTML lane */}
      <div style={inputBoxDim}>
        <div style={titleStyle}>HTML bytes</div>
        <div style={subtitleStyle}>from network</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={parseSubdued}>
        <div style={titleStyle}>Parse</div>
        <div style={subtitleStyle}>tokenize tags</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={styleFor("dom", "input")}>
        <div style={titleStyle}>DOM tree</div>
        <div style={subtitleStyle}>element nodes</div>
      </div>

      {/* Row 2: CSS lane */}
      <div style={inputBoxDim}>
        <div style={titleStyle}>CSS bytes</div>
        <div style={subtitleStyle}>from network</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={parseSubdued}>
        <div style={titleStyle}>Parse</div>
        <div style={subtitleStyle}>match rules</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={styleFor("cssom", "input")}>
        <div style={titleStyle}>CSSOM</div>
        <div style={subtitleStyle}>style tree</div>
      </div>
    </div>

    {/* Merge connector — two lanes curve into a single arrow */}
    <svg
      viewBox="0 0 50 90"
      width="40"
      height="90"
      role="img"
      aria-label="The DOM and CSSOM lanes converge into the render tree."
      style="margin: 0; display: block; flex: 0 0 auto;"
      preserveAspectRatio="none"
    >
      <path
        d="M 0 22 Q 25 22 25 45 L 42 45"
        fill="none"
        stroke="currentColor"
        stroke-opacity="0.35"
        stroke-width="1.4"
      />
      <path
        d="M 0 68 Q 25 68 25 45 L 42 45"
        fill="none"
        stroke="currentColor"
        stroke-opacity="0.35"
        stroke-width="1.4"
      />
      <path
        d="M 46 45 L 38 41 L 38 49 Z"
        fill="currentColor"
        fill-opacity="0.45"
      />
    </svg>

    {/* Downstream pipeline strip */}
    <div
      style="margin: 0; display: flex; flex-direction: row; align-items: center; flex-wrap: nowrap; gap: 3px; flex: 0 0 auto;"
    >
      <div style={styleFor("render-tree", "pipeline")}>
        <div style={titleStyle}>Render tree</div>
        <div style={subtitleStyle}>{"DOM ∩ style"}</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={styleFor("layout", "pipeline")}>
        <div style={titleStyle}>Layout</div>
        <div style={subtitleStyle}>geometry</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={styleFor("paint", "pipeline")}>
        <div style={titleStyle}>Paint</div>
        <div style={subtitleStyle}>into layers</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={styleFor("composite", "pipeline")}>
        <div style={titleStyle}>Composite</div>
        <div style={subtitleStyle}>to GPU frame</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={finalBoxDim}>
        <div style={titleStyle}>Pixels on screen</div>
        <div style={subtitleStyle}>frame pushed</div>
      </div>
    </div>
  </div>
</div>
