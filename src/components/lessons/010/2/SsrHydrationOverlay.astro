---
// SSR + hydration overlay diagram.
// Two views toggled via TabbedContent:
//   - "Pipeline only"           — withSsr=false, the base pipeline compressed.
//   - "Pipeline + SSR + hydration" — withSsr=true, same pipeline with a server
//     upstream box and a hydration downstream branch.
//
// Visual vocabulary mirrors PipelineOverview.astro: tinted blue downstream
// pipeline, soft-grey input lanes, pink terminal. New tints introduced here:
//   - emerald for the server-side SSR box (runs on the server, distinct lane)
//   - violet for the hydration branch (interactivity layer, distinct from
//     the compositor pipeline)
//
// `margin: 0` reset is applied to every inner element per the Starlight
// prose-margin gotcha.

interface Props {
  withSsr?: boolean;
}

const { withSsr = false } = Astro.props;

const arrow = "▸";

// Shared chrome for the rounded card boxes.
const boxBase = [
  "margin: 0",
  "padding: 5px 7px",
  "border-radius: 6px",
  "min-width: 0",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 1px",
].join("; ");

const inputBox = `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 18%, transparent); background: color-mix(in srgb, currentColor 6%, transparent);`;
const pipelineBox = `${boxBase}; border: 1px solid color-mix(in srgb, #38bdf8 50%, transparent); background: color-mix(in srgb, #38bdf8 10%, transparent);`;
const finalBox = `${boxBase}; border: 1px solid color-mix(in srgb, #f472b6 55%, transparent); background: color-mix(in srgb, #f472b6 12%, transparent);`;
const serverBox = `${boxBase}; border: 1px solid color-mix(in srgb, #10b981 55%, transparent); background: color-mix(in srgb, #10b981 12%, transparent);`;
const hydrationBox = `${boxBase}; border: 1px solid color-mix(in srgb, #a78bfa 55%, transparent); background: color-mix(in srgb, #a78bfa 12%, transparent);`;

const titleStyle =
  "margin: 0; font-size: 11px; font-weight: 600; line-height: 1.2; white-space: nowrap;";
const subtitleStyle =
  "margin: 2px 0 0; font-size: 9.5px; opacity: 0.6; line-height: 1.2; white-space: nowrap;";

const arrowStyle = [
  "margin: 0",
  "color: currentColor",
  "opacity: 0.45",
  "font-size: 12px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 14px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* Main pipeline row */}
  <div
    style="margin: 0; display: flex; flex-direction: row; align-items: center; justify-content: center; flex-wrap: wrap; column-gap: 4px; row-gap: 10px; min-width: 0;"
  >
    {/* Optional upstream SSR box */}
    {
      withSsr && (
        <>
          <div style={serverBox}>
            <div style={titleStyle}>Server Components</div>
            <div style={subtitleStyle}>runs on the server</div>
          </div>
          <div style={arrowStyle}>{arrow}</div>
        </>
      )
    }

    {/* Left segment: two stacked input lanes (HTML on top, CSS on bottom),
        compressed (Parse stages omitted to keep the strip short). */}
    <div
      style="margin: 0; display: grid; grid-template-columns: auto auto auto; grid-template-rows: auto auto; column-gap: 4px; row-gap: 6px; align-items: center; flex: 0 0 auto;"
    >
      {/* Row 1: HTML lane */}
      <div style={inputBox}>
        <div style={titleStyle}>HTML bytes</div>
        <div style={subtitleStyle}>{withSsr ? "already populated" : "from network"}</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={inputBox}>
        <div style={titleStyle}>DOM tree</div>
        <div style={subtitleStyle}>element nodes</div>
      </div>

      {/* Row 2: CSS lane */}
      <div style={inputBox}>
        <div style={titleStyle}>CSS bytes</div>
        <div style={subtitleStyle}>from network</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={inputBox}>
        <div style={titleStyle}>CSSOM</div>
        <div style={subtitleStyle}>style tree</div>
      </div>
    </div>

    {/* Merge connector — two lanes curve into a single arrow */}
    <svg
      viewBox="0 0 50 90"
      width="32"
      height="80"
      role="img"
      aria-label="The DOM and CSSOM lanes converge into the render tree."
      style="margin: 0; display: block; flex: 0 0 auto;"
      preserveAspectRatio="none"
    >
      <path
        d="M 0 22 Q 25 22 25 45 L 42 45"
        fill="none"
        stroke="currentColor"
        stroke-opacity="0.45"
        stroke-width="1.4"
      ></path>
      <path
        d="M 0 68 Q 25 68 25 45 L 42 45"
        fill="none"
        stroke="currentColor"
        stroke-opacity="0.45"
        stroke-width="1.4"
      ></path>
      <path
        d="M 46 45 L 38 41 L 38 49 Z"
        fill="currentColor"
        fill-opacity="0.55"
      ></path>
    </svg>

    {/* Downstream pipeline strip */}
    <div
      style="margin: 0; display: flex; flex-direction: row; align-items: center; flex-wrap: nowrap; gap: 3px; flex: 0 0 auto;"
    >
      <div style={pipelineBox}>
        <div style={titleStyle}>Render tree</div>
        <div style={subtitleStyle}>{"DOM ∩ style"}</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={pipelineBox}>
        <div style={titleStyle}>Layout</div>
        <div style={subtitleStyle}>geometry</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={pipelineBox}>
        <div style={titleStyle}>Paint</div>
        <div style={subtitleStyle}>into layers</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={pipelineBox}>
        <div style={titleStyle}>Composite</div>
        <div style={subtitleStyle}>to GPU frame</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={finalBox}>
        <div style={titleStyle}>Pixels on screen</div>
        <div style={subtitleStyle}>first paint</div>
      </div>
    </div>
  </div>

  {/* Hydration branch — only in the SSR view */}
  {
    withSsr && (
      <div
        style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 6px;"
      >
        {/* Bracket label spanning the visible-but-not-interactive gap */}
        <div
          style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 2px; width: 100%; max-width: 560px;"
        >
          <div
            style="margin: 0; display: flex; align-items: center; gap: 6px; width: 100%;"
          >
            <span
              style="margin: 0; flex: 1 1 auto; height: 1px; background: color-mix(in srgb, #a78bfa 55%, transparent);"
            />
            <span
              style="margin: 0; font-size: 10.5px; font-weight: 600; letter-spacing: 0.02em; color: color-mix(in srgb, #a78bfa 90%, currentColor); white-space: nowrap;"
            >
              visible but not interactive
            </span>
            <span
              style="margin: 0; flex: 1 1 auto; height: 1px; background: color-mix(in srgb, #a78bfa 55%, transparent);"
            />
          </div>
        </div>

        {/* Hydration row */}
        <div
          style="margin: 0; display: flex; flex-direction: row; align-items: center; flex-wrap: wrap; column-gap: 4px; row-gap: 6px; justify-content: center;"
        >
          <div style={hydrationBox}>
            <div style={titleStyle}>JS bundle downloads</div>
            <div style={subtitleStyle}>after first paint</div>
          </div>
          <div style={arrowStyle}>{arrow}</div>
          <div style={hydrationBox}>
            <div style={titleStyle}>React hydrates</div>
            <div style={subtitleStyle}>attaches listeners + state</div>
          </div>
          <div style={arrowStyle}>{arrow}</div>
          <div style={finalBox}>
            <div style={titleStyle}>Page is interactive</div>
            <div style={subtitleStyle}>clicks fire</div>
          </div>
        </div>
      </div>
    )
  }

  {/* Legend chips */}
  <div
    style="margin: 0; display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; font-size: 10.5px; opacity: 0.7;"
  >
    {
      withSsr && (
        <div style="margin: 0; display: flex; align-items: center; gap: 6px;">
          <span style="margin: 0; display: inline-block; width: 11px; height: 11px; border-radius: 3px; border: 1px solid color-mix(in srgb, #10b981 55%, transparent); background: color-mix(in srgb, #10b981 12%, transparent);" />
          <span style="margin: 0;">Server</span>
        </div>
      )
    }
    <div style="margin: 0; display: flex; align-items: center; gap: 6px;">
      <span
        style="margin: 0; display: inline-block; width: 11px; height: 11px; border-radius: 3px; border: 1px solid color-mix(in srgb, currentColor 18%, transparent); background: color-mix(in srgb, currentColor 6%, transparent);"
      ></span>
      <span style="margin: 0;">Inputs (parallel)</span>
    </div>
    <div style="margin: 0; display: flex; align-items: center; gap: 6px;">
      <span
        style="margin: 0; display: inline-block; width: 11px; height: 11px; border-radius: 3px; border: 1px solid color-mix(in srgb, #38bdf8 50%, transparent); background: color-mix(in srgb, #38bdf8 10%, transparent);"
      ></span>
      <span style="margin: 0;">Browser pipeline</span>
    </div>
    {
      withSsr && (
        <div style="margin: 0; display: flex; align-items: center; gap: 6px;">
          <span style="margin: 0; display: inline-block; width: 11px; height: 11px; border-radius: 3px; border: 1px solid color-mix(in srgb, #a78bfa 55%, transparent); background: color-mix(in srgb, #a78bfa 12%, transparent);" />
          <span style="margin: 0;">Hydration (interactivity)</span>
        </div>
      )
    }
  </div>
</div>
