---
// Browser-side rendering pipeline overview.
// Two input lanes (HTML, CSS) converge into the render tree, then a sequential
// chain to pixels on screen.
//
// Layout: a single horizontal flex strip. The left segment is a 2-row inline
// grid (HTML lane on top row, CSS lane on bottom row). An inline SVG draws the
// two converging lines into a merge point. From there, the downstream pipeline
// is a flat row of boxes connected by inline arrows.
//
// `margin: 0` is applied to every inner element to defeat the Starlight
// prose-margin selector that injects ~16px on every block-level descendant
// after the first.

const arrow = "▸";

// Shared chrome for the rounded card boxes.
const boxBase = [
  "margin: 0",
  "padding: 6px 8px",
  "border-radius: 7px",
  "min-width: 0",
  "text-align: center",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 1px",
].join("; ");

// Input lane boxes: soft gray fill, currentColor border so it adapts to theme.
const inputBox = `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 18%, transparent); background: color-mix(in srgb, currentColor 6%, transparent);`;

// Pipeline boxes: tinted blue fill, signals "downstream pipeline".
const pipelineBox = `${boxBase}; border: 1px solid color-mix(in srgb, #38bdf8 50%, transparent); background: color-mix(in srgb, #38bdf8 10%, transparent);`;

// Terminal "pixels on screen" box: tinted pink to mark it as the final output.
const finalBox = `${boxBase}; border: 1px solid color-mix(in srgb, #f472b6 55%, transparent); background: color-mix(in srgb, #f472b6 12%, transparent);`;

const titleStyle =
  "margin: 0; font-size: 12px; font-weight: 600; line-height: 1.2; white-space: nowrap;";
const subtitleStyle =
  "margin: 2px 0 0; font-size: 10px; opacity: 0.6; line-height: 1.2; white-space: nowrap;";

const arrowStyle = [
  "margin: 0",
  "color: currentColor",
  "opacity: 0.45",
  "font-size: 13px",
  "line-height: 1",
  "user-select: none",
  "flex: 0 0 auto",
].join("; ");
---

<div
  style="margin: 0; display: flex; flex-direction: column; gap: 12px; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {/* Main horizontal strip: lanes -> merge -> downstream pipeline */}
  <div
    style="margin: 0; display: flex; flex-direction: row; align-items: center; justify-content: center; flex-wrap: nowrap; gap: 4px; min-width: 0;"
  >
    {/* Left segment: two stacked input lanes (HTML on top, CSS on bottom) */}
    <div
      style="margin: 0; display: grid; grid-template-columns: auto auto auto auto auto; grid-template-rows: auto auto; column-gap: 4px; row-gap: 6px; align-items: center; flex: 0 0 auto;"
    >
      {/* Row 1: HTML lane */}
      <div style={inputBox}>
        <div style={titleStyle}>HTML bytes</div>
        <div style={subtitleStyle}>from network</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={inputBox}>
        <div style={titleStyle}>Parse</div>
        <div style={subtitleStyle}>tokenize tags</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={inputBox}>
        <div style={titleStyle}>DOM tree</div>
        <div style={subtitleStyle}>element nodes</div>
      </div>

      {/* Row 2: CSS lane */}
      <div style={inputBox}>
        <div style={titleStyle}>CSS bytes</div>
        <div style={subtitleStyle}>from network</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={inputBox}>
        <div style={titleStyle}>Parse</div>
        <div style={subtitleStyle}>match rules</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={inputBox}>
        <div style={titleStyle}>CSSOM</div>
        <div style={subtitleStyle}>style tree</div>
      </div>
    </div>

    {/* Merge connector — two lanes curve into a single arrow */}
    <svg
      viewBox="0 0 50 90"
      width="40"
      height="90"
      role="img"
      aria-label="The DOM and CSSOM lanes converge into the render tree."
      style="margin: 0; display: block; flex: 0 0 auto;"
      preserveAspectRatio="none"
    >
      <path
        d="M 0 22 Q 25 22 25 45 L 42 45"
        fill="none"
        stroke="currentColor"
        stroke-opacity="0.45"
        stroke-width="1.4"
      />
      <path
        d="M 0 68 Q 25 68 25 45 L 42 45"
        fill="none"
        stroke="currentColor"
        stroke-opacity="0.45"
        stroke-width="1.4"
      />
      <path
        d="M 46 45 L 38 41 L 38 49 Z"
        fill="currentColor"
        fill-opacity="0.55"
      />
    </svg>

    {/* Downstream pipeline strip */}
    <div
      style="margin: 0; display: flex; flex-direction: row; align-items: center; flex-wrap: nowrap; gap: 3px; flex: 0 0 auto;"
    >
      <div style={pipelineBox}>
        <div style={titleStyle}>Render tree</div>
        <div style={subtitleStyle}>{"DOM ∩ style"}</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={pipelineBox}>
        <div style={titleStyle}>Layout</div>
        <div style={subtitleStyle}>geometry</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={pipelineBox}>
        <div style={titleStyle}>Paint</div>
        <div style={subtitleStyle}>into layers</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={pipelineBox}>
        <div style={titleStyle}>Composite</div>
        <div style={subtitleStyle}>to GPU frame</div>
      </div>
      <div style={arrowStyle}>{arrow}</div>
      <div style={finalBox}>
        <div style={titleStyle}>Pixels on screen</div>
        <div style={subtitleStyle}>frame pushed</div>
      </div>
    </div>
  </div>

  {/* Region legend chips */}
  <div
    style="margin: 0; display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; font-size: 11px; opacity: 0.7;"
  >
    <div style="margin: 0; display: flex; align-items: center; gap: 6px;">
      <span
        style="margin: 0; display: inline-block; width: 12px; height: 12px; border-radius: 3px; border: 1px solid color-mix(in srgb, currentColor 18%, transparent); background: color-mix(in srgb, currentColor 6%, transparent);"
      ></span>
      <span style="margin: 0;">{"Inputs — built in parallel"}</span>
    </div>
    <div style="margin: 0; display: flex; align-items: center; gap: 6px;">
      <span
        style="margin: 0; display: inline-block; width: 12px; height: 12px; border-radius: 3px; border: 1px solid color-mix(in srgb, #38bdf8 50%, transparent); background: color-mix(in srgb, #38bdf8 10%, transparent);"
      ></span>
      <span style="margin: 0;">{"Pipeline — sequential after the merge"}</span>
    </div>
  </div>
</div>
