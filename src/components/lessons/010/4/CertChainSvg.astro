---
// Certificate chain diagram for chapter 010, lesson 4.
//
// Three labeled boxes laid out left to right, widths growing rightward to
// signal the trust scope expanding from "one hostname" to "everything in
// the store":
//
//   Leaf cert   →   Intermediate CA   →   Root CA
//   (CN=localhost)  (signs the leaf)      (trust anchor)
//
// Right-to-left arrows labeled "signs" connect adjacent boxes. A short
// vertical arrow above the root box ties it to a small "OS / browser
// trust store" pill — the diagram's anchor.
//
// Style choices follow documentation/diagrams/svg.md:
//   - currentColor for primary strokes and text, theme-aware.
//   - #9ca3af for subordinate labels (subtitles, leader lines).
//   - viewBox sized tight to content.

import Figure from '../../../figures/Figure.astro';

// Box geometry — widths grow rightward.
const BOX_H = 60;
const BOX_Y = 70;
const BOX_Y_BOTTOM = BOX_Y + BOX_H; // 130
const BOX_Y_CENTER = BOX_Y + BOX_H / 2; // 100

const boxes = [
	{
		title: 'Leaf cert',
		subtitle: 'CN=localhost · 1 yr',
		width: 130,
	},
	{
		title: 'Intermediate CA',
		subtitle: '"Let\'s Encrypt R3"',
		width: 170,
	},
	{
		title: 'Root CA',
		subtitle: 'trust anchor',
		width: 220,
		isAnchor: true,
	},
];

// Horizontal placement: PAD_X · box · GAP · box · GAP · box · PAD_X.
const PAD_X = 20;
const GAP = 50;

let cursor = PAD_X;
const placed = boxes.map((b) => {
	const x = cursor;
	cursor += b.width + GAP;
	return { ...b, x };
});
// Remove trailing GAP from the last box; right edge of content:
const contentRight = cursor - GAP + PAD_X;
const viewW = contentRight;

// "signs" arrow geometry between adjacent boxes — right-to-left.
// SVG marker-end places the marker at (x2, y2), so x2 is the head.
const ARROW_Y = BOX_Y_CENTER;
const arrows = placed.slice(0, -1).map((left, i) => {
	const right = placed[i + 1];
	const xRightEdgeOfLeft = left.x + left.width;
	const xLeftEdgeOfRight = right.x;
	return {
		// Arrow points right-to-left: tail on the right, head on the left.
		xTail: xLeftEdgeOfRight - 4, // right end of the arrow (signer side)
		xHead: xRightEdgeOfLeft + 4, // left end of the arrow (signed side)
		midX: (xRightEdgeOfLeft + xLeftEdgeOfRight) / 2,
	};
});

// Trust-store pill — sits centered above the root box.
const rootBox = placed[placed.length - 1];
const TRUST_W = 230;
const TRUST_H = 26;
const TRUST_X = rootBox.x + rootBox.width / 2 - TRUST_W / 2;
const TRUST_Y = 8;
const TRUST_Y_BOTTOM = TRUST_Y + TRUST_H; // 34
const TRUST_CENTER_X = rootBox.x + rootBox.width / 2;

// Subtitle row sits a few px below the box.
const SUBTITLE_Y = BOX_Y_BOTTOM + 16; // 146

const viewH = SUBTITLE_Y + 8; // 154
---

<Figure
	caption={"Validating a TLS certificate is walking the chain rightward until you reach a CA already in the trust store. A self-signed cert has no chain to walk — it stops at itself, the walk fails, and the browser shows “your connection is not private.”"}
>
	<div style="overflow-x: auto;">
		<svg
			viewBox={`0 0 ${viewW} ${viewH}`}
			role="img"
			aria-label="The TLS certificate chain. A leaf cert for CN=localhost is signed by an intermediate CA, which is signed by a root CA. The root CA is trusted by the operating system and browser trust store. The boxes grow wider from left to right to signal trust scope expanding from one hostname to every site the store vouches for."
			xmlns="http://www.w3.org/2000/svg"
			style={`width: 100%; min-width: ${viewW}px; height: auto; display: block;`}
		>
			<defs>
				<marker
					id="cert-chain-arrow"
					viewBox="0 0 10 10"
					refX="9"
					refY="5"
					markerWidth="7"
					markerHeight="7"
					orient="auto-start-reverse"
				>
					<path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
				</marker>
			</defs>

			{/* ── Trust store pill, anchored above the root box ── */}
			<g>
				<rect
					x={TRUST_X}
					y={TRUST_Y}
					width={TRUST_W}
					height={TRUST_H}
					rx="13"
					ry="13"
					fill="none"
					stroke="#9ca3af"
					stroke-width="1"
					stroke-dasharray="4 3"
				/>
				<text
					x={TRUST_CENTER_X}
					y={TRUST_Y + TRUST_H / 2}
					font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
					font-size="12"
					fill="#9ca3af"
					text-anchor="middle"
					dominant-baseline="central"
				>
					OS / browser trust store
				</text>
			</g>

			{/* ── Upward arrow from root box to trust store, with "trusted by" label ── */}
			<g>
				<line
					x1={TRUST_CENTER_X}
					y1={BOX_Y - 2}
					x2={TRUST_CENTER_X}
					y2={TRUST_Y_BOTTOM + 2}
					stroke="currentColor"
					stroke-width="1.25"
					marker-end="url(#cert-chain-arrow)"
				/>
				<text
					x={TRUST_CENTER_X + 8}
					y={(BOX_Y + TRUST_Y_BOTTOM) / 2 + 4}
					font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
					font-size="11"
					fill="currentColor"
					text-anchor="start"
				>
					trusted by
				</text>
			</g>

			{/* ── Right-to-left "signs" arrows between adjacent boxes ── */}
			{arrows.map((a) => (
				<g>
					<line
						x1={a.xTail}
						y1={ARROW_Y}
						x2={a.xHead}
						y2={ARROW_Y}
						stroke="currentColor"
						stroke-width="1.25"
						marker-end="url(#cert-chain-arrow)"
					/>
					<text
						x={a.midX}
						y={ARROW_Y - 8}
						font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
						font-size="11"
						fill="currentColor"
						text-anchor="middle"
					>
						signs
					</text>
				</g>
			))}

			{/* ── Chain boxes ── */}
			{placed.map((b) => (
				<g>
					<rect
						x={b.x}
						y={BOX_Y}
						width={b.width}
						height={BOX_H}
						rx="6"
						ry="6"
						fill={
							b.isAnchor
								? 'var(--sl-color-accent-low, color-mix(in srgb, currentColor 8%, transparent))'
								: 'var(--sl-color-bg-sidebar, transparent)'
						}
						stroke={b.isAnchor ? 'var(--sl-color-accent, currentColor)' : 'currentColor'}
						stroke-width={b.isAnchor ? '2' : '1.5'}
					/>
					<text
						x={b.x + b.width / 2}
						y={BOX_Y_CENTER}
						font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
						font-size="14"
						font-weight="600"
						fill="currentColor"
						text-anchor="middle"
						dominant-baseline="central"
					>
						{b.title}
					</text>
					<text
						x={b.x + b.width / 2}
						y={SUBTITLE_Y}
						font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
						font-size="11"
						fill="#9ca3af"
						text-anchor="middle"
					>
						{b.subtitle}
					</text>
				</g>
			))}
		</svg>
	</div>
</Figure>
