---
// Diagram: leftmost-prefix made spatial (diagram id: composite-prefix-diagram,
// Chapter 039 Lesson 1 — "Indexes that earn their weight"). The point: a
// composite index on (org_id, created_at) is sorted by org_id FIRST, so an
// org_id filter lands one contiguous block, but a created_at filter can't use
// the sort because the dates are only ordered WITHIN each org group, never
// globally.
//
// LAYOUT: one sorted two-column table (org_id | created_at), 8 rows in sorted
// order. The org_id column is banded by group so the three equal-org runs read
// as solid blocks at a glance.
//
//   LEFT annotation column  — a GREEN bracket spanning the three org_id = 7
//     rows, labelled "where org_id = 7 → one contiguous block, jump straight
//     to it". Equal-org rows sit together, so the index hands the engine that
//     block directly.
//
//   RIGHT annotation column — ORANGE markers on one early-January date inside
//     each org group (01-02 in org 7, 01-03 in org 9, 01-04 in org 12). Those
//     three markers land in three separate, non-adjacent regions of the table,
//     showing the early-Jan dates are scattered: the column is NOT globally
//     sorted by date, so `where created_at = '2026-01-03'` (no org_id) can't
//     jump to a block. A callout points at the 01-03 row (the date named in
//     the caption).
//
// Colour convention (matches the sibling seq-scan-vs-index diagram): GREEN =
// the index can serve it (contiguous block); ORANGE = the index can't help
// (scattered, wasted). Neutral slate chrome carries no meaning.
//
// House style follows the sibling diagram: pinned `color-scheme: light` so the
// hand-picked tints survive dark mode, inline style strings only, `margin: 0`
// on every inner element to defeat Starlight's injected prose margin-top,
// box-sizing: border-box throughout. Row-matched annotation cells share the
// table's vertical rhythm (one fixed-height cell per data row) so glyphs line
// up 1:1 with their row — no fragile spacer math. No leader lines, so the
// figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// neutral chrome — carries no meaning.
const CELL_BORDER = '#e2e8f0'; // slate-200
const HEAD_BG = '#f1f5f9'; // slate-100

// CAN SERVE — green (contiguous block, the index helps).
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_INK = '#15803d'; // green-700

// CAN'T HELP — orange (scattered, wasted).
const ORANGE = '#ea580c'; // orange-600
const ORANGE_BG = '#fff7ed'; // orange-50 wash
const ORANGE_INK = '#c2410c'; // orange-700

// the sorted index entries — sorted by org_id first, then created_at within
// each org. `jan` flags the early-January row we mark inside each group (the
// chronologically-first January date per group), to show those dates are
// scattered across the table. `focus` is the exact 01-03 row the caption names.
type Row = {
  org: number;
  date: string;
  block: boolean; // part of the green org_id = 7 block
  jan: boolean; // an early-January marker (one per org group)
  focus: boolean; // the '2026-01-03' row the callout points at
};
const rows: Row[] = [
  { org: 7, date: '2026-01-02', block: true, jan: true, focus: false },
  { org: 7, date: '2026-01-05', block: true, jan: false, focus: false },
  { org: 7, date: '2026-02-11', block: true, jan: false, focus: false },
  { org: 9, date: '2026-01-03', block: false, jan: true, focus: true },
  { org: 9, date: '2026-01-09', block: false, jan: false, focus: false },
  { org: 9, date: '2026-03-01', block: false, jan: false, focus: false },
  { org: 12, date: '2026-01-04', block: false, jan: true, focus: false },
  { org: 12, date: '2026-02-20', block: false, jan: false, focus: false },
];

// subtle per-group banding on the org_id column so equal-org runs read as
// solid blocks. Two alternating neutral washes, keyed by group index.
const groupBand = ['#f8fafc', '#eef2f7']; // slate-50 / slightly deeper
const orgOrder = [...new Set(rows.map((r) => r.org))];
const bandFor = (org: number) => groupBand[orgOrder.indexOf(org) % 2];

const ROW_H = 30; // px, one data row — shared by table cells and anno cells
const HEAD_H = 30; // px, the table header row — anno columns prepend a spacer
// of this height so their per-row cells line up 1:1 with the DATA rows below
// the header (the sibling seq-scan diagram has no header, so it needs none).

// ---- outer stage ---------------------------------------------------------
// top-aligned so the row-matched annotation columns (which begin with a
// header-height spacer) line up with the table's rows. Centering against the
// tallest sibling would float the shorter columns down and break the match.
const stage = [
  'display: flex',
  'flex-wrap: wrap',
  'align-items: flex-start',
  'justify-content: center',
  'column-gap: 6px',
  'row-gap: 16px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// ---- LEFT annotation column: the green contiguous-block bracket -----------
// a vertical green bracket (a left border + two end caps) drawn next to the
// three org_id = 7 rows, with its label to the left of the bracket.
const blockRows = rows.filter((r) => r.block).length;

// the left annotation is a label (vertically centred against the org-block,
// see leftLabel) sitting beside a row-matched bracket column. The bracket
// column has a header-height spacer, then one cell per data row; the green
// bracket border is drawn only across the org=7 cells so it spans exactly the
// contiguous block — no centering math.
const leftAnno = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'align-items: flex-start',
  'gap: 8px',
  'margin: 0',
  'max-width: 188px',
].join('; ');

// the descriptive label, nudged down so it sits centred against the three
// org=7 rows (header spacer + half the 3-row block).
const leftLabel = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'justify-content: center',
  'gap: 3px',
  'margin: 0',
  `padding-top: ${HEAD_H}px`,
  `min-height: ${blockRows * ROW_H}px`,
  'text-align: right',
].join('; ');

// the row-matched bracket column: spacer + per-row cells.
const bracketCol = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'margin: 0',
  'width: 9px',
].join('; ');
const bracketSpacer = [
  'box-sizing: border-box',
  'margin: 0',
  `height: ${HEAD_H}px`,
].join('; ');
// one bracket cell; `pos`: 'top' | 'mid' | 'bottom' draws the relevant edges of
// the green bracket, 'none' leaves the cell empty.
const bracketCell = (pos: 'top' | 'mid' | 'bottom' | 'none') => {
  const base = [
    'box-sizing: border-box',
    'margin: 0',
    `height: ${ROW_H}px`,
    'width: 9px',
  ];
  if (pos === 'none') return base.join('; ');
  base.push(`border-right: 2.5px solid ${GREEN}`);
  if (pos === 'top')
    base.push(
      `border-top: 2.5px solid ${GREEN}`,
      'border-top-right-radius: 6px',
    );
  if (pos === 'bottom')
    base.push(
      `border-bottom: 2.5px solid ${GREEN}`,
      'border-bottom-right-radius: 6px',
    );
  return base.join('; ');
};

const labelQuery = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 12px',
  'font-weight: 800',
  'line-height: 1.25',
  `color: ${GREEN_INK}`,
].join('; ');
const labelGloss = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 600',
  'line-height: 1.3',
  `color: ${INK_SOFT}`,
].join('; ');

// ---- the table -----------------------------------------------------------
const table = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'margin: 0',
  'border-radius: 12px',
  `border: 1.5px solid ${CELL_BORDER}`,
  'overflow: hidden',
  `background: ${SURFACE}`,
].join('; ');

const headRow = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  `height: ${HEAD_H}px`,
  'margin: 0',
  `background: ${HEAD_BG}`,
  `border-bottom: 1.5px solid ${CELL_BORDER}`,
].join('; ');
const headCell = (extra = '') =>
  [
    'box-sizing: border-box',
    'margin: 0',
    'padding: 6px 12px',
    `font-family: ${mono}`,
    'font-size: 11px',
    'font-weight: 800',
    'letter-spacing: 0.02em',
    'line-height: 1.2',
    `color: ${INK}`,
    'white-space: nowrap',
    extra,
  ].join('; ');

const bodyRow = [
  'box-sizing: border-box',
  'display: flex',
  'margin: 0',
  `height: ${ROW_H}px`,
].join('; ');

// org_id cell: banded by group, with a green wash on the org=7 block rows.
const orgCell = (r: Row, isFirstInGroup: boolean) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'width: 84px',
    'margin: 0',
    'padding: 0 12px',
    `background: ${r.block ? GREEN_BG : bandFor(r.org)}`,
    `border-right: 1.5px solid ${CELL_BORDER}`,
    isFirstInGroup ? `border-top: 1px solid ${CELL_BORDER}` : 'border-top: none',
    `font-family: ${mono}`,
    'font-size: 13px',
    `font-weight: ${r.block ? 800 : 700}`,
    'line-height: 1',
    `color: ${r.block ? GREEN_INK : INK}`,
  ].join('; ');

// created_at cell: orange wash on the early-January marker rows.
const dateCell = (r: Row) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'width: 132px',
    'margin: 0',
    'padding: 0 12px',
    `background: ${r.jan ? ORANGE_BG : SURFACE}`,
    `border-top: 1px solid ${CELL_BORDER}`,
    `font-family: ${mono}`,
    'font-size: 13px',
    `font-weight: ${r.jan ? 800 : 600}`,
    'line-height: 1',
    `color: ${r.jan ? ORANGE_INK : INK_SOFT}`,
  ].join('; ');
// the first body row needs no top border (the header already drew one).
const noTop = 'border-top: none';

// ---- RIGHT annotation column: scattered-date markers ---------------------
// one row-matched cell per data row; an orange dot on each early-January row,
// a pointing arrow + the dates-aren't-sorted gloss anchored on the focus row.
const rightAnno = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'margin: 0',
  'width: 26px',
].join('; ');
// a header-height spacer so the marker cells below line up with the DATA rows.
const headSpacer = ['box-sizing: border-box', 'margin: 0', `height: ${HEAD_H}px`].join(
  '; ',
);
const markCell = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'justify-content: flex-start',
  `height: ${ROW_H}px`,
  'margin: 0',
].join('; ');
const markDot = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'justify-content: center',
  'width: 9px',
  'height: 9px',
  'margin: 0',
  'border-radius: 999px',
  `background: ${ORANGE}`,
].join('; ');
const focusArrow = [
  'margin: 0',
  `color: ${ORANGE}`,
  'font-size: 15px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');

// the gloss to the right of the markers, centred against the DATA rows (it tops
// out level with the table, so a header-height pad pushes it onto the body).
const rightGloss = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'justify-content: center',
  'gap: 3px',
  'margin: 0',
  `padding-top: ${HEAD_H}px`,
  `min-height: ${rows.length * ROW_H}px`,
  'max-width: 184px',
].join('; ');
const glossQuery = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 12px',
  'font-weight: 800',
  'line-height: 1.25',
  `color: ${ORANGE_INK}`,
].join('; ');
const glossText = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 600',
  'line-height: 1.3',
  `color: ${INK_SOFT}`,
].join('; ');

// a legend strip under the table tying the two colours to the two verdicts.
const legend = [
  'box-sizing: border-box',
  'flex: 1 1 100%',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'justify-content: center',
  'column-gap: 18px',
  'row-gap: 6px',
  'margin: 0',
  'padding-top: 4px',
].join('; ');
const legendItem = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'gap: 6px',
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 600',
  `color: ${INK_SOFT}`,
].join('; ');
const swatch = (color: string) =>
  [
    'box-sizing: border-box',
    'display: inline-block',
    'width: 12px',
    'height: 12px',
    'margin: 0',
    'border-radius: 3px',
    `background: ${color}`,
  ].join('; ');

// precompute which body rows start a new org group (for the inner divider).
const firstInGroup = rows.map(
  (r, i) => i === 0 || rows[i - 1].org !== r.org,
);
---

<Figure>
  <div style={stage}>
    {/* ============ LEFT — contiguous-block bracket ============ */}
    <div style={leftAnno}>
      <div style={leftLabel}>
        <p style={labelQuery}>where org_id = 7</p>
        <p style={labelGloss}>
          one contiguous block &mdash; jump straight to it
        </p>
      </div>
      {/* row-matched bracket column: header spacer, then a green bracket edge
          on each org=7 row (top / mid / bottom), empty cells elsewhere. */}
      <div style={bracketCol} aria-hidden="true">
        <div style={bracketSpacer}></div>
        {
          rows.map((r, i) => {
            const blockIdxs = rows
              .map((row, idx) => (row.block ? idx : -1))
              .filter((idx) => idx >= 0);
            const pos = !r.block
              ? 'none'
              : i === blockIdxs[0]
                ? 'top'
                : i === blockIdxs[blockIdxs.length - 1]
                  ? 'bottom'
                  : 'mid';
            return <div style={bracketCell(pos)}></div>;
          })
        }
      </div>
    </div>

    {/* ============ the sorted index table ============ */}
    <div style={table}>
      <div style={headRow}>
        <div style={headCell(`width: 84px; border-right: 1.5px solid ${CELL_BORDER};`)}>
          org_id
        </div>
        <div style={headCell('width: 132px;')}>created_at</div>
      </div>
      {
        rows.map((r, i) => (
          <div style={bodyRow}>
            <div
              style={
                orgCell(r, firstInGroup[i]) + (i === 0 ? `; ${noTop}` : '')
              }
            >
              {r.org}
            </div>
            <div style={dateCell(r) + (i === 0 ? `; ${noTop}` : '')}>
              {r.date}
            </div>
          </div>
        ))
      }
    </div>

    {/* ============ RIGHT — scattered-date markers + gloss ============ */}
    <div style={rightAnno} aria-hidden="true">
      <div style={headSpacer}></div>
      {
        rows.map((r) => (
          <span style={markCell}>
            {
              r.focus ? (
                <span style={focusArrow}>&#9664;</span>
              ) : r.jan ? (
                <span style={markDot}></span>
              ) : null
            }
          </span>
        ))
      }
    </div>
    <div style={rightGloss}>
      <p style={glossQuery}>{"where created_at = '2026-01-03'"}</p>
      <p style={glossText}>
        the early-January dates are scattered &mdash; not globally sorted, so
        the index can&rsquo;t help
      </p>
    </div>

    {/* ============ legend ============ */}
    <div style={legend}>
      <span style={legendItem}>
        <span style={swatch(GREEN_BG)}></span>
        org_id leads &rarr; equal orgs sit together
      </span>
      <span style={legendItem}>
        <span style={swatch(ORANGE)}></span>
        same early-January date, three different groups
      </span>
    </div>
  </div>
  <Fragment slot="caption">
    A composite index on <code>(org_id, created_at)</code> is sorted by{' '}
    <code>org_id</code> first &mdash; so an <code>org_id</code> filter lands a
    contiguous block, but a <code>created_at</code> filter can&rsquo;t use the
    sort.
  </Fragment>
</Figure>
