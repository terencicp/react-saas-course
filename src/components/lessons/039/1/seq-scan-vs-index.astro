---
// Diagram: sequential scan vs. index scan, side by side (diagram id:
// seq-scan-vs-index, Chapter 039 Lesson 1 — "Indexes that earn their weight").
// The one durable picture for "an index changes the PATH to a row, never the
// row itself." Two equal-height panels, laid out horizontally, compressed
// vertically for the laptop viewport.
//
// LEFT PANEL "Sequential scan": an UNORDERED stack of 8 row chips with
// scrambled ids (17, 3, 88, 42, 9, 56, 21, 70). A vertical arrow rail on the
// left steps down from the first chip; the engine touches every row in order
// until it hits the match. The first three chips (17, 3, 88) are tinted ORANGE
// = "read" (a miss); the fourth chip (42) is GREEN = the match. The four rows
// below it stay neutral and un-touched — but the point in the sublabel is that
// on a big table the scan keeps going through most of them. Sublabel: "reads
// rows until it finds the match".
//
// RIGHT PANEL "Index scan": a SORTED column of the same keys
// (3, 9, 17, 21, 42, 56, 70, 88), each carrying a small "→ row" pointer glyph.
// One arrow lands directly on the 42 entry (GREEN); a dashed pointer line runs
// from that entry across to a single "row 42" target box on the right. No other
// entry is tinted — the engine jumps straight to the key. Sublabel: "jumps
// straight to the key".
//
// Colour convention: ORANGE = rows the scan had to read (wasted work); GREEN =
// the match / the direct landing. Neutral slate chrome carries no meaning.
//
// House style follows the ch 033/034 family: pinned `color-scheme: light` so the
// hand-picked tints survive dark mode, inline style strings only (a reader can
// copy the source and see exactly what styled it), `margin: 0` on every inner
// element to defeat Starlight's injected prose margin-top, box-sizing:
// border-box throughout. No leader lines, so the figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// neutral chrome — carries no meaning.
const CHIP_BORDER = '#cbd5e1'; // slate-300
const CHIP_BG = '#f8fafc'; // slate-50
const PANEL_BORDER = '#e2e8f0'; // slate-200

// READ / wasted work — orange.
const ORANGE = '#ea580c'; // orange-600
const ORANGE_BG = '#fff7ed'; // orange-50 wash
const ORANGE_INK = '#c2410c'; // orange-700

// MATCH / direct landing — green.
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_INK = '#15803d'; // green-700

// scrambled, unordered table (left) and the sorted index (right).
const TARGET_ID = 42;
const tableIds = [17, 3, 88, 42, 9, 56, 21, 70];
const indexKeys = [3, 9, 17, 21, 42, 56, 70, 88];
// how far the scan walks before it finds the match (inclusive of the hit).
const matchPos = tableIds.indexOf(TARGET_ID); // 3 → first three are reads

// ---- outer stage: two panels side by side --------------------------------
const stage = [
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 18px',
  'row-gap: 18px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// one panel — a titled card holding the chip column.
const panel = [
  'box-sizing: border-box',
  'flex: 1 1 300px',
  'display: flex',
  'flex-direction: column',
  'align-items: stretch',
  'gap: 10px',
  'margin: 0',
  'padding: 14px 16px 12px',
  'border-radius: 14px',
  `border: 1.5px solid ${PANEL_BORDER}`,
  `background: ${SURFACE}`,
  'min-width: 0',
  'max-width: 420px',
].join('; ');

// panel title.
const panelTitle = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 13px',
  'font-weight: 800',
  'letter-spacing: 0.01em',
  'line-height: 1.2',
  `color: ${INK}`,
].join('; ');

// "what the engine does here" subtitle under the title.
const panelLede = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 11px',
    'font-weight: 600',
    'line-height: 1.3',
    `color: ${ink}`,
  ].join('; ');

// ---- LEFT: scan rail + chip column ---------------------------------------
// the rail (an arrow) and the chip column sit in a row.
const scanBody = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: flex-start',
  'gap: 8px',
  'margin: 0',
].join('; ');

// ROW-MATCHED ANNOTATION COLUMN. Every annotation column (the scan rail, the
// index landing arrow, the dashed pointer) shares the chip column's vertical
// rhythm: a flex column with the SAME `gap: 6px` and one `height: 28px` cell per
// data row. Putting a glyph in the matching row's cell lines it up 1:1 with the
// chip in that row — no fragile flex-spacer math.
const annoCol = (width: string) =>
  [
    'box-sizing: border-box',
    'flex: 0 0 auto',
    'display: flex',
    'flex-direction: column',
    'gap: 6px',
    'margin: 0',
    `width: ${width}`,
  ].join('; ');
const annoCell = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'height: 28px',
  'margin: 0',
].join('; ');

// the chip column (left + right share this).
const chipCol = [
  'box-sizing: border-box',
  'flex: 1 1 auto',
  'display: flex',
  'flex-direction: column',
  'gap: 6px',
  'margin: 0',
  'min-width: 0',
].join('; ');

// one row chip. `state`: 'read' (orange), 'match' (green), or 'idle' (neutral).
const chip = (state: 'read' | 'match' | 'idle') => {
  const [bd, bg, ink] =
    state === 'read'
      ? [ORANGE, ORANGE_BG, ORANGE_INK]
      : state === 'match'
        ? [GREEN, GREEN_BG, GREEN_INK]
        : [CHIP_BORDER, CHIP_BG, INK_SOFT];
  return [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'justify-content: space-between',
    'gap: 8px',
    'margin: 0',
    'padding: 4px 10px',
    'height: 28px',
    'border-radius: 8px',
    `border: 1.5px solid ${bd}`,
    `background: ${bg}`,
    `color: ${ink}`,
    state === 'match' ? 'font-weight: 800' : 'font-weight: 700',
  ].join('; ');
};
const chipLabel = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 13px',
  'line-height: 1',
].join('; ');
const chipKey = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 13px',
    'font-weight: 800',
    'line-height: 1',
    `color: ${ink}`,
  ].join('; ');
// the tiny status tag on the touched chips ("read" / "match").
const chipTag = (ink: string) =>
  [
    'box-sizing: border-box',
    'margin: 0',
    'padding: 1px 6px',
    'border-radius: 999px',
    `border: 1px solid ${ink}`,
    `background: ${SURFACE}`,
    `color: ${ink}`,
    `font-family: ${sans}`,
    'font-size: 8.5px',
    'font-weight: 800',
    'text-transform: uppercase',
    'letter-spacing: 0.04em',
    'line-height: 1.4',
    'white-space: nowrap',
  ].join('; ');

// ---- RIGHT: sorted index column + pointer + row target -------------------
// the index column and the row target sit in a row, with a pointer between.
const indexBody = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: flex-start',
  'gap: 0',
  'margin: 0',
].join('; ');

// one index entry: key on the left, "→ row" pointer glyph on the right.
const entry = (hit: boolean) => {
  const [bd, bg, ink] = hit
    ? [GREEN, GREEN_BG, GREEN_INK]
    : [CHIP_BORDER, CHIP_BG, INK_SOFT];
  return [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'justify-content: space-between',
    'gap: 8px',
    'margin: 0',
    'padding: 4px 10px',
    'height: 28px',
    'border-radius: 8px',
    `border: 1.5px solid ${bd}`,
    `background: ${bg}`,
    `color: ${ink}`,
    hit ? 'font-weight: 800' : 'font-weight: 700',
  ].join('; ');
};
const entryPtr = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 11px',
    'font-weight: 700',
    'line-height: 1',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

// the green landing arrow that points into the matched index entry — a
// row-matched annotation cell (see annoCol/annoCell above).
const landArrow = [
  `color: ${GREEN}`,
  'font-size: 18px',
  'font-weight: 900',
  'line-height: 1',
  'margin: 0',
].join('; ');

// the dashed pointer line from the matched entry to the row target, drawn
// inside the matching row's annotation cell.
const pointerLine = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'width: 100%',
  'margin: 0',
].join('; ');
const dash = [
  'box-sizing: border-box',
  'flex: 1 1 auto',
  'height: 0',
  'margin: 0',
  `border-top: 2px dashed ${GREEN}`,
].join('; ');
const dashHead = [
  'margin: 0 0 0 -2px',
  `color: ${GREEN}`,
  'font-size: 14px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');

// the single "row 42" target box on the right — a row-matched cell so the box
// centres on the matched (5th) entry and the dashed pointer stays horizontal.
const rowTargetCell = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'justify-content: flex-start',
  'height: 28px',
  'overflow: visible',
  'margin: 0',
].join('; ');
const rowTarget = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: flex-start',
  'gap: 2px',
  'margin: 0',
  'padding: 6px 10px',
  'border-radius: 8px',
  `border: 1.5px solid ${GREEN}`,
  `background: ${GREEN_BG}`,
].join('; ');
const rowTargetTop = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 8.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.04em',
  'line-height: 1.3',
  `color: ${GREEN_INK}`,
].join('; ');
const rowTargetKey = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 14px',
  'font-weight: 800',
  'line-height: 1.1',
  `color: ${GREEN_INK}`,
].join('; ');

// shared sublabel under each panel.
const subLabel = (ink: string) =>
  [
    'margin: 0',
    'padding-top: 2px',
    `font-family: ${sans}`,
    'font-size: 11px',
    'font-weight: 700',
    'line-height: 1.3',
    'text-align: center',
    `color: ${ink}`,
  ].join('; ');
---

<Figure>
  <div style={stage}>
    {/* ============ LEFT — Sequential scan ============ */}
    <div style={panel}>
      <p style={panelTitle}>Sequential scan</p>
      <p style={panelLede(ORANGE_INK)}>
        no shortcut &mdash; the table is an unordered pile
      </p>

      <div style={scanBody}>
        {/* the stepping arrow rail — one row-matched cell per chip: a small
            down-chevron in each row the scan READS, then the solid head on the
            match row. Empty cells below (the scan stopped). */}
        <div style={annoCol('14px')} aria-hidden="true">
          {
            tableIds.map((id, i) => {
              const isMatch = id === TARGET_ID;
              const isRead = i < matchPos;
              return (
                <span style={annoCell}>
                  {
                    isMatch ? (
                      <span
                        style={`color: ${GREEN}; font-size: 15px; font-weight: 900; line-height: 1; margin: 0;`}
                      >
                        &#9660;
                      </span>
                    ) : isRead ? (
                      <span
                        style={`color: ${ORANGE}; font-size: 12px; font-weight: 900; line-height: 1; margin: 0;`}
                      >
                        &#8675;
                      </span>
                    ) : (
                      <span style="margin: 0;">&nbsp;</span>
                    )
                  }
                </span>
              );
            })
          }
        </div>

        <div style={chipCol}>
          {
            tableIds.map((id, i) => {
              const isMatch = id === TARGET_ID;
              const isRead = i < matchPos;
              const state = isMatch ? 'match' : isRead ? 'read' : 'idle';
              const ink =
                state === 'match'
                  ? GREEN_INK
                  : state === 'read'
                    ? ORANGE_INK
                    : INK_SOFT;
              return (
                <div style={chip(state)}>
                  <span style={chipKey(ink)}>{`id ${id}`}</span>
                  {
                    isMatch ? (
                      <span style={chipTag(GREEN_INK)}>&check; match</span>
                    ) : isRead ? (
                      <span style={chipTag(ORANGE_INK)}>read</span>
                    ) : (
                      <span style={chipLabel}>&nbsp;</span>
                    )
                  }
                </div>
              );
            })
          }
        </div>
      </div>

      <p style={subLabel(INK_SOFT)}>
        reads rows until it finds the match &mdash; here it touched {matchPos + 1}
      </p>
    </div>

    {/* ============ RIGHT — Index scan ============ */}
    <div style={panel}>
      <p style={panelTitle}>Index scan</p>
      <p style={panelLede(GREEN_INK)}>
        a separate, sorted copy of the key
      </p>

      <div style={indexBody}>
        {/* green landing arrow — a row-matched cell, glyph only on the match */}
        <div style={annoCol('14px')} aria-hidden="true">
          {indexKeys.map((k) => (
            <span style={annoCell}>
              {k === TARGET_ID ? <span style={landArrow}>&#9654;</span> : null}
            </span>
          ))}
        </div>

        {/* the sorted index column */}
        <div style={chipCol}>
          {
            indexKeys.map((k) => {
              const hit = k === TARGET_ID;
              const ink = hit ? GREEN_INK : INK_SOFT;
              return (
                <div style={entry(hit)}>
                  <span style={chipKey(ink)}>{k}</span>
                  <span style={entryPtr(ink)}>&rarr; row</span>
                </div>
              );
            })
          }
        </div>

        {/* dashed pointer from the matched entry across to the row target —
            drawn in the match row's cell, empty cells elsewhere */}
        <div style={annoCol('30px')} aria-hidden="true">
          {indexKeys.map((k) => (
            <span style={annoCell}>
              {
                k === TARGET_ID ? (
                  <span style={pointerLine}>
                    <span style={dash}></span>
                    <span style={dashHead}>&#9654;</span>
                  </span>
                ) : null
              }
            </span>
          ))}
        </div>

        {/* the single matched row, fetched directly — placed in the match
            row's cell so it lines up with the pointer */}
        <div style={annoCol('auto')}>
          {indexKeys.map((k) => (
            <span style={rowTargetCell}>
              {
                k === TARGET_ID ? (
                  <span style={rowTarget}>
                    <span style={rowTargetTop}>&check; the row</span>
                    <span style={rowTargetKey}>id {TARGET_ID}</span>
                  </span>
                ) : null
              }
            </span>
          ))}
        </div>
      </div>

      <p style={subLabel(INK_SOFT)}>
        jumps straight to the key &mdash; one entry, then the row
      </p>
    </div>
  </div>
  <Fragment slot="caption">
    An index changes the <em>path</em> to a row, never the row itself.
  </Fragment>
</Figure>
