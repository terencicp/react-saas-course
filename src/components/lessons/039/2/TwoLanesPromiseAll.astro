---
// TwoLanesPromiseAll — the "layer confusion" figure for Ch039 L2
// ("Spotting and fixing N+1"). Its whole job is to make one idea visible at a
// glance: `Promise.all` rearranges the *JavaScript-await* layer (top lane) but
// leaves the *database round-trip* layer (bottom lane) pixel-for-pixel the same.
//
// Two stacked lanes share one left-to-right time axis. Each lane holds two
// sub-rows — "Sequential" and "Promise.all" — so the reader compares the two
// strategies on the same picture:
//
//   LANE 1  JavaScript awaits   (green tint — this layer DID change)
//     Sequential : N await blocks end-to-end, spanning the full axis (long).
//     Promise.all: the same N blocks launched together — a short overlapping
//                  fan at the start of the axis (visibly short).
//
//   LANE 2  Database round-trips (red/orange tint — this layer did NOT change)
//     Sequential : N identical statement ticks across the axis.
//     Promise.all: the SAME N identical ticks — same count, same width.
//
// The punchline is the contrast in width: the top lane shrinks between the two
// rows; the bottom lane is identical. Pure HTML + CSS so it survives Figure's
// expand lightbox and is devtools-inspectable. `not-content` + per-element
// `margin: 0` defeat Starlight's prose-margin injection (see html-css.md).
//
// Mirrors the inline-style + theme-variable conventions of the sibling
// RoundtripFrame.astro in this same lesson folder.

// Number of statements / awaits drawn per row. Kept modest so the ticks stay
// readable; the count is identical in both lanes by design.
const N = 8;
const items = Array.from({ length: N }, (_, i) => i + 1);

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Lane accents.
const GREEN = "#16a34a"; // green-600 — the layer Promise.all rearranges
const RED = "#dc2626"; // red-600   — the layer it leaves untouched

// ---- shared chrome -----------------------------------------------------

const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 14px",
  "width: 100%",
  "max-width: 760px",
  "margin-inline: auto",
].join("; ");

// One lane = a tinted card holding a header + two sub-rows.
const laneCard = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 10px",
    "padding: 12px 14px 13px",
    "border-radius: 12px",
    `border: 1.5px solid color-mix(in srgb, ${accent} 38%, transparent)`,
    `background: color-mix(in srgb, ${accent} 7%, var(--sl-color-gray-6))`,
  ].join("; ");

// Lane header: a coloured tag + the lane title + the verdict on the right.
const laneHead = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "gap: 9px",
  "flex-wrap: wrap",
].join("; ");

const laneTag = (accent: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "font-size: 13px",
    "font-weight: 700",
    "line-height: 1.2",
    "color: var(--sl-color-text)",
  ].join("; ");

const verdictPill = (accent: string, changed: boolean) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "margin-left: auto",
    "display: inline-flex",
    "align-items: center",
    "gap: 5px",
    "font-size: 10.5px",
    "font-weight: 800",
    "letter-spacing: 0.02em",
    "text-transform: uppercase",
    "padding: 3px 9px",
    "border-radius: 999px",
    `color: ${accent}`,
    `background: color-mix(in srgb, ${accent} 14%, transparent)`,
    `border: 1px solid color-mix(in srgb, ${accent} 40%, transparent)`,
  ].join("; ");

// A sub-row = small strategy label on the left, the track on the right.
const subRow = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: 92px minmax(0, 1fr)",
  "align-items: center",
  "gap: 10px",
].join("; ");

const strategyLabel = [
  reset,
  sans,
  "box-sizing: border-box",
  "font-size: 11px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-gray-2)",
  "text-align: right",
].join("; ");

// The track is the time-axis surface each row's blocks sit on.
const track = [
  reset,
  "box-sizing: border-box",
  "position: relative",
  "width: 100%",
  "height: 30px",
  "border-radius: 7px",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "border: 1px solid var(--sl-color-gray-5)",
].join("; ");

// ---- LANE 1: JavaScript awaits ----------------------------------------

// Sequential awaits: blocks laid end-to-end, filling the whole track.
const awaitSeqWrap = [
  reset,
  "box-sizing: border-box",
  "position: absolute",
  "inset: 4px",
  "display: flex",
  "gap: 3px",
].join("; ");

const awaitBlock = [
  reset,
  mono,
  "box-sizing: border-box",
  "flex: 1",
  "min-width: 0",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "border-radius: 4px",
  "font-size: 9.5px",
  "font-weight: 700",
  "line-height: 1",
  "color: #fff",
  `background: ${GREEN}`,
].join("; ");

// Promise.all awaits: the same N blocks launched together — a short overlapping
// fan pinned to the start of the axis. Each card is offset a few px right and
// down from the previous so the stack reads as "all at once", and the whole fan
// occupies only a sliver of the time axis (that's the point — it's short).
const awaitFanWrap = [
  reset,
  "box-sizing: border-box",
  "position: absolute",
  "top: 4px",
  "left: 4px",
  "bottom: 4px",
  "width: 132px",
  "max-width: calc(100% - 8px)",
].join("; ");

const awaitFanCard = (i: number) =>
  [
    reset,
    "box-sizing: border-box",
    "position: absolute",
    "top: 0",
    "bottom: 0",
    `left: ${i * 5}px`,
    "width: 26px",
    "border-radius: 4px",
    `background: ${GREEN}`,
    "border: 1px solid color-mix(in srgb, #000 18%, transparent)",
    `opacity: ${0.55 + (i / (N - 1)) * 0.45}`,
  ].join("; ");

const fanBrace = [
  reset,
  sans,
  "box-sizing: border-box",
  "position: absolute",
  "top: 50%",
  "left: 150px",
  "transform: translateY(-50%)",
  "font-size: 10px",
  "font-weight: 700",
  "line-height: 1.2",
  "white-space: nowrap",
  `color: ${GREEN}`,
].join("; ");

const laneNote = (accent: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "grid-column: 2",
    "font-size: 10.5px",
    "font-weight: 600",
    "line-height: 1.3",
    `color: color-mix(in srgb, ${accent} 75%, var(--sl-color-text))`,
  ].join("; ");

// ---- LANE 2: Database round-trips -------------------------------------

// Identical ticks in BOTH sub-rows — same count, same spacing, same width.
const tickWrap = [
  reset,
  "box-sizing: border-box",
  "position: absolute",
  "inset: 4px",
  "display: flex",
  "gap: 3px",
].join("; ");

const tick = [
  reset,
  mono,
  "box-sizing: border-box",
  "flex: 1",
  "min-width: 0",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "border-radius: 4px",
  "font-size: 9px",
  "font-weight: 700",
  "line-height: 1",
  "color: #fff",
  `background: ${RED}`,
].join("; ");

const tickLabel = (accent: string) =>
  [
    reset,
    mono,
    "box-sizing: border-box",
    "grid-column: 2",
    "font-size: 10px",
    "font-weight: 600",
    "line-height: 1.3",
    "color: var(--sl-color-gray-2)",
  ].join("; ");

// ---- shared time axis --------------------------------------------------

const axisRow = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: 92px minmax(0, 1fr)",
  "align-items: center",
  "gap: 10px",
  "margin-top: -2px",
].join("; ");

const axisLine = [
  reset,
  "box-sizing: border-box",
  "grid-column: 2",
  "position: relative",
  "height: 14px",
].join("; ");

const axisLabel = [
  reset,
  sans,
  "box-sizing: border-box",
  "position: absolute",
  "right: 0",
  "top: 50%",
  "transform: translateY(-50%)",
  "padding-left: 6px",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "background: var(--sl-color-bg-sidebar, var(--sl-color-gray-7))",
].join("; ");
---

<div class="not-content tlpa" style={root}>
  {/* ---- LANE 1 — JavaScript awaits (this layer changes) ---- */}
  <div style={laneCard(GREEN)}>
    <div style={laneHead}>
      <span style={laneTag(GREEN)}>
        JavaScript awaits — what <code class="tlpa-code">Promise.all</code> changes
      </span>
      <span style={verdictPill(GREEN, true)}>rearranged</span>
    </div>

    {/* Sequential: blocks end-to-end, full width */}
    <div style={subRow}>
      <span style={strategyLabel}>Sequential</span>
      <div style={track}>
        <div style={awaitSeqWrap}>
          {items.map((i) => <div style={awaitBlock}>{`await ${i}`}</div>)}
        </div>
      </div>
    </div>

    {/* Promise.all: overlapping fan at the start, short on the axis */}
    <div style={subRow}>
      <span style={strategyLabel}>Promise.all</span>
      <div style={track}>
        <div style={awaitFanWrap}>
          {items.map((i) => <div style={awaitFanCard(i - 1)} />)}
          <span style={fanBrace}>{`all ${N} awaits launched together`}</span>
        </div>
      </div>
    </div>

    <span style={laneNote(GREEN)}>The awaits now overlap — the lane gets shorter.</span>
  </div>

  {/* ---- LANE 2 — Database round-trips (this layer does NOT change) ---- */}
  <div style={laneCard(RED)}>
    <div style={laneHead}>
      <span style={laneTag(RED)}>
        Database round-trips — what <code class="tlpa-code">Promise.all</code> does
        <strong style="font-weight: 800; margin: 0 0 0 3px;">NOT</strong> change
      </span>
      <span style={verdictPill(RED, false)}>identical</span>
    </div>

    {/* Sequential: N identical statement ticks */}
    <div style={subRow}>
      <span style={strategyLabel}>Sequential</span>
      <div style={track}>
        <div style={tickWrap}>
          {items.map(() => <div style={tick}>SQL</div>)}
        </div>
      </div>
      <span style={tickLabel(RED)}>
        {`${N} × `}<code class="tlpa-code">line_items where invoice_id = …</code>
      </span>
    </div>

    {/* Promise.all: the SAME N identical ticks */}
    <div style={subRow}>
      <span style={strategyLabel}>Promise.all</span>
      <div style={track}>
        <div style={tickWrap}>
          {items.map(() => <div style={tick}>SQL</div>)}
        </div>
      </div>
      <span style={tickLabel(RED)}>
        {`${N} × `}<code class="tlpa-code">line_items where invoice_id = …</code>
        {" — same count, same trips"}
      </span>
    </div>

    <span style={laneNote(RED)}>
      Still N statements, N round-trips — the count never moved.
    </span>
  </div>

  {/* ---- shared time axis ---- */}
  <div style={axisRow}>
    <div class="tlpa-axis" style={axisLine}>
      <span style={axisLabel}>time →</span>
    </div>
  </div>
</div>

<style>
  /* Inline-code pills inside the diagram: keep them quiet so the lane titles
     read as one line. Strip Starlight's prose pill padding/background. */
  .tlpa .tlpa-code {
    margin: 0;
    padding: 0 2px;
    background: transparent;
    border: 0;
    font-size: 0.92em;
    white-space: nowrap;
    color: inherit;
  }

  /* The time-axis arrow line, drawn behind the "time →" label. */
  .tlpa .tlpa-axis::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 0;
    border-top: 1.5px solid var(--sl-color-gray-5);
    transform: translateY(-50%);
  }
  .tlpa .tlpa-axis::after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    width: 0;
    height: 0;
    transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid var(--sl-color-gray-5);
  }
</style>
