---
// RoundtripFrame — one frame of the N+1 round-trip timeline, used inside
// <DiagramSequence> in Ch039 L2 ("Spotting and fixing N+1"). The whole job of
// this figure is to make N+1 *felt* as a count of trips across the wire: the
// app on the left asks, the database on the right answers, and every statement
// is its own crossing of the lane. Scrubbing the steps watches the trip count
// climb from 1 (the parent list) to 21 (one child query per returned row).
//
// Layout is a stable three-column grid — App box | wire lane | Database box —
// where App and Database never move between steps. Only the wire lane and the
// round-trip counter change as the reader scrubs, so the stage never reflows.
//
// The wire lane holds a FIXED set of rows on every step (invoices, $1, $2, a
// collapsed "rest" cluster, and a total banner). Each row is active / done /
// pending / hidden per step; hidden rows keep their box via visibility so the
// height is constant. This mirrors the DriftFrame.astro pattern in Ch037 L1.
//
// Pure HTML + CSS so it survives DiagramSequence's stacked grid (inactive steps
// stay in layout). `not-content` + `margin: 0` resets defeat Starlight's
// prose-margin selector.

interface Props {
  step: 1 | 2 | 3 | 4 | 5;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const ACCENT = "var(--sl-color-accent)"; // blue — the active, in-flight trip
const RETURN = "#16a34a"; // green-600 — rows coming back

// Per-step running round-trip count shown in the counter pill.
const counters: Record<Props["step"], number> = { 1: 1, 2: 2, 3: 3, 4: 20, 5: 21 };
const count = counters[step];

// ---- wire-lane row model ----------------------------------------------
//
// Each row is one round-trip: a request arrow App -> DB (with a SQL label) and
// a return arrow DB -> App (with a result label). A row's `tone` decides how it
// reads:
//   active  — the trip happening this step (blue, full opacity)
//   done    — a trip already paid (grey, dimmed)
//   hidden  — not yet fired; box kept for layout, contents invisible

type Tone = "active" | "done" | "hidden";

interface Row {
  sql: string; // request label, App -> DB
  rows: string; // return label, DB -> App
  tone: Tone;
}

// The first three named round-trips, plus a collapsed "rest" cluster. Their
// tone is decided per step below.
function rowsForStep(s: number): Row[] {
  const parent: Tone =
    s === 1 ? "active" : "done"; // invoices list: fires first, then stays done
  const child1: Tone = s < 2 ? "hidden" : s === 2 ? "active" : "done"; // $1
  const child2: Tone = s < 3 ? "hidden" : s === 3 ? "active" : "done"; // $2

  return [
    {
      sql: "select … from invoices",
      rows: "20 rows",
      tone: parent,
    },
    {
      sql: "select … from line_items where invoice_id = $1",
      rows: "items",
      tone: child1,
    },
    {
      sql: "select … from line_items where invoice_id = $2",
      rows: "items",
      tone: child2,
    },
  ];
}

const rows = rowsForStep(step);

// The collapsed cluster ("…round-trips 4 through 20…") appears active on step 4
// and stays as a done block on step 5. Hidden (but space-reserving) before that.
const clusterTone: Tone = step < 4 ? "hidden" : step === 4 ? "active" : "done";

// ---- shared chrome -----------------------------------------------------

const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 12px",
  "width: 100%",
  "max-width: 720px",
  "margin-inline: auto",
].join("; ");

// Counter pill, top-right, always present.
const counterRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "justify-content: flex-end",
  "width: 100%",
].join("; ");

const counterPill = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: baseline",
  "gap: 7px",
  "padding: 4px 11px",
  "border-radius: 999px",
  `border: 1.5px solid color-mix(in srgb, ${ACCENT} 45%, transparent)`,
  `background: color-mix(in srgb, ${ACCENT} 12%, var(--sl-color-gray-6))`,
].join("; ");

const counterLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-2)",
].join("; ");

const counterNum = [
  reset,
  mono,
  "font-size: 18px",
  "font-weight: 800",
  "line-height: 1",
  `color: ${ACCENT}`,
].join("; ");

// The main stage: App | wire lane | Database.
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: auto minmax(0, 1fr) auto",
  "align-items: stretch",
  "gap: 12px",
  "width: 100%",
].join("; ");

// The two endpoint columns (App, Database) — fixed identity, never change.
const endpoint = (kind: "app" | "db") =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "justify-content: center",
    "gap: 5px",
    "width: 96px",
    "padding: 12px 8px",
    "border-radius: 11px",
    "border: 1.5px solid var(--sl-color-gray-4)",
    "background: var(--sl-color-gray-6)",
    "text-align: center",
  ].join("; ");

const endpointIcon = [
  reset,
  "font-size: 22px",
  "line-height: 1",
].join("; ");

const endpointTitle = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.15",
  "color: var(--sl-color-text)",
].join("; ");

const endpointSub = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The wire lane stacks the round-trip rows.
const lane = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 9px",
  "min-width: 0",
].join("; ");

// One round-trip row: request arrow on top, return arrow below.
const tripRow = (tone: Tone) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 3px",
    "min-width: 0",
    "transition: opacity 200ms ease",
    tone === "hidden" ? "visibility: hidden" : "",
    tone === "done" ? "opacity: 0.4" : "opacity: 1",
  ]
    .filter(Boolean)
    .join("; ");

// A directional line with a label sitting on it. `dir` flips the arrowhead.
const wire = (tone: Tone, dir: "out" | "back") => {
  const color =
    tone === "active"
      ? dir === "out"
        ? ACCENT
        : RETURN
      : "var(--sl-color-gray-3)";
  const weight = tone === "active" ? "2px" : "1.4px";
  return [
    reset,
    "box-sizing: border-box",
    "position: relative",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "min-width: 0",
    `--wire-color: ${color}`,
    `--wire-weight: ${weight}`,
    dir === "out" ? "padding: 0 14px 0 2px" : "padding: 0 2px 0 14px",
  ].join("; ");
};

// The label that rides on the wire — small pill so the line reads through.
const wireLabel = (tone: Tone, dir: "out" | "back") => {
  const color =
    tone === "active"
      ? dir === "out"
        ? ACCENT
        : RETURN
      : "var(--sl-color-gray-3)";
  return [
    reset,
    mono,
    "box-sizing: border-box",
    "position: relative",
    "z-index: 1",
    "max-width: 100%",
    "overflow: hidden",
    "text-overflow: ellipsis",
    "white-space: nowrap",
    "font-size: 11px",
    `font-weight: ${tone === "active" ? "700" : "600"}`,
    "line-height: 1.3",
    "padding: 1px 8px",
    "border-radius: 5px",
    `color: ${color}`,
    "background: var(--sl-color-bg, var(--sl-color-gray-7))",
    `border: 1px solid color-mix(in srgb, ${color} ${tone === "active" ? "40%" : "26%"}, transparent)`,
  ].join("; ");
};

// The return label is a short data pill (e.g. "20 rows").
const returnLabel = (tone: Tone) => {
  const color = tone === "active" ? RETURN : "var(--sl-color-gray-3)";
  return [
    reset,
    sans,
    "box-sizing: border-box",
    "position: relative",
    "z-index: 1",
    "font-size: 10px",
    "font-weight: 700",
    "line-height: 1.3",
    "padding: 1px 8px",
    "border-radius: 999px",
    `color: ${color}`,
    "background: var(--sl-color-bg, var(--sl-color-gray-7))",
    `border: 1px solid color-mix(in srgb, ${color} ${tone === "active" ? "45%" : "26%"}, transparent)`,
  ].join("; ");
};

// The collapsed cluster row standing in for round-trips 4..20.
const clusterBox = (tone: Tone) =>
  [
    reset,
    "box-sizing: border-box",
    "position: relative",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "gap: 9px",
    "min-width: 0",
    "padding: 8px 10px",
    "border-radius: 9px",
    "transition: opacity 200ms ease",
    tone === "hidden" ? "visibility: hidden" : "",
    tone === "done" ? "opacity: 0.4" : "opacity: 1",
    tone === "active"
      ? `border: 1.5px dashed color-mix(in srgb, ${ACCENT} 60%, transparent); background: color-mix(in srgb, ${ACCENT} 9%, var(--sl-color-gray-6))`
      : "border: 1.5px dashed var(--sl-color-gray-4); background: var(--sl-color-gray-6)",
  ].join("; ");

const clusterText = (tone: Tone) =>
  [
    reset,
    mono,
    "font-size: 11px",
    "font-weight: 700",
    "line-height: 1.3",
    tone === "active" ? `color: ${ACCENT}` : "color: var(--sl-color-gray-2)",
  ].join("; ");

const clusterCount = (tone: Tone) =>
  [
    reset,
    sans,
    "font-size: 10px",
    "font-weight: 800",
    "letter-spacing: 0.02em",
    "padding: 2px 8px",
    "border-radius: 999px",
    tone === "active"
      ? `color: ${ACCENT}; background: color-mix(in srgb, ${ACCENT} 16%, transparent); border: 1px solid color-mix(in srgb, ${ACCENT} 40%, transparent)`
      : "color: var(--sl-color-gray-2); background: var(--sl-color-gray-5); border: 1px solid var(--sl-color-gray-4)",
  ].join("; ");

// The total banner — only the final step fills it; the slot is reserved on
// every step so the stage height is constant while scrubbing.
const bannerSlot = [
  reset,
  "box-sizing: border-box",
  "width: 100%",
  "min-height: 46px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
].join("; ");

const banner = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "gap: 12px",
  "width: 100%",
  "max-width: 560px",
  "padding: 10px 16px",
  "border-radius: 10px",
  `border: 1.5px solid color-mix(in srgb, ${ACCENT} 55%, transparent)`,
  `background: color-mix(in srgb, ${ACCENT} 12%, var(--sl-color-gray-6))`,
].join("; ");

const bannerBig = [
  reset,
  mono,
  "font-size: 26px",
  "font-weight: 800",
  "line-height: 1",
  `color: ${ACCENT}`,
].join("; ");

const bannerText = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: var(--sl-color-text)",
].join("; ");
---

<div class="not-content rtf" style={root}>
  {/* running round-trip counter, top-right */}
  <div style={counterRow}>
    <span style={counterPill}>
      <span style={counterLabel}>round-trips so far</span>
      <span style={counterNum}>{count}</span>
    </span>
  </div>

  {/* App | wire lane | Database */}
  <div style={stage}>
    {/* App endpoint — fixed */}
    <div style={endpoint("app")}>
      <span style={endpointIcon}>🖥️</span>
      <span style={endpointTitle}>App</span>
      <span style={endpointSub}>your page</span>
    </div>

    {/* the wire lane */}
    <div class="rtf-lane" style={lane}>
      {
        rows.map((r) => (
          <div style={tripRow(r.tone)}>
            {/* request: App -> DB */}
            <div class="wire wire-out" style={wire(r.tone, "out")}>
              <span style={wireLabel(r.tone, "out")}>{r.sql}</span>
            </div>
            {/* return: DB -> App */}
            <div class="wire wire-back" style={wire(r.tone, "back")}>
              <span style={returnLabel(r.tone)}>{r.rows}</span>
            </div>
          </div>
        ))
      }

      {/* collapsed cluster: round-trips 4..20 */}
      <div style={clusterBox(clusterTone)}>
        <span style={clusterText(clusterTone)}>
          …line_items where invoice_id = $4 … $20 …
        </span>
        <span style={clusterCount(clusterTone)}>×17 more</span>
      </div>
    </div>

    {/* Database endpoint — fixed */}
    <div style={endpoint("db")}>
      <span style={endpointIcon}>🗄️</span>
      <span style={endpointTitle}>Database</span>
      <span style={endpointSub}>Postgres</span>
    </div>
  </div>

  {/* total banner slot — filled only on the final step */}
  <div style={bannerSlot}>
    {
      step === 5 && (
        <div style={banner}>
          <span style={bannerBig}>21</span>
          <span style={bannerText}>
            round-trips to render one 20-invoice page — one parent query, then one
            child query per row. That's the N+1.
          </span>
        </div>
      )
    }
  </div>
</div>

<style>
  /* Draw the connecting line behind each wire's label. The arrowhead is a small
     CSS triangle pinned to the destination end (right for requests, left for
     returns). Colour and weight come from the per-wire custom properties. */
  .rtf .wire::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 0;
    border-top: var(--wire-weight) solid var(--wire-color);
    transform: translateY(-50%);
  }
  .rtf .wire::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 0;
    height: 0;
    transform: translateY(-50%);
  }
  .rtf .wire-out::after {
    right: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 8px solid var(--wire-color);
  }
  .rtf .wire-back::after {
    left: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-right: 8px solid var(--wire-color);
  }

  /* Laptop viewports — the design target — show the full lane width. On narrow
     screens the SQL labels would crush; let the endpoints shrink a touch and
     allow the labels to truncate (they already ellipsis) rather than wrap. */
  @media (max-width: 560px) {
    .rtf .rtf-lane {
      gap: 7px !important;
    }
  }
</style>
