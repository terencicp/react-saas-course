---
// Diagram: atomicity as a commit/rollback fork (diagram id: atomicity-fork,
// Chapter 039 Lesson 4 — "Transactions and isolation levels"). The one durable
// picture for "a transaction has exactly two outcomes — every statement commits
// or every statement rolls back; there is no third branch."
//
// Layout (horizontal, three columns, compressed for the laptop viewport):
//   LEFT  — a single rounded BOUNDARY box labelled "transaction" holding three
//           stacked statement chips: insert invoice / insert line items /
//           update customer. This is the indivisible unit.
//   MID   — a small fork: from the boundary's right edge, one connector goes UP
//           and one goes DOWN, splitting into exactly two real outcomes.
//   RIGHT — three stacked outcome cards:
//             • TOP    GREEN  "COMMIT"   — "all three persisted"   (real)
//             • MIDDLE GREY   "impossible" — a half state, struck through with
//               an ✕ overlay: "invoice saved · line items missing". No arrow
//               reaches it — the whole point is it can't happen.
//             • BOTTOM RED    "ROLLBACK" — "none persisted"        (real)
//
// Colour convention: GREEN = the committed outcome, RED = the rolled-back
// outcome, GREY + strike = the partial state a transaction deletes from the
// realm of possibility. Neutral slate chrome carries no meaning.
//
// House style follows the ch 039 family (seq-scan-vs-index.astro): pinned
// `color-scheme: light` so the hand-picked tints survive dark mode, inline
// style strings only (a reader can copy the source and see exactly what styled
// it), `margin: 0` on every inner element to defeat Starlight's injected prose
// margin-top, box-sizing: border-box throughout. No leader lines, so the figure
// stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// neutral chrome — carries no meaning.
const CHIP_BORDER = '#cbd5e1'; // slate-300
const CHIP_BG = '#f8fafc'; // slate-50
const BOUNDARY_BORDER = '#94a3b8'; // slate-400

// COMMIT — green.
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_INK = '#15803d'; // green-700

// ROLLBACK — red.
const RED = '#dc2626'; // red-600
const RED_BG = '#fef2f2'; // red-50 wash
const RED_INK = '#b91c1c'; // red-700

// IMPOSSIBLE partial state — grey + strike.
const GREY = '#cbd5e1'; // slate-300 border
const GREY_BG = '#f1f5f9'; // slate-100 wash
const GREY_INK = '#94a3b8'; // slate-400 muted ink

const statements = ['insert invoice', 'insert line items', 'update customer'];

// ---- outer stage: boundary | fork | outcomes -----------------------------
const stage = [
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'justify-content: center',
  'column-gap: 6px',
  'row-gap: 18px',
  'margin: 0',
  'padding: 4px 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// ---- LEFT: the transaction boundary box ----------------------------------
const boundary = [
  'box-sizing: border-box',
  'position: relative',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'gap: 7px',
  'margin: 0',
  'padding: 22px 16px 14px',
  'border-radius: 14px',
  `border: 2px dashed ${BOUNDARY_BORDER}`,
  `background: ${SURFACE}`,
  'width: 218px',
  'max-width: 100%',
].join('; ');

// "transaction" legend pill straddling the boundary's top border.
const boundaryLegend = [
  'box-sizing: border-box',
  'position: absolute',
  'top: -11px',
  'left: 14px',
  'margin: 0',
  'padding: 2px 9px',
  'border-radius: 999px',
  `border: 1.5px solid ${BOUNDARY_BORDER}`,
  `background: ${SURFACE}`,
  `color: ${INK}`,
  `font-family: ${mono}`,
  'font-size: 11px',
  'font-weight: 700',
  'line-height: 1.3',
  'letter-spacing: 0.01em',
].join('; ');

// "all three, or none" micro-note under the legend, top-right of the box.
const boundaryHint = [
  'box-sizing: border-box',
  'position: absolute',
  'top: -9px',
  'right: 12px',
  'margin: 0',
  'padding: 1px 8px',
  'border-radius: 999px',
  `background: ${SURFACE}`,
  `color: ${INK_SOFT}`,
  `font-family: ${sans}`,
  'font-size: 9px',
  'font-weight: 700',
  'text-transform: uppercase',
  'letter-spacing: 0.04em',
  'line-height: 1.4',
].join('; ');

// one statement chip inside the boundary.
const stmtChip = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 8px',
  'margin: 0',
  'padding: 6px 10px',
  'border-radius: 8px',
  `border: 1.5px solid ${CHIP_BORDER}`,
  `background: ${CHIP_BG}`,
].join('; ');

const stmtDot = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'width: 6px',
  'height: 6px',
  'margin: 0',
  'border-radius: 999px',
  `background: ${INK_SOFT}`,
].join('; ');

const stmtLabel = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 12px',
  'font-weight: 600',
  'line-height: 1.2',
  `color: ${INK}`,
].join('; ');

// ---- MID: the fork (two connectors out of the boundary) ------------------
// A fixed-size SVG carries the two diverging lines + arrowheads so they read as
// "exactly two outcomes". Nothing points at the middle (impossible) card.
const forkWrap = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'margin: 0',
].join('; ');

// ---- RIGHT: the three outcome cards --------------------------------------
const outcomes = [
  'box-sizing: border-box',
  'flex: 0 1 auto',
  'display: flex',
  'flex-direction: column',
  'gap: 9px',
  'margin: 0',
  'width: 248px',
  'max-width: 100%',
].join('; ');

// a real outcome card (commit / rollback).
const outcomeCard = (border: string, bg: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'gap: 11px',
    'margin: 0',
    'padding: 9px 12px',
    'border-radius: 11px',
    `border: 1.5px solid ${border}`,
    `background: ${bg}`,
  ].join('; ');

const outcomeIcon = (ink: string) =>
  [
    'box-sizing: border-box',
    'flex: 0 0 auto',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'width: 24px',
    'height: 24px',
    'margin: 0',
    'border-radius: 999px',
    `border: 2px solid ${ink}`,
    `color: ${ink}`,
    'font-size: 14px',
    'font-weight: 900',
    'line-height: 1',
  ].join('; ');

const outcomeText = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 1px',
  'margin: 0',
  'min-width: 0',
].join('; ');

const outcomeTitle = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 14px',
    'font-weight: 800',
    'letter-spacing: 0.02em',
    'line-height: 1.2',
    `color: ${ink}`,
  ].join('; ');

const outcomeSub = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 11px',
    'font-weight: 600',
    'line-height: 1.25',
    `color: ${ink}`,
  ].join('; ');

// the middle IMPOSSIBLE card — greyed, struck, with an ✕ overlay.
const impossibleCard = [
  'box-sizing: border-box',
  'position: relative',
  'display: flex',
  'align-items: center',
  'gap: 11px',
  'margin: 0',
  'padding: 8px 12px',
  'border-radius: 11px',
  `border: 1.5px dashed ${GREY}`,
  `background: ${GREY_BG}`,
  'opacity: 0.92',
].join('; ');

// the diagonal strike drawn across the impossible card.
const strike = [
  'box-sizing: border-box',
  'position: absolute',
  'left: 8px',
  'right: 8px',
  'top: 50%',
  'height: 0',
  'margin: 0',
  `border-top: 2px solid ${RED}`,
  'transform: rotate(-9deg)',
  'opacity: 0.7',
  'pointer-events: none',
].join('; ');

const impossibleIcon = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'width: 24px',
  'height: 24px',
  'margin: 0',
  'border-radius: 999px',
  `border: 2px solid ${RED}`,
  `background: ${SURFACE}`,
  `color: ${RED}`,
  'font-size: 14px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');

const impossibleTag = [
  'box-sizing: border-box',
  'margin: 0 0 1px',
  `font-family: ${sans}`,
  'font-size: 8.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.05em',
  'line-height: 1.3',
  `color: ${RED_INK}`,
].join('; ');

const impossibleSub = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 600',
  'line-height: 1.25',
  `color: ${GREY_INK}`,
  'text-decoration: line-through',
  `text-decoration-color: ${GREY_INK}`,
].join('; ');
---

<Figure>
  <div style={stage}>
    {/* ============ LEFT — the transaction boundary ============ */}
    <div style={boundary}>
      <span style={boundaryLegend}>transaction</span>
      <span style={boundaryHint}>one unit</span>
      {
        statements.map((s) => (
          <div style={stmtChip}>
            <span style={stmtDot} aria-hidden="true"></span>
            <span style={stmtLabel}>{s}</span>
          </div>
        ))
      }
    </div>

    {/* ============ MID — the fork: exactly two ways out ============ */}
    <div style={forkWrap} aria-hidden="true">
      <svg
        width="58"
        height="150"
        viewBox="0 0 58 150"
        fill="none"
        style="display: block; margin: 0; overflow: visible;"
      >
        <defs>
          <marker
            id="atomfork-head-green"
            markerWidth="7"
            markerHeight="7"
            refX="5.4"
            refY="3.5"
            orient="auto"
          >
            <path d="M0 0 L6 3.5 L0 7 Z" fill={GREEN}></path>
          </marker>
          <marker
            id="atomfork-head-red"
            markerWidth="7"
            markerHeight="7"
            refX="5.4"
            refY="3.5"
            orient="auto"
          >
            <path d="M0 0 L6 3.5 L0 7 Z" fill={RED}></path>
          </marker>
        </defs>
        {/* shared origin at the boundary's mid-right edge */}
        <circle cx="3" cy="75" r="3.5" fill={BOUNDARY_BORDER}></circle>
        {/* upper connector → COMMIT (green) */}
        <path
          d="M5 75 C 26 75, 24 25, 52 25"
          stroke={GREEN}
          stroke-width="2.5"
          marker-end="url(#atomfork-head-green)"
        ></path>
        {/* lower connector → ROLLBACK (red) */}
        <path
          d="M5 75 C 26 75, 24 125, 52 125"
          stroke={RED}
          stroke-width="2.5"
          marker-end="url(#atomfork-head-red)"
        ></path>
      </svg>
    </div>

    {/* ============ RIGHT — the two real outcomes + the impossible one ============ */}
    <div style={outcomes}>
      {/* COMMIT (real) */}
      <div style={outcomeCard(GREEN, GREEN_BG)}>
        <span style={outcomeIcon(GREEN_INK)}>&check;</span>
        <span style={outcomeText}>
          <span style={outcomeTitle(GREEN_INK)}>COMMIT</span>
          <span style={outcomeSub(GREEN_INK)}>all three persisted</span>
        </span>
      </div>

      {/* IMPOSSIBLE partial state — no arrow reaches it */}
      <div style={impossibleCard}>
        <span style={impossibleIcon}>&times;</span>
        <span style={outcomeText}>
          <span style={impossibleTag}>can&rsquo;t happen</span>
          <span style={impossibleSub}>invoice saved &middot; line items missing</span>
        </span>
        <span style={strike} aria-hidden="true"></span>
      </div>

      {/* ROLLBACK (real) */}
      <div style={outcomeCard(RED, RED_BG)}>
        <span style={outcomeIcon(RED_INK)}>&#8635;</span>
        <span style={outcomeText}>
          <span style={outcomeTitle(RED_INK)}>ROLLBACK</span>
          <span style={outcomeSub(RED_INK)}>none persisted</span>
        </span>
      </div>
    </div>
  </div>
  <Fragment slot="caption">
    A transaction has exactly two outcomes &mdash; every statement commits, or
    every statement rolls back. There is no third branch.
  </Fragment>
</Figure>
