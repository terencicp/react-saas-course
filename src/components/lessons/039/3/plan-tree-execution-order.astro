---
// Diagram: walk one Postgres plan tree in EXECUTION order (diagram id:
// plan-tree-execution-order, Chapter 039 Lesson 3 — "Reading EXPLAIN ANALYZE").
//
// The keystone picture for the lesson's #1 beginner stumble: a plan is an
// INVERTED tree — the most-indented (deepest) node runs FIRST, output flows
// UPWARD, and the top line is the LAST thing that happens, not the first.
//
// One DiagramSequence with four DiagramSteps. Every step renders the SAME
// monospace plan block (defined once, below, as the single source of truth) with
// a different node lit, so the reader sees the highlight climb the tree as they
// scrub. Each plan line carries a `node` id; a step lights a set of node ids.
// Three states per node line:
//   - active  → the node executing in THIS step (green accent + "running" pill)
//   - done    → a node that already executed in an earlier step (muted check tint)
//   - idle    → not run yet (neutral)
// The done state is what makes "results flow upward" legible: by step 3 the two
// leaves read as done while the join is active and the Sort is still idle.
//
// House style follows the ch 039/1 family: pinned `color-scheme: light` so the
// hand-picked tints survive dark mode, inline style strings only (copy the
// source, see exactly what styled it), `margin: 0` everywhere to defeat
// Starlight's injected prose margins, box-sizing: border-box throughout. No
// leader lines, so each step stays safe inside the sequence's grid stack.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary plan ink
const INK_SOFT = '#94a3b8'; // slate-400 — idle / un-run nodes, dimmed
const SURFACE = '#0f172a00'; // (unused fill placeholder)
const BLOCK_BG = '#f8fafc'; // slate-50 — the plan block surface
const BLOCK_BORDER = '#e2e8f0'; // slate-200

// ACTIVE — the node running in this step. Green = "this is happening now".
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#dcfce7'; // green-100 — the lit row band
const GREEN_INK = '#14532d'; // green-900 — text on the lit row

// DONE — a node that already executed. Muted slate so it reads as "settled".
const DONE_INK = '#475569'; // slate-600
const DONE_BG = '#eef2f6'; // very soft slate band

// ---- the plan, defined ONCE -----------------------------------------------
// Each line: its rendered text and the `node` it belongs to. The two detail
// lines (Sort Key, Hash Cond) attach to their parent node so they light with it.
type Line = { text: string; node: NodeId };
type NodeId =
  | 'sort'
  | 'join'
  | 'invoices'
  | 'hash'
  | 'customers';

const lines: Line[] = [
  { text: 'Sort  (actual time=2.31..2.34 rows=20 loops=1)', node: 'sort' },
  { text: '  Sort Key: i.created_at DESC', node: 'sort' },
  { text: '  ->  Hash Join  (actual time=0.42..2.10 rows=180 loops=1)', node: 'join' },
  { text: '        Hash Cond: (i.customer_id = c.id)', node: 'join' },
  { text: '        ->  Seq Scan on invoices i  (actual time=0.01..1.40 rows=180 loops=1)', node: 'invoices' },
  { text: '        ->  Hash  (actual time=0.30..0.30 rows=40 loops=1)', node: 'hash' },
  { text: '              ->  Seq Scan on customers c  (actual time=0.01..0.18 rows=40 loops=1)', node: 'customers' },
];

// ---- the four steps, deepest-first ----------------------------------------
// `active` = the node(s) lit this step; `done` = nodes already executed before
// this step (everything earlier in the execution chain). The execution chain,
// deepest → root, is: customers → hash → [invoices, join] → sort.
type Step = {
  active: NodeId[];
  done: NodeId[];
  pill: string; // the right-edge status pill on active rows
  caption: string;
};

const steps: Step[] = [
  {
    active: ['customers'],
    done: [],
    pill: 'runs first',
    caption:
      'Deepest node, so it runs first. Postgres reads all 40 customer rows. Nothing above has happened yet.',
  },
  {
    active: ['hash'],
    done: ['customers'],
    pill: 'now running',
    caption:
      'Its parent, the Hash node, takes those 40 rows and builds a hash table keyed by customer id — ready to be probed.',
  },
  {
    active: ['join', 'invoices'],
    done: ['customers', 'hash'],
    pill: 'now running',
    caption:
      'Now the join runs: Postgres scans the 180 invoices and probes the hash for each one’s customer. Output: 180 joined rows, flowing up.',
  },
  {
    active: ['sort'],
    done: ['customers', 'hash', 'invoices', 'join'],
    pill: 'runs last',
    caption:
      'Last, the root sorts those rows by created_at descending and returns the final 20. The top line is where execution ends, not where it begins.',
  },
];

// ---- styles ---------------------------------------------------------------
// The plan block: a monospace pre-like surface. We render it as a column of rows
// (not a single <pre>) so each node line can carry its own band/tint.
const block = [
  'box-sizing: border-box',
  'margin: 0',
  'padding: 14px 8px',
  'border-radius: 12px',
  `border: 1.5px solid ${BLOCK_BORDER}`,
  `background: ${BLOCK_BG}`,
  'overflow-x: auto',
  'color-scheme: light',
  `color: ${INK}`,
].join('; ');

// one plan line. `state`: 'active' | 'done' | 'idle'.
const row = (state: 'active' | 'done' | 'idle') => {
  const [bg, ink, weight] =
    state === 'active'
      ? [GREEN_BG, GREEN_INK, '700']
      : state === 'done'
        ? [DONE_BG, DONE_INK, '500']
        : ['transparent', INK_SOFT, '500'];
  return [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'justify-content: space-between',
    'gap: 14px',
    'margin: 0',
    'padding: 3px 10px',
    'border-radius: 6px',
    `background: ${bg}`,
    state === 'active' ? `box-shadow: inset 0 0 0 1.5px ${GREEN}` : 'box-shadow: none',
    'transition: background-color 0.15s, color 0.15s, box-shadow 0.15s',
    `color: ${ink}`,
    `font-weight: ${weight}`,
  ].join('; ');
};

// the plan text itself — monospace, whitespace preserved (the indentation IS the
// tree depth, so it must survive verbatim).
const code = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 12.5px',
  'line-height: 1.55',
  'white-space: pre',
  'letter-spacing: -0.01em',
].join('; ');

// the right-edge status pill on the active row(s).
const pillStyle = (kind: 'green' | 'done') => {
  const ink = kind === 'green' ? GREEN : DONE_INK;
  return [
    'box-sizing: border-box',
    'flex: 0 0 auto',
    'margin: 0',
    'padding: 1px 8px',
    'border-radius: 999px',
    `border: 1px solid ${ink}`,
    `background: ${kind === 'green' ? '#ffffff' : 'transparent'}`,
    `color: ${ink}`,
    `font-family: ${sans}`,
    'font-size: 9px',
    'font-weight: 800',
    'text-transform: uppercase',
    'letter-spacing: 0.05em',
    'line-height: 1.5',
    'white-space: nowrap',
  ].join('; ');
};

// small flow label above the block, fixed across steps.
const flowNote = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 6px',
  'margin: 0 2px 8px',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 700',
  `color: ${INK_SOFT}`,
  'text-transform: uppercase',
  'letter-spacing: 0.04em',
].join('; ');

// render one full plan block for a given step.
function stateFor(node: NodeId, step: Step): 'active' | 'done' | 'idle' {
  if (step.active.includes(node)) return 'active';
  if (step.done.includes(node)) return 'done';
  return 'idle';
}
// only the FIRST line of an active/done node carries the pill (so multi-line
// nodes don't repeat it).
function isFirstLineOfNode(index: number): boolean {
  return index === 0 || lines[index - 1].node !== lines[index].node;
}
---

<DiagramSequence>
  {
    steps.map((step) => (
      <DiagramStep caption={step.caption}>
        <div style={flowNote}>
          <span style={`color: ${GREEN}; font-size: 13px; line-height: 1;`}>&uarr;</span>
          results flow upward — deepest node runs first
        </div>
        <div style={block}>
          {lines.map((line, i) => {
            const state = stateFor(line.node, step);
            const showPill = state !== 'idle' && isFirstLineOfNode(i);
            return (
              <div style={row(state)}>
                <span style={code}>{line.text}</span>
                {showPill ? (
                  state === 'active' ? (
                    <span style={pillStyle('green')}>{step.pill}</span>
                  ) : (
                    <span style={pillStyle('done')}>&check; done</span>
                  )
                ) : (
                  <span style="flex: 0 0 auto; width: 0;" />
                )}
              </div>
            );
          })}
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>
