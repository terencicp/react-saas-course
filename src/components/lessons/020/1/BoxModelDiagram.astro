---
// The four nested boxes of the CSS box model, drawn as four concentric
// color-coded bands — content innermost, margin outermost. The fills are chosen
// to match Chrome DevTools' own box-model overlay (content blue, padding green,
// border yellow, margin tan/orange) so the lesson's later DevTools section needs
// no re-teaching of the color scheme: the student already met these exact colors
// here.
//
// Geometry: every band is the previous one inset by a tall TOP strip (to house a
// two-line name + role label, DevTools-style) and a thin side/bottom frame (just
// enough to read as a visible band). The innermost rect is the content box, with
// its label centered. Labels are a fixed dark slate that reads on all four
// light-tint bands; the margin band carries a hatch overlay to signal it is the
// see-through one. All <text> content is wrapped in JS expressions so
// remark-smartypants can't curl the middot or rewrite punctuation.

import Figure from "../../../figures/Figure.astro";

// DevTools-matched band fills (theme-safe light tints, readable in both modes).
const MARGIN = "#f8cb9c"; // tan / orange
const BORDER = "#fbbf24"; // gold / yellow
const PADDING = "#a7d96f"; // green
const CONTENT = "#7cb3f0"; // blue

// Dark slate for every label — reads clearly on all four light bands.
const INK = "#1e293b";
const INK_SOFT = "#334155"; // role line, a touch lighter than the name

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// Concentric band rectangles (see header note for the inset model).
const bands = {
  margin: { x: 8, y: 8, width: 504, height: 284 },
  border: { x: 28, y: 48, width: 464, height: 224 },
  padding: { x: 48, y: 86, width: 424, height: 166 },
  content: { x: 68, y: 122, width: 384, height: 110 },
};

// Top-left label anchor for a band's name/role pair, sitting in its top strip.
const LABEL_X = (b: { x: number }) => b.x + 16;
const NAME_Y = (b: { y: number }) => b.y + 20;
const ROLE_Y = (b: { y: number }) => b.y + 35;

const cx = bands.content.x + bands.content.width / 2;
const cy = bands.content.y + bands.content.height / 2;
---

<Figure caption="The four boxes, from the inside out. These are the same colors Chrome DevTools paints when you inspect an element.">
  <svg
    viewBox="0 0 520 300"
    role="img"
    aria-label="The four nested boxes of the CSS box model: content inside padding inside border inside margin, color-coded to match DevTools — content blue, padding green, border yellow, margin tan."
    xmlns="http://www.w3.org/2000/svg"
    style="width: 100%; height: auto; display: block; color-scheme: light;"
  >
    <defs>
      {/* Diagonal hatch marking the margin band as the see-through one. */}
      <pattern
        id="margin-hatch"
        width="8"
        height="8"
        patternUnits="userSpaceOnUse"
        patternTransform="rotate(45)"
      >
        <line x1="0" y1="0" x2="0" y2="8" stroke={INK} stroke-width="1" opacity="0.18" />
      </pattern>
    </defs>

    {/* ---------- nested band fills, outermost first ---------- */}
    <rect {...bands.margin} fill={MARGIN} rx="6" />
    <rect {...bands.margin} fill="url(#margin-hatch)" rx="6" />
    <rect {...bands.border} fill={BORDER} rx="5" />
    <rect {...bands.padding} fill={PADDING} rx="4" />
    <rect {...bands.content} fill={CONTENT} rx="3" />

    {/* hairline edges so the seams between same-direction bands stay legible */}
    <g fill="none" stroke={INK} stroke-opacity="0.22" stroke-width="1">
      <rect {...bands.margin} rx="6" />
      <rect {...bands.border} rx="5" />
      <rect {...bands.padding} rx="4" />
      <rect {...bands.content} rx="3" />
    </g>

    {/* ---------- top-left labels for the three outer bands ---------- */}
    <g font-family={sans} text-anchor="start">
      {/* margin */}
      <text x={LABEL_X(bands.margin)} y={NAME_Y(bands.margin)} font-size="15" font-weight="700" fill={INK}>{"margin"}</text>
      <text x={LABEL_X(bands.margin)} y={ROLE_Y(bands.margin)} font-size="12" fill={INK_SOFT}>{"outside space · pushes neighbors"}</text>

      {/* border */}
      <text x={LABEL_X(bands.border)} y={NAME_Y(bands.border)} font-size="15" font-weight="700" fill={INK}>{"border"}</text>
      <text x={LABEL_X(bands.border)} y={ROLE_Y(bands.border)} font-size="12" fill={INK_SOFT}>{"the visible edge"}</text>

      {/* padding */}
      <text x={LABEL_X(bands.padding)} y={NAME_Y(bands.padding)} font-size="15" font-weight="700" fill={INK}>{"padding"}</text>
      <text x={LABEL_X(bands.padding)} y={ROLE_Y(bands.padding)} font-size="12" fill={INK_SOFT}>{"inside space · takes the background"}</text>
    </g>

    {/* ---------- centered content label ---------- */}
    <g font-family={sans} text-anchor="middle">
      <text x={cx} y={cy - 4} font-size="16" font-weight="700" fill={INK}>{"content"}</text>
      <text x={cx} y={cy + 15} font-size="12" fill={INK_SOFT}>{"children + text"}</text>
    </g>
  </svg>
</Figure>
