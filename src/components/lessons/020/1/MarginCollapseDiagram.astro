---
// Margin collapse, made visual: two block siblings stacked in normal flow. The
// upper box has a 32px bottom margin (mb-8), the lower box a 16px top margin
// (mt-4). The naive mental model adds them (48px); the browser instead collapses
// them to the LARGER value (32px) and discards the smaller. The whole point is
// the arithmetic surprise, so the single gap between the boxes is the focus.
//
// The gap is drawn as the tan/orange margin band the sibling BoxModelDiagram and
// DevTools both use, so "this space is margin" reads instantly. The smaller 16px
// margin is nested INSIDE the 32px band as a faded, dashed region — it visibly
// shares the gap rather than stacking below it, which is what "discarded" means.
//
// Annotations sit on opposite sides of the boxes so each stays uncrowded:
//   - LEFT  — a quiet, struck-through "expected 48px" bracket that overshoots
//             past the lower box's top edge (the wrong sum).
//   - RIGHT — a solid accent "actual 32px" bracket matching the real gap.
// <text> is wrapped in JS expressions so remark-smartypants can't curl
// punctuation; color-scheme is pinned light so the fixed tan fill stays correct
// in dark mode.

import Figure from "../../../figures/Figure.astro";

// Palette — shared with BoxModelDiagram so the two figures read as a set.
const MARGIN = "#f8cb9c"; // tan / orange — the margin band (matches DevTools)
const BOX_FILL = "#ffffff"; // fixed light box fill (figure is pinned color-scheme: light)
const INK = "#1e293b"; // primary labels
const QUIET = "#94a3b8"; // the muted, struck "expected" annotation
const ACCENT = "#c2410c"; // saturated orange — the "actual" signal, on-theme for margin

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// --- Geometry (1 unit = 1px) -------------------------------------------------
const BOX_X = 150;
const BOX_W = 150;

const TOP_Y = 22;
const BOX_H = 44;
const TOP_BOTTOM = TOP_Y + BOX_H; // 66 — where the upper box ends / gap begins

const GAP = 32; // collapsed gap = the larger margin
const SMALL = 16; // the discarded margin
const BOT_Y = TOP_BOTTOM + GAP; // 98 — lower box top edge
const BOT_BOTTOM = BOT_Y + BOX_H; // 142

// Gap bands.
const GAP_X = BOX_X + 14;
const GAP_W = BOX_W - 28;
const SMALL_Y = TOP_BOTTOM + (GAP - SMALL); // lower-half band, abutting the box

// --- Brackets ----------------------------------------------------------------
const tick = 5; // bracket end-cap length
const GAP_MID = (TOP_BOTTOM + BOT_Y) / 2;

// LEFT: "expected 48px" — quiet, struck, overshoots past the lower box.
const EXP_X = BOX_X - 22;
const EXP_BOTTOM = TOP_BOTTOM + SMALL + GAP; // 114 — the wrong sum, lands inside the lower box

// RIGHT: "actual 32px" — solid accent, spans the real gap.
const ACT_X = BOX_X + BOX_W + 22;

// A square bracket spanning [yTop, yBot] at column x; `dir` = 1 ticks right, -1 ticks left.
function bracket(x: number, yTop: number, yBot: number, dir: number) {
  const t = x + dir * tick;
  return `M ${t} ${yTop} L ${x} ${yTop} L ${x} ${yBot} L ${t} ${yBot}`;
}
---

<Figure caption="Adjacent vertical margins collapse to the larger value, never the sum. 32px wins; the 16px is discarded.">
  <svg
    viewBox="0 0 450 156"
    role="img"
    aria-label="Two stacked boxes: the top has a 32px bottom margin, the bottom a 16px top margin. The gap between them is 32px, not 48px — the smaller margin collapses into the larger and is discarded."
    xmlns="http://www.w3.org/2000/svg"
    style="width: 100%; height: auto; display: block; color-scheme: light;"
  >
    {/* ---------- the collapsed gap, drawn as one margin band ---------- */}
    <rect x={GAP_X} y={TOP_BOTTOM} width={GAP_W} height={GAP} fill={MARGIN} rx="3" />
    {/* the smaller 16px margin, nested inside — faded + dashed = discarded */}
    <rect
      x={GAP_X + 6}
      y={SMALL_Y}
      width={GAP_W - 12}
      height={SMALL}
      fill="#ffffff"
      fill-opacity="0.5"
      stroke={INK}
      stroke-opacity="0.5"
      stroke-width="1"
      stroke-dasharray="3 2"
      rx="2"
    />

    {/* ---------- the two block boxes ---------- */}
    <g text-anchor="middle">
      {/* upper box */}
      <rect
        x={BOX_X}
        y={TOP_Y}
        width={BOX_W}
        height={BOX_H}
        fill={BOX_FILL}
        stroke={INK}
        stroke-opacity="0.55"
        stroke-width="1.5"
        rx="4"
      />
      <text x={BOX_X + BOX_W / 2} y={TOP_Y + BOX_H / 2 + 5} font-family={mono} font-size="14" font-weight="600" fill={INK}>{"mb-8"}</text>

      {/* lower box */}
      <rect
        x={BOX_X}
        y={BOT_Y}
        width={BOX_W}
        height={BOX_H}
        fill={BOX_FILL}
        stroke={INK}
        stroke-opacity="0.55"
        stroke-width="1.5"
        rx="4"
      />
      <text x={BOX_X + BOX_W / 2} y={BOT_Y + BOX_H / 2 + 5} font-family={mono} font-size="14" font-weight="600" fill={INK}>{"mt-4"}</text>
    </g>

    {/* ---------- LEFT: "expected 48px" — quiet, struck, overshoots ---------- */}
    <g>
      <path d={bracket(EXP_X, TOP_BOTTOM, EXP_BOTTOM, -1)} fill="none" stroke={QUIET} stroke-width="1.5" />
      <g font-family={sans} text-anchor="end">
        <text
          x={EXP_X - 12}
          y={(TOP_BOTTOM + EXP_BOTTOM) / 2 - 4}
          font-size="13"
          font-weight="600"
          fill={QUIET}
          style="text-decoration: line-through;"
        >{"expected 48px"}</text>
        <text x={EXP_X - 12} y={(TOP_BOTTOM + EXP_BOTTOM) / 2 + 12} font-size="11" fill={QUIET}>{"32 + 16, the sum"}</text>
      </g>
    </g>

    {/* ---------- RIGHT: "actual 32px" — solid accent, the real gap ---------- */}
    <g>
      <path d={bracket(ACT_X, TOP_BOTTOM, BOT_Y, 1)} fill="none" stroke={ACCENT} stroke-width="2" />
      <g font-family={sans} text-anchor="start">
        <text x={ACT_X + 12} y={GAP_MID - 2} font-size="13" font-weight="700" fill={ACCENT}>{"actual 32px"}</text>
        <text x={ACT_X + 12} y={GAP_MID + 14} font-size="11" fill={ACCENT}>{"the larger margin"}</text>
      </g>
    </g>
  </svg>
</Figure>
