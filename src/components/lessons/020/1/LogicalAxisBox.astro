---
// One box used by BOTH tabs of the logical-axis demo, so the "same markup, same
// class, you wrote it once" claim is literally true in source — the only thing
// that differs between the two tabs is the `dir` on the wrapper this box sits in.
//
// The box authors the LOGICAL property directly (padding-inline-start: 32px, the
// raw form of Tailwind's `ps-8`). Because it's the *inline-start* edge, the
// browser resolves it against the inherited writing direction: left in LTR,
// right in RTL. We deliberately do NOT hard-code a physical side anywhere — the
// flip is real, performed by the browser, not faked per tab.
//
// To make the padded edge unmistakable, the inline-start padding region is
// painted as a tinted band via a left/right-agnostic inset background that also
// flips with direction (an inline-positioned ::before would over-complicate an
// Astro component, so the band is a flex spacer that occupies the padding). The
// content sits flush against the band so the gap reads at a glance, and a small
// inline-axis arrow points the way text advances (right in LTR, left in RTL)
// using the CSS-logical fact that `scale-x` under rtl mirrors a glyph.
//
// Colors are fixed light tints (this is an illustration, not project code, so it
// doesn't route through @theme tokens) and color-scheme is pinned so they read
// correctly in dark mode. The padding tint reuses the green the box-model figure
// uses for the padding band, keeping the lesson's figures a visual set.

interface Props {
  // The short phrase shown inside the box, in the tab's own language.
  text: string;
  // Caption-free label naming the inline-start edge, e.g. "inline-start".
  edgeLabel: string;
}

const { text, edgeLabel } = Astro.props;

const PADDING = "#a7d96f"; // green — the padding band, matches BoxModelDiagram
const BOX_BORDER = "#7cb3f0"; // blue — the box's own border
const BOX_FILL = "#eef5fd"; // very light blue box fill
const INK = "#1e293b";

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";
---

<div class="logical-axis-box" style={`color-scheme: light; font-family: ${sans};`}>
  {/* The element carrying ps-8, authored as the raw logical property so it
      genuinely flips with the inherited dir. The inline-start padding is filled
      by a tinted spacer so the padded edge is visible. */}
  <div
    class="lab-card"
    style={`
      display: flex;
      align-items: stretch;
      padding-inline-start: 32px;
      border: 2px solid ${BOX_BORDER};
      background: ${BOX_FILL};
      border-radius: 8px;
      overflow: hidden;
    `}
  >
    {/* Tinted band sitting in the inline-start padding. It's an absolutely-free
        flex child pinned to the start edge, so it follows the direction flip. */}
    <span
      class="lab-band"
      aria-hidden="true"
      style={`
        position: absolute;
        inset-block: 0;
        inset-inline-start: 0;
        width: 32px;
        background: ${PADDING};
      `}></span>

    <div
      class="lab-content"
      style={`
        position: relative;
        padding-block: 14px;
        padding-inline-end: 18px;
        font-family: ${mono};
        font-size: 0.9375rem;
        font-weight: 600;
        color: ${INK};
      `}
    >
      {text}
    </div>
  </div>

  {/* Inline-axis arrow: points the way a line of text advances. Under dir=rtl the
      arrow glyph and the label flow to the right edge and the arrow visually
      points left, because the whole row is laid out on the inline axis. */}
  <div
    class="lab-axis"
    style={`
      display: flex;
      align-items: center;
      gap: 8px;
      margin-block-start: 10px;
      font-size: 0.75rem;
      color: ${INK};
      opacity: 0.85;
    `}
  >
    <span style={`font-family: ${mono}; font-weight: 600;`}>{edgeLabel}</span>
    <span class="lab-arrow" aria-hidden="true" style={`font-size: 1rem; line-height: 1;`}>{"→"}</span>
    <span style="font-style: italic;">{"inline axis"}</span>
  </div>
</div>

<style>
  /* The card needs relative positioning so the absolute padding band anchors to
     it; set here rather than inline to keep the band's anchor explicit. */
  .lab-card {
    position: relative;
  }

  /* Mirror the arrow glyph when the ambient direction is RTL so it points the way
     text actually advances (toward the left). The label/text reordering is
     handled for free by the inline flow under dir=rtl. */
  :global([dir="rtl"]) .lab-arrow {
    display: inline-block;
    transform: scaleX(-1);
  }
</style>
