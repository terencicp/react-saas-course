---
// Intro visual hook for Chapter 020 L4 (Grid): the SAME six product cards laid
// out two ways, side by side, so the disappointment-vs-clean contrast is read at
// a glance before the prose explains it.
//
//   LEFT  — a REAL `display: flex; flex-wrap: wrap; gap: 12px` container. The
//           cards size to their CONTENT (flex: 0 0 auto), so different name/price
//           lengths make the column widths ragged and the sixth card orphans onto
//           a new row that doesn't line up under the columns above. This is the
//           "almost right" flex-wrap result the lesson opens on.
//   RIGHT — the SAME six cards in a REAL `display: grid;
//           grid-template-columns: repeat(3, minmax(0,1fr)); gap: 12px`: three
//           perfectly equal columns, two tidy rows, every card the same width
//           regardless of its content.
//
// Both panels are real CSS so a reader can open devtools and inspect the actual
// flex / grid boxes (the pedagogical USP of HTML+CSS figures). This component
// renders the two-panel body only; the MDX wraps it in <Figure> with the caption.
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches
// FlexLayout / AxisFrame in this chapter). `margin: 0` on every inner element
// defeats Starlight's prose-margin injection into flex/grid children.

// Illustration palette (hard-coded, not @theme — see header note). Same blue
// family as L3's FlexLayout so the chapter's figures feel of a piece, plus one
// amber accent to flag the orphaned card on the flex side.
const PANEL_BG = "#ffffff"; // card surface
const CARD_BG = "#eff6ff"; // blue 50 — soft card fill
const CARD_BRD = "#bfdbfe"; // blue 200 — card border
const TITLE_INK = "#0f172a"; // slate 900 — product name
const PRICE_INK = "#64748b"; // slate 500 — price line
const FRAME_BRD = "#cbd5e1"; // slate 300 — the container ring
const FRAME_BG = "#f8fafc"; // slate 50 — container fill
const LABEL_INK = "#475569"; // slate 600 — panel label text
const WARN_BRD = "#fcd34d"; // amber 300 — orphaned-card border
const WARN_BG = "#fffbeb"; // amber 50 — orphaned-card fill
const WARN_INK = "#b45309"; // amber 700 — orphaned-card text

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// Six products with DELIBERATELY different name lengths so the flex panel's
// content-sized columns come out ragged. Names are kept short enough that they
// still fit a 3-column grid track without clipping — the right panel should read
// as the clean, tidy outcome (the minmax(0,1fr) clip behaviour is a later teach,
// not this intro hook). The grid panel ignores these widths regardless.
const products = [
  { name: "Pen", price: "$3" },
  { name: "Wireless Mouse", price: "$45" },
  { name: "USB-C Cable", price: "$12" },
  { name: "Monitor Arm", price: "$84" },
  { name: "Mug", price: "$9" },
  { name: "Desk Lamp", price: "$38" },
];

// A single product card. `highlight` paints the orphaned sixth card amber on the
// flex side so the "lone card that doesn't line up" reads instantly.
const card = (highlight = false) =>
  [
    "margin: 0",
    "box-sizing: border-box",
    `background: ${highlight ? WARN_BG : CARD_BG}`,
    `border: 1px solid ${highlight ? WARN_BRD : CARD_BRD}`,
    "border-radius: 10px",
    "padding: 10px 12px",
  ].join("; ");

const titleStyle = (highlight = false) =>
  [
    "margin: 0",
    `color: ${highlight ? WARN_INK : TITLE_INK}`,
    "font-weight: 700",
    "font-size: 0.8rem",
    "line-height: 1.2",
    "white-space: nowrap",
  ].join("; ");

const priceStyle = [
  "margin: 2px 0 0",
  `color: ${PRICE_INK}`,
  "font-size: 0.75rem",
  "line-height: 1.2",
].join("; ");

// The dashed ring + label scaffold shared by both panels.
const panel = [
  "margin: 0",
  "flex: 1 1 320px",
  "min-width: 280px",
  "box-sizing: border-box",
].join("; ");

const panelLabel = [
  "margin: 0 0 8px",
  `color: ${LABEL_INK}`,
  "font-size: 0.72rem",
  "font-weight: 700",
  "letter-spacing: 0.01em",
  "display: flex",
  "align-items: center",
  "gap: 6px",
].join("; ");

const labelCode = [
  "margin: 0",
  `font-family: ${mono}`,
  `color: ${TITLE_INK}`,
  "background: #e2e8f0",
  "border-radius: 5px",
  "padding: 1px 6px",
  "font-size: 0.72rem",
  "font-weight: 600",
].join("; ");

const frame = (display: string) =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "border-radius: 12px",
    `border: 1px dashed ${FRAME_BRD}`,
    `background: ${FRAME_BG}`,
    "padding: 12px",
    display,
  ].join("; ");
---

<div
  style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; flex-wrap: wrap; gap: 24px; background: ${PANEL_BG}; border-radius: 12px;`}
>
  {/* ----------------------- LEFT: flex flex-wrap ---------------------- */}
  <div style={panel}>
    <p style={panelLabel}>
      <span style={labelCode}>flex flex-wrap</span>
      <span style="margin: 0; font-weight: 600;">ragged, orphaned last card</span>
    </p>
    {/* REAL flexbox: cards size to content, so widths go ragged and #6 wraps. */}
    <div style={frame("display: flex; flex-wrap: wrap; gap: 12px; align-content: flex-start;")}>
      {
        products.map((product, i) => {
          const orphan = i === products.length - 1;
          return (
            <div style={`${card(orphan)}; flex: 0 0 auto;`}>
              <p style={titleStyle(orphan)}>{product.name}</p>
              <p style={priceStyle}>{product.price}</p>
            </div>
          );
        })
      }
    </div>
  </div>

  {/* ------------------------ RIGHT: grid grid-cols-3 ------------------ */}
  <div style={panel}>
    <p style={panelLabel}>
      <span style={labelCode}>grid grid-cols-3</span>
      <span style="margin: 0; font-weight: 600;">equal columns, tidy rows</span>
    </p>
    {/* REAL grid: three equal minmax(0,1fr) tracks ignore content width. */}
    <div
      style={frame(
        "display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px;",
      )}
    >
      {
        products.map((product) => (
          <div style={card()}>
            <p style={`${titleStyle()}; overflow: hidden; text-overflow: ellipsis;`}>
              {product.name}
            </p>
            <p style={priceStyle}>{product.price}</p>
          </div>
        ))
      }
    </div>
  </div>
</div>
