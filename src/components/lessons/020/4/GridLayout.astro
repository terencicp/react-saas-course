---
// The "five grid layouts you'll reach for" renderings for Chapter 020 L4.
//
// Goal: each of the five canonical 2D layouts as a REAL `display: grid` mini-app
// (devtools-inspectable per the HTML+CSS diagram doc) that the student can open
// the grid overlay on. This is the lesson's cheat-sheet gallery — a single
// scannable reference the student returns to. This component renders ONE pattern;
// the MDX drops it into a <TabbedItem> five times and pairs it with the matching
// Tailwind class string as the tab caption. It does NOT wrap itself in <Figure>:
// TabbedContent already supplies the figure card.
//
// The five patterns mirror the prose + the close-out list exactly:
//   cards-breakpoints — grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6
//                       (rendered at the 3-col desktop state: repeat(3, minmax(0,1fr)))
//   cards-autofit     — grid grid-cols-[repeat(auto-fit,minmax(16rem,1fr))] gap-6
//                       (a REAL auto-fit track, so resizing the figure reflows the
//                       column count; a narrower min is used so several columns fit
//                       the figure width — the mechanic is identical to 16rem)
//   shell             — the header / sidebar / main / footer app shell via
//                       grid-template-areas (the desktop arrangement)
//   hero              — a single card centred on both axes via place-items-center
//   dashboard         — the 5-tile stats dashboard with one col-span-2 row-span-2
//                       featured tile; the four smaller tiles flow around it
//
// This mirrors L3's FlexLayout.astro convention. Colours are hard-coded
// illustration tints with `color-scheme: light` pinned — the sanctioned
// divergence from the OKLCH @theme tokens for figures (matches FlexLayout /
// ShellLayout / AutoPlacementCells / AxisFrame in this chapter). `margin: 0` on
// every inner element defeats Starlight's prose-margin injection into grid
// children.

interface Props {
  pattern: "cards-breakpoints" | "cards-autofit" | "shell" | "hero" | "dashboard";
}

const { pattern } = Astro.props;

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// Illustration palette (hard-coded, not @theme — see header note). Same blue
// family as the chapter's other figures so the gallery feels of a piece.
const ACCENT = "#2563eb"; // blue 600 — primary action / focal element
const ACCENT_INK = "#ffffff"; // text on the accent fill
const CARD_BG = "#dbeafe"; // blue 100 — soft card fill
const CARD_BRD = "#93c5fd"; // blue 300 — soft card border
const CARD_INK = "#1e3a8a"; // blue 900 — soft card text
const FRAME_BRD = "#cbd5e1"; // slate 300 — the dashed grid-container ring
const FRAME_BG = "#f8fafc"; // slate 50 — grid-container fill (shows in gutters)
const MUTED_INK = "#64748b"; // slate 500 — secondary text
const TAG_INK = "#475569"; // slate 600 — the span tag text

// The dashed ring that marks "this is the grid container under discussion".
const frame = (extra = "") =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "border-radius: 16px",
    `border: 1px dashed ${FRAME_BRD}`,
    `background: ${FRAME_BG}`,
    "padding: 14px",
    extra,
  ]
    .filter(Boolean)
    .join("; ");

// A plain soft-tinted card used by both card-grid patterns.
const card = (label: string) =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "min-width: 0", // the minmax(0,…) floor, made real so a long label can't blow the track
    "height: 56px",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    `background: ${CARD_BG}`,
    `border: 1px solid ${CARD_BRD}`,
    `color: ${CARD_INK}`,
    "border-radius: 10px",
    "font-weight: 700",
    "font-size: 0.85rem",
  ].join("; ");

const cardLabels = ["One", "Two", "Three", "Four", "Five", "Six"];

// --- shell region palette (distinct fill per region, like ShellLayout) -------
const shellRegions = {
  header: { label: "Header", bg: "#dbeafe", brd: "#93c5fd", ink: "#1e3a8a" }, // blue
  sidebar: { label: "Sidebar", bg: "#ede9fe", brd: "#c4b5fd", ink: "#5b21b6" }, // violet
  main: { label: "Main", bg: "#dcfce7", brd: "#86efac", ink: "#166534" }, // green
  footer: { label: "Footer", bg: "#ffedd5", brd: "#fdba74", ink: "#9a3412" }, // amber
} as const;
type ShellKey = keyof typeof shellRegions;

const shellGrid = [
  "margin: 0",
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: 120px 1fr",
  "grid-template-rows: auto 1fr auto",
  "grid-template-areas: 'header header' 'sidebar main' 'footer footer'",
  "gap: 10px",
  "height: 220px",
].join("; ");

const shellRegionStyle = (key: ShellKey) => {
  const r = shellRegions[key];
  return [
    "margin: 0",
    "box-sizing: border-box",
    `grid-area: ${key}`,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "border-radius: 10px",
    "padding: 6px 8px",
    "min-height: 0",
    "min-width: 0",
    `background: ${r.bg}`,
    `border: 1px solid ${r.brd}`,
    `color: ${r.ink}`,
    "font-weight: 700",
    "font-size: 0.82rem",
  ].join("; ");
};
const shellOrder: ShellKey[] = ["header", "sidebar", "main", "footer"];

// --- dashboard tiles ---------------------------------------------------------
// Five stat tiles in a 3-col grid; tile 0 is the col-span-2 row-span-2 hero.
const dashTiles = [
  { label: "Revenue", hero: true },
  { label: "Users", hero: false },
  { label: "Churn", hero: false },
  { label: "MRR", hero: false },
  { label: "Trials", hero: false },
];

const dashGrid = [
  "margin: 0",
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  "grid-auto-rows: 1fr",
  "gap: 10px",
  "height: 220px",
].join("; ");

const dashTileStyle = (hero: boolean) =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "min-width: 0",
    "min-height: 0",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "justify-content: center",
    "gap: 4px",
    "border-radius: 10px",
    "text-align: center",
    hero ? "grid-column: span 2" : "",
    hero ? "grid-row: span 2" : "",
    hero ? `background: ${ACCENT}` : `background: ${CARD_BG}`,
    hero ? "border: 0" : `border: 1px solid ${CARD_BRD}`,
    hero ? `color: ${ACCENT_INK}` : `color: ${CARD_INK}`,
    hero ? "font-size: 1rem" : "font-size: 0.82rem",
    "font-weight: 700",
  ]
    .filter(Boolean)
    .join("; ");

// The little span tag under the featured tile's label.
const spanTag = [
  "margin: 0",
  `font-family: ${mono}`,
  "color: rgba(255,255,255,0.85)",
  "background: transparent",
  "padding: 0",
  "font-size: 0.66rem",
  "line-height: 1.1",
  "white-space: nowrap",
].join("; ");
---

{
  /* --------------------- CARD GRID — BREAKPOINTS --------------------- */
  pattern === "cards-breakpoints" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      {/* REAL grid: three equal minmax(0,1fr) columns — the desktop state of
          grid-cols-1 md:grid-cols-2 lg:grid-cols-3. Inspect it: each track is
          minmax(0,1fr), so the columns are equal and shrink cleanly. */}
      <div
        style={frame(
          "display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px;",
        )}
      >
        {cardLabels.map((label) => (
          <div style={card(label)}>{label}</div>
        ))}
      </div>
    </div>
  )
}

{
  /* ----------------------- CARD GRID — AUTO-FIT --------------------- */
  pattern === "cards-autofit" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      {/* REAL auto-fit track. The canonical class uses minmax(16rem,1fr); a
          narrower 7.5rem min is used here so several columns fit the figure's
          width — the mechanic is identical. Resize the viewport and the column
          COUNT reflows on its own, with no breakpoints. */}
      <div
        style={frame(
          "display: grid; grid-template-columns: repeat(auto-fit, minmax(7.5rem, 1fr)); gap: 12px;",
        )}
      >
        {cardLabels.map((label) => (
          <div style={card(label)}>{label}</div>
        ))}
      </div>
      <p
        style={`margin: 8px 2px 0; color: ${MUTED_INK}; font-size: 0.74rem; line-height: 1.3; text-align: center;`}
      >
        Resize the page — the grid picks the column count itself.
      </p>
    </div>
  )
}

{
  /* ----------------------------- PAGE SHELL ------------------------- */
  pattern === "shell" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      {/* REAL CSS grid using grid-template-areas — the header / sidebar / main /
          footer app shell. Header & footer span both columns; the sidebar holds
          the fixed track, main takes the 1fr. */}
      <div style={frame(shellGrid)}>
        {shellOrder.map((key) => (
          <div style={shellRegionStyle(key)}>{shellRegions[key].label}</div>
        ))}
      </div>
    </div>
  )
}

{
  /* ---------------------------- CENTERED HERO ----------------------- */
  pattern === "hero" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      {/* REAL grid with place-items-center: one item, centred on both axes. The
          tall frame stands in for a min-h-dvh viewport-height container. */}
      <div
        style={frame(
          "display: grid; place-items: center; height: 240px;",
        )}
      >
        <div
          style={`margin: 0; box-sizing: border-box; width: 200px; max-width: 100%; background: #ffffff; border: 1px solid ${CARD_BRD}; border-radius: 12px; padding: 18px; display: flex; flex-direction: column; align-items: center; gap: 10px; box-shadow: 0 1px 2px rgba(15,23,42,0.06);`}
        >
          <span
            style={`margin: 0; width: 30px; height: 30px; border-radius: 9px; background: ${ACCENT};`}
          />
          <span style={`margin: 0; color: ${CARD_INK}; font-weight: 800; font-size: 0.95rem;`}>
            Sign in
          </span>
          <span
            style={`margin: 0; width: 100%; height: 32px; border-radius: 8px; background: ${ACCENT}; color: ${ACCENT_INK}; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.82rem;`}
          >
            Continue
          </span>
        </div>
      </div>
    </div>
  )
}

{
  /* ----------------------- DASHBOARD — FEATURED --------------------- */
  pattern === "dashboard" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      {/* REAL grid: three minmax(0,1fr) columns. The Revenue tile claims a 2×2
          block with `grid-column: span 2; grid-row: span 2` (Tailwind
          col-span-2 row-span-2); the four smaller tiles auto-place around it. */}
      <div style={frame(dashGrid)}>
        {dashTiles.map((tile) => (
          <div style={dashTileStyle(tile.hero)}>
            <span style="margin: 0;">{tile.label}</span>
            {tile.hero && <code style={spanTag}>col-span-2 row-span-2</code>}
          </div>
        ))}
      </div>
    </div>
  )
}
