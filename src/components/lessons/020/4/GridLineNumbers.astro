---
// Grid line-numbers figure for Chapter 020 L4 (Grid, the 2D primitive).
//
// Goal: demystify that grid LINES are edges, numbered from 1 — not the tracks
// between them. A 3-column grid has 4 vertical lines (1..4); a 2-row grid has 3
// horizontal lines (1..3). Once the student pictures the lines as numbered edges,
// `col-start-2 col-end-4` reads literally as "from line 2 to line 4" — i.e. the
// columns BETWEEN those two lines (columns 2 and 3). The figure shades exactly
// that region so the placement string maps onto a visible span.
//
// Build: a REAL `display: grid` (3 cols × 2 rows) is the base layer, so a reader
// can open devtools and inspect the actual tracks (the pedagogical USP of the
// HTML+CSS diagram doc). The tracks are GAP-LESS — adjacent cells share one edge —
// because the whole point is "a line is a single shared edge"; a gap would make
// "which side is line 2?" ambiguous. The cells are kept FAINT on purpose; the
// emphasized lines and their number badges, drawn as deterministically-positioned
// overlays on top, are the visual focus.
//
// Layering inside the positioned stage (bottom → top):
//   1. the real CSS grid of faint cells (inspectable),
//   2. the blue shaded region spanning columns 2–3 (what col-start-2 col-end-4 grabs),
//   3. the emphasized gridlines (full-height verticals, full-width horizontals),
//   4. the line-number badges hugging the top edge (verticals) and left edge (rows).
// Every overlay coordinate is computed from the fixed CELL_W / CELL_H below, so the
// badges and lines sit exactly on the real grid's edges.
//
// This component renders the figure body only; the MDX wraps it in <Figure> with
// the caption. Colours are hard-coded illustration tints with `color-scheme: light`
// pinned — the sanctioned divergence from the OKLCH @theme tokens for figures
// (matches AutoPlacementCells / PlaceItemsVsPlaceContent in this chapter). `margin:
// 0` on every inner element defeats Starlight's prose-margin injection.

// Illustration palette (hard-coded, not @theme — see header note). Same slate
// frame + blue accent family as the chapter's other L4 figures so it feels of a
// piece. The faint cells stay near-invisible; the LINES carry the slate-700 ink so
// they dominate, and the shaded selection + its line numbers use the blue accent.
const FRAME_BRD = "#cbd5e1"; // slate 300 — outer figure-frame ring
const FRAME_BG = "#f8fafc"; // slate 50 — figure-frame fill
const CELL_BG = "#ffffff"; // white — faint cell fill (recedes)
const CELL_BRD = "#e2e8f0"; // slate 200 — faint cell boundary (barely there)
const LINE_INK = "#334155"; // slate 700 — the emphasized gridlines (the focus)
const BADGE_BG = "#334155"; // slate 700 — vertical/horizontal line-number badge fill
const BADGE_INK = "#ffffff"; // white — line-number digit on the slate badges
const SEL_BG = "rgba(59, 130, 246, 0.14)"; // blue 500 @ 14% — the col-start-2/col-end-4 span
const SEL_LINE = "#2563eb"; // blue 600 — the two lines bounding the selection (2 and 4)
const SEL_BADGE_BG = "#2563eb"; // blue 600 — badges for the selection's bounding lines
const SEL_INK = "#1d4ed8"; // blue 700 — the col-start/col-end label text
const SEL_LABEL_BG = "#dbeafe"; // blue 100 — the col-start/col-end label pill fill
const AXIS_INK = "#64748b"; // slate 500 — the tiny "vertical lines / horizontal lines" axis hints

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// --- fixed grid geometry ---------------------------------------------------
// Exact pixel tracks so every overlaid line / badge coordinate is deterministic.
// Three equal columns, two rows, NO gap (adjacent cells share one edge — a line).
const COLS = 3;
const ROWS = 2;
const CELL_W = 104;
const CELL_H = 74;
const LINE_W = 3; // emphasized-line thickness

const gridW = COLS * CELL_W; // 312 — no gap, so width is just cols × cell
const gridH = ROWS * CELL_H; // 148

// x of vertical line i (1-based): line 1 = left edge … line COLS+1 = right edge.
const vx = (i: number) => (i - 1) * CELL_W;
// y of horizontal line j (1-based): line 1 = top edge … line ROWS+1 = bottom edge.
const hy = (j: number) => (j - 1) * CELL_H;

// The selection demonstrated by the caption: col-start-2 col-end-4 → the span
// BETWEEN vertical line 2 and vertical line 4 (covering columns 2 and 3).
const SEL_START = 2;
const SEL_END = 4;
const selLeft = vx(SEL_START);
const selWidth = vx(SEL_END) - vx(SEL_START);

const verticalLines = Array.from({ length: COLS + 1 }, (_, k) => k + 1); // 1..4
const horizontalLines = Array.from({ length: ROWS + 1 }, (_, k) => k + 1); // 1..3
const cells = Array.from({ length: COLS * ROWS }); // 6 faint cells

// Is a given line one of the two that bound the highlighted selection?
const isSelV = (i: number) => i === SEL_START || i === SEL_END;

// The real, inspectable grid of faint cells — the base layer.
const gridStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "display: grid",
  `grid-template-columns: repeat(${COLS}, ${CELL_W}px)`,
  `grid-template-rows: repeat(${ROWS}, ${CELL_H}px)`,
  "gap: 0",
  `width: ${gridW}px`,
  `height: ${gridH}px`,
].join("; ");

const cellStyle = [
  "margin: 0",
  "box-sizing: border-box",
  `background: ${CELL_BG}`,
  `border: 1px solid ${CELL_BRD}`,
].join("; ");

// A line-number badge. `kind` swaps the slate default for the blue selection
// colour on lines 2 and 4 so the eye ties the numbers to the shaded span.
const badge = (selected: boolean) =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "position: absolute",
    "width: 20px",
    "height: 20px",
    "border-radius: 999px",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "font-size: 0.74rem",
    "font-weight: 700",
    "line-height: 1",
    `font-family: ${mono}`,
    `color: ${BADGE_INK}`,
    `background: ${selected ? SEL_BADGE_BG : BADGE_BG}`,
    "box-shadow: 0 1px 2px rgba(15, 23, 42, 0.25)",
  ].join("; ");

// Padding around the grid INSIDE the stage so badges sitting just outside the
// grid edges (top row of vertical numbers, left column of row numbers) have room.
const PAD_TOP = 26; // room for the vertical-line numbers above the grid
const PAD_LEFT = 26; // room for the horizontal-line numbers left of the grid
const PAD_RIGHT = 8;
const PAD_BOTTOM = 8;
---

<div
  style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; justify-content: center; padding: 6px 2px;`}
>
  <div style="margin: 0; display: inline-block;">
    {/* Stage: the grid plus all positioned overlays. Padded so edge badges fit. */}
    <div
      style={`margin: 0; position: relative; box-sizing: border-box; padding: ${PAD_TOP}px ${PAD_RIGHT}px ${PAD_BOTTOM}px ${PAD_LEFT}px; border-radius: 16px; border: 1px dashed ${FRAME_BRD}; background: ${FRAME_BG};`}
    >
      {/* Inner positioning context whose top-left is the grid's (0,0), so every
          vx()/hy() coordinate maps straight onto an edge of the real grid. */}
      <div style={`margin: 0; position: relative; width: ${gridW}px; height: ${gridH}px;`}>
        {/* 1 — the REAL, inspectable grid of faint cells (the base layer). */}
        <div style={gridStyle}>
          {cells.map(() => <div style={cellStyle}></div>)}
        </div>

        {/* 2 — the shaded selection: columns 2–3, i.e. everything between
               vertical lines 2 and 4. This is what col-start-2 col-end-4 grabs. */}
        <div
          style={`margin: 0; position: absolute; top: 0; height: ${gridH}px; left: ${selLeft}px; width: ${selWidth}px; background: ${SEL_BG}; pointer-events: none;`}
        >
        </div>

        {/* 3a — horizontal gridlines (full width), drawn first so the verticals
                cross OVER them at the corners for a clean lattice. */}
        {
          horizontalLines.map((j) => (
            <div
              style={`margin: 0; position: absolute; left: 0; width: ${gridW}px; top: ${hy(j) - LINE_W / 2}px; height: ${LINE_W}px; background: ${LINE_INK}; border-radius: 2px; pointer-events: none;`}
            />
          ))
        }

        {/* 3b — vertical gridlines (full height). Lines 2 and 4 (the selection's
                bounds) take the blue accent and a touch more weight. */}
        {
          verticalLines.map((i) => (
            <div
              style={`margin: 0; position: absolute; top: 0; height: ${gridH}px; left: ${vx(i) - LINE_W / 2}px; width: ${LINE_W}px; background: ${isSelV(i) ? SEL_LINE : LINE_INK}; border-radius: 2px; pointer-events: none;`}
            />
          ))
        }

        {/* 4a — vertical-line number badges, hugging the TOP edge of the grid.
                Centred on each line's x; lifted just above the grid. */}
        {
          verticalLines.map((i) => (
            <span
              style={`${badge(isSelV(i))}; left: ${vx(i) - 10}px; top: -${PAD_TOP - 1}px;`}
            >
              {i}
            </span>
          ))
        }

        {/* 4b — horizontal-line number badges, hugging the LEFT edge of the grid.
                Centred on each line's y; pushed just left of the grid. */}
        {
          horizontalLines.map((j) => (
            <span
              style={`${badge(false)}; top: ${hy(j) - 10}px; left: -${PAD_LEFT - 1}px;`}
            >
              {j}
            </span>
          ))
        }
      </div>

      {/* Axis hints: tiny labels naming the two line directions, placed at the
          padded margins so the student reads "these top numbers = vertical lines,
          these side numbers = horizontal lines". */}
      <span
        style={`margin: 0; position: absolute; top: 5px; left: ${PAD_LEFT + gridW / 2}px; transform: translateX(-50%); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.02em; color: ${AXIS_INK}; white-space: nowrap;`}
      >
        vertical lines
      </span>
      <span
        style={`margin: 0; position: absolute; left: 4px; top: ${PAD_TOP + gridH / 2}px; transform: translateY(-50%) rotate(-90deg); transform-origin: left center; font-size: 0.62rem; font-weight: 600; letter-spacing: 0.02em; color: ${AXIS_INK}; white-space: nowrap;`}
      >
        horizontal lines
      </span>

      {/* The col-start-2 col-end-4 label pill, centred under the shaded span so the
          placement string visibly maps onto the highlighted columns 2–3. */}
      <span
        style={`margin: 0; position: absolute; bottom: -11px; left: ${PAD_LEFT + selLeft + selWidth / 2}px; transform: translateX(-50%); padding: 2px 8px; border-radius: 999px; background: ${SEL_LABEL_BG}; color: ${SEL_INK}; font-family: ${mono}; font-size: 0.7rem; font-weight: 700; white-space: nowrap; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.12);`}
      >
        col-start-2 col-end-4
      </span>
    </div>
  </div>
</div>
