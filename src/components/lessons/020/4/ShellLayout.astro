---
// Page-shell figure for Chapter 020 L4 (Grid, the 2D primitive).
//
// Goal: make "one template change rearranges the whole shell" concrete. The SAME
// four region boxes — Header / Sidebar / Main / Footer — are laid out two ways
// (this component renders ONE variant; the MDX puts both in a TabbedContent so
// switching tabs swaps the arrangement under fixed children):
//
//   variant="desktop" — `grid-template-columns: 200px 1fr;
//                        grid-template-rows: auto 1fr auto;
//                        grid-template-areas: 'header header' 'sidebar main'
//                        'footer footer'`. Header spans both columns on top, a
//                        fixed 200px sidebar on the left, main fills the rest, a
//                        full-width footer at the bottom. A fixed height makes the
//                        `1fr` main region visibly the tall one.
//   variant="mobile"  — the SAME four boxes, single column:
//                        `grid-template-columns: 1fr;
//                        grid-template-rows: auto auto 1fr auto;
//                        grid-template-areas: 'header' 'main' 'sidebar' 'footer'`.
//                        Everything stacks one per row and the sidebar drops BELOW
//                        main. Rendered in a narrow centred frame so it reads as a
//                        phone.
//
// The pedagogical payoff: ONLY the container's track + area strings change between
// the two. Every child keeps its `[grid-area:NAME]` — so each region box carries a
// tiny `grid-area:` tag that stays identical across tabs, and it's all a REAL CSS
// grid using `grid-template-areas` / `grid-area` (the exact mechanic the
// AnnotatedCode block above teaches), so a reader can open devtools and see it.
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches
// RaggedFlexVsEvenGrid / AutoPlacementCells / AxisFrame in this chapter). Each
// region gets a DISTINCT soft fill (not the chapter's single-blue family) so the
// four areas stay individually trackable as they rearrange between tabs. `margin:
// 0` on every inner element defeats Starlight's prose-margin injection into grid
// children.

interface Props {
  variant: "desktop" | "mobile";
}

const { variant } = Astro.props;
const isMobile = variant === "mobile";

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// Frame chrome — same dashed slate ring + slate-50 fill as the chapter's other
// figures, so the shell reads as living inside "the grid container".
const FRAME_BRD = "#cbd5e1"; // slate 300
const FRAME_BG = "#f8fafc"; // slate 50 — shows through the gap gutters
const TAG_INK = "#475569"; // slate 600 — the grid-area: tag text

// One distinct soft fill + matching border + ink per region, held CONSTANT across
// both variants so the eye tracks each box from desktop to mobile.
const regions = {
  header: { label: "Header", bg: "#dbeafe", brd: "#93c5fd", ink: "#1e3a8a" }, // blue
  sidebar: { label: "Sidebar", bg: "#ede9fe", brd: "#c4b5fd", ink: "#5b21b6" }, // violet
  main: { label: "Main", bg: "#dcfce7", brd: "#86efac", ink: "#166534" }, // green
  footer: { label: "Footer", bg: "#ffedd5", brd: "#fdba74", ink: "#9a3412" }, // amber
} as const;

type RegionKey = keyof typeof regions;

// The REAL grid container. Each variant differs ONLY in its track templates and
// area map — the children below are byte-identical between variants.
const gridStyle = isMobile
  ? [
      "margin: 0",
      "box-sizing: border-box",
      "display: grid",
      "grid-template-columns: 1fr",
      "grid-template-rows: auto auto 1fr auto",
      "grid-template-areas: 'header' 'main' 'sidebar' 'footer'",
      "gap: 10px",
      "height: 320px",
      "max-width: 220px",
      "margin-inline: auto",
      "padding: 12px",
      "border-radius: 16px",
      `border: 1px dashed ${FRAME_BRD}`,
      `background: ${FRAME_BG}`,
    ].join("; ")
  : [
      "margin: 0",
      "box-sizing: border-box",
      "display: grid",
      "grid-template-columns: 200px 1fr",
      "grid-template-rows: auto 1fr auto",
      "grid-template-areas: 'header header' 'sidebar main' 'footer footer'",
      "gap: 12px",
      "height: 280px",
      "padding: 14px",
      "border-radius: 16px",
      `border: 1px dashed ${FRAME_BRD}`,
      `background: ${FRAME_BG}`,
    ].join("; ");

// A region box: filled, labelled, and tagged with the `[grid-area:NAME]` it
// claims. `grid-area` is the load-bearing line — it's the SAME on both variants.
const regionStyle = (key: RegionKey) => {
  const r = regions[key];
  return [
    "margin: 0",
    "box-sizing: border-box",
    `grid-area: ${key}`,
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "justify-content: center",
    "gap: 4px",
    "border-radius: 10px",
    "padding: 8px 10px",
    "min-height: 0", // let the 1fr main region shrink/grow inside the fixed frame
    "min-width: 0",
    `background: ${r.bg}`,
    `border: 1px solid ${r.brd}`,
  ].join("; ");
};

const labelStyle = (key: RegionKey) =>
  [
    "margin: 0",
    `color: ${regions[key].ink}`,
    "font-weight: 700",
    "font-size: 0.85rem",
    "line-height: 1.1",
  ].join("; ");

// The little `grid-area:` tag under each label. Hard-coded transparent background
// + zero padding so Starlight's inline-<code> pill styling can't widen it.
const tagStyle = [
  "margin: 0",
  `font-family: ${mono}`,
  `color: ${TAG_INK}`,
  "background: transparent",
  "padding: 0",
  "font-size: 0.68rem",
  "line-height: 1.1",
  "white-space: nowrap",
].join("; ");

// Source order is FIXED across variants (header, sidebar, main, footer) — it
// matches the AnnotatedCode block's child order. Auto-placement is overridden by
// each child's grid-area, so DOM order and visual order diverge by design; the
// grid-template-areas map is what decides where each box lands.
const order: RegionKey[] = ["header", "sidebar", "main", "footer"];
---

<div style={`margin: 0; color-scheme: light; font-family: ${sans}; padding: 4px 2px;`}>
  {/* REAL CSS grid using grid-template-areas. Inspect it: the only difference
      between the two tabs is this element's track + area strings. */}
  <div style={gridStyle}>
    {
      order.map((key) => (
        <div style={regionStyle(key)}>
          <span style={labelStyle(key)}>{regions[key].label}</span>
          <code style={tagStyle}>{`grid-area: ${key}`}</code>
        </div>
      ))
    }
  </div>
</div>
