---
// Auto-placement figure for Chapter 020 L4 (Grid, the 2D primitive).
//
// Goal: make "items flow into cells in source order" visible at a glance — with
// no instructions, the Nth grid item lands in the Nth cell, left-to-right then
// top-to-bottom. This illustrates the `grid grid-cols-3 gap-4` six-card example
// printed directly above it in the lesson.
//
// The cells sit in a REAL `display: grid; grid-template-columns: repeat(3, …)`
// container (devtools-inspectable per the HTML+CSS diagram doc), with the `gap`
// showing as visible gutters between cells — not just borders. Each cell carries
// its source-order number 1..6 and a tiny `Card` tag echoing the `<Card>…` rows
// of the code block above, so "item n → cell n" reads instantly.
//
// A serpentine flow ribbon is drawn as a pointer-events:none SVG laid OVER the
// real grid. The grid has fixed cell/gap pixel sizes, so the ribbon's path
// coordinates are fully deterministic; the SVG is pure decoration and never
// touches the grid's own layout. The ribbon traces 1→2→3, wraps down, then
// 4→5→6, with an arrowhead at the end — the "next free cell" reading order.
//
// This component renders the figure body only; the MDX wraps it in <Figure> with
// the caption. Colours are hard-coded illustration tints with `color-scheme:
// light` pinned — the sanctioned divergence from the OKLCH @theme tokens for
// figures (matches RaggedFlexVsEvenGrid / AxisFrame in this chapter). `margin: 0`
// on every inner element defeats Starlight's prose-margin injection into grid
// children.

// Illustration palette (hard-coded, not @theme — see header note). Same blue
// family as the other Ch020 figures so the chapter feels of a piece; the flow
// ribbon uses the violet accent so it reads as an overlay distinct from the
// cells, not another border.
const CELL_BG = "#eff6ff"; // blue 50 — cell fill
const CELL_BRD = "#bfdbfe"; // blue 200 — cell border
const NUM_INK = "#1e3a8a"; // blue 900 — the big source-order number
const FRAME_BRD = "#cbd5e1"; // slate 300 — the grid-container ring
const FRAME_BG = "#f8fafc"; // slate 50 — the grid-container fill (shows in gutters)
const FLOW = "#9333ea"; // violet 600 — the auto-placement flow ribbon

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// --- fixed grid geometry ---------------------------------------------------
// The grid is laid out at exact pixel sizes so the overlaid SVG ribbon can be
// drawn with deterministic coordinates. Three equal columns, two rows.
const COLS = 3;
const ROWS = 2;
const CELL_W = 100;
const CELL_H = 78;
const GAP = 16;

const gridW = COLS * CELL_W + (COLS - 1) * GAP; // 332
const gridH = ROWS * CELL_H + (ROWS - 1) * GAP; // 172

// Cell centre coordinates (col index 0..2, row index 0..1).
const cx = (col: number) => col * (CELL_W + GAP) + CELL_W / 2;
const cy = (row: number) => row * (CELL_H + GAP) + CELL_H / 2;

// The serpentine ribbon runs across the TOP strip of each cell, clear of the
// big number which sits in the lower portion. `yOff` lifts the ribbon toward
// the top edge of the cells so the path and the digit never collide.
const yOff = 24;
const r1 = cy(0) - yOff; // row-1 ribbon y
const r2 = cy(1) - yOff; // row-2 ribbon y
const xL = cx(0); // left column centre x
const xR = cx(COLS - 1); // right column centre x

// The ribbon reads cleanest as three strokes: a solid forward run along each
// row (with an arrowhead), plus a dashed "carriage return" loop for the wrap —
// so it never looks like the ribbon also flows 6→4.
const bow = gridW * 0.16; // how far the wrap loop bulges past the cells
const runRow1 = `M ${xL} ${r1} L ${xR} ${r1}`;
const runRow2 = `M ${xL} ${r2} L ${xR} ${r2}`;
// Wrap: from the end of row 1 (right) loop down and back to the start of row 2
// (left). Drawn dashed to read as "carriage return", not a content flow.
const wrap = `M ${xR} ${r1} C ${xR + bow} ${r1}, ${xR + bow} ${r2}, ${xR} ${r2} L ${xL} ${r2}`;

// The big source-order number sits in the LOWER portion of the cell (the ribbon
// rides the top strip), so it's pushed down with `justify-content: flex-end`
// plus bottom padding rather than vertically centred.
const cell = [
  "margin: 0",
  "box-sizing: border-box",
  `width: ${CELL_W}px`,
  `height: ${CELL_H}px`,
  `background: ${CELL_BG}`,
  `border: 1px solid ${CELL_BRD}`,
  "border-radius: 12px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: flex-end",
  "padding: 0 0 12px",
].join("; ");

const numStyle = [
  "margin: 0",
  `color: ${NUM_INK}`,
  "font-weight: 800",
  "font-size: 1.6rem",
  "line-height: 1",
].join("; ");

// The REAL grid container. Fixed-size tracks + a real `gap` so the gutters are
// visibly the spacing between cells, and the slate-50 fill shows through them.
const gridStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "display: grid",
  `grid-template-columns: repeat(${COLS}, ${CELL_W}px)`,
  `grid-template-rows: repeat(${ROWS}, ${CELL_H}px)`,
  `gap: ${GAP}px`,
  "padding: 14px",
  "border-radius: 16px",
  `border: 1px dashed ${FRAME_BRD}`,
  `background: ${FRAME_BG}`,
].join("; ");
---

<div
  style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; justify-content: center; padding: 4px 2px;`}
>
  {/* Positioning context: the grid plus its overlaid flow ribbon. The ribbon's
      coordinate box matches the grid's content box (after the 14px padding). */}
  <div style="margin: 0; position: relative; display: inline-block;">
    {/* REAL CSS grid — six numbered cells, auto-placed in source order. */}
    <div style={gridStyle}>
      {
        [1, 2, 3, 4, 5, 6].map((n) => (
          <div style={cell}>
            <span style={numStyle}>{n}</span>
          </div>
        ))
      }
    </div>

    {/* Flow ribbon overlay. Inset by the grid's 14px padding so the SVG's
        coordinate space lines up with the cell tracks. pointer-events:none and
        purely decorative — the grid underneath is the real, inspectable thing. */}
    <svg
      width={gridW}
      height={gridH}
      viewBox={`0 0 ${gridW} ${gridH}`}
      style="position: absolute; top: 14px; left: 14px; pointer-events: none; overflow: visible;"
      aria-hidden="true"
    >
      <defs>
        <marker
          id="apc-arrow"
          viewBox="0 0 10 10"
          refX="7"
          refY="5"
          markerWidth="7"
          markerHeight="7"
          orient="auto-start-reverse"
        >
          <path d="M 0 0 L 10 5 L 0 10 z" fill={FLOW}></path>
        </marker>
      </defs>

      {/* Row 1 forward run: 1 → 2 → 3 */}
      <path
        d={runRow1}
        fill="none"
        stroke={FLOW}
        stroke-width="3"
        stroke-linecap="round"
        marker-end="url(#apc-arrow)"
      ></path>

      {/* The wrap (carriage return): end of row 1 loops down to start of row 2.
          Dashed so it reads as "go to next row", not a 6→4 content flow. */}
      <path
        d={wrap}
        fill="none"
        stroke={FLOW}
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-dasharray="2 5"
        opacity="0.65"
      ></path>

      {/* Row 2 forward run: 4 → 5 → 6 */}
      <path
        d={runRow2}
        fill="none"
        stroke={FLOW}
        stroke-width="3"
        stroke-linecap="round"
        marker-end="url(#apc-arrow)"
      ></path>
    </svg>
  </div>
</div>
