---
// place-items vs place-content figure for Chapter 020 L4 (Grid, the 2D primitive).
//
// Goal: pin down the pair of grid-alignment shorthands students reliably confuse.
// Both panels show the SAME oversized "container" (identical width, height, and
// solid border) so the only thing that differs is what the grid does inside it —
// which makes "the container" vs "the track group" legible side by side.
//
//   LEFT  — labelled `place-items-center`. A REAL grid that FILLS the container:
//           `grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(3, 1fr)`,
//           so the nine cells stretch edge-to-edge (their faint borders run to the
//           container edge). `place-items: center` then centres a SMALL accent
//           square WITHIN each full-size cell. Takeaway: the items move inside
//           their cells; the grid itself fills the container.
//   RIGHT — labelled `place-content-center`. A REAL grid whose tracks DON'T fill
//           the container: three fixed-size columns and rows
//           (`grid-template-columns: repeat(3, 46px); grid-template-rows: repeat(3, 30px)`)
//           sitting in the same big box, with `place-content: center` on the
//           container. The whole little block of nine tracks centres in the
//           oversized container, leaving equal empty margin all around. The cells
//           are accent-FILLED so it's clear the *group* of tracks moved as a unit,
//           not the items within their cells.
//
// Both panels are real CSS grids so a reader can open devtools and inspect the
// actual tracks / cells (the pedagogical USP of HTML+CSS figures). This component
// renders the two-panel body only; the MDX wraps it in <Figure> with the caption.
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches
// RaggedFlexVsEvenGrid / ShellLayout / SubgridBeforeAfter in this chapter).
// `margin: 0` on every inner element defeats Starlight's prose-margin injection
// into grid children.

// Illustration palette (hard-coded, not @theme — see header note). Same slate
// frame family as the chapter's other L4 figures; one blue accent for the items so
// the contrast between "small item in a big cell" and "the moved track block"
// reads at a glance.
const PANEL_BG = "#ffffff"; // figure surface behind both panels
const CONTAINER_BRD = "#94a3b8"; // slate 400 — the solid "container" ring (identical both sides)
const CONTAINER_BG = "#f8fafc"; // slate 50 — container fill (the empty space the group floats in)
const CELL_BRD = "#e2e8f0"; // slate 200 — faint cell boundary lines
const ITEM_BG = "#bfdbfe"; // blue 200 — accent item fill
const ITEM_BRD = "#60a5fa"; // blue 400 — accent item border
const LABEL_INK = "#475569"; // slate 600 — panel label text
const TITLE_INK = "#0f172a"; // slate 900 — label code text

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// The SAME oversized container for both panels — same coordinate box so the only
// visible difference is the grid behaviour inside it.
const BOX = 168; // px — square container, clearly bigger than the right panel's tracks need

// Nine cells, rendered the same count both sides; left stretches them, right keeps
// them small and clustered.
const cells = Array.from({ length: 9 });

// One panel column (label on top, the big container below). Sized so the two
// panels sit side by side on wide cards and wrap on narrow ones.
const panel = ["margin: 0", "box-sizing: border-box", "flex: 0 1 auto"].join("; ");

const panelLabel = [
  "margin: 0 0 8px",
  `color: ${LABEL_INK}`,
  "font-size: 0.72rem",
  "font-weight: 600",
  "display: flex",
  "align-items: center",
  "gap: 7px",
].join("; ");

const labelCode = [
  "margin: 0",
  `font-family: ${mono}`,
  `color: ${TITLE_INK}`,
  "background: #e2e8f0",
  "border-radius: 5px",
  "padding: 1px 6px",
  "font-size: 0.72rem",
  "font-weight: 600",
  "white-space: nowrap",
].join("; ");

// LEFT container: the grid FILLS the box (1fr tracks), and place-items centres each
// small item inside its full-size cell.
const fillGrid = [
  "margin: 0",
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: repeat(3, 1fr)",
  "grid-template-rows: repeat(3, 1fr)",
  "place-items: center", // ← the demonstrated property: items centred WITHIN their cells
  "gap: 0",
  `width: ${BOX}px`,
  `height: ${BOX}px`,
  "border-radius: 12px",
  `border: 1px solid ${CONTAINER_BRD}`,
  `background: ${CONTAINER_BG}`,
].join("; ");

// A full-size cell in the left grid: faint border so the 3×3 cell structure is
// visible running edge-to-edge. The small centred item sits inside it.
const fillCell = [
  "margin: 0",
  "box-sizing: border-box",
  "width: 100%",
  "height: 100%",
  "display: grid",
  "place-items: center",
  `border: 1px dashed ${CELL_BRD}`,
].join("; ");

const fillItem = [
  "margin: 0",
  "box-sizing: border-box",
  "width: 18px",
  "height: 18px",
  "border-radius: 5px",
  `background: ${ITEM_BG}`,
  `border: 1px solid ${ITEM_BRD}`,
].join("; ");

// RIGHT container: SAME box, but the tracks are small fixed sizes that don't fill
// it, and place-content centres the whole track block — equal margin all around.
const blockGrid = [
  "margin: 0",
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: repeat(3, 46px)",
  "grid-template-rows: repeat(3, 30px)",
  "place-content: center", // ← the demonstrated property: the whole track GROUP centred
  "gap: 4px",
  `width: ${BOX}px`,
  `height: ${BOX}px`,
  "border-radius: 12px",
  `border: 1px solid ${CONTAINER_BRD}`,
  `background: ${CONTAINER_BG}`,
].join("; ");

// A small cell in the right grid: accent-FILLED so the clustered block reads as a
// single moved group of tracks, not items floating inside big cells.
const blockCell = [
  "margin: 0",
  "box-sizing: border-box",
  "border-radius: 5px",
  `background: ${ITEM_BG}`,
  `border: 1px solid ${ITEM_BRD}`,
].join("; ");
---

<div
  style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; flex-wrap: wrap; gap: 28px 32px; justify-content: center; align-items: flex-start; background: ${PANEL_BG}; border-radius: 12px;`}
>
  {/* ---------------- LEFT: place-items-center (items within cells) -------------- */}
  <div style={panel}>
    <p style={panelLabel}>
      <span style={labelCode}>place-items-center</span>
      <span style="margin: 0; font-weight: 600;">item centred in its cell</span>
    </p>
    {/* REAL grid: 1fr tracks fill the container; place-items centres each small
        item inside its full-size cell. Inspect it — the cells run edge-to-edge. */}
    <div style={fillGrid}>
      {cells.map(() => (
        <div style={fillCell}>
          <div style={fillItem}></div>
        </div>
      ))}
    </div>
  </div>

  {/* --------------- RIGHT: place-content-center (the track group) -------------- */}
  <div style={panel}>
    <p style={panelLabel}>
      <span style={labelCode}>place-content-center</span>
      <span style="margin: 0; font-weight: 600;">whole track group centred</span>
    </p>
    {/* REAL grid: small fixed tracks don't fill the container, so place-content
        centres the whole block — equal empty margin all around. Inspect it. */}
    <div style={blockGrid}>
      {cells.map(() => (
        <div style={blockCell}></div>
      ))}
    </div>
  </div>
</div>
