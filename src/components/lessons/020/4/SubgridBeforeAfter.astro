---
// Subgrid before/after figure for Chapter 020 L4 (Grid, the 2D primitive).
//
// Goal: make the cross-card alignment problem — and subgrid's fix — visible at a
// glance. The SAME three product cards (a title / image / body / footer-button
// structure, with DELIBERATELY different title lengths: one one-liner, one that
// wraps to two lines, one to three) are laid out two ways. This component renders
// ONE variant; the MDX puts both in a TabbedContent so flipping tabs swaps the
// row-track behaviour under byte-identical cards:
//
//   variant="without" — three cards in a `grid-template-columns: repeat(3,1fr)`
//                        parent, but each card is its OWN independent column flow
//                        (display:flex / flex-direction:column) sized to its own
//                        content. Because the titles are different heights, each
//                        card's image block, body, and footer start at a DIFFERENT
//                        y — the image tops visibly stair-step and the footer
//                        buttons don't line up across the row. The raggedness is
//                        the whole point.
//   variant="with"     — the SAME three cards, same titles, but the parent now
//                        declares explicit shared row tracks
//                        (`grid-template-rows: auto auto 1fr auto` →
//                        title / image / body / footer) and each card SPANS those
//                        four rows (`grid-row: span 4`) and sets
//                        `grid-template-rows: subgrid`, so the card's own four
//                        sections place onto the PARENT's lines. Now every title
//                        row is the same height (tall enough for the 3-line one),
//                        every image starts at the same y, every footer aligns.
//
// This is the exact mechanic the prose calls out: span the parent's rows AND
// declare grid-rows-subgrid. It's a REAL CSS grid + real subgrid (Baseline, so it
// renders in every current browser), devtools-inspectable per the HTML+CSS diagram
// doc — open the overlay on the "with" tab and the card's tracks are the parent's.
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches
// RaggedFlexVsEvenGrid / AutoPlacementCells / ShellLayout in this chapter). Each
// card section gets a distinct soft band so title/image/body/footer stay
// individually trackable as they (mis)align. `margin: 0` on every inner element
// defeats Starlight's prose-margin injection into grid/flex children.

interface Props {
  variant: "without" | "with";
}

const { variant } = Astro.props;
const isSubgrid = variant === "with";

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// Illustration palette (hard-coded, not @theme — see header note). Blue card
// surface to match the chapter family; each internal section gets its own soft
// tint so the rows read as distinct bands and their alignment (or lack of it) is
// obvious across the three cards.
const FRAME_BRD = "#cbd5e1"; // slate 300 — grid-container ring
const FRAME_BG = "#f8fafc"; // slate 50 — container fill (shows in gutters)
const CARD_BG = "#ffffff"; // card surface
const CARD_BRD = "#bfdbfe"; // blue 200 — card border

const TITLE_BG = "#dbeafe"; // blue 100 — title band
const TITLE_INK = "#1e3a8a"; // blue 900 — title text
const IMG_BG = "#c7d2fe"; // indigo 200 — flat "image" rectangle
const IMG_INK = "#3730a3"; // indigo 800 — image placeholder label
const BODY_INK = "#475569"; // slate 600 — body lines
const BTN_BG = "#4f46e5"; // indigo 600 — footer button
const BTN_INK = "#ffffff"; // button label

// Three cards with DELIBERATELY different title lengths so the title row is 1, 2,
// and 3 lines tall. The fixed-ish card width (the 1fr track at the figure's size)
// plus these word counts make the wrap deterministic enough for the demo: the
// misalignment in the "without" tab comes straight from these height differences.
const cards = [
  { title: "Aurora Lamp", body: "Warm bedside glow." },
  { title: "Drift Lounge Chair Set", body: "Two-seat oak frame." },
  { title: "Mesa Adjustable Standing Desk Pro", body: "Electric sit-stand base." },
] as const;

// The REAL grid container. Both variants share three equal columns and a gap; the
// "with" variant ALSO declares the four shared row tracks the cards subgrid onto.
const gridStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  isSubgrid ? "grid-template-rows: auto auto 1fr auto" : "",
  // Top-align the cards in the "without" case so each one hugs its own content
  // height and the stair-step is visible (otherwise the grid would stretch them
  // all to the tallest, hiding the bug). Irrelevant under subgrid.
  isSubgrid ? "" : "align-items: start",
  "gap: 12px",
  "max-width: 460px",
  "margin-inline: auto",
  "padding: 14px",
  "border-radius: 16px",
  `border: 1px dashed ${FRAME_BRD}`,
  `background: ${FRAME_BG}`,
]
  .filter(Boolean)
  .join("; ");

// A card. In the "without" case it's a self-contained vertical flex column sized
// to its own content. In the "with" case it's a grid item that SPANS the parent's
// four rows and adopts them via subgrid — so its children (title/image/body/
// footer) land on the PARENT's shared lines instead of inventing their own.
const cardStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "min-width: 0",
  "border-radius: 10px",
  "overflow: hidden",
  `background: ${CARD_BG}`,
  `border: 1px solid ${CARD_BRD}`,
  ...(isSubgrid
    ? [
        "display: grid",
        "grid-row: span 4", // span the parent's four shared row tracks …
        "grid-template-rows: subgrid", // … and place children onto THOSE lines
      ]
    : ["display: flex", "flex-direction: column"]),
].join("; ");

// Section bands. Under subgrid each is a direct grid child landing on one of the
// parent's rows; under flow they just stack. `margin: 0` throughout.
const titleStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "padding: 8px 10px",
  `background: ${TITLE_BG}`,
  `color: ${TITLE_INK}`,
  "font-weight: 700",
  "font-size: 0.82rem",
  "line-height: 1.25",
].join("; ");

const imageStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "height: 46px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  `background: ${IMG_BG}`,
  `color: ${IMG_INK}`,
  "font-size: 0.62rem",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
].join("; ");

const bodyStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "padding: 8px 10px",
  `color: ${BODY_INK}`,
  "font-size: 0.74rem",
  "line-height: 1.3",
].join("; ");

const footerStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "padding: 8px 10px 10px",
  "display: flex",
].join("; ");

const buttonStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "width: 100%",
  "padding: 5px 0",
  "border-radius: 6px",
  "border: 0",
  `background: ${BTN_BG}`,
  `color: ${BTN_INK}`,
  "font-family: inherit",
  "font-size: 0.7rem",
  "font-weight: 700",
  "text-align: center",
].join("; ");
---

<div style={`margin: 0; color-scheme: light; font-family: ${sans}; padding: 4px 2px;`}>
  {/* REAL CSS grid. Under the "with" variant the card elements span the parent's
      four rows and use grid-template-rows:subgrid — inspect it in devtools and the
      card's tracks ARE the parent's, which is why the sections line up. */}
  <div style={gridStyle}>
    {
      cards.map((c) => (
        <div style={cardStyle}>
          <p style={titleStyle}>{c.title}</p>
          <div style={imageStyle}>image</div>
          <p style={bodyStyle}>{c.body}</p>
          <div style={footerStyle}>
            <span style={buttonStyle}>Add to cart</span>
          </div>
        </div>
      ))
    }
  </div>
</div>
