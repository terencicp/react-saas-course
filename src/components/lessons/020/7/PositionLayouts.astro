---
// The "five position layouts you'll reach for" renderings for Chapter 020 L7.
//
// Goal: each of the five canonical positioning patterns a senior ships, as a
// REAL mini-app (devtools-inspectable per the HTML+CSS diagram doc). This
// component renders ONE pattern; the MDX drops it into a <TabbedItem> five
// times and pairs it with the matching Tailwind class string in a `tsx` fence.
// It does NOT wrap itself in <Figure>: TabbedContent already supplies the card.
//
// The five patterns mirror the prose + the gallery list exactly:
//   badge   — relative card + absolute -top-2 -right-2 badge (the atomic unit)
//   sticky  — a REAL position:sticky header inside a scroll container; the
//             container scrolls (not the page), so it demos honestly without
//             pinning to the viewport
//   toast   — FAKED: a framed "app window" (position:relative) with the toast
//             placed via absolute bottom/right INSIDE it, so it LOOKS pinned to
//             the viewport without actually being fixed (which would break the
//             page). Caption says so.
//   drawer  — FAKED the same way: a framed window with the panel pinned
//             full-height to the right edge via absolute inset-y-0 right-0.
//   overlay — real absolute inset-0 cover over a relative card.
//
// CRITICAL: `fixed`/`sticky` are NEVER emitted at figure scope. `fixed` would
// pin to the whole viewport and break the lesson page; the toast/drawer fake it
// with `position:absolute` inside an explicitly-`relative` frame. `sticky` IS
// used, but only inside a self-contained scroll container, so it stays trapped
// in the figure. The Tailwind strings the student copies (shown in the MDX
// fences) keep the real `fixed`/`sticky` — only the rendering is reframed.
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches
// FlexLayout / GridLayout / ContainingBlockDiagram in this chapter). `margin: 0`
// on every inner element defeats Starlight's prose-margin injection.

interface Props {
  pattern: "badge" | "sticky" | "toast" | "drawer" | "overlay";
}

const { pattern } = Astro.props;

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// Illustration palette (hard-coded, not @theme — see header note). Same blue
// family as the chapter's other figures so the gallery feels of a piece.
const ACCENT = "#2563eb"; // blue 600 — the "New" badge / primary action
const ACCENT_INK = "#ffffff"; // text on the accent fill
const PANEL_BG = "#ffffff"; // card / panel surface
const PANEL_BRD = "#e2e8f0"; // slate 200 — card border
const FRAME_BRD = "#94a3b8"; // slate 400 — the dashed "viewport" frame ring
const FRAME_BG = "#f1f5f9"; // slate 100 — faux page background behind chrome
const HEADING_INK = "#0f172a"; // slate 900 — strong heading text
const MUTED_INK = "#64748b"; // slate 500 — secondary text
const GHOST_BG = "#e2e8f0"; // slate 200 — skeleton placeholder bars
const TOAST_BG = "#0f172a"; // slate 900 — the toast surface (matches the code)
const TOAST_INK = "#ffffff";

// A wordmark "logo" dot, reused across the framed windows.
const logoDot = `margin: 0; width: 16px; height: 16px; border-radius: 5px; background: ${ACCENT}; flex: none;`;

// Skeleton "content" bar — neutral grey block standing in for page text/cards.
const skeletonBar = (w: string, h = "12px") =>
  `margin: 0; width: ${w}; height: ${h}; border-radius: 6px; background: ${GHOST_BG};`;

// The dashed ring + faux title bar that marks "this is a fake viewport window".
// Used by the toast and drawer patterns so a `position:absolute` child reads as
// "pinned to the window" without ever using real `fixed`.
const windowFrame = `position: relative; margin: 0; box-sizing: border-box; overflow: hidden; border-radius: 14px; border: 1.5px dashed ${FRAME_BRD}; background: ${FRAME_BG};`;
---

{
  /* ----------------------------- BADGE ON A CARD ----------------------------- */
  /* Real CSS: a position:relative card with a position:absolute badge that
     overhangs the top-right corner via -top-2 -right-2. The card is the badge's
     containing block, so it anchors to the card — exactly as in production. */
  pattern === "badge" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; justify-content: center; padding: 18px 8px;`}>
      <article
        style={`position: relative; margin: 0; box-sizing: border-box; width: 240px; max-width: 100%; border-radius: 12px; border: 1px solid ${PANEL_BRD}; background: ${PANEL_BG}; padding: 16px; box-shadow: 0 1px 2px rgba(15,23,42,0.06);`}
      >
        {/* the absolute badge, overhanging the corner thanks to negative offsets */}
        <span
          style={`position: absolute; top: -8px; right: -8px; margin: 0; border-radius: 999px; background: ${ACCENT}; color: ${ACCENT_INK}; padding: 2px 8px; font-size: 0.72rem; font-weight: 700; line-height: 1.4; box-shadow: 0 1px 2px rgba(15,23,42,0.15);`}
        >
          New
        </span>
        <h3 style={`margin: 0; color: ${HEADING_INK}; font-size: 0.95rem; font-weight: 700;`}>
          Starter plan
        </h3>
        <p style={`margin: 8px 0 0; color: ${MUTED_INK}; font-size: 0.82rem; line-height: 1.4;`}>
          Everything to launch your first project.
        </p>
        <div style={`margin: 14px 0 0; ${skeletonBar('60%', '10px')}`} />
      </article>
    </div>
  )
}

{
  /* --------------------------- STICKY SECTION HEADER -------------------------- */
  /* Real position:sticky, demoed HONESTLY: the scroll happens inside this fixed-
     height, overflow-y:auto box (NOT the page), so the header pins to the top of
     the box and never escapes to the viewport. Scroll the panel to see it stick. */
  pattern === "sticky" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; justify-content: center; padding: 8px;`}>
      <div
        style={`position: relative; margin: 0; box-sizing: border-box; width: 320px; max-width: 100%; height: 240px; overflow-y: auto; border-radius: 12px; border: 1px solid ${PANEL_BRD}; background: ${PANEL_BG};`}
      >
        {/* the sticky header: position:sticky + top:0 pins it to the scroll box top */}
        <h2
          style={`position: sticky; top: 0; z-index: 1; margin: 0; box-sizing: border-box; padding: 10px 16px; background: ${PANEL_BG}; border-bottom: 1px solid ${PANEL_BRD}; color: ${HEADING_INK}; font-size: 0.9rem; font-weight: 700;`}
        >
          Recent activity
        </h2>
        {/* enough rows to force a scroll, so the header has somewhere to stick */}
        <ul style="margin: 0; padding: 8px 16px 16px; list-style: none; display: flex; flex-direction: column; gap: 12px;">
          {[
            "Priya invited 3 teammates",
            "Invoice #1042 was paid",
            "New comment on the roadmap",
            "Workspace plan upgraded",
            "API key rotated",
            "Backup completed",
            "2 members joined",
            "Domain verified",
          ].map((line, i) => (
            <li style="margin: 0; display: flex; align-items: center; gap: 10px;">
              <span style={`margin: 0; flex: none; width: 26px; height: 26px; border-radius: 999px; background: ${FRAME_BG}; border: 1px solid ${PANEL_BRD};`} />
              <span style={`margin: 0; color: ${i === 0 ? HEADING_INK : MUTED_INK}; font-size: 0.8rem;`}>{line}</span>
            </li>
          ))}
        </ul>
        {/* a faint "scroll me" hint pinned to the box's own bottom-right */}
        <span
          style={`position: sticky; bottom: 6px; float: right; margin: 0 6px 6px 0; padding: 2px 8px; border-radius: 999px; background: rgba(15,23,42,0.72); color: #fff; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.02em; pointer-events: none;`}
        >
          scroll ↑
        </span>
      </div>
    </div>
  )
}

{
  /* ------------------------------ TOAST (FAKED) ------------------------------ */
  /* In your app this is `fixed bottom-4 right-4 z-50`. Here the toast is placed
     with position:absolute inside a framed, position:relative "app window", so it
     LOOKS pinned to the viewport corner without actually being fixed (which would
     pin it to the whole lesson page and break the layout). */
  pattern === "toast" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; justify-content: center; padding: 8px;`}>
      <div style={`${windowFrame} width: 360px; max-width: 100%; height: 230px;`}>
        {/* faux browser title bar */}
        <div style={`margin: 0; box-sizing: border-box; height: 34px; display: flex; align-items: center; gap: 8px; padding: 0 12px; background: ${PANEL_BG}; border-bottom: 1px solid ${PANEL_BRD};`}>
          <span style={logoDot} />
          <span style={`margin: 0; color: ${HEADING_INK}; font-weight: 700; font-size: 0.78rem;`}>Dashboard</span>
        </div>
        {/* faux page content behind the toast */}
        <div style="margin: 0; padding: 16px; display: flex; flex-direction: column; gap: 10px;">
          <div style={skeletonBar('45%', '13px')} />
          <div style={skeletonBar('100%')} />
          <div style={skeletonBar('100%')} />
          <div style={skeletonBar('70%')} />
        </div>
        {/* the toast — absolute inside the frame stands in for fixed in the app */}
        <div
          style={`position: absolute; right: 16px; bottom: 16px; margin: 0; border-radius: 10px; background: ${TOAST_BG}; color: ${TOAST_INK}; padding: 9px 16px; font-size: 0.82rem; font-weight: 600; box-shadow: 0 8px 20px rgba(15,23,42,0.28);`}
        >
          Saved
        </div>
      </div>
    </div>
  )
}

{
  /* ------------------------------ DRAWER (FAKED) ----------------------------- */
  /* In your app this is `fixed inset-y-0 right-0 w-72`. Here the panel is placed
     with position:absolute + inset-y-0 right-0 inside a framed, position:relative
     "app window", so it LOOKS like a full-height drawer pinned to the viewport's
     right edge without actually being fixed. */
  pattern === "drawer" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; justify-content: center; padding: 8px;`}>
      <div style={`${windowFrame} width: 360px; max-width: 100%; height: 230px;`}>
        {/* faux browser title bar */}
        <div style={`margin: 0; box-sizing: border-box; height: 34px; display: flex; align-items: center; gap: 8px; padding: 0 12px; background: ${PANEL_BG}; border-bottom: 1px solid ${PANEL_BRD};`}>
          <span style={logoDot} />
          <span style={`margin: 0; color: ${HEADING_INK}; font-weight: 700; font-size: 0.78rem;`}>Dashboard</span>
        </div>
        {/* dimmed page content behind the drawer */}
        <div style="margin: 0; padding: 16px; display: flex; flex-direction: column; gap: 10px;">
          <div style={skeletonBar('45%', '13px')} />
          <div style={skeletonBar('100%')} />
          <div style={skeletonBar('80%')} />
        </div>
        {/* the drawer — absolute inset-y-0 right-0 stands in for fixed in the app.
            Spans the full window height and pins to the right edge. */}
        <aside
          style={`position: absolute; top: 0; bottom: 0; right: 0; width: 168px; margin: 0; box-sizing: border-box; background: ${PANEL_BG}; border-left: 1px solid ${PANEL_BRD}; padding: 14px; display: flex; flex-direction: column; gap: 12px; box-shadow: -8px 0 20px rgba(15,23,42,0.12);`}
        >
          <span style={`margin: 0; color: ${HEADING_INK}; font-weight: 700; font-size: 0.82rem;`}>Settings</span>
          <div style={skeletonBar('100%', '10px')} />
          <div style={skeletonBar('80%', '10px')} />
          <div style={skeletonBar('90%', '10px')} />
          <div style={skeletonBar('60%', '10px')} />
        </aside>
      </div>
    </div>
  )
}

{
  /* --------------------------- FULL-COVER OVERLAY ---------------------------- */
  /* Real position:absolute + inset:0 — the overlay fills its relative parent card
     exactly. (The modal-backdrop variant is the same shape with `fixed inset-0`
     over the whole screen; here it covers just the card so the page is safe.) */
  pattern === "overlay" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; justify-content: center; padding: 14px 8px;`}>
      <div
        style={`position: relative; margin: 0; box-sizing: border-box; width: 280px; max-width: 100%; height: 170px; overflow: hidden; border-radius: 12px; border: 1px solid ${PANEL_BRD}; background: ${PANEL_BG};`}
      >
        {/* the card's own content, partly visible under the dimming layer */}
        <div style="margin: 0; padding: 16px; display: flex; flex-direction: column; gap: 10px;">
          <span style={`margin: 0; color: ${HEADING_INK}; font-weight: 700; font-size: 0.9rem;`}>Project Atlas</span>
          <div style={skeletonBar('100%')} />
          <div style={skeletonBar('85%')} />
          <div style={skeletonBar('70%')} />
        </div>
        {/* the overlay: absolute inset-0 fills the card edge-to-edge */}
        <div
          style="position: absolute; inset: 0; margin: 0; display: flex; align-items: center; justify-content: center; background: rgba(15,23,42,0.55);"
        >
          <span style="margin: 0; color: #fff; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.01em;">
            absolute inset-0
          </span>
        </div>
      </div>
    </div>
  )
}
