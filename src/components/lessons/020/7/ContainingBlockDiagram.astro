---
// "The absolute child climbs the ancestor tree" — two cases side by side, drawn
// as REAL HTML boxes (not SVG) so a student can open devtools and inspect the
// nested rectangles directly, which is the whole point of the containing-block
// lesson.
//
// Each panel is a faux "viewport" frame holding a "card". A small "child" badge
// sits at a TOP-RIGHT corner (the lesson's own `-top-2 -right-2` convention,
// which also keeps the badge clear of each box's TOP-LEFT legend pill). An
// L-shaped climb arrow runs from the card's top-right corner UP and OVER to the
// anchor:
//   - Panel A (no positioned ancestor): the card is `static`, so the arrow
//     shoots PAST the card all the way to the frame's top-right corner, where the
//     runaway badge has landed — "anchors to the viewport".
//   - Panel B (`relative` parent): the card is `relative` (accent outline), so the
//     arrow STOPS at the card's own top-right corner, where the badge correctly
//     overhangs — "anchors to the card".
//
// Fixed-width panels (sanctioned by the diagrams guide for figures that need an
// internal coordinate system for arrows); they wrap to a stack on narrow
// viewports. Conventions borrowed from this chapter's other illustrations: a
// fixed dark-slate ink that reads on every light tint, a system-ui sans stack,
// hairline edges, and color-scheme pinned light so the hard-coded tints survive
// dark mode. The accent is the lesson's own violet (the ParamPlayground target
// box uses the same family). EVERY element carries an explicit `margin` so
// Starlight's prose `margin-top` injection cannot distort the layout.

import Figure from "../../../figures/Figure.astro";

// Palette ---------------------------------------------------------------------
const INK_SOFT = "#475569"; // secondary / legend text
const FRAME_BORDER = "#94a3b8"; // muted slate — the viewport frame edge
const FRAME_FILL = "#f8fafc"; // very faint slate — viewport interior
const CARD_FILL = "#ffffff"; // the card surface
const CARD_BORDER = "#cbd5e1"; // muted card edge (the STATIC card)
const ACCENT = "#7c3aed"; // violet — the relative card + both climb arrows
const ACCENT_SOFT = "#ede9fe"; // violet tint — the child badge fill
const ACCENT_BORDER = "#c4b5fd"; // violet badge border

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// Panel coordinate system (px) ------------------------------------------------
const PW = 300; // panel width
const PH = 236; // panel height
const CARD = { left: 64, top: 122, width: 172, height: 96 };
const SIZE = 38; // child badge edge
const RAIL = 2.5; // arrow stroke width

// A panel is its own positioning context for the boxes + arrow inside it.
const panel = `position: relative; flex: 0 0 auto; width: ${PW}px; height: ${PH}px; margin: 0;`;

// The faux viewport frame fills the panel.
const frame = `position: absolute; inset: 0; border: 1.5px dashed ${FRAME_BORDER}; border-radius: 12px; background: ${FRAME_FILL}; margin: 0;`;

// A label pill that straddles a box's top border line ("fieldset legend").
function legend(color: string, bg: string, weight = 600) {
  return `display: block; width: fit-content; margin: 0; padding: 1px 7px; font-family: ${sans}; font-size: 11px; font-weight: ${weight}; line-height: 1.4; color: ${color}; background: ${bg}; border-radius: 999px;`;
}

// The "child" badge box.
const badge = `position: absolute; width: ${SIZE}px; height: ${SIZE}px; margin: 0; display: flex; align-items: center; justify-content: center; border-radius: 9px; background: ${ACCENT_SOFT}; border: 1.5px solid ${ACCENT_BORDER}; color: ${ACCENT}; font-family: ${mono}; font-size: 10px; font-weight: 700; line-height: 1;`;

// The destination anchor dot (where the offsets resolve from).
const dot = `position: absolute; width: 11px; height: 11px; margin: 0; border-radius: 999px; background: ${ACCENT}; box-shadow: 0 0 0 3px ${ACCENT}33;`;

// Arrow primitives — a vertical rail, a horizontal rail, and a right-pointing head.
const vrail = `position: absolute; width: ${RAIL}px; margin: 0; background: ${ACCENT};`;
const hrail = `position: absolute; height: ${RAIL}px; margin: 0; background: ${ACCENT};`;
const headRight = `position: absolute; width: 0; height: 0; margin: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent; border-left: 7px solid ${ACCENT};`;
const headUp = `position: absolute; width: 0; height: 0; margin: 0; border-left: 5px solid transparent; border-right: 5px solid transparent; border-bottom: 7px solid ${ACCENT};`;

// Anchor caption styling.
const note = `position: absolute; margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; color: ${ACCENT}; line-height: 1.2;`;

// Derived corners.
const CARD_TR_X = CARD.left + CARD.width; // card top-right corner x
const CARD_TR_Y = CARD.top; // card top-right corner y
// The vertical rail rides just inside the card's right edge.
const RAIL_X = CARD_TR_X - 16;
// Frame top-right inset for the runaway badge.
const FRAME_PAD = 12;
---

<Figure caption="An absolute element climbs the tree until it finds a positioned ancestor. With nothing positioned (left) the climb runs all the way out to the viewport corner; a relative parent (right) stops the climb at the card.">
  <div
    style={`display: flex; flex-wrap: wrap; gap: 24px 36px; justify-content: center; align-items: flex-start; font-family: ${sans}; color-scheme: light; margin: 0;`}
  >
    {/* ============================ PANEL A ============================ */}
    {/* No positioned ancestor → the badge runs out to the viewport corner. */}
    <div style={panel}>
      <div style={frame}></div>

      {/* viewport legend, top-left of the frame */}
      <span style={`position: absolute; left: 16px; top: -9px; ${legend(INK_SOFT, FRAME_FILL, 700)}`}>viewport</span>

      {/* the runaway badge, parked in the frame's top-right corner */}
      <div style={`${badge} right: ${FRAME_PAD}px; top: ${FRAME_PAD}px;`}>child</div>
      {/* the anchor-origin dot at the very corner */}
      <div style={`${dot} right: ${FRAME_PAD - 4}px; top: ${FRAME_PAD - 4}px;`}></div>

      {/* the card — STATIC (nothing positioned) */}
      <div style={`position: absolute; left: ${CARD.left}px; top: ${CARD.top}px; width: ${CARD.width}px; height: ${CARD.height}px; margin: 0; border-radius: 10px; background: ${CARD_FILL}; border: 1.5px solid ${CARD_BORDER};`}>
        <span style={`position: absolute; left: 12px; top: -9px; ${legend(INK_SOFT, CARD_FILL)}`}><span style="font-family: inherit; font-weight: 600;">card</span> <span style={`font-family: ${mono}; font-weight: 600;`}>static</span></span>
        {/* the empty slot the badge VACATED when it ran away */}
        <div style={`position: absolute; right: 8px; top: 8px; width: ${SIZE}px; height: ${SIZE}px; margin: 0; border-radius: 9px; border: 1.5px dashed ${CARD_BORDER}; background: transparent;`}></div>
      </div>

      {/* L-shaped climb arrow: up the card's right edge, then over to the corner */}
      {/* vertical leg: from the card's top-right up toward the frame top */}
      <div style={`${vrail} left: ${RAIL_X}px; top: ${FRAME_PAD + SIZE / 2}px; height: ${CARD_TR_Y + 6 - (FRAME_PAD + SIZE / 2)}px;`}></div>
      {/* horizontal leg: from the rail across toward the corner badge */}
      <div style={`${hrail} left: ${RAIL_X}px; top: ${FRAME_PAD + SIZE / 2 - RAIL / 2}px; width: ${PW - FRAME_PAD - SIZE - RAIL_X - 2}px;`}></div>
      {/* head: points right into the runaway badge */}
      <div style={`${headRight} right: ${FRAME_PAD + SIZE + 1}px; top: ${FRAME_PAD + SIZE / 2 - 5}px;`}></div>

      {/* anchor caption, tucked under the corner badge in the right strip (clear of the rail) */}
      <span style={`${note} right: ${FRAME_PAD}px; top: ${FRAME_PAD + SIZE + 8}px; width: 62px; text-align: right;`}>anchors to the viewport</span>
    </div>

    {/* ============================ PANEL B ============================ */}
    {/* relative parent → the badge anchors to the card's own corner. */}
    <div style={panel}>
      <div style={frame}></div>

      {/* viewport legend, top-left of the frame */}
      <span style={`position: absolute; left: 16px; top: -9px; ${legend(INK_SOFT, FRAME_FILL, 700)}`}>viewport</span>

      {/* the card — RELATIVE (accent outline = the positioned ancestor) */}
      <div style={`position: absolute; left: ${CARD.left}px; top: ${CARD.top}px; width: ${CARD.width}px; height: ${CARD.height}px; margin: 0; border-radius: 10px; background: ${CARD_FILL}; border: 2px solid ${ACCENT}; box-shadow: 0 0 0 3px ${ACCENT}1f;`}>
        <span style={`position: absolute; left: 12px; top: -9px; ${legend(ACCENT, CARD_FILL, 700)}`}><span style="font-family: inherit; font-weight: 700;">card</span> <span style={`font-family: ${mono}; font-weight: 700;`}>relative</span></span>
      </div>

      {/* the correctly-pinned badge, overhanging the card's top-right corner */}
      <div style={`${badge} left: ${CARD_TR_X - SIZE + 12}px; top: ${CARD_TR_Y - 12}px;`}>child</div>
      {/* the anchor-origin dot on the card's corner */}
      <div style={`${dot} left: ${CARD_TR_X - 5}px; top: ${CARD_TR_Y - 5}px;`}></div>

      {/* SHORT climb arrow: the search stops at the card — a stub rising from */}
      {/* inside the card to its own top edge (the positioned ancestor boundary). */}
      {/* The contrast with Panel A's long climb is the whole point. */}
      <div style={`${vrail} left: ${CARD_TR_X - 34}px; top: ${CARD_TR_Y + 8}px; height: 54px;`}></div>
      <div style={`${headUp} left: ${CARD_TR_X - 39}px; top: ${CARD_TR_Y + 2}px;`}></div>

      {/* anchor caption, in the right strip just below the badge (clear of the rail) */}
      <span style={`${note} left: ${CARD_TR_X - 10}px; top: ${CARD_TR_Y + SIZE - 8}px; width: 62px;`}>anchors to the card</span>
    </div>
  </div>
</Figure>
