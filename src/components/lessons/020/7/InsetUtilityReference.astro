---
// The inset-family lookup table: each Tailwind offset utility, the literal CSS it
// emits, and a one-line plain-language read of the effect. The student runs it in
// both directions — forward ("I wrote inset-y-0, what does that do?") and backward
// ("I want full height, which utility?") — so it's a scan-at-a-glance map, not a
// diagram. Rows climb the tiers the prose just walked: a single edge, the same
// edge negated (the badge-overhang move), the two axis pairs, then the all-four
// fill. Reading it top-to-bottom recaps the section.
//
// Deliberately the sibling of Chapter 18's UtilityToCssMap (same chapter family of
// "utility -> arrow -> CSS" reference grids), extended with a fourth column for the
// effect. Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the layout:
// four columns (utility | arrow | declaration | effect). `margin: 0` reset on every
// inner element (belt-and-braces with the `not-content` class) defeats Starlight's
// prose-margin injection. Chrome uses Starlight gray/theme CSS variables so it flips
// with light/dark; the utility column carries the chapter's faint sky "this is a
// class name" tint, and the `0` / negative fragments in the CSS column get the same
// accent so the "pinned to the edge / pulled outside" idea reads visually.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Each row: the utility class, the CSS declaration it compiles to (as ordered
// segments so the literal spacing survives — a `key` segment is the part the eye
// should catch, an accented `0` or a negative value; `plain` is literal CSS text),
// and the plain-language effect. The negated row is flagged so it can carry a
// left rule, since the prose singles out negative offsets as the badge-overhang
// move.
const rows: {
  utility: string;
  decl: { t: "plain" | "key"; v: string }[];
  effect: string;
  negated?: boolean;
}[] = [
  {
    utility: "top-4",
    decl: [{ t: "plain", v: "top: 1rem;" }],
    effect: "one edge held 1rem in from the top",
  },
  {
    utility: "-top-2",
    decl: [
      { t: "plain", v: "top: " },
      { t: "key", v: "-0.5rem" },
      { t: "plain", v: ";" },
    ],
    effect: "pulled above the containing block's top edge",
    negated: true,
  },
  {
    utility: "inset-x-0",
    decl: [
      { t: "plain", v: "left: " },
      { t: "key", v: "0" },
      { t: "plain", v: "; right: " },
      { t: "key", v: "0" },
      { t: "plain", v: ";" },
    ],
    effect: "stretched edge-to-edge across the width",
  },
  {
    utility: "inset-y-0",
    decl: [
      { t: "plain", v: "top: " },
      { t: "key", v: "0" },
      { t: "plain", v: "; bottom: " },
      { t: "key", v: "0" },
      { t: "plain", v: ";" },
    ],
    effect: "stretched top-to-bottom over the height",
  },
  {
    utility: "inset-0",
    decl: [
      { t: "plain", v: "top: " },
      { t: "key", v: "0" },
      { t: "plain", v: "; right: " },
      { t: "key", v: "0" },
      { t: "plain", v: "; bottom: " },
      { t: "key", v: "0" },
      { t: "plain", v: "; left: " },
      { t: "key", v: "0" },
      { t: "plain", v: ";" },
    ],
    effect: "all four offsets at 0 — fills the containing block",
  },
];

const grid = [
  reset,
  "display: grid",
  // utility column | arrow column (intrinsic) | declaration column | effect column
  "grid-template-columns: minmax(96px, max-content) auto minmax(0, 1.1fr) minmax(0, 1fr)",
  "align-items: stretch",
  "column-gap: 0",
  "row-gap: 6px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Column header cells (the small uppercase labels over each tile column).
const headStyle = (pad: string) =>
  [
    reset,
    sans,
    "font-size: 11px",
    "font-weight: 600",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "line-height: 1",
    "color: var(--sl-color-gray-3)",
    `padding: 0 0 4px ${pad}`,
  ].join("; ");

// Left tile: the utility class. Faint sky tint so the "class name" side is distinct
// from the declaration; a negated row carries an accent left rule so the
// badge-overhang case stands out as the prose calls it out.
const utilityCell = (negated: boolean) =>
  [
    reset,
    mono,
    "font-size: 14px",
    "font-weight: 600",
    "line-height: 1.2",
    "display: flex",
    "align-items: center",
    "padding: 8px 14px",
    "border-radius: 8px 0 0 8px",
    "background: rgba(56, 189, 248, 0.12)",
    "color: var(--sl-color-white)",
    "white-space: nowrap",
    negated
      ? "border-left: 3px solid #38bdf8"
      : "border-left: 3px solid transparent",
    "box-sizing: border-box",
  ].join("; ");

// Center arrow column.
const arrowCell = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "padding: 0 12px",
  "color: var(--sl-color-gray-3)",
  "font-size: 16px",
  "line-height: 1",
  "user-select: none",
].join("; ");

// Declaration tile: the literal CSS. A flex column (centered) but the segments
// flow inside a single inline span so the literal spaces after each colon survive
// — flex would drop the whitespace between sibling spans.
const declCell = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 400",
  "line-height: 1.3",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "padding: 8px 14px",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.04))",
  "color: var(--sl-color-gray-1)",
  "box-sizing: border-box",
  "overflow-wrap: anywhere",
].join("; ");

// The key fragment inside a declaration — the accented `0` or negative value the
// eye should catch.
const keySpan = ["color: #38bdf8", "font-weight: 600"].join("; ");

// Right tile: the plain-language effect. Sans-serif and muted so it reads as a
// gloss, not part of the code; wraps freely in the remaining width.
const effectCell = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.35",
  "display: flex",
  "align-items: center",
  "padding: 8px 14px",
  "border-radius: 0 8px 8px 0",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.04))",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");
---

<div class="not-content" style={grid}>
  {/* Header row: labels over the utility, declaration, and effect tiles; the arrow column is unlabeled */}
  <div style={headStyle("2px")}>Utility</div>
  <div style={reset}></div>
  <div style={headStyle("14px")}>CSS it emits</div>
  <div style={headStyle("14px")}>Effect</div>

  {/* One grid row per utility — four sibling cells so the row reads edge to edge */}
  {
    rows.map((r) => {
      const negated = r.negated ?? false;
      return (
        <Fragment>
          <div style={utilityCell(negated)}>{r.utility}</div>
          <div style={arrowCell} aria-hidden="true">
            &rarr;
          </div>
          <div style={declCell}>
            <span style={reset}>
              {r.decl.map((seg) =>
                seg.t === "key" ? <span style={keySpan}>{seg.v}</span> : seg.v,
              )}
            </span>
          </div>
          <div style={effectCell}>{r.effect}</div>
        </Fragment>
      );
    })
  }
</div>
