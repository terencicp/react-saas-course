---
// The two-tree model of hiding, made spatial. The browser keeps TWO trees — a
// layout tree (what gets painted and takes space) and an accessibility tree (what
// gets announced) — and an element can be present or absent in each independently.
// That independence is a 2×2, and each hiding tool lands in one cell, so the word
// "hide" stops being ambiguous once you say WHICH tree you mean.
//
// Axes:
//   columns = IN THE LAYOUT TREE?  yes (painted, takes space) / no
//   rows    = IN THE ACCESSIBILITY TREE?  yes (announced) / no
//
// The four cells, by the placeholder's colour plan:
//   layout YES × a11y YES  → "Visible & announced" — the default. Tinted green/positive.
//   layout YES × a11y NO   → `aria-hidden="true"` — on screen but silent. Tinted amber/warning.
//   layout NO  × a11y YES  → the DEGENERATE corner (visually gone yet announced is the
//                            job of sr-only, not a plain display tool). Tinted muted grey.
//   layout NO  × a11y NO   → `display: none` / `hidden` (and conditional render). Neutral grey.
//
// `visibility: hidden` breaks the clean 2×2 — it is absent from the a11y tree and
// paints nothing, yet STILL RESERVES its box in the layout tree — so it gets its own
// footnote-style strip beneath the grid, kept visually distinct from the four cells.
//
// Authored with `display: grid` (devtools-inspectable, thematically on-topic).
// Colours are hard-coded light tints, NOT @theme tokens — a deliberate
// illustration-colour divergence matching BoxModelDiagram / DisplayOuterInnerMatrix
// in this chapter — with color-scheme pinned so they read in dark mode. Every
// element carries `margin: 0` to defeat Starlight's prose-margin injection.

import Figure from "../../../figures/Figure.astro";

// Cell tints (illustration colours, not @theme tokens — see header note).
const GREEN_BG = "#dcfce7"; // emerald 100 — the positive default cell
const GREEN_RING = "#86efac"; // emerald 300
const GREEN_INK = "#166534"; // emerald 800

const AMBER_BG = "#fef3c7"; // amber 100 — aria-hidden (on screen, silent)
const AMBER_RING = "#fcd34d"; // amber 300
const AMBER_INK = "#92400e"; // amber 800

const GREY_BG = "#f1f5f9"; // slate 100 — display:none / conditional render
const GREY_RING = "#cbd5e1"; // slate 300
const GREY_INK = "#334155"; // slate 700

// The degenerate corner: more muted than the others, dashed, to read as "the odd one".
const MUTED_BG = "#f8fafc"; // slate 50
const MUTED_INK = "#94a3b8"; // slate 400

// Axis-header accents — a neutral slate so they frame without competing with the cells.
const HEAD_BG = "#e2e8f0"; // slate 200
const HEAD_INK = "#334155"; // slate 700

const INK = "#1e293b";
const INK_SOFT = "#475569";

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// Shared shells so every cell aligns.
const cellBase =
  "display: flex; flex-direction: column; gap: 4px; padding: 14px 14px; border-radius: 10px; margin: 0; text-align: center; align-items: center; justify-content: center; line-height: 1.3; min-height: 96px;";
const headBase =
  "display: flex; flex-direction: column; gap: 1px; padding: 12px 10px; border-radius: 8px; margin: 0; text-align: center; align-items: center; justify-content: center; line-height: 1.25;";
---

<Figure
  caption="Two trees, four corners. 'Hide' is ambiguous until you say which tree you mean. visibility: hidden is the odd one out — gone from sight and from screen readers, yet still holding its space."
>
  <div
    style={`color-scheme: light; font-family: ${sans}; color: ${INK}; max-width: 760px; margin: 0 auto;`}
  >
    <div
      style="display: grid; grid-template-columns: minmax(132px, 0.85fr) 1fr 1fr; gap: 10px; margin: 0;"
    >
      {/* ---------- header row: corner legend + the two layout-tree columns ---------- */}
      <div
        style={`${headBase} background: transparent; border: 1px dashed ${INK_SOFT};`}
      >
        <span style={`font-size: 0.72rem; font-weight: 700; color: ${INK_SOFT}; margin: 0;`}>{"in layout tree? →"}</span>
        <span style={`font-size: 0.72rem; font-weight: 700; color: ${INK_SOFT}; margin: 0;`}>{"in a11y tree? ↓"}</span>
      </div>

      <div style={`${headBase} background: ${HEAD_BG}; color: ${HEAD_INK};`}>
        <span style={`font-size: 0.9rem; font-weight: 800; margin: 0;`}>{"Yes"}</span>
        <span style={`font-size: 0.68rem; font-weight: 600; opacity: 0.85; margin: 0;`}>{"painted · takes space"}</span>
      </div>

      <div style={`${headBase} background: ${HEAD_BG}; color: ${HEAD_INK};`}>
        <span style={`font-size: 0.9rem; font-weight: 800; margin: 0;`}>{"No"}</span>
        <span style={`font-size: 0.68rem; font-weight: 600; opacity: 0.85; margin: 0;`}>{"no box"}</span>
      </div>

      {/* ---------- a11y = YES row ---------- */}
      <div style={`${headBase} background: ${HEAD_BG}; color: ${HEAD_INK};`}>
        <span style={`font-size: 0.9rem; font-weight: 800; margin: 0;`}>{"Yes"}</span>
        <span style={`font-size: 0.68rem; font-weight: 600; opacity: 0.85; margin: 0;`}>{"announced"}</span>
      </div>

      {/* layout YES × a11y YES — the positive default */}
      <div style={`${cellBase} background: ${GREEN_BG}; box-shadow: inset 0 0 0 1px ${GREEN_RING};`}>
        <span style={`font-size: 0.95rem; font-weight: 800; color: ${GREEN_INK}; margin: 0;`}>{"Visible & announced"}</span>
        <span style={`font-size: 0.74rem; font-weight: 500; color: ${INK_SOFT}; margin: 0;`}>{"the default — a normal element"}</span>
      </div>

      {/* layout NO × a11y YES — the degenerate corner */}
      <div style={`${cellBase} background: ${MUTED_BG}; box-shadow: inset 0 0 0 1px ${GREY_RING}; border: 1px dashed ${MUTED_INK};`}>
        <span style={`font-size: 0.82rem; font-weight: 700; color: ${MUTED_INK}; margin: 0;`}>{"(rarely useful alone)"}</span>
        <span style={`font-size: 0.74rem; font-weight: 500; color: ${MUTED_INK}; margin: 0;`}>{"visually gone yet still announced is the job of "}<code style={`font-family: ${mono}; font-size: 0.78rem; color: ${MUTED_INK};`}>{"sr-only"}</code></span>
      </div>

      {/* ---------- a11y = NO row ---------- */}
      <div style={`${headBase} background: ${HEAD_BG}; color: ${HEAD_INK};`}>
        <span style={`font-size: 0.9rem; font-weight: 800; margin: 0;`}>{"No"}</span>
        <span style={`font-size: 0.68rem; font-weight: 600; opacity: 0.85; margin: 0;`}>{"silent"}</span>
      </div>

      {/* layout YES × a11y NO — aria-hidden */}
      <div style={`${cellBase} background: ${AMBER_BG}; box-shadow: inset 0 0 0 1px ${AMBER_RING};`}>
        <code style={`font-family: ${mono}; font-size: 0.92rem; font-weight: 700; color: ${AMBER_INK}; margin: 0;`}>{'aria-hidden="true"'}</code>
        <span style={`font-size: 0.74rem; font-weight: 500; color: ${INK_SOFT}; margin: 0;`}>{"on screen, takes space, silent to screen readers — e.g. a decorative icon"}</span>
      </div>

      {/* layout NO × a11y NO — display:none / conditional render */}
      <div style={`${cellBase} background: ${GREY_BG}; box-shadow: inset 0 0 0 1px ${GREY_RING};`}>
        <span style={`margin: 0;`}>
          <code style={`font-family: ${mono}; font-size: 0.92rem; font-weight: 700; color: ${GREY_INK};`}>{"display: none"}</code>
          <span style={`font-size: 0.82rem; font-weight: 600; color: ${INK_SOFT};`}>{" / "}</span>
          <code style={`font-family: ${mono}; font-size: 0.92rem; font-weight: 700; color: ${GREY_INK};`}>{"hidden"}</code>
        </span>
        <span style={`font-size: 0.74rem; font-weight: 500; color: ${INK_SOFT}; margin: 0;`}>{"no box, no space, not announced — also what conditional render produces"}</span>
      </div>
    </div>

    {/* ---------- the special case that breaks the grid ---------- */}
    <div
      style={`display: flex; align-items: flex-start; gap: 12px; margin: 14px 0 0; padding: 12px 16px; border-radius: 10px; background: transparent; border: 1px dashed ${INK_SOFT};`}
    >
      <code
        style={`flex: none; font-family: ${mono}; font-size: 0.88rem; font-weight: 700; color: ${INK}; background: ${HEAD_BG}; padding: 4px 8px; border-radius: 6px; margin: 0; line-height: 1.5;`}
      >{"visibility: hidden"}</code>
      <span style={`font-size: 0.82rem; font-weight: 500; color: ${INK_SOFT}; margin: 0; line-height: 1.5;`}
        ><strong style={`color: ${INK};`}>{"The odd one out — it doesn't fit the grid."}</strong>{" Absent from the accessibility tree and paints nothing, but "}<strong style={`color: ${INK};`}>{"still reserves its box"}</strong>{" in the layout tree. So it's gone from sight and from screen readers, yet still holding its space."}</span>
    </div>
  </div>
</Figure>
