---
// The six core `display` keywords laid out as one 2-axis grid, so the student
// stops memorising eight magic words and starts reading them as a cross-product.
//
// Axes:
//   rows    = OUTER role (toward siblings): block-level vs inline-level
//   columns = INNER formatting context (for children): flow / flex / grid
//
// Each of the six body cells holds the single Tailwind/CSS keyword that produces
// that outer × inner combination, shown in monospace. The two outer-role rows are
// tinted differently — a cool blue for block-level, a warm amber for inline-level —
// so the eye groups them; the keyword text stays a neutral readable ink. The
// `inline-flex` cell is given a stronger ring because the caption calls it out as
// the canonical "why does this exist" corner.
//
// The matrix is itself authored with `display: grid` (devtools-inspectable, and
// thematically on-topic for a display lesson). Colours are hard-coded light tints,
// NOT routed through @theme tokens — a deliberate illustration-colour divergence
// matching BoxModelDiagram in lesson 1 — with color-scheme pinned so they read in
// dark mode. Every element carries `margin: 0` to defeat Starlight's prose-margin
// injection into grid children.

import Figure from "../../../figures/Figure.astro";

// Outer-role accents (illustration tints, not @theme tokens — see header note).
const BLOCK_HEADER = "#bfdbfe"; // cool blue 200 — block-level row header
const BLOCK_ROW = "#eff6ff"; // very light blue — block-level body cells
const BLOCK_INK = "#1e40af"; // blue 800 — block-level header text

const INLINE_HEADER = "#fde68a"; // warm amber 200 — inline-level row header
const INLINE_ROW = "#fffbeb"; // very light amber — inline-level body cells
const INLINE_INK = "#92400e"; // amber 800 — inline-level header text

// Inner-axis accent (the column headers) — a neutral slate so it doesn't compete
// with the two outer-role colours, which are the ones the eye should group on.
const INNER_HEADER = "#e2e8f0"; // slate 200
const INNER_INK = "#334155"; // slate 700

// Neutral readable ink for the keyword cells and the axis legend.
const INK = "#1e293b";
const INK_SOFT = "#475569"; // sub-labels

// The highlighted corner (inline-flex) gets a stronger ring.
const RING = "#f59e0b"; // amber 500

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// A shared cell shell so every body cell aligns; `highlight` thickens the ring on
// the inline-flex corner.
const cellBase = `display: flex; align-items: center; justify-content: center; padding: 14px 12px; border-radius: 8px; margin: 0;`;
---

<Figure
  caption="Every display value is a point on this grid: an outer role (toward siblings) crossed with an inner formatting context (for children). 'inline-flex' is just the inline-outer, flex-inner corner."
>
  <div
    style={`color-scheme: light; font-family: ${sans}; color: ${INK}; max-width: 720px; margin: 0 auto;`}
  >
    <div
      style="display: grid; grid-template-columns: minmax(118px, 0.9fr) repeat(3, 1fr); gap: 8px; margin: 0;"
    >
      {/* ---------- header row: axis legend + the three inner-context columns ---------- */}
      <div
        style={`${cellBase} flex-direction: column; gap: 2px; background: transparent; border: 1px dashed ${INK_SOFT}; text-align: center; line-height: 1.25;`}
      >
        <span style={`font-size: 0.72rem; font-weight: 700; color: ${INK_SOFT}; margin: 0;`}>{"inner →"}</span>
        <span style={`font-size: 0.72rem; font-weight: 700; color: ${INK_SOFT}; margin: 0;`}>{"outer ↓"}</span>
      </div>

      <div style={`${cellBase} flex-direction: column; gap: 1px; background: ${INNER_HEADER}; color: ${INNER_INK};`}>
        <span style={`font-family: ${mono}; font-size: 0.95rem; font-weight: 700; margin: 0;`}>{"flow"}</span>
        <span style={`font-size: 0.68rem; font-weight: 600; opacity: 0.8; margin: 0;`}>{"(normal)"}</span>
      </div>

      <div style={`${cellBase} background: ${INNER_HEADER}; color: ${INNER_INK};`}>
        <span style={`font-family: ${mono}; font-size: 0.95rem; font-weight: 700; margin: 0;`}>{"flex"}</span>
      </div>

      <div style={`${cellBase} background: ${INNER_HEADER}; color: ${INNER_INK};`}>
        <span style={`font-family: ${mono}; font-size: 0.95rem; font-weight: 700; margin: 0;`}>{"grid"}</span>
      </div>

      {/* ---------- block-level row ---------- */}
      <div
        style={`${cellBase} flex-direction: column; gap: 2px; background: ${BLOCK_HEADER}; color: ${BLOCK_INK}; text-align: center; line-height: 1.25;`}
      >
        <span style={`font-size: 0.9rem; font-weight: 800; margin: 0;`}>{"block-level"}</span>
        <span style={`font-size: 0.68rem; font-weight: 600; opacity: 0.85; margin: 0;`}>{"own line"}</span>
      </div>

      <div style={`${cellBase} background: ${BLOCK_ROW};`}>
        <span style={`font-family: ${mono}; font-size: 1rem; font-weight: 700; color: ${INK}; margin: 0;`}>{"block"}</span>
      </div>

      <div style={`${cellBase} background: ${BLOCK_ROW};`}>
        <span style={`font-family: ${mono}; font-size: 1rem; font-weight: 700; color: ${INK}; margin: 0;`}>{"flex"}</span>
      </div>

      <div style={`${cellBase} background: ${BLOCK_ROW};`}>
        <span style={`font-family: ${mono}; font-size: 1rem; font-weight: 700; color: ${INK}; margin: 0;`}>{"grid"}</span>
      </div>

      {/* ---------- inline-level row ---------- */}
      <div
        style={`${cellBase} flex-direction: column; gap: 2px; background: ${INLINE_HEADER}; color: ${INLINE_INK}; text-align: center; line-height: 1.25;`}
      >
        <span style={`font-size: 0.9rem; font-weight: 800; margin: 0;`}>{"inline-level"}</span>
        <span style={`font-size: 0.68rem; font-weight: 600; opacity: 0.85; margin: 0;`}>{"flows in text"}</span>
      </div>

      <div style={`${cellBase} background: ${INLINE_ROW};`}>
        <span style={`font-family: ${mono}; font-size: 1rem; font-weight: 700; color: ${INK}; margin: 0;`}>{"inline"}</span>
      </div>

      {/* the called-out corner: inline outer + flex inner */}
      <div style={`${cellBase} background: ${INLINE_ROW}; box-shadow: 0 0 0 2px ${RING}; position: relative;`}>
        <span style={`font-family: ${mono}; font-size: 1rem; font-weight: 700; color: ${INK}; margin: 0;`}>{"inline-flex"}</span>
      </div>

      <div style={`${cellBase} background: ${INLINE_ROW};`}>
        <span style={`font-family: ${mono}; font-size: 1rem; font-weight: 700; color: ${INK}; margin: 0;`}>{"inline-grid"}</span>
      </div>
    </div>
  </div>
</Figure>
