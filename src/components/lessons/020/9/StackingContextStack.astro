---
// The "nested stacking context" build for Chapter 020 L9
// (diagram id: stacking-context-build).
//
// Goal: make the SCOPE rule visible. Four discrete frames the student scrubs
// through in a <DiagramSequence>, all sharing the SAME overlapping-box scene so
// the eye locks onto the one thing that changes — which box paints on top.
//   1 — three sibling boxes in the root context (z-10 / z-20 / z-30); z-30 wins.
//   2 — same three boxes, two z-values swapped; the order follows the numbers.
//   3 — the middle box is now wrapped in a dashed "context-creating parent"
//       envelope and carries a giant z-[999]; it still reads as on top.
//   4 — the reveal: a root sibling at z-40 paints OVER the whole envelope,
//       trapped z-[999] child and all. The small number beats the big one.
//
// FRAMED illustration, NOT project code — the boxes are absolutely positioned
// inside a relative stage and stack via REAL `z-index`, so the paint order the
// student sees is the genuine browser behaviour the lesson teaches (and is
// devtools-inspectable). Colours are hard-coded illustration tints with
// `color-scheme: light` pinned — the sanctioned divergence from the OKLCH
// @theme tokens for figures, matching PositionLayouts / FlexLayout / GridLayout
// / StickySidebarScroll in this chapter. `margin: 0` on every element defeats
// Starlight's prose-margin injection.

interface Props {
  // Which frame of the build to render (1–4). See the header for what each shows.
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace";

// Illustration palette — same blue/slate family as the chapter's other figures,
// with one distinct hue per box so each keeps its identity across frames.
const PANEL_BG = "#ffffff"; // the framed stage surface
const PANEL_BRD = "#e2e8f0"; // slate 200 — stage hairline
const HEADING_INK = "#0f172a"; // slate 900 — strong text
const MUTED_INK = "#64748b"; // slate 500 — labels on the envelope

// The three travelling boxes. `back`/`mid`/`front` name their *role in step 1*,
// kept as stable identities even as their z-values change.
const BACK = { bg: "#ecfdf5", brd: "#34d399", ink: "#065f46" }; // emerald
const MID = { bg: "#eff6ff", brd: "#3b82f6", ink: "#1e3a8a" }; // blue
const SIB = { bg: "#fffbeb", brd: "#f59e0b", ink: "#92400e" }; // amber (root sibling / front)

// The "context-creating parent" envelope (steps 3–4) — faint slate, dashed.
const ENV_BG = "#f8fafc"; // slate 50
const ENV_BRD = "#94a3b8"; // slate 400 — dashed outline
const ENV_INK = "#475569"; // slate 600 — envelope label

// ---- stage geometry ---------------------------------------------------------
const STAGE_W = 440;
const STAGE_H = 260;
const BOX_W = 150;
const BOX_H = 96;

// Per-step model. Each box gets a screen position (kept stable so the scene
// reads as ONE scene) plus the z-index it carries this frame. `top` is the
// box's place in the stacking comparison that actually matters this frame —
// driving a small "on top" flag we render as a corner ribbon on the winner.
type Box = {
  label: string; // role label
  z: string; // z-index shown on the chip
  zIndex: number; // the real z-index applied (drives paint order)
  left: number;
  top: number;
  tint: { bg: string; brd: string; ink: string };
};

// Stable screen anchors for the three boxes (diagonal overlap) in steps 1–2.
// The horizontal step (≈114px) exceeds a z-chip's width, so each box's top-left
// chip stays clear of the box cascading in front of it — every z-value stays
// readable regardless of which box is on top.
const BACK_POS = { left: 18, top: 20 };
const MID_POS = { left: 132, top: 78 };
const SIB_POS = { left: 246, top: 136 };
// In steps 3–4 the sibling moves from "beside" the envelope (clear, no overlap →
// the trapped child still reads on top) to "over" it (covering the child). Same
// box, two positions — the reveal is it sliding across.
const SIB_BESIDE = { left: 288, top: 150 };
const SIB_OVER = { left: 180, top: 120 };

let boxes: Box[] = [];
// Whether the middle box is wrapped in the envelope this frame.
const wrapped = step >= 3;
// Which role currently paints on top of everything (for the ribbon).
let winner: "back" | "mid" | "sib" = "mid";

if (step === 1) {
  boxes = [
    { label: "box A", z: "z-10", zIndex: 10, ...BACK_POS, tint: BACK },
    { label: "box B", z: "z-20", zIndex: 20, ...MID_POS, tint: MID },
    { label: "box C", z: "z-30", zIndex: 30, ...SIB_POS, tint: SIB },
  ];
  winner = "sib"; // box C (z-30) wins
} else if (step === 2) {
  // Swap A and C: the front-most box C drops to z-10, the back box A rises to z-30.
  boxes = [
    { label: "box A", z: "z-30", zIndex: 30, ...BACK_POS, tint: BACK },
    { label: "box B", z: "z-20", zIndex: 20, ...MID_POS, tint: MID },
    { label: "box C", z: "z-10", zIndex: 10, ...SIB_POS, tint: SIB },
  ];
  winner = "back"; // box A (z-30) now wins
} else {
  // Steps 3 & 4 share one physical model — the truthful one. The scene narrows
  // to the two actors that matter: the context-creating parent (envelope) with
  // its trapped child, and ONE root sibling at z-40. The blue box B from steps
  // 1–2 *becomes* the child; the amber box becomes the sibling, so identities
  // carry over. The envelope ALWAYS creates a context (isolation:
  // isolate, below), so the child's z-[999] is genuinely scoped inside it in both
  // frames. The only thing that changes is the sibling's POSITION: in step 3 it
  // "sits beside" the parent (no overlap → nothing covers the child), in step 4
  // it slides over to overlap the envelope and — being z-40 vs the envelope's
  // auto(~0) — paints over it, child and all. Real CSS stacking; no faked order.
  boxes = [
    {
      label: "sibling",
      z: "z-40",
      zIndex: 40,
      ...(step === 3 ? SIB_BESIDE : SIB_OVER),
      tint: SIB,
    },
  ];
  // The child is rendered separately, INSIDE the envelope (see template).
  winner = step === 3 ? "mid" : "sib";
}

// The "child" box, rendered inside the envelope in steps 3–4. Its z-[999] is
// scoped to the envelope's context, so the value is real but caged.
const childBox =
  step >= 3
    ? { label: "child", z: "z-[999]", zIndex: 999, left: 0, top: 0, tint: MID }
    : null;

// The context-creating parent envelope. It uses `isolation: isolate` — a real
// stacking context with NO visual side effect and z-index left at `auto` (≈ 0),
// exactly the "deliberate, side-effect-free trigger" the lesson teaches. So in
// the root it sits at ~0; the sibling's z-40 beats it in step 4.
const ENV_PAD = 16;
const ENV_LABEL_H = 20;
const envLeft = MID_POS.left - ENV_PAD;
const envTop = MID_POS.top - ENV_PAD - ENV_LABEL_H;
const envW = BOX_W + ENV_PAD * 2;
const envH = BOX_H + ENV_PAD * 2 + ENV_LABEL_H;

// ---- shared element styles --------------------------------------------------
const stageStyle = [
  "position: relative",
  "margin: 0",
  "color-scheme: light",
  `font-family: ${sans}`,
  "box-sizing: border-box",
  "width: 100%",
  `max-width: ${STAGE_W}px`,
  `height: ${STAGE_H}px`,
  "border-radius: 14px",
  `border: 1px solid ${PANEL_BRD}`,
  `background: ${PANEL_BG}`,
  "background-image: radial-gradient(circle, #eef2f7 1px, transparent 1px)",
  "background-size: 16px 16px",
  "box-shadow: 0 1px 2px rgba(15,23,42,0.06)",
  "overflow: hidden",
].join("; ");

const rootTagStyle = [
  "position: absolute",
  "top: 8px",
  "left: 10px",
  "margin: 0",
  `color: ${MUTED_INK}`,
  `font-family: ${mono}`,
  "font-size: 0.66rem",
  "font-weight: 600",
  "letter-spacing: 0.02em",
].join("; ");

const boxStyle = (b: Box) =>
  [
    "position: absolute",
    "margin: 0",
    "box-sizing: border-box",
    `left: ${b.left}px`,
    `top: ${b.top}px`,
    `width: ${BOX_W}px`,
    `height: ${BOX_H}px`,
    `z-index: ${b.zIndex}`,
    "border-radius: 10px",
    `border: 1.5px solid ${b.tint.brd}`,
    `background: ${b.tint.bg}`,
    "box-shadow: 0 6px 16px -6px rgba(15,23,42,0.28)",
    "display: flex",
    "flex-direction: column",
    "gap: 6px",
    "padding: 12px",
  ].join("; ");

const boxLabelStyle = (b: Box) =>
  `margin: 0; color: ${b.tint.ink}; font-weight: 700; font-size: 0.82rem;`;

const zChipStyle = (b: Box) =>
  [
    "margin: 0",
    "align-self: flex-start",
    `color: ${b.tint.ink}`,
    `background: ${b.tint.bg}`,
    `border: 1px solid ${b.tint.brd}`,
    "border-radius: 6px",
    "padding: 1px 7px",
    `font-family: ${mono}`,
    "font-size: 0.74rem",
    "font-weight: 700",
  ].join("; ");

const ribbonStyle = (b: Box) =>
  [
    "position: absolute",
    "top: -9px",
    "right: -8px",
    "margin: 0",
    "color: #ffffff",
    `background: ${b.tint.brd}`,
    "border-radius: 999px",
    "padding: 2px 8px",
    "font-size: 0.62rem",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "text-transform: uppercase",
    "box-shadow: 0 1px 3px rgba(15,23,42,0.3)",
    "white-space: nowrap",
  ].join("; ");

const envelopeStyle = [
  "position: absolute",
  "margin: 0",
  "box-sizing: border-box",
  `left: ${envLeft}px`,
  `top: ${envTop}px`,
  `width: ${envW}px`,
  `height: ${envH}px`,
  // isolation: isolate creates a real stacking context with NO visual effect and
  // z-index left at auto (≈ 0). This is what cages the child's z-[999] AND what
  // the sibling's z-40 beats in step 4 — genuine browser behaviour.
  "isolation: isolate",
  "border-radius: 12px",
  `border: 1.5px dashed ${ENV_BRD}`,
  `background: ${ENV_BG}`,
  "box-shadow: 0 8px 20px -8px rgba(15,23,42,0.22)",
].join("; ");

const envLabelStyle = [
  "position: absolute",
  "top: 6px",
  "left: 12px",
  "margin: 0",
  `color: ${ENV_INK}`,
  "font-size: 0.64rem",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "display: flex",
  "align-items: center",
  "gap: 5px",
].join("; ");

const envZChipStyle = [
  "margin: 0",
  `color: ${ENV_INK}`,
  "background: #ffffff",
  `border: 1px dashed ${ENV_BRD}`,
  "border-radius: 5px",
  "padding: 0 5px",
  `font-family: ${mono}`,
  "font-size: 0.62rem",
  "font-weight: 700",
  "text-transform: none",
  "letter-spacing: 0",
].join("; ");

// The child sits INSIDE the envelope, so its on-screen position is relative to
// the envelope's padded content box rather than the stage. Its z-[999] is real
// but scoped to the envelope's isolated context.
const childInEnvStyle = (b: Box) =>
  [
    "position: absolute",
    "margin: 0",
    "box-sizing: border-box",
    `left: ${ENV_PAD}px`,
    `top: ${ENV_PAD + ENV_LABEL_H}px`,
    `width: ${BOX_W}px`,
    `height: ${BOX_H}px`,
    `z-index: ${b.zIndex}`,
    "border-radius: 10px",
    `border: 1.5px solid ${b.tint.brd}`,
    `background: ${b.tint.bg}`,
    "box-shadow: 0 6px 16px -6px rgba(15,23,42,0.28)",
    "display: flex",
    "flex-direction: column",
    "gap: 6px",
    "padding: 12px",
  ].join("; ");
---

<div class="not-content" style="margin: 0; display: flex; justify-content: center; padding: 6px 4px;">
  <div style={stageStyle}>
    <span style={rootTagStyle}>{"<html>"} — root context</span>

    {/* Stage-level boxes — siblings in the root context. In steps 3–4 these are
        box A (quiet, z-10) and the root sibling (z-40); the child lives in the
        envelope below. */}
    {
      boxes.map((b) => (
        <div style={boxStyle(b)}>
          <span style={zChipStyle(b)}>{b.z}</span>
          <span style={boxLabelStyle(b)}>{b.label}</span>
          {((winner === "back" && b.label === "box A") ||
            (winner === "sib" && (b.label === "box C" || b.label === "sibling"))) && (
            <span style={ribbonStyle(b)}>on top</span>
          )}
        </div>
      ))
    }

    {/* Steps 3–4: the context-creating parent envelope with the trapped child. */}
    {
      wrapped && childBox && (
        <div style={envelopeStyle}>
          <span style={envLabelStyle}>
            context-creating parent
            <span style={envZChipStyle}>z: auto ≈ 0</span>
          </span>
          <div style={childInEnvStyle(childBox)}>
            <span style={zChipStyle(childBox)}>{childBox.z}</span>
            <span style={boxLabelStyle(childBox)}>{childBox.label}</span>
            {winner === "mid" && <span style={ribbonStyle(childBox)}>on top</span>}
          </div>
        </div>
      )
    }
  </div>
</div>
