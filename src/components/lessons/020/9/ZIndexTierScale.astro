---
// Diagram: a team-readable z-index tier scale (diagram id: zindex-tiers).
//
// Reference material, not an illustration — it lives inline in prose at the end
// of the lesson, so unlike the chapter's framed figures it is THEME-AWARE
// (Starlight CSS vars, adapts to dark mode) rather than pinned to a light
// palette. Modeled on lesson 009/3's TemporalTypesTable: a CSS-grid "table"
// with per-row accents (left rail + tinted background + dot) and a stacked
// card layout on narrow viewports.
//
// Three columns: Tier | Use for | Example. Four tier BANDS, mapped to
// Tailwind's default z utilities. The accent hue climbs from cool (content,
// low) through to warm (rare escapes, high) so the eye reads the rows as a
// rising scale, not an arbitrary list — the whole point of the section is that
// a z-index should tell you what KIND of thing an element is.
//
// The `z-*` values render as monospace chips. The surrounding prose already
// narrates the scale (the z-50-is-the-toast payoff, the portaling reframe), so
// no caption / outer <Figure> here — the table is pure reference.

// Accent per band, ascending the scale's "altitude": slate → blue → violet → amber.
const CONTENT_ACCENT = '#0ea5e9'; // sky-500   — content-level layering (lowest)
const CHROME_ACCENT = '#6366f1'; // indigo-500 — page chrome
const OVERLAY_ACCENT = '#a855f7'; // violet-500 — overlays
const ESCAPE_ACCENT = '#f59e0b'; // amber-500  — rare escapes (highest)

type Accent = 'content' | 'chrome' | 'overlay' | 'escape';

type Row = {
	tiers: string[]; // z-* utilities shown as chips, low → high within the band
	use: string; // the "Use for" column
	example: string; // a concrete "Example" element
	accent: Accent;
};

const rows: Row[] = [
	{
		tiers: ['z-0', 'z-10', 'z-20'],
		use: 'Content-level layering',
		example: 'A raised card; a sticky table cell over body rows.',
		accent: 'content',
	},
	{
		tiers: ['z-30', 'z-40'],
		use: 'Page chrome',
		example: 'Sticky header, sidebar.',
		accent: 'chrome',
	},
	{
		tiers: ['z-50'],
		use: 'Overlays',
		example: 'Modals, drawers, dialogs, the dim backdrop.',
		accent: 'overlay',
	},
	{
		tiers: ['z-[100]', 'and up'],
		use: 'Rare escapes',
		example:
			'Only non-portaled toasts / tooltips — and the right move is usually to portal them instead.',
		accent: 'escape',
	},
];
---

<div class="zts-root not-content">
	<div class="zts-row zts-header">
		<div class="zts-cell zts-head-cell">Tier</div>
		<div class="zts-cell zts-head-cell">Use for</div>
		<div class="zts-cell zts-head-cell">Example</div>
	</div>

	{
		rows.map((r) => (
			<div class={`zts-row zts-accent-${r.accent}`}>
				<div class="zts-cell zts-tier" data-label="Tier">
					<span class="zts-dot" aria-hidden="true" />
					<span class="zts-chips">
						{r.tiers.map((t) =>
							t === 'and up' ? (
								<span class="zts-and">and up</span>
							) : (
								<code class="zts-chip">{t}</code>
							),
						)}
					</span>
				</div>
				<div class="zts-cell zts-use" data-label="Use for">
					{r.use}
				</div>
				<div class="zts-cell zts-example" data-label="Example">
					{r.example}
				</div>
			</div>
		))
	}
</div>

<style
	define:vars={{
		CONTENT_ACCENT,
		CHROME_ACCENT,
		OVERLAY_ACCENT,
		ESCAPE_ACCENT,
	}}
>
	.zts-root {
		display: grid;
		grid-template-columns: max-content minmax(0, 0.9fr) minmax(0, 1.5fr);
		row-gap: 1px;
		column-gap: 0;
		padding: 0;
		margin: 1.25rem 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		border-radius: 10px;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}

	.zts-row {
		display: contents;
	}

	.zts-cell {
		padding: 11px 16px;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.zts-head-cell {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		padding-top: 9px;
		padding-bottom: 9px;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.zts-tier {
		flex-direction: row;
		align-items: center;
		gap: 11px;
	}

	.zts-dot {
		display: inline-block;
		flex-shrink: 0;
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: currentColor;
		margin: 0;
	}

	.zts-chips {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 5px;
		margin: 0;
	}

	/* Code chips — theme-aware, override Starlight's default inline-code styling. */
	.zts-chip {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		font-weight: 600;
		white-space: nowrap;
		color: var(--sl-color-white);
		background: color-mix(in srgb, currentColor 9%, transparent);
		border: 1px solid color-mix(in srgb, currentColor 22%, transparent);
		border-radius: 6px;
		padding: 1px 7px;
		margin: 0;
	}

	.zts-and {
		font-size: 11.5px;
		font-style: italic;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* Per-band accent: dot color + tinted row + a left rail on the first cell.
	   The rail thickens as the scale climbs, so the bands read as a stack. */
	.zts-accent-content .zts-dot {
		color: var(--CONTENT_ACCENT);
	}
	.zts-accent-chrome .zts-dot {
		color: var(--CHROME_ACCENT);
	}
	.zts-accent-overlay .zts-dot {
		color: var(--OVERLAY_ACCENT);
	}
	.zts-accent-escape .zts-dot {
		color: var(--ESCAPE_ACCENT);
	}

	.zts-accent-content .zts-cell {
		background: color-mix(in srgb, var(--CONTENT_ACCENT) 7%, transparent);
	}
	.zts-accent-chrome .zts-cell {
		background: color-mix(in srgb, var(--CHROME_ACCENT) 7%, transparent);
	}
	.zts-accent-overlay .zts-cell {
		background: color-mix(in srgb, var(--OVERLAY_ACCENT) 8%, transparent);
	}
	.zts-accent-escape .zts-cell {
		background: color-mix(in srgb, var(--ESCAPE_ACCENT) 8%, transparent);
	}

	.zts-accent-content .zts-tier {
		border-left: 3px solid color-mix(in srgb, var(--CONTENT_ACCENT) 60%, transparent);
	}
	.zts-accent-chrome .zts-tier {
		border-left: 4px solid color-mix(in srgb, var(--CHROME_ACCENT) 65%, transparent);
	}
	.zts-accent-overlay .zts-tier {
		border-left: 5px solid color-mix(in srgb, var(--OVERLAY_ACCENT) 70%, transparent);
	}
	.zts-accent-escape .zts-tier {
		border-left: 6px solid color-mix(in srgb, var(--ESCAPE_ACCENT) 75%, transparent);
	}

	/* Narrow viewport: collapse to a stacked card layout, one card per band. */
	@media (max-width: 640px) {
		.zts-root {
			grid-template-columns: 1fr;
			row-gap: 10px;
			border: none;
			overflow: visible;
		}

		.zts-row.zts-header {
			display: none;
		}

		.zts-row {
			display: block;
			padding: 11px 13px;
			border-radius: 9px;
			margin: 0;
		}

		.zts-accent-content {
			background: color-mix(in srgb, var(--CONTENT_ACCENT) 7%, transparent);
			border-left: 3px solid color-mix(in srgb, var(--CONTENT_ACCENT) 60%, transparent);
		}
		.zts-accent-chrome {
			background: color-mix(in srgb, var(--CHROME_ACCENT) 7%, transparent);
			border-left: 4px solid color-mix(in srgb, var(--CHROME_ACCENT) 65%, transparent);
		}
		.zts-accent-overlay {
			background: color-mix(in srgb, var(--OVERLAY_ACCENT) 8%, transparent);
			border-left: 5px solid color-mix(in srgb, var(--OVERLAY_ACCENT) 70%, transparent);
		}
		.zts-accent-escape {
			background: color-mix(in srgb, var(--ESCAPE_ACCENT) 8%, transparent);
			border-left: 6px solid color-mix(in srgb, var(--ESCAPE_ACCENT) 75%, transparent);
		}

		.zts-cell {
			background: transparent !important;
			border-left: none !important;
			padding: 4px 0;
			flex-direction: row;
			align-items: baseline;
			gap: 8px;
		}

		.zts-cell::before {
			content: attr(data-label);
			font-size: 10.5px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--sl-color-gray-3);
			flex-shrink: 0;
			min-width: 64px;
			padding-top: 2px;
		}

		.zts-tier {
			padding-top: 0;
			align-items: flex-start;
		}

		.zts-tier .zts-dot {
			display: none;
		}
	}
</style>
