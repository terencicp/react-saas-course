---
// The preview scene for the "opacity-traps-zindex" ParamPlayground (Chapter 020
// L9). It is dropped inside <Preview> and reads the slider value as
// `var(--parentOpacity)` (set on the .pp-preview-wrap ancestor by the
// ParamPlayground script, with the "%" suffix baked in — e.g. `95%`).
//
// THE WHOLE POINT IS REAL CSS. Nothing here fakes the paint order:
//   - parent and sibling are real siblings in the same stacking context,
//   - the child is a real `position: relative; z-index: 50` inside the parent,
//   - the sibling is a real `position: relative; z-index: 40`.
// At `opacity: 100%` the parent creates NO stacking context, so the child's
// z-50 competes directly against the sibling's z-40 in the shared context and
// genuinely paints on top. The instant the slider drops to 99%, `opacity < 1`
// makes the parent a stacking context: the child's z-50 is now scoped inside
// the parent's envelope, the parent itself sits at `auto` (~0) in the shared
// context, and the sibling's z-40 paints over the whole parent — child and all.
// The browser does this, not us. That is the lesson, made tactile.
//
// FRAMED illustration, NOT project code — hard-coded illustration tints with
// `color-scheme: light` pinned, matching StackingContextStack / PositionLayouts
// / FlexLayout in this chapter (the sanctioned divergence from @theme tokens for
// figures). `margin: 0` everywhere defeats Starlight's prose-margin injection.

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace";

// Stage chrome — same slate family / dotted surface as StackingContextStack so
// the two figures in this lesson read as one visual set.
const PANEL_BG = "#ffffff";
const PANEL_BRD = "#e2e8f0"; // slate 200
const MUTED_INK = "#64748b"; // slate 500 — the <html> root-context tag

// The three actors. Parent = faint slate (the innocent-looking wrapper); child
// = blue; sibling = amber. Distinct hues so each keeps its identity as the
// stack flips.
const PARENT_BG = "#f1f5f9"; // slate 100 — the faint wrapper a designer would fade
const PARENT_BRD = "#94a3b8"; // slate 400
const PARENT_INK = "#475569"; // slate 600

const CHILD = { bg: "#dbeafe", brd: "#3b82f6", ink: "#1e3a8a" }; // blue — z-50
const SIB = { bg: "#fef3c7", brd: "#f59e0b", ink: "#92400e" }; // amber — z-40

// ---- stage geometry ---------------------------------------------------------
const STAGE_W = 460;
const STAGE_H = 250;

// The parent wrapper box (slate). Its child (blue) is pinned near the parent's
// bottom-left; the amber sibling lives OUTSIDE the parent and covers the child's
// right half — a deliberately generous (~56px) overlap so the flip in paint
// order is unmistakable. The child's z-chip/label sit at its top-left, left of
// the sibling's edge, so they stay legible even when the sibling paints over.
const PARENT = { left: 28, top: 50, w: 200, h: 152 };
const CHILD_BOX = { left: 22, top: 58, w: 152, h: 78 }; // relative to the parent box → stage 50..202
const SIB_BOX = { left: 146, top: 98, w: 180, h: 98 }; // relative to the stage  → 146..326

const stageStyle = [
  "position: relative",
  "margin: 0",
  "color-scheme: light",
  `font-family: ${sans}`,
  "box-sizing: border-box",
  "width: 100%",
  `max-width: ${STAGE_W}px`,
  `height: ${STAGE_H}px`,
  "border-radius: 14px",
  `border: 1px solid ${PANEL_BRD}`,
  `background: ${PANEL_BG}`,
  "background-image: radial-gradient(circle, #eef2f7 1px, transparent 1px)",
  "background-size: 16px 16px",
  "box-shadow: 0 1px 2px rgba(15,23,42,0.06)",
  "overflow: hidden",
].join("; ");

const rootTagStyle = [
  "position: absolute",
  "top: 8px",
  "left: 10px",
  "margin: 0",
  `color: ${MUTED_INK}`,
  `font-family: ${mono}`,
  "font-size: 0.66rem",
  "font-weight: 600",
  "letter-spacing: 0.02em",
].join("; ");

// The parent wrapper. `position: relative` (no z-index → NOT a context on its
// own) so it stays in the shared context; `opacity: var(--parentOpacity)` is the
// single trigger the slider drives. At 100% it is exactly 1 → no context; below
// 100% → a context. The label chip echoes that the wrapper's own place in the
// shared context is `auto` (~0) — the number the sibling's 40 actually beats.
const parentStyle = [
  // Absolute placement on the stage. `position` (any value other than static)
  // does NOT create a stacking context without a z-index, so the wrapper stays
  // in the shared context and its only context trigger is the opacity below.
  "position: absolute",
  "margin: 0",
  "box-sizing: border-box",
  `left: ${PARENT.left}px`,
  `top: ${PARENT.top}px`,
  `width: ${PARENT.w}px`,
  `height: ${PARENT.h}px`,
  // THE trigger — real opacity from the slider, suffix "%" already baked in
  // (e.g. `95%`). Exactly 100% is `1` → no context; anything below → a context.
  "opacity: var(--parentOpacity)",
  "border-radius: 12px",
  `border: 1.5px dashed ${PARENT_BRD}`,
  `background: ${PARENT_BG}`,
  "box-shadow: 0 8px 20px -10px rgba(15,23,42,0.25)",
].join("; ");

const parentLabelStyle = [
  "position: absolute",
  "top: 8px",
  "left: 12px",
  "margin: 0",
  `color: ${PARENT_INK}`,
  "font-size: 0.62rem",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "display: flex",
  "align-items: center",
  "gap: 5px",
].join("; ");

const parentChipStyle = [
  "margin: 0",
  `color: ${PARENT_INK}`,
  "background: #ffffff",
  `border: 1px dashed ${PARENT_BRD}`,
  "border-radius: 5px",
  "padding: 0 5px",
  `font-family: ${mono}`,
  "font-size: 0.6rem",
  "font-weight: 700",
  "text-transform: none",
  "letter-spacing: 0",
].join("; ");

// Shared box look for child + sibling. `align` decides which corner the chip +
// label hug: the child anchors top-LEFT, the sibling top-RIGHT — so that with a
// ~58px overlap, whichever box loses still shows its own label in the strip the
// winner never covers (child's left edge / sibling's right edge stay clear).
const floatBox = (
  pos: { left: number; top: number; w: number; h: number },
  z: number,
  tint: { bg: string; brd: string; ink: string },
  align: "left" | "right" = "left",
) =>
  [
    // The child / sibling are themselves positioned with a REAL z-index — this
    // is what competes (the whole demo). `absolute` lets us place them precisely;
    // the z-index below is live either way.
    "position: absolute",
    "margin: 0",
    "box-sizing: border-box",
    `left: ${pos.left}px`,
    `top: ${pos.top}px`,
    `width: ${pos.w}px`,
    `height: ${pos.h}px`,
    `z-index: ${z}`,
    "border-radius: 10px",
    `border: 1.5px solid ${tint.brd}`,
    `background: ${tint.bg}`,
    "box-shadow: 0 6px 16px -6px rgba(15,23,42,0.28)",
    "display: flex",
    "flex-direction: column",
    `align-items: ${align === "right" ? "flex-end" : "flex-start"}`,
    "gap: 5px",
    "padding: 11px 12px",
  ].join("; ");

const zChipStyle = (tint: { bg: string; brd: string; ink: string }) =>
  [
    "margin: 0",
    `color: ${tint.ink}`,
    "background: #ffffff",
    `border: 1px solid ${tint.brd}`,
    "border-radius: 6px",
    "padding: 1px 7px",
    `font-family: ${mono}`,
    "font-size: 0.72rem",
    "font-weight: 700",
  ].join("; ");

const boxLabelStyle = (tint: { bg: string; brd: string; ink: string }) =>
  `margin: 0; color: ${tint.ink}; font-weight: 700; font-size: 0.8rem; line-height: 1.15;`;
---

<div
  class="not-content"
  style="margin: 0; display: flex; justify-content: center; width: 100%;"
>
  <div style={stageStyle}>
    <span style={rootTagStyle}>{"<html>"} — root context</span>

    {/* Parent wrapper — the innocent fade. Real opacity from the slider. */}
    <div style={parentStyle}>
      <span style={parentLabelStyle}>
        parent
        <span style={parentChipStyle}>opacity</span>
      </span>

      {/* Child — real position + z-index:50, INSIDE the parent. */}
      <div style={floatBox(CHILD_BOX, 50, CHILD)}>
        <span style={zChipStyle(CHILD)}>z-50</span>
        <span style={boxLabelStyle(CHILD)}>child</span>
      </div>
    </div>

    {/* Sibling — real position + z-index:40, OUTSIDE the parent, overlapping
        the child. 40 < 50, yet it wins the moment the parent becomes a context.
        Its chip/label hug the right edge, clear of where the child overlaps. */}
    <div style={floatBox(SIB_BOX, 40, SIB, "right")}>
      <span style={zChipStyle(SIB)}>z-40</span>
      <span style={boxLabelStyle(SIB)}>sibling</span>
    </div>
  </div>
</div>
