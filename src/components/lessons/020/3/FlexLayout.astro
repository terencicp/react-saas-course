---
// The "five flex layouts you'll reach for" renderings for Chapter 020 L3.
//
// Goal: each of the five canonical 1D layouts as a REAL `display: flex` mini-app
// (devtools-inspectable per the HTML+CSS diagram doc) that the student can open
// the flex overlay on. This component renders ONE pattern; the MDX drops it into
// a <TabbedItem> five times and pairs it with the matching Tailwind class string
// in a `tsx` fence beneath. It does NOT wrap itself in <Figure>: TabbedContent
// already supplies the figure card.
//
// The five patterns mirror the prose exactly:
//   nav      — flex items-center justify-between (logo left, actions right)
//   form     — shrink-0 label + flex-1 min-w-0 input
//   stack    — flex flex-col gap (vertical card list)
//   toolbar  — left cluster + flex-1 spacer + right cluster
//   footer   — flex flex-col h-full, flex-1 body pushes a pinned footer down
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches
// AxisFrame / BaselineAlign in this chapter). `margin: 0` on every inner element
// defeats Starlight's prose-margin injection into flex children.

interface Props {
  pattern: "nav" | "form" | "stack" | "toolbar" | "footer";
}

const { pattern } = Astro.props;

// Illustration palette (hard-coded, not @theme — see header note). Mirrors the
// blue/violet accents of AxisFrame so the lesson's figures feel of a piece.
const ACCENT = "#2563eb"; // blue 600 — primary action / the "fill" element
const ACCENT_INK = "#ffffff"; // text on the accent fill
const TINT_BG = "#dbeafe"; // blue 100 — soft block fill
const TINT_BRD = "#93c5fd"; // blue 300 — soft block border
const TINT_INK = "#1e40af"; // blue 800 — soft block text
const GHOST_BG = "#eef2f7"; // slate 100 — neutral chip / button
const GHOST_INK = "#475569"; // slate 600 — neutral chip text
const PANEL_BG = "#ffffff"; // card surface
const PANEL_BRD = "#e2e8f0"; // slate 200 — card border
const FRAME_BRD = "#94a3b8"; // slate 400 — the dashed flex-container ring
const MUTED_INK = "#64748b"; // slate 500 — secondary text

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// The dashed ring that marks "this is the flex container under discussion".
const frame = (extra = "") =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "border-radius: 12px",
    `border: 1px dashed ${FRAME_BRD}`,
    "background: rgba(255,255,255,0.6)",
    "padding: 12px",
    extra,
  ]
    .filter(Boolean)
    .join("; ");

// A wordmark "logo": a coloured dot + the app name.
const logoDot = [
  "margin: 0",
  "width: 18px",
  "height: 18px",
  "border-radius: 6px",
  `background: ${ACCENT}`,
  "flex: none",
].join("; ");

const wordmark = [
  "margin: 0",
  `color: #0f172a`,
  "font-weight: 800",
  "font-size: 0.95rem",
  "letter-spacing: -0.01em",
].join("; ");

// A muted nav link.
const navLink = [
  "margin: 0",
  `color: ${GHOST_INK}`,
  "font-weight: 600",
  "font-size: 0.85rem",
  "white-space: nowrap",
].join("; ");

// The primary (accent) button.
const primaryBtn = [
  "margin: 0",
  "flex: none",
  `background: ${ACCENT}`,
  `color: ${ACCENT_INK}`,
  "font-weight: 600",
  "font-size: 0.85rem",
  "border: 0",
  "border-radius: 8px",
  "padding: 7px 14px",
  "white-space: nowrap",
].join("; ");

// A neutral toolbar/ghost button.
const ghostBtn = [
  "margin: 0",
  "flex: none",
  `background: ${GHOST_BG}`,
  `color: ${GHOST_INK}`,
  "font-weight: 600",
  "font-size: 0.85rem",
  "border: 0",
  "border-radius: 8px",
  "padding: 7px 12px",
  "white-space: nowrap",
].join("; ");

// One soft tinted card for the vertical stack.
const stackCard = [
  "margin: 0",
  "box-sizing: border-box",
  `background: ${TINT_BG}`,
  `border: 1px solid ${TINT_BRD}`,
  `color: ${TINT_INK}`,
  "border-radius: 10px",
  "padding: 12px 14px",
  "font-weight: 600",
  "font-size: 0.85rem",
].join("; ");
---

{
  /* ----------------------------- NAV BAR ----------------------------- */
  pattern === "nav" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      <header
        style={frame(
          "display: flex; align-items: center; justify-content: space-between; gap: 16px;",
        )}
      >
        {/* left cluster: logo + wordmark */}
        <div style="margin: 0; display: flex; align-items: center; gap: 10px;">
          <span style={logoDot} />
          <span style={wordmark}>Ledger</span>
        </div>
        {/* right cluster: links + sign-in */}
        <nav style="margin: 0; display: flex; align-items: center; gap: 18px;">
          <span style={navLink}>Pricing</span>
          <span style={navLink}>Docs</span>
          <button style={primaryBtn}>Sign in</button>
        </nav>
      </header>
    </div>
  )
}

{
  /* ----------------------------- FORM ROW ---------------------------- */
  pattern === "form" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      <div
        style={frame("display: flex; align-items: center; gap: 12px;")}
      >
        <label
          style={`margin: 0; flex: none; color: #0f172a; font-weight: 600; font-size: 0.9rem; white-space: nowrap;`}
        >
          Workspace URL
        </label>
        <div
          style={`margin: 0; flex: 1 1 0%; min-width: 0; box-sizing: border-box; height: 38px; display: flex; align-items: center; padding: 0 12px; background: ${PANEL_BG}; border: 1px solid ${PANEL_BRD}; border-radius: 8px; color: ${MUTED_INK}; font-size: 0.85rem; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;`}
        >
          acme.ledger.app
        </div>
      </div>
    </div>
  )
}

{
  /* ---------------------------- CARD STACK --------------------------- */
  pattern === "stack" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      <div
        style={frame("display: flex; flex-direction: column; gap: 12px;")}
      >
        <div style={stackCard}>Invite teammates</div>
        <div style={stackCard}>Connect a bank account</div>
        <div style={stackCard}>Set your billing currency</div>
      </div>
    </div>
  )
}

{
  /* -------------------------- TOOLBAR SPACER ------------------------- */
  pattern === "toolbar" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      <div style={frame("display: flex; align-items: center; gap: 8px;")}>
        {/* left cluster */}
        <button style={ghostBtn}>Bold</button>
        <button style={ghostBtn}>Italic</button>
        {/* the leftover-space spacer — labelled so the trick is legible */}
        <div
          style={`margin: 0; flex: 1 1 0%; align-self: stretch; display: flex; align-items: center; justify-content: center; min-height: 32px; border-radius: 8px; border: 1px dashed ${TINT_BRD}; background: rgba(219,234,254,0.5); color: ${ACCENT}; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.02em;`}
        >
          flex-1 spacer
        </div>
        {/* right cluster */}
        <button style={ghostBtn}>Discard</button>
        <button style={primaryBtn}>Publish</button>
      </div>
    </div>
  )
}

{
  /* -------------------------- PINNED FOOTER -------------------------- */
  pattern === "footer" && (
    <div style={`margin: 0; color-scheme: light; font-family: ${sans};`}>
      <div
        style={frame(
          `display: flex; flex-direction: column; gap: 10px; height: 240px; padding: 14px;`,
        )}
      >
        {/* header */}
        <header
          style={`margin: 0; flex: none; display: flex; align-items: center; gap: 10px;`}
        >
          <span style={logoDot} />
          <span style={wordmark}>Usage this month</span>
        </header>
        {/* body — flex-1 eats the spare vertical space and shoves the footer down */}
        <div
          style={`margin: 0; flex: 1 1 0%; box-sizing: border-box; display: flex; align-items: center; justify-content: center; border-radius: 10px; border: 1px dashed ${TINT_BRD}; background: rgba(219,234,254,0.45); color: ${ACCENT}; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.02em;`}
        >
          flex-1 body — grows to fill
        </div>
        {/* footer — pinned to the bottom regardless of how short the body is */}
        <footer
          style={`margin: 0; flex: none; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 4px;`}
        >
          <span style={`margin: 0; color: ${MUTED_INK}; font-size: 0.8rem;`}>
            Resets June 30
          </span>
          <button style={primaryBtn}>Upgrade</button>
        </footer>
      </div>
    </div>
  )
}
