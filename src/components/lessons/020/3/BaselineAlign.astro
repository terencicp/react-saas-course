---
// items-center vs items-baseline figure for Chapter 020 L3 (Flexbox).
//
// Goal: make the baseline insight visible. Two REAL flex rows side by side, each
// mixing a large word ("Revenue") with a small one ("updated 2m ago"):
//   - items-center  → centres the two BOXES, so the small text floats ABOVE the
//     big text's baseline and the words look misaligned.
//   - items-baseline → aligns the text BASELINES, so the words sit on one line
//     the way they would in a sentence.
//
// Both rows are genuine `display: flex` (devtools-inspectable) per the HTML+CSS
// diagram doc — the student can open the flex overlay on either. The big word
// carries a dashed rose underline at its baseline (line-height: 1 puts the box
// bottom on the baseline), so the "floats above" vs "sits on the line"
// difference is read against a concrete rule, not left to the eye. Anchoring the
// rule to the big word itself keeps it correct in BOTH rows even though
// align-items shifts the word's box up or down within the row.
//
// This component wraps itself in <Figure> (it is dropped straight into the MDX,
// not inside a TabbedContent). Colours are hard-coded illustration tints with
// `color-scheme: light` pinned — the sanctioned divergence from the OKLCH @theme
// tokens for figures (matches the other 020 diagrams). `margin: 0` on every inner
// element defeats Starlight's prose-margin injection into flex children.

import Figure from "../../../figures/Figure.astro";

// Illustration palette (hard-coded, not @theme — see header note).
const BIG_INK = "#0f172a"; // slate 900 — the large word
const SMALL_INK = "#64748b"; // slate 500 — the small caption
const PANEL_BG = "#f8fafc"; // slate 50 — the demo row backdrop
const PANEL_BRD = "#e2e8f0"; // slate 200 — the demo row border
const BASELINE = "#f43f5e"; // rose 500 — the shared-baseline reference rule
const LABEL_INK = "#334155"; // slate 700 — the utility label

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// The big word and the small caption. Shared between both panels so the only
// variable is `align-items`.
const bigWord = [
  "margin: 0",
  `color: ${BIG_INK}`,
  "font-size: 2rem",
  "font-weight: 800",
  "line-height: 1",
  // Dashed rule ON the big word's alphabetic baseline. text-decoration underline
  // is drawn relative to the glyph baseline (not the box bottom), so it lands
  // exactly where a baseline-aligned sibling's text sits — correct in both rows.
  "text-decoration-line: underline",
  "text-decoration-style: dashed",
  `text-decoration-color: ${BASELINE}`,
  "text-decoration-thickness: 2px",
  "text-underline-offset: 2px",
].join("; ");

const smallWord = [
  "margin: 0",
  `color: ${SMALL_INK}`,
  "font-size: 0.8rem",
  "font-weight: 600",
  "line-height: 1",
].join("; ");

// One demo: a labelled, real flex row. `align` is the align-items value under
// test. The dashed baseline rule is an absolutely-positioned decoration sitting
// behind the words at the big word's baseline (~88% down the 64px row).
const panel = [
  "margin: 0",
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
  "flex: 1 1 220px",
  "min-width: 0",
].join("; ");

const label = (utility: string, accent: boolean) =>
  [
    "margin: 0",
    "align-self: flex-start",
    `font-family: ${sans}`,
    "font-size: 0.78rem",
    "font-weight: 700",
    `color: ${accent ? BASELINE : LABEL_INK}`,
    "background: #ffffff",
    `border: 1px solid ${accent ? BASELINE : PANEL_BRD}`,
    "border-radius: 999px",
    "padding: 2px 10px",
    "white-space: nowrap",
  ].join("; ");

// The real flex row.
const demoRow = (align: string) =>
  [
    "margin: 0",
    "display: flex",
    `align-items: ${align}`,
    "gap: 10px",
    "height: 64px",
    "padding: 0 16px",
    `background: ${PANEL_BG}`,
    `border: 1px solid ${PANEL_BRD}`,
    "border-radius: 12px",
    "box-sizing: border-box",
  ].join("; ");
---

<Figure caption="items-center aligns the boxes; items-baseline aligns the text. The dashed rose rule marks the big word's baseline — with items-center the small caption floats above it, with items-baseline the words share it. With mixed font sizes, baseline is usually what you want.">
  <div
    style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; flex-wrap: wrap; gap: 20px;`}
  >
    {/* items-center — boxes centred, small text floats above the baseline */}
    <div style={panel}>
      <span style={label("items-center", false)}>items-center</span>
      <div style={demoRow("center")}>
        <span style={bigWord}>Revenue</span>
        <span style={smallWord}>updated 2m ago</span>
      </div>
    </div>

    {/* items-baseline — text baselines aligned, words sit on one line */}
    <div style={panel}>
      <span style={label("items-baseline", true)}>items-baseline</span>
      <div style={demoRow("baseline")}>
        <span style={bigWord}>Revenue</span>
        <span style={smallWord}>updated 2m ago</span>
      </div>
    </div>
  </div>
</Figure>
