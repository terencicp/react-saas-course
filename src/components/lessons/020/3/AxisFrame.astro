---
// The two-axis figure for Chapter 020 L3 (Flexbox, the 1D primitive).
//
// Goal: make "main axis" and "cross axis" concrete and spatial BEFORE any
// utility name, and — the load-bearing insight — show that the axes are not
// glued to "horizontal"/"vertical". Switch the container from row to column and
// both arrows rotate together while the three boxes barely move.
//
// This component renders ONE orientation (row or column) and is dropped into a
// <TabbedItem> twice from the MDX (Row / Column tabs). It does NOT wrap itself
// in <Figure>: TabbedContent already supplies the figure card.
//
// Real `display: flex` (devtools-inspectable) per the HTML+CSS diagram doc — the
// boxes sit in a genuine flex container the student can open the flex overlay on,
// not absolutely-positioned fakes. The two axis arrows are decoration laid out
// AROUND that real container.
//
// Layout trick that sells the "axes rotate" idea: in both orientations the three
// boxes occupy the same top-left slot. Only the arrows move — the thick MAIN
// arrow always runs parallel to the flow (horizontal in a row, vertical in a
// column) and the thin CROSS arrow always runs perpendicular.
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches the
// lesson-1/2 diagrams in this chapter). `margin: 0` on every inner element
// defeats Starlight's prose-margin injection into flex children.

interface Props {
  direction: "row" | "column";
}

const { direction } = Astro.props;
const isRow = direction === "row";

// Illustration palette (hard-coded, not @theme — see header note).
const MAIN = "#2563eb"; // blue 600 — the main axis (the flow)
const CROSS = "#9333ea"; // violet 600 — the cross axis (perpendicular)
const BOX_BG = "#dbeafe"; // blue 100 — the flex-item fill
const BOX_BRD = "#93c5fd"; // blue 300 — the flex-item border
const BOX_INK = "#1e3a8a"; // blue 900 — the flex-item number

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// One of the three flex items.
const box = [
  "margin: 0",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "width: 52px",
  "height: 52px",
  "border-radius: 10px",
  `background: ${BOX_BG}`,
  `border: 1px solid ${BOX_BRD}`,
  `color: ${BOX_INK}`,
  "font-size: 1.1rem",
  "font-weight: 700",
  "box-sizing: border-box",
  "flex: none",
].join("; ");

// The REAL flex container the figure is about. `display: inline-flex` so it
// shrink-wraps the three boxes (the surrounding decoration handles alignment),
// `flex-direction` swung by the prop. A faint dashed ring marks its bounds so the
// student can see "this is the flex container".
const flexContainer = [
  "margin: 0",
  "display: inline-flex",
  `flex-direction: ${direction}`,
  "gap: 10px",
  "padding: 10px",
  "border-radius: 12px",
  "border: 1px dashed #94a3b8",
  "background: rgba(255,255,255,0.6)",
  "box-sizing: border-box",
].join("; ");

// --- axis arrow ------------------------------------------------------------
// A label + a line ending in a chevron, oriented horizontally or vertically.
// `thick` distinguishes the main axis (heavier line, bolder label) from the
// cross axis. Built so the chevron sits at the arrow's far end (right / bottom).

const arrowLabel = (color: string, thick: boolean) =>
  [
    "margin: 0",
    `font-family: ${sans}`,
    `font-size: ${thick ? "0.8rem" : "0.72rem"}`,
    `font-weight: ${thick ? "800" : "700"}`,
    "letter-spacing: 0.01em",
    "white-space: nowrap",
    `color: ${color}`,
  ].join("; ");

// The shaft+head as a single horizontal or vertical run.
const arrowTrack = (horizontal: boolean) =>
  [
    "margin: 0",
    "display: flex",
    "align-items: center",
    horizontal ? "flex-direction: row" : "flex-direction: column",
  ].join("; ");

const arrowShaft = (color: string, thick: boolean, horizontal: boolean) =>
  [
    "margin: 0",
    `background: ${color}`,
    "border-radius: 2px",
    horizontal
      ? `height: ${thick ? "4px" : "2px"}`
      : `width: ${thick ? "4px" : "2px"}`,
    horizontal ? "flex: 1 1 auto" : "flex: 1 1 auto",
  ].join("; ");

// Chevron head: a rotated CSS triangle pointing along the run.
const arrowHead = (color: string, thick: boolean, dir: "right" | "down") => {
  const size = thick ? 9 : 7;
  const base = ["margin: 0", "width: 0", "height: 0", "flex: none"];
  if (dir === "right") {
    base.push(
      `border-top: ${size}px solid transparent`,
      `border-bottom: ${size}px solid transparent`,
      `border-left: ${size + 2}px solid ${color}`,
    );
  } else {
    base.push(
      `border-left: ${size}px solid transparent`,
      `border-right: ${size}px solid transparent`,
      `border-top: ${size + 2}px solid ${color}`,
    );
  }
  return base.join("; ");
};
---

{
  isRow ? (
    /* ---------- ROW: main runs horizontally, cross runs vertically ---------- */
    <div
      style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; align-items: flex-start; gap: 14px; padding: 4px 2px;`}
    >
      {/* cross axis (vertical) sits to the LEFT of the boxes */}
      <div
        style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 8px; align-self: stretch; padding-top: 6px;"
      >
        <span style={arrowLabel(CROSS, false)}>cross axis</span>
        <div style={`${arrowTrack(false)}; flex: 1 1 auto;`}>
          <div style={arrowShaft(CROSS, false, false)} />
          <div style={arrowHead(CROSS, false, "down")} />
        </div>
      </div>

      {/* boxes on top, main axis (horizontal) beneath */}
      <div style="margin: 0; display: flex; flex-direction: column; gap: 12px;">
        <div style={flexContainer}>
          <div style={box}>1</div>
          <div style={box}>2</div>
          <div style={box}>3</div>
        </div>
        <div style="margin: 0; display: flex; flex-direction: column; gap: 6px;">
          <div style={`${arrowTrack(true)}; width: 100%;`}>
            <div style={arrowShaft(MAIN, true, true)} />
            <div style={arrowHead(MAIN, true, "right")} />
          </div>
          <span style={`${arrowLabel(MAIN, true)}; text-align: center;`}>
            main axis
          </span>
        </div>
      </div>
    </div>
  ) : (
    /* ---------- COLUMN: main runs vertically, cross runs horizontally ---------- */
    <div
      style={`margin: 0; color-scheme: light; font-family: ${sans}; display: flex; align-items: flex-start; gap: 14px; padding: 4px 2px;`}
    >
      {/* boxes on top, cross axis (horizontal) beneath */}
      <div style="margin: 0; display: flex; flex-direction: column; gap: 12px;">
        <div style={flexContainer}>
          <div style={box}>1</div>
          <div style={box}>2</div>
          <div style={box}>3</div>
        </div>
        <div style="margin: 0; display: flex; flex-direction: column; gap: 6px;">
          <div style={`${arrowTrack(true)}; width: 100%;`}>
            <div style={arrowShaft(CROSS, false, true)} />
            <div style={arrowHead(CROSS, false, "right")} />
          </div>
          <span style={`${arrowLabel(CROSS, false)}; text-align: center;`}>
            cross axis
          </span>
        </div>
      </div>

      {/* main axis (vertical) sits to the RIGHT of the boxes */}
      <div
        style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 8px; align-self: stretch; padding-top: 6px;"
      >
        <span style={arrowLabel(MAIN, true)}>main axis</span>
        <div style={`${arrowTrack(false)}; flex: 1 1 auto;`}>
          <div style={arrowShaft(MAIN, true, false)} />
          <div style={arrowHead(MAIN, true, "down")} />
        </div>
      </div>
    </div>
  )
}
