---
// A REAL, devtools-inspectable scroll-snap carousel for Chapter 020 L8
// (diagram id: snap-carousel).
//
// Goal: the section's "the platform replaced the JS library" payoff — so this is
// the GENUINE CSS, not a framed mock like StickySidebarScroll. The row is an
// actual scroll container (overflow-x: auto; scroll-snap-type: x mandatory;
// scroll-padding-inline: 1rem) of fixed-width cards, each flex: none (= shrink-0)
// with scroll-snap-align: start. Drag/scroll it sideways and the browser settles
// each card to the container's start edge — with no JavaScript whatsoever, which
// is the whole point: a student can open devtools and confirm the snap utilities
// are the only thing doing the work. The inline styles map 1:1 onto the lesson's
// Tailwind code sample (flex gap-4 overflow-x-auto snap-x snap-mandatory
// scroll-px-4 on the row; w-64 shrink-0 snap-start on each card).
//
// Conventions match the chapter's other figure components (OverflowModesTable /
// StickySidebarScroll): `not-content` wrapper, `color-scheme: light` pinned,
// hard-coded slate/blue illustration tints (the sanctioned divergence from the
// OKLCH @theme tokens for figures), and `margin: 0` on every inner element to
// defeat Starlight's prose-margin injection. The native scrollbar is kept VISIBLE
// (bottom padding reserves room for it) so the overflow reads as scrollable rather
// than a clipped/broken row — and so the student sees the thumb shrink, proving
// the content overflows.

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Illustration palette — same blue/slate family as the chapter's other figures.
const ACCENT = "#2563eb"; // blue 600 — price + accent rule
const CARD_BG = "#ffffff"; // card surface
const CARD_BRD = "#e2e8f0"; // slate 200 — card hairline
const TRACK_BG = "#f8fafc"; // slate 50 — scroller surface (the "rail")
const HEADING_INK = "#0f172a"; // slate 900 — product name
const MUTED_INK = "#64748b"; // slate 500 — secondary text
const PRICE_INK = "#1e3a8a"; // blue 900 — price

// Six products — distinct content per card, in the chapter's SaaS / Acme
// Invoicing narrative. Each gets its own thumbnail tint so the cards are visually
// distinguishable as they snap past.
const products = [
  { name: "Starter seat", price: "$12/mo", tint: "#dbeafe", ink: "#1e40af" },
  { name: "Team seat", price: "$29/mo", tint: "#cffafe", ink: "#155e75" },
  { name: "Usage credits", price: "$0.004/req", tint: "#dcfce7", ink: "#166534" },
  { name: "Priority support", price: "$99/mo", tint: "#fef3c7", ink: "#92400e" },
  { name: "Audit log", price: "$19/mo", tint: "#ede9fe", ink: "#5b21b6" },
  { name: "SSO add-on", price: "$49/mo", tint: "#ffe4e6", ink: "#9f1239" },
];

// ---- shared element styles --------------------------------------------------

// Outer bordered card. Pins color-scheme so the tints render the same in dark
// mode; the inner scroller sits on a faint slate rail.
const cardStyle = [
  "margin: 0",
  "color-scheme: light",
  `font-family: ${sans}`,
  "box-sizing: border-box",
  "width: 100%",
  "border-radius: 14px",
  `border: 1px solid ${CARD_BRD}`,
  `background: ${TRACK_BG}`,
  "padding: 14px",
  "box-shadow: 0 1px 2px rgba(15,23,42,0.06)",
].join("; ");

// A tiny "scroll sideways" hint above the rail.
const hintStyle = [
  "margin: 0 0 10px",
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "gap: 6px",
  `color: ${MUTED_INK}`,
  "font-size: 12px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
].join("; ");

// THE SCROLL CONTAINER. This is the genuine article — overflow-x: auto makes it
// scrollable, scroll-snap-type: x mandatory turns on snapping, and
// scroll-padding-inline offsets the snap points 1rem inward so a snapped card
// isn't flush against the edge. The native scrollbar is left visible (bottom
// padding reserves its track). gap is the flex `gap-4`.
const scrollerStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "display: flex",
  "gap: 16px", // gap-4
  "overflow-x: auto",
  "overflow-y: hidden",
  "scroll-snap-type: x mandatory",
  "scroll-padding-inline: 16px", // scroll-px-4
  "padding-block-end: 12px", // room so the scrollbar doesn't cover the cards
  // a subtle edge fade hint that there's more to the right
  "-webkit-overflow-scrolling: touch",
].join("; ");

// EACH CARD. flex: none is the `shrink-0` that keeps the card at its real width
// instead of squashing to fit; scroll-snap-align: start aligns its leading edge
// to the container's snap port. Fixed 15rem width (= w-64-ish) so the six cards
// comfortably overflow the figure and there's always something to scroll.
const slideStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "flex: none", // shrink-0
  "width: 15rem",
  "scroll-snap-align: start",
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "border-radius: 12px",
  `border: 1px solid ${CARD_BRD}`,
  `background: ${CARD_BG}`,
  "padding: 14px",
  "box-shadow: 0 1px 2px rgba(15,23,42,0.05)",
].join("; ");

// The tinted thumbnail block at the top of each card — carries the card's index
// so the snap is legible as you scroll past.
const thumbStyle = (tint: string, ink: string) =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "height: 78px",
    "border-radius: 9px",
    `background: ${tint}`,
    `color: ${ink}`,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "font-size: 26px",
    "font-weight: 800",
    "letter-spacing: 0.01em",
  ].join("; ");

const nameStyle = [
  "margin: 0",
  `color: ${HEADING_INK}`,
  "font-size: 0.95rem",
  "font-weight: 700",
  "line-height: 1.2",
].join("; ");

const rowStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "display: flex",
  "align-items: baseline",
  "justify-content: space-between",
  "gap: 8px",
].join("; ");

const priceStyle = [
  "margin: 0",
  mono,
  `color: ${PRICE_INK}`,
  "font-size: 0.92rem",
  "font-weight: 700",
].join("; ");

const planStyle = `margin: 0; color: ${MUTED_INK}; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;`;
---

<div class="not-content" style={cardStyle}>
  <p style={hintStyle}>
    <span style="margin: 0;">Scroll sideways</span>
    <span style="margin: 0; font-size: 14px;">&rarr;</span>
  </p>

  {/* The genuine scroll-snap container — inspect it in devtools. */}
  <div style={scrollerStyle}>
    {
      products.map((p, i) => (
        <article style={slideStyle}>
          <div style={thumbStyle(p.tint, p.ink)}>{i + 1}</div>
          <span style={planStyle}>Add-on</span>
          <div style={rowStyle}>
            <span style={nameStyle}>{p.name}</span>
            <span style={priceStyle}>{p.price}</span>
          </div>
        </article>
      ))
    }
  </div>
</div>
