---
// The "sticky header inside an internally-scrolling sidebar" sequence for
// Chapter 020 L8 (diagram id: sticky-sidebar-scroll).
//
// Goal: freeze the MOTION of the canonical dashboard pattern into three discrete
// frames the student scrubs through in a <DiagramSequence>. Each frame renders
// the SAME faithful two-pane app mock — a full-width top bar, then a narrow left
// sidebar (the scroll container, with a pinned "Navigation" header over a list of
// nav-link rows) beside a wide main content region. The three frames differ ONLY
// in the sidebar's scroll position; the top bar and main content are byte-for-byte
// identical across all three, so the eye locks onto them as the constant the
// caption tells the student to watch.
//
// FAKED / FRAMED scroll, NOT a real scroll region — the same convention L7's
// PositionLayouts used for framed `fixed`/`sticky`. The sidebar body is clipped
// (overflow: hidden) and its link list is shifted up by a per-step offset
// (translateY), so earlier links slide UNDER the pinned header exactly as a real
// scroll would look — but the frame is static and can't escape the figure. The
// "Navigation" header is layered on top with an opaque, tinted surface so links
// tuck beneath it. A faux scrollbar track on the sidebar's right edge carries a
// thumb whose position (top / middle / bottom) reflects the step, making "this
// scrolled" legible without any actual motion.
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures, matching
// PositionLayouts / FlexLayout / GridLayout / OverflowModesTable in this chapter.
// `margin: 0` on every inner element defeats Starlight's prose-margin injection.

interface Props {
  // Which frame of the scroll sequence to render.
  //   1 — top of the sidebar's scroll (header at top, first links below)
  //   2 — scrolled mid-way (header pinned, earlier links tucked under it)
  //   3 — scrolled to the bottom (last link flush, the scroll stops here)
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// Illustration palette — same blue/slate family as the chapter's other figures.
const ACCENT = "#2563eb"; // blue 600 — logo dot + pinned-header accent rule
const PANEL_BG = "#ffffff"; // top bar + main surface
const SIDEBAR_BG = "#f8fafc"; // slate 50 — sidebar surface
const HEADER_BG = "#eff6ff"; // blue 50 — the pinned "Navigation" header tint
const HEADER_INK = "#1e3a8a"; // blue 900 — pinned-header text
const PANEL_BRD = "#e2e8f0"; // slate 200 — chrome hairlines
const HEADING_INK = "#0f172a"; // slate 900 — strong text
const MUTED_INK = "#64748b"; // slate 500 — secondary text
const LINK_INK = "#475569"; // slate 600 — nav-link text
const GHOST_BG = "#e2e8f0"; // slate 200 — skeleton placeholder bars
const TRACK_BG = "#e2e8f0"; // slate 200 — faux scrollbar track
const THUMB_BG = "#94a3b8"; // slate 400 — faux scrollbar thumb

// Frame geometry. The whole app window is a fixed box; the sidebar body is a
// clipped viewport of fixed height that a taller link list scrolls inside.
const WIN_H = 252; // app window height
const BAR_H = 36; // top bar height
const HEADER_H = 34; // pinned "Navigation" header height
const ROW_H = 30; // one nav-link row (height incl. its share of the gap)
const LINK_COUNT = 14; // links in the list — comfortably taller than the body

// The sidebar body (area below the top bar) and the scrollable viewport beneath
// the pinned header.
const BODY_H = WIN_H - BAR_H;
const VIEWPORT_H = BODY_H - HEADER_H;
const LIST_H = LINK_COUNT * ROW_H + 8; // intrinsic list height (+ bottom pad)
const MAX_OFFSET = LIST_H - VIEWPORT_H; // furthest the list can scroll up

// Per-step scroll offset (px the list is shifted UP) and the matching faux-thumb
// travel (0 = top of track, 1 = bottom). Step 1 top, step 2 mid, step 3 bottom.
const offsetFraction = step === 1 ? 0 : step === 2 ? 0.5 : 1;
const listOffset = Math.round(MAX_OFFSET * offsetFraction);

// Faux scrollbar thumb: its length is the viewport/list ratio, its top travels
// the remaining track in lockstep with the list offset.
const TRACK_PAD = 6;
const trackTravel = VIEWPORT_H - 2 * TRACK_PAD;
const thumbH = Math.max(28, Math.round((VIEWPORT_H / LIST_H) * trackTravel));
const thumbTop = TRACK_PAD + Math.round((trackTravel - thumbH) * offsetFraction);

// Nav-link labels. A real dashboard's nav — long enough to need scrolling.
const links = [
  "Overview",
  "Invoices",
  "Customers",
  "Products",
  "Subscriptions",
  "Payments",
  "Payouts",
  "Disputes",
  "Reports",
  "Webhooks",
  "API keys",
  "Team",
  "Billing",
  "Settings",
];

// A skeleton "content" bar for the main region — neutral grey block.
const skeletonBar = (w: string, h = "12px") =>
  `margin: 0; width: ${w}; height: ${h}; border-radius: 6px; background: ${GHOST_BG};`;

// ---- shared element styles --------------------------------------------------

// The framed app window.
const windowStyle = [
  "margin: 0",
  "color-scheme: light",
  `font-family: ${sans}`,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 460px",
  `height: ${WIN_H}px`,
  "display: flex",
  "flex-direction: column",
  "overflow: hidden",
  "border-radius: 14px",
  `border: 1px solid ${PANEL_BRD}`,
  `background: ${PANEL_BG}`,
  "box-shadow: 0 1px 2px rgba(15,23,42,0.06)",
].join("; ");

// Full-width top bar — IDENTICAL across all three frames (the constant).
const topBarStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "flex: none",
  `height: ${BAR_H}px`,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "padding: 0 14px",
  `background: ${PANEL_BG}`,
  `border-bottom: 1px solid ${PANEL_BRD}`,
].join("; ");

const logoDotStyle = `margin: 0; flex: none; width: 16px; height: 16px; border-radius: 5px; background: ${ACCENT};`;

const wordmarkStyle = `margin: 0; color: ${HEADING_INK}; font-weight: 700; font-size: 0.82rem;`;

// The row holding sidebar + main.
const splitStyle = "margin: 0; box-sizing: border-box; flex: 1; display: flex; min-height: 0;";

// The sidebar: fixed-width column, its own surface, a clipped body below a pinned
// header. position: relative so the faux scrollbar can pin to its edge.
const sidebarStyle = [
  "position: relative",
  "margin: 0",
  "box-sizing: border-box",
  "flex: none",
  "width: 150px",
  "display: flex",
  "flex-direction: column",
  `background: ${SIDEBAR_BG}`,
  `border-right: 1px solid ${PANEL_BRD}`,
  "overflow: hidden",
].join("; ");

// The pinned "Navigation" header — tinted + accent left-rule so the eye tracks
// it staying put, and OPAQUE so links slide under it cleanly.
const navHeaderStyle = [
  "position: relative",
  "z-index: 1",
  "margin: 0",
  "box-sizing: border-box",
  "flex: none",
  `height: ${HEADER_H}px`,
  "display: flex",
  "align-items: center",
  "padding: 0 12px",
  `background: ${HEADER_BG}`,
  `border-bottom: 1px solid ${PANEL_BRD}`,
  `box-shadow: inset 3px 0 0 ${ACCENT}, 0 1px 2px rgba(15,23,42,0.06)`,
  `color: ${HEADER_INK}`,
  "font-size: 0.72rem",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
].join("; ");

// The clipped viewport beneath the header — this is where the "scroll" happens.
const viewportStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "flex: 1",
  "position: relative",
  "overflow: hidden",
].join("; ");

// The link list — taller than the viewport, shifted up by `listOffset` to fake
// the scroll. A CSS transition makes the scrub between frames read as motion.
const listStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "position: absolute",
  "left: 0",
  "right: 0",
  "top: 0",
  `transform: translateY(-${listOffset}px)`,
  "transition: transform 280ms cubic-bezier(0.22, 0.61, 0.36, 1)",
  "padding: 6px 8px 8px",
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
  "list-style: none",
].join("; ");

const linkRowStyle = (active: boolean) =>
  [
    "margin: 0",
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "gap: 8px",
    `height: ${ROW_H - 4}px`,
    "padding: 0 8px",
    "border-radius: 6px",
    active ? `background: ${HEADER_BG}` : "background: transparent",
    `color: ${active ? HEADER_INK : LINK_INK}`,
    "font-size: 0.78rem",
    active ? "font-weight: 600" : "font-weight: 500",
  ].join("; ");

const linkDotStyle = (active: boolean) =>
  `margin: 0; flex: none; width: 6px; height: 6px; border-radius: 999px; background: ${active ? ACCENT : MUTED_INK};`;

// Faux scrollbar — a track pinned to the sidebar's right edge with a thumb whose
// position reflects the step. In step 3 it sits flush at the bottom.
const trackStyle = [
  "position: absolute",
  `top: ${HEADER_H + TRACK_PAD}px`,
  `bottom: ${TRACK_PAD}px`,
  "right: 3px",
  "margin: 0",
  "width: 5px",
  "border-radius: 999px",
  `background: ${TRACK_BG}`,
].join("; ");

const thumbStyle = [
  "position: absolute",
  "left: 0",
  "right: 0",
  `top: ${thumbTop}px`,
  `height: ${thumbH}px`,
  "margin: 0",
  "border-radius: 999px",
  `background: ${THUMB_BG}`,
  "transition: top 280ms cubic-bezier(0.22, 0.61, 0.36, 1)",
].join("; ");

// The main content region — IDENTICAL across all three frames (the constant).
const mainStyle = [
  "margin: 0",
  "box-sizing: border-box",
  "flex: 1",
  "min-width: 0",
  `background: ${PANEL_BG}`,
  "padding: 16px",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
].join("; ");
---

<div class="not-content" style="margin: 0; display: flex; justify-content: center; padding: 6px 4px;">
  <div style={windowStyle}>
    {/* Top bar — the constant. Same in every frame. */}
    <div style={topBarStyle}>
      <span style={logoDotStyle}></span>
      <span style={wordmarkStyle}>Acme Invoicing</span>
    </div>

    <div style={splitStyle}>
      {/* Sidebar — the ONLY thing that differs between frames. */}
      <aside style={sidebarStyle}>
        <div style={navHeaderStyle}>Navigation</div>
        <div style={viewportStyle}>
          <ul style={listStyle}>
            {
              links.map((label, i) => (
                <li style={linkRowStyle(i === 0)}>
                  <span style={linkDotStyle(i === 0)}></span>
                  <span style="margin: 0;">{label}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div style={trackStyle}>
          <div style={thumbStyle}></div>
        </div>
      </aside>

      {/* Main content — the constant. Same in every frame. */}
      <main style={mainStyle}>
        <span style={`margin: 0; color: ${HEADING_INK}; font-weight: 700; font-size: 0.9rem;`}>Invoices</span>
        <div style={skeletonBar("90%", "13px")}></div>
        <div style={skeletonBar("100%")}></div>
        <div style={skeletonBar("100%")}></div>
        <div style={skeletonBar("75%")}></div>
        <div style={`margin: 6px 0 0; ${skeletonBar("60%", "13px")}`}></div>
        <div style={skeletonBar("100%")}></div>
        <div style={skeletonBar("85%")}></div>
      </main>
    </div>
  </div>
</div>
