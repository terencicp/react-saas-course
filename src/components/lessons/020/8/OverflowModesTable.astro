---
// The five-mode `overflow` reference table for Chapter 020 L8.
//
// Goal: a scan-at-a-glance lookup for the five `overflow` values, framed by the
// two questions the prose leads with — "Clips?" and "Scroll container?" — plus a
// "reach for it when…" gloss. The whole section hinges on the SECOND question
// (which values create a scroll container), so this table is built to be read
// down that column: the three "Yes" cells (hidden / auto / scroll) read calm and
// uniform, and the two "No" cells (visible / clip) are deliberately made to pop
// as the odd ones out — that visual split IS the lesson's central distinction.
//
// Sibling of L7's InsetUtilityReference (same chapter family of HTML+CSS
// reference grids, devtools-inspectable): a real CSS grid drives the layout —
// four columns (value | clips? | scroll container? | when). `margin: 0` reset on
// every inner element (belt-and-braces with `not-content`) defeats Starlight's
// prose-margin injection. Unlike the L7 grid it pins `color-scheme: light` and
// uses hard-coded slate/blue illustration tints (the sanctioned figure
// divergence for this chapter — matches PositionLayouts / FlexLayout / GridLayout
// rather than the theme grays), and wraps itself in its own bordered card.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// Illustration palette (hard-coded, not @theme — see header note). Same blue
// family as the chapter's other figures so the section feels of a piece.
const CARD_BG = "#ffffff"; // outer card surface
const CARD_BRD = "#e2e8f0"; // slate 200 — outer card + cell hairlines
const HEAD_INK = "#0f172a"; // slate 900 — column labels
const VALUE_TINT = "#eff6ff"; // blue 50 — the "this is a CSS value" column tint
const VALUE_INK = "#1e3a8a"; // blue 900 — the monospace value
const VALUE_BRD = "#2563eb"; // blue 600 — value column left rule
const GLOSS_INK = "#475569"; // slate 600 — the "reach for it when" gloss
const FOCUS_HEAD_BG = "#1e3a8a"; // blue 900 — the emphasized column header fill
const FOCUS_HEAD_INK = "#ffffff";
const FOCUS_COL_BG = "#f8fafc"; // slate 50 — faint wash behind the focal column

// Yes / No pill palettes. The "Clips?" column is informational, so its pills are
// quiet (neutral slate). The "Scroll container?" column is the focal one, so its
// pills carry real colour: "Yes" a calm blue, "No" a loud amber so the two odd
// rows (visible / clip) jump out when the eye scans the column.
const quietYes = `background: #e2e8f0; color: #334155; border-color: #cbd5e1;`;
const quietNo = `background: #f1f5f9; color: #64748b; border-color: #e2e8f0;`;
const loudYes = `background: #dbeafe; color: #1e40af; border-color: #93c5fd;`;
const loudNo = `background: #fef3c7; color: #92400e; border-color: #fcd34d;`;

type Pill = "yes" | "no";

interface Row {
  value: string;
  clips: Pill;
  container: Pill;
  when: string;
}

// Rows in the prose's order. `container` is the load-bearing column: visible and
// clip are "no", the other three "yes".
const rows: Row[] = [
  {
    value: "visible",
    clips: "no",
    container: "no",
    when: "The default. Content spills past the box and stays visible. Every box you've built so far has been visible.",
  },
  {
    value: "hidden",
    clips: "yes",
    container: "yes",
    when: "You want to cut off overflow and also want a scroll container (e.g. to give a sticky child something to stick to). The scroll-container part is the surprise.",
  },
  {
    value: "clip",
    clips: "yes",
    container: "no",
    when: "You want pure clipping with zero side effects. The clean clipper.",
  },
  {
    value: "auto",
    clips: "yes",
    container: "yes",
    when: "A region is meant to scroll. Scrollbar appears only when needed. The default you reach for.",
  },
  {
    value: "scroll",
    clips: "yes",
    container: "yes",
    when: "Almost never in 2026. Scrollbars show even when content fits.",
  },
];

// Outer bordered card. Pins color-scheme so the hard-coded tints render the same
// in dark mode, and resets prose margins on the wrapper itself.
const card = [
  reset,
  "color-scheme: light",
  `background: ${CARD_BG}`,
  `border: 1px solid ${CARD_BRD}`,
  "border-radius: 14px",
  "padding: 14px",
  "box-sizing: border-box",
  "overflow: hidden",
].join("; ");

// Four columns: value (intrinsic) | clips? (intrinsic) | scroll container?
// (intrinsic, the focal one) | when (flexes to fill). Row gap separates rows;
// the focal column's wash spans the whole column via a tile background on each
// of its cells (header + body), so it reads as one continuous strip.
const grid = [
  reset,
  "display: grid",
  "grid-template-columns: minmax(92px, max-content) max-content max-content minmax(0, 1fr)",
  "align-items: stretch",
  "column-gap: 10px",
  "row-gap: 8px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Column header label. `focus` swaps to the filled blue chip that marks the
// column the student is told to read by.
const headStyle = (focus = false) =>
  [
    reset,
    sans,
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "line-height: 1.1",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "text-align: center",
    "padding: 6px 10px",
    "border-radius: 7px",
    focus ? `background: ${FOCUS_HEAD_BG}` : "background: transparent",
    focus ? `color: ${FOCUS_HEAD_INK}` : `color: ${HEAD_INK}`,
    "box-sizing: border-box",
  ].join("; ");

// The leftmost header sits over the value column and is left-aligned to match its
// cells.
const headStyleLeft = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1.1",
  "display: flex",
  "align-items: center",
  "padding: 6px 4px",
  `color: ${HEAD_INK}`,
  "box-sizing: border-box",
].join("; ");

// The monospace value tile — faint blue tint + accent left rule so the "CSS
// value" column is distinct, echoing L7's utility column.
const valueCell = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 600",
  "line-height: 1.2",
  "display: flex",
  "align-items: center",
  "padding: 9px 12px",
  "border-radius: 8px",
  `background: ${VALUE_TINT}`,
  `color: ${VALUE_INK}`,
  `border-left: 3px solid ${VALUE_BRD}`,
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

// A pill-bearing cell. The focal column carries the faint column wash so it reads
// as a continuous strip down the table.
const pillCell = (focus = false) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "padding: 9px 8px",
    "border-radius: 8px",
    focus ? `background: ${FOCUS_COL_BG}` : "background: transparent",
    "box-sizing: border-box",
  ].join("; ");

// The Yes/No pill itself.
const pill = (kind: Pill, focus: boolean) => {
  const tone = focus
    ? kind === "yes"
      ? loudYes
      : loudNo
    : kind === "yes"
      ? quietYes
      : quietNo;
  return [
    reset,
    sans,
    "font-size: 12px",
    "font-weight: 700",
    "line-height: 1",
    "display: inline-flex",
    "align-items: center",
    "padding: 4px 11px",
    "border-radius: 999px",
    "border: 1px solid transparent",
    tone,
    "box-sizing: border-box",
    "white-space: nowrap",
  ].join("; ");
};

// The plain-language "reach for it when" gloss — muted sans, wraps freely.
const whenCell = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.4",
  "display: flex",
  "align-items: center",
  "padding: 9px 4px",
  `color: ${GLOSS_INK}`,
  "box-sizing: border-box",
].join("; ");
---

<div class="not-content" style={card}>
  <div style={grid}>
    {/* Header row — the third label (Scroll container?) is the emphasized chip */}
    <div style={headStyleLeft}>Value</div>
    <div style={headStyle(false)}>Clips?</div>
    <div style={headStyle(true)}>Scroll container?</div>
    <div style={headStyleLeft}>Reach for it when&hellip;</div>

    {/* One grid row per value — four sibling cells so the row reads edge to edge */}
    {
      rows.map((r) => (
        <Fragment>
          <div style={valueCell}>{r.value}</div>
          <div style={pillCell(false)}>
            <span style={pill(r.clips, false)}>
              {r.clips === "yes" ? "Yes" : "No"}
            </span>
          </div>
          <div style={pillCell(true)}>
            <span style={pill(r.container, true)}>
              {r.container === "yes" ? "Yes" : "No"}
            </span>
          </div>
          <div style={whenCell}>{r.when}</div>
        </Fragment>
      ))
    }
  </div>
</div>
