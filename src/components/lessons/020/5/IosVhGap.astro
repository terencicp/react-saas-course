---
// Opening visual hook for Chapter 020 L5 (Sizing): the iOS `100vh` bug made
// visible in 5 seconds. The SAME hero — same `100vh` height in both — shown in
// two states side by side, so the gap between what you designed and what the
// phone renders is read at a glance before any prose explains the mechanism.
//
//   LEFT  — "What you designed": a phone with a full-screen hero, a centred
//            headline bar and a call-to-action button comfortably above the
//            bottom edge. Nothing is hidden; the whole `100vh` box fits the
//            visible viewport because (in this idealised state) the address bar
//            is collapsed.
//   RIGHT — "What iOS renders": the SAME phone, the SAME hero at the SAME
//            `100vh` height — but the browser's address bar is showing and eats
//            the bottom slice of the visible viewport. Because the hero is sized
//            to the *largest* viewport (`100vh` = `lvh`, address bar gone), its
//            bottom now runs UNDER the address bar. The CTA button lives in that
//            overlap, so it ends up hidden behind the bar. The overlap slice is
//            tinted with a warning accent to flag "this is off-screen / hidden".
//
// The whole point is that the hero geometry is identical between the two phones —
// only the visible viewport changed. Both heroes are the same fixed pixel height
// on screen; the right phone simply paints an address-bar strip over its lower
// portion and shades the part of the hero swallowed by it.
//
// This is a "make the pain visible" illustration, not an interactive — the
// surrounding prose carries the mechanism (lvh/svh/dvh come later in the lesson).
//
// Colours are hard-coded illustration tints with `color-scheme: light` pinned —
// the sanctioned divergence from the OKLCH @theme tokens for figures (matches
// FlexLayout / RaggedFlexVsEvenGrid in this chapter). A neutral dark-slate hero
// keeps the "your design" surface meaning-free; one amber/red warning accent
// flags the hidden region — deliberately NOT reusing the box-model lesson's
// content/padding/border/margin colour mapping. Every element carries
// `margin: 0` to defeat Starlight's prose-margin injection into flex children.

import Figure from "../../../figures/Figure.astro";

// --- Illustration palette (hard-coded, not @theme — see header note) ---
const HERO_TOP = "#1e293b"; // slate 800 — hero gradient top
const HERO_BOT = "#0f172a"; // slate 900 — hero gradient bottom
const HEADLINE = "#f8fafc"; // slate 50 — headline bar (placeholder text)
const SUBLINE = "#94a3b8"; // slate 400 — sub-headline bar

const CTA_BG = "#3b82f6"; // blue 500 — the call-to-action button
const CTA_INK = "#ffffff"; // button label

const BAR_BG = "#e2e8f0"; // slate 200 — browser address-bar chrome
const BAR_FIELD = "#ffffff"; // the URL field inside the bar
const BAR_BRD = "#cbd5e1"; // slate 300 — bar top edge / field border
const BAR_INK = "#64748b"; // slate 500 — faux URL text

const WARN = "#dc2626"; // red 600 — "hidden / off-screen" accent
const WARN_WASH = "rgba(220, 38, 38, 0.16)"; // tint over the swallowed slice

const PHONE_BODY = "#0b1220"; // near-black phone bezel
const PHONE_NOTCH = "#000000"; // notch / speaker

const LABEL_INK = "#475569"; // slate 600 — column heading
const LABEL_OK = "#16a34a"; // green 600 — "what you designed" tick
const FRAME_BG = "#f8fafc"; // slate 50 — figure body fill

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// On-screen geometry. Both phones share these so the heroes are pixel-identical.
const SCREEN_W = 184; // visible screen width
const SCREEN_H = 348; // visible screen height (this is "100vh" in both phones)
const BAR_H = 56; // address-bar height on the right phone (the bottom slice)

// A phone bezel wrapping a fixed-size screen. The screen is `position: relative`
// so the address bar (right phone) can be absolutely pinned to its bottom and
// the hero can fill it edge to edge underneath.
const phoneBody = [
  "margin: 0",
  "box-sizing: border-box",
  `background: ${PHONE_BODY}`,
  "border-radius: 30px",
  "padding: 10px",
  `box-shadow: 0 10px 30px -12px rgba(2, 6, 23, 0.55)`,
  "flex: 0 0 auto",
].join("; ");

const screen = [
  "margin: 0",
  "position: relative",
  "overflow: hidden",
  `width: ${SCREEN_W}px`,
  `height: ${SCREEN_H}px`,
  "border-radius: 22px",
].join("; ");

const notch = [
  "margin: 0",
  "position: absolute",
  "top: 0",
  "left: 50%",
  "transform: translateX(-50%)",
  "width: 64px",
  "height: 16px",
  `background: ${PHONE_NOTCH}`,
  "border-bottom-left-radius: 10px",
  "border-bottom-right-radius: 10px",
  "z-index: 5",
].join("; ");

// The hero: a full-height (= 100vh) column with the headline group centred and
// the CTA pinned toward the bottom. IDENTICAL on both phones.
const hero = [
  "margin: 0",
  "box-sizing: border-box",
  "position: absolute",
  "inset: 0",
  `height: ${SCREEN_H}px`, // exactly "100vh" — the same on both phones
  `background: linear-gradient(160deg, ${HERO_TOP}, ${HERO_BOT})`,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "padding: 28px 20px",
].join("; ");

const headlineBar = [
  "margin: 0",
  `background: ${HEADLINE}`,
  "border-radius: 4px",
  "height: 11px",
  "width: 70%",
].join("; ");

const headlineBar2 = [
  "margin: 8px 0 0",
  `background: ${HEADLINE}`,
  "border-radius: 4px",
  "height: 11px",
  "width: 48%",
].join("; ");

const subBar = [
  "margin: 14px 0 0",
  `background: ${SUBLINE}`,
  "border-radius: 3px",
  "height: 7px",
  "width: 60%",
].join("; ");

// The CTA is pinned a fixed distance from the hero's bottom. On the left phone
// that distance sits above the screen edge (visible). On the right phone the
// address bar covers the same band, so the button lands behind it.
const ctaWrap = [
  "margin: 0",
  "position: absolute",
  "left: 0",
  "right: 0",
  "bottom: 26px",
  "display: flex",
  "justify-content: center",
].join("; ");

const cta = (hidden = false) =>
  [
    "margin: 0",
    `background: ${CTA_BG}`,
    `color: ${CTA_INK}`,
    "font-size: 0.72rem",
    "font-weight: 700",
    "border-radius: 8px",
    "padding: 7px 16px",
    "white-space: nowrap",
    `box-shadow: 0 0 0 1.5px ${hidden ? WARN : "transparent"}`,
  ].join("; ");

// The browser address bar (right phone only): pinned to the bottom of the
// screen, painted OVER the hero so the hero's bottom slice disappears behind it.
const addressBar = [
  "margin: 0",
  "box-sizing: border-box",
  "position: absolute",
  "left: 0",
  "right: 0",
  "bottom: 0",
  `height: ${BAR_H}px`,
  `background: ${BAR_BG}`,
  `border-top: 1px solid ${BAR_BRD}`,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 6px",
  "padding: 0 14px 8px",
  "z-index: 4",
].join("; ");

const urlField = [
  "margin: 0",
  "box-sizing: border-box",
  `background: ${BAR_FIELD}`,
  `border: 1px solid ${BAR_BRD}`,
  "border-radius: 999px",
  "height: 18px",
  "display: flex",
  "align-items: center",
  "padding: 0 10px",
  `color: ${BAR_INK}`,
  "font-size: 0.5rem",
  "letter-spacing: 0.02em",
].join("; ");

// The warning wash marking the slice of the hero swallowed by the address bar.
// Sits just ABOVE the bar (z below it), tinting the overlap band so the viewer
// reads "this part of your 100vh hero is past the bottom of what's visible".
const swallowedSlice = [
  "margin: 0",
  "position: absolute",
  "left: 0",
  "right: 0",
  `bottom: ${BAR_H}px`,
  "height: 36px",
  `background: linear-gradient(to top, ${WARN_WASH}, transparent)`,
  "z-index: 3",
].join("; ");

// Column heading above each phone.
const colLabel = [
  "margin: 0 0 10px",
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "font-size: 0.78rem",
  "font-weight: 700",
  `color: ${LABEL_INK}`,
].join("; ");

const column = "margin: 0; display: flex; flex-direction: column; align-items: center;";

// Tiny floating tag that points at the hidden CTA on the right phone.
const hiddenTag = [
  "margin: 0",
  "position: absolute",
  "right: -8px",
  `bottom: ${BAR_H + 4}px`,
  "transform: translateX(100%)",
  `background: ${WARN}`,
  "color: #ffffff",
  "font-size: 0.6rem",
  "font-weight: 700",
  "white-space: nowrap",
  "padding: 3px 7px",
  "border-radius: 6px",
  "line-height: 1.2",
  "box-shadow: 0 4px 10px -4px rgba(220, 38, 38, 0.6)",
].join("; ");
---

<Figure>
  <div
    style={`color-scheme: light; font-family: ${sans}; background: ${FRAME_BG}; border-radius: 12px; display: flex; flex-wrap: wrap; justify-content: center; align-items: flex-start; column-gap: 56px; row-gap: 28px; padding: 8px 4px;`}
  >
    {/* ----------------------- LEFT: what you designed ----------------------- */}
    <div style={column}>
      <p style={colLabel}>
        <span style={`color: ${LABEL_OK}; font-size: 0.95rem; line-height: 1;`}>{"✓"}</span>
        <span style="margin: 0;">{"What you designed"}</span>
      </p>
      <div style={phoneBody}>
        <div style={screen}>
          <div style={notch}></div>
          <div style={hero}>
            <div style={headlineBar}></div>
            <div style={headlineBar2}></div>
            <div style={subBar}></div>
          </div>
          <div style={ctaWrap}>
            <span style={cta(false)}>{"Get started"}</span>
          </div>
        </div>
      </div>
      <p style={`margin: 10px 0 0; font-size: 0.72rem; color: ${LABEL_INK};`}>
        {"Button sits comfortably above the bottom edge."}
      </p>
    </div>

    {/* --------------------- RIGHT: what iOS renders ------------------------- */}
    <div style={column}>
      <p style={colLabel}>
        <span style={`color: ${WARN}; font-size: 0.95rem; line-height: 1;`}>{"✕"}</span>
        <span style="margin: 0;">{"What iOS renders"}</span>
      </p>
      <div style={phoneBody}>
        <div style={screen}>
          <div style={notch}></div>
          {/* SAME hero, SAME 100vh height as the left phone */}
          <div style={hero}>
            <div style={headlineBar}></div>
            <div style={headlineBar2}></div>
            <div style={subBar}></div>
          </div>
          {/* The CTA is at the same spot in the hero — now in the danger band */}
          <div style={ctaWrap}>
            <span style={cta(true)}>{"Get started"}</span>
          </div>
          {/* Warning wash over the slice the address bar swallows */}
          <div style={swallowedSlice}></div>
          {/* The browser chrome, painted OVER the hero's bottom */}
          <div style={addressBar}>
            <div style={urlField}>{"yoursaas.com"}</div>
          </div>
          {/* Pointer tag flagging the hidden button */}
          <div style={hiddenTag}>{"← button hidden"}</div>
        </div>
      </div>
      <p style={`margin: 10px 0 0; font-size: 0.72rem; color: ${WARN}; font-weight: 600;`}>
        {"Address bar covers the bottom of the hero — the button is unreachable."}
      </p>
    </div>
  </div>

  <Fragment slot="caption">
    The hero is the same <code style={`font-family: ${mono};`}>100vh</code> in both phones &mdash; its height never changed.
    Only the visible viewport did: with the address bar showing, <code style={`font-family: ${mono};`}>100vh</code> runs past the bottom of the screen, so the button at the bottom of the hero ends up behind the bar.
  </Fragment>
</Figure>
