---
// The sizing mental-model figure for Chapter 020 L5: for three kinds of element,
// which AXIS is forced (extrinsic) and which is content-driven (intrinsic),
// colour-coded. The whole lesson hangs off this asymmetry, so the figure's job is
// to make "the display mode already decided which axis is forced" spatial and
// memorable BEFORE the utility tables.
//
// THREE real specimens, left to right, each a genuine devtools-inspectable box
// (per the HTML+CSS diagram doc — "layout concepts rendered with real CSS"), not
// absolutely-positioned fakes:
//
//   1. Block <div>   — a real block box inside a faint parent outline. Its WIDTH
//                       fills the parent (forced); its HEIGHT grows to fit a line
//                       of placeholder text (content-driven).
//   2. Inline <span> — a real inline box hugging a short word inside a line of
//                       text. BOTH axes content-driven (it ignores width/height).
//   3. Flex item     — a real `flex: 1` item in a `display: flex` row with two
//                       siblings. Its MAIN axis (horizontal) is forced by the flex
//                       track; its CROSS axis (vertical) is content-driven.
//
// Each axis is annotated with a thin DOUBLE-HEADED arrow running ALONG the
// relevant edge (width = a horizontal arrow above the box; height = a vertical
// arrow beside it), tinted by the legend: violet = forced (extrinsic), teal =
// content-driven (intrinsic). A compact legend sits at the top.
//
// COLOUR DISCIPLINE: the box-model lesson (L1) fixed content=blue / padding=green
// / border=yellow / margin=orange. This is a NEW axis-colouring, so the two hues
// are deliberately OUTSIDE that set — violet (forced) and teal (content-driven) —
// per the lesson outline's instruction. Hard-coded illustration tints with
// `color-scheme: light` pinned (the sanctioned divergence from @theme tokens for
// figures, matching IosVhGap / FlexLayout in this chapter). `margin: 0` on every
// element defeats Starlight's prose-margin injection into flex children.

import Figure from "../../../figures/Figure.astro";

// --- Axis palette (hard-coded illustration, not @theme — see header note) ---
const FORCED = "#7c3aed"; // violet 600 — forced / extrinsic axis
const FORCED_INK = "#5b21b6"; // violet 800 — forced label text
const CONTENT = "#0d9488"; // teal 600 — content-driven / intrinsic axis
const CONTENT_INK = "#0f766e"; // teal 700 — content label text

// Neutral specimen surfaces (meaning-free, so the axis colours read as the only
// signal). Each specimen gets a faint card so the three read as separate cases.
const SPEC_BG = "#ffffff"; // specimen card fill
const SPEC_BRD = "#e2e8f0"; // slate 200 — specimen card edge
const PARENT_BRD = "#cbd5e1"; // slate 300 — the faint "parent" outline (dashed)

const BOX_BG = "#f1f5f9"; // slate 100 — the element box fill
const BOX_BRD = "#94a3b8"; // slate 400 — the element box edge
const BOX_INK = "#334155"; // slate 700 — placeholder text inside a box

const SIB_BG = "#f8fafc"; // slate 50 — inert flex siblings
const SIB_BRD = "#e2e8f0"; // slate 200 — inert flex sibling edge
const SIB_INK = "#94a3b8"; // slate 400 — inert sibling label

const FLEX_BRD = "#cbd5e1"; // slate 300 — the flex container outline (dashed)

const HEAD = "#0f172a"; // slate 900 — specimen heading
const TAG_INK = "#64748b"; // slate 500 — the <div>/<span> code tag
const NOTE_INK = "#64748b"; // slate 500 — the small footnote under the span
const FRAME_BG = "#f8fafc"; // slate 50 — figure body fill
const TEXT_INK = "#475569"; // slate 600 — the line of body text around the span

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// --- Double-headed axis arrow ------------------------------------------------
// A thin line with a chevron at BOTH ends, oriented horizontally (a width axis,
// drawn above the box) or vertically (a height axis, drawn beside the box). Built
// from flex so it stretches to whatever length its slot gives it.

const ARROW_THICK = 2; // shaft thickness in px

// Chevron pointing in one of four directions, as a bare CSS triangle.
const chevron = (color: string, dir: "left" | "right" | "up" | "down") => {
  const s = 6; // half-base
  const len = 7; // point length
  const base = ["margin: 0", "width: 0", "height: 0", "flex: none"];
  if (dir === "left") {
    base.push(
      `border-top: ${s}px solid transparent`,
      `border-bottom: ${s}px solid transparent`,
      `border-right: ${len}px solid ${color}`,
    );
  } else if (dir === "right") {
    base.push(
      `border-top: ${s}px solid transparent`,
      `border-bottom: ${s}px solid transparent`,
      `border-left: ${len}px solid ${color}`,
    );
  } else if (dir === "up") {
    base.push(
      `border-left: ${s}px solid transparent`,
      `border-right: ${s}px solid transparent`,
      `border-bottom: ${len}px solid ${color}`,
    );
  } else {
    base.push(
      `border-left: ${s}px solid transparent`,
      `border-right: ${s}px solid transparent`,
      `border-top: ${len}px solid ${color}`,
    );
  }
  return base.join("; ");
};

const arrowRow = (horizontal: boolean) =>
  [
    "margin: 0",
    "display: flex",
    "align-items: center",
    horizontal ? "flex-direction: row" : "flex-direction: column",
    horizontal ? "width: 100%" : "height: 100%",
  ].join("; ");

const shaft = (color: string, horizontal: boolean) =>
  [
    "margin: 0",
    `background: ${color}`,
    "border-radius: 2px",
    "flex: 1 1 auto",
    horizontal ? `height: ${ARROW_THICK}px` : `width: ${ARROW_THICK}px`,
  ].join("; ");

// The label that names how the axis is sized — placed on/near the arrow.
const axisLabel = (color: string) =>
  [
    "margin: 0",
    `font-family: ${sans}`,
    "font-size: 0.66rem",
    "font-weight: 700",
    "line-height: 1.25",
    "letter-spacing: 0.01em",
    "white-space: nowrap",
    `color: ${color}`,
    "text-align: center",
  ].join("; ");

// --- Shared specimen chrome --------------------------------------------------
const specimenCard = [
  "margin: 0",
  "box-sizing: border-box",
  `background: ${SPEC_BG}`,
  `border: 1px solid ${SPEC_BRD}`,
  "border-radius: 12px",
  "padding: 14px 16px 16px",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "flex: 1 1 230px",
  "min-width: 220px",
  "max-width: 300px",
].join("; ");

const specHeading = [
  "margin: 0",
  "display: flex",
  "align-items: baseline",
  "gap: 8px",
  "flex-wrap: wrap",
].join("; ");

const specName = [
  "margin: 0",
  `font-family: ${sans}`,
  "font-size: 0.84rem",
  "font-weight: 700",
  `color: ${HEAD}`,
].join("; ");

const specTag = [
  "margin: 0",
  `font-family: ${mono}`,
  "font-size: 0.72rem",
  `color: ${TAG_INK}`,
].join("; ");

// The element box that the arrows annotate (used differently per specimen).
const elementBox = [
  "margin: 0",
  "box-sizing: border-box",
  `background: ${BOX_BG}`,
  `border: 1px solid ${BOX_BRD}`,
  "border-radius: 8px",
  "display: flex",
  "align-items: center",
  "padding: 10px 12px",
  `color: ${BOX_INK}`,
  `font-family: ${sans}`,
  "font-size: 0.7rem",
  "line-height: 1.4",
].join("; ");
---

<Figure>
  <div
    style={`color-scheme: light; font-family: ${sans}; background: ${FRAME_BG}; border-radius: 12px; padding: 14px 12px; display: flex; flex-direction: column; gap: 16px;`}
  >
    {/* ----------------------------- legend ----------------------------- */}
    <div
      style="margin: 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 8px 22px;"
    >
      <span style="margin: 0; display: inline-flex; align-items: center; gap: 8px;">
        <span style={`margin: 0; width: 26px; height: ${ARROW_THICK}px; background: ${FORCED}; border-radius: 2px;`}></span>
        <span style={`margin: 0; font-size: 0.74rem; font-weight: 700; color: ${FORCED_INK};`}>
          {"Forced"}
          <span style={`font-weight: 500; color: ${TAG_INK};`}>{" (extrinsic) — something outside sets it"}</span>
        </span>
      </span>
      <span style="margin: 0; display: inline-flex; align-items: center; gap: 8px;">
        <span style={`margin: 0; width: 26px; height: ${ARROW_THICK}px; background: ${CONTENT}; border-radius: 2px;`}></span>
        <span style={`margin: 0; font-size: 0.74rem; font-weight: 700; color: ${CONTENT_INK};`}>
          {"Content-driven"}
          <span style={`font-weight: 500; color: ${TAG_INK};`}>{" (intrinsic) — the content sets it"}</span>
        </span>
      </span>
    </div>

    {/* --------------------------- specimens --------------------------- */}
    <div
      style="margin: 0; display: flex; flex-wrap: wrap; justify-content: center; align-items: stretch; gap: 18px;"
    >
      {/* ===================== 1 · BLOCK <div> ===================== */}
      <div style={specimenCard}>
        <p style={specHeading}>
          <span style={specName}>{"Block"}</span>
          <span style={specTag}>{"<div>"}</span>
        </p>

        {/* width arrow above, spanning the full parent width */}
        <div style="margin: 0; display: flex; flex-direction: column; gap: 4px;">
          <div style={arrowRow(true)}>
            <div style={chevron(FORCED, "left")}></div>
            <div style={shaft(FORCED, true)}></div>
            <div style={chevron(FORCED, "right")}></div>
          </div>
          <span style={axisLabel(FORCED_INK)}>{"width — forced (fills parent)"}</span>
        </div>

        {/* height arrow (left) + the real block box inside its parent outline */}
        <div style="margin: 0; display: flex; align-items: stretch; gap: 8px;">
          <div style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 4px;">
            <div style={`${arrowRow(false)}; flex: 1 1 auto;`}>
              <div style={chevron(CONTENT, "up")}></div>
              <div style={shaft(CONTENT, false)}></div>
              <div style={chevron(CONTENT, "down")}></div>
            </div>
          </div>

          {/* the faint PARENT: the block fills its width, sits at its top */}
          <div
            style={`margin: 0; box-sizing: border-box; flex: 1 1 auto; border: 1px dashed ${PARENT_BRD}; border-radius: 10px; padding: 8px; display: flex; flex-direction: column;`}
          >
            <div style={elementBox}>{"text grows the height"}</div>
          </div>
        </div>
        <span style={`margin: 0; ${axisLabel(CONTENT_INK)}; text-align: left; padding-left: 22px;`}>
          {"height — content-driven (fits content)"}
        </span>
      </div>

      {/* ===================== 2 · INLINE <span> ===================== */}
      <div style={specimenCard}>
        <p style={specHeading}>
          <span style={specName}>{"Inline"}</span>
          <span style={specTag}>{"<span>"}</span>
        </p>

        {/* width arrow above — only as wide as the word it hugs */}
        <div style="margin: 0; display: flex; flex-direction: column; align-items: center; gap: 4px;">
          <div style="margin: 0; display: flex; flex-direction: row; align-items: center; width: 96px;">
            <div style={chevron(CONTENT, "left")}></div>
            <div style={shaft(CONTENT, true)}></div>
            <div style={chevron(CONTENT, "right")}></div>
          </div>
        </div>

        {/* a line of text with a real inline box hugging one word */}
        <div style="margin: 0; display: flex; align-items: center; justify-content: center; gap: 8px;">
          <div style="margin: 0; display: flex; flex-direction: column; align-items: center; height: 30px; justify-content: center;">
            <div style="margin: 0; display: flex; flex-direction: column; align-items: center; height: 30px;">
              <div style={chevron(CONTENT, "up")}></div>
              <div style={shaft(CONTENT, false)}></div>
              <div style={chevron(CONTENT, "down")}></div>
            </div>
          </div>

          <p
            style={`margin: 0; font-family: ${sans}; font-size: 0.78rem; line-height: 1.7; color: ${TEXT_INK}; text-align: center;`}
          >
            {"the price is "}
            <span
              style={`margin: 0; background: ${BOX_BG}; border: 1px solid ${BOX_BRD}; border-radius: 5px; padding: 1px 6px; color: ${BOX_INK}; font-weight: 700;`}
            >{"free"}</span>
            {" today"}
          </p>
        </div>

        <span style={`margin: 0; ${axisLabel(CONTENT_INK)}`}>
          {"both axes — content-driven"}
        </span>
        <p style={`margin: 0; font-family: ${sans}; font-size: 0.66rem; color: ${NOTE_INK}; text-align: center; line-height: 1.4;`}>
          {"ignores "}
          <code style={`font-family: ${mono};`}>{"width"}</code>
          {" & "}
          <code style={`font-family: ${mono};`}>{"height"}</code>
        </p>
      </div>

      {/* ===================== 3 · FLEX ITEM ===================== */}
      <div style={specimenCard}>
        <p style={specHeading}>
          <span style={specName}>{"Flex item"}</span>
          <span style={specTag}>{"flex-1"}</span>
        </p>

        {/* the REAL flex row: one flex-1 item + two inert siblings */}
        <div
          style={`margin: 0; box-sizing: border-box; display: flex; gap: 8px; border: 1px dashed ${FLEX_BRD}; border-radius: 10px; padding: 8px; align-items: stretch;`}
        >
          {/* the flex-1 item, with a horizontal MAIN-axis arrow drawn across it */}
          <div style="margin: 0; flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; gap: 4px;">
            <div style={arrowRow(true)}>
              <div style={chevron(FORCED, "left")}></div>
              <div style={shaft(FORCED, true)}></div>
              <div style={chevron(FORCED, "right")}></div>
            </div>
            <div
              style={`margin: 0; box-sizing: border-box; background: ${BOX_BG}; border: 1px solid ${BOX_BRD}; border-radius: 8px; padding: 10px 8px; color: ${BOX_INK}; font-family: ${sans}; font-size: 0.7rem; font-weight: 700; text-align: center;`}
            >{"flex-1"}</div>
          </div>

          {/* two inert siblings, sitting at the top so they don't stretch */}
          <div style={`margin: 0; align-self: flex-start; box-sizing: border-box; background: ${SIB_BG}; border: 1px solid ${SIB_BRD}; border-radius: 8px; padding: 10px 10px; color: ${SIB_INK}; font-family: ${sans}; font-size: 0.7rem; margin-top: 19px;`}>{"·"}</div>
          <div style={`margin: 0; align-self: flex-start; box-sizing: border-box; background: ${SIB_BG}; border: 1px solid ${SIB_BRD}; border-radius: 8px; padding: 10px 10px; color: ${SIB_INK}; font-family: ${sans}; font-size: 0.7rem; margin-top: 19px;`}>{"·"}</div>

          {/* cross-axis (vertical) arrow on the far right of the row */}
          <div style="margin: 0; align-self: stretch; display: flex; flex-direction: column; align-items: center; margin-top: 19px;">
            <div style={`${arrowRow(false)}; flex: 1 1 auto;`}>
              <div style={chevron(CONTENT, "up")}></div>
              <div style={shaft(CONTENT, false)}></div>
              <div style={chevron(CONTENT, "down")}></div>
            </div>
          </div>
        </div>

        <span style={`margin: 0; ${axisLabel(FORCED_INK)}`}>
          {"main axis — forced (flex track)"}
        </span>
        <span style={`margin: 0; ${axisLabel(CONTENT_INK)}`}>
          {"cross axis — content-driven"}
        </span>
      </div>
    </div>
  </div>

  <Fragment slot="caption">
    The display mode decides which axis is forced. A sizing utility only bites on an axis the layout algorithm hasn't already claimed.
  </Fragment>
</Figure>
