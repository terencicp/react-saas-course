---
// Interactive viewport-unit simulator for Chapter 020 L5 (Sizing). Its whole job
// is to make `dvh` / `svh` / `lvh` (and `vh`, which equals `lvh`) legible on a
// LAPTOP, where you can't feel the iOS address-bar behavior the units exist for.
//
// Real viewport units measure the actual browser window, so they can't be faked
// with CSS custom properties (the lesson outline flagged this — hence a dedicated
// component, NOT a ParamPlayground). Instead we mock a phone whose "screen" is a
// fixed pixel box of height H, and size each unit-bar as a fraction of THAT box:
//
//   • vh / lvh bar  = H ALWAYS              (the LARGEST viewport — chrome gone)
//   • svh bar       = SMALL·H ALWAYS        (the SMALLEST viewport — chrome shown)
//   • dvh bar       = the CURRENT viewport  (H when bar hidden, SMALL·H when shown)
//
// A single toggle shows / hides a simulated address bar pinned to the BOTTOM of
// the screen. The bar paints OVER the lower slice of the bars, so the viewer
// literally watches the vh/lvh bar run off behind it (the iOS bug) while svh
// stops short and dvh tracks the bar exactly.
//
// Problem regions are tinted so the three behaviors read at a glance:
//   • bar SHOWN  → the slice of the vh/lvh bar hidden behind the address bar gets
//                  a red "content hidden behind the bar" wash (the iOS bug).
//   • bar HIDDEN → the gap above the svh bar gets a muted "dead space" wash.
// A live caption under the frame echoes the current state.
//
// INTERACTIVE, so unlike this lesson's two static figures (IosVhGap,
// IntrinsicExtrinsicAxes) it carries a `<style>` block + a client `<script>` and
// self-provides its card chrome (matching ParamPlayground / JankComparison) — it
// is NOT wrapped in <Figure>, which would double the card and risk the
// lightbox-relocation detaching the toggle's listener. `.not-content` opts the
// widget out of Starlight's prose styling; a scoped `.vus` root namespaces every
// rule. Colours are hard-coded illustration tints (the chapter's sanctioned
// divergence from @theme tokens for figures) with `color-scheme: light` pinned —
// red (#dc2626) reuses this lesson's "problem / hidden" accent from IosVhGap.
//
// On toggle, the script writes a small set of CSS custom properties on the root
// (the dvh bar's height, the address-bar shift/opacity, the red-slice opacity, the
// dead-space height/opacity) and mirrors the state into `data-bar` + the caption.
// Driving the dynamic dimensions through inherited custom properties (rather than
// attribute-selector descendant rules) keeps the recalc reliable and matches the
// JankComparison pattern. The toggle is a real <button aria-pressed> so it has a
// single, unambiguous hit area. The static bars (vh = full screen, svh = small
// viewport) never change, so they keep plain heights.
//
// On-screen phone geometry (the CSS below mirrors these literal pixels): H is the
// full screen height = "100vh / 100lvh"; the address bar takes (1 − SMALL) of it,
// so the small viewport (svh) is SMALL·H and the address bar / swallowed slice is
// BAR_H. These constants document the numbers the stylesheet hard-codes.
const H = 300; // px — full screen height (the LARGE viewport)
const SMALL = 0.82; // small-viewport fraction (≈ chrome takes 18% of the screen)
const SMALL_H = Math.round(H * SMALL); // 246px — the SMALL viewport height (svh)
const BAR_H = H - SMALL_H; // 54px — address-bar height (the swallowed slice)
---

<div class="vus not-content" data-vus-root data-bar="shown">
	<div class="vus-stage">
		{/* ---------------- the phone ---------------- */}
		<div class="vus-phone">
			<div class="vus-screen">
				<div class="vus-notch"></div>

				{/* The three unit-bars, growing UP from the bottom of the screen.
				    Each is "100 of its unit" tall; the address bar (below) paints
				    over their lower slice. */}
				<div class="vus-bars">
					{/* vh = lvh — always the full screen height (the bug bar) */}
					<div class="vus-col">
						<div class="vus-bar vus-bar-vh">
							{/* the slice that ends up hidden behind the address bar */}
							<div class="vus-hidden-slice"></div>
							<span class="vus-bar-label">vh<br />= lvh</span>
						</div>
					</div>

					{/* svh — always the small-viewport height */}
					<div class="vus-col">
						<div class="vus-bar vus-bar-svh">
							<span class="vus-bar-label">svh</span>
						</div>
						{/* the dead-space gap BELOW svh, marked when the bar is hidden */}
						<div class="vus-deadspace"></div>
					</div>

					{/* dvh — tracks the current viewport (the always-correct bar) */}
					<div class="vus-col">
						<div class="vus-bar vus-bar-dvh">
							<span class="vus-bar-label">dvh</span>
						</div>
					</div>
				</div>

				{/* The simulated browser address bar, pinned to the screen bottom,
				    painted OVER the lower slice of the bars. */}
				<div class="vus-addressbar">
					<div class="vus-urlfield">yoursaas.com</div>
				</div>
			</div>
		</div>

		{/* ---------------- the control + legend ---------------- */}
		<div class="vus-side">
			<div class="vus-control">
				<span class="vus-control-label">Address bar</span>
				<button
					type="button"
					class="vus-toggle"
					data-vus-toggle
					aria-pressed="true"
					aria-label="Toggle the simulated address bar"
				>
					<span class="vus-toggle-track">
						<span class="vus-toggle-knob"></span>
					</span>
					<span class="vus-toggle-text" data-vus-toggle-text>shown</span>
				</button>
				<p class="vus-control-hint">
					Flip it to scroll the bar away, like you would on a phone.
				</p>
			</div>

			<ul class="vus-legend">
				<li>
					<span class="vus-swatch vus-sw-vh"></span>
					<span><b>vh / lvh</b> — the largest the viewport ever gets</span>
				</li>
				<li>
					<span class="vus-swatch vus-sw-svh"></span>
					<span><b>svh</b> — the smallest, with the bar showing</span>
				</li>
				<li>
					<span class="vus-swatch vus-sw-dvh"></span>
					<span><b>dvh</b> — the live viewport, right now</span>
				</li>
			</ul>
		</div>
	</div>

	{/* live caption echoing the state */}
	<p class="vus-caption">
		<span class="vus-cap-when" data-vus-cap-when>Address bar shown</span>
		<span class="vus-cap-sep">&rarr;</span>
		<span class="vus-cap-body" data-vus-cap-body>
			<b class="vus-bad">vh</b> overflows behind it,
			<b class="vus-ok">svh</b> fits, <b class="vus-ok">dvh</b> fits.
		</span>
	</p>
</div>

<style>
	.vus {
		/* hard-coded illustration palette — pinned light, like the lesson's
		   other figures (sanctioned divergence from @theme tokens) */
		color-scheme: light;
		--vus-frame-bg: #f8fafc; /* slate 50 — stage fill */
		--vus-phone-body: #0b1220; /* near-black bezel */
		--vus-screen-bg: #eef2f6; /* the screen behind the bars */
		--vus-notch: #000000;

		--vus-vh: #6366f1; /* indigo 500 — the vh/lvh bar */
		--vus-svh: #0d9488; /* teal 600 — the svh bar */
		--vus-dvh: #16a34a; /* green 600 — the dvh bar (always correct) */

		--vus-bar-ink: #ffffff; /* labels sit on saturated bars */

		--vus-bad: #dc2626; /* red 600 — "hidden behind the bar" (matches IosVhGap) */
		--vus-bad-wash: rgba(220, 38, 38, 0.34);
		--vus-dead-wash: repeating-linear-gradient(
			-45deg,
			rgba(100, 116, 139, 0.22) 0,
			rgba(100, 116, 139, 0.22) 5px,
			rgba(100, 116, 139, 0.08) 5px,
			rgba(100, 116, 139, 0.08) 10px
		);

		--vus-bar-bg: #e2e8f0; /* slate 200 — address-bar chrome */
		--vus-bar-field: #ffffff;
		--vus-bar-brd: #cbd5e1; /* slate 300 */
		--vus-bar-url: #64748b; /* slate 500 */

		--vus-ink: #334155; /* slate 700 — body text */
		--vus-muted: #64748b; /* slate 500 — secondary text */

		--vus-accent: #6366f1; /* control accent (indigo) */
		--vus-track: #cbd5e1; /* toggle off track */

		position: relative;
		margin: 1.5rem 0;
		background: var(--vus-frame-bg);
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 18px;
		font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
		color: var(--vus-ink);
	}

	.vus-stage {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 28px 40px;
	}

	/* ----------------------------- the phone ----------------------------- */
	.vus-phone {
		margin: 0;
		box-sizing: border-box;
		background: var(--vus-phone-body);
		border-radius: 30px;
		padding: 10px;
		box-shadow: 0 12px 32px -14px rgba(2, 6, 23, 0.55);
		flex: 0 0 auto;
	}

	.vus-screen {
		margin: 0;
		position: relative;
		overflow: hidden;
		width: 248px;
		height: 300px;
		border-radius: 22px;
		background: var(--vus-screen-bg);
	}

	.vus-notch {
		margin: 0;
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 78px;
		height: 16px;
		background: var(--vus-notch);
		border-bottom-left-radius: 10px;
		border-bottom-right-radius: 10px;
		z-index: 6;
	}

	/* The three bars sit in a row, TOP-aligned, growing downward — exactly like a
	   `height: 100vh` box starts at the top of the page and extends down. So a bar
	   that is taller than the visible viewport runs DOWN past the address bar (the
	   bug), and svh stops short, leaving a gap at the BOTTOM. */
	.vus-bars {
		margin: 0;
		position: absolute;
		inset: 0;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		gap: 18px;
		z-index: 2;
	}

	.vus-col {
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		height: 100%;
		width: 56px;
	}

	.vus-bar {
		margin: 0;
		box-sizing: border-box;
		position: relative;
		flex: 0 0 auto; /* never let flex reinterpret the explicit bar height */
		width: 56px;
		border-top-left-radius: 6px;
		border-top-right-radius: 6px;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 7px;
		transition: height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.vus-bar-label {
		margin: 0;
		font-size: 0.7rem;
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: 0.01em;
		text-align: center;
		color: var(--vus-bar-ink);
	}

	/* vh / lvh — always the FULL screen height. */
	.vus-bar-vh {
		background: var(--vus-vh);
		height: 300px; /* = H, the large viewport */
	}

	/* svh — always the SMALL viewport height. */
	.vus-bar-svh {
		background: var(--vus-svh);
		height: 246px; /* = round(H * 0.82) */
	}

	/* dvh — tracks the CURRENT viewport. Its height is driven by a custom
	   property the script flips (300px bar hidden, 246px bar shown), so the
	   change recalcs reliably instead of relying on attribute-selector rules. */
	.vus-bar-dvh {
		background: var(--vus-dvh);
		height: var(--vus-dvh-h, 246px);
		transition: height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* The red slice inside the vh bar that the address bar swallows — only the
	   bottom BAR_H px, faded in only while the bar is shown (--vus-hidden-op). */
	.vus-hidden-slice {
		margin: 0;
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 54px; /* = BAR_H */
		background: var(--vus-bad-wash);
		border-top: 2px dashed var(--vus-bad);
		opacity: var(--vus-hidden-op, 1);
		transition: opacity 0.3s 0.15s;
		z-index: 1;
	}

	/* The hatched "dead space" gap that appears ABOVE svh when the bar hides.
	   Height + opacity + border colour all driven by script-set properties. */
	.vus-deadspace {
		margin: 0;
		flex: 0 0 auto; /* hold its height; don't let the column shrink it */
		width: 56px;
		height: var(--vus-dead-h, 0px);
		background: var(--vus-dead-wash);
		border: 1px dashed var(--vus-dead-brd, transparent);
		border-radius: 6px;
		box-sizing: border-box;
		opacity: var(--vus-dead-op, 0);
		transition:
			height 0.45s cubic-bezier(0.4, 0, 0.2, 1),
			opacity 0.3s;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	/* The simulated browser address bar, pinned to the screen bottom. It slides
	   down out of frame (--vus-bar-shift) and fades (--vus-bar-op) when hidden. */
	.vus-addressbar {
		margin: 0;
		box-sizing: border-box;
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 54px; /* = BAR_H */
		background: var(--vus-bar-bg);
		border-top: 1px solid var(--vus-bar-brd);
		display: flex;
		align-items: center;
		padding: 0 14px;
		z-index: 4;
		transform: translateY(var(--vus-bar-shift, 0%));
		opacity: var(--vus-bar-op, 1);
		transition:
			transform 0.45s cubic-bezier(0.4, 0, 0.2, 1),
			opacity 0.3s;
	}

	.vus-urlfield {
		margin: 0;
		box-sizing: border-box;
		width: 100%;
		background: var(--vus-bar-field);
		border: 1px solid var(--vus-bar-brd);
		border-radius: 999px;
		height: 22px;
		display: flex;
		align-items: center;
		padding: 0 12px;
		color: var(--vus-bar-url);
		font-size: 0.62rem;
		letter-spacing: 0.01em;
	}

	/* State (bar shown vs hidden) is applied entirely through the custom
	   properties above, set on the root by the script — see the <script>. */

	/* ----------------------------- side panel ---------------------------- */
	.vus-side {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 20px;
		flex: 0 1 280px;
		min-width: 220px;
	}

	.vus-control {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.vus-control-label {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--vus-ink);
	}
	.vus-control-hint {
		margin: 0;
		font-size: 0.72rem;
		line-height: 1.45;
		color: var(--vus-muted);
	}

	/* toggle — a real <button> (single, unambiguous hit area) styled as a
	   ParamPlayground-flavoured switch with an inline state word. */
	.vus-toggle {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		cursor: pointer;
		user-select: none;
		appearance: none;
		-webkit-appearance: none;
		background: none;
		border: 0;
		padding: 0;
		margin: 0;
		font: inherit;
		color: inherit;
		text-align: left;
	}
	.vus-toggle-track {
		position: relative;
		display: inline-block;
		width: 38px;
		height: 22px;
		background: var(--vus-track);
		border-radius: 999px;
		transition: background-color 0.16s;
		flex: 0 0 auto;
	}
	.vus-toggle-knob {
		position: absolute;
		top: 2px;
		left: 2px;
		width: 18px;
		height: 18px;
		background: #ffffff;
		border-radius: 50%;
		box-shadow: 0 1px 3px rgba(2, 6, 23, 0.3);
		transition: transform 0.16s;
	}
	/* "pressed" (aria-pressed="true") = address bar SHOWN = knob to the right */
	.vus-toggle[aria-pressed="true"] .vus-toggle-track {
		background: var(--vus-accent);
	}
	.vus-toggle[aria-pressed="true"] .vus-toggle-knob {
		transform: translateX(16px);
	}
	.vus-toggle:focus-visible .vus-toggle-track {
		outline: 2px solid var(--vus-accent);
		outline-offset: 2px;
	}
	.vus-toggle-text {
		font-size: 0.74rem;
		font-weight: 700;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--vus-muted);
		min-width: 3.2em;
	}

	.vus-legend {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 9px;
	}
	.vus-legend li {
		margin: 0;
		display: flex;
		align-items: flex-start;
		gap: 9px;
		font-size: 0.76rem;
		line-height: 1.35;
		color: var(--vus-muted);
	}
	.vus-legend b {
		color: var(--vus-ink);
		font-weight: 700;
	}
	.vus-swatch {
		margin: 0;
		flex: 0 0 auto;
		width: 14px;
		height: 14px;
		border-radius: 4px;
		margin-top: 2px;
	}
	.vus-sw-vh {
		background: var(--vus-vh);
	}
	.vus-sw-svh {
		background: var(--vus-svh);
	}
	.vus-sw-dvh {
		background: var(--vus-dvh);
	}

	/* ----------------------------- caption ------------------------------- */
	.vus-caption {
		margin: 18px 0 0;
		padding-top: 14px;
		border-top: 1px solid #e2e8f0;
		font-size: 0.82rem;
		line-height: 1.5;
		color: var(--vus-ink);
		text-align: center;
	}
	.vus-cap-when {
		font-weight: 700;
	}
	.vus-cap-sep {
		margin: 0 6px;
		color: var(--vus-muted);
	}
	.vus-bad {
		color: var(--vus-bad);
	}
	.vus-ok {
		color: var(--vus-dvh);
	}

	@media (max-width: 560px) {
		.vus-stage {
			gap: 24px;
		}
		.vus-side {
			flex-basis: 100%;
		}
	}
</style>

<script>
	document.querySelectorAll<HTMLElement>("[data-vus-root]").forEach((root) => {
		const toggle = root.querySelector<HTMLButtonElement>("[data-vus-toggle]");
		const toggleText = root.querySelector<HTMLElement>("[data-vus-toggle-text]");
		const capWhen = root.querySelector<HTMLElement>("[data-vus-cap-when]");
		const capBody = root.querySelector<HTMLElement>("[data-vus-cap-body]");
		if (!toggle || !toggleText || !capWhen || !capBody) return;

		// Phone geometry mirrored from the frontmatter constants: full screen
		// height H, the address-bar slice BAR_H, so SMALL_H = H - BAR_H.
		const H = 300;
		const BAR_H = 54;
		const SMALL_H = H - BAR_H; // 246 — the small viewport

		// "shown" === aria-pressed="true" (the switch is on / the bar is present).
		const apply = () => {
			const shown = toggle.getAttribute("aria-pressed") === "true";
			root.dataset.bar = shown ? "shown" : "hidden";
			toggleText.textContent = shown ? "shown" : "hidden";

			const s = root.style;
			if (shown) {
				// dvh tracks the small viewport; address bar in frame; the red
				// "hidden behind the bar" slice on the vh bar is revealed; no gap.
				s.setProperty("--vus-dvh-h", SMALL_H + "px");
				s.setProperty("--vus-bar-shift", "0%");
				s.setProperty("--vus-bar-op", "1");
				s.setProperty("--vus-hidden-op", "1");
				s.setProperty("--vus-dead-h", "0px");
				s.setProperty("--vus-dead-op", "0");
				s.setProperty("--vus-dead-brd", "transparent");

				capWhen.textContent = "Address bar shown";
				capBody.innerHTML =
					'<b class="vus-bad">vh</b> overflows behind it, ' +
					'<b class="vus-ok">svh</b> fits, <b class="vus-ok">dvh</b> fits.';
			} else {
				// Bar gone: dvh grows to the full screen; bar slides out and fades;
				// the red slice hides; the dead-space gap above svh opens up.
				s.setProperty("--vus-dvh-h", H + "px");
				s.setProperty("--vus-bar-shift", "100%");
				s.setProperty("--vus-bar-op", "0");
				s.setProperty("--vus-hidden-op", "0");
				s.setProperty("--vus-dead-h", BAR_H + "px");
				s.setProperty("--vus-dead-op", "1");
				s.setProperty("--vus-dead-brd", "rgba(100, 116, 139, 0.5)");

				capWhen.textContent = "Address bar hidden";
				capBody.innerHTML =
					'<b class="vus-ok">vh</b> fits, ' +
					'<b class="vus-bad">svh</b> leaves dead space, ' +
					'<b class="vus-ok">dvh</b> fits.';
			}
		};

		toggle.addEventListener("click", () => {
			const next = toggle.getAttribute("aria-pressed") !== "true";
			toggle.setAttribute("aria-pressed", String(next));
			apply();
		});
		apply();
	});
</script>
