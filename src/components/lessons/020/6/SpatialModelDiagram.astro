---
// The padding / gap / margin spatial model, drawn as one annotated picture so
// "inside vs. between vs. outside" lands in a single glance. This is L6's
// centerpiece visual and the conceptual anchor the rest of the lesson hangs on.
//
// Composition: one PARENT box (rounded, hairline border) on the left holding TWO
// children stacked vertically. Three regions are color-coded and labeled:
//   - PADDING — the parent's inner inset all the way around (between its border
//     and where the children start). Filled the SAME green as L1's BoxModelDiagram
//     so the student's freshly-built box-model intuition carries straight over.
//   - GAP — the horizontal channel BETWEEN the two stacked children. Filled a
//     teal/cyan that collides with neither the green padding nor the tan margin;
//     this is the new concept, so it's the region drawn to catch the eye.
//   - MARGIN — a tan band OUTSIDE the parent, in the corridor between the parent
//     and a faint "outside sibling" box that is clearly NOT inside the parent. An
//     arrow runs from the parent's edge across that band to the outside box, so
//     "margin pushes away from things in a different container" reads spatially.
//     Reuses L1's margin tan.
//
// Conventions copied from L1's BoxModelDiagram on purpose: fixed dark-slate ink
// for labels (reads on every light tint), a system-ui sans stack, hairline edges
// so same-direction seams stay legible, all <text> wrapped in JS expressions so
// remark-smartypants can't curl the middot, and color-scheme pinned light so the
// fixed tints survive dark mode. Height is kept well under the laptop cap.

import Figure from "../../../figures/Figure.astro";

// Region fills — padding + margin shared verbatim with L1 so the figures read as
// one family; gap is a deliberately distinct teal.
const PADDING = "#a7d96f"; // green — matches L1 box-model padding exactly
const GAP = "#5eead4"; // teal / cyan — the new "between siblings" region
const MARGIN = "#f8cb9c"; // tan / orange — matches L1 box-model margin

const CHILD_FILL = "#ffffff"; // the two sibling boxes (figure is pinned light)
const OUTSIDE_FILL = "#f1f5f9"; // faint slate — the box in a different container

// Dark slate for labels — legible on green, teal, tan, and white alike.
const INK = "#1e293b";
const INK_SOFT = "#475569"; // role line, a touch lighter than the name

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";

// --- Geometry (1 unit = 1px) -------------------------------------------------
// Parent box on the left.
const PARENT = { x: 16, y: 56, width: 300, height: 196 };
const PAD = 22; // padding inset thickness, all four sides

// Inner area available to the children, after the padding inset.
const INNER_X = PARENT.x + PAD;
const INNER_Y = PARENT.y + PAD;
const INNER_W = PARENT.width - PAD * 2;
const INNER_H = PARENT.height - PAD * 2;

// Two children stacked vertically inside the inner area, separated by the gap.
const GAP_H = 20; // the gap channel height
const CHILD_H = (INNER_H - GAP_H) / 2;
const CHILD1 = { x: INNER_X, y: INNER_Y, width: INNER_W, height: CHILD_H };
const CHILD2 = { x: INNER_X, y: INNER_Y + CHILD_H + GAP_H, width: INNER_W, height: CHILD_H };
const GAP_BAND = { x: INNER_X, y: INNER_Y + CHILD_H, width: INNER_W, height: GAP_H };

// Margin band: the corridor to the right of the parent, before the outside box.
const MARGIN_W = 56;
const MARGIN_BAND = {
  x: PARENT.x + PARENT.width,
  y: PARENT.y + 40,
  width: MARGIN_W,
  height: PARENT.height - 80,
};

// The "outside sibling" — same vertical span as the parent, plainly separate.
const OUTSIDE = {
  x: MARGIN_BAND.x + MARGIN_W,
  y: PARENT.y,
  width: 92,
  height: PARENT.height,
};

// Arrow from the parent's right edge, across the margin band, to the outside box.
const ARROW_Y = PARENT.y + PARENT.height / 2;
const ARROW_X1 = PARENT.x + PARENT.width + 6;
const ARROW_X2 = OUTSIDE.x - 8;

// Leader for the gap label: from the gap band out to the right.
const GAP_MID_Y = GAP_BAND.y + GAP_BAND.height / 2;
---

<Figure caption="Padding sits inside the element, gap sits between siblings, margin sits outside — pushing away from things in a different container.">
  <svg
    viewBox="0 0 480 268"
    role="img"
    aria-label="A parent box holds two stacked children. Green padding insets the parent's edge from the children; a teal gap channel sits between the two children; a tan margin band sits outside the parent, with an arrow pushing toward a separate box in a different container."
    xmlns="http://www.w3.org/2000/svg"
    style="width: 100%; height: auto; display: block; color-scheme: light;"
  >
    <defs>
      {/* Arrowhead for the margin push. */}
      <marker
        id="spatial-arrow"
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="7"
        markerHeight="7"
        orient="auto-start-reverse"
      >
        <path d="M 0 1 L 9 5 L 0 9 z" fill={INK_SOFT} />
      </marker>
    </defs>

    {/* ---------- MARGIN band, outside the parent ---------- */}
    <rect {...MARGIN_BAND} fill={MARGIN} rx="3" />

    {/* ---------- the outside sibling (a different container) ---------- */}
    <rect
      {...OUTSIDE}
      fill={OUTSIDE_FILL}
      stroke={INK}
      stroke-opacity="0.3"
      stroke-width="1.5"
      stroke-dasharray="4 3"
      rx="6"
    />
    <g font-family={sans} text-anchor="middle" fill={INK_SOFT}>
      <text x={OUTSIDE.x + OUTSIDE.width / 2} y={ARROW_Y - 4} font-size="12">{"a box"}</text>
      <text x={OUTSIDE.x + OUTSIDE.width / 2} y={ARROW_Y + 12} font-size="12">{"outside"}</text>
    </g>

    {/* ---------- the parent box: padding fill, then children + gap ---------- */}
    {/* padding band = the whole parent, green; children + gap paint over it */}
    <rect {...PARENT} fill={PADDING} rx="8" />

    {/* the two stacked children */}
    <rect {...CHILD1} fill={CHILD_FILL} rx="4" />
    <rect {...CHILD2} fill={CHILD_FILL} rx="4" />

    {/* the gap channel between them — the region to notice */}
    <rect {...GAP_BAND} fill={GAP} rx="2" />

    {/* hairline edges so the seams stay legible */}
    <g fill="none" stroke={INK} stroke-opacity="0.22" stroke-width="1">
      <rect {...PARENT} rx="8" />
      <rect {...CHILD1} rx="4" />
      <rect {...CHILD2} rx="4" />
    </g>

    {/* sibling labels, centered in each child */}
    <g font-family={sans} text-anchor="middle" fill={INK} font-size="12.5" font-weight="600">
      <text x={CHILD1.x + CHILD1.width / 2} y={CHILD1.y + CHILD1.height / 2 + 4.5}>{"sibling"}</text>
      <text x={CHILD2.x + CHILD2.width / 2} y={CHILD2.y + CHILD2.height / 2 + 4.5}>{"sibling"}</text>
    </g>

    {/* ---------- the margin push arrow, across the tan band ---------- */}
    <line
      x1={ARROW_X1}
      y1={ARROW_Y}
      x2={ARROW_X2}
      y2={ARROW_Y}
      stroke={INK_SOFT}
      stroke-width="1.75"
      marker-end="url(#spatial-arrow)"
    />

    {/* ================= labels ================= */}
    <g font-family={sans}>
      {/* PADDING — top-left, sitting on the parent's top padding band */}
      <g text-anchor="start">
        <text x={PARENT.x + 12} y={PARENT.y + 15} font-size="13.5" font-weight="700" fill={INK}>{"padding"}</text>
        <text x={PARENT.x + 12} y={PARENT.y + 15 + 14} font-size="11" fill={INK_SOFT}>{"inside the parent"}</text>
      </g>

      {/* GAP — a short leader from the gap band to a label below the parent */}
      <line
        x1={GAP_BAND.x + GAP_BAND.width - 8}
        y1={GAP_MID_Y}
        x2={GAP_BAND.x + GAP_BAND.width + 18}
        y2={GAP_MID_Y}
        stroke={INK_SOFT}
        stroke-width="1.25"
      />
      <line
        x1={GAP_BAND.x + GAP_BAND.width + 18}
        y1={GAP_MID_Y}
        x2={GAP_BAND.x + GAP_BAND.width + 18}
        y2={PARENT.y + PARENT.height + 14}
        stroke={INK_SOFT}
        stroke-width="1.25"
      />
      <g text-anchor="start">
        <text x={GAP_BAND.x + GAP_BAND.width + 14} y={PARENT.y + PARENT.height + 26} font-size="13.5" font-weight="700" fill={INK}>{"gap"}</text>
        <text x={GAP_BAND.x + GAP_BAND.width + 14} y={PARENT.y + PARENT.height + 26 + 14} font-size="11" fill={INK_SOFT}>{"between siblings"}</text>
      </g>

      {/* MARGIN — above the tan band */}
      <g text-anchor="middle">
        <text x={MARGIN_BAND.x + MARGIN_W / 2} y={PARENT.y + 15} font-size="13.5" font-weight="700" fill={INK}>{"margin"}</text>
        <text x={MARGIN_BAND.x + MARGIN_W / 2 + 14} y={PARENT.y + 15 + 14} font-size="11" fill={INK_SOFT}>{"outside · pushes away"}</text>
      </g>
    </g>
  </svg>
</Figure>
