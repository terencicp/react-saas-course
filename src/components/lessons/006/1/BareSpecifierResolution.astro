---
// Diagram: three rows of bare-specifier resolution. Each row has a code
// snippet on the left and the resolution rule on the right, connected by
// a matched-color arrow glyph. The shape on the left and the rule on the
// right share a tinted border so the eye pairs them at a glance.
//
// Three rows, three rules:
//   1. Package name        — 'react'         → node_modules + exports
//   2. Subpath in package  — 'next/headers'  → exports['./headers']
//   3. Path alias          — '@/db'          → tsconfig.json paths
//
// Plain HTML + CSS, no interactivity. Three-column CSS grid (left, arrow,
// right) on wide viewports; collapses to single-column with a downward
// arrow on narrow viewports.

import Figure from '../../../figures/Figure.astro';

type Row = {
	color: string;
	specifier: string;
	rule: { kind: string; trail: string };
};

// Saturated mid-tones — readable against both light and dark backgrounds.
const rows: Row[] = [
	{
		color: '#3b82f6', // blue-500
		specifier: "import { useState } from 'react'",
		rule: {
			kind: 'node_modules/react/package.json',
			trail: "exports field",
		},
	},
	{
		color: '#16a34a', // green-600
		specifier: "import { cookies } from 'next/headers'",
		rule: {
			kind: 'node_modules/next/package.json',
			trail: "exports['./headers']",
		},
	},
	{
		color: '#8b5cf6', // violet-500
		specifier: "import { db } from '@/db'",
		rule: {
			kind: 'tsconfig.json',
			trail: "paths['@/*'] -> on-disk file",
		},
	},
];

const codeStyle =
	'margin: 0; padding: 0; background: transparent; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; color: var(--sl-color-text); word-break: break-word;';

const ruleKindStyle =
	'margin: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11.5px; color: var(--sl-color-text); word-break: break-word;';

const ruleTrailStyle =
	'margin: 4px 0 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11.5px; color: var(--sl-color-gray-2); word-break: break-word;';

const cellStyle = (color: string) =>
	[
		'margin: 0',
		'padding: 10px 14px',
		'border-radius: 8px',
		`border: 1px solid color-mix(in srgb, ${color} 55%, transparent)`,
		`background: color-mix(in srgb, ${color} 10%, transparent)`,
		'display: flex',
		'flex-direction: column',
		'justify-content: center',
		'min-width: 0',
	].join('; ');
---

<Figure
	caption="Three bare-specifier shapes; three resolution rules. The shape on the left tells you which rule on the right will fire."
>
	<div class="bsr-grid">
		{rows.map((row) => (
			<>
				<div style={cellStyle(row.color)} class="bsr-spec">
					<code style={codeStyle}>{row.specifier}</code>
				</div>
				<div class="bsr-arrow" style={`color: ${row.color};`} aria-hidden="true">
					<svg
						class="bsr-arrow-h"
						width="32"
						height="14"
						viewBox="0 0 32 14"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M0 7 H26 M20 1 L26 7 L20 13"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							fill="none"
						/>
					</svg>
					<svg
						class="bsr-arrow-v"
						width="14"
						height="22"
						viewBox="0 0 14 22"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M7 0 V18 M1 12 L7 18 L13 12"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							fill="none"
						/>
					</svg>
				</div>
				<div style={cellStyle(row.color)} class="bsr-rule">
					<div style={ruleKindStyle}>{row.rule.kind}</div>
					<div style={ruleTrailStyle}>{`-> ${row.rule.trail}`}</div>
				</div>
			</>
		))}
	</div>
</Figure>

<style>
	.bsr-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		column-gap: 10px;
		row-gap: 8px;
		align-items: stretch;
		margin: 0;
	}

	.bsr-arrow {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
	}

	.bsr-arrow-v {
		display: none;
	}

	@media (max-width: 540px) {
		.bsr-grid {
			grid-template-columns: minmax(0, 1fr);
			row-gap: 6px;
		}
		.bsr-arrow-h {
			display: none;
		}
		.bsr-arrow-v {
			display: block;
		}
		.bsr-arrow {
			padding: 2px 0;
		}
	}
</style>
</content>
</invoke>