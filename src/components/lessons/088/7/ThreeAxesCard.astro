---
// "Three assertion axes" card (Chapter 088 L7, "Server Action tests").
// Goal: cement that one action call is not one assertion but THREE independent
// checks — each axis catches a regression the other two are blind to.
//
// Layout: a single source box on the left — createInvoice(input, { db: tx }) —
// fans out via three short chevrons to a stacked column of three axis cards on
// the right. Each card is tinted its own signal colour and carries a code-shaped
// "what to assert" line plus a plain-language sub-label of what it proves:
//
//   RETURN   (blue)   — the Result the caller gets back.
//   DATABASE (green)  — the rows Postgres actually stored (echoes the chapter's
//                       rollback-safety green).
//   CACHE    (orange) — what the revalidatePath spy was told.
//
// Pure HTML + CSS, no JS / leader-line: the fan-out is carried by chevron glyphs.
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// the row wraps the source box above the cards on narrow viewports. Height-capped
// well under the laptop ceiling and devtools-inspectable.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

// ---- axis data ----------------------------------------------------------

const axes = [
	{
		label: "Return",
		n: "1",
		accent: "#2563eb", // blue-600
		tint: "rgba(37, 99, 235, 0.10)",
		code: "expect(result).toBeOkResult(…)",
		code2: ".toBeErrResult(…)",
		sub: "what the caller gets back",
	},
	{
		label: "Database",
		n: "2",
		accent: "#16a34a", // green-600 — echoes the chapter's rollback colour
		tint: "rgba(22, 163, 74, 0.10)",
		code: "tx.select().from(invoices)",
		code2: null,
		sub: "what Postgres actually stored",
	},
	{
		label: "Cache",
		n: "3",
		accent: "#ea580c", // orange-600
		tint: "rgba(234, 88, 12, 0.10)",
		code: "expect(revalidatePath)",
		code2: ".toHaveBeenCalledWith(…)",
		sub: "what the cache was told",
	},
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-wrap: wrap",
	"align-items: center",
	"justify-content: center",
	"column-gap: 8px",
	"row-gap: 18px",
	"width: 100%",
	"max-width: 720px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// The source box — vertically centred against the three-card stack.
const source = [
	reset,
	"box-sizing: border-box",
	"flex: 0 1 auto",
	"display: flex",
	"flex-direction: column",
	"gap: 5px",
	"padding: 13px 15px",
	"border-radius: 11px",
	"border: 1px solid var(--sl-color-gray-4, rgba(125,125,125,0.5))",
	"background: var(--sl-color-gray-6, rgba(125,125,125,0.10))",
].join("; ");

const sourceEyebrow = [
	reset,
	sans,
	"font-size: 10.5px",
	"font-weight: 700",
	"letter-spacing: 0.06em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-2, #9b9b9b)",
].join("; ");

const sourceCode = [
	reset,
	mono,
	"font-size: 13px",
	"font-weight: 600",
	"line-height: 1.35",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

// The stacked column of three axis cards.
const stack = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 9px",
	"flex: 1 1 320px",
	"min-width: 260px",
	"max-width: 420px",
].join("; ");

// One row = a chevron + a card.
const axisRow = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"gap: 7px",
].join("; ");

const chevron = [
	reset,
	"display: flex",
	"align-items: center",
	"flex: 0 0 auto",
].join("; ");

const card = (accent: string, tint: string) =>
	[
		reset,
		"box-sizing: border-box",
		"flex: 1 1 auto",
		"min-width: 0",
		"display: flex",
		"flex-direction: column",
		"gap: 3px",
		"padding: 8px 12px",
		"border-radius: 9px",
		"border: 1px solid " + accent,
		"border-left: 4px solid " + accent,
		"background: " + tint,
	].join("; ");

const cardHead = [
	reset,
	"display: flex",
	"align-items: baseline",
	"gap: 6px",
].join("; ");

const cardLabel = (accent: string) =>
	[
		reset,
		sans,
		"font-size: 12px",
		"font-weight: 700",
		"letter-spacing: 0.04em",
		"text-transform: uppercase",
		"color: " + accent,
	].join("; ");

const cardN = (accent: string) =>
	[
		reset,
		sans,
		"font-size: 10px",
		"font-weight: 700",
		"line-height: 1",
		"padding: 2px 5px",
		"border-radius: 999px",
		"color: #fff",
		"background: " + accent,
	].join("; ");

const cardCode = [
	reset,
	mono,
	"font-size: 12px",
	"font-weight: 600",
	"line-height: 1.3",
	"color: var(--sl-color-white, currentColor)",
	"word-break: break-word",
].join("; ");

const cardSub = [
	reset,
	sans,
	"font-size: 11px",
	"font-weight: 500",
	"line-height: 1.3",
	"color: var(--sl-color-gray-2, #9b9b9b)",
].join("; ");
---

<div class="not-content" style={root}>
	<div style={source}>
		<span style={sourceEyebrow}>one call</span>
		<span style={sourceCode}>createInvoice(input,</span>
		<span style={sourceCode}>{"  { db: tx })"}</span>
	</div>

	<div style={stack}>
		{
			axes.map((a) => (
				<div style={axisRow}>
					<span style={chevron} aria-hidden="true">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none">
							<path
								d="M9 6l6 6-6 6"
								stroke={a.accent}
								stroke-width="2.5"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</span>
					<div style={card(a.accent, a.tint)}>
						<div style={cardHead}>
							<span style={cardN(a.accent)} aria-hidden="true">
								{a.n}
							</span>
							<span style={cardLabel(a.accent)}>{a.label}</span>
						</div>
						<span style={cardCode}>
							{a.code}
							{a.code2 && <span style="opacity: 0.7">{a.code2}</span>}
						</span>
						<span style={cardSub}>{a.sub}</span>
					</div>
				</div>
			))
		}
	</div>
</div>
