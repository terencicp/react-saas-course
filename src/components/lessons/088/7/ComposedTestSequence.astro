---
/**
 * Composed action-test sequence for Chapter 088, Lesson 7 ("Server Action tests").
 *
 * The capstone diagram: one `createSubscription` integration test walked as a
 * temporal sequence, so the reader sees the layers fire IN ORDER through the full
 * stack. Every chapter primitive appears once and lights up on the step where it
 * is live — `tx` (L1), `signedInAs` (L3), the `authedAction` wrapper (Ch 057),
 * the Stripe wire via MSW (L4/L5), and the typed `Result` (Ch 043/087).
 *
 * Shape, mirroring the sibling IdempotencyReplay (046/3):
 *   - A FIXED legend strip of the five layers stays in the same position across
 *     all eight steps, so scrubbing animates one diagram changing rather than
 *     swapping eight differently-sized pictures (the grid-stack stage sizes to
 *     the tallest step). The active layer(s) light up per step.
 *   - Below the strip, a single "operation" card shows the code/line that runs at
 *     this step plus a one-line plain-language note.
 *   - The per-step caption (DiagramStep `caption` slot) carries the lesson prose.
 *
 * Palette echoes the lesson's ThreeAxesCard / chapter convention:
 *   green #16a34a  — `tx` / transaction-safety (rollback colour)
 *   indigo #6366f1 — `signedInAs` identity
 *   blue   #2563eb — the `authedAction` wrapper
 *   violet #8b5cf6 — Stripe over the MSW wire
 *   amber  #ea580c — the returned `Result`
 *
 * DiagramSequence provides its own card and must NOT be wrapped in <Figure>.
 */
import DiagramSequence from '../../../../components/figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../../components/figures/diagram-sequence/DiagramStep.astro';

// The five layers, fixed order, each with its own accent key.
const layers = [
  { key: 'tx', label: 'tx', mono: true },
  { key: 'auth', label: 'signedInAs' },
  { key: 'wrapper', label: 'wrapper' },
  { key: 'stripe', label: 'Stripe (MSW)' },
  { key: 'result', label: 'Result' },
];

// Per-step: which layers are lit, the operation line, and a short note.
// `active` keys map to the legend strip; `op` is the code line; `note` the gloss.
const steps = [
  {
    n: 1,
    title: 'Arrange identity',
    active: ['auth', 'tx'],
    op: "await signedInAs({ role: 'admin', plan: 'pro' }, tx)",
    note: 'inserts user / org / membership / session inside tx, stubs the session seam',
  },
  {
    n: 2,
    title: 'Arrange the wire',
    active: ['stripe'],
    op: "server.use(http.post('/v1/subscriptions', …))",
    note: 'registers a one-test Stripe handler that captures the request',
  },
  {
    n: 3,
    title: 'Act',
    active: ['wrapper'],
    op: "await createSubscription({ priceId }, { db: tx })",
    note: 'call the exported action exactly as production does — input + the { db: tx } handle',
  },
  {
    n: 4,
    title: 'Wrapper authorizes',
    active: ['wrapper', 'auth'],
    op: 'session resolved → pro admin → role gate cleared',
    note: 'the wrapper reads the stubbed session, passes the role gate, the body gets to run',
  },
  {
    n: 5,
    title: 'Body writes the row',
    active: ['tx'],
    op: 'db.insert(subscriptions).values(…)   // db === tx',
    note: 'the write lands in tx — visible to this test, invisible to the global db',
  },
  {
    n: 6,
    title: 'Body calls Stripe',
    active: ['stripe'],
    op: "stripe.subscriptions.create(…) → fetch → MSW",
    note: 'the real SDK builds the real request; MSW catches it at the network boundary',
  },
  {
    n: 7,
    title: 'Return Result.ok',
    active: ['result'],
    op: "return ok({ id: 'sub_123' })",
    note: 'three things proven from one call: the return, the bytes Stripe saw, the row in Postgres',
  },
  {
    n: 8,
    title: 'Rollback',
    active: ['tx'],
    op: 'withRollback throws its sentinel → transaction unwinds',
    note: 'the DB is exactly as it was — but the Stripe call already happened, it does not roll back',
  },
];

// Per-step caption prose (rendered under the body via the caption slot).
const captions = [
  'Identity exists, in the transaction. The session seam is primed to resolve this user.',
  'MSW is now listening for the Stripe call this action will make.',
  'Call the exported action exactly as production does — parsed input plus the { db: tx } handle.',
  'Session resolved, role gate cleared — the body gets to run.',
  'The write lands in tx, visible to this test, invisible to the global db.',
  'The real SDK builds the real request; MSW catches it at the network boundary and returns the canned subscription.',
  'Three things proven from one call: the return, the bytes Stripe saw, the row in Postgres.',
  'The test ends, the transaction rolls back, the database is exactly as it was. The Stripe call already happened — it does not roll back, which is why you asserted on the intercepted request, not a real charge.',
];
---

<DiagramSequence>
  {
    steps.map((step, i) => (
      <DiagramStep caption={captions[i]}>
        <div class="cts">
          {/* Fixed legend strip — same position every step, active layers lit. */}
          <div class="cts-lanes" aria-hidden="true">
            {layers.map((l) => (
              <span
                class={`cts-lane cts-${l.key}${
                  step.active.includes(l.key) ? ' is-on' : ''
                }`}
              >
                <span class={l.mono ? 'cts-mono' : ''}>{l.label}</span>
              </span>
            ))}
          </div>

          {/* The operation that runs at this step. */}
          <div class={`cts-op cts-op-${step.active[0]}`}>
            <span class="cts-step-tag">
              <span class="cts-step-n">{step.n}</span>
              <span class="cts-step-title">{step.title}</span>
            </span>
            <code class="cts-code">{step.op}</code>
            <span class="cts-note">{step.note}</span>
          </div>
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>

<style>
  .cts {
    --tx: #16a34a;
    --auth: #6366f1;
    --wrapper: #2563eb;
    --stripe: #8b5cf6;
    --result: #ea580c;
    width: 100%;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  /* ── Fixed five-layer legend strip ─────────────────────────────────────── */
  .cts-lanes {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .cts-lane {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 999px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-weight: 600;
    font-size: 0.78rem;
    line-height: 1.2;
    white-space: nowrap;
    transition: none;
  }
  .cts-mono {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.95em;
  }

  /* A lit lane takes its layer's accent — border, tinted fill, bold text. */
  .cts-lane.is-on {
    color: var(--sl-color-white);
    font-weight: 700;
  }
  .cts-tx.is-on {
    border-color: var(--tx);
    background: color-mix(in srgb, var(--tx) 22%, var(--sl-color-gray-6));
  }
  .cts-auth.is-on {
    border-color: var(--auth);
    background: color-mix(in srgb, var(--auth) 22%, var(--sl-color-gray-6));
  }
  .cts-wrapper.is-on {
    border-color: var(--wrapper);
    background: color-mix(in srgb, var(--wrapper) 22%, var(--sl-color-gray-6));
  }
  .cts-stripe.is-on {
    border-color: var(--stripe);
    background: color-mix(in srgb, var(--stripe) 22%, var(--sl-color-gray-6));
  }
  .cts-result.is-on {
    border-color: var(--result);
    background: color-mix(in srgb, var(--result) 22%, var(--sl-color-gray-6));
  }

  /* ── The per-step operation card ───────────────────────────────────────── */
  .cts-op {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.9rem 1.05rem;
    border: 1px solid var(--sl-color-gray-4);
    border-left: 4px solid var(--sl-color-gray-3);
    border-radius: 11px;
    background: var(--sl-color-bg);
  }
  /* The card's left rail picks up the colour of the step's primary layer. */
  .cts-op-tx {
    border-left-color: var(--tx);
  }
  .cts-op-auth {
    border-left-color: var(--auth);
  }
  .cts-op-wrapper {
    border-left-color: var(--wrapper);
  }
  .cts-op-stripe {
    border-left-color: var(--stripe);
  }
  .cts-op-result {
    border-left-color: var(--result);
  }

  .cts-step-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cts-step-n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.4rem;
    height: 1.4rem;
    padding: 0 0.35rem;
    border-radius: 999px;
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1;
  }
  .cts-step-title {
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--sl-color-white);
  }
  .cts-code {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
    padding: 0.45rem 0.6rem;
    border-radius: 7px;
    word-break: break-word;
  }
  .cts-note {
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--sl-color-gray-2);
  }

  @media (max-width: 30rem) {
    .cts-lanes {
      gap: 0.25rem;
    }
    .cts-sep {
      display: none;
    }
    .cts-lane {
      font-size: 0.72rem;
      padding: 0.28rem 0.55rem;
    }
  }
</style>
