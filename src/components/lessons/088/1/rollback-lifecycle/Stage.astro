---
// One frame of the rollback-lifecycle DiagramSequence (Ch088 L1, "Transaction
// rollback against real Postgres"). This is the conceptual core of the lesson:
// the student must SEE that a deliberately-thrown error is the isolation
// primitive — the invoice row appears inside the transaction and then never
// existed once it rolls back.
//
// One <Stage active={n} /> renders inside each <DiagramStep>. Every step renders
// the SAME five-box strip plus the SAME "DB rows" indicator below it, and only
// changes which box is lit and whether the uncommitted-invoice chip is present.
// Keeping the geometry stable frame-to-frame is the whole point: the eye tracks
// ONE artifact (the invoice) appearing then vanishing, not five pictures. It also
// keeps every step the same height so DiagramSequence's grid stack never reflows.
//
// The five stages, left to right:
//   BEGIN → RUN BODY → THROW → ROLLBACK → SWALLOW
//
// DB rows indicator: the baseline seed chip is ALWAYS visible (it lives outside
// the transaction, untouched by any rollback). The "+1 invoice" chip is present
// and lit only during RUN BODY and THROW (steps 1 and 2, zero-indexed) — the
// window where the write exists inside the open transaction. At ROLLBACK and
// SWALLOW it drops to a ghosted "gone" state so the disappearance is legible
// rather than a layout jump.
//
// Pure HTML + CSS per the diagrams guide (a sequential phase strip, no graph, no
// parallelism). `not-content` + margin:0 resets defeat Starlight's injected prose
// margins. DiagramSequence supplies the outer card, so this component is only the
// step body — no <Figure>/<DiagramSequence> wrapper here.
//
// Colour language, theme-stable via color-mix so tints track the page background:
//   blue  (#3b82f6, matching DiagramSequence's own accent) = the active stage
//   amber (#d97706) = the uncommitted invoice — "real enough to read, not landed"
//   green (#16a34a) = the durable baseline seed that survives every rollback

interface Props {
	// Index (0-4) of the lit stage this frame.
	active: number;
}

const { active } = Astro.props;

// The five stages, in order. `label` is the box headline; `sub` its one-word role.
const stages: { label: string; sub: string }[] = [
	{ label: 'BEGIN', sub: 'open tx' },
	{ label: 'RUN BODY', sub: 'insert + assert' },
	{ label: 'THROW', sub: 'RollbackSignal' },
	{ label: 'ROLLBACK', sub: 'discard writes' },
	{ label: 'SWALLOW', sub: 'catch sentinel' },
];

// The uncommitted invoice exists inside the transaction only during RUN BODY and
// THROW. Outside that window (BEGIN, ROLLBACK, SWALLOW) the table holds the seed
// alone — the row either hasn't been written yet or has just been discarded.
const invoiceVisible = active === 1 || active === 2;
// Distinguish "not yet written" (BEGIN) from "just discarded" (ROLLBACK, SWALLOW)
// so the chip's ghost copy reads correctly on each side of the row's lifetime.
const invoiceGone = active >= 3;

const BLUE = '#3b82f6';
const AMBER = '#d97706';
const GREEN = '#16a34a';
---

<div class="rl not-content" data-active={active}>
	<div
		class="rl-strip"
		role="img"
		aria-label={`Transaction lifecycle: BEGIN, RUN BODY, THROW, ROLLBACK, SWALLOW. Active stage: ${stages[active]?.label}.`}
	>
		{
			stages.map((stage, i) => (
				<>
					<div class:list={['rl-node', { 'is-on': i === active }]}>
						<span class="rl-node-label">{stage.label}</span>
						<span class="rl-node-sub">{stage.sub}</span>
					</div>
					{i < stages.length - 1 && (
						<span class:list={['rl-arrow', { 'is-on': i < active }]} aria-hidden="true">
							<svg viewBox="0 0 34 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="1" y1="7" x2="26" y2="7" />
								<polyline points="21 2.5 27.5 7 21 11.5" />
							</svg>
						</span>
					)}
				</>
			))
		}
	</div>

	<div class="rl-db">
		<span class="rl-db-label">DB rows visible inside <code>tx</code></span>
		<div class="rl-chips">
			<span class="rl-chip rl-chip--seed">baseline seed</span>
			<span class="rl-chip-plus" aria-hidden="true">+</span>
			<span
				class:list={[
					'rl-chip',
					'rl-chip--invoice',
					{ 'is-on': invoiceVisible, 'is-gone': invoiceGone },
				]}
			>
				{invoiceGone ? '1 invoice — discarded' : '1 invoice — uncommitted'}
			</span>
		</div>
	</div>
</div>

<style define:vars={{ 'rl-blue': BLUE, 'rl-amber': AMBER, 'rl-green': GREEN }}>
	.rl {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* ── The horizontal lifecycle strip ───────────────────────────────────── */
	.rl-strip {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
	}

	.rl-node {
		margin: 0;
		flex: 1 1 0;
		min-width: 92px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		padding: 11px 9px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s;
	}
	.rl-node.is-on {
		border: 1.5px solid var(--rl-blue);
		background: color-mix(in srgb, var(--rl-blue) 13%, transparent);
		color: color-mix(in srgb, var(--rl-blue) 82%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--rl-blue) 14%, transparent);
	}

	.rl-node-label {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12.5px;
		font-weight: 700;
		letter-spacing: 0.02em;
		line-height: 1.2;
	}
	.rl-node-sub {
		margin: 0;
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		line-height: 1.2;
		opacity: 0.85;
	}

	/* Connectors light up once crossed, so the strip reads as progress. */
	.rl-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.rl-arrow.is-on {
		color: var(--rl-blue);
	}
	.rl-arrow svg {
		width: 26px;
		height: 14px;
	}

	/* ── DB rows indicator: the watch-the-row-vanish panel ────────────────── */
	.rl-db {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 9px;
		padding: 13px 15px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
	}
	.rl-db-label {
		margin: 0;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}
	.rl-db-label code {
		font-size: 11px;
		background: transparent;
		border: 0;
		padding: 0;
		color: inherit;
	}

	.rl-chips {
		margin: 0;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
	}

	.rl-chip {
		margin: 0;
		display: inline-flex;
		align-items: center;
		font-size: 12px;
		font-weight: 700;
		line-height: 1.1;
		padding: 5px 11px;
		border-radius: 999px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-3);
		transition:
			color 0.18s,
			border-color 0.18s,
			background-color 0.18s,
			opacity 0.18s;
	}

	/* The seed is always durable — it lives outside the transaction. */
	.rl-chip--seed {
		color: color-mix(in srgb, var(--rl-green) 80%, var(--sl-color-text));
		border-color: color-mix(in srgb, var(--rl-green) 50%, transparent);
		background: color-mix(in srgb, var(--rl-green) 11%, transparent);
	}

	.rl-chip-plus {
		margin: 0;
		font-size: 14px;
		font-weight: 800;
		color: var(--sl-color-gray-4);
	}

	/* The invoice: faint placeholder by default (not written yet); amber + solid
	   while it exists inside the open transaction; struck-through ghost once the
	   rollback has discarded it. */
	.rl-chip--invoice {
		border-style: dashed;
		opacity: 0.45;
	}
	.rl-chip--invoice.is-on {
		opacity: 1;
		border-style: solid;
		color: color-mix(in srgb, var(--rl-amber) 82%, var(--sl-color-text));
		border-color: color-mix(in srgb, var(--rl-amber) 55%, transparent);
		background: color-mix(in srgb, var(--rl-amber) 13%, transparent);
	}
	.rl-chip--invoice.is-gone {
		opacity: 0.5;
		border-style: dashed;
		text-decoration: line-through;
		text-decoration-color: color-mix(in srgb, var(--sl-color-gray-2) 70%, transparent);
		color: var(--sl-color-gray-3);
	}

	/* ── Narrow viewports: stack the strip, rotate the connectors ─────────── */
	@media (max-width: 560px) {
		.rl-strip {
			flex-direction: column;
			align-items: stretch;
		}
		.rl-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
