---
// Cost-tiers strip (Ch088 L1, "Transaction rollback against real Postgres").
// A three-bar comparison anchoring WHY rollback is the reach over the obvious
// truncate-and-reseed alternative:
//
//   /lib unit test            ~5 ms     (the cheap baseline the seam can't match)
//   integration, rollback     ~20–80 ms (the price of the pattern — the middle bar)
//   truncate and reseed       ~500 ms   (the obvious move rollback beats by ~100×)
//
// Pure HTML + CSS per the diagrams guide (a sequential cost strip, no graph, no
// parallelism, devtools-inspectable). `not-content` + margin:0 resets defeat
// Starlight's injected prose margins. <Figure> in the MDX supplies the outer card,
// so this component is only the strip body.
//
// SCALE — log, deliberately. On a linear axis the 500 ms bar would dwarf the other
// two into invisibility (5 ms is 1% of the track). A log axis keeps all three bars
// legible AND makes "two orders of magnitude" the literal visual story: each power
// of ten is one equal-width band, so the truncate bar clears the rollback bar by
// ~the same span the rollback bar clears the unit bar. The real millisecond value
// rides on every bar so the numbers, not the bar lengths, carry the exact cost.
//
// The rollback tier is a range (20–80 ms), so its bar is drawn as a band: a solid
// fill to 20 ms and a softer fill out to 80 ms, with the label spanning both.
//
// Colour language matches this lesson's other figure (Stage.astro), theme-stable
// via color-mix so tints track the page background:
//   green (#16a34a) = the cheap /lib unit baseline
//   blue  (#3b82f6) = integration rollback, the pattern this lesson teaches
//   amber (#d97706) = truncate-and-reseed, the expensive alternative being beaten

const GREEN = '#16a34a';
const BLUE = '#3b82f6';
const AMBER = '#d97706';

// Log axis: 1 ms (10^0) at the left, 1000 ms (10^3) at the right. Four decade
// ticks. A bar's length is log10(ms) / log10(axisMax) as a percentage.
const AXIS_MIN_LOG = 0; // log10(1)
const AXIS_MAX_LOG = 3; // log10(1000)
const span = AXIS_MAX_LOG - AXIS_MIN_LOG;

const pct = (ms: number) => ((Math.log10(ms) - AXIS_MIN_LOG) / span) * 100;

const ticks = [1, 10, 100, 1000];

type Tier = {
	name: string;
	value: string;
	ms: number; // upper edge of the solid fill
	msEnd?: number; // upper edge of the soft band, for range tiers
	color: string;
};

const tiers: Tier[] = [
	{ name: '/lib unit test', value: '~5 ms', ms: 5, color: GREEN },
	{
		name: 'Integration, rollback per test',
		value: '~20–80 ms',
		ms: 20,
		msEnd: 80,
		color: BLUE,
	},
	{ name: 'Truncate and reseed', value: '~500 ms', ms: 500, color: AMBER },
];
---

<div class="ct not-content">
	<div
		class="ct-plot"
		role="img"
		aria-label="Per-test cost on a logarithmic scale: a /lib unit test is about 5 milliseconds, an integration test with rollback is 20 to 80 milliseconds, and truncate-and-reseed is about 500 milliseconds — roughly two orders of magnitude more expensive than rollback."
	>
		{/* Decade gridlines behind the bars so the log scale reads honestly. */}
		<div class="ct-grid" aria-hidden="true">
			{
				ticks.map((t) => (
					<span class="ct-gridline" style={`left: ${pct(t)}%`} />
				))
			}
		</div>

		<div class="ct-rows">
			{
				tiers.map((tier) => (
					<div class="ct-row">
						<div class="ct-head">
							<span class="ct-name">{tier.name}</span>
							<span class="ct-value" style={`color: ${tier.color}`}>
								{tier.value}
							</span>
						</div>
						<div class="ct-track">
							{tier.msEnd && (
								<div
									class="ct-bar ct-bar--soft"
									style={`width: ${pct(tier.msEnd)}%; --ct-fill: ${tier.color}`}
								/>
							)}
							<div
								class="ct-bar ct-bar--solid"
								style={`width: ${pct(tier.ms)}%; --ct-fill: ${tier.color}`}
							/>
						</div>
					</div>
				))
			}
		</div>

		{/* Axis ticks under the bars label each decade of the log scale. */}
		<div class="ct-axis" aria-hidden="true">
			{
				ticks.map((t) => (
					<span class="ct-tick" style={`left: ${pct(t)}%`}>
						{t === 1000 ? '1 s' : `${t} ms`}
					</span>
				))
			}
		</div>
	</div>
</div>

<style>
	.ct {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* The plot is the shared coordinate system: gridlines, bar rows, and axis
	   ticks all measure left-% from the same edge so they line up. The left pad
	   leaves room nothing measures into; bars and ticks start at 0% of the track. */
	.ct-plot {
		margin: 0;
		position: relative;
	}

	/* ── Decade gridlines, painted behind the bars ────────────────────────── */
	.ct-grid {
		margin: 0;
		position: absolute;
		top: 0;
		bottom: 26px; /* stop above the axis row */
		left: 0;
		right: 0;
		pointer-events: none;
	}
	.ct-gridline {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 1px;
		background: var(--sl-color-gray-5);
		transform: translateX(-0.5px);
	}

	/* ── Bar rows ──────────────────────────────────────────────────────────── */
	.ct-rows {
		margin: 0;
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.ct-row {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 5px;
	}

	.ct-head {
		margin: 0;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
	}
	.ct-name {
		margin: 0;
		font-size: 12.5px;
		font-weight: 600;
		color: var(--sl-color-text);
	}
	.ct-value {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12.5px;
		font-weight: 700;
		white-space: nowrap;
	}

	.ct-track {
		margin: 0;
		position: relative;
		height: 22px;
		border-radius: 6px;
		background: var(--sl-color-gray-6);
		overflow: hidden;
	}

	.ct-bar {
		margin: 0;
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		border-radius: 6px;
		min-width: 3px;
	}
	/* Solid fill = the lower edge (or the single value). */
	.ct-bar--solid {
		background: color-mix(in srgb, var(--ct-fill) 78%, transparent);
		border: 1px solid color-mix(in srgb, var(--ct-fill) 90%, transparent);
		box-sizing: border-box;
	}
	/* Soft fill = the upper edge of a range tier, drawn behind the solid one. */
	.ct-bar--soft {
		background: color-mix(in srgb, var(--ct-fill) 28%, transparent);
		border: 1px dashed color-mix(in srgb, var(--ct-fill) 55%, transparent);
		box-sizing: border-box;
	}

	/* ── Log axis ticks ────────────────────────────────────────────────────── */
	.ct-axis {
		margin: 8px 0 0;
		position: relative;
		height: 14px;
	}
	.ct-tick {
		margin: 0;
		position: absolute;
		top: 0;
		transform: translateX(-50%);
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 10px;
		font-weight: 600;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}
</style>
