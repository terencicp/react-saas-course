---
// SdkTower — Chapter 088 Lesson 4 ("Mock the wire, not the SDK"),
// the lesson's primary teaching figure.
//
// Pedagogical goal: replace "stripeClient is a magic object that talks to
// Stripe" with "an SDK is a stack of plain code whose bottom rung is one
// outbound network call." Data flows DOWN. The only line the student wrote is
// the top rung; everything below it the SDK manufactures. The visceral payoff
// is the pair of side brackets spanning serialize -> network -> parse: that
// whole region either RUNS FOR REAL (mock at the network) or is THROWN AWAY
// (mock the function / class) depending on where the mock sits.
//
// Shape: an "annotated illustration" — geometric stacked layers with callouts,
// per the diagrams index. Plain HTML + CSS inside <Figure>; no JS. The network
// rung is the accent-highlighted exit; it is labeled "HTTP request to
// api.stripe.com" (NOT fetch() — the Stripe Node SDK exits through node:https,
// so naming a primitive would be inaccurate). Height-capped well under 800px.
//
// Layout: a CSS grid. The left column is the 6-row tower; the two right columns
// are the green/red brackets, each a tall element that grid-spans rows 2-6 so
// it lines up exactly with the serialize->parse region. `margin: 0` on every
// descendant defeats Starlight's injected prose margins; `not-content` opts the
// body out of article prose styling.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const GREEN = '#16a34a'; // the region runs for real if you mock at the network
const RED = '#dc2626'; // the region is thrown away if you mock function / class
const ACCENT = '#2563eb'; // the network rung — the real process boundary

type Layer = {
	/** Bold label on the left. */
	label: string;
	/** Render the label in monospace (the call site only). */
	labelMono?: boolean;
	/** One-line callout on the right. */
	callout: string;
	/** Optional emphasized fragment appended to the callout. */
	calloutEmph?: string;
	/** The highlighted network rung. */
	network?: boolean;
	/** A sub-label under a network rung's label. */
	sub?: string;
};

// Top to bottom — data flows down. Rung 1 is the student's call; rungs 2-6 are
// SDK output (rung 5 is the highlighted exit).
const layers: Layer[] = [
	{
		label: 'stripeClient.checkout.sessions.create({ … })',
		labelMono: true,
		callout: 'your call — typed, ergonomic, the only line you wrote',
	},
	{
		label: 'Serialize',
		callout:
			'turns the JS object into a URL-encoded form body (application/x-www-form-urlencoded — ',
		calloutEmph: 'not JSON)',
	},
	{
		label: 'Sign & set headers',
		callout: 'adds Authorization: Bearer, Idempotency-Key, Stripe-Version',
	},
	{
		label: 'Retry',
		callout: 'on 429 / 5xx, retries with backoff',
	},
	{
		label: 'HTTP request to api.stripe.com',
		callout: 'the real process boundary',
		network: true,
		sub: 'this is the only thing Stripe sees',
	},
	{
		label: 'Parse',
		callout: 'decodes the response body, maps error JSON to a thrown StripeError',
	},
];

const ALT =
	'A vertical stack of six layers, data flowing top to bottom. Top rung: your call, stripeClient.checkout.sessions.create, the only line you wrote. Below it, five rungs the SDK generates: Serialize (turns the JS object into a URL-encoded form body, not JSON); Sign and set headers (Authorization Bearer, Idempotency-Key, Stripe-Version); Retry (on 429 or 5xx, backs off); the highlighted HTTP request to api.stripe.com, the real process boundary and the only thing Stripe sees; and Parse (decodes the response, maps errors to a thrown StripeError). Two vertical brackets run down the right side spanning the Serialize-through-Parse region: a green one labeled "runs for real — but only if you mock at the network," and a red one labeled "thrown away if you mock the function or the class." The two brackets cover the same rungs, side by side, to show this whole region is either exercised or discarded depending on where the mock sits.';
---

<Figure
	caption="Every checkout.sessions.create call is a trip down this tower. The only line you wrote is the top one; the SDK generates everything below it."
>
	<div class="tower not-content" role="img" aria-label={ALT}>
		<div class="tower-grid">
			{
				layers.map((l, i) => (
					<div
						class={`tower-rung${l.network ? ' tower-rung-net' : ''}${i === 0 ? ' tower-rung-call' : ''}`}
						style={`grid-row: ${i + 1}`}
					>
						<div class="tower-rung-main">
							<span
								class={`tower-label${l.labelMono ? ' tower-label-mono' : ''}${l.network ? ' tower-label-net' : ''}`}
							>
								{l.label}
							</span>
							<span class="tower-callout">
								{l.callout}
								{l.calloutEmph && (
									<strong class="tower-callout-emph">{l.calloutEmph}</strong>
								)}
							</span>
						</div>
						{l.sub && <span class="tower-sub">{l.sub}</span>}
					</div>
				))
			}

			{/* Green bracket: spans rungs 2-6 (serialize -> parse). */}
			<div class="tower-bracket tower-bracket-green">
				<span class="tower-bracket-line tower-bracket-line-green" />
				<span class="tower-bracket-text tower-bracket-text-green">
					runs for real — but only if you mock at the network
				</span>
			</div>

			{/* Red bracket: same rungs, the discarded region. */}
			<div class="tower-bracket tower-bracket-red">
				<span class="tower-bracket-line tower-bracket-line-red" />
				<span class="tower-bracket-text tower-bracket-text-red">
					thrown away if you mock the function or the class
				</span>
			</div>
		</div>
	</div>
</Figure>

<style define:vars={{ GREEN, RED, ACCENT, sans, mono }}>
	.tower {
		box-sizing: border-box;
		max-width: 760px;
		margin: 0 auto;
		padding: 6px 2px;
		font-family: var(--sans);
		color: var(--sl-color-white);
		/* Reflow on the figure's own width, not the viewport — robust to narrow
		   article columns and to embedding contexts that don't report a viewport
		   width. */
		container-type: inline-size;
		container-name: tower;
	}

	.tower :global(*) {
		margin: 0;
		box-sizing: border-box;
	}

	/* Grid: [tower] [green bracket] [red bracket]. The six rungs occupy rows
	   1-6 of the left column; each bracket grid-spans rows 2-6 so it lines up
	   with the serialize->parse region exactly. */
	.tower-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto auto;
		grid-template-rows: repeat(6, auto);
		column-gap: 10px;
		row-gap: 7px;
		align-items: stretch;
	}

	/* ── a tower rung ── */
	.tower-rung {
		grid-column: 1;
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 10px 14px;
		border: 1px solid var(--sl-color-gray-5, #353c4a);
		border-radius: 9px;
		background: var(--sl-color-bg-sidebar);
	}

	/* The student's call site — dashed accent border to read as "yours". */
	.tower-rung-call {
		border-style: dashed;
		border-color: var(--sl-color-gray-4, #4d5666);
		background: color-mix(in srgb, var(--sl-color-gray-5, #353c4a) 30%, transparent);
	}

	/* The one rung that leaves the process — the accent-highlighted exit. */
	.tower-rung-net {
		border: 2px solid var(--ACCENT);
		background: color-mix(in srgb, var(--ACCENT) 12%, var(--sl-color-bg-sidebar));
	}

	.tower-rung-main {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		column-gap: 12px;
		row-gap: 2px;
	}

	.tower-label {
		flex: 0 0 auto;
		font-size: 13px;
		font-weight: 800;
		line-height: 1.35;
		color: var(--sl-color-white);
	}
	.tower-label-mono {
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 700;
	}
	.tower-label-net {
		color: var(--ACCENT);
	}

	.tower-callout {
		flex: 1 1 240px;
		min-width: 0;
		font-size: 12px;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #c0c7d1);
	}
	.tower-callout-emph {
		font-weight: 800;
		color: var(--sl-color-white);
	}

	.tower-sub {
		font-size: 10.5px;
		font-weight: 800;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--ACCENT);
	}

	/* ── the two side brackets, each spanning rungs 2-6 ── */
	.tower-bracket {
		grid-row: 2 / 7;
		display: flex;
		align-items: stretch;
		gap: 7px;
	}
	.tower-bracket-green {
		grid-column: 2;
	}
	.tower-bracket-red {
		grid-column: 3;
	}

	/* The vertical bracket line: a left border + small end caps via ::before /
	   ::after make a [ shape hugging the region. */
	.tower-bracket-line {
		position: relative;
		flex: 0 0 7px;
		border-left: 2.5px solid currentColor;
		border-top-left-radius: 4px;
		border-bottom-left-radius: 4px;
	}
	.tower-bracket-line::before,
	.tower-bracket-line::after {
		content: '';
		position: absolute;
		left: 0;
		width: 7px;
		height: 2.5px;
		background: currentColor;
		border-radius: 2px;
	}
	.tower-bracket-line::before {
		top: 0;
	}
	.tower-bracket-line::after {
		bottom: 0;
	}
	.tower-bracket-line-green {
		color: var(--GREEN);
	}
	.tower-bracket-line-red {
		color: var(--RED);
	}

	/* The bracket label, set vertically so it reads alongside the region. */
	.tower-bracket-text {
		display: flex;
		align-items: center;
		max-width: 96px;
		font-size: 11px;
		font-weight: 700;
		line-height: 1.3;
	}
	.tower-bracket-text-green {
		color: var(--GREEN);
	}
	.tower-bracket-text-red {
		color: var(--RED);
	}

	/* On narrow figure widths the two side brackets would crush the tower; drop
	   them below the stack as a stacked legend instead. Keyed on the figure's
	   own inline-size via a container query. */
	@container tower (max-width: 540px) {
		.tower-grid {
			grid-template-columns: 1fr;
		}
		.tower-bracket {
			grid-row: auto;
			grid-column: 1;
			align-items: center;
			gap: 9px;
			padding: 7px 10px;
			border-radius: 8px;
		}
		.tower-bracket-green {
			border: 1px solid color-mix(in srgb, var(--GREEN) 55%, transparent);
		}
		.tower-bracket-red {
			border: 1px solid color-mix(in srgb, var(--RED) 55%, transparent);
		}
		.tower-bracket-line {
			flex: 0 0 16px;
			border-left: none;
			border-top: 2.5px solid currentColor;
			border-radius: 0;
		}
		.tower-bracket-line::before,
		.tower-bracket-line::after {
			display: none;
		}
		.tower-bracket-text {
			max-width: none;
		}
	}
</style>
