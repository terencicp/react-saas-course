---
// OwnershipBoundary — Chapter 088 Lesson 4 ("Mock the wire, not the SDK"),
// the chapter's retain-this figure.
//
// Pedagogical goal: fuse the chapter's two isolation strategies onto a single
// image of one action's two boundaries. The same action gets OPPOSITE treatment
// at each seam, and the deciding question is ownership:
//   - the boundary you OWN (your Postgres) -> run it for real, roll back (tx)
//   - the boundary you DON'T OWN (Stripe)  -> mock the wire (MSW)
// One glance should show: two boundaries, opposite rules, keyed on ownership.
//
// Shape: an annotated illustration whose nodes are custom HTML (each carries a
// title + a mono sub-line, and sits inside a tinted ownership zone), so this is
// an <ArrowDiagram> inside a <Figure expandable={false}> (leader-lines are
// positioned from document.body and break if the figure is relocated).
//
// Layout: the action sits top-center. Its OWNED boundary (Postgres) sits
// bottom-left inside a green zone; its UNOWNED boundary (Stripe) sits middle-
// right inside a red zone. Two arrows leave the action: down-left to Postgres
// (green, bottom -> top), right to Stripe (red, right -> left). Gap width on the
// right column is reserved for the "mock the wire (MSW)" label per the
// ArrowDiagram guidance.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const GREEN = '#16a34a'; // the boundary you own — run it, roll back
const RED = '#dc2626'; // the boundary you don't own — mock the wire
const ACCENT = '#2563eb'; // the action under test, in the middle

const ALT =
	'One Server Action, createSubscription, sits in the middle with two boundaries that get opposite treatment. An arrow runs down-left from the action to a Postgres box (sub-line: your schema) that sits inside a green zone labeled "you own it"; the arrow is labeled "run it for real, roll back (tx)". A second arrow runs right from the action to a Stripe box (sub-line: api.stripe.com) that sits inside a red zone labeled "you don\'t own it"; that arrow is labeled "mock the wire (MSW)". The single glance shows the action\'s two boundaries handled the opposite way, keyed on ownership.';
---

<Figure
	expandable={false}
	caption="The same action, two boundaries, opposite rules. You own the database, so you run it and roll back. You don't own Stripe, so you mock the wire."
>
	<div class="own not-content" role="img" aria-label={ALT}>
		<div class="own-grid">
			{/* Top-center: the action under test. */}
			<div class="own-cell own-cell-action">
				<div class="own-box own-box-action" id="ob-action">
					<span class="own-box-title own-box-title-mono">createSubscription</span>
					<span class="own-box-sub">your Server Action</span>
				</div>
			</div>

			{/* Bottom-left: the boundary you own — green zone. */}
			<div class="own-cell own-cell-pg">
				<div class="own-zone own-zone-green">
					<span class="own-zone-tag own-zone-tag-green">you own it</span>
					<div class="own-box own-box-pg" id="ob-postgres">
						<span class="own-box-title">Postgres</span>
						<span class="own-box-sub own-box-sub-mono">your schema</span>
					</div>
				</div>
			</div>

			{/* Right: the boundary you don't own — red zone. */}
			<div class="own-cell own-cell-stripe">
				<div class="own-zone own-zone-red">
					<span class="own-zone-tag own-zone-tag-red">you don't own it</span>
					<div class="own-box own-box-stripe" id="ob-stripe">
						<span class="own-box-title">Stripe</span>
						<span class="own-box-sub own-box-sub-mono">api.stripe.com</span>
					</div>
				</div>
			</div>
		</div>

		<ArrowDiagram
			arrows={[
				{
					from: 'ob-action',
					to: 'ob-postgres',
					label: 'run it for real → roll back (tx)',
					color: GREEN,
					startSocket: 'bottom',
					endSocket: 'top',
					startSocketGravity: [-40, 70],
					endSocketGravity: [0, -70],
					labelOffset: [0, 4],
					labelStyle: `background:#0b1220;color:${GREEN};border:1px solid ${GREEN};`,
				},
				{
					from: 'ob-action',
					to: 'ob-stripe',
					label: 'mock the wire (MSW)',
					color: RED,
					startSocket: 'right',
					endSocket: 'left',
					startSocketGravity: [90, 0],
					endSocketGravity: [-90, 0],
					labelOffset: [0, -14],
					labelStyle: `background:#0b1220;color:${RED};border:1px solid ${RED};`,
				},
			]}
		/>
	</div>
</Figure>

<style define:vars={{ GREEN, RED, ACCENT, sans, mono }}>
	.own {
		box-sizing: border-box;
		max-width: 720px;
		margin: 0 auto;
		padding: 8px 4px 4px;
		font-family: var(--sans);
		color: var(--sl-color-white);
		container-type: inline-size;
		container-name: own;
	}

	.own :global(*) {
		margin: 0;
		box-sizing: border-box;
	}

	/* Two columns, two rows. The action sits top-center spanning both columns;
	   Postgres takes the bottom-left cell, Stripe the right cell spanning both
	   rows so it sits at the action's vertical midline (its arrow leaves the
	   action's right side). The right column reserves width for the MSW label. */
	.own-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(180px, 0.95fr);
		grid-template-rows: auto auto;
		column-gap: 130px;
		row-gap: 64px;
		align-items: center;
		justify-items: center;
		padding: 4px 6px;
	}

	.own-cell-action {
		grid-column: 1;
		grid-row: 1;
		justify-self: center;
	}
	.own-cell-pg {
		grid-column: 1;
		grid-row: 2;
		justify-self: center;
	}
	.own-cell-stripe {
		grid-column: 2;
		grid-row: 1 / 3;
		justify-self: center;
	}

	/* ── ownership zones ── */
	.own-zone {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 9px;
		padding: 14px 18px 16px;
		border-radius: 14px;
		border: 1.5px dashed;
	}
	.own-zone-green {
		border-color: color-mix(in srgb, var(--GREEN) 55%, transparent);
		background: color-mix(in srgb, var(--GREEN) 10%, transparent);
	}
	.own-zone-red {
		border-color: color-mix(in srgb, var(--RED) 55%, transparent);
		background: color-mix(in srgb, var(--RED) 10%, transparent);
	}

	.own-zone-tag {
		font-size: 10.5px;
		font-weight: 800;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}
	.own-zone-tag-green {
		color: var(--GREEN);
	}
	.own-zone-tag-red {
		color: var(--RED);
	}

	/* ── boxes ── */
	.own-box {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		padding: 11px 18px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #353c4a);
		background: var(--sl-color-bg-sidebar);
		text-align: center;
		min-width: 150px;
	}

	.own-box-action {
		border: 2px solid var(--ACCENT);
		background: color-mix(in srgb, var(--ACCENT) 12%, var(--sl-color-bg-sidebar));
	}

	.own-box-title {
		font-size: 14px;
		font-weight: 800;
		line-height: 1.3;
		color: var(--sl-color-white);
	}
	.own-box-title-mono {
		font-family: var(--mono);
		font-size: 13px;
		font-weight: 700;
	}

	.own-box-sub {
		font-size: 11px;
		line-height: 1.3;
		color: var(--sl-color-gray-2, #c0c7d1);
	}
	.own-box-sub-mono {
		font-family: var(--mono);
		font-size: 10.5px;
	}

	/* On narrow figure widths the right column would crush; stack the three cells
	   into a single column. The cross-region arrow degrades to an arc, which the
	   ArrowDiagram guidance accepts as graceful. */
	@container own (max-width: 520px) {
		.own-grid {
			grid-template-columns: 1fr;
			grid-template-rows: auto auto auto;
			column-gap: 0;
			row-gap: 48px;
		}
		.own-cell-action {
			grid-column: 1;
			grid-row: 1;
		}
		.own-cell-stripe {
			grid-column: 1;
			grid-row: 2;
		}
		.own-cell-pg {
			grid-column: 1;
			grid-row: 3;
		}
	}
</style>
