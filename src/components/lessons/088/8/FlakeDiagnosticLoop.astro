---
// flake-diagnostic-loop — Ch088 L8 "Flake has a structural cause", the figure
// that closes the "Finding the cause: repeats and shuffle" section.
//
// The four-step diagnostic loop run on ONE concrete create-invoice.int.test.ts:
//   1. Symptom  — red on a PR (CI), green locally.            ("intermittent")
//   2. Quantify — add { repeats: 100 }, run the file → 7/100. (a rate, on demand)
//   3. Name     — the mock-impl leak: test sets a session,    (bucket A taxon)
//                 the setup file's afterEach never resets it.
//   4. Fix+prove — one afterEach(resetAllMocks) in the setup  (structural, proven)
//                 file → 100/100.
//
// A <DiagramSequence> so the reader SCRUBS the loop as a temporal process —
// "quantify → locate → fix → re-prove" becomes a sequence they can replay
// mentally, anchored to a leak they already understand from L7. It carries its
// own card, so it is NOT wrapped in <Figure> at the call site.
//
// Each step body is a small "terminal"/"editor" chrome panel (mono text, a top
// bar with traffic dots) plus, where it helps, a verdict pill. Colour reuses the
// sibling FlakeTwoBuckets vocabulary: GREEN = the state-leak / fixed track,
// ORANGE accents the "named cause". Red marks the failing rows. The captions are
// the narration and swap with each body.
//
// Static figure — no interactivity beyond the sequence's own slider/chevrons.
// Step 3 (the two stacked code panels) is the tallest; all steps share its
// height so the stage never reflows while scrubbing. Well under the 800px cap.

import DiagramSequence from "../../../../components/figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../components/figures/diagram-sequence/DiagramStep.astro";

const mono =
	"var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans = "var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
---

<div class="fdl not-content">
	<DiagramSequence>
		{/* STEP 1 — the symptom: red on CI, green locally. */}
		<DiagramStep caption="The symptom: red on a pull request that never touched this file; green when you run it locally. 'Intermittent' is where most people stop.">
			<div class="fdl-stage">
				<div class="fdl-panel">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">CI — pull request #482</span>
					</div>
					<div class="fdl-body">
						<span class="fdl-row fdl-row--fail"
							><span class="fdl-glyph">✗</span> create-invoice.int.test.ts</span
						>
						<span class="fdl-note">a change that never touched this file</span>
					</div>
				</div>
				<div class="fdl-panel">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">local — your machine</span>
					</div>
					<div class="fdl-body">
						<span class="fdl-row fdl-row--pass"
							><span class="fdl-glyph">✓</span> create-invoice.int.test.ts</span
						>
						<span class="fdl-note">re-run it: green again</span>
					</div>
				</div>
			</div>
		</DiagramStep>

		{/* STEP 2 — quantify with { repeats: 100 }; it fires in source order → bucket A. */}
		<DiagramStep>
			<div class="fdl-stage">
				<div class="fdl-panel">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">create-invoice.int.test.ts</span>
					</div>
					<div class="fdl-code">
						<span class="fdl-cl"
							><span class="kw">it</span>(<span class="str"
								>'creates an invoice'</span
							>, <span class="opt">&#123; repeats: 100 &#125;</span>, <span
								class="kw">async</span
							> () =&gt; &#123;</span
						>
						<span class="fdl-cl fdl-cl--dim">  // …the test body, unchanged</span>
						<span class="fdl-cl">&#125;);</span>
					</div>
				</div>
				<div class="fdl-panel">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">terminal</span>
					</div>
					<div class="fdl-code">
						<span class="fdl-cl fdl-cl--prompt"
							>$ vitest run create-invoice.int.test.ts</span
						>
						<span class="fdl-cl fdl-result"
							><span class="fail">7/100 failed</span> · source order, no shuffle</span
						>
					</div>
				</div>
			</div>
			<Fragment slot="caption">
				Add <code>&#123; repeats: 100 &#125;</code> and run the file — a rate, on demand.
				It fires in source order with no shuffle, so it's a state leak (bucket A).
			</Fragment>
		</DiagramStep>

		{/* STEP 3 — name the taxon: the mock-impl leak, and the missing reset. */}
		<DiagramStep caption="Name the taxon: an earlier test's admin session bleeds in because setup-file mocks aren't auto-reset. Mock-implementation leak.">
			<div class="fdl-stage fdl-stage--col">
				<div class="fdl-panel">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">a test, earlier in the run</span>
					</div>
					<div class="fdl-code">
						<span class="fdl-cl"
							>vi.mocked(auth.api.getSession)</span
						>
						<span class="fdl-cl">  .<span class="kw">mockResolvedValue</span
							>(adminSession);</span
						>
					</div>
				</div>
				<div class="fdl-panel fdl-panel--gap">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">tests/integration/setup.ts</span>
					</div>
					<div class="fdl-code">
						<span class="fdl-cl"
							><span class="kw">afterEach</span>(() =&gt; &#123;</span
						>
						<span class="fdl-cl">  server.<span class="kw">resetHandlers</span
							>();</span
						>
						<span class="fdl-cl fdl-cl--missing"
							>  <span class="miss">// no mock reset — the gap</span></span
						>
						<span class="fdl-cl">&#125;);</span>
					</div>
				</div>
			</div>
		</DiagramStep>

		{/* STEP 4 — the structural fix in the setup file, re-proven 100/100. */}
		<DiagramStep caption="The structural fix lands in the setup file, not the test body. Re-run with repeats: 100 → 100/100. Fixed, and proven — not hoped.">
			<div class="fdl-stage fdl-stage--col">
				<div class="fdl-panel">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">tests/integration/setup.ts</span>
					</div>
					<div class="fdl-code">
						<span class="fdl-cl"
							><span class="kw">afterEach</span>(() =&gt; &#123;</span
						>
						<span class="fdl-cl">  server.<span class="kw">resetHandlers</span
							>();</span
						>
						<span class="fdl-cl fdl-cl--ins"
							>  vi.<span class="kw">resetAllMocks</span>();</span
						>
						<span class="fdl-cl">&#125;);</span>
					</div>
				</div>
				<div class="fdl-panel fdl-panel--gap">
					<div class="fdl-bar">
						<span class="fdl-dot"></span><span class="fdl-dot"></span><span
							class="fdl-dot"></span>
						<span class="fdl-bar-label">terminal</span>
					</div>
					<div class="fdl-code">
						<span class="fdl-cl fdl-cl--prompt"
							>$ vitest run create-invoice.int.test.ts</span
						>
						<span class="fdl-cl fdl-result"
							><span class="pass">100/100</span> · fixed, and proven</span
						>
					</div>
				</div>
			</div>
		</DiagramStep>
	</DiagramSequence>
</div>

<style define:vars={{ monoFont: mono, sansFont: sans }}>
	.fdl {
		margin: 0;
		font-family: var(--sansFont);
		/* Theme-aware status colours, declared once. green = pass/fixed track,
		   red = the failing rows, matching the sibling FlakeTwoBuckets vocabulary. */
		--ok: #16a34a;
		--fail: #ef4444;
	}

	/* Two panels side by side per step; the height-setting steps stack vertically. */
	.fdl-stage {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
		align-items: start;
		width: 100%;
		max-width: 720px;
		margin-inline: auto;
		box-sizing: border-box;
	}
	.fdl-stage--col {
		grid-template-columns: 1fr;
		max-width: 560px;
		gap: 0;
	}

	/* A window-chrome panel: top bar + body. */
	.fdl-panel {
		box-sizing: border-box;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		overflow: hidden;
	}
	.fdl-panel--gap {
		margin-top: 14px;
	}

	.fdl-bar {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 7px 12px;
		border-bottom: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-6);
	}
	.fdl-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--sl-color-gray-4);
		flex: none;
	}
	.fdl-bar-label {
		margin-inline-start: 6px;
		font-family: var(--monoFont);
		font-size: 11px;
		font-weight: 600;
		color: var(--sl-color-gray-2);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* Plain (non-code) body — CI/local result rows. */
	.fdl-body {
		display: flex;
		flex-direction: column;
		gap: 5px;
		padding: 14px 14px;
	}
	.fdl-row {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--monoFont);
		font-size: 12.5px;
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.fdl-glyph {
		font-weight: 800;
	}
	.fdl-row--fail .fdl-glyph {
		color: var(--fail);
	}
	.fdl-row--pass .fdl-glyph {
		color: var(--ok);
	}
	.fdl-note {
		font-family: var(--sansFont);
		font-size: 11.5px;
		font-weight: 500;
		font-style: italic;
		color: var(--sl-color-gray-2);
		padding-inline-start: 22px;
	}

	/* Code body — monospace lines. */
	.fdl-code {
		display: flex;
		flex-direction: column;
		padding: 12px 14px;
		font-family: var(--monoFont);
		font-size: 12.5px;
		line-height: 1.55;
		overflow-x: auto;
	}
	.fdl-cl {
		white-space: pre;
		color: var(--sl-color-white);
	}
	.fdl-cl--dim {
		color: var(--sl-color-gray-3);
	}
	.fdl-cl--prompt {
		color: var(--sl-color-gray-2);
	}
	.fdl-result {
		margin-top: 2px;
		color: var(--sl-color-gray-2);
	}

	/* The added fix line: green ins gutter highlight. */
	.fdl-cl--ins {
		background: color-mix(in srgb, var(--ok) 16%, transparent);
		box-shadow: inset 3px 0 0 var(--ok);
		border-radius: 0 4px 4px 0;
	}
	/* The missing-line gap: a faint red marker. */
	.fdl-cl--missing {
		background: color-mix(in srgb, var(--fail) 12%, transparent);
		box-shadow: inset 3px 0 0 color-mix(in srgb, var(--fail) 60%, transparent);
		border-radius: 0 4px 4px 0;
	}

	/* Token colours — kept minimal, expressive-code-ish. */
	.fdl-code .kw {
		color: #c084fc;
	}
	.fdl-code .str {
		color: #86c578;
	}
	.fdl-code .opt {
		color: #7cc4ff;
		font-weight: 700;
	}
	.fdl-code .miss {
		color: var(--fail);
		font-style: italic;
	}
	.fail {
		color: var(--fail);
		font-weight: 800;
	}
	.pass,
	.fdl-code .pass {
		color: var(--ok);
		font-weight: 800;
	}

	/* Inline code in the rich caption. */
	.fdl :global(.diagram-step-caption code),
	.fdl code {
		font-family: var(--monoFont);
	}

	@media (max-width: 560px) {
		.fdl-stage {
			grid-template-columns: 1fr;
			gap: 12px;
		}
		.fdl-panel--gap {
			margin-top: 12px;
		}
	}
</style>
