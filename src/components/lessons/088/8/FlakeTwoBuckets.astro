---
// flake-two-buckets — Ch088 L8 "Flake has a structural cause", the figure that
// closes the "'intermittent' is a symptom, not a diagnosis" section.
//
// The lesson's spine made visual: ONE symptom forks into TWO root-cause buckets,
// and each bucket points at its OWN shape of fix. The whole pedagogy is "first
// decide the bucket, then the fix follows" — so the fork is the message.
//
//   ┌─────────┐   green   ┌────────────┐   green   ┌──────────────┐
//   │ Symptom │ ────────▶ │ State leak │ ────────▶ │ Isolate/reset│
//   │         │           └────────────┘           └──────────────┘
//   │         │   orange  ┌────────────┐   orange  ┌──────────────┐
//   └─────────┘ ────────▶ │ Order /    │ ────────▶ │ Remove the   │
//                         │ nondet.    │           │ dependency   │
//                         └────────────┘           └──────────────┘
//
// Color carries the two tracks: GREEN = the state-leak path (passes alone, fails
// in the suite → reset/isolate), ORANGE = the order/nondeterminism path (passes
// one order, fails another → remove the dependency). Two distinct colours let the
// reader trace either track end-to-end without reading any box.
//
// Built with <ArrowDiagram> (leader-line) because the placeholder asks for real
// directional arrows in clean column gaps that cross no body text — the right
// case for it. Boxes are custom HTML (title + two body lines), rendered verbatim.
// Wrapped in <Figure expandable={false}> at the call site: ArrowDiagram's leader
// lines are body-positioned and break if relocated into the expand lightbox.
//
// Static figure — no interactivity. Single horizontal row, well under the 800px
// height cap; collapses to a vertical stack on narrow cards (arrows degrade
// gracefully, the left→right reading order carries the fork).

import ArrowDiagram from "../../../../components/figures/ArrowDiagram.astro";

const mono =
	"font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Theme-aware mid-tones reused verbatim in light + dark. Tailwind 500/600 shades.
const LEAK = "#16a34a"; // green-600 — the state-leak track
const ORDER = "#f97316"; // orange-500 — the order/nondeterminism track

// Each arrow leaves the source on its right and lands on the target's left, with
// a moderate horizontal gravity so the curve bows cleanly into the column gap.
// The two arrows out of `sym` get opposite vertical gravity so they don't stack
// at the symptom box's right edge — one rises to the leak box, one drops to the
// order box.
const arrows = [
	{
		from: "sym",
		to: "cause-leak",
		color: LEAK,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [80, -40],
		endSocketGravity: [-80, 0],
	},
	{
		from: "sym",
		to: "cause-order",
		color: ORDER,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [80, 40],
		endSocketGravity: [-80, 0],
	},
	{
		from: "cause-leak",
		to: "fix-leak",
		color: LEAK,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
	},
	{
		from: "cause-order",
		to: "fix-order",
		color: ORDER,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
	},
];
---

<ArrowDiagram arrows={arrows}>
	<div class="ftb not-content">
		{/* COLUMN 1 — the single symptom the developer actually sees. */}
		<div class="ftb-col ftb-col--sym">
			<div class="ftb-box ftb-box--sym" id="sym">
				<span class="ftb-eyebrow">Symptom</span>
				<span class="ftb-line">passes alone, fails in the suite</span>
				<span class="ftb-line">passes one order, fails another</span>
			</div>
		</div>

		{/* COLUMN 2 — the two root-cause buckets the symptom forks into. */}
		<div class="ftb-col ftb-col--cause">
			<div class="ftb-box ftb-box--leak" id="cause-leak">
				<span class="ftb-title">State leak</span>
				<span class="ftb-line">a test leaves a mutation the next test inherits</span>
			</div>
			<div class="ftb-box ftb-box--order" id="cause-order">
				<span class="ftb-title">Order / nondeterminism</span>
				<span class="ftb-line">the test depends on run order, real time, or a random value</span>
			</div>
		</div>

		{/* COLUMN 3 — the fix shape each bucket points at. */}
		<div class="ftb-col ftb-col--fix">
			<div class="ftb-box ftb-box--leak" id="fix-leak">
				<span class="ftb-title">Isolate or reset</span>
				<span class="ftb-line">structurally, in a fixture or <code>afterEach</code></span>
			</div>
			<div class="ftb-box ftb-box--order" id="fix-order">
				<span class="ftb-title">Remove the dependency</span>
				<span class="ftb-line">seam it, then prove with <code>--sequence.shuffle.files</code></span>
			</div>
		</div>
	</div>
</ArrowDiagram>

<style define:vars={{ leak: LEAK, order: ORDER, monoFont: mono, sansFont: sans }}>
	.ftb {
		margin: 0;
		display: grid;
		grid-template-columns:
			minmax(150px, 190px)
			minmax(180px, 240px)
			minmax(180px, 240px);
		column-gap: 110px;
		align-items: center;
		width: 100%;
		max-width: 760px;
		margin-inline: auto;
		box-sizing: border-box;
		font-family: var(--sansFont);
	}

	.ftb-col {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 34px;
		width: 100%;
	}

	/* Each box: rounded, hairline-bordered, padded. */
	.ftb-box {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 12px 14px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
	}

	/* The starting symptom box is the neutral anchor of the fork. */
	.ftb-box--sym {
		border-color: var(--sl-color-gray-3);
		background: var(--sl-color-gray-6);
	}

	/* Track colours: green = state leak, orange = order/nondeterminism. */
	.ftb-box--leak {
		border-color: color-mix(in srgb, var(--leak) 55%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--leak) 9%, var(--sl-color-bg));
	}
	.ftb-box--order {
		border-color: color-mix(in srgb, var(--order) 55%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--order) 9%, var(--sl-color-bg));
	}

	.ftb-eyebrow {
		margin: 0;
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		line-height: 1.2;
		color: var(--sl-color-gray-2);
	}

	.ftb-title {
		margin: 0;
		font-size: 14px;
		font-weight: 800;
		line-height: 1.25;
		color: var(--sl-color-white);
	}

	.ftb-box--leak .ftb-title {
		color: color-mix(in srgb, var(--leak) 75%, var(--sl-color-white));
	}
	.ftb-box--order .ftb-title {
		color: color-mix(in srgb, var(--order) 80%, var(--sl-color-white));
	}

	.ftb-line {
		margin: 0;
		font-size: 12.5px;
		font-weight: 500;
		line-height: 1.35;
		color: var(--sl-color-gray-1, var(--sl-color-white));
	}
	.ftb-box--sym .ftb-line {
		font-weight: 600;
		color: var(--sl-color-white);
	}

	.ftb-line code {
		font-family: var(--monoFont);
		font-size: 11.5px;
		padding: 1px 4px;
		border-radius: 5px;
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
	}

	/* On narrow cards the three columns stack vertically. The cross-region arrows
	   degrade gracefully (they arc between stacked boxes); the symptom→cause→fix
	   reading is carried by source order even before the curves. */
	@media (max-width: 620px) {
		.ftb {
			grid-template-columns: 1fr;
			row-gap: 30px;
			column-gap: 0;
			max-width: 340px;
		}
		.ftb-col {
			gap: 14px;
		}
	}
</style>
