---
// One panel of the getdb-fork-two-states DiagramSequence (Ch088 L6, "Webhook
// receivers under test"). This is the conceptual core of the AsyncLocalStorage
// section: the student coming from explicit `createInvoice(input, { db: tx })`
// passing asks "where did `tx` go?" — nothing in the handler's call tree mentions
// it, yet every query uses it. The diagram makes that IMPLICIT flow visible.
//
// One <Fork state="prod" /> / <Fork state="test" /> renders inside each
// <DiagramStep>. BOTH panels render the SAME call tree — POST(request) → getDb()
// → the `?? defaultDb` fork → db.transaction(...) → claimEvent / dispatch — and
// change ONLY three things: the store contents, which fork edge is lit, and the
// resolved value. Keeping the tree byte-identical frame-to-frame is the whole
// point: the eye tracks the ONE thing that differs (the store), so the `??`
// fallback clicks. It also keeps both panels the same height so
// DiagramSequence's grid stack never reflows.
//
// The store sits to the LEFT of the fork as its input — getStore() reads it. In
// `prod` the store is empty → getStore() is undefined → the `?? defaultDb` arm is
// taken → real singleton → every query commits for real. In `test` the handler
// runs inside testTxContext.run(tx, () => POST(request)), so the store holds tx →
// getStore() returns tx → the left arm is taken → every query rides the tx that
// withRollback rolls back.
//
// Pure HTML + CSS per the diagrams guide (a small fixed call tree with one fork,
// no real graph engine needed). `not-content` + margin:0 resets defeat
// Starlight's injected prose margins. DiagramSequence supplies the outer card, so
// this component is only the step body — no <Figure>/<DiagramSequence> wrapper.
//
// Colour language, theme-stable via color-mix so tints track the page background,
// shared with the rest of this chapter's visual family:
//   blue  (#3b82f6, DiagramSequence's own accent) = the shared, unchanging spine
//         (POST, getDb, transaction, leaves) — same in both panels.
//   green (#16a34a) = the `tx` path: the populated store, the left fork arm, the
//         resolved value when the test owns the store. Matches lesson 1's "rides
//         the tx" green and the MDX highlighting testTxContext.run green.
//   gray  = whichever fork arm is NOT taken this panel — ghosted, never gone, so
//         the fork's shape is identical in both states.

interface Props {
	// Which state this panel shows. `prod`: empty store → defaultDb.
	// `test`: store holds tx → tx.
	state: 'prod' | 'test';
}

const { state } = Astro.props;
const isTest = state === 'test';

// The left arm (tx) is taken in the test panel; the right arm (defaultDb) in prod.
const resolved = isTest ? 'tx' : 'defaultDb';

const BLUE = '#3b82f6';
const GREEN = '#16a34a';
---

<div
	class="gf not-content"
	data-state={state}
	role="img"
	aria-label={`getDb call tree. ${
		isTest
			? 'Test panel: the AsyncLocalStorage store holds tx, so getStore() returns tx and the fork resolves to tx; every query rides the transaction.'
			: 'Production panel: the AsyncLocalStorage store is empty, so getStore() returns undefined and the fork resolves to the real defaultDb singleton; every query commits for real.'
	}`}
>
	<!-- Entry node: the fixed Next.js handler signature. -->
	<div class="gf-node gf-node--spine">
		<code>POST(request)</code>
	</div>
	<span class="gf-edge gf-edge--spine" aria-hidden="true"></span>

	<!-- getDb() — the one indirection production already exposes. -->
	<div class="gf-node gf-node--spine">
		<code>getDb()</code>
	</div>
	<span class="gf-edge gf-edge--spine" aria-hidden="true"></span>

	<!-- The fork row: the store feeds getStore(), the fork resolves one arm. -->
	<div class="gf-fork-row">
		<div
			class:list={['gf-store', { 'is-populated': isTest }]}
			aria-hidden="true"
		>
			<span class="gf-store-label">AsyncLocalStorage store</span>
			<span class="gf-store-value">{isTest ? 'tx' : '∅ empty'}</span>
		</div>

		<span
			class:list={['gf-edge', 'gf-edge--store', { 'is-test': isTest }]}
			aria-hidden="true"></span>

		<div class="gf-fork">
			<code class="gf-fork-expr"
				><span class:list={['gf-fork-store-call', { 'is-on': isTest }]}
					>als.getStore()</span
				> ?? <span class:list={['gf-fork-fallback', { 'is-on': !isTest }]}
					>defaultDb</span
				></code
			>
			<span class="gf-fork-arms">
				<span class:list={['gf-arm', 'gf-arm--tx', { 'is-on': isTest }]}>
					<span class="gf-arm-edge" aria-hidden="true"></span>
					<span class="gf-arm-target"><code>tx</code></span>
				</span>
				<span class:list={['gf-arm', 'gf-arm--default', { 'is-on': !isTest }]}>
					<span class="gf-arm-edge" aria-hidden="true"></span>
					<span class="gf-arm-target"><code>defaultDb</code></span>
				</span>
			</span>
		</div>
	</div>

	<!-- The resolved value flows down into the transaction. -->
	<div class="gf-resolved" aria-hidden="true">
		<span class="gf-resolved-label">getDb() →</span>
		<code class="gf-resolved-value">{resolved}</code>
	</div>
	<span class="gf-edge gf-edge--spine" aria-hidden="true"></span>

	<!-- db.transaction on the resolved handle, and the leaves that ride it. -->
	<div class="gf-node gf-node--spine">
		<code>{resolved}.transaction(...)</code>
	</div>
	<span class="gf-edge gf-edge--spine" aria-hidden="true"></span>

	<div class="gf-leaves">
		<div class="gf-node gf-node--leaf"><code>claimEvent</code></div>
		<div class="gf-node gf-node--leaf"><code>dispatch</code></div>
	</div>

	<p class="gf-verdict">
		Every query rides <code>{resolved}</code> —{' '}
		<span class:list={['gf-verdict-tag', isTest ? 'is-test' : 'is-prod']}>
			{isTest ? 'rolled back by withRollback' : 'commits for real'}
		</span>
	</p>
</div>

<style define:vars={{ 'gf-blue': BLUE, 'gf-green': GREEN }}>
	.gf {
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
	}

	.gf code {
		font-family: inherit;
		font-size: 12.5px;
		background: transparent;
		border: 0;
		padding: 0;
		color: inherit;
	}

	/* ── Spine nodes (identical in both panels) ───────────────────────────── */
	.gf-node {
		margin: 0;
		box-sizing: border-box;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 8px 14px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-text);
		font-weight: 700;
		text-align: center;
	}
	.gf-node--spine {
		border-color: color-mix(in srgb, var(--gf-blue) 38%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--gf-blue) 7%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--gf-blue) 80%, var(--sl-color-text));
	}

	/* Vertical connectors between spine rows. */
	.gf-edge--spine {
		display: block;
		width: 2px;
		height: 16px;
		background: color-mix(in srgb, var(--gf-blue) 42%, var(--sl-color-gray-4));
	}

	.gf-leaves {
		margin: 0;
		display: flex;
		gap: 10px;
	}
	.gf-node--leaf {
		font-weight: 600;
		font-size: 12px;
		padding: 6px 12px;
		color: color-mix(in srgb, var(--gf-blue) 72%, var(--sl-color-text));
	}

	/* ── The fork row: store → getStore() ?? defaultDb ────────────────────── */
	.gf-fork-row {
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0;
		flex-wrap: wrap;
	}

	.gf-store {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		padding: 9px 13px;
		border-radius: 10px;
		border: 1.5px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-3);
		transition:
			border-color 0.16s,
			background-color 0.16s,
			color 0.16s;
	}
	.gf-store.is-populated {
		border-style: solid;
		border-color: color-mix(in srgb, var(--gf-green) 55%, transparent);
		background: color-mix(in srgb, var(--gf-green) 12%, transparent);
		color: color-mix(in srgb, var(--gf-green) 82%, var(--sl-color-text));
	}
	.gf-store-label {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			sans-serif
		);
		font-size: 9.5px;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		line-height: 1.1;
	}
	.gf-store-value {
		margin: 0;
		font-size: 14px;
		font-weight: 800;
		line-height: 1.1;
	}

	/* Horizontal connector from the store into the fork. Lit green only when the
	   store actually feeds a value (test); ghosted in prod (empty → undefined). */
	.gf-edge--store {
		display: block;
		width: 26px;
		height: 2px;
		background: var(--sl-color-gray-4);
		transition: background-color 0.16s;
	}
	.gf-edge--store.is-test {
		background: color-mix(in srgb, var(--gf-green) 60%, transparent);
	}

	.gf-fork {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		padding: 12px 15px 14px;
		border-radius: 11px;
		border: 1.5px solid var(--gf-blue);
		background: color-mix(in srgb, var(--gf-blue) 9%, var(--sl-color-bg));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--gf-blue) 12%, transparent);
	}
	.gf-fork-expr {
		font-size: 13px;
		font-weight: 700;
		color: var(--sl-color-gray-2);
		white-space: nowrap;
	}
	/* The two halves of the `?? ` expression: highlight whichever side wins. */
	.gf-fork-store-call,
	.gf-fork-fallback {
		padding: 1px 4px;
		border-radius: 5px;
		opacity: 0.55;
		transition:
			opacity 0.16s,
			background-color 0.16s,
			color 0.16s;
	}
	.gf-fork-store-call.is-on {
		opacity: 1;
		background: color-mix(in srgb, var(--gf-green) 18%, transparent);
		color: color-mix(in srgb, var(--gf-green) 88%, var(--sl-color-text));
	}
	.gf-fork-fallback.is-on {
		opacity: 1;
		background: color-mix(in srgb, var(--gf-blue) 18%, transparent);
		color: color-mix(in srgb, var(--gf-blue) 88%, var(--sl-color-text));
	}

	/* The two outgoing arms. The taken arm is solid + coloured; the other is a
	   ghost, present so the fork's shape is identical in both panels. */
	.gf-fork-arms {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		gap: 30px;
	}
	.gf-arm {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		opacity: 0.4;
		transition: opacity 0.16s;
	}
	.gf-arm.is-on {
		opacity: 1;
	}
	.gf-arm-edge {
		display: block;
		width: 2px;
		height: 14px;
		background: var(--sl-color-gray-4);
	}
	.gf-arm-target {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 4px 12px;
		border-radius: 8px;
		border: 1.5px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg);
		font-weight: 800;
		color: var(--sl-color-gray-3);
	}
	.gf-arm--tx.is-on .gf-arm-edge {
		background: color-mix(in srgb, var(--gf-green) 60%, transparent);
	}
	.gf-arm--tx.is-on .gf-arm-target {
		border-color: color-mix(in srgb, var(--gf-green) 55%, transparent);
		background: color-mix(in srgb, var(--gf-green) 13%, transparent);
		color: color-mix(in srgb, var(--gf-green) 86%, var(--sl-color-text));
	}
	.gf-arm--default.is-on .gf-arm-edge {
		background: color-mix(in srgb, var(--gf-blue) 55%, transparent);
	}
	.gf-arm--default.is-on .gf-arm-target {
		border-color: color-mix(in srgb, var(--gf-blue) 50%, transparent);
		background: color-mix(in srgb, var(--gf-blue) 12%, transparent);
		color: color-mix(in srgb, var(--gf-blue) 86%, var(--sl-color-text));
	}

	/* ── Resolved value flowing down into the transaction ─────────────────── */
	.gf-resolved {
		margin: 6px 0 0;
		display: inline-flex;
		align-items: center;
		gap: 7px;
		padding: 5px 12px;
		border-radius: 999px;
		border: 1.5px solid
			color-mix(in srgb, var(--branch) 50%, transparent);
		background: color-mix(in srgb, var(--branch) 12%, transparent);
	}
	.gf-resolved-label {
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			sans-serif
		);
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}
	.gf-resolved-value {
		font-size: 13px;
		font-weight: 800;
		color: color-mix(in srgb, var(--branch) 86%, var(--sl-color-text)) !important;
	}

	/* ── The verdict line under the tree ──────────────────────────────────── */
	.gf-verdict {
		margin: 14px 0 0;
		display: inline-flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: center;
		gap: 7px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			sans-serif
		);
		font-size: 12.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2);
		text-align: center;
	}
	.gf-verdict code {
		font-size: 12px;
		font-weight: 800;
		color: color-mix(in srgb, var(--branch) 84%, var(--sl-color-text));
	}
	.gf-verdict-tag {
		display: inline-flex;
		align-items: center;
		padding: 3px 10px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.02em;
	}
	.gf-verdict-tag.is-test {
		color: color-mix(in srgb, var(--gf-green) 86%, var(--sl-color-text));
		border: 1.5px solid color-mix(in srgb, var(--gf-green) 50%, transparent);
		background: color-mix(in srgb, var(--gf-green) 12%, transparent);
	}
	.gf-verdict-tag.is-prod {
		color: color-mix(in srgb, var(--gf-blue) 86%, var(--sl-color-text));
		border: 1.5px solid color-mix(in srgb, var(--gf-blue) 50%, transparent);
		background: color-mix(in srgb, var(--gf-blue) 12%, transparent);
	}

	/* Per-panel branch accent: green when tx wins, blue when defaultDb wins.
	   Lets the resolved pill + verdict tint themselves from one variable. */
	.gf[data-state='test'] {
		--branch: var(--gf-green);
	}
	.gf[data-state='prod'] {
		--branch: var(--gf-blue);
	}

	/* ── Narrow viewports: stack the store above the fork ─────────────────── */
	@media (max-width: 560px) {
		.gf-fork-row {
			flex-direction: column;
		}
		.gf-edge--store {
			width: 2px;
			height: 16px;
		}
		.gf-fork-arms {
			gap: 20px;
		}
	}
</style>
