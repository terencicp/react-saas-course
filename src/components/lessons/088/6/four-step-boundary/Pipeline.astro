---
// One frame of the four-step-boundary DiagramSequence (Ch088 L6, "Webhook
// receivers under test"). This is a RECALL visual: the student already built
// this receiver in chapters 063/065, so the nodes stay lean — no implementation
// detail inside them. The value of each frame is its caption (supplied in the
// MDX), which names the production incident that step exists to prevent. The
// strip's only job is to keep the eye anchored on which of the four steps is the
// one whose failure mode the caption is describing.
//
// One <Pipeline active={n} /> renders inside each <DiagramStep>. Every step
// renders the SAME four-box strip and lights exactly one box plus the connectors
// already crossed, so the geometry is stable frame-to-frame and DiagramSequence's
// grid stack never reflows.
//
// The four steps, left to right — the receiver's strict order:
//   Verify raw body → Claim in processed_events → Dispatch side effect → Respond
//
// Pure HTML + CSS per the diagrams guide (a sequential phase strip, no graph, no
// parallelism), mirroring the lesson-1 rollback-lifecycle Stage so the chapter
// reads as one visual family. `not-content` + margin:0 resets defeat Starlight's
// injected prose margins. DiagramSequence supplies the outer card, so this
// component is only the step body — no <Figure>/<DiagramSequence> wrapper here.
//
// Colour language, theme-stable via color-mix so tints track the page background:
//   blue (#3b82f6, matching DiagramSequence's own accent) = the active step.
// Every step shares one accent because no step is "more correct" than another —
// the order itself is the design, and the caption carries each step's stakes.

interface Props {
	// Index (0-3) of the lit step this frame.
	active: number;
}

const { active } = Astro.props;

// The four steps, in strict order. `label` is the box headline; `sub` its
// one-word role. Kept lean — this is recall of an already-built handler.
const steps: { label: string; sub: string }[] = [
	{ label: 'Verify raw body', sub: 'signature' },
	{ label: 'Claim in processed_events', sub: 'dedupe' },
	{ label: 'Dispatch side effect', sub: 'in tx' },
	{ label: 'Respond', sub: 'status' },
];

const BLUE = '#3b82f6';
---

<div class="wb not-content" data-active={active}>
	<div
		class="wb-strip"
		role="img"
		aria-label={`Webhook receiver pipeline: Verify raw body, Claim in processed_events, Dispatch side effect, Respond. Active step: ${steps[active]?.label}.`}
	>
		{
			steps.map((step, i) => (
				<>
					<div class:list={['wb-node', { 'is-on': i === active }]}>
						<span class="wb-node-num">{i + 1}</span>
						<span class="wb-node-text">
							<span class="wb-node-label">{step.label}</span>
							<span class="wb-node-sub">{step.sub}</span>
						</span>
					</div>
					{i < steps.length - 1 && (
						<span class:list={['wb-arrow', { 'is-on': i < active }]} aria-hidden="true">
							<svg viewBox="0 0 34 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="1" y1="7" x2="26" y2="7" />
								<polyline points="21 2.5 27.5 7 21 11.5" />
							</svg>
						</span>
					)}
				</>
			))
		}
	</div>

	<p class="wb-boundary" aria-hidden="true">
		<span class="wb-boundary-mark">trust boundary</span>
		<span class="wb-boundary-note">nothing past step 1 is trusted; nothing past step 2 may run twice</span>
	</p>
</div>

<style define:vars={{ 'wb-blue': BLUE }}>
	.wb {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 14px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* ── The horizontal four-step strip ───────────────────────────────────── */
	.wb-strip {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
	}

	.wb-node {
		margin: 0;
		flex: 1 1 0;
		min-width: 116px;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 12px 13px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: left;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s;
	}
	.wb-node.is-on {
		border: 1.5px solid var(--wb-blue);
		background: color-mix(in srgb, var(--wb-blue) 13%, transparent);
		color: color-mix(in srgb, var(--wb-blue) 82%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--wb-blue) 14%, transparent);
	}

	.wb-node-num {
		margin: 0;
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		border-radius: 999px;
		border: 1.5px solid var(--sl-color-gray-4);
		font-size: 11px;
		font-weight: 800;
		line-height: 1;
		color: var(--sl-color-gray-3);
	}
	.wb-node.is-on .wb-node-num {
		border-color: var(--wb-blue);
		background: color-mix(in srgb, var(--wb-blue) 18%, transparent);
		color: color-mix(in srgb, var(--wb-blue) 88%, var(--sl-color-text));
	}

	.wb-node-text {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}
	.wb-node-label {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12.5px;
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1.2;
	}
	.wb-node-sub {
		margin: 0;
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		line-height: 1.2;
		opacity: 0.85;
	}

	/* Connectors light up once crossed, so the strip reads as strict order. */
	.wb-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.wb-arrow.is-on {
		color: var(--wb-blue);
	}
	.wb-arrow svg {
		width: 26px;
		height: 14px;
	}

	/* ── The boundary annotation under the strip ──────────────────────────── */
	.wb-boundary {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 9px;
		padding: 9px 14px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
	}
	.wb-boundary-mark {
		margin: 0;
		flex: 0 0 auto;
		font-size: 10.5px;
		font-weight: 800;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 3px 9px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--wb-blue) 84%, var(--sl-color-text));
		border: 1.5px solid color-mix(in srgb, var(--wb-blue) 50%, transparent);
		background: color-mix(in srgb, var(--wb-blue) 11%, transparent);
	}
	.wb-boundary-note {
		margin: 0;
		font-size: 11.5px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-3);
	}

	/* ── Narrow viewports: stack the strip, rotate the connectors ─────────── */
	@media (max-width: 600px) {
		.wb-strip {
			flex-direction: column;
			align-items: stretch;
		}
		.wb-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
