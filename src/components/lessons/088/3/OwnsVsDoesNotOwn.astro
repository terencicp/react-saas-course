---
// "Owns vs does-not-own" reference card (Chapter 088 L3, "The signedInAs
// fixture"). Goal: draw the identity-vs-activity boundary BEFORE the student is
// tempted to cross it — the line that keeps the fixture from rotting into a
// god-object. Two side-by-side "table-cards":
//
//   LEFT  — signedInAs OWNS: identity. The user/org/membership/session/header
//           rows the fixture sets up so a caller is signed in.
//   RIGHT — per-test factories OWN: activity. The world-state a particular test
//           arranges itself (`await buildInvoice(...)` x3, a past-due sub, an
//           existing invoice number).
//
// The split reads at a glance because the two columns are tinted with two
// DISTINCT accents:
//   indigo = identity (the fixture's job)   #4f46e5
//   amber  = activity (the test's job)       #d97706
// These deliberately avoid the chapter's green=covered / red=missed semantic
// pair so nothing is overloaded.
//
// The right column's items lead with the plain-English "the user has…" sentence
// and trail a monospace factory call, mirroring the prose's "is vs has" rule.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// the grid collapses to one column under ~560px. No JS, devtools-inspectable,
// height-capped well under the laptop ceiling.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

const IDENTITY = "#4f46e5"; // indigo-600 — the fixture's job
const ACTIVITY = "#d97706"; // amber-600 — the test's job

// Soft tint backgrounds derived from the accents, readable on light + dark.
const IDENTITY_TINT = "rgba(79, 70, 229, 0.08)";
const ACTIVITY_TINT = "rgba(217, 119, 6, 0.08)";

// ---- column data --------------------------------------------------------

const identityRows = [
	{ text: "the ", em: "user", rest: " row" },
	{ text: "the ", em: "org", rest: " row (or reuse of the seed org)" },
	{ text: "the ", em: "membership", rest: " linking user → org with a role" },
	{ text: "the ", em: "session", rest: "" },
	{ text: "the cookie + ", em: "Origin", rest: " headers" },
];

// Right column: plain-English sentence + an optional monospace factory call.
const activityRows = [
	{
		text: "“the user ",
		em: "has",
		rest: " 3 invoices”",
		call: "await buildInvoice({ orgId: ctx.org.id }, tx)  ×3",
	},
	{
		text: "“the org is on a past-due subscription”",
		em: "",
		rest: "",
		call: "",
	},
	{
		text: "“an invoice already exists with number INV-1001”",
		em: "",
		rest: "",
		call: "",
	},
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: grid",
	"grid-template-columns: repeat(auto-fit, minmax(248px, 1fr))",
	"gap: 16px",
	"width: 100%",
	"max-width: 720px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// One column = a tinted card with a colored header band and a list of rows.
const card = (tint: string, accent: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"border-radius: 12px",
		"border: 1px solid " + accent,
		"background: " + tint,
		"overflow: hidden",
	].join("; ");

const cardHeader = (accent: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"gap: 2px",
		"padding: 10px 14px",
		"background: " + accent,
		"color: #ffffff",
	].join("; ");

const headerEyebrow = [
	reset,
	sans,
	"font-size: 11px",
	"font-weight: 700",
	"letter-spacing: 0.07em",
	"text-transform: uppercase",
	"opacity: 0.85",
].join("; ");

const headerTitle = (isMono: boolean) =>
	[
		reset,
		isMono ? mono : sans,
		"font-size: 14.5px",
		"font-weight: 800",
		"line-height: 1.25",
	].join("; ");

const list = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"list-style: none",
	"padding: 6px 0",
	"flex: 1 1 auto",
].join("; ");

const listItem = (accent: string, last: boolean) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"gap: 5px",
		"padding: 9px 14px",
		"border-left: 3px solid " + accent,
		last ? "" : "border-bottom: 1px solid var(--sl-color-gray-6, rgba(125,125,125,0.18))",
	].join("; ");

const itemText = [
	reset,
	sans,
	"font-size: 13.5px",
	"line-height: 1.35",
	"color: var(--sl-color-white, currentColor)",
].join("; ");

const emphasis = (accent: string) =>
	[
		reset,
		mono,
		"font-weight: 700",
		"color: " + accent,
	].join("; ");

// The trailing factory call chip on right-column rows.
const callChip = [
	reset,
	mono,
	"box-sizing: border-box",
	"display: inline-block",
	"align-self: flex-start",
	"padding: 3px 8px",
	"border-radius: 6px",
	"background: var(--sl-color-gray-7, rgba(125,125,125,0.08))",
	"border: 1px solid var(--sl-color-gray-5, rgba(125,125,125,0.3))",
	"font-size: 11.5px",
	"line-height: 1.3",
	"color: var(--sl-color-gray-2, #6b7280)",
	"white-space: pre-wrap",
].join("; ");
---

<div class="not-content" style={root}>
	<section style={card(IDENTITY_TINT, IDENTITY)}>
		<div style={cardHeader(IDENTITY)}>
			<span style={headerEyebrow}>Identity</span>
			<span style={headerTitle(true)}>signedInAs owns</span>
		</div>
		<ul style={list}>
			{
				identityRows.map((r, i) => (
					<li style={listItem(IDENTITY, i === identityRows.length - 1)}>
						<span style={itemText}>
							{r.text}
							<span style={emphasis(IDENTITY)}>{r.em}</span>
							{r.rest}
						</span>
					</li>
				))
			}
		</ul>
	</section>

	<section style={card(ACTIVITY_TINT, ACTIVITY)}>
		<div style={cardHeader(ACTIVITY)}>
			<span style={headerEyebrow}>Activity</span>
			<span style={headerTitle(false)}>Per-test factories own</span>
		</div>
		<ul style={list}>
			{
				activityRows.map((r, i) => (
					<li style={listItem(ACTIVITY, i === activityRows.length - 1)}>
						<span style={itemText}>
							{r.text}
							{r.em && <span style={emphasis(ACTIVITY)}>{r.em}</span>}
							{r.rest}
						</span>
						{r.call && <code style={callChip}>{r.call}</code>}
					</li>
				))
			}
		</ul>
	</section>
</div>
