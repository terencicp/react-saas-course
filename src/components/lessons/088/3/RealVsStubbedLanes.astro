---
// "Real vs stubbed lanes" figure (Chapter 088 L3, "The signedInAs fixture").
// Goal: justify the real-rows + stubbed-session hybrid by drawing the two paths
// the action takes through a test as two PARALLEL lanes that never cross — the
// whole point being that "real" and "stubbed" touch different things.
//
//   LANE A — Real, runs in tx, rolls back. The action reading its OWN data:
//            action body → tenant query → real user/org/membership/invoices
//            rows (in tx). Terminal box tinted GREEN to echo the chapter's
//            rollback-safety colour.
//   LANE B — Stubbed, no DB, no crypto. The session decode the FRAMEWORK owns:
//            action wrapper → requireOrgUser → auth.api.getSession → a fake
//            session. Terminal box tinted a contrasting AMBER so the stub reads
//            as "the one synthetic thing".
//
// Each lane is a left-to-right flex row of boxes separated by a chevron glyph;
// direction is carried by the chevrons, so no JS / leader-line. The two lanes
// sit one above the other with a clear gap and never connect — the visual
// argument that the mock is drawn at exactly the right depth.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins;
// the lanes wrap their boxes on narrow viewports. Devtools-inspectable,
// height-capped well under the laptop ceiling.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";

const REAL = "#16a34a"; // green-600 — real rows, runs in tx, rolls back
const STUB = "#d97706"; // amber-600 — the stubbed session

const REAL_TINT = "rgba(22, 163, 74, 0.10)";
const STUB_TINT = "rgba(217, 119, 6, 0.10)";

// ---- lane data ----------------------------------------------------------
// `mono` flips a box to a monospace identifier; `accent`/`tint` mark the
// terminal box of each lane.

const realLane = [
	{ label: "action body", mono: false },
	{ label: "requireInvoice / tenant query", mono: true },
	{
		label: "user · org · membership · invoices rows",
		sub: "in tx",
		mono: false,
		terminal: true,
	},
];

const stubLane = [
	{ label: "action wrapper", mono: false },
	{ label: "requireOrgUser", mono: true },
	{ label: "auth.api.getSession", mono: true },
	{ label: "fake session", sub: "no DB · no crypto", mono: false, terminal: true },
];

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 22px",
	"width: 100%",
	"max-width: 760px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// One lane = an eyebrow label above a wrapping row of boxes + chevrons.
const lane = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 8px",
].join("; ");

const laneLabel = (accent: string) =>
	[
		reset,
		sans,
		"display: inline-flex",
		"align-items: center",
		"gap: 7px",
		"font-size: 11.5px",
		"font-weight: 700",
		"letter-spacing: 0.05em",
		"text-transform: uppercase",
		"color: " + accent,
	].join("; ");

const laneDot = (accent: string) =>
	[
		reset,
		"width: 9px",
		"height: 9px",
		"border-radius: 999px",
		"background: " + accent,
		"flex: 0 0 auto",
	].join("; ");

const laneRow = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"flex-wrap: wrap",
	"align-items: stretch",
	"gap: 7px",
].join("; ");

const box = (terminal: boolean, accent: string, tint: string) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"justify-content: center",
		"gap: 2px",
		"padding: 9px 12px",
		"border-radius: 9px",
		"border: 1px solid " +
			(terminal ? accent : "var(--sl-color-gray-5, rgba(125,125,125,0.4))"),
		"background: " +
			(terminal ? tint : "var(--sl-color-gray-7, rgba(125,125,125,0.06))"),
	].join("; ");

const boxLabel = (isMono: boolean, terminal: boolean, accent: string) =>
	[
		reset,
		isMono ? mono : sans,
		"font-size: 13px",
		"font-weight: " + (terminal ? "700" : "600"),
		"line-height: 1.3",
		"color: " +
			(terminal ? accent : "var(--sl-color-white, currentColor)"),
	].join("; ");

const boxSub = [
	reset,
	mono,
	"font-size: 10.5px",
	"font-weight: 600",
	"letter-spacing: 0.02em",
	"line-height: 1.2",
	"text-transform: uppercase",
	"opacity: 0.75",
].join("; ");

const chevron = [
	reset,
	"display: flex",
	"align-items: center",
	"color: var(--sl-color-gray-3, #8b8b8b)",
	"flex: 0 0 auto",
].join("; ");
---

<div class="not-content" style={root}>
	<section style={lane}>
		<span style={laneLabel(REAL)}>
			<span style={laneDot(REAL)} aria-hidden="true"></span>
			Real — runs in tx, rolls back
		</span>
		<div style={laneRow}>
			{
				realLane.map((b, i) => (
					<>
						<div style={box(!!b.terminal, REAL, REAL_TINT)}>
							<span style={boxLabel(b.mono, !!b.terminal, REAL)}>{b.label}</span>
							{b.sub && <span style={boxSub}>{b.sub}</span>}
						</div>
						{i < realLane.length - 1 && (
							<span style={chevron} aria-hidden="true">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none">
									<path
										d="M9 6l6 6-6 6"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</span>
						)}
					</>
				))
			}
		</div>
	</section>

	<section style={lane}>
		<span style={laneLabel(STUB)}>
			<span style={laneDot(STUB)} aria-hidden="true"></span>
			Stubbed — no DB, no crypto
		</span>
		<div style={laneRow}>
			{
				stubLane.map((b, i) => (
					<>
						<div style={box(!!b.terminal, STUB, STUB_TINT)}>
							<span style={boxLabel(b.mono, !!b.terminal, STUB)}>{b.label}</span>
							{b.sub && <span style={boxSub}>{b.sub}</span>}
						</div>
						{i < stubLane.length - 1 && (
							<span style={chevron} aria-hidden="true">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none">
									<path
										d="M9 6l6 6-6 6"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</span>
						)}
					</>
				))
			}
		</div>
	</section>
</div>
