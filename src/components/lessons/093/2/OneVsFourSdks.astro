---
// OneVsFourSdks — Chapter 093 Lesson 2 ("When PostHog earns its weight"),
// the "one platform vs. four vendors" contrast figure.
//
// The contrast IS the argument. Two labeled-box layouts (one per tab of the
// surrounding <TabbedContent>):
//
//   - "Four vendors": four disconnected boxes side by side, each a separate
//     vendor with its own SDK and its own "identity: ???" chip, no shared
//     line — visually isolated. The cross-tool question needs a join nobody
//     maintains.
//   - "One platform": a single PostHog hub on the left with one "distinct ID"
//     chip, fanning out with connector lines to the four primitive labels on
//     the right. One identifier feeds all four.
//
// Plain HTML + CSS per the diagram guidance (labels-only layout, NOT a diagram
// engine). The fan-out connectors in the second layout are a tiny inline SVG
// behind the boxes. Inline styles only, theme tokens via --sl-color-*,
// color-mix for accent tints so each box reads on both light and dark.
// `not-content` on each root to defeat Starlight prose-margin injection.
//
// Two named slots are NOT used — instead each layout is exported as a tiny
// component-shaped fragment selected by the `variant` prop, so the lesson
// drops one instance per tab.

interface Props {
  variant: "four" | "one";
}
const { variant } = Astro.props;

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--sl-font-system-mono, ui-monospace, monospace)";

// Shared accent palette — events=blue, flags=violet, replay=teal,
// experiments=orange, matching FourNeedsMap so the four primitives keep the
// same color identity across the lesson.
const ACCENTS = {
  events: "#2563eb",
  flags: "#7c3aed",
  replay: "#0d9488",
  experiments: "#ea580c",
} as const;

const POSTHOG = "#f54e00"; // PostHog brand orange-red

type Primitive = keyof typeof ACCENTS;
const PRIMITIVES: { key: Primitive; label: string }[] = [
  { key: "events", label: "events" },
  { key: "flags", label: "flags" },
  { key: "replay", label: "replay" },
  { key: "experiments", label: "experiments" },
];

// ---- "Four vendors" layout -------------------------------------------------

const vendors: { name: string; need: Primitive }[] = [
  { name: "Mixpanel", need: "events" },
  { name: "LaunchDarkly", need: "flags" },
  { name: "FullStory", need: "replay" },
  { name: "Statsig", need: "experiments" },
];

const fourGrid = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "display: grid",
  "grid-template-columns: repeat(auto-fit, minmax(150px, 1fr))",
  "gap: 12px",
  "align-items: stretch",
].join("; ");

const vendorCard = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 9px",
    "min-width: 0",
    "padding: 13px 13px 12px",
    "border-radius: 12px",
    `border: 1px dashed color-mix(in srgb, ${accent} 45%, var(--sl-color-gray-4))`,
    `background: color-mix(in srgb, ${accent} 6%, var(--sl-color-bg))`,
  ].join("; ");

const vendorName = (accent: string) =>
  [
    reset,
    "font-size: 14px",
    "font-weight: 700",
    "line-height: 1.15",
    `color: ${accent}`,
  ].join("; ");

const needChip = [
  reset,
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "color: var(--sl-color-gray-2)",
].join("; ");

const sdkChip = [
  reset,
  mono,
  "box-sizing: border-box",
  "align-self: flex-start",
  "font-size: 10.5px",
  "padding: 2px 7px",
  "border-radius: 999px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The "identity: ???" chip — the load-bearing detail. Warm-muted to read as a
// problem, divider above it.
const idMystery = [
  reset,
  mono,
  "box-sizing: border-box",
  "margin-top: auto",
  "padding-top: 9px",
  "border-top: 1px dashed var(--sl-color-gray-5)",
  "font-size: 11px",
  "font-weight: 600",
  "color: #b45309", // amber-700, reads as a caution on both themes
].join("; ");

// ---- "One platform" layout -------------------------------------------------

const oneWrap = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "display: flex",
  "align-items: stretch",
  "gap: 0",
].join("; ");

const hubCol = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "flex: 0 0 auto",
].join("; ");

const hubCard = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 9px",
  "padding: 16px 16px 14px",
  "border-radius: 13px",
  `border: 1.5px solid color-mix(in srgb, ${POSTHOG} 55%, transparent)`,
  `background: color-mix(in srgb, ${POSTHOG} 9%, var(--sl-color-bg))`,
  "max-width: 190px",
].join("; ");

const hubName = [
  reset,
  "font-size: 15px",
  "font-weight: 800",
  "line-height: 1.1",
  `color: ${POSTHOG}`,
].join("; ");

const hubSub = [
  reset,
  "font-size: 11px",
  "font-weight: 600",
  "color: var(--sl-color-gray-2)",
].join("; ");

const idChip = [
  reset,
  mono,
  "box-sizing: border-box",
  "align-self: flex-start",
  "font-size: 11px",
  "font-weight: 600",
  "padding: 3px 9px",
  "border-radius: 999px",
  `border: 1px solid color-mix(in srgb, ${POSTHOG} 45%, transparent)`,
  `background: color-mix(in srgb, ${POSTHOG} 14%, var(--sl-color-bg))`,
  `color: ${POSTHOG}`,
].join("; ");

// Connector column holds the fan-out SVG between hub and primitives.
const connCol = [
  reset,
  "box-sizing: border-box",
  "flex: 0 0 54px",
  "align-self: stretch",
  "min-height: 0",
  "position: relative",
].join("; ");

const svgStyle = [
  "display: block",
  "width: 100%",
  "height: 100%",
  "position: absolute",
  "inset: 0",
].join("; ");

const primCol = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 auto",
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 9px",
].join("; ");

const primPill = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "gap: 9px",
    "padding: 9px 13px",
    "border-radius: 10px",
    `border: 1px solid color-mix(in srgb, ${accent} 40%, transparent)`,
    `background: color-mix(in srgb, ${accent} 9%, var(--sl-color-bg))`,
    `border-left: 3px solid ${accent}`,
  ].join("; ");

const dot = (accent: string) =>
  [
    reset,
    "flex: 0 0 auto",
    "width: 8px",
    "height: 8px",
    "border-radius: 999px",
    `background: ${accent}`,
  ].join("; ");

const primLabel = (accent: string) =>
  [reset, "font-size: 13.5px", "font-weight: 700", `color: ${accent}`].join(
    "; ",
  );
---

{
  variant === "four" && (
    <div class="not-content" style={fourGrid}>
      {vendors.map((v) => (
        <div style={vendorCard(ACCENTS[v.need])}>
          <span style={vendorName(ACCENTS[v.need])}>{v.name}</span>
          <span style={needChip}>{v.need}</span>
          <span style={sdkChip}>+ own SDK</span>
          <span style={idMystery}>identity: ???</span>
        </div>
      ))}
    </div>
  )
}

{
  variant === "one" && (
    <div class="not-content" style={oneWrap}>
      <div style={hubCol}>
        <div style={hubCard}>
          <span style={hubName}>PostHog</span>
          <span style={hubSub}>one SDK</span>
          <span style={idChip}>distinct ID</span>
        </div>
      </div>

      <div style={connCol}>
        {/* Fan-out from the hub edge (left) to four primitive rows (right).
            viewBox 0..100 x / 0..100 y; primitive rows sit at 12.5/37.5/62.5/87.5%. */}
        <svg
          style={svgStyle}
          viewBox="0 0 100 100"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          {[12.5, 37.5, 62.5, 87.5].map((y) => (
            <path
              d={`M 0 50 C 45 50, 55 ${y}, 100 ${y}`}
              fill="none"
              stroke={POSTHOG}
              stroke-width="1.6"
              stroke-opacity="0.55"
              vector-effect="non-scaling-stroke"
            />
          ))}
        </svg>
      </div>

      <div style={primCol}>
        {PRIMITIVES.map((p) => (
          <div style={primPill(ACCENTS[p.key])}>
            <span style={dot(ACCENTS[p.key])} />
            <span style={primLabel(ACCENTS[p.key])}>{p.label}</span>
          </div>
        ))}
      </div>
    </div>
  )
}
