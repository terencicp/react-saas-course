---
// FourNeedsMap — Chapter 093 Lesson 2 ("When PostHog earns its weight"),
// the "four needs that cross the threshold" figure.
//
// Makes "four needs" a single memorable visual unit instead of a bulleted
// list buried in prose. Four compact cards side by side (one per need),
// collapsing to a 2x2 grid on narrow viewports via auto-fit/minmax. Each
// card stacks three rows: the need name (bold, with an accent icon), the
// question it answers (italic), and the concrete example ask (muted, small).
//
// Plain HTML + CSS per the diagram guidance (NOT a diagram engine — this is a
// labels-only layout). Inline styles only, theme tokens via --sl-color-*,
// color-mix for accent tints so each card reads on both light and dark.
// `margin: 0` everywhere to defeat Starlight's prose-margin injection;
// `not-content` on the root for the same reason. Each card carries its own
// saturated accent so the four needs stay visually distinct and memorable.

import { Icon } from "astro-icon/components";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

type Need = {
  name: string;
  icon: string;
  question: string;
  ask: string;
  accent: string;
};

// The four needs in the same order the prose introduces them.
const needs: Need[] = [
  {
    name: "Events",
    icon: "lucide:bar-chart-3",
    question: "What do users do across sessions?",
    ask: "Trial-to-paid funnel",
    accent: "#2563eb", // blue-600
  },
  {
    name: "Feature flags",
    icon: "lucide:toggle-right",
    question: "Who sees what feature, when?",
    ask: "Roll out to 10% of orgs",
    accent: "#7c3aed", // violet-600
  },
  {
    name: "Session replay",
    icon: "lucide:play-circle",
    question: "What did they do before they bailed?",
    ask: "The no-error dashboard bug",
    accent: "#0d9488", // teal-600
  },
  {
    name: "Experiments",
    icon: "lucide:flask-conical",
    question: "Did this change move the metric?",
    ask: "Did the new pricing copy lift upgrades?",
    accent: "#ea580c", // orange-600
  },
];

const grid = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "display: grid",
  // 4-up on wide cards, 2x2 when the figure narrows, 1-up on very narrow.
  "grid-template-columns: repeat(auto-fit, minmax(190px, 1fr))",
  "gap: 12px",
  "align-items: stretch",
].join("; ");

const card = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 8px",
    "min-width: 0",
    "padding: 14px 14px 13px",
    "border-radius: 12px",
    `border: 1px solid color-mix(in srgb, ${accent} 40%, transparent)`,
    // A faint accent wash plus a stronger left edge so each card is distinct.
    `background: color-mix(in srgb, ${accent} 8%, var(--sl-color-bg))`,
    `border-left: 3px solid ${accent}`,
  ].join("; ");

// Top row: accent icon chip + need name.
const head = [reset, "display: flex", "align-items: center", "gap: 8px"].join(
  "; ",
);

const iconWrap = (accent: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "width: 26px",
    "height: 26px",
    "flex: 0 0 auto",
    "border-radius: 7px",
    "color: var(--sl-color-white)",
    `background: ${accent}`,
  ].join("; ");

const name = [
  reset,
  "font-size: 14.5px",
  "font-weight: 700",
  "line-height: 1.15",
  "color: var(--sl-color-white)",
  "min-width: 0",
].join("; ");

const question = [
  reset,
  "font-style: italic",
  "font-size: 13px",
  "line-height: 1.35",
  "color: var(--sl-color-gray-1)",
].join("; ");

// Pushed to the bottom so the muted "ask" rows align across cards.
const ask = [
  reset,
  "margin-top: auto",
  "padding-top: 2px",
  "font-size: 11.5px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

const askLabel = [
  reset,
  "font-size: 9.5px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "margin: 0 0 2px",
].join("; ");
---

<div class="not-content" style={grid}>
  {
    needs.map((need) => (
      <div style={card(need.accent)}>
        <div style={head}>
          <span style={iconWrap(need.accent)}>
            <Icon name={need.icon} width={16} height={16} />
          </span>
          <span style={name}>{need.name}</span>
        </div>
        <p style={question}>{need.question}</p>
        <div style={ask}>
          <div style={askLabel}>Example ask</div>
          {need.ask}
        </div>
      </div>
    ))
  }
</div>
