---
// The identify stitch (diagram id: identify-stitch-sequence, Chapter 093 L4). A
// five-step scrubbable DiagramSequence that makes the anonymous->known handshake
// concrete: every event hangs off a distinct ID, and the moment identify() fires
// PostHog re-tags the prior anonymous events to the stable user ID. That re-tag
// IS the stitch — the frame the whole section is built around — and the last step
// makes the once-per-session rule visceral by showing a second identify() get
// rejected.
//
//   Step 1  Before sign-in: one "anon_8f3..." box, three event chips below it,
//           every chip tagged anon. This is the anonymous person.
//   Step 2  Sign-in fires identify('user_123', { email }). The anon box and the
//           three chips are unchanged; a call-out chip shows the identify() call.
//           Nothing has moved yet — the call is in flight.
//   Step 3  THE STITCH. An arrow anon_8f3... -> user_123 is drawn, and the three
//           prior chips re-tag from anon (struck) to user_123 (green emphasis).
//           This is the key frame: the anonymous events are not lost, they are
//           linked to the now-known person.
//   Step 4  New events fire directly under user_123: the three stitched chips
//           plus a fresh plan_upgraded chip, all tagged user_123.
//   Step 5  The failure case: a second identify('user_456') with no reset is
//           struck through and marked rejected, with a fix arrow to reset() first.
//
// Layout: a fixed skeleton on every step — an identity row at the top (one or two
// id boxes), a column of event chips in a reserved-height area, and a status strip
// below. All five steps share the shape so the grid stack never reflows; the chip
// area reserves room for four chips so steps 1-3 (three chips) don't grow when
// step 4 adds the fourth.
//
// House style follows this codebase's DiagramSequence components (SnapshotTimeline
// / StaleFrameSequence): fixed slate ink, color-scheme pinned light so the
// hand-picked tints survive dark mode, `margin: 0` on every inner element to
// defeat Starlight's injected prose margins. Blue is the known-user accent (the
// lesson's primary tint), green is the stitch emphasis, red the rejection, slate
// the anonymous/neutral state.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary chip surface
const BORDER = '#cbd5e1'; // ordinary edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)

const SLATE_TAG = '#64748b'; // anon tag pill (slate-500)
const SLATE_TAG_BG = '#e2e8f0'; // anon tag wash (slate-200)

const BLUE = '#2563eb'; // blue-600 — the known user accent
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const GREEN = '#16a34a'; // green-600 — the stitch emphasis
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const RED = '#dc2626'; // red-600 — the rejection
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all five steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The identity row at the top: one or two distinct-id boxes joined by an arrow.
const idRow = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 10px; margin: 0; min-height: 58px;`;

// A distinct-id box. `tone` swaps anon (slate) / known (blue) / dim (faded
// previous box during the stitch).
const idBoxBase = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 3px; margin: 0; padding: 8px 14px; border-radius: 10px; min-width: 158px;`;
const idBox = {
	anon: `${idBoxBase} border: 1.5px solid ${BORDER}; background: ${PANEL_BG};`,
	known: `${idBoxBase} border: 2px solid ${BLUE}; background: ${BLUE_BG}; box-shadow: 0 1px 4px rgba(37, 99, 235, 0.25);`,
	dim: `${idBoxBase} border: 1.5px dashed ${BORDER}; background: ${SURFACE}; opacity: 0.6;`,
};
const idEyebrow = (tone: 'anon' | 'known') =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: ${tone === 'known' ? BLUE : INK_SOFT};`;
const idValue = (tone: 'anon' | 'known' | 'dim') =>
	`margin: 0; font-family: ${mono}; font-size: 14px; font-weight: 700; color: ${tone === 'known' ? BLUE_INK : INK};`;

// The arrow that links the anon box to the known box during the stitch.
const linkArrow = `display: flex; flex: 0 0 auto; flex-direction: column; align-items: center; gap: 1px; margin: 0;`;
const linkArrowGlyph = `margin: 0; font-family: ${sans}; font-size: 22px; font-weight: 800; line-height: 1; color: ${GREEN};`;
const linkArrowLabel = `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${GREEN};`;

// The "events" wash that holds the chip column — labelled and reserved-height so
// the four-chip step doesn't grow the figure past the three-chip steps.
const eventsBox = `box-sizing: border-box; display: flex; flex-direction: column; gap: 7px; margin: 0; padding: 10px 12px 12px; border: 1px solid ${BORDER}; border-radius: 12px; background: #fafbfc; width: 100%; max-width: 380px; min-height: 196px;`;
const eventsLabel = `display: inline-flex; align-self: flex-start; align-items: center; margin: 0; padding: 2px 8px; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT}; background: ${SURFACE}; border: 1px solid ${BORDER}; border-radius: 6px; white-space: nowrap;`;

// One event chip: an event name on the left, a "tag" pill on the right showing
// which distinct ID it is attached to. `fresh` outlines a just-fired chip.
const chip = (fresh = false) =>
	`box-sizing: border-box; display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 10px; border-radius: 8px; background: ${SURFACE}; ` +
	(fresh ? `border: 1.5px solid ${BLUE}; box-shadow: 0 1px 3px rgba(37, 99, 235, 0.2);` : `border: 1px solid ${BORDER};`);
const chipName = `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 600; color: ${INK};`;

// The tag pill on a chip. `tone` swaps anon (slate) / known (blue) /
// stitched (green) / old (struck-through slate, used during the re-tag frame).
const tagBase = `display: inline-flex; align-items: center; gap: 4px; flex: 0 0 auto; margin: 0 0 0 auto; padding: 2px 8px; font-family: ${mono}; font-size: 10px; font-weight: 700; border-radius: 999px; white-space: nowrap;`;
const tag = {
	anon: `${tagBase} color: ${SLATE_TAG}; background: ${SLATE_TAG_BG}; border: 1px solid ${BORDER};`,
	known: `${tagBase} color: ${BLUE_INK}; background: ${BLUE_BG}; border: 1px solid ${BLUE};`,
	stitched: `${tagBase} color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN};`,
	old: `${tagBase} color: ${INK_SOFT}; background: ${SLATE_TAG_BG}; border: 1px solid ${BORDER}; text-decoration: line-through; opacity: 0.75;`,
};
// The little "->" between the struck old tag and the new green tag on a re-tagging chip.
const retagWrap = `display: inline-flex; align-items: center; gap: 5px; flex: 0 0 auto; margin: 0 0 0 auto;`;
const retagArrow = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 800; color: ${GREEN};`;
const inlineTag = (variant: 'old' | 'stitched') =>
	`display: inline-flex; align-items: center; padding: 2px 8px; font-family: ${mono}; font-size: 10px; font-weight: 700; border-radius: 999px; white-space: nowrap; ` +
	(variant === 'old'
		? `color: ${INK_SOFT}; background: ${SLATE_TAG_BG}; border: 1px solid ${BORDER}; text-decoration: line-through; opacity: 0.75;`
		: `color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN};`);

// The call-out chip carrying the identify() / reset() code, placed inside the
// events box as a distinct, accented row.
const callout = (tone: 'blue' | 'red' | 'green') => {
	const t =
		tone === 'red'
			? `color: ${RED_INK}; background: ${RED_BG}; border: 1.5px solid ${RED};`
			: tone === 'green'
				? `color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1.5px solid ${GREEN};`
				: `color: ${BLUE_INK}; background: ${BLUE_BG}; border: 1.5px solid ${BLUE};`;
	return `box-sizing: border-box; display: flex; align-items: center; gap: 8px; margin: 0; padding: 8px 11px; border-radius: 8px; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.3; ${t}`;
};
const calloutStruck = `font-family: ${mono}; font-size: 12px; font-weight: 700; text-decoration: line-through; color: ${RED_INK};`;
const calloutTag = (bg: string) =>
	`display: inline-block; flex: 0 0 auto; margin: 0; padding: 1px 6px; font-family: ${sans}; font-size: 8.5px; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; color: #ffffff; background: ${bg}; border-radius: 4px;`;

// The reserved status strip under the events box — same footprint on every step.
const stripBase = `display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 7px 13px; border-radius: 999px; font-family: ${sans}; font-size: 12.5px; font-weight: 600; line-height: 1.3; max-width: 400px; text-align: left;`;
const strip = {
	neutral: `${stripBase} color: ${INK_SOFT}; background: ${PANEL_BG}; border: 1px solid ${BORDER};`,
	blue: `${stripBase} color: ${BLUE_INK}; background: ${BLUE_BG}; border: 1px solid ${BLUE};`,
	green: `${stripBase} color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN};`,
	red: `${stripBase} color: ${RED_INK}; background: ${RED_BG}; border: 1px solid ${RED};`,
};
const stripTag = (bg: string) =>
	`display: inline-block; flex: 0 0 auto; margin: 0; padding: 1px 6px; font-family: ${mono}; font-size: 9px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #ffffff; background: ${bg}; border-radius: 4px;`;
---

<DiagramSequence>
	{/* ---- Step 1: anonymous — every event hangs off the anon distinct ID ---- */}
	<DiagramStep caption="Before sign-in: every event hangs off one anonymous distinct ID, persisted in localStorage and a cookie.">
		<div style={stage}>
			<div style={idRow}>
				<div style={idBox.anon}>
					<span style={idEyebrow('anon')}>distinct id</span>
					<span style={idValue('anon')}>anon_8f3&hellip;</span>
				</div>
			</div>
			<div style={eventsBox}>
				<span style={eventsLabel}>events captured so far</span>
				<div style={chip()}>
					<span style={chipName}>$pageview</span>
					<span style={tag.anon}>anon_8f3&hellip;</span>
				</div>
				<div style={chip()}>
					<span style={chipName}>$pageview</span>
					<span style={tag.anon}>anon_8f3&hellip;</span>
				</div>
				<div style={chip()}>
					<span style={chipName}>paywall_viewed</span>
					<span style={tag.anon}>anon_8f3&hellip;</span>
				</div>
			</div>
			<p style={strip.neutral}>An unknown visitor browsing the pricing page. Every event is attached to the same anonymous id.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: sign-in fires identify() — call in flight, nothing moved ---- */}
	<DiagramStep caption="Sign-in fires identify() with the app's stable user ID — the database primary key, never the email.">
		<div style={stage}>
			<div style={idRow}>
				<div style={idBox.anon}>
					<span style={idEyebrow('anon')}>distinct id</span>
					<span style={idValue('anon')}>anon_8f3&hellip;</span>
				</div>
			</div>
			<div style={eventsBox}>
				<span style={eventsLabel}>events captured so far</span>
				<div style={chip()}>
					<span style={chipName}>$pageview</span>
					<span style={tag.anon}>anon_8f3&hellip;</span>
				</div>
				<div style={chip()}>
					<span style={chipName}>paywall_viewed</span>
					<span style={tag.anon}>anon_8f3&hellip;</span>
				</div>
				<div style={callout('blue')}>
					<span style={calloutTag(BLUE)}>fires</span>
					<span>posthog.identify('user_123', &#123; email &#125;)</span>
				</div>
			</div>
			<p style={strip.blue}>The call is in flight. Nothing has re-tagged yet — PostHog now has the link to make.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: THE STITCH — anon -> user_123, prior chips re-tag ---- */}
	<DiagramStep caption="PostHog links the anonymous id to user_123 and re-tags the prior events. This re-tag is the stitch — the anonymous events are not lost, they are linked.">
		<div style={stage}>
			<div style={idRow}>
				<div style={idBox.dim}>
					<span style={idEyebrow('anon')}>distinct id</span>
					<span style={idValue('dim')}>anon_8f3&hellip;</span>
				</div>
				<span style={linkArrow} aria-hidden="true">
					<span style={linkArrowLabel}>link</span>
					<span style={linkArrowGlyph}>&rarr;</span>
				</span>
				<div style={idBox.known}>
					<span style={idEyebrow('known')}>distinct id</span>
					<span style={idValue('known')}>user_123</span>
				</div>
			</div>
			<div style={eventsBox}>
				<span style={eventsLabel}>events re-tagged to the known person</span>
				<div style={chip()}>
					<span style={chipName}>$pageview</span>
					<span style={retagWrap}>
						<span style={inlineTag('old')}>anon_8f3&hellip;</span>
						<span style={retagArrow} aria-hidden="true">&rarr;</span>
						<span style={inlineTag('stitched')}>user_123</span>
					</span>
				</div>
				<div style={chip()}>
					<span style={chipName}>$pageview</span>
					<span style={retagWrap}>
						<span style={inlineTag('old')}>anon_8f3&hellip;</span>
						<span style={retagArrow} aria-hidden="true">&rarr;</span>
						<span style={inlineTag('stitched')}>user_123</span>
					</span>
				</div>
				<div style={chip()}>
					<span style={chipName}>paywall_viewed</span>
					<span style={retagWrap}>
						<span style={inlineTag('old')}>anon_8f3&hellip;</span>
						<span style={retagArrow} aria-hidden="true">&rarr;</span>
						<span style={inlineTag('stitched')}>user_123</span>
					</span>
				</div>
			</div>
			<p style={strip.green}>
				<span style={stripTag(GREEN)}>the stitch</span>The pre-signup paywall_viewed now belongs to the known user.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 4: new events fire directly under user_123 ---- */}
	<DiagramStep caption="New events now fire directly under user_123 — no re-tagging needed, the person is known.">
		<div style={stage}>
			<div style={idRow}>
				<div style={idBox.known}>
					<span style={idEyebrow('known')}>distinct id</span>
					<span style={idValue('known')}>user_123</span>
				</div>
			</div>
			<div style={eventsBox}>
				<span style={eventsLabel}>one connected event stream</span>
				<div style={chip()}>
					<span style={chipName}>$pageview</span>
					<span style={tag.stitched}>user_123</span>
				</div>
				<div style={chip()}>
					<span style={chipName}>paywall_viewed</span>
					<span style={tag.stitched}>user_123</span>
				</div>
				<div style={chip(true)}>
					<span style={chipName}>plan_upgraded</span>
					<span style={tag.known}>user_123</span>
				</div>
			</div>
			<p style={strip.blue}>
				<span style={stripTag(BLUE)}>new</span>The pre-signup view and the upgrade are one person — the funnel can span the boundary.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 5: the failure case — a second identify() rejected ---- */}
	<DiagramStep caption="The failure case: a second identify() with a different ID and no reset is rejected. To switch identities, reset() first.">
		<div style={stage}>
			<div style={idRow}>
				<div style={idBox.known}>
					<span style={idEyebrow('known')}>distinct id</span>
					<span style={idValue('known')}>user_123</span>
				</div>
			</div>
			<div style={eventsBox}>
				<span style={eventsLabel}>already identified as user_123</span>
				<div style={callout('red')}>
					<span style={calloutTag(RED)}>rejected</span>
					<span style={calloutStruck}>posthog.identify('user_456')</span>
				</div>
				<p style={{ margin: 0, fontFamily: sans, fontSize: '11.5px', fontWeight: 600, lineHeight: 1.4, color: RED_INK, textAlign: 'center' }}>
					PostHog refuses to re-identify an already-identified user with a different id.
				</p>
				<div style={callout('green')}>
					<span style={calloutTag(GREEN)}>fix</span>
					<span>posthog.reset() &mdash; then identify the next user</span>
				</div>
			</div>
			<p style={strip.red}>
				<span style={stripTag(RED)}>once per session</span>The handshake happens once; switching identities needs a reset first.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
