---
// Consent fork (Chapter 093 L1): the lesson's single most important takeaway
// picture. Two LANES that make the gate-vs-no-gate boundary SPATIAL.
//
//   TOP lane  — Vercel Analytics + Speed Insights → straight, unobstructed
//               arrow → ingest. Green / open. Tag: "no consent needed —
//               cookieless". This lane has NO gate; that absence is the point.
//   BOTTOM lane — PostHog → arrow that runs THROUGH a visible checkpoint
//               labelled useConsent() → ingest. Neutral / muted. Tag: "fires
//               only on accept". The gate must read as a barrier the top lane
//               bypasses.
//
// The contrast "straight through" vs "stops at a gate" carries the whole idea,
// so the gate is the loudest element on the bottom lane and is conspicuously
// absent from the top one. Green = the cookieless floor (matches TwoTierStack);
// the PostHog lane is muted neutral so the gate reads as the differentiator.
//
// Pure HTML + inline CSS, no JS, theme-aware via Starlight variables. Wide and
// short (capped well under 300px). `margin: 0` on every descendant defeats
// Starlight's injected prose margins. The <Figure> wrapper + caption come from
// the MDX call site.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

const FLOOR = "#16a34a"; // green-600 — the cookieless floor / "go straight"
const GATE = "#d97706"; // amber-600 — the consent checkpoint

const ALT =
	"Two request lanes side by side. The top lane, Vercel Analytics plus Speed Insights, runs a straight unobstructed arrow to ingest and is tagged no consent needed — cookieless. The bottom lane, PostHog, runs an arrow through a checkpoint labelled useConsent() before reaching ingest, tagged fires only on accept. The top lane has no gate; the bottom lane stops at one.";

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 14px",
	"width: 100%",
	"max-width: 640px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// One lane = a horizontal flow row.
const lane = (open: boolean) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"align-items: center",
		"flex-wrap: wrap",
		"gap: 8px",
		"padding: 12px 14px 10px",
		"border-radius: 12px",
		open
			? "border: 2px solid color-mix(in srgb, " + FLOOR + " 50%, transparent)"
			: "border: 1.5px solid var(--sl-color-gray-4, #9ca3af)",
		open
			? "background: color-mix(in srgb, " + FLOOR + " 9%, var(--sl-color-bg))"
			: "background: color-mix(in srgb, var(--sl-color-gray-5, #6b7280) 6%, transparent)",
	].join("; ");

// Source / destination node.
const node = (open: boolean) =>
	[
		reset,
		sans,
		"flex: none",
		"display: inline-flex",
		"flex-direction: column",
		"gap: 1px",
		"padding: 8px 12px",
		"border-radius: 9px",
		"background: var(--sl-color-bg, #fff)",
		open
			? "border: 1.5px solid color-mix(in srgb, " + FLOOR + " 55%, transparent)"
			: "border: 1.5px solid var(--sl-color-gray-4, #9ca3af)",
		"max-width: 200px",
	].join("; ");

const nodeTitle = [
	reset,
	sans,
	"font-size: 13px",
	"font-weight: 700",
	"line-height: 1.2",
	"color: var(--sl-color-white, #111827)",
].join("; ");

const nodeSub = [
	reset,
	sans,
	"font-size: 11px",
	"font-weight: 500",
	"line-height: 1.2",
	"color: var(--sl-color-gray-3, #6b7280)",
].join("; ");

// The ingest endpoint — same on both lanes (a flat, neutral terminal).
const ingest = [
	reset,
	sans,
	"flex: none",
	"display: inline-flex",
	"align-items: center",
	"gap: 6px",
	"padding: 8px 12px",
	"border-radius: 9px",
	"font-size: 13px",
	"font-weight: 700",
	"color: var(--sl-color-gray-1, #374151)",
	"background: var(--sl-color-gray-6, #f3f4f6)",
	"border: 1.5px solid var(--sl-color-gray-4, #9ca3af)",
].join("; ");

// Arrow segment: a line + chevron. Grows to push nodes apart.
const arrowWrap = (open: boolean) =>
	[
		reset,
		"flex: 1 1 28px",
		"min-width: 28px",
		"display: flex",
		"align-items: center",
		"color: " + (open ? FLOOR : "var(--sl-color-gray-3, #6b7280)"),
	].join("; ");

const arrowLine = (open: boolean) =>
	[
		reset,
		"flex: 1 1 auto",
		"height: 2px",
		open
			? "background: " + FLOOR
			: "background: var(--sl-color-gray-3, #6b7280)",
	].join("; ");

const arrowHead = [reset, "flex: none", "display: flex"].join("; ");

// The consent GATE — the conspicuous checkpoint on the PostHog lane only.
const gate = [
	reset,
	sans,
	"flex: none",
	"display: inline-flex",
	"flex-direction: column",
	"align-items: center",
	"gap: 2px",
	"padding: 7px 11px",
	"border-radius: 9px",
	"background: color-mix(in srgb, " + GATE + " 14%, var(--sl-color-bg))",
	"border: 2px dashed " + GATE,
].join("; ");

const gateLabel = [
	reset,
	mono,
	"font-size: 12px",
	"font-weight: 700",
	"line-height: 1.1",
	"color: color-mix(in srgb, " + GATE + " 80%, var(--sl-color-text))",
].join("; ");

const gateNote = [
	reset,
	sans,
	"font-size: 9.5px",
	"font-weight: 700",
	"letter-spacing: 0.04em",
	"text-transform: uppercase",
	"line-height: 1",
	"color: color-mix(in srgb, " + GATE + " 78%, var(--sl-color-text))",
].join("; ");

// Per-lane caption pinned under each flow.
const tag = (open: boolean) =>
	[
		reset,
		sans,
		"flex-basis: 100%",
		"margin-top: 6px",
		"font-size: 11.5px",
		"font-weight: 600",
		open
			? "color: color-mix(in srgb, " + FLOOR + " 78%, var(--sl-color-text))"
			: "color: color-mix(in srgb, " + GATE + " 70%, var(--sl-color-text))",
	].join("; ");
---

<div class="not-content" style={root} role="img" aria-label={ALT}>
	{/* ── TOP lane — cookieless floor: straight through, no gate ──────────── */}
	<div style={lane(true)}>
		<span style={node(true)}>
			<span style={nodeTitle}>Vercel Analytics</span>
			<span style={nodeSub}>+ Speed Insights</span>
		</span>

		<span style={arrowWrap(true)}>
			<span style={arrowLine(true)}></span>
			<span style={arrowHead}>
				<svg width="9" height="12" viewBox="0 0 9 12" aria-hidden="true">
					<path d="M0 0 L9 6 L0 12 Z" fill={FLOOR} />
				</svg>
			</span>
		</span>

		<span style={ingest}>ingest</span>

		<span style={tag(true)}>no consent needed — cookieless</span>
	</div>

	{/* ── BOTTOM lane — PostHog: arrow runs THROUGH the consent gate ──────── */}
	<div style={lane(false)}>
		<span style={node(false)}>
			<span style={nodeTitle}>PostHog</span>
			<span style={nodeSub}>events · IDs · IPs</span>
		</span>

		<span style={arrowWrap(false)}>
			<span style={arrowLine(false)}></span>
			<span style={arrowHead}>
				<svg width="9" height="12" viewBox="0 0 9 12" aria-hidden="true">
					<path d="M0 0 L9 6 L0 12 Z" fill="var(--sl-color-gray-3, #6b7280)" />
				</svg>
			</span>
		</span>

		<span style={gate}>
			<span style={gateLabel}>useConsent()</span>
			<span style={gateNote}>gate</span>
		</span>

		<span style={arrowWrap(false)}>
			<span style={arrowLine(false)}></span>
			<span style={arrowHead}>
				<svg width="9" height="12" viewBox="0 0 9 12" aria-hidden="true">
					<path d="M0 0 L9 6 L0 12 Z" fill="var(--sl-color-gray-3, #6b7280)" />
				</svg>
			</span>
		</span>

		<span style={ingest}>ingest</span>

		<span style={tag(false)}>fires only on accept</span>
	</div>
</div>
