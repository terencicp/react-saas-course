---
// Two-tier analytics stack (Chapter 093 L1): the spine of the whole chapter in
// one plain illustration. Two tiers stacked vertically so the metaphor is
// literal — the bottom tier is the SOLID FOUNDATION you pour today, the top tier
// is an ADDITIVE, OPTIONAL slab that comes later.
//
// The dimming + dashed border on the top tier is LOAD-BEARING: it must read as
// "not yet — next lesson" against the full-opacity, solidly-bordered floor. The
// floor carries a green accent (the "go / ship it" signal); the top tier is a
// muted neutral so it recedes.
//
// This is a simple visual aid, NOT a system / box-and-arrow graph — no arrows,
// no flow. Wide and short (capped well under 300px), horizontal-leaning rows of
// pills inside each tier.
//
// `margin: 0` on every descendant defeats Starlight's injected prose margins.
// No JS. The <Figure> wrapper and caption come from the MDX call site.

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const FLOOR = "#16a34a"; // green-600 — the solid, ship-it foundation

interface Tier {
	badge: string;
	title: string;
	sub: string;
	pills: string[];
}

const floor: Tier = {
	badge: "Tier 0",
	title: "Cookieless floor",
	sub: "Vercel Web Analytics + Speed Insights",
	pills: ["always on", "no consent", "free"],
};

const top: Tier = {
	badge: "Tier 1",
	title: "PostHog",
	sub: "events · flags · replay · experiments",
	pills: ["earns its weight", "consent-gated"],
};

const ALT =
	"A two-tier analytics stack. The bottom tier, Tier 0 — Cookieless floor (Vercel Web Analytics + Speed Insights), is a solid foundation tagged always on, no consent, free. The top tier, Tier 1 — PostHog, sits above it dimmed and dashed to read as additive and not-yet, tagged earns its weight and consent-gated.";

// ---- styles -------------------------------------------------------------

const root = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 6px",
	"width: 100%",
	"max-width: 620px",
	"margin-left: auto",
	"margin-right: auto",
	"box-sizing: border-box",
	sans,
].join("; ");

// Top tier: dimmed, dashed, recedes. The "comes later" slab.
const topTier = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"flex-wrap: wrap",
	"column-gap: 14px",
	"row-gap: 8px",
	"padding: 12px 16px",
	"border-radius: 12px",
	"border: 1.5px dashed var(--sl-color-gray-4, #9ca3af)",
	"background: color-mix(in srgb, var(--sl-color-gray-5, #6b7280) 7%, transparent)",
	"opacity: 0.62",
].join("; ");

// Bottom tier: solid, full-opacity, green-accented. The foundation.
const floorTier = [
	reset,
	"box-sizing: border-box",
	"display: flex",
	"align-items: center",
	"flex-wrap: wrap",
	"column-gap: 14px",
	"row-gap: 8px",
	"padding: 14px 16px",
	"border-radius: 12px",
	"border: 2px solid color-mix(in srgb, " + FLOOR + " 55%, transparent)",
	"background: color-mix(in srgb, " + FLOOR + " 12%, var(--sl-color-bg))",
	"box-shadow: 0 1px 0 color-mix(in srgb, " + FLOOR + " 30%, transparent)",
].join("; ");

const badge = (solid: boolean) =>
	[
		reset,
		sans,
		"flex: none",
		"display: inline-flex",
		"align-items: center",
		"padding: 3px 10px",
		"border-radius: 999px",
		"font-size: 11px",
		"font-weight: 700",
		"letter-spacing: 0.04em",
		"text-transform: uppercase",
		"white-space: nowrap",
		solid
			? "color: #fff"
			: "color: var(--sl-color-gray-2, #4b5563)",
		solid
			? "background: " + FLOOR
			: "background: color-mix(in srgb, var(--sl-color-gray-4, #9ca3af) 35%, transparent)",
	].join("; ");

// Title + sub-label stack, grows to push the pills to the right edge.
const labelStack = [
	reset,
	"display: flex",
	"flex-direction: column",
	"gap: 2px",
	"flex: 1 1 220px",
	"min-width: 0",
].join("; ");

const title = (solid: boolean) =>
	[
		reset,
		sans,
		"font-size: 16px",
		"font-weight: 700",
		"line-height: 1.2",
		solid
			? "color: var(--sl-color-white, #111827)"
			: "color: var(--sl-color-gray-1, #374151)",
	].join("; ");

const sub = [
	reset,
	sans,
	"font-size: 12.5px",
	"font-weight: 500",
	"line-height: 1.3",
	"color: var(--sl-color-gray-3, #6b7280)",
].join("; ");

const pillRow = [
	reset,
	"display: flex",
	"flex-wrap: wrap",
	"gap: 6px",
	"flex: none",
].join("; ");

const pill = (solid: boolean) =>
	[
		reset,
		sans,
		"display: inline-flex",
		"align-items: center",
		"padding: 3px 10px",
		"border-radius: 999px",
		"font-size: 11.5px",
		"font-weight: 600",
		"white-space: nowrap",
		solid
			? "color: color-mix(in srgb, " + FLOOR + " 88%, var(--sl-color-text))"
			: "color: var(--sl-color-gray-2, #4b5563)",
		solid
			? "background: color-mix(in srgb, " + FLOOR + " 18%, transparent)"
			: "background: color-mix(in srgb, var(--sl-color-gray-4, #9ca3af) 22%, transparent)",
		solid
			? "border: 1px solid color-mix(in srgb, " + FLOOR + " 40%, transparent)"
			: "border: 1px solid color-mix(in srgb, var(--sl-color-gray-4, #9ca3af) 35%, transparent)",
	].join("; ");

// A faint "additive, comes later" cue between the two slabs.
const seam = [
	reset,
	sans,
	"align-self: center",
	"font-size: 10.5px",
	"font-weight: 600",
	"letter-spacing: 0.06em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-4, #9ca3af)",
].join("; ");
---

<div class="not-content" style={root} role="img" aria-label={ALT}>
	{/* ── Top tier — dimmed / dashed: additive, comes later ─────────────── */}
	<div style={topTier}>
		<span style={badge(false)}>{top.badge}</span>
		<div style={labelStack}>
			<div style={title(false)}>{top.title}</div>
			<div style={sub}>{top.sub}</div>
		</div>
		<div style={pillRow}>
			{top.pills.map((p) => <span style={pill(false)}>{p}</span>)}
		</div>
	</div>

	<div style={seam}>additive · next lesson</div>

	{/* ── Bottom tier — solid foundation: ships today, unconditionally ───── */}
	<div style={floorTier}>
		<span style={badge(true)}>{floor.badge}</span>
		<div style={labelStack}>
			<div style={title(true)}>{floor.title}</div>
			<div style={sub}>{floor.sub}</div>
		</div>
		<div style={pillRow}>
			{floor.pills.map((p) => <span style={pill(true)}>{p}</span>)}
		</div>
	</div>
</div>
