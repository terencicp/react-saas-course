---
// A faithful hand-authored mock of the Vercel Web Analytics OVERVIEW panel —
// no real Vercel account is provisioned, so this synthetic dashboard stands in
// for the live screenshot the student will see once the floor is wired and
// verified. It shows exactly what the lesson promises: the Visitors / Page
// Views numbers up top, a small traffic chart, and the Top Pages + Top
// Referrers lists. This is the "verified" state — real numbers landing.
//
// All project-identifying data is a placeholder: the project reads
// "your-saas" and the domain "your-saas.vercel.app", never a real name. The
// numbers are representative pre-PMF traffic, nothing more.
//
// Built from Starlight CSS variables so it tracks light/dark theme. The black
// Vercel triangle is the one brand mark; everything else is neutral chrome.
// Wide and self-contained — the <Figure> wrapper + caption live here.
import Figure from '../../../figures/Figure.astro';

// Top metric cards across the header.
const metrics = [
	{ label: 'Visitors', value: '4,812', delta: '+18%', up: true },
	{ label: 'Page Views', value: '11,907', delta: '+12%', up: true },
	{ label: 'Bounce Rate', value: '38%', delta: '-4%', up: true },
];

// Top pages — the second question ("which pages convert vs. leak") in data
// form. Bar widths are proportional to the share of views.
const pages = [
	{ path: '/', views: '3,420', pct: 100 },
	{ path: '/pricing', views: '2,160', pct: 63 },
	{ path: '/blog/launch', views: '1,540', pct: 45 },
	{ path: '/signup', views: '980', pct: 29 },
	{ path: '/docs', views: '610', pct: 18 },
];

// Top referrers — the first question ("where is traffic coming from").
const referrers = [
	{ src: 'Direct', views: '2,940', pct: 100 },
	{ src: 'google.com', views: '1,810', pct: 62 },
	{ src: 't.co', views: '1,120', pct: 38 },
	{ src: 'news.ycombinator.com', views: '740', pct: 25 },
	{ src: 'github.com', views: '420', pct: 14 },
];

// A 12-bar sparkline-ish daily-visitors chart. Heights in % of the tallest.
const bars = [34, 41, 38, 52, 47, 63, 58, 71, 66, 78, 84, 92];

const ALT =
	'The Vercel Web Analytics overview panel for the project "your-saas". A header shows three metric cards — Visitors 4,812 (up 18%), Page Views 11,907 (up 12%), and Bounce Rate 38% — above a bar chart of daily visitors trending upward over the last days. Below, two lists: Top Pages (/, /pricing, /blog/launch, /signup, /docs) and Top Referrers (Direct, google.com, t.co, news.ycombinator.com, github.com), each row with a view count and a proportional bar. This is the verified state once the analytics floor is wired.';
---

<Figure caption="The Web Analytics overview — visitors, page views, and top pages. This is what 'verified' looks like once the floor is wired.">
	<div class="wao" role="img" aria-label={ALT}>
		{/* ── Browser-window chrome ─────────────────────────────────────── */}
		<div class="wao-titlebar">
			<span class="wao-dot wao-dot-r"></span>
			<span class="wao-dot wao-dot-y"></span>
			<span class="wao-dot wao-dot-g"></span>
			<span class="wao-omnibox">vercel.com/your-saas/analytics</span>
		</div>

		{/* ── Vercel app top bar ────────────────────────────────────────── */}
		<div class="wao-appbar">
			<svg class="wao-logo" viewBox="0 0 24 22" aria-hidden="true">
				<path d="M12 1 23 21 1 21 Z" />
			</svg>
			<span class="wao-proj">your-saas</span>
			<span class="wao-slash">/</span>
			<span class="wao-env">Production</span>
			<span class="wao-spacer"></span>
			<span class="wao-range">Last 7 days ▾</span>
		</div>

		{/* ── Sub-nav tabs (Analytics active) ───────────────────────────── */}
		<div class="wao-tabs">
			<span class="wao-tab">Overview</span>
			<span class="wao-tab wao-tab-active">Web Analytics</span>
			<span class="wao-tab">Speed Insights</span>
			<span class="wao-tab">Logs</span>
		</div>

		<div class="wao-body">
			{/* ── Metric cards ──────────────────────────────────────────── */}
			<div class="wao-metrics">
				{
					metrics.map((m) => (
						<div class="wao-metric">
							<div class="wao-metric-label">{m.label}</div>
							<div class="wao-metric-value">{m.value}</div>
							<div class:list={['wao-metric-delta', m.up && 'is-up']}>
								{m.delta}
							</div>
						</div>
					))
				}
			</div>

			{/* ── Daily-visitors chart ──────────────────────────────────── */}
			<div class="wao-chart-card">
				<div class="wao-chart-head">
					<span class="wao-chart-title">Visitors</span>
					<span class="wao-chart-sub">per day</span>
				</div>
				<div class="wao-chart">
					{bars.map((h) => <span class="wao-bar" style={`height:${h}%`} />)}
				</div>
			</div>

			{/* ── Top pages + Top referrers ─────────────────────────────── */}
			<div class="wao-lists">
				<div class="wao-list">
					<div class="wao-list-head">
						<span>Top Pages</span>
						<span class="wao-list-head-r">Views</span>
					</div>
					{
						pages.map((p) => (
							<div class="wao-row">
								<span class="wao-row-fill" style={`width:${p.pct}%`} />
								<span class="wao-row-label">{p.path}</span>
								<span class="wao-row-val">{p.views}</span>
							</div>
						))
					}
				</div>

				<div class="wao-list">
					<div class="wao-list-head">
						<span>Top Referrers</span>
						<span class="wao-list-head-r">Views</span>
					</div>
					{
						referrers.map((r) => (
							<div class="wao-row">
								<span class="wao-row-fill" style={`width:${r.pct}%`} />
								<span class="wao-row-label">{r.src}</span>
								<span class="wao-row-val">{r.views}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</Figure>

<style>
	.wao {
		max-width: 50rem;
		margin: 0 auto;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.6rem;
		overflow: hidden;
		background: var(--sl-color-bg);
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
		box-shadow: 0 1px 0 var(--sl-color-hairline);
	}

	/* ── Browser chrome ────────────────────────────────────────────── */
	.wao-titlebar {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.4rem 0.75rem;
		background: var(--sl-color-bg-sidebar);
		border-bottom: 1px solid var(--sl-color-hairline);
	}
	.wao-dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		flex: none;
	}
	.wao-dot-r {
		background: #ef5350;
	}
	.wao-dot-y {
		background: #f5b740;
	}
	.wao-dot-g {
		background: #4caf50;
	}
	.wao-omnibox {
		flex: 1;
		margin-left: 0.5rem;
		padding: 0.18rem 0.6rem;
		border-radius: 0.35rem;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		color: var(--sl-color-gray-3);
		font-size: 0.72rem;
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
	}

	/* ── Vercel app bar ────────────────────────────────────────────── */
	.wao-appbar {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.55rem 0.9rem;
		border-bottom: 1px solid var(--sl-color-hairline);
		font-size: 0.82rem;
	}
	.wao-logo {
		width: 15px;
		height: 14px;
		flex: none;
	}
	.wao-logo path {
		fill: var(--sl-color-white);
	}
	.wao-proj {
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.wao-slash {
		color: var(--sl-color-gray-4);
	}
	.wao-env {
		color: var(--sl-color-gray-2);
	}
	.wao-spacer {
		flex: 1;
	}
	.wao-range {
		padding: 0.22rem 0.6rem;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 0.35rem;
		color: var(--sl-color-gray-2);
		font-size: 0.74rem;
	}

	/* ── Tabs ──────────────────────────────────────────────────────── */
	.wao-tabs {
		display: flex;
		gap: 1.1rem;
		padding: 0 0.9rem;
		border-bottom: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg-sidebar);
	}
	.wao-tab {
		padding: 0.5rem 0.1rem;
		font-size: 0.78rem;
		color: var(--sl-color-gray-3);
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
	}
	.wao-tab-active {
		color: var(--sl-color-white);
		font-weight: 600;
		border-bottom-color: var(--sl-color-white);
	}

	.wao-body {
		padding: 0.9rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	/* ── Metric cards ──────────────────────────────────────────────── */
	.wao-metrics {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.7rem;
	}
	.wao-metric {
		border: 1px solid var(--sl-color-hairline);
		border-radius: 0.5rem;
		padding: 0.7rem 0.8rem;
		background: color-mix(in srgb, var(--sl-color-bg-sidebar) 50%, var(--sl-color-bg));
	}
	.wao-metric-label {
		font-size: 0.72rem;
		color: var(--sl-color-gray-3);
	}
	.wao-metric-value {
		font-size: 1.45rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
		margin-top: 0.1rem;
		font-variant-numeric: tabular-nums;
	}
	.wao-metric-delta {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--sl-color-gray-3);
		margin-top: 0.05rem;
	}
	.wao-metric-delta.is-up {
		color: #16a34a;
	}

	/* ── Chart ─────────────────────────────────────────────────────── */
	.wao-chart-card {
		border: 1px solid var(--sl-color-hairline);
		border-radius: 0.5rem;
		padding: 0.7rem 0.8rem 0.8rem;
		background: color-mix(in srgb, var(--sl-color-bg-sidebar) 50%, var(--sl-color-bg));
	}
	.wao-chart-head {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
		margin-bottom: 0.55rem;
	}
	.wao-chart-title {
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.wao-chart-sub {
		font-size: 0.68rem;
		color: var(--sl-color-gray-3);
	}
	.wao-chart {
		display: flex;
		align-items: flex-end;
		gap: 0.4rem;
		height: 4.5rem;
	}
	.wao-bar {
		flex: 1;
		border-radius: 0.18rem 0.18rem 0 0;
		background: color-mix(in srgb, #3b82f6 75%, var(--sl-color-bg));
		min-height: 3px;
	}

	/* ── Top-pages / referrers lists ───────────────────────────────── */
	.wao-lists {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.7rem;
	}
	.wao-list {
		border: 1px solid var(--sl-color-hairline);
		border-radius: 0.5rem;
		padding: 0.6rem 0.7rem 0.7rem;
		background: color-mix(in srgb, var(--sl-color-bg-sidebar) 50%, var(--sl-color-bg));
	}
	.wao-list-head {
		display: flex;
		justify-content: space-between;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-2);
		margin-bottom: 0.5rem;
	}
	.wao-list-head-r {
		color: var(--sl-color-gray-3);
		font-weight: 600;
	}
	.wao-row {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.3rem 0.45rem;
		border-radius: 0.3rem;
		overflow: hidden;
		font-size: 0.76rem;
	}
	.wao-row-fill {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		background: color-mix(in srgb, #3b82f6 16%, transparent);
		border-radius: 0.3rem;
	}
	.wao-row-label {
		position: relative;
		color: var(--sl-color-white);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
		font-size: 0.73rem;
	}
	.wao-row-val {
		position: relative;
		flex: none;
		color: var(--sl-color-gray-2);
		font-variant-numeric: tabular-nums;
	}

	/* ── Narrow viewports ──────────────────────────────────────────── */
	@media (max-width: 600px) {
		.wao-metrics {
			grid-template-columns: 1fr;
		}
		.wao-lists {
			grid-template-columns: 1fr;
		}
		.wao-tab {
			font-size: 0.72rem;
		}
	}
</style>
