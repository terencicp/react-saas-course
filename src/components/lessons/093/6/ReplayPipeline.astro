---
// replay-pipeline — the spine diagram for Lesson 93.6.
//
// The one idea the whole lesson hangs on: session replay records the DOM, not a
// video, and masking is STRUCTURAL — the real value is replaced with *** at
// CAPTURE TIME, in the user's browser, before anything is transmitted. So this
// DiagramSequence walks the capture-to-replay pipeline left-to-right and lets
// the student scrub to watch exactly WHERE the secret disappears:
//
//   1. Browser — the live DOM renders real values (hunter2, Visa •••• 4242).
//   2. Capture — masking happens HERE; the serialized payload already reads ***.
//   3. Transit + storage (PostHog Cloud EU) — *** travels and rests; the real
//      value was never in the payload, so it's never transmitted or stored.
//   4. Replay player — the operator re-renders the DOM and sees ***, never the
//      secret (but still sees that the user typed into the field).
//
// Layout is fixed across all four steps so the stage never reflows (the
// DiagramSequence stack sizes to the tallest step and keeps inactive ones in
// layout). The pipeline strip on top is identical in every step — only the
// "active" stage and the detail panel below it change. The detail panels are
// kept to roughly equal height so the stage doesn't jump.
//
// Pure HTML + CSS (devtools-inspectable). Starlight theme variables keep it
// native in light and dark: green = the active / safe stage, an accent/orange
// pulse on the secret value in step 1 that flips to a calm *** from step 2 on.
// `not-content` + margin resets defeat Starlight's prose-margin selector.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

// The four pipeline stages, in order. `key` drives which one is active per step.
const stages = [
  { key: "browser", label: "Browser", sub: "live DOM" },
  { key: "capture", label: "Capture", sub: "in the browser" },
  { key: "transit", label: "Transit + storage", sub: "PostHog Cloud EU" },
  { key: "replay", label: "Replay player", sub: "operator" },
] as const;

type StageKey = (typeof stages)[number]["key"];

type StepDef = {
  active: StageKey;
  // does the value still hold the real secret, or has it become ***?
  masked: boolean;
  caption: string;
};

const steps: StepDef[] = [
  {
    active: "browser",
    masked: false,
    caption:
      "In the user's browser, the page renders real values, exactly as the user sees them.",
  },
  {
    active: "capture",
    masked: true,
    caption:
      "Masking happens here, before anything leaves the device. The real value is replaced with *** at capture time — it is never serialized.",
  },
  {
    active: "transit",
    masked: true,
    caption:
      "The real values were never in the payload, so they are never transmitted and never stored. Only *** travels to and rests in PostHog Cloud EU.",
  },
  {
    active: "replay",
    masked: true,
    caption:
      "The operator re-renders the recorded DOM and sees structure and interaction — that the user typed into the password field — never the secret.",
  },
];

// The two sensitive values we track through the pipeline.
const PASSWORD_REAL = "hunter2";
const CARD_REAL = "Visa •••• 4242";
const MASK = "•••";
---

<DiagramSequence>
  {
    steps.map((step) => {
      const activeIndex = stages.findIndex((s) => s.key === step.active);
      return (
      <DiagramStep caption={step.caption}>
        <div class="rp not-content">
          {/* Fixed pipeline strip — identical in every step; only `active` moves. */}
          <div class="rp-pipe" aria-hidden="true">
            {stages.map((stage, i) => (
              <>
                {i > 0 && <span class="rp-pipe-arrow" />}
                <div
                  class={`rp-pipe-node ${
                    stage.key === step.active ? "is-active" : ""
                  } ${i < activeIndex ? "is-past" : ""}`}
                >
                  <span class="rp-pipe-label">{stage.label}</span>
                  <span class="rp-pipe-sub">{stage.sub}</span>
                </div>
              </>
            ))}
          </div>

          {/* Detail panel — a stylized view of the active stage. */}
          <div class="rp-detail">
            {step.active === "browser" && (
              <div class="rp-card rp-card--app">
                <div class="rp-card-bar">
                  <span class="rp-card-title">Your app — sign-in</span>
                </div>
                <div class="rp-field">
                  <span class="rp-field-label">Password</span>
                  <div class="rp-input">
                    <span class="rp-secret rp-secret--real">{PASSWORD_REAL}</span>
                  </div>
                </div>
                <div class="rp-field">
                  <span class="rp-field-label">
                    <code>&lt;div class="sensitive"&gt;</code>
                  </span>
                  <div class="rp-text">
                    <span class="rp-secret rp-secret--real">{CARD_REAL}</span>
                  </div>
                </div>
              </div>
            )}

            {step.active === "capture" && (
              <div class="rp-card rp-card--payload">
                <div class="rp-card-bar">
                  <span class="rp-card-title">Serialized DOM snapshot</span>
                </div>
                <pre class="rp-code"><code>{`{ tag: "input", type: "password",
  value: "`}<span class="rp-secret rp-secret--mask">{MASK}</span>{`" }
{ tag: "div", class: "sensitive",
  text:  "`}<span class="rp-secret rp-secret--mask">{MASK}</span>{`" }`}</code></pre>
              </div>
            )}

            {step.active === "transit" && (
              <div class="rp-card rp-card--payload">
                <div class="rp-card-bar">
                  <span class="rp-card-title">Payload → storage (Frankfurt)</span>
                </div>
                <pre class="rp-code"><code>{`POST /ingest  →  PostHog Cloud EU

  password value: "`}<span class="rp-secret rp-secret--mask">{MASK}</span>{`"
  .sensitive text: "`}<span class="rp-secret rp-secret--mask">{MASK}</span>{`"`}</code></pre>
              </div>
            )}

            {step.active === "replay" && (
              <div class="rp-card rp-card--player">
                <div class="rp-card-bar">
                  <span class="rp-card-title">Replay player</span>
                  <span class="rp-card-dot" />
                  <span class="rp-card-dot" />
                  <span class="rp-card-dot" />
                </div>
                <div class="rp-field">
                  <span class="rp-field-label">Password</span>
                  <div class="rp-input rp-input--focus">
                    <span class="rp-secret rp-secret--mask">{MASK}</span>
                    <span class="rp-caret" />
                  </div>
                </div>
                <div class="rp-field">
                  <span class="rp-field-label">
                    <code>.sensitive</code>
                  </span>
                  <div class="rp-text">
                    <span class="rp-secret rp-secret--mask">{MASK}</span>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </DiagramStep>
      );
    })
  }
</DiagramSequence>

<style>
  .rp {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --rp-green: var(--sl-color-green, #16a34a);
    --rp-green-hi: var(--sl-color-green-high, #16a34a);
    --rp-accent: var(--sl-color-orange, #ea580c);
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* ---- Pipeline strip (fixed across steps) ---------------------------- */

  .rp-pipe {
    margin: 0;
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  .rp-pipe-node {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 9px 8px;
    border-radius: 10px;
    border: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
    text-align: center;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      opacity 0.2s ease;
    opacity: 0.55;
  }

  /* A stage the pipeline has already passed reads as "done" (subtle green). */
  .rp-pipe-node.is-past {
    opacity: 0.8;
    border-color: color-mix(in srgb, var(--rp-green) 30%, transparent);
    background: color-mix(in srgb, var(--rp-green) 5%, transparent);
  }

  /* The current stage. */
  .rp-pipe-node.is-active {
    opacity: 1;
    border-color: color-mix(in srgb, var(--rp-green) 60%, transparent);
    background: color-mix(in srgb, var(--rp-green) 11%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--rp-green) 35%, transparent);
  }

  .rp-pipe-label {
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--sl-color-text);
  }

  .rp-pipe-sub {
    font-size: 10.5px;
    line-height: 1.2;
    color: var(--sl-color-gray-2);
  }

  .rp-pipe-arrow {
    flex: 0 0 18px;
    align-self: center;
    height: 2px;
    position: relative;
    background: var(--sl-color-gray-4);
  }

  .rp-pipe-arrow::after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    border-left: 5px solid var(--sl-color-gray-4);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
  }

  /* ---- Detail panel --------------------------------------------------- */

  .rp-detail {
    display: flex;
    justify-content: center;
  }

  .rp-card {
    margin: 0;
    width: 100%;
    max-width: 460px;
    min-height: 188px;
    box-sizing: border-box;
    border-radius: 12px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    overflow: hidden;
  }

  .rp-card-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-6) 55%, transparent);
  }

  .rp-card-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-2);
  }

  .rp-card-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sl-color-gray-4);
  }
  .rp-card-dot:first-of-type {
    margin-left: auto;
  }

  /* ---- Mock form fields (browser + replay panels) --------------------- */

  .rp-field {
    margin: 0;
    padding: 12px 14px 0;
  }
  .rp-field:last-child {
    padding-bottom: 14px;
  }

  .rp-field-label {
    display: block;
    margin: 0 0 5px;
    font-size: 11px;
    color: var(--sl-color-gray-2);
  }

  .rp-field-label code {
    margin: 0;
    font-size: 10.5px;
    background: none;
    border: none;
    padding: 0;
    color: var(--sl-color-gray-2);
  }

  .rp-input {
    display: flex;
    align-items: center;
    gap: 1px;
    padding: 8px 10px;
    border-radius: 7px;
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-6) 25%, transparent);
  }

  /* In the replay panel the field shows a focus ring + caret: the operator can
     see the act of typing, just not the value. */
  .rp-input--focus {
    border-color: color-mix(in srgb, var(--rp-green) 60%, transparent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--rp-green) 22%, transparent);
  }

  .rp-text {
    padding: 6px 0 0;
  }

  .rp-secret {
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 13px;
    line-height: 1.3;
  }

  /* The real value (step 1 only): accent-tinted so the eye locks onto it,
     then watches it vanish. */
  .rp-secret--real {
    color: var(--rp-accent);
    font-weight: 700;
    background: color-mix(in srgb, var(--rp-accent) 12%, transparent);
    padding: 1px 6px;
    border-radius: 4px;
  }

  /* The masked value (steps 2–4): calm, green, settled — "this is what left
     the browser." */
  .rp-secret--mask {
    color: var(--rp-green-hi);
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .rp-caret {
    width: 1.5px;
    height: 15px;
    margin-left: 2px;
    background: var(--rp-green-hi);
    animation: rp-blink 1s steps(2, start) infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .rp-caret {
      animation: none;
    }
  }

  @keyframes rp-blink {
    to {
      opacity: 0;
    }
  }

  /* ---- Code-style panels (capture + transit) -------------------------- */

  .rp-code {
    margin: 0;
    padding: 14px;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12px;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    white-space: pre;
    overflow-x: auto;
    background: none;
  }

  .rp-code code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .rp-code .rp-secret {
    font-size: 12px;
  }

  /* Narrow viewports: the four-node strip can't stay side-by-side and readable,
     so stack it vertically with downward arrows. */
  @media (max-width: 560px) {
    .rp-pipe {
      flex-direction: column;
      align-items: stretch;
    }
    .rp-pipe-node {
      flex-direction: row;
      justify-content: space-between;
      gap: 8px;
    }
    .rp-pipe-arrow {
      width: 2px;
      height: 14px;
      align-self: center;
    }
    .rp-pipe-arrow::after {
      right: 50%;
      top: auto;
      bottom: 0;
      transform: translateX(50%);
      border-left: 4px solid transparent;
      border-right: 4px solid transparent;
      border-top: 5px solid var(--sl-color-gray-4);
      border-bottom: none;
    }
  }
</style>
