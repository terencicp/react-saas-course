---
// mask-vs-block — the operator's-eye contrast for Lesson 93.6.
//
// Mask and block both hide sensitive content, but they hide DIFFERENT amounts
// of it. The fastest way to feel the difference is to look at what the operator
// actually SEES in the replay player. So this is a TabbedContent with two tabs
// rendering the SAME login form (email + password + submit) two ways:
//
//   Masked  — the password field is a normal-looking, FOCUSED input whose value
//             reads ***, with a blinking caret. The operator can see the field,
//             the focus ring, the act of typing — just not the value. Reach for
//             this when the interaction matters for debugging.
//   Blocked — the password field is replaced by a flat grey placeholder box of
//             the SAME footprint: no outline, no caret, no content. The element
//             is gone from the recording entirely. Reach for this only when the
//             content shouldn't exist in the recording at all.
//
// The two tabs share an identical frame (title bar, email field, submit button)
// so the eye locks onto the one thing that differs: the password row. The frame
// is sized so both tabs have the same footprint and the card doesn't reflow when
// switching tabs.
//
// Pure HTML + CSS, devtools-inspectable, on Starlight theme variables so it
// stays native in light and dark. The visual idiom (player card, masked ***,
// focus ring + caret) deliberately matches ReplayPipeline's step-4 panel, since
// both show "what the operator sees." TabbedContent provides the outer card, so
// this is NOT wrapped in <Figure>. `not-content` + margin resets defeat
// Starlight's prose-margin selector.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

const MASK = "•••";
const EMAIL_MASK = "•••••••••••••";
---

<TabbedContent>
  <TabbedItem
    label="Masked"
    caption="Masked — the operator sees the field, the focus, the act of typing. Just not the value. Use this when the interaction matters for debugging."
  >
    <div class="mvb not-content">
      <div class="mvb-card">
        <div class="mvb-bar">
          <span class="mvb-title">Replay player</span>
          <span class="mvb-dot"></span>
          <span class="mvb-dot"></span>
          <span class="mvb-dot"></span>
        </div>
        <div class="mvb-body">
          <div class="mvb-field">
            <span class="mvb-label">Email</span>
            <div class="mvb-input">
              <span class="mvb-secret">{EMAIL_MASK}</span>
            </div>
          </div>
          <div class="mvb-field">
            <span class="mvb-label">Password</span>
            <div class="mvb-input mvb-input--focus">
              <span class="mvb-secret">{MASK}</span>
              <span class="mvb-caret"></span>
            </div>
          </div>
          <button class="mvb-submit" type="button" tabindex="-1">Sign in</button>
        </div>
      </div>
    </div>
  </TabbedItem>

  <TabbedItem
    label="Blocked"
    caption="Blocked — the element is gone from the recording entirely. Use this only when the content shouldn't exist in the recording at all."
  >
    <div class="mvb not-content">
      <div class="mvb-card">
        <div class="mvb-bar">
          <span class="mvb-title">Replay player</span>
          <span class="mvb-dot"></span>
          <span class="mvb-dot"></span>
          <span class="mvb-dot"></span>
        </div>
        <div class="mvb-body">
          <div class="mvb-field">
            <span class="mvb-label">Email</span>
            <div class="mvb-input">
              <span class="mvb-secret">{EMAIL_MASK}</span>
            </div>
          </div>
          <div class="mvb-field">
            <span class="mvb-label">Password</span>
            <div class="mvb-blocked" aria-label="not recorded"></div>
          </div>
          <button class="mvb-submit" type="button" tabindex="-1">Sign in</button>
        </div>
      </div>
    </div>
  </TabbedItem>
</TabbedContent>

<style>
  .mvb {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --mvb-green: var(--sl-color-green, #16a34a);
    --mvb-green-hi: var(--sl-color-green-high, #16a34a);
    display: flex;
    justify-content: center;
  }

  /* ---- Player card (matches ReplayPipeline's step-4 panel) ------------- */

  .mvb-card {
    margin: 0;
    width: 100%;
    max-width: 360px;
    box-sizing: border-box;
    border-radius: 12px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    overflow: hidden;
  }

  .mvb-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-6) 55%, transparent);
  }

  .mvb-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-2);
  }

  .mvb-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sl-color-gray-4);
  }
  .mvb-dot:first-of-type {
    margin-left: auto;
  }

  .mvb-body {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* ---- Form fields ---------------------------------------------------- */

  .mvb-field {
    margin: 0;
  }

  .mvb-label {
    display: block;
    margin: 0 0 5px;
    font-size: 11px;
    color: var(--sl-color-gray-2);
  }

  .mvb-input {
    display: flex;
    align-items: center;
    gap: 1px;
    padding: 8px 10px;
    height: 36px;
    box-sizing: border-box;
    border-radius: 7px;
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-6) 25%, transparent);
  }

  /* The password row in the Masked tab: a focus ring + caret. The operator can
     see the act of typing, just not the value. */
  .mvb-input--focus {
    border-color: color-mix(in srgb, var(--mvb-green) 60%, transparent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--mvb-green) 22%, transparent);
  }

  .mvb-secret {
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 13px;
    line-height: 1.3;
    color: var(--mvb-green-hi);
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .mvb-caret {
    width: 1.5px;
    height: 15px;
    margin-left: 2px;
    background: var(--mvb-green-hi);
    animation: mvb-blink 1s steps(2, start) infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .mvb-caret {
      animation: none;
    }
  }

  @keyframes mvb-blink {
    to {
      opacity: 0;
    }
  }

  /* The password row in the Blocked tab: a flat grey placeholder of the SAME
     footprint as the input above — no outline, no caret, no content. The element
     is simply gone from the recording. Diagonal hatching reads as "absent." */
  .mvb-blocked {
    height: 36px;
    box-sizing: border-box;
    border-radius: 7px;
    background-color: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 6px,
      color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent) 6px,
      color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent) 12px
    );
  }

  .mvb-submit {
    margin: 0;
    padding: 8px 12px;
    border-radius: 7px;
    border: none;
    background: color-mix(in srgb, var(--sl-color-accent) 85%, transparent);
    color: var(--sl-color-text-invert, #fff);
    font-size: 12.5px;
    font-weight: 600;
    text-align: center;
    cursor: default;
  }
</style>
