---
// replay-workflow — the operator workflow diagram for Lesson 93.6.
//
// This is the section that justifies the whole primitive: how an on-call
// engineer reads a replay to turn an un-reproducible ticket ("the upgrade
// button does nothing") into a one-line fix. The skill is not "watch the
// video" — it is reading the player's panels TOGETHER: the DOM stage, the
// event timeline, the Console panel, and the Network panel. The diagnosis in
// this case is precisely that Console and Network are CLEAN — which is why
// Sentry and the structured logs saw nothing.
//
// So this DiagramSequence reproduces a stylized replay player and lets the
// student scrub the same five beats the on-call would:
//
//   1. Find the session — the replay list filtered to one distinct ID.
//   2. Scrub to the click — dashboard with the cursor over "Upgrade", a click
//      marker on the timeline.
//   3. The modal opens — exactly as designed.
//   4. ...and immediately closes — a stray backdrop click a few ms later
//      (highlighted on the timeline); Console clean, Network clean.
//   5. Diagnosis — the modal-content click bubbled to the backdrop's close
//      handler; the fix is one e.stopPropagation().
//
// The player chrome (card + title bar + dots), the masked-value idiom, the
// green "active/safe" accent, and the Starlight theme variables deliberately
// match ReplayPipeline and MaskVsBlock so it reads as the same product. Layout
// is fixed across all five steps — the title bar, the timeline strip, and the
// Console/Network panel row are present in every step so the stage never
// reflows; only the stage content and which timeline marker is highlighted
// change. Pure HTML + CSS, devtools-inspectable, native in light and dark.
// `not-content` + margin resets defeat Starlight's prose-margin selector.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

// Click markers on the timeline. The stray backdrop click (the bug) appears in
// steps 4–5 and is highlighted there. Positions are % across the strip.
type Marker = { at: number; kind: "click" | "stray" };

type StepDef = {
  title: string; // the player title-bar label (the on-call's current beat)
  markers: Marker[];
  playhead: number; // % position of the scrubber
  console: "idle" | "clean"; // idle = not looked at yet; clean = the diagnosis beat
  network: "idle" | "clean";
  caption: string;
};

const steps: StepDef[] = [
  {
    title: "Replay list",
    markers: [],
    playhead: 0,
    console: "idle",
    network: "idle",
    caption:
      "Find the session. Look up the user's PostHog distinct ID — it is on the user row from the identify join earlier in this chapter, or search PostHog by email. Filter the replay list to that ID and open the session.",
  },
  {
    title: "Session — 00:14",
    markers: [{ at: 62, kind: "click" }],
    playhead: 62,
    console: "idle",
    network: "idle",
    caption:
      "Scrub the timeline to the moment they clicked Upgrade.",
  },
  {
    title: "Session — 00:14",
    markers: [{ at: 62, kind: "click" }],
    playhead: 64,
    console: "idle",
    network: "idle",
    caption:
      "The modal opens, exactly as designed.",
  },
  {
    title: "Session — 00:14",
    markers: [
      { at: 62, kind: "click" },
      { at: 70, kind: "stray" },
    ],
    playhead: 70,
    console: "clean",
    network: "clean",
    caption:
      "A split second later the modal is gone. The timeline shows a stray click on the backdrop. Console: clean. Network: clean — which is exactly why Sentry and the logs saw nothing.",
  },
  {
    title: "Diagnosis",
    markers: [
      { at: 62, kind: "click" },
      { at: 70, kind: "stray" },
    ],
    playhead: 70,
    console: "clean",
    network: "clean",
    caption:
      "The click on the modal content bubbled up to the backdrop's close handler. The fix is one line: stop the click from propagating. An un-reproducible bug, reproduced — without a single call to the user.",
  },
];
---

<DiagramSequence>
  {
    steps.map((step, idx) => (
      <DiagramStep caption={step.caption}>
        <div class="rw not-content">
          <div class="rw-card">
            {/* Title bar — present every step; label tracks the on-call beat. */}
            <div class="rw-bar">
              <span class="rw-title">{step.title}</span>
              <span class="rw-dot" />
              <span class="rw-dot" />
              <span class="rw-dot" />
            </div>

            {/* Stage — the one region that changes most per step. */}
            <div class="rw-stage">
              {idx === 0 && (
                <div class="rw-list" aria-label="Replay list filtered to one user">
                  <div class="rw-list-head">
                    <span class="rw-pill">distinct_id = usr_8f3c</span>
                  </div>
                  <div class="rw-row is-match">
                    <span class="rw-avatar" />
                    <span class="rw-row-main">jordan@acme.com</span>
                    <span class="rw-row-meta">0:42 · today</span>
                    <span class="rw-play">▶</span>
                  </div>
                  <div class="rw-row is-ghost" aria-hidden="true">
                    <span class="rw-avatar" />
                    <span class="rw-row-main rw-skel" />
                    <span class="rw-row-meta rw-skel rw-skel--sm" />
                  </div>
                </div>
              )}

              {idx === 1 && (
                <div class="rw-app" aria-label="The user's dashboard">
                  <div class="rw-app-head">
                    <span class="rw-app-title">Dashboard</span>
                  </div>
                  <div class="rw-app-body">
                    <span class="rw-line rw-line--w70" />
                    <span class="rw-line rw-line--w45" />
                    <div class="rw-cta-wrap">
                      <button class="rw-cta" type="button" tabindex="-1">
                        Upgrade
                      </button>
                      <span class="rw-cursor" data-clicking="true">
                        <span class="rw-cursor-ring" />
                      </span>
                    </div>
                  </div>
                </div>
              )}

              {idx === 2 && (
                <div class="rw-app" aria-label="The upgrade modal, open">
                  <div class="rw-app-head">
                    <span class="rw-app-title">Dashboard</span>
                  </div>
                  <div class="rw-backdrop">
                    <div class="rw-modal">
                      <span class="rw-modal-title">Upgrade your plan</span>
                      <span class="rw-line rw-line--w80" />
                      <span class="rw-line rw-line--w55" />
                      <button class="rw-modal-cta" type="button" tabindex="-1">
                        Choose plan
                      </button>
                    </div>
                  </div>
                </div>
              )}

              {idx === 3 && (
                <div class="rw-app" aria-label="The modal closed itself">
                  <div class="rw-app-head">
                    <span class="rw-app-title">Dashboard</span>
                  </div>
                  <div class="rw-app-body rw-app-body--dim">
                    <span class="rw-line rw-line--w70" />
                    <span class="rw-line rw-line--w45" />
                    <div class="rw-cta-wrap">
                      <button class="rw-cta" type="button" tabindex="-1">
                        Upgrade
                      </button>
                    </div>
                    <span class="rw-flash" aria-label="stray backdrop click">
                      <span class="rw-flash-ring" />
                      <span class="rw-flash-label">backdrop click</span>
                    </span>
                  </div>
                </div>
              )}

              {idx === 4 && (
                <div class="rw-app" aria-label="Diagnosis">
                  <div class="rw-app-head">
                    <span class="rw-app-title">Dashboard</span>
                  </div>
                  <div class="rw-diag">
                    <div class="rw-diag-stack">
                      <span class="rw-diag-box rw-diag-box--outer">
                        backdrop · onClick = close()
                      </span>
                      <span class="rw-diag-box rw-diag-box--inner">
                        modal content · click
                      </span>
                    </div>
                    <span class="rw-diag-arrow" aria-hidden="true">
                      click bubbles ↑
                    </span>
                    <code class="rw-fix">e.stopPropagation()</code>
                  </div>
                </div>
              )}
            </div>

            {/* Timeline strip — present every step; markers + playhead move. */}
            <div class="rw-timeline" aria-label="Event timeline">
              <span class="rw-track" />
              {step.markers.map((m) => (
                <span
                  class={`rw-marker ${m.kind === "stray" ? "is-stray" : ""}`}
                  style={`left:${m.at}%`}
                  data-label={m.kind === "stray" ? "stray click" : "click: Upgrade"}
                />
              ))}
              <span class="rw-playhead" style={`left:${step.playhead}%`} />
            </div>

            {/* Console + Network panels — present every step; read together. */}
            <div class="rw-panels">
              <div class={`rw-panel rw-panel--${step.console}`}>
                <span class="rw-panel-head">Console</span>
                {step.console === "clean" ? (
                  <span class="rw-panel-state rw-panel-state--ok">
                    no errors
                  </span>
                ) : (
                  <span class="rw-panel-state">—</span>
                )}
              </div>
              <div class={`rw-panel rw-panel--${step.network}`}>
                <span class="rw-panel-head">Network</span>
                {step.network === "clean" ? (
                  <span class="rw-panel-state rw-panel-state--ok">
                    all 200 · no failed requests
                  </span>
                ) : (
                  <span class="rw-panel-state">—</span>
                )}
              </div>
            </div>
          </div>
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>

<style>
  .rw {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --rw-green: var(--sl-color-green, #16a34a);
    --rw-green-hi: var(--sl-color-green-high, #16a34a);
    --rw-accent: var(--sl-color-orange, #ea580c);
    display: flex;
    justify-content: center;
  }

  /* ---- Player card (matches ReplayPipeline / MaskVsBlock) -------------- */

  .rw-card {
    margin: 0;
    width: 100%;
    max-width: 520px;
    box-sizing: border-box;
    border-radius: 12px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    overflow: hidden;
  }

  .rw-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-6) 55%, transparent);
  }

  .rw-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-2);
  }

  .rw-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sl-color-gray-4);
  }
  .rw-dot:first-of-type {
    margin-left: auto;
  }

  /* ---- Stage (fixed height so the card never reflows) ------------------ */

  .rw-stage {
    position: relative;
    height: 172px;
    box-sizing: border-box;
    padding: 12px;
    background: color-mix(in srgb, var(--sl-color-gray-6) 20%, transparent);
    border-bottom: 1px solid var(--sl-color-hairline);
    overflow: hidden;
  }

  /* ---- Step 1: replay list -------------------------------------------- */

  .rw-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rw-list-head {
    margin-bottom: 2px;
  }

  .rw-pill {
    display: inline-block;
    padding: 3px 9px;
    border-radius: 999px;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 11px;
    color: var(--rw-green-hi);
    background: color-mix(in srgb, var(--rw-green) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--rw-green) 35%, transparent);
  }

  .rw-row {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 10px;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
  }

  .rw-row.is-match {
    border-color: color-mix(in srgb, var(--rw-green) 55%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--rw-green) 30%, transparent);
  }

  .rw-row.is-ghost {
    opacity: 0.4;
  }

  .rw-avatar {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--sl-color-gray-4);
  }

  .rw-row-main {
    font-size: 12.5px;
    color: var(--sl-color-text);
    flex: 1 1 auto;
  }

  .rw-row-meta {
    font-size: 11px;
    color: var(--sl-color-gray-2);
  }

  .rw-play {
    font-size: 11px;
    color: var(--rw-green-hi);
  }

  .rw-skel {
    height: 9px;
    border-radius: 4px;
    background: var(--sl-color-gray-5);
  }
  .rw-skel--sm {
    width: 48px;
    flex: 0 0 auto;
  }

  /* ---- Steps 2–5: the app stage --------------------------------------- */

  .rw-app {
    height: 100%;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    overflow: hidden;
    position: relative;
  }

  .rw-app-head {
    padding: 6px 10px;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-6) 45%, transparent);
  }

  .rw-app-title {
    font-size: 10.5px;
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }

  .rw-app-body {
    position: relative;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .rw-app-body--dim {
    opacity: 0.85;
  }

  .rw-line {
    display: block;
    height: 8px;
    border-radius: 4px;
    background: var(--sl-color-gray-5);
  }
  .rw-line--w80 {
    width: 80%;
  }
  .rw-line--w70 {
    width: 70%;
  }
  .rw-line--w55 {
    width: 55%;
  }
  .rw-line--w45 {
    width: 45%;
  }

  .rw-cta-wrap {
    position: relative;
    margin-top: 4px;
    align-self: flex-start;
  }

  .rw-cta {
    padding: 7px 16px;
    border-radius: 7px;
    border: none;
    background: color-mix(in srgb, var(--sl-color-accent) 85%, transparent);
    color: var(--sl-color-text-invert, #fff);
    font-size: 12px;
    font-weight: 600;
    cursor: default;
  }

  /* The replay cursor + a click ripple over the Upgrade button (step 2). */
  .rw-cursor {
    position: absolute;
    right: -8px;
    bottom: -8px;
    width: 14px;
    height: 14px;
  }
  .rw-cursor::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--sl-color-text);
    clip-path: polygon(0 0, 0 75%, 28% 55%, 48% 100%, 65% 92%, 45% 48%, 80% 45%);
  }
  .rw-cursor-ring {
    position: absolute;
    left: -6px;
    top: -6px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--sl-color-accent) 70%, transparent);
    animation: rw-ping 1.6s ease-out infinite;
  }

  @keyframes rw-ping {
    0% {
      transform: scale(0.5);
      opacity: 0.9;
    }
    100% {
      transform: scale(1.3);
      opacity: 0;
    }
  }

  /* ---- Step 3: open modal --------------------------------------------- */

  .rw-backdrop {
    position: absolute;
    inset: 25px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--sl-color-black, #000) 35%, transparent);
  }

  .rw-modal {
    width: 78%;
    max-width: 280px;
    padding: 12px 14px;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--sl-color-black, #000) 25%, transparent);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rw-modal-title {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .rw-modal-cta {
    align-self: flex-start;
    margin-top: 2px;
    padding: 6px 13px;
    border-radius: 6px;
    border: none;
    background: color-mix(in srgb, var(--sl-color-accent) 85%, transparent);
    color: var(--sl-color-text-invert, #fff);
    font-size: 11.5px;
    font-weight: 600;
    cursor: default;
  }

  /* ---- Step 4: the stray-click flash ---------------------------------- */

  .rw-flash {
    position: absolute;
    right: 22px;
    top: 16px;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .rw-flash-ring {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--rw-accent);
    background: color-mix(in srgb, var(--rw-accent) 25%, transparent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--rw-accent) 18%, transparent);
  }

  .rw-flash-label {
    font-size: 10.5px;
    font-weight: 700;
    color: var(--rw-accent);
    background: color-mix(in srgb, var(--rw-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--rw-accent) 35%, transparent);
    border-radius: 5px;
    padding: 2px 6px;
    white-space: nowrap;
  }

  /* ---- Step 5: diagnosis --------------------------------------------- */

  .rw-diag {
    height: calc(100% - 25px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 4px 14px;
  }

  .rw-diag-stack {
    position: relative;
    width: 100%;
    max-width: 320px;
  }

  .rw-diag-box {
    display: block;
    box-sizing: border-box;
    border-radius: 7px;
    font-size: 11.5px;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    text-align: center;
  }

  .rw-diag-box--outer {
    padding: 6px 10px 24px;
    border: 1px solid color-mix(in srgb, var(--rw-accent) 45%, transparent);
    background: color-mix(in srgb, var(--rw-accent) 7%, transparent);
    color: var(--sl-color-gray-2);
  }

  .rw-diag-box--inner {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 6px;
    padding: 5px 8px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
  }

  .rw-diag-arrow {
    font-size: 10.5px;
    font-weight: 700;
    color: var(--rw-accent);
  }

  .rw-fix {
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12.5px;
    font-weight: 700;
    color: var(--rw-green-hi);
    background: color-mix(in srgb, var(--rw-green) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--rw-green) 40%, transparent);
    border-radius: 6px;
    padding: 4px 10px;
  }

  /* ---- Timeline strip (fixed across steps) --------------------------- */

  .rw-timeline {
    position: relative;
    height: 30px;
    padding: 0 12px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-6) 35%, transparent);
  }

  .rw-track {
    position: absolute;
    left: 12px;
    right: 12px;
    height: 4px;
    border-radius: 3px;
    background: var(--sl-color-gray-5);
  }

  .rw-marker {
    position: absolute;
    top: 50%;
    width: 9px;
    height: 9px;
    margin-left: -4.5px;
    transform: translateY(-50%);
    border-radius: 50%;
    background: var(--sl-color-gray-2);
    border: 1.5px solid var(--sl-color-bg);
  }

  /* The stray backdrop click — the bug. Accent-tinted and pulsing so the eye
     locks onto it the moment it appears (steps 4–5). */
  .rw-marker.is-stray {
    width: 12px;
    height: 12px;
    margin-left: -6px;
    background: var(--rw-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--rw-accent) 22%, transparent);
    animation: rw-pulse 1.4s ease-in-out infinite;
  }

  @keyframes rw-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--rw-accent) 22%, transparent);
    }
    50% {
      box-shadow: 0 0 0 7px color-mix(in srgb, var(--rw-accent) 8%, transparent);
    }
  }

  .rw-playhead {
    position: absolute;
    top: 4px;
    bottom: 4px;
    width: 2px;
    margin-left: -1px;
    border-radius: 2px;
    background: var(--sl-color-text);
    transition: left 0.25s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .rw-marker.is-stray,
    .rw-cursor-ring {
      animation: none;
    }
    .rw-playhead {
      transition: none;
    }
  }

  /* ---- Console + Network panels (fixed across steps) ----------------- */

  .rw-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .rw-panel {
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .rw-panel:first-child {
    border-right: 1px solid var(--sl-color-hairline);
  }

  .rw-panel-head {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
  }

  .rw-panel-state {
    font-size: 11.5px;
    color: var(--sl-color-gray-2);
  }

  /* On the diagnosis beat (steps 4–5) "clean" is the headline, so it reads as
     a calm, deliberate green: the cleanliness IS the diagnosis. */
  .rw-panel-state--ok {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-weight: 600;
    color: var(--rw-green-hi);
  }
  .rw-panel-state--ok::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--rw-green-hi);
  }

  /* ---- Narrow viewports ---------------------------------------------- */

  @media (max-width: 520px) {
    .rw-stage {
      height: 240px;
    }
    .rw-panel {
      padding: 7px 10px;
    }
    .rw-panel-state {
      font-size: 10.5px;
      line-height: 1.3;
    }
    /* The diagnosis step is the tallest; compress it so it clears the stage at
       the narrowest widths. */
    .rw-diag {
      gap: 7px;
      padding: 6px 10px;
    }
    .rw-diag-box {
      font-size: 11px;
    }
    .rw-diag-box--outer {
      padding: 6px 8px 24px;
    }
    .rw-fix {
