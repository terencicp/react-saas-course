---
// PackageMap — Chapter 093 Lesson 3 ("Wiring PostHog through the consent gate").
//
// Orientation map for PostHog's App Router package surface: three package names,
// three places they run. Read it before any code so the rest of the lesson is
// legible — when the provider says `import('posthog-js')` and the server section
// reaches for `posthog-node`, the student already knows which is which.
//
//   posthog-js     → browser   (the SDK belt two dynamically imports)
//   posthog-node   → server    (capture with no browser in the room)
//   @posthog/next  → wraps both (the App Router convenience layer — beta)
//
// A plain three-card strip per the diagrams guide: an annotated map, not a
// system graph, small enough to live inline. Goes inside a <Figure> supplied
// by the MDX (which carries the caption). The third card is visually
// de-emphasized — dashed border, muted fill, a "beta" pill — to signal it is
// NOT the default this lesson teaches.
//
// `not-content` + a `margin: 0` reset on every inner element defeat Starlight's
// prose-margin selector; color-mix tints track the theme background.

type Card = {
	name: string;
	role: string;
	runs: string;
	accent: string;
	beta?: boolean;
};

const cards: Card[] = [
	{
		name: "posthog-js",
		role: "The browser SDK. Events, the feature-flag client, session-replay capture.",
		runs: "runs in the browser",
		accent: "#0ea5e9", // sky — the client surface
	},
	{
		name: "posthog-node",
		role: "The server SDK. Capturing an event when there is no browser in the room — a Stripe webhook, a scheduled job.",
		runs: "runs on the server",
		accent: "#0d9488", // teal — the server surface
	},
	{
		name: "@posthog/next",
		role: "The App Router convenience layer. Folds the proxy route, the distinct-ID cookie, and flag bootstrap into one wrapper.",
		runs: "wraps both",
		accent: "#8b5cf6", // violet — the wrapper, held at arm's length
		beta: true,
	},
];
---

<div class="pmap not-content">
	<div class="pmap-row">
		{
			cards.map((c) => (
				<div
					class={`pmap-card${c.beta ? " pmap-card--beta" : ""}`}
					style={`--pmap-accent:${c.accent};`}
				>
					<div class="pmap-head">
						<code class="pmap-name">{c.name}</code>
						{c.beta && <span class="pmap-pill">beta</span>}
					</div>
					<p class="pmap-role">{c.role}</p>
					<div class="pmap-foot">{c.runs}</div>
				</div>
			))
		}
	</div>
</div>

<style>
	.pmap {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* Three side-by-side cards; wraps to a column on narrow viewports so each
	   card stays readable. */
	.pmap-row {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 12px;
		margin: 0;
	}

	.pmap-card {
		display: flex;
		flex-direction: column;
		flex: 1 1 220px;
		min-width: 0;
		box-sizing: border-box;
		padding: 14px 15px 12px;
		border-radius: 13px;
		background: color-mix(in srgb, var(--pmap-accent) 7%, var(--sl-color-bg));
		border: 1.5px solid
			color-mix(in srgb, var(--pmap-accent) 38%, transparent);
		margin: 0;
	}

	/* The wrapper card, held at arm's length: dashed border, muted fill — it is
	   not the default the lesson teaches. */
	.pmap-card--beta {
		border-style: dashed;
		border-color: color-mix(in srgb, var(--pmap-accent) 30%, transparent);
		background: color-mix(in srgb, var(--pmap-accent) 4%, var(--sl-color-bg));
		opacity: 0.92;
	}

	.pmap-head {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 0 0 9px;
	}

	/* The package name, the card's identity. Override Starlight's inline-code
	   pill so it reads as a heading, not prose code. */
	.pmap-name {
		margin: 0;
		padding: 0;
		background: transparent;
		border: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 15px;
		font-weight: 700;
		line-height: 1.2;
		color: color-mix(in srgb, var(--pmap-accent) 70%, var(--sl-color-white));
	}

	/* Small "beta" pill on the wrapper card — the muted status signal. */
	.pmap-pill {
		margin: 0;
		padding: 1px 7px;
		border-radius: 999px;
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-2);
		background: color-mix(in srgb, var(--sl-color-gray-5) 50%, transparent);
		border: 1px solid var(--sl-color-gray-5);
	}

	.pmap-role {
		margin: 0;
		flex: 1 1 auto;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
	}

	/* The monospace "where it runs" footer label, set off by a hairline rule. */
	.pmap-foot {
		margin: 11px 0 0;
		padding: 7px 0 0;
		border-top: 1px solid
			color-mix(in srgb, var(--pmap-accent) 22%, transparent);
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 11.5px;
		font-weight: 600;
		letter-spacing: 0.01em;
		color: color-mix(in srgb, var(--pmap-accent) 62%, var(--sl-color-gray-2));
	}

	/* Stack on narrow viewports so each card keeps its full width. */
	@media (max-width: 560px) {
		.pmap-card {
			flex: 1 1 auto;
		}
	}
</style>
