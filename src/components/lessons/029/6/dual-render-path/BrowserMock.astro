---
// BrowserMock (diagram id: d1-dual-render-path, Chapter 029 L6 — the PRIMARY
// diagram). A small browser-window mock — macOS traffic lights, a tab, a
// toolbar with an address pill, and a "viewport" result area below it.
//
// One component, two variants, so the CHROME is byte-for-byte identical and
// only the result area differs. That is the entire pedagogical point: the same
// URL (/photo/42) renders two different things depending on how you arrived.
//
//   variant="soft"  — soft navigation (clicked a photo in the feed). The feed
//                      grid is still mounted but DIMMED behind a centered modal
//                      card showing the big photo. Rendered by the intercepter.
//   variant="hard"  — hard navigation (refresh / shared link / Cmd-click). A
//                      FULL standalone photo page with header + back link and
//                      NO feed behind it. Rendered by the real route.
//
// Both instances live in two <TabbedItem>s; the per-tab captions (authored in
// the MDX) name the file that produced each render.
//
// House style follows this chapter-cluster's hand-styled figures (029/2
// nesting-dolls, 010/4 PadlockAddressBar): a fixed slate palette with
// `color-scheme: light` pinned so the hand-picked tints survive dark mode, and
// `margin: 0` on every node to defeat Starlight's injected prose margin-top.

interface Props {
	variant: 'soft' | 'hard';
}

const { variant } = Astro.props;
const soft = variant === 'soft';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette (fixed — color-scheme pinned light so these survive dark mode).
const CHROME = '#e2e8f0'; // slate-200 — window chrome / toolbar
const CHROME_TOP = '#cbd5e1'; // slate-300 — tab strip
const PILL_BG = '#f8fafc'; // slate-50 — address pill fill
const PILL_BORDER = '#cbd5e1'; // slate-300 — address pill border
const VIEWPORT = '#ffffff'; // page surface
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const PHOTO = '#0ea5e9'; // sky-500 — "the photo" accent
const PHOTO_DEEP = '#0369a1'; // sky-700 — photo gradient end
const GRID_TILE = '#cbd5e1'; // slate-300 — feed thumbnail tiles
const MODAL_BORDER = '#bae6fd'; // sky-200 — modal card hairline

const reset = 'margin: 0';

// ── The big photo block, shared by both variants (modal body + page body). ──
const photoBlock = [
	reset,
	'box-sizing: border-box',
	'border-radius: 8px',
	`background: linear-gradient(135deg, ${PHOTO} 0%, ${PHOTO_DEEP} 100%)`,
	'display: flex',
	'align-items: flex-end',
	'padding: 10px',
	`font-family: ${sans}`,
	'font-size: 11px',
	'font-weight: 700',
	'color: #ffffff',
	'letter-spacing: 0.2px',
].join('; ');

// A single dimmed feed thumbnail (soft variant only).
const tile = [
	reset,
	'box-sizing: border-box',
	'border-radius: 5px',
	`background: ${GRID_TILE}`,
	'aspect-ratio: 1 / 1',
].join('; ');
---

<div
	style={`margin: 0; color-scheme: light; font-family: ${sans};`}
	aria-hidden="true"
>
	{/* ── Browser window ─────────────────────────────────────────────── */}
	<div
		style={`margin: 0; box-sizing: border-box; max-width: 460px; margin-inline: auto; border-radius: 12px; overflow: hidden; border: 1px solid ${CHROME_TOP}; box-shadow: 0 6px 20px rgba(15, 23, 42, 0.16);`}
	>
		{/* Tab strip — traffic lights + active tab */}
		<div
			style={`margin: 0; background: ${CHROME_TOP}; padding: 7px 12px 0; display: flex; align-items: center; gap: 12px;`}
		>
			<div style="margin: 0; display: inline-flex; gap: 6px; padding-bottom: 7px;">
				<span
					style="margin: 0; display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: #ff5f56;"
				></span>
				<span
					style="margin: 0; display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: #ffbd2e;"
				></span>
				<span
					style="margin: 0; display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: #27c93f;"
				></span>
			</div>
			<div
				style={`margin: 0; padding: 5px 14px 7px; background: ${CHROME}; border-radius: 8px 8px 0 0; color: ${INK}; font-size: 11.5px; font-weight: 600;`}
			>
				Photo
			</div>
		</div>

		{/* Toolbar — nav glyphs + address pill */}
		<div
			style={`margin: 0; padding: 9px 12px; display: flex; align-items: center; gap: 10px; background: ${CHROME};`}
		>
			<div
				style={`margin: 0; display: inline-flex; align-items: center; gap: 11px; color: ${INK_SOFT}; font-size: 15px;`}
			>
				<span style="margin: 0;">‹</span>
				<span style="margin: 0;">›</span>
				<span style="margin: 0; font-size: 13px;">↻</span>
			</div>
			<div
				style={`margin: 0; flex: 1 1 auto; min-width: 0; display: inline-flex; align-items: center; gap: 7px; background: ${PILL_BG}; border: 1px solid ${PILL_BORDER}; border-radius: 13px; padding: 4px 12px; font-family: ${mono}; font-size: 12.5px; color: ${INK};`}
			>
				{/* small lock glyph — the URL is a real, secure, shareable URL */}
				<svg
					width="11"
					height="13"
					viewBox="0 0 14 16"
					xmlns="http://www.w3.org/2000/svg"
					style="margin: 0; display: block; flex: 0 0 auto;"
				>
					<path
						d="M3.5 7 V5 a3.5 3.5 0 0 1 7 0 V7"
						fill="none"
						stroke={INK_SOFT}
						stroke-width="1.6"
						stroke-linecap="round"></path>
					<rect x="1.5" y="7" width="11" height="8" rx="1.6" fill={INK_SOFT}
					></rect>
				</svg>
				<span style="margin: 0; white-space: nowrap;">
					<span style={`color: ${INK_SOFT};`}>app.example.com</span>/photo/42
				</span>
			</div>
		</div>

		{/* ── Viewport (the rendered result area) ──────────────────────── */}
		<div
			style={`margin: 0; box-sizing: border-box; position: relative; background: ${VIEWPORT}; height: 232px; overflow: hidden;`}
		>
			{
				soft ? (
					<Fragment>
						{/* The feed grid, still mounted but dimmed behind the modal. */}
						<div style="margin: 0; box-sizing: border-box; position: absolute; inset: 0; padding: 14px; display: flex; flex-direction: column; gap: 9px; filter: blur(1px); opacity: 0.45;">
							<span
								style={`margin: 0; display: block; width: 64px; height: 9px; border-radius: 3px; background: ${GRID_TILE};`}
							/>
							<div style="margin: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 9px;">
								<span style={tile} />
								<span style={tile} />
								<span style={tile} />
								<span style={tile} />
								<span style={tile} />
								<span style={tile} />
							</div>
						</div>
						{/* Scrim over the dimmed feed. */}
						<div style="margin: 0; position: absolute; inset: 0; background: rgba(15, 23, 42, 0.28);" />
						{/* The modal card, floating over the feed. */}
						<div style="margin: 0; box-sizing: border-box; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 16px;">
							<div
								style={`margin: 0; box-sizing: border-box; width: 100%; max-width: 250px; background: ${VIEWPORT}; border: 1px solid ${MODAL_BORDER}; border-radius: 12px; box-shadow: 0 14px 36px rgba(15, 23, 42, 0.32); padding: 12px;`}
							>
								<div style={`${photoBlock} height: 124px;`}>Photo #42</div>
								<span
									style={`margin: 8px 0 0; display: block; width: 70%; height: 7px; border-radius: 3px; background: ${GRID_TILE};`}
								/>
								<span
									style={`margin: 6px 0 0; display: block; width: 45%; height: 7px; border-radius: 3px; background: ${GRID_TILE};`}
								/>
							</div>
						</div>
						{/* Floating tag — feed still underneath. */}
						<span
							style={`margin: 0; position: absolute; left: 10px; bottom: 9px; padding: 2px 8px; border-radius: 999px; background: ${INK}; color: #fff; font-size: 10px; font-weight: 600; font-family: ${sans};`}
						>
							feed still mounted
						</span>
					</Fragment>
				) : (
					<Fragment>
						{/* A full standalone photo page — page chrome, no feed. */}
						<div style="margin: 0; box-sizing: border-box; position: absolute; inset: 0; display: flex; flex-direction: column; padding: 0;">
							{/* page header + back link */}
							<div
								style={`margin: 0; box-sizing: border-box; display: flex; align-items: center; gap: 8px; padding: 9px 14px; border-bottom: 1px solid ${CHROME}; color: ${INK_SOFT}; font-size: 11px; font-weight: 600;`}
							>
								<span style={`margin: 0; color: ${PHOTO_DEEP};`}>
									← Back to feed
								</span>
								<span style={`margin: 0; margin-left: auto; color: ${INK_SOFT};`}>
									Photo
								</span>
							</div>
							{/* page body — the photo at full width */}
							<div style="margin: 0; box-sizing: border-box; flex: 1 1 auto; display: flex; flex-direction: column; padding: 14px;">
								<div style={`${photoBlock} flex: 1 1 auto;`}>Photo #42</div>
								<span
									style={`margin: 9px 0 0; display: block; width: 55%; height: 8px; border-radius: 3px; background: ${GRID_TILE};`}
								/>
								<span
									style={`margin: 7px 0 0; display: block; width: 80%; height: 8px; border-radius: 3px; background: ${GRID_TILE};`}
								/>
							</div>
						</div>
						{/* Floating tag — standalone, no feed. */}
						<span
							style={`margin: 0; position: absolute; right: 10px; bottom: 9px; padding: 2px 8px; border-radius: 999px; background: ${INK}; color: #fff; font-size: 10px; font-weight: 600; font-family: ${sans};`}
						>
							standalone page · no feed
						</span>
					</Fragment>
				)
			}
		</div>
	</div>
</div>
