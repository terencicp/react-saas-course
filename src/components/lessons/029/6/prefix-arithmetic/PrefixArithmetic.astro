---
// PrefixArithmetic (diagram id: d2-prefix-arithmetic, Chapter 029 L6).
//
// The single most counterintuitive point of the lesson, made spatial: the
// intercepting prefix counts URL segments, NOT folders. `(..)photo` is "one
// URL segment up", even though the `photo` route is TWO folders up on disk —
// because the `@modal` slot folder between them contributes no URL segment.
//
// Two horizontal strips of chips, sharing one CSS grid so their columns line up
// pixel-for-pixel:
//   TOP    the file-system path of the intercepter:  app · feed · @modal · (..)photo · [id]
//   BOTTOM the URL it intercepts:                    /   · feed ·  —     ·  photo    · 42
//
// The payoff is the @modal column: top has a chip, bottom is an empty ghost
// cell, so the eye literally sees the file-system strip carry one segment more
// than the URL strip. Surviving chips align by meaning — feed↔feed and the
// accent-tinted (..)photo↔photo — and a one-segment "hop" under the bottom
// strip shows `(..)` walking from the intercepter's level up to `feed`, with
// `photo` (the target) tinted on both strips.
//
// House style of this chapter's path/URL figure (029/1 AppTreeToUrls): pure
// HTML + CSS, theme-aware Starlight CSS variables (so it flips light/dark
// natively), a `not-content` wrapper, and `margin: 0` on every node to defeat
// Starlight's injected prose margin-top.

const reset = "margin: 0";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const accent = "var(--sl-color-text-accent)";
const accentTint = "color-mix(in srgb, var(--sl-color-text-accent) 14%, transparent)";

// ── Layout ────────────────────────────────────────────────────────────────
// One grid, two strip-rows + a thin "hop" row between, so the five path
// columns are a shared coordinate system across both strips. A leading
// max-content gutter column holds each strip's caption.
const grid = [
  reset,
  "display: grid",
  "grid-template-columns: max-content repeat(5, auto)",
  "align-items: center",
  "justify-content: center",
  "column-gap: 10px",
  "row-gap: 0",
  "width: 100%",
  "box-sizing: border-box",
  "overflow-x: auto",
  sans,
].join("; ");

// The little caption that labels each strip, in the gutter column.
const gutter = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "text-align: right",
  "white-space: nowrap",
  "padding-right: 4px",
].join("; ");

// Base chip — a path/URL segment.
const chipBase = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 14px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 8px 11px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
].join("; ");

// A surviving-correspondence chip: feed (neutral, but it IS the matched pair).
const chipMatched = `${chipBase}; border-color: var(--sl-color-gray-4); color: var(--sl-color-white)`;

// The accent pair — (..)photo on top, photo below — the segment the prefix
// actually targets. Tinted so the eye reads them as the same thing.
const chipAccent = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1",
  "padding: 8px 11px",
  "border-radius: 8px",
  `border: 1px solid ${accent}`,
  `background: ${accentTint}`,
  `color: ${accent}`,
  "white-space: nowrap",
].join("; ");

// The @modal chip — greyed + struck, the folder that drops out of the count.
const chipDropped = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 14px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 8px 11px",
  "border-radius: 8px",
  "border: 1px dashed var(--sl-color-gray-5)",
  "background: transparent",
  "color: var(--sl-color-gray-4)",
  "text-decoration: line-through",
  "text-decoration-thickness: 1.5px",
  "white-space: nowrap",
].join("; ");

// The ghost cell in the URL strip under @modal — visually "nothing here".
const chipGhost = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "text-transform: uppercase",
  "line-height: 1.1",
  "padding: 6px 8px",
  "border-radius: 8px",
  "border: 1px dashed var(--sl-color-gray-5)",
  "background: transparent",
  "color: var(--sl-color-gray-4)",
  "text-align: center",
  "white-space: nowrap",
].join("; ");

// "0 URL segments" sub-badge that sits under the struck @modal chip.
const droppedBadge = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 9px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 3px 6px",
  "border-radius: 999px",
  "background: var(--sl-color-gray-5)",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
].join("; ");

// Vertical breathing room between the two strips (each strip gets its own
// padded grid row; this is applied via the strip wrapper cells).
const stripCellTop = `${reset}; padding: 4px 0 14px;`;
const stripCellBottom = `${reset}; padding: 14px 0 4px;`;

// The "hop" connector row beneath the URL strip: a tinted bracket from the
// (..)photo column back one URL segment to feed, labelled "(..) → one URL up".
const hopWrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "justify-content: center",
].join("; ");

const hopBar = [
  reset,
  "height: 11px",
  `border-left: 2px solid ${accent}`,
  `border-right: 2px solid ${accent}`,
  `border-bottom: 2px solid ${accent}`,
  "border-radius: 0 0 6px 6px",
].join("; ");

const hopLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "text-align: center",
  `color: ${accent}`,
  "padding-top: 5px",
  "white-space: nowrap",
].join("; ");
---

<div class="not-content" style={`${reset}; ${sans}`}>
  <div style={grid}>
    {/* ── TOP strip — the intercepter's file-system path ── */}
    <div style={`${gutter}; ${stripCellTop}`}>On&nbsp;disk</div>
    <div style={stripCellTop}><code style={chipBase}>app</code></div>
    <div style={stripCellTop}><code style={chipMatched}>feed</code></div>
    <div style={`${stripCellTop}; display: flex; flex-direction: column; align-items: center; gap: 5px;`}>
      <code style={chipDropped}>@modal</code>
      <span style={droppedBadge}>0 URL segments</span>
    </div>
    <div style={stripCellTop}><code style={chipAccent}>(..)photo</code></div>
    <div style={stripCellTop}><code style={chipBase}>[id]</code></div>

    {/* ── BOTTOM strip — the URL it intercepts ── */}
    <div style={`${gutter}; ${stripCellBottom}`}>In&nbsp;the&nbsp;URL</div>
    <div style={stripCellBottom}><code style={chipBase}>/</code></div>
    <div style={stripCellBottom}><code style={chipMatched}>feed</code></div>
    <div style={stripCellBottom}><span style={chipGhost}>(nothing)</span></div>
    <div style={stripCellBottom}><code style={chipAccent}>photo</code></div>
    <div style={stripCellBottom}><code style={chipBase}>42</code></div>

    {/* ── HOP row — under the URL strip, a bracket from `photo` back one URL
        segment to `feed` (skipping the empty @modal column between them). That
        single hop is what `(..)` counts. Placed explicitly over the
        feed→photo columns (grid lines 3→6). ── */}
    <div style={`${hopWrap}; grid-row: 3; grid-column: 3 / 6;`}>
      <div style={hopBar}></div>
      <div style={hopLabel}>
        <code
          style={`${reset}; ${mono}; background: transparent; padding: 0; color: ${accent}; font-weight: 700;`}
          >(..)</code
        > = one URL segment up
      </div>
    </div>
  </div>
</div>
