---
// Route -> params table for a single `[id]` segment, the figure that makes the
// "any string the user types lands here" point VISIBLE before the prose argues
// it. Three URLs hit `app/invoices/[id]/page.tsx`; each row maps the URL on the
// left to the resolved `params` object on the right, with the captured segment
// of the URL highlighted so the eye sees exactly which part becomes `params.id`.
//
//   row 1  /invoices/inv_42        -> { id: 'inv_42' }      (a friendly id)
//   row 2  /invoices/8f3a-...      -> { id: '8f3a-...' }    (a uuid-ish id)
//   row 3  /invoices/' OR 1=1 --   -> { id: "' OR 1=1 --" } (a SQL-injection probe)
//
// Row 3 is the whole reason the figure exists: it carries the red `--mark-red`
// accent and an "untrusted" chip so the hostile string pops, foreshadowing the
// validation section ("the URL bar is an input field"). The benign rows stay on
// neutral chrome so the contrast does the teaching.
//
// Pure HTML + CSS, devtools-inspectable, matching the chapter family's figures:
// a `not-content` wrapper, Starlight gray/white variables for dim chrome (they
// flip light/dark), the theme-aware `--mark-red`/`--mark-green` accents from
// custom.css for the signal, inline styles only, and a `margin: 0` reset on
// every inner element to defeat Starlight's prose-margin injection.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Each row is one request. `prefix` is the dimmed, always-the-same part of the
// path; `captured` is the segment the `[id]` folder grabs (highlighted); the
// `params` cell echoes it back as the resolved object. `hostile` flips the row
// to the red danger accent.
type Row = {
  prefix: string;
  captured: string;
  // The right-hand `params` object, split so the captured value can be tinted.
  paramsPre: string;
  paramsValue: string;
  paramsPost: string;
  hostile?: boolean;
  note?: string;
};

const rows: Row[] = [
  {
    prefix: "/invoices/",
    captured: "inv_42",
    paramsPre: "{ id: ",
    paramsValue: "'inv_42'",
    paramsPost: " }",
  },
  {
    prefix: "/invoices/",
    captured: "8f3a-4c…",
    paramsPre: "{ id: ",
    paramsValue: "'8f3a-4c…'",
    paramsPost: " }",
  },
  {
    prefix: "/invoices/",
    captured: "' OR 1=1 --",
    paramsPre: "{ id: ",
    paramsValue: "\"' OR 1=1 --\"",
    paramsPost: " }",
    hostile: true,
    note: "a string is a string — hostile ones land here too",
  },
];

// ── style fragments ────────────────────────────────────────────────────────

// Outer wrapper: a 3-column grid (URL | arrow | params) so all three rows share
// one coordinate system and the columns line up. `align-items: center` keeps the
// arrow centered against each row's box.
const root = [
  reset,
  "display: grid",
  "grid-template-columns: minmax(0, 1fr) auto minmax(0, 0.9fr)",
  "align-items: center",
  "column-gap: 12px",
  "row-gap: 10px",
  "width: 100%",
  "max-width: 680px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// Column headers framing the two sides ("URL" / "params"), matching the prose.
const headCell = (align: "start" | "end") =>
  [
    reset,
    sans,
    "font-size: 10.5px",
    "font-weight: 700",
    "letter-spacing: 0.06em",
    "text-transform: uppercase",
    "line-height: 1",
    "color: var(--sl-color-gray-3)",
    "text-align: " + (align === "start" ? "left" : "right"),
    "padding: 0 2px 2px",
    "box-sizing: border-box",
  ].join("; ");

// The URL cell, styled like a browser address bar: a pill with a leading
// affordance dot and the path in mono. The captured segment is tinted.
const urlCell = (hostile: boolean) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "gap: 8px",
    "min-width: 0",
    "padding: 8px 11px",
    "border-radius: 999px",
    "box-sizing: border-box",
    hostile
      ? "border: 1.5px solid var(--mark-red-brd); background: var(--mark-red-bg)"
      : "border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
  ].join("; ");

// Tiny address-bar affordance (a lock/globe stand-in) so the pill reads as a URL
// bar at a glance.
const urlDot = (hostile: boolean) =>
  [
    reset,
    "flex: 0 0 auto",
    "width: 7px",
    "height: 7px",
    "border-radius: 50%",
    "box-sizing: border-box",
    hostile
      ? "background: var(--mark-red-brd)"
      : "background: var(--sl-color-gray-4)",
  ].join("; ");

const urlText = [
  reset,
  mono,
  "font-size: 13px",
  "line-height: 1.3",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
  "min-width: 0",
  "box-sizing: border-box",
].join("; ");

const urlPrefix = [
  reset,
  "color: var(--sl-color-gray-3)",
].join("; ");

// The captured segment — the part the `[id]` folder grabs. Tinted so the eye
// can trace URL-segment -> params value.
const captured = (hostile: boolean) =>
  [
    reset,
    "font-weight: 700",
    "padding: 1px 4px",
    "border-radius: 5px",
    "box-sizing: border-box",
    hostile
      ? "color: var(--sl-color-white); background: var(--mark-red-bg); border: 1px solid var(--mark-red-brd)"
      : "color: var(--sl-color-white); background: var(--mark-blue-bg); border: 1px solid var(--mark-blue-brd)",
  ].join("; ");

// The arrow between the two columns: "captured by [id]".
const arrowCell = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 3px",
  "box-sizing: border-box",
].join("; ");

const arrowLabel = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

// The params cell: the resolved object, mono, with the captured value tinted to
// match its source segment.
const paramsCell = (hostile: boolean) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "gap: 5px",
    "min-width: 0",
    "padding: 8px 11px",
    "border-radius: 9px",
    "box-sizing: border-box",
    hostile
      ? "border: 1.5px solid var(--mark-red-brd); background: var(--mark-red-bg)"
      : "border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
  ].join("; ");

const paramsCode = [
  reset,
  mono,
  "font-size: 13px",
  "line-height: 1.3",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
  "min-width: 0",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

const paramsValue = (hostile: boolean) =>
  [
    reset,
    "font-weight: 700",
    "box-sizing: border-box",
    hostile ? "color: var(--mark-red-brd)" : "color: var(--mark-blue-brd)",
  ].join("; ");

// The "untrusted" chip on the hostile row's params cell.
const chip = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 4px",
  "align-self: flex-start",
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 3px 6px",
  "border-radius: 5px",
  "color: var(--sl-color-white)",
  "background: var(--mark-red-bg)",
  "border: 1px solid var(--mark-red-brd)",
  "box-sizing: border-box",
].join("; ");

const chipDot = [
  reset,
  "width: 5px",
  "height: 5px",
  "border-radius: 50%",
  "background: var(--mark-red-brd)",
  "box-sizing: border-box",
].join("; ");

// SVG arrow fill picks up the danger accent on the hostile row.
const arrowFill = (hostile: boolean) =>
  hostile ? "var(--mark-red-brd)" : "var(--sl-color-gray-4)";
---

<div class="not-content" style={root}>
  {/* column headers */}
  <div style={headCell("start")}>URL</div>
  <div style={`${reset}; box-sizing: border-box;`}></div>
  <div style={headCell("end")}>params</div>

  {
    rows.map((row) => (
      <Fragment>
        {/* URL cell — styled like an address bar */}
        <div style={urlCell(Boolean(row.hostile))}>
          <span style={urlDot(Boolean(row.hostile))} aria-hidden="true" />
          <span style={urlText}>
            <span style={urlPrefix}>{row.prefix}</span>
            <span style={captured(Boolean(row.hostile))}>{row.captured}</span>
          </span>
        </div>

        {/* arrow — the framework captures the segment into params */}
        <div style={arrowCell}>
          <span style={arrowLabel}>
            captured by <code style={`${mono}; background: transparent; padding: 0; color: var(--sl-color-gray-2);`}>[id]</code>
          </span>
          <svg
            width="46"
            height="14"
            viewBox="0 0 46 14"
            role="img"
            aria-label="captured by the [id] folder into params"
            style="margin: 0; display: block;"
          >
            <line
              x1="0"
              y1="7"
              x2="37"
              y2="7"
              stroke={arrowFill(Boolean(row.hostile))}
              stroke-width="1.5"
            />
            <path d="M 46 7 L 37 2.5 L 37 11.5 Z" fill={arrowFill(Boolean(row.hostile))} />
          </svg>
        </div>

        {/* params cell — the resolved object */}
        <div style={paramsCell(Boolean(row.hostile))}>
          <span style={paramsCode}>
            {row.paramsPre}
            <span style={paramsValue(Boolean(row.hostile))}>{row.paramsValue}</span>
            {row.paramsPost}
          </span>
          {row.hostile && (
            <span style={chip}>
              <span style={chipDot} aria-hidden="true" />
              untrusted
            </span>
          )}
        </div>
      </Fragment>
    ))
  }
</div>
