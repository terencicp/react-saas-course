---
// Route -> params table for one catch-all variant, the panel that lives inside
// each tab of the `tabbed-catchall-tables` figure. Same visual idiom as this
// lesson's `RouteParamsTableSingle` so the two figures read as a family: each
// row is one request, with the URL on the left styled like an address bar (the
// captured segments tinted), an arrow in the middle ("captured by [...slug]"),
// and the resolved `params.slug` echoed on the right.
//
// The whole point of the figure is the A/B: rows 2-4 are byte-for-byte identical
// across the two variants, and ONLY the top row (`/docs`, the bare parent)
// differs. So this component takes a `variant` and changes exactly that row:
//
//   variant="catchall"  ([...slug])    /docs -> no match, an HTTP 404 (red)
//   variant="optional"  ([[...slug]])  /docs -> params.slug is `undefined` (orange)
//
// The differing row carries a colored accent in BOTH variants so that when the
// student flips the tab, the eye is already parked on the row that changes. The
// identical rows stay on neutral chrome so the contrast does the teaching.
//
// Pure HTML + CSS, devtools-inspectable: a `not-content` wrapper, Starlight
// gray/white variables for dim chrome (they flip light/dark), the theme-aware
// `--mark-*` accents from custom.css for signal, inline styles only, and a
// `margin: 0` reset on every inner element to defeat Starlight's prose margins.

interface Props {
  variant: "catchall" | "optional";
}

const { variant } = Astro.props;

const isOptional = variant === "optional";

// The folder shape this table is for — drives the arrow label and the captions.
const folder = isOptional ? "[[...slug]]" : "[...slug]";

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Each row is one request. `segments` is the list of path parts the catch-all
// captures (empty for the bare parent); rendering joins them with tinted "/"
// separators so the eye can trace each URL segment to an array entry. The first
// row is special-cased per variant via the `special` flag.
type Row =
  | {
      // The bare `/docs` parent — its right-hand cell depends on the variant.
      special: true;
    }
  | {
      special?: false;
      // Captured path segments, e.g. ['a', 'b'] for /docs/a/b.
      segments: string[];
    };

const rows: Row[] = [
  { special: true },
  { segments: ["a"] },
  { segments: ["a", "b"] },
  { segments: ["a", "b", "c"] },
];

// ── style fragments ────────────────────────────────────────────────────────

// Outer wrapper: a 3-column grid (URL | arrow | params) so every row shares one
// coordinate system and the two columns line up. `align-items: center` keeps the
// arrow centered against each row's box.
const root = [
  reset,
  "display: grid",
  "grid-template-columns: minmax(0, 1fr) auto minmax(0, 0.95fr)",
  "align-items: center",
  "column-gap: 12px",
  "row-gap: 10px",
  "width: 100%",
  "max-width: 660px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// Column headers framing the two sides ("URL" / "params.slug").
const headCell = (align: "start" | "end") =>
  [
    reset,
    sans,
    "font-size: 10.5px",
    "font-weight: 700",
    "letter-spacing: 0.06em",
    "text-transform: uppercase",
    "line-height: 1",
    "color: var(--sl-color-gray-3)",
    "text-align: " + (align === "start" ? "left" : "right"),
    "padding: 0 2px 2px",
    "box-sizing: border-box",
  ].join("; ");

// accent — which mark color tints a row. "blue" = the neutral captured segments,
// "red" = the catch-all 404, "orange" = the optional `undefined`.
type Accent = "blue" | "red" | "orange";

// The URL cell, styled like a browser address bar: a pill with a leading
// affordance dot and the path in mono.
const urlCell = (accent: Accent | null) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "gap: 8px",
    "min-width: 0",
    "padding: 8px 11px",
    "border-radius: 999px",
    "box-sizing: border-box",
    accent === "red"
      ? "border: 1.5px solid var(--mark-red-brd); background: var(--mark-red-bg)"
      : accent === "orange"
        ? "border: 1.5px solid var(--mark-orange-brd); background: var(--mark-orange-bg)"
        : "border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
  ].join("; ");

const urlDot = (accent: Accent | null) =>
  [
    reset,
    "flex: 0 0 auto",
    "width: 7px",
    "height: 7px",
    "border-radius: 50%",
    "box-sizing: border-box",
    accent === "red"
      ? "background: var(--mark-red-brd)"
      : accent === "orange"
        ? "background: var(--mark-orange-brd)"
        : "background: var(--sl-color-gray-4)",
  ].join("; ");

const urlText = [
  reset,
  mono,
  "font-size: 13px",
  "line-height: 1.3",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
  "min-width: 0",
  "box-sizing: border-box",
].join("; ");

const urlPrefix = [reset, "color: var(--sl-color-gray-3)"].join("; ");

// A single captured segment — tinted blue so the eye can trace URL part ->
// array entry. The "/" separators between segments are dimmed.
const segment = [
  reset,
  "font-weight: 700",
  "padding: 1px 4px",
  "border-radius: 5px",
  "box-sizing: border-box",
  "color: var(--sl-color-white)",
  "background: var(--mark-blue-bg)",
  "border: 1px solid var(--mark-blue-brd)",
].join("; ");

const slash = [reset, "color: var(--sl-color-gray-3)", "padding: 0 1px"].join(
  "; ",
);

// The arrow between the two columns: "captured by [...slug]".
const arrowCell = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 3px",
  "box-sizing: border-box",
].join("; ");

const arrowLabel = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

// The params cell: the resolved `params.slug` value, mono.
const paramsCell = (accent: Accent | null) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "min-width: 0",
    "padding: 8px 11px",
    "border-radius: 9px",
    "box-sizing: border-box",
    accent === "red"
      ? "border: 1.5px solid var(--mark-red-brd); background: var(--mark-red-bg)"
      : accent === "orange"
        ? "border: 1.5px solid var(--mark-orange-brd); background: var(--mark-orange-bg)"
        : "border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
  ].join("; ");

const paramsCode = [
  reset,
  mono,
  "font-size: 13px",
  "line-height: 1.3",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
  "min-width: 0",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

// The tinted array literal on a captured row, e.g. ['a', 'b'].
const arrayValue = [reset, "color: var(--mark-blue-brd)", "font-weight: 700"].join(
  "; ",
);

// The special first-row value: a red "404" pill for catch-all, an orange
// `undefined` token for optional.
const valueToken = (accent: Accent) =>
  [
    reset,
    "font-weight: 700",
    accent === "red" ? "color: var(--mark-red-brd)" : "color: var(--mark-orange-brd)",
  ].join("; ");

// The status chip on the differing first row ("404 — no match" / "matches parent").
const chip = (accent: Accent) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "gap: 4px",
    "margin-left: 8px",
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "line-height: 1",
    "padding: 3px 6px",
    "border-radius: 5px",
    "box-sizing: border-box",
    "white-space: nowrap",
    "color: var(--sl-color-white)",
    accent === "red"
      ? "background: var(--mark-red-bg); border: 1px solid var(--mark-red-brd)"
      : "background: var(--mark-orange-bg); border: 1px solid var(--mark-orange-brd)",
  ].join("; ");

// SVG arrow fill: dimmed by default, red on the catch-all 404 row.
const arrowFill = (accent: Accent | null) =>
  accent === "red"
    ? "var(--mark-red-brd)"
    : accent === "orange"
      ? "var(--mark-orange-brd)"
      : "var(--sl-color-gray-4)";

// Resolve the accent for the special first row from the variant.
const specialAccent: Accent = isOptional ? "orange" : "red";
---

<div class="not-content" style={root}>
  {/* column headers */}
  <div style={headCell("start")}>URL</div>
  <div style={`${reset}; box-sizing: border-box;`}></div>
  <div style={headCell("end")}><code style={`${mono}; background: transparent; padding: 0; color: var(--sl-color-gray-3);`}>params.slug</code></div>

  {
    rows.map((row) => {
      const accent: Accent | null = row.special ? specialAccent : null;
      return (
        <Fragment>
          {/* URL cell — styled like an address bar */}
          <div style={urlCell(accent)}>
            <span style={urlDot(accent)} aria-hidden="true" />
            <span style={urlText}>
              <span style={urlPrefix}>/docs</span>
              {!row.special &&
                row.segments.map((seg) => (
                  <Fragment>
                    <span style={slash}>/</span>
                    <span style={segment}>{seg}</span>
                  </Fragment>
                ))}
            </span>
          </div>

          {/* arrow — the catch-all folder captures the trailing segments */}
          <div style={arrowCell}>
            <span style={arrowLabel}>
              <code style={`${mono}; background: transparent; padding: 0; color: var(--sl-color-gray-2);`}>{folder}</code>
            </span>
            <svg
              width="46"
              height="14"
              viewBox="0 0 46 14"
              role="img"
              aria-label={`captured by the ${folder} folder into params.slug`}
              style="margin: 0; display: block;"
            >
              <line x1="0" y1="7" x2="37" y2="7" stroke={arrowFill(accent)} stroke-width="1.5" />
              <path d="M 46 7 L 37 2.5 L 37 11.5 Z" fill={arrowFill(accent)} />
            </svg>
          </div>

          {/* params cell — the resolved params.slug value */}
          <div style={paramsCell(accent)}>
            <span style={paramsCode}>
              {row.special ? (
                isOptional ? (
                  <Fragment>
                    <span style={valueToken("orange")}>undefined</span>
                    <span style={chip("orange")}>matches parent</span>
                  </Fragment>
                ) : (
                  <Fragment>
                    <span style={valueToken("red")}>—</span>
                    <span style={chip("red")}>404 · no match</span>
                  </Fragment>
                )
              ) : (
                <span style={arrayValue}>
                  [{row.segments.map((seg, i) => `${i > 0 ? ", " : ""}'${seg}'`).join("")}]
                </span>
              )}
            </span>
          </div>
        </Fragment>
      );
    })
  }
</div>
