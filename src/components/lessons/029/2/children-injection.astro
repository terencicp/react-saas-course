---
// children-injection (Chapter 029 L2). The framework fills a layout's `children`
// with the page that resolves at the same folder — the diagram makes that
// correspondence visible WITHOUT an arrow.
//
// Two small code panels, side by side:
//   LEFT  src/app/dashboard/page.tsx    — exports DashboardPage
//   RIGHT src/app/dashboard/layout.tsx  — renders {children}
//
// The relationship is pure identity ("the page IS the children"), and an arrow
// from the left panel to the {children} token on the right would have to cut
// across the right panel's code lines — exactly the case the ArrowDiagram doc
// says to drop the curve and color-match instead. So the page's identifier and
// the layout's {children} token wear the SAME blue match-highlight (#0ea5e9 wash
// + 1px inset ring); identity carries the wiring, no line crosses any code.
//
// House style follows this chapter-cluster's hand-styled figures (e.g. 023/2
// TypeMatchTrees): inline style strings, `not-content` to shed Starlight prose
// chrome, `margin: 0` on every node to defeat the injected prose margin-top, and
// `color-scheme: light` pinned with a fixed editor palette so the hand-picked
// blue match reads identically in light and dark mode. Panels `flex-wrap` so the
// pair stacks on narrow viewports.

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Editor palette (fixed — color-scheme is pinned light so these survive dark mode).
const PANEL_BG = '#f8fafc'; // slate-50 — code surface
const PANEL_BORDER = '#e2e8f0'; // slate-200 — panel edge
const HEAD_BG = '#eef2f7'; // slate-100-ish — filename bar
const CODE_INK = '#334155'; // slate-700 — code text
const MUTED = '#64748b'; // slate-500 — filename + path
const PUNCT = '#94a3b8'; // slate-400 — braces / punctuation
const KEYWORD = '#7c3aed'; // violet-600 — export/function/return keywords
const TAG = '#0f766e'; // teal-700 — JSX tag names

// The shared match colour. Same blue both panels wear on the corresponding token.
const MATCH = '#0ea5e9'; // sky-500
const matchWash = `color-mix(in srgb, ${MATCH} 22%, transparent)`;
const matchRing = `inset 0 0 0 1px color-mix(in srgb, ${MATCH} 65%, transparent)`;

// One code panel: a filename header strip over a monospace code body.
const panel = [
	'box-sizing: border-box',
	'display: flex',
	'flex-direction: column',
	'flex: 1 1 320px',
	'min-width: 290px',
	'max-width: 460px',
	'margin: 0',
	'border-radius: 11px',
	'overflow: hidden',
	`border: 1px solid ${PANEL_BORDER}`,
	`background: ${PANEL_BG}`,
].join('; ');

const header = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'gap: 7px',
	'margin: 0',
	'padding: 8px 13px',
	`background: ${HEAD_BG}`,
	`border-bottom: 1px solid ${PANEL_BORDER}`,
	`font-family: ${mono}`,
	'font-size: 12px',
	'font-weight: 600',
	'line-height: 1.2',
	`color: ${MUTED}`,
].join('; ');

const dot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 9px; height: 9px; margin: 0; border-radius: 999px; background: ${c};`;

const body = [
	'box-sizing: border-box',
	'margin: 0',
	'padding: 14px 16px 15px',
	`font-family: ${mono}`,
	'font-size: 13px',
	'line-height: 1.65',
	`color: ${CODE_INK}`,
	'white-space: pre',
	'overflow-x: auto',
].join('; ');

const line = 'display: block; margin: 0; white-space: pre;';
const kw = `color: ${KEYWORD};`;
const tag = `color: ${TAG};`;
const punct = `color: ${PUNCT};`;

// The match-highlight worn by the corresponding token in each panel.
const match = [
	'border-radius: 4px',
	'padding: 1px 3px',
	'margin: 0 -1px',
	`background: ${matchWash}`,
	`box-shadow: ${matchRing}`,
	`color: ${CODE_INK}`,
	'font-weight: 700',
].join('; ');
---

<div
	class="not-content"
	style={`display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; column-gap: 18px; row-gap: 16px; margin: 0; color-scheme: light; font-family: ${sans};`}
>
	{/* ---- LEFT: the page ---- */}
	<div style={panel}>
		<div style={header}>
			<span style={dot(MATCH)} aria-hidden="true"></span>
			<span style="margin: 0;">src/app/dashboard/page.tsx</span>
		</div>
		<code style={body}>
			<span style={line}><span style={kw}>export default function </span><span style={match}>DashboardPage</span><span style={punct}>() {'{'}</span></span>
			<span style={line}>{'  '}<span style={kw}>return </span><span style={punct}>&lt;</span><span style={tag}>h1</span><span style={punct}>&gt;</span>Dashboard<span style={punct}>&lt;/</span><span style={tag}>h1</span><span style={punct}>&gt;;</span></span>
			<span style={line}><span style={punct}>{'}'}</span></span>
		</code>
	</div>

	{/* ---- RIGHT: the layout ---- */}
	<div style={panel}>
		<div style={header}>
			<span style={dot(MUTED)} aria-hidden="true"></span>
			<span style="margin: 0;">src/app/dashboard/layout.tsx</span>
		</div>
		<code style={body}>
			<span style={line}><span style={kw}>export default function </span><span style={tag}>DashboardLayout</span><span style={punct}>({'{ '}</span>children<span style={punct}>{' }'}) {'{'}</span></span>
			<span style={line}>{'  '}<span style={kw}>return </span><span style={punct}>&lt;</span><span style={tag}>section</span><span style={punct}>&gt;</span><span style={match}>{'{'}children{'}'}</span><span style={punct}>&lt;/</span><span style={tag}>section</span><span style={punct}>&gt;;</span></span>
			<span style={line}><span style={punct}>{'}'}</span></span>
		</code>
	</div>
</div>
