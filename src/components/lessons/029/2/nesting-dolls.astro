---
// nesting-dolls (diagram id: layout-nesting-dolls, Chapter 029 L2). A three-step
// scrubbable DiagramSequence showing layout composition as concentric rings —
// the page is the innermost doll, the dashboard layout wraps it, the root layout
// wraps that. Each step lights one more outer ring, built from the inside out.
//
//   Step 1  the page alone        page.tsx renders bare.
//   Step 2  + dashboard ring      dashboard/layout.tsx wraps it (sidebar strip).
//   Step 3  + root ring           app/layout.tsx wraps that (<html>/<body> + top bar).
//
// HEIGHT STABILITY (the DiagramSequence grid stack sizes to the tallest step and
// must not reflow as the reader scrubs): all three steps render the *same* three
// concentric boxes with the *same* outer footprint. The outer rings always
// reserve their padding + a constant transparent border, so the page sits in the
// exact same pixels in every step — only each ring's PAINT toggles per level
// (border colour, the fieldset-legend label pill, the chrome strip). Nothing in
// flow changes size, so the stage never jumps and the page never drifts.
//
// The pill labels straddle each ring's top border (display: block + fit-content +
// negative margin-top per the html-css fieldset-legend pattern); the sidebar /
// top-bar chrome strips are absolutely positioned inside their ring so they paint
// without disturbing the content box that holds the next doll.
//
// House style follows this chapter-cluster's hand-styled figures (children-injection,
// 023/2 PositionMatchSequence): fixed slate palette, `color-scheme: light` pinned
// so the hand-picked tints survive dark mode, `margin: 0` on every node to defeat
// Starlight's injected prose margin-top.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette (fixed — color-scheme pinned light so these survive dark mode).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const STRIP_BG = '#e2e8f0'; // slate-200 — chrome strip placeholder fill
const STRIP_BAR = '#cbd5e1'; // slate-300 — mock control bars on a strip

// Each ring owns one accent — the pill, border, and chrome strip share it.
const ROOT = '#0f766e'; // teal-700 — root layout ring
const ROOT_BG = '#f0fdfa'; // teal-50 — root ring wash
const DASH = '#7c3aed'; // violet-600 — dashboard layout ring
const DASH_BG = '#f5f3ff'; // violet-50 — dashboard ring wash
const PAGE = '#0ea5e9'; // sky-500 — the page (innermost doll)
const PAGE_BG = '#ffffff'; // page surface

// The fixed border width every ring reserves (transparent when the ring is unlit,
// so the geometry is identical across all three steps).
const RING_BW = '2px';

// Outer stage shared by every step: pinned light, centered, constant shape.
const stage = `display: flex; justify-content: center; margin: 0; padding: 4px 2px 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A concentric ring box. `lit` paints the border + wash; unlit keeps a
// transparent border of the same width so the inner content never shifts.
function ring(lit: boolean, accent: string, wash: string, extra: string) {
	return [
		'position: relative',
		'box-sizing: border-box',
		'margin: 0',
		'border-radius: 12px',
		`border: ${RING_BW} solid ${lit ? accent : 'transparent'}`,
		`background: ${lit ? wash : 'transparent'}`,
		extra,
	].join('; ');
}

// The fieldset-legend pill that straddles a ring's top border. Block + fit-content
// + negative margin-top lands its centre on the border line. `lit` hides it
// (visibility, so it keeps reserving no flow height either way — it's already
// out of flow via the negative margin, but visibility avoids a paint).
function pill(lit: boolean, accent: string) {
	return [
		'display: block',
		'width: fit-content',
		'box-sizing: border-box',
		'position: relative',
		'z-index: 2',
		'margin: -11px 0 0 14px', // pull the pill's centre onto the top border
		'padding: 2px 9px',
		`font-family: ${mono}`,
		'font-size: 11.5px',
		'font-weight: 700',
		'line-height: 1.3',
		'white-space: nowrap',
		'border-radius: 6px',
		`color: #ffffff`,
		`background: ${accent}`,
		`visibility: ${lit ? 'visible' : 'hidden'}`,
	].join('; ');
}

// The dashboard ring's left sidebar chrome strip (absolutely positioned so it
// paints without pushing the page doll right). Reserved in flow by the ring's
// left padding.
function sidebarStrip(lit: boolean) {
	return [
		'position: absolute',
		'top: 12px',
		'left: 10px',
		'bottom: 12px',
		'width: 30px',
		'box-sizing: border-box',
		'display: flex',
		'flex-direction: column',
		'gap: 5px',
		'margin: 0',
		'padding: 7px 6px',
		'border-radius: 7px',
		`background: ${STRIP_BG}`,
		`visibility: ${lit ? 'visible' : 'hidden'}`,
	].join('; ');
}

// The root ring's top app-bar chrome strip (absolutely positioned; reserved in
// flow by the ring's top padding).
function topbarStrip(lit: boolean) {
	return [
		'position: absolute',
		'top: 10px',
		'left: 12px',
		'right: 12px',
		'height: 20px',
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'justify-content: flex-end',
		'gap: 6px',
		'margin: 0',
		'padding: 0 10px',
		'border-radius: 6px',
		`background: ${STRIP_BG}`,
		`visibility: ${lit ? 'visible' : 'hidden'}`,
	].join('; ');
}

// Small mock control bars that live on the chrome strips.
const navBar = `display: block; width: 100%; height: 5px; margin: 0; border-radius: 3px; background: ${STRIP_BAR};`;
const topDot = `display: block; width: 11px; height: 11px; margin: 0; border-radius: 999px; background: ${STRIP_BAR};`;
const topBar = `display: block; width: 34px; height: 6px; margin: 0; border-radius: 3px; background: ${STRIP_BAR};`;

// The page doll itself — always painted, dead centre, identical in every step.
const pageBox = `position: relative; box-sizing: border-box; margin: 0; padding: 14px 16px 16px; border-radius: 10px; border: ${RING_BW} solid ${PAGE}; background: ${PAGE_BG}; min-width: 150px; box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);`;
// margin-top clears the page.tsx legend pill that precedes the h1 in flow.
const pageH1 = `display: block; margin: 9px 0 0; font-family: ${sans}; font-size: 15px; font-weight: 700; line-height: 1.2; color: ${INK};`;
const pageLine = (w: string) => `display: block; width: ${w}; height: 6px; margin: 9px 0 0; border-radius: 3px; background: #e2e8f0;`;

// Fixed insets so each ring sits a constant distance inside its parent. These
// padding values reserve room for the chrome strips and pill labels at every
// level, lit or not.
const rootPad = 'padding: 34px 16px 16px;'; // top padding clears the top-bar strip
const dashPad = 'padding: 16px 16px 16px 48px;'; // left padding clears the sidebar strip

// Render the full concentric figure at a given level (1, 2, or 3).
function dolls(level: number) {
	return { level };
}
const STEPS = [dolls(1), dolls(2), dolls(3)];
---

<DiagramSequence>
	{
		STEPS.map(({ level }) => {
			const dashLit = level >= 2;
			const rootLit = level >= 3;
			const caption =
				level === 1
					? 'Step 1 — the page alone. src/app/dashboard/page.tsx renders bare: just the leaf’s own UI, no shell around it yet.'
					: level === 2
						? 'Step 2 — the dashboard layout wraps it. The sidebar chrome from dashboard/layout.tsx appears around the page; the page renders exactly where {children} sits.'
						: 'Step 3 — the root layout wraps that. app/layout.tsx adds the <html>/<body> document shell and any app-wide chrome around the whole thing. This is the final tree the browser receives.';

			return (
				<DiagramStep caption={caption}>
					<div style={stage}>
						{/* Root ring (outermost) */}
						<div style={ring(rootLit, ROOT, ROOT_BG, rootPad)}>
							<span style={pill(rootLit, ROOT)}>app/layout.tsx — &lt;html&gt; / &lt;body&gt;</span>
							<div style={topbarStrip(rootLit)} aria-hidden="true">
								<span style={topBar} />
								<span style={topDot} />
							</div>

							{/* Dashboard ring (middle) */}
							<div style={ring(dashLit, DASH, DASH_BG, dashPad)}>
								<span style={pill(dashLit, DASH)}>dashboard/layout.tsx — sidebar</span>
								<div style={sidebarStrip(dashLit)} aria-hidden="true">
									<span style={navBar} />
									<span style={navBar} />
									<span style={navBar} />
								</div>

								{/* Page (innermost doll) — always painted */}
								<div style={pageBox}>
									<span style={pill(true, PAGE)}>page.tsx</span>
									<span style={pageH1}>Dashboard</span>
									<span style={pageLine('118px')} aria-hidden="true" />
									<span style={pageLine('92px')} aria-hidden="true" />
								</div>
							</div>
						</div>
					</div>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>
