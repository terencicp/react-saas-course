---
// default-mechanics (diagram id: default-mechanics, Chapter 029 L5 — the
// load-bearing visual of the `default.tsx` section). A three-step scrubbable
// DiagramSequence that makes the soft-vs-hard navigation distinction VISIBLE,
// and pins down why a missing `default.tsx` 404s the WHOLE route.
//
//   Step 1  soft nav  /invoices -> /invoices/42
//             children = KEPT (page.tsx — its match did not change)
//             detail   = RE-RESOLVED (@detail/[id]/page.tsx)
//             both filled — the router carries the unchanged slot forward.
//
//   Step 2  hard nav  refresh on /invoices/42
//             every slot resolved fresh from the URL — and both still match.
//             children -> page.tsx ✓ ; detail -> @detail/[id]/page.tsx ✓
//             no fallback needed.
//
//   Step 3  hard nav  /invoices/42/edit — a deeper path the `children` tree
//             covers ([id]/edit) but the `detail` slot has no route for. An
//             inner TabbedContent puts the two outcomes side by side:
//               Without default.tsx — detail has NO match (red), and rather
//                 than render half a screen the framework 404s the WHOLE route
//                 (red banner across the box).
//               With default.tsx — the detail slot falls back to default.tsx
//                 (green), the route survives and renders.
//
// VISUAL THROUGH-LINE: this is the second sequence in the lesson, so it reuses
// the SAME browser-window + two-pane vocabulary as 029/5 url-to-slot-mapping
// (chrome bar with traffic lights + URL pill, two panes with slot pills and
// file footers). Same fixed slate palette, `color-scheme: light` pinned so the
// hand-picked tints survive dark mode, `margin: 0` everywhere to defeat
// Starlight's injected prose margin-top, mono for file/URL labels. Slot accents
// match the sibling: sky = children/list, violet = detail. New here: a STATE
// colour layered on each pane's status chip + footer tick — green = matched/
// filled, red = unmatched (the failure). The slot identity colour and the
// match-state colour are kept separate so "this is the detail slot" and "the
// detail slot has no match" read as two different facts.
//
// HEIGHT STABILITY: the DiagramSequence grid stack sizes to the tallest step.
// Step 3 carries the inner TabbedContent (extra tab strip + card chrome) so it
// is the tallest; steps 1–2 sit at the top of that cell. Every browser box
// across all steps/panels shares the same width and the same fixed pane height,
// so no individual stage reflows as the reader scrubs or switches tabs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';
import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette (fixed — color-scheme pinned light so these survive dark mode).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const FAINT = '#94a3b8'; // slate-400 — placeholder / faint text
const HAIRLINE = '#e2e8f0'; // slate-200 — borders
const SURFACE = '#ffffff'; // pane surface
const CHROME = '#f1f5f9'; // slate-100 — browser chrome / pane header strip

// Slot identity accents — match the sibling url-to-slot-mapping sequence.
const KIDS = '#0ea5e9'; // sky-500 — children / list slot
const KIDS_WASH = '#f0f9ff'; // sky-50
const DETAIL = '#7c3aed'; // violet-600 — detail slot
const DETAIL_WASH = '#f5f3ff'; // violet-50

// Match-state accents — layered on the status chip + footer, separate from slot
// identity so "which slot" and "matched / unmatched" never collide on one hue.
const OK = '#059669'; // emerald-600 — matched / filled
const OK_WASH = '#ecfdf5'; // emerald-50
const BAD = '#dc2626'; // red-600 — unmatched (the failure)
const BAD_WASH = '#fef2f2'; // red-50

// ---- shared geometry ----------------------------------------------------------
const VIEWPORT_W = 540; // browser box content width (panes + gap live inside)
const PANE_H = 132; // fixed inner height every pane reserves

// Outer stage shared by every step/panel: pinned light, centered, constant shape.
const stage = `display: flex; justify-content: center; margin: 0; padding: 2px 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The mock browser window: chrome bar (URL) over the two-pane body.
const browser = [
	'box-sizing: border-box',
	`width: min(100%, ${VIEWPORT_W}px)`,
	'margin: 0',
	'border-radius: 12px',
	`border: 1px solid ${HAIRLINE}`,
	'overflow: hidden',
	`background: ${SURFACE}`,
	'box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08)',
].join('; ');

// Browser chrome strip: traffic-light dots, nav-mode chip, URL bar.
const chromeBar = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'gap: 10px',
	'margin: 0',
	'padding: 9px 12px',
	`background: ${CHROME}`,
	`border-bottom: 1px solid ${HAIRLINE}`,
].join('; ');

const dots = 'display: flex; gap: 5px; flex: 0 0 auto; margin: 0;';
const dot = (c: string) => `display: block; width: 9px; height: 9px; margin: 0; border-radius: 999px; background: ${c};`;

// The nav-mode chip that sits in the chrome — "soft nav (Link click)" etc.
const navChip = (accent: string, wash: string) =>
	[
		'display: inline-flex',
		'align-items: center',
		'gap: 5px',
		'flex: 0 0 auto',
		'box-sizing: border-box',
		'margin: 0',
		'padding: 3px 8px',
		'border-radius: 999px',
		`border: 1px solid ${accent}`,
		`background: ${wash}`,
		`font-family: ${sans}`,
		'font-size: 10.5px',
		'font-weight: 700',
		'letter-spacing: 0.01em',
		`color: ${accent}`,
		'white-space: nowrap',
	].join('; ');

// The address bar pill. Segments inside it are individually coloured.
const urlBar = [
	'box-sizing: border-box',
	'flex: 1 1 auto',
	'min-width: 0',
	'margin: 0',
	'padding: 4px 11px',
	'border-radius: 6px',
	`border: 1px solid ${HAIRLINE}`,
	`background: ${SURFACE}`,
	`font-family: ${mono}`,
	'font-size: 12.5px',
	'line-height: 1.4',
	`color: ${INK_SOFT}`,
	'white-space: nowrap',
	'overflow: hidden',
	'text-overflow: ellipsis',
].join('; ');
const urlBase = `color: ${INK_SOFT};`;
const urlSeg = (accent: string, wash: string) =>
	`color: ${accent}; font-weight: 700; background: ${wash}; border-radius: 4px; padding: 1px 4px; margin: 0 -1px;`;

// The two-pane body. Identical column template everywhere.
const paneBody = [
	'box-sizing: border-box',
	'display: grid',
	'grid-template-columns: 1fr 1.45fr',
	'gap: 12px',
	'margin: 0',
	'padding: 14px',
].join('; ');

// One pane (a column). The whole pane is tinted by match-state (ok/bad) — a
// faint wash + a coloured border — so a failing slot reads at a glance.
const pane = (state: 'ok' | 'bad') => {
	const accent = state === 'bad' ? BAD : HAIRLINE;
	const bg = state === 'bad' ? BAD_WASH : SURFACE;
	return [
		'box-sizing: border-box',
		'display: flex',
		'flex-direction: column',
		'margin: 0',
		'border-radius: 10px',
		`border: 1px solid ${accent}`,
		`background: ${bg}`,
		'overflow: hidden',
	].join('; ');
};

// Pane header: slot identity pill (children/detail) + a match-state status chip.
const paneHead = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 8px',
	'margin: 0',
	'padding: 7px 9px',
	`background: ${CHROME}`,
	`border-bottom: 1px solid ${HAIRLINE}`,
].join('; ');

const slotPill = (accent: string) =>
	[
		'display: inline-block',
		'box-sizing: border-box',
		'margin: 0',
		'padding: 2px 8px',
		'border-radius: 5px',
		`font-family: ${mono}`,
		'font-size: 11px',
		'font-weight: 700',
		'line-height: 1.3',
		'color: #ffffff',
		`background: ${accent}`,
	].join('; ');

// Status chip on the right of the header: "kept", "re-resolved", "match",
// "no match", "default.tsx". Coloured by match-state.
const statusChip = (state: 'ok' | 'bad') => {
	const accent = state === 'bad' ? BAD : OK;
	const wash = state === 'bad' ? BAD_WASH : OK_WASH;
	return [
		'display: inline-flex',
		'align-items: center',
		'gap: 4px',
		'box-sizing: border-box',
		'margin: 0',
		'padding: 2px 7px',
		'border-radius: 999px',
		`border: 1px solid ${accent}`,
		`background: ${wash}`,
		`font-family: ${sans}`,
		'font-size: 10px',
		'font-weight: 700',
		'letter-spacing: 0.02em',
		`color: ${accent}`,
		'white-space: nowrap',
	].join('; ');
};

// Pane content area — fixed height so the box never resizes.
const paneContent = [
	'box-sizing: border-box',
	`height: ${PANE_H}px`,
	'margin: 0',
	'padding: 10px',
	'overflow: hidden',
].join('; ');

// File footer: the file (or non-file message) that filled this pane.
const fileFoot = (state: 'ok' | 'bad', slotAccent: string, slotWash: string) => {
	// Matched footers wear the slot's identity colour (as in the sibling
	// sequence). The unmatched footer goes red — it isn't filled by any file.
	const accent = state === 'bad' ? BAD : slotAccent;
	const wash = state === 'bad' ? BAD_WASH : slotWash;
	return [
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'gap: 6px',
		'margin: 0',
		'padding: 6px 9px',
		`border-top: 1px solid ${HAIRLINE}`,
		`background: ${wash}`,
		`font-family: ${mono}`,
		'font-size: 11px',
		'font-weight: 600',
		'line-height: 1.3',
		`color: ${accent}`,
		'white-space: nowrap',
		'overflow: hidden',
		'text-overflow: ellipsis',
	].join('; ');
};

// ---- list-pane rows (the children/list content, identical everywhere) ---------
const ROWS = [
	{ id: 'INV-041', amount: '$1,200', n: 41 },
	{ id: 'INV-042', amount: '$3,480', n: 42 },
	{ id: 'INV-043', amount: '$760', n: 43 },
];
const listWrap = 'display: flex; flex-direction: column; gap: 7px; margin: 0;';
function rowStyle(active: boolean) {
	return [
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'justify-content: space-between',
		'gap: 8px',
		'margin: 0',
		'padding: 7px 10px',
		'border-radius: 7px',
		`border: 1px solid ${active ? KIDS : HAIRLINE}`,
		`background: ${active ? KIDS_WASH : '#f8fafc'}`,
		`box-shadow: ${active ? `inset 2px 0 0 ${KIDS}` : 'none'}`,
	].join('; ');
}
const rowId = (active: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 11.5px; font-weight: ${active ? 700 : 600}; color: ${active ? '#075985' : INK};`;
const rowAmount = (active: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 11px; color: ${active ? '#0369a1' : INK_SOFT};`;

// ---- detail-pane: the invoice card (matched detail) ---------------------------
const card = [
	'box-sizing: border-box',
	'height: 100%',
	'display: flex',
	'flex-direction: column',
	'gap: 8px',
	'margin: 0',
	'padding: 11px',
	'border-radius: 8px',
	`border: 1px solid ${DETAIL}`,
	`background: ${DETAIL_WASH}`,
].join('; ');
const cardTop = 'display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin: 0;';
const cardTitle = `margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 700; color: #5b21b6;`;
const cardBadge = `margin: 0; padding: 1px 7px; border-radius: 999px; font-family: ${sans}; font-size: 9.5px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #ffffff; background: ${DETAIL};`;
const cardAmount = `margin: 0; font-family: ${sans}; font-size: 20px; font-weight: 800; line-height: 1.1; color: ${INK};`;
const cardMeta = (w: string) => `display: block; width: ${w}; height: 7px; margin: 0; border-radius: 3px; background: color-mix(in srgb, ${DETAIL} 22%, #ffffff);`;

// ---- detail-pane: the unmatched state (step 3, "without default") -------------
const noMatchBox = [
	'box-sizing: border-box',
	'height: 100%',
	'display: flex',
	'flex-direction: column',
	'align-items: center',
	'justify-content: center',
	'gap: 8px',
	'margin: 0',
	'border-radius: 8px',
	`border: 1px dashed ${BAD}`,
	`background: ${BAD_WASH}`,
	'text-align: center',
].join('; ');
const noMatchGlyph = `display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; margin: 0; border-radius: 999px; background: ${BAD}; color: #ffffff; font-size: 15px; font-weight: 800; line-height: 1;`;
const noMatchText = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 700; color: ${BAD};`;
const noMatchSub = `margin: 0; font-family: ${mono}; font-size: 10.5px; color: #b91c1c;`;

// ---- detail-pane: the default.tsx fallback (step 3, "with default") -----------
const defaultBox = [
	'box-sizing: border-box',
	'height: 100%',
	'display: flex',
	'flex-direction: column',
	'align-items: center',
	'justify-content: center',
	'gap: 8px',
	'margin: 0',
	'border-radius: 8px',
	`border: 1px dashed ${OK}`,
	`background: ${OK_WASH}`,
	'text-align: center',
].join('; ');
const defaultGlyph = `display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; margin: 0; border-radius: 7px; background: ${OK}; color: #ffffff; font-size: 13px; font-weight: 800; line-height: 1;`;
const defaultText = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 700; color: #047857;`;
const defaultSub = `margin: 0; font-family: ${mono}; font-size: 10.5px; color: #047857;`;

// ---- the 404 banner across the whole box (step 3, "without default") ----------
const banner = (state: 'bad' | 'ok') => {
	const accent = state === 'bad' ? BAD : OK;
	const wash = state === 'bad' ? BAD_WASH : OK_WASH;
	return [
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'justify-content: center',
		'gap: 7px',
		'margin: 0',
		'padding: 8px 12px',
		`border-top: 1px solid ${accent}`,
		`background: ${wash}`,
		`font-family: ${sans}`,
		'font-size: 11.5px',
		'font-weight: 700',
		`color: ${accent}`,
		'text-align: center',
	].join('; ');
};
const bannerCode = `font-family: ${mono}; font-weight: 700;`;
---

<DiagramSequence>
	{/* ============================ STEP 1 — soft nav ======================== */}
	<DiagramStep caption="Soft navigation remembers the other slots. Clicking a row swaps only the detail slot; children's match did not change, so the router keeps it. Both slots stay filled — and this happy path is exactly what hides the bug.">
		<div style={stage}>
			<div style={browser}>
				<div style={chromeBar}>
					<div style={dots} aria-hidden="true">
						<span style={dot('#f87171')} />
						<span style={dot('#fbbf24')} />
						<span style={dot('#34d399')} />
					</div>
					<span style={navChip(KIDS, KIDS_WASH)}>soft nav · Link click</span>
					<div style={urlBar}>
						<span style={urlBase}>app.example.com</span>
						<span style={urlSeg(KIDS, KIDS_WASH)}>/invoices</span>
						<span style={urlSeg(DETAIL, DETAIL_WASH)}>/42</span>
					</div>
				</div>

				<div style={paneBody}>
					{/* children — KEPT */}
					<div style={pane('ok')}>
						<div style={paneHead}>
							<span style={slotPill(KIDS)}>children</span>
							<span style={statusChip('ok')}>kept</span>
						</div>
						<div style={paneContent}>
							<div style={listWrap}>
								{ROWS.map((r) => {
									const active = r.n === 42;
									return (
										<div style={rowStyle(active)}>
											<span style={rowId(active)}>{r.id}</span>
											<span style={rowAmount(active)}>{r.amount}</span>
										</div>
									);
								})}
							</div>
						</div>
						<div style={fileFoot('ok', KIDS, KIDS_WASH)}>
							<span style={`flex: 0 0 auto; margin: 0; color: ${OK};`} aria-hidden="true">✓</span>
							<span style="margin: 0;">page.tsx</span>
						</div>
					</div>

					{/* detail — RE-RESOLVED */}
					<div style={pane('ok')}>
						<div style={paneHead}>
							<span style={slotPill(DETAIL)}>detail</span>
							<span style={statusChip('ok')}>re-resolved</span>
						</div>
						<div style={paneContent}>
							<div style={card}>
								<div style={cardTop}>
									<span style={cardTitle}>INV-042</span>
									<span style={cardBadge}>Paid</span>
								</div>
								<span style={cardAmount}>$3,480.00</span>
								<span style={cardMeta('72%')} aria-hidden="true" />
								<span style={cardMeta('54%')} aria-hidden="true" />
							</div>
						</div>
						<div style={fileFoot('ok', DETAIL, DETAIL_WASH)}>
							<span style={`flex: 0 0 auto; margin: 0; color: ${OK};`} aria-hidden="true">✓</span>
							<span style="margin: 0;">@detail/[id]/page.tsx</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ============================ STEP 2 — hard nav, both match ============= */}
	<DiagramStep caption="On a hard load — a refresh, a direct visit, a new tab — there is no previous match to keep, so every slot is resolved from the URL alone. Here both slots still have a matching route, so both fill and no fallback is needed.">
		<div style={stage}>
			<div style={browser}>
				<div style={chromeBar}>
					<div style={dots} aria-hidden="true">
						<span style={dot('#f87171')} />
						<span style={dot('#fbbf24')} />
						<span style={dot('#34d399')} />
					</div>
					<span style={navChip(INK_SOFT, CHROME)}>
						<span style="margin: 0; font-size: 12px;" aria-hidden="true">↻</span>
						hard nav · refresh
					</span>
					<div style={urlBar}>
						<span style={urlBase}>app.example.com</span>
						<span style={urlSeg(KIDS, KIDS_WASH)}>/invoices</span>
						<span style={urlSeg(DETAIL, DETAIL_WASH)}>/42</span>
					</div>
				</div>

				<div style={paneBody}>
					{/* children — matches */}
					<div style={pane('ok')}>
						<div style={paneHead}>
							<span style={slotPill(KIDS)}>children</span>
							<span style={statusChip('ok')}>match</span>
						</div>
						<div style={paneContent}>
							<div style={listWrap}>
								{ROWS.map((r) => {
									const active = r.n === 42;
									return (
										<div style={rowStyle(active)}>
											<span style={rowId(active)}>{r.id}</span>
											<span style={rowAmount(active)}>{r.amount}</span>
										</div>
									);
								})}
							</div>
						</div>
						<div style={fileFoot('ok', KIDS, KIDS_WASH)}>
							<span style={`flex: 0 0 auto; margin: 0; color: ${OK};`} aria-hidden="true">✓</span>
							<span style="margin: 0;">page.tsx</span>
						</div>
					</div>

					{/* detail — matches */}
					<div style={pane('ok')}>
						<div style={paneHead}>
							<span style={slotPill(DETAIL)}>detail</span>
							<span style={statusChip('ok')}>match</span>
						</div>
						<div style={paneContent}>
							<div style={card}>
								<div style={cardTop}>
									<span style={cardTitle}>INV-042</span>
									<span style={cardBadge}>Paid</span>
								</div>
								<span style={cardAmount}>$3,480.00</span>
								<span style={cardMeta('72%')} aria-hidden="true" />
								<span style={cardMeta('54%')} aria-hidden="true" />
							</div>
						</div>
						<div style={fileFoot('ok', DETAIL, DETAIL_WASH)}>
							<span style={`flex: 0 0 auto; margin: 0; color: ${OK};`} aria-hidden="true">✓</span>
							<span style="margin: 0;">@detail/[id]/page.tsx</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ============================ STEP 3 — the unmatched slot ============== */}
	<DiagramStep>
		<TabbedContent>
			{/* -------- Without default.tsx — the whole route 404s ---------- */}
			<TabbedItem label="Without default.tsx">
				<div style={stage}>
					<div style={browser}>
						<div style={chromeBar}>
							<div style={dots} aria-hidden="true">
								<span style={dot('#f87171')} />
								<span style={dot('#fbbf24')} />
								<span style={dot('#34d399')} />
							</div>
							<span style={navChip(BAD, BAD_WASH)}>hard nav · shared link</span>
							<div style={urlBar}>
								<span style={urlBase}>app.example.com</span>
								<span style={urlSeg(KIDS, KIDS_WASH)}>/invoices/42/edit</span>
							</div>
						</div>

						<div style={paneBody}>
							{/* children — matches the deeper [id]/edit route */}
							<div style={pane('ok')}>
								<div style={paneHead}>
									<span style={slotPill(KIDS)}>children</span>
									<span style={statusChip('ok')}>matches</span>
								</div>
								<div style={paneContent}>
									<div style={listWrap}>
										{ROWS.map((r) => {
											const active = r.n === 42;
											return (
												<div style={rowStyle(active)}>
													<span style={rowId(active)}>{r.id}</span>
													<span style={rowAmount(active)}>{r.amount}</span>
												</div>
											);
										})}
									</div>
								</div>
								<div style={fileFoot('ok', KIDS, KIDS_WASH)}>
									<span style={`flex: 0 0 auto; margin: 0; color: ${OK};`} aria-hidden="true">✓</span>
									<span style="margin: 0;">[id]/edit/page.tsx</span>
								</div>
							</div>

							{/* detail — NO match, and no fallback */}
							<div style={pane('bad')}>
								<div style={paneHead}>
									<span style={slotPill(DETAIL)}>detail</span>
									<span style={statusChip('bad')}>no match</span>
								</div>
								<div style={paneContent}>
									<div style={noMatchBox}>
										<span style={noMatchGlyph} aria-hidden="true">!</span>
										<span style={noMatchText}>No route for this URL</span>
										<span style={noMatchSub}>and no default.tsx</span>
									</div>
								</div>
								<div style={fileFoot('bad', DETAIL, DETAIL_WASH)}>
									<span style="flex: 0 0 auto; margin: 0;" aria-hidden="true">✕</span>
									<span style="margin: 0;">nothing to render</span>
								</div>
							</div>
						</div>

						{/* The failure spans the WHOLE box — not just the empty slot. */}
						<div style={banner('bad')}>
							<span style={bannerCode}>404</span>
							<span style="margin: 0;">no fallback → the entire route 404s</span>
						</div>
					</div>
				</div>
			</TabbedItem>

			{/* -------- With default.tsx — the route survives ---------------- */}
			<TabbedItem label="With default.tsx">
				<div style={stage}>
					<div style={browser}>
						<div style={chromeBar}>
							<div style={dots} aria-hidden="true">
								<span style={dot('#f87171')} />
								<span style={dot('#fbbf24')} />
								<span style={dot('#34d399')} />
							</div>
							<span style={navChip(OK, OK_WASH)}>hard nav · shared link</span>
							<div style={urlBar}>
								<span style={urlBase}>app.example.com</span>
								<span style={urlSeg(KIDS, KIDS_WASH)}>/invoices/42/edit</span>
							</div>
						</div>

						<div style={paneBody}>
							{/* children — matches the deeper [id]/edit route */}
							<div style={pane('ok')}>
								<div style={paneHead}>
									<span style={slotPill(KIDS)}>children</span>
									<span style={statusChip('ok')}>matches</span>
								</div>
								<div style={paneContent}>
									<div style={listWrap}>
										{ROWS.map((r) => {
											const active = r.n === 42;
											return (
												<div style={rowStyle(active)}>
													<span style={rowId(active)}>{r.id}</span>
													<span style={rowAmount(active)}>{r.amount}</span>
												</div>
											);
										})}
									</div>
								</div>
								<div style={fileFoot('ok', KIDS, KIDS_WASH)}>
									<span style={`flex: 0 0 auto; margin: 0; color: ${OK};`} aria-hidden="true">✓</span>
									<span style="margin: 0;">[id]/edit/page.tsx</span>
								</div>
							</div>

							{/* detail — no route match, but default.tsx fills it */}
							<div style={pane('ok')}>
								<div style={paneHead}>
									<span style={slotPill(DETAIL)}>detail</span>
									<span style={statusChip('ok')}>fallback</span>
								</div>
								<div style={paneContent}>
									<div style={defaultBox}>
										<span style={defaultGlyph} aria-hidden="true">↩</span>
										<span style={defaultText}>Falls back to the slot default</span>
										<span style={defaultSub}>Select an invoice</span>
									</div>
								</div>
								<div style={fileFoot('ok', DETAIL, DETAIL_WASH)}>
									<span style={`flex: 0 0 auto; margin: 0; color: ${OK};`} aria-hidden="true">✓</span>
									<span style="margin: 0;">@detail/default.tsx</span>
								</div>
							</div>
						</div>

						{/* The route survives and renders. */}
						<div style={banner('ok')}>
							<span style={bannerCode} aria-hidden="true">200</span>
							<span style="margin: 0;">fallback rendered → the route survives</span>
						</div>
					</div>
				</div>
			</TabbedItem>
		</TabbedContent>

		<Fragment slot="caption">
			<p>
				<code>default.tsx</code> is the difference between a shareable URL and a 404. On a hard load to a path the <strong>detail</strong>{' '}
				slot can't match, a missing fallback 404s the <strong>whole</strong> route — switch the tab to add one <code>default.tsx</code> and
				the slot falls back, the route survives.
			</p>
		</Fragment>
	</DiagramStep>
</DiagramSequence>
