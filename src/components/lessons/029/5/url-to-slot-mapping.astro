---
// url-to-slot-mapping (Chapter 029 L5). A two-step scrubbable DiagramSequence that
// makes the URL -> slot mapping concrete: one URL resolves TWO independent route
// trees at once, and the left "list" pane (children) stays byte-for-byte identical
// while only the right "detail" pane swaps.
//
//   Step A  /invoices       children <- page.tsx (the list)
//                           detail   <- @detail/page.tsx (the empty placeholder)
//   Step B  /invoices/42    children <- page.tsx (the list, UNCHANGED)
//                           detail   <- @detail/[id]/page.tsx  (params.id = '42')
//
// HEIGHT/WIDTH STABILITY (the DiagramSequence grid stack sizes to the tallest step
// and must not reflow as the reader scrubs): both steps render the SAME browser
// viewport box, the SAME two panes at the SAME widths, and the SAME three list rows
// with the SAME label under the left pane. Only two things change between steps —
// the URL bar's trailing segment, and the right (detail) pane's content + its file
// label. The detail pane reserves a fixed height in both steps so the placeholder
// and the invoice card occupy identical pixels; nothing in flow resizes, so the
// stage never jumps.
//
// House style follows this chapter-cluster's hand-styled figures (nesting-dolls,
// children-injection): fixed slate palette, `color-scheme: light` pinned so the
// hand-picked tints survive dark mode, `margin: 0` on every node to defeat
// Starlight's injected prose margin-top, mono for file/URL labels. Accents map a
// slot to one colour the whole chain wears: sky = children/list, violet = detail.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette (fixed — color-scheme pinned light so these survive dark mode).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const FAINT = '#94a3b8'; // slate-400 — placeholder / faint text
const HAIRLINE = '#e2e8f0'; // slate-200 — borders
const SURFACE = '#ffffff'; // pane surface
const CHROME = '#f1f5f9'; // slate-100 — browser chrome / pane header strip
const ROW_BG = '#f8fafc'; // slate-50 — resting list-row fill

// Each slot owns one accent: the pill, the active highlight, the file label share it.
const KIDS = '#0ea5e9'; // sky-500 — children / list slot
const KIDS_WASH = '#f0f9ff'; // sky-50
const DETAIL = '#7c3aed'; // violet-600 — detail slot
const DETAIL_WASH = '#f5f3ff'; // violet-50

// ---- shared geometry ----------------------------------------------------------
const VIEWPORT_W = 540; // browser box content width (panes + gap live inside)
const PANE_H = 168; // fixed inner height every pane reserves, both steps

// Outer stage shared by every step: pinned light, centered, constant shape.
const stage = `display: flex; justify-content: center; margin: 0; padding: 2px 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The mock browser window: chrome bar (URL) over the two-pane body.
const browser = [
	'box-sizing: border-box',
	`width: min(100%, ${VIEWPORT_W}px)`,
	'margin: 0',
	'border-radius: 12px',
	`border: 1px solid ${HAIRLINE}`,
	'overflow: hidden',
	`background: ${SURFACE}`,
	'box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08)',
].join('; ');

// The browser chrome strip holding the traffic-light dots and the URL bar.
const chromeBar = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'gap: 10px',
	'margin: 0',
	'padding: 9px 12px',
	`background: ${CHROME}`,
	`border-bottom: 1px solid ${HAIRLINE}`,
].join('; ');

const dots = 'display: flex; gap: 5px; flex: 0 0 auto; margin: 0;';
const dot = (c: string) => `display: block; width: 9px; height: 9px; margin: 0; border-radius: 999px; background: ${c};`;

// The address bar pill. Segments inside it are individually coloured.
const urlBar = [
	'box-sizing: border-box',
	'flex: 1 1 auto',
	'min-width: 0',
	'margin: 0',
	'padding: 4px 11px',
	'border-radius: 6px',
	`border: 1px solid ${HAIRLINE}`,
	`background: ${SURFACE}`,
	`font-family: ${mono}`,
	'font-size: 12.5px',
	'line-height: 1.4',
	`color: ${INK_SOFT}`,
	'white-space: nowrap',
	'overflow: hidden',
	'text-overflow: ellipsis',
].join('; ');
const urlBase = `color: ${INK_SOFT};`;
const urlSeg = (accent: string, wash: string) =>
	`color: ${accent}; font-weight: 700; background: ${wash}; border-radius: 4px; padding: 1px 4px; margin: 0 -1px;`;

// The two-pane body. Identical column template in both steps.
const paneBody = [
	'box-sizing: border-box',
	'display: grid',
	'grid-template-columns: 1fr 1.45fr',
	'gap: 12px',
	'margin: 0',
	'padding: 14px',
].join('; ');

// One pane (a column). `accent`/`wash` tint its header pill; the box itself is neutral.
const pane = [
	'box-sizing: border-box',
	'display: flex',
	'flex-direction: column',
	'margin: 0',
	'border-radius: 10px',
	`border: 1px solid ${HAIRLINE}`,
	`background: ${SURFACE}`,
	'overflow: hidden',
].join('; ');

// Pane header: the slot pill (children/detail) on the left, role label on the right.
const paneHead = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 8px',
	'margin: 0',
	'padding: 7px 9px',
	`background: ${CHROME}`,
	`border-bottom: 1px solid ${HAIRLINE}`,
].join('; ');

const slotPill = (accent: string) =>
	[
		'display: inline-block',
		'box-sizing: border-box',
		'margin: 0',
		'padding: 2px 8px',
		'border-radius: 5px',
		`font-family: ${mono}`,
		'font-size: 11px',
		'font-weight: 700',
		'line-height: 1.3',
		'color: #ffffff',
		`background: ${accent}`,
	].join('; ');

const roleLabel = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; color: ${FAINT};`;

// Pane content area — fixed height in BOTH steps so the box never resizes.
const paneContent = (extra = '') =>
	[
		'box-sizing: border-box',
		`height: ${PANE_H}px`,
		'margin: 0',
		'padding: 10px',
		'overflow: hidden',
		extra,
	].join('; ');

// File label footer: the file that filled this pane, in mono, tinted by slot.
const fileFoot = (accent: string, wash: string) =>
	[
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'gap: 6px',
		'margin: 0',
		'padding: 6px 9px',
		`border-top: 1px solid ${HAIRLINE}`,
		`background: ${wash}`,
		`font-family: ${mono}`,
		'font-size: 11px',
		'font-weight: 600',
		'line-height: 1.3',
		`color: ${accent}`,
		'white-space: nowrap',
		'overflow: hidden',
		'text-overflow: ellipsis',
	].join('; ');
const fileTick = (accent: string) => `flex: 0 0 auto; margin: 0; font-size: 10px; color: ${accent};`;

// ---- list-pane rows (identical in both steps) ---------------------------------
// Each invoice row: an id + an amount. Resting vs active styling toggles only the
// active row in step B; geometry is identical so the list never reflows.
const ROWS = [
	{ id: 'INV-041', amount: '$1,200', n: 41 },
	{ id: 'INV-042', amount: '$3,480', n: 42 },
	{ id: 'INV-043', amount: '$760', n: 43 },
];

const listWrap = 'display: flex; flex-direction: column; gap: 7px; margin: 0;';
function rowStyle(active: boolean) {
	return [
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'justify-content: space-between',
		'gap: 8px',
		'margin: 0',
		'padding: 8px 10px',
		'border-radius: 7px',
		`border: 1px solid ${active ? KIDS : HAIRLINE}`,
		`background: ${active ? KIDS_WASH : ROW_BG}`,
		`box-shadow: ${active ? `inset 2px 0 0 ${KIDS}` : 'none'}`,
	].join('; ');
}
const rowId = (active: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 12px; font-weight: ${active ? 700 : 600}; color: ${active ? '#075985' : INK};`;
const rowAmount = (active: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 11.5px; color: ${active ? '#0369a1' : INK_SOFT};`;

// ---- detail-pane: placeholder (step A) ----------------------------------------
const placeholder = [
	'box-sizing: border-box',
	'height: 100%',
	'display: flex',
	'flex-direction: column',
	'align-items: center',
	'justify-content: center',
	'gap: 8px',
	'margin: 0',
	'border-radius: 8px',
	`border: 1px dashed ${HAIRLINE}`,
	'text-align: center',
].join('; ');
const placeholderIcon = `display: block; width: 30px; height: 30px; margin: 0; border-radius: 8px; background: ${CHROME}; border: 1px solid ${HAIRLINE};`;
const placeholderText = `margin: 0; font-family: ${sans}; font-size: 12.5px; color: ${FAINT};`;

// ---- detail-pane: the invoice card (step B) -----------------------------------
const card = [
	'box-sizing: border-box',
	'height: 100%',
	'display: flex',
	'flex-direction: column',
	'gap: 9px',
	'margin: 0',
	'padding: 12px',
	'border-radius: 8px',
	`border: 1px solid ${DETAIL}`,
	`background: ${DETAIL_WASH}`,
].join('; ');
const cardTop = 'display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin: 0;';
const cardTitle = `margin: 0; font-family: ${mono}; font-size: 14px; font-weight: 700; color: #5b21b6;`;
const cardBadge = `margin: 0; padding: 1px 7px; border-radius: 999px; font-family: ${sans}; font-size: 10px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: #ffffff; background: ${DETAIL};`;
const cardAmount = `margin: 0; font-family: ${sans}; font-size: 22px; font-weight: 800; line-height: 1.1; color: ${INK};`;
const cardMeta = (w: string) => `display: block; width: ${w}; height: 7px; margin: 0; border-radius: 3px; background: color-mix(in srgb, ${DETAIL} 22%, #ffffff);`;
const paramTag = `margin: 0; font-family: ${mono}; font-size: 11px; color: #6d28d9;`;

const STEPS = ['A', 'B'] as const;
---

<DiagramSequence>
	{
		STEPS.map((which) => {
			const isB = which === 'B';
			const caption = isB
				? 'URL /invoices/42 — children is STILL page.tsx (the list, byte-for-byte unchanged, so it stays mounted), while detail is now filled by @detail/[id]/page.tsx with params.id = "42". Only the right pane swapped.'
				: 'URL /invoices — children is filled by page.tsx (the list), and detail is filled by @detail/page.tsx (the empty placeholder). Two route trees, one URL.';

			return (
				<DiagramStep caption={caption}>
					<div style={stage}>
						<div style={browser}>
							{/* ---- browser chrome: traffic lights + URL bar ---- */}
							<div style={chromeBar}>
								<div style={dots} aria-hidden="true">
									<span style={dot('#f87171')} />
									<span style={dot('#fbbf24')} />
									<span style={dot('#34d399')} />
								</div>
								<div style={urlBar}>
									<span style={urlBase}>app.example.com</span>
									<span style={urlSeg(KIDS, KIDS_WASH)}>/invoices</span>
									{isB && <span style={urlSeg(DETAIL, DETAIL_WASH)}>/42</span>}
								</div>
							</div>

							{/* ---- two-pane body ---- */}
							<div style={paneBody}>
								{/* LEFT — children / the list (identical in both steps) */}
								<div style={pane}>
									<div style={paneHead}>
										<span style={slotPill(KIDS)}>children</span>
										<span style={roleLabel}>list</span>
									</div>
									<div style={paneContent()}>
										<div style={listWrap}>
											{ROWS.map((r) => {
												const active = isB && r.n === 42;
												return (
													<div style={rowStyle(active)}>
														<span style={rowId(active)}>{r.id}</span>
														<span style={rowAmount(active)}>{r.amount}</span>
													</div>
												);
											})}
										</div>
									</div>
									<div style={fileFoot(KIDS, KIDS_WASH)}>
										<span style={fileTick(KIDS)} aria-hidden="true">●</span>
										<span style="margin: 0;">src/app/invoices/page.tsx</span>
									</div>
								</div>

								{/* RIGHT — detail (the slot that swaps) */}
								<div style={pane}>
									<div style={paneHead}>
										<span style={slotPill(DETAIL)}>detail</span>
										<span style={roleLabel}>{isB ? 'invoice 42' : 'empty'}</span>
									</div>
									<div style={paneContent()}>
										{isB ? (
											<div style={card}>
												<div style={cardTop}>
													<span style={cardTitle}>INV-042</span>
													<span style={cardBadge}>Paid</span>
												</div>
												<span style={cardAmount}>$3,480.00</span>
												<span style={cardMeta('72%')} aria-hidden="true" />
												<span style={cardMeta('54%')} aria-hidden="true" />
												<span style={paramTag}>params.id = "42"</span>
											</div>
										) : (
											<div style={placeholder}>
												<span style={placeholderIcon} aria-hidden="true" />
												<span style={placeholderText}>Select an invoice</span>
											</div>
										)}
									</div>
									<div style={fileFoot(DETAIL, DETAIL_WASH)}>
										<span style={fileTick(DETAIL)} aria-hidden="true">●</span>
										<span style="margin: 0;">{isB ? '@detail/[id]/page.tsx' : '@detail/page.tsx'}</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>
