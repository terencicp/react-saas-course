---
// app-tree-to-urls — the anchor diagram of Lesson 29.1.
//
// Makes the folder-path → URL function visually literal. Two columns:
//   LEFT   a Starlight <FileTree> of the src/app/ tree, with the three
//          page.tsx leaves bolded (FileTree's .highlight style) and each
//          carrying a small numbered badge in its comment slot.
//   RIGHT  a "function table": one row per page.tsx, reading
//          `app/.../page.tsx  →  /url`, the URL accent-tinted. The same
//          numbered badge on each row ties it back to the matching leaf on
//          the left, so the correspondence survives even though a real
//          FileTree's row heights don't line up pixel-for-pixel.
//
// The shared signal is the index number + the accent: a page.tsx is the only
// thing on the left that is bolded, and the URL is the only thing on the right
// that is tinted. Read it as: feed in a folder path ending in page.tsx, read
// out a URL.
//
// Pure HTML + CSS (plus the FileTree component). `not-content` wrapper and a
// `margin: 0` reset on every inner element defeat Starlight's prose-margin
// selector; theme gray/accent variables keep it native in both light and dark.

import { FileTree } from "@astrojs/starlight/components";

const reset = "margin: 0";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const root = [
  reset,
  "display: grid",
  // Left tree sizes to its content; right table takes the rest.
  // Tree sizes to its content; the function table gets a comfortable, capped
  // share so its rows don't stretch too wide on desktop.
  "grid-template-columns: max-content minmax(260px, 1fr)",
  "align-items: center",
  "column-gap: clamp(16px, 3vw, 36px)",
  "row-gap: 16px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// A small circular index badge, shared by both columns.
const badge = (n: number) =>
  [
    reset,
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "flex: 0 0 auto",
    "width: 17px",
    "height: 17px",
    "border-radius: 999px",
    "background: var(--sl-color-text-accent)",
    "color: var(--sl-color-text-invert)",
    "font-size: 10.5px",
    "font-weight: 700",
    sans,
    "line-height: 1",
  ].join("; ");

// Right column wrapper: the three function rows, stacked.
const table = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "min-width: 0",
].join("; ");

// Each row is a two-line block: line 1 the file path (with its badge),
// line 2 the URL it produces — so the row literally reads top-to-bottom as
// "this file → this URL", and every row keeps a uniform height regardless of
// path length (no ragged wrapping).
const row = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 6px",
  "padding: 10px 12px",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 9px",
  "background: var(--sl-color-gray-6)",
  "min-width: 0",
].join("; ");

// Line 1 of a row: badge + file path.
const rowTop = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 9px",
  "min-width: 0",
].join("; ");

// Line 2 of a row: the URL, indented to align under the path (past the badge).
const rowBottom = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 8px",
  "padding-left: 26px",
  "min-width: 0",
].join("; ");

// The file path on the left of each row. The page.tsx piece is accent-tinted
// to echo the bold leaf on the left tree.
const pathText = [
  reset,
  mono,
  "font-size: 13px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
  "white-space: nowrap",
].join("; ");
const pageFile = "color: var(--sl-color-white); font-weight: 700";

// The arrow between path and URL.
const arrow = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 700",
  "color: var(--sl-color-gray-3)",
  "flex: 0 0 auto",
].join("; ");

// The resulting URL — the accented payload of the row.
const url = [
  reset,
  mono,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "padding: 2px 8px",
  "border-radius: 6px",
  "color: var(--sl-color-text-accent)",
  "background: color-mix(in srgb, var(--sl-color-text-accent) 12%, transparent)",
  "white-space: nowrap",
].join("; ");

// "renders at" connective above each URL, so a row reads as a sentence.
const rendersAt = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "flex: 0 0 auto",
].join("; ");

const rows = [
  { n: 1, dir: "app/", file: "page.tsx", path: "app/page.tsx", to: "/" },
  {
    n: 2,
    path: "app/dashboard/page.tsx",
    to: "/dashboard",
  },
  {
    n: 3,
    path: "app/dashboard/invoices/page.tsx",
    to: "/dashboard/invoices",
  },
];
---

<div class="not-content" style={root}>
  {/* LEFT — the app/ tree. page.tsx leaves are bolded; the badge rides in the
      comment slot (text after the filename renders dimmed by FileTree). */}
  <div style={`${reset}; min-width: 0;`}>
    <FileTree>
      <ul>
        <li>
          src/
          <ul>
            <li>
              app/
              <ul>
                <li><strong>page.tsx</strong> ①</li>
                <li>
                  dashboard/
                  <ul>
                    <li><strong>page.tsx</strong> ②</li>
                    <li>
                      invoices/
                      <ul>
                        <li><strong>page.tsx</strong> ③</li>
                      </ul>
                    </li>
                  </ul>
                </li>
              </ul>
            </li>
          </ul>
        </li>
      </ul>
    </FileTree>
  </div>

  {/* RIGHT — the function table: one row per page.tsx. */}
  <div style={table}>
    {
      rows.map((r) => (
        <div style={row}>
          <div style={rowTop}>
            <span style={badge(r.n)}>{r.n}</span>
            <code style={pathText}>
              {r.path.slice(0, r.path.length - "page.tsx".length)}
              <span style={pageFile}>page.tsx</span>
            </code>
          </div>
          <div style={rowBottom}>
            <span style={arrow}>↳</span>
            <span style={rendersAt}>renders at</span>
            <code style={url}>{r.to}</code>
          </div>
        </div>
      ))
    }
  </div>
</div>
