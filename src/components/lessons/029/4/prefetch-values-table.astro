---
// prefetch-values-table (diagram id: prefetch-values-table, Chapter 029 L4).
//
// The three legal values of the <Link> `prefetch` prop, as a scan-at-a-glance
// reference: Value | What it does | When to reach for it.
//
// Pedagogical hook: the whole section's headline is "trust the default." So the
// table is built to be read down the FIRST column with the eye landing on the
// default — the `"auto"` row is the loud, emphasized one (accent left rule,
// tinted strip, a "default" badge on the value), and `true` / `false` read as
// the two quieter, deliberate-override rows. That visual split — one warm row,
// two cool ones — IS the lesson's message: reach for the default, override only
// for a named reason.
//
// Sibling of this chapter cluster's hand-styled figures (029/4 prefetch-timeline
// directly above it) and of 020/8 OverflowModesTable (the same "values reference
// grid" pattern this is modelled on). A real CSS grid drives the layout — three
// columns (value | what it does | when). `margin: 0` reset on every inner node
// (belt-and-braces with `not-content`) defeats Starlight's prose-margin
// injection; `color-scheme: light` is pinned so the hand-picked slate/sky tints
// survive dark mode; it wraps itself in its own bordered card (so NO <Figure> —
// that would double-card). At narrow widths the grid collapses to stacked cards
// with `data-label` prefixes.

const reset = 'margin: 0';
const mono = 'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = "font-family: system-ui, -apple-system, 'Segoe UI', sans-serif";

// Palette (hard-coded, color-scheme pinned light — see header note). Sky family
// to match prefetch-timeline's subject-link accent directly above.
const CARD_BG = '#ffffff'; // outer card surface
const CARD_BRD = '#e2e8f0'; // slate-200 — outer card + cell hairlines
const HEAD_INK = '#0f172a'; // slate-900 — column labels
const BODY_INK = '#1e293b'; // slate-800 — "what it does" text
const GLOSS_INK = '#475569'; // slate-600 — the "when to reach for it" gloss

// The default row (`"auto"`) — the warm, emphasized one.
const DEF_TINT = '#f0f9ff'; // sky-50 — the default row's wash strip
const DEF_BRD = '#0ea5e9'; // sky-500 — default row left rule + value rule
const DEF_VALUE_BG = '#e0f2fe'; // sky-100 — value pill fill on the default row
const DEF_VALUE_INK = '#075985'; // sky-800 — value pill ink on the default row
const DEF_BADGE_BG = '#0284c7'; // sky-600 — the "default" badge fill
const DEF_BADGE_INK = '#ffffff';

// The two override rows (`true` / `false`) — quiet, neutral slate.
const OV_TINT = '#f8fafc'; // slate-50 — faint resting strip
const OV_VALUE_BG = '#f1f5f9'; // slate-100 — value pill fill
const OV_VALUE_INK = '#334155'; // slate-700 — value pill ink
const OV_VALUE_BRD = '#cbd5e1'; // slate-300 — value pill left rule

type Row = {
	value: string;
	badge?: string; // optional pill next to the value (the "default" tag)
	does: string;
	when: string;
	isDefault: boolean;
};

// Rows in the prose's order: the default first (and emphasized), then the two
// deliberate overrides. Content lifted verbatim from the lesson outline.
const rows: Row[] = [
	{
		value: '"auto"',
		badge: 'default',
		does: 'Prefetch on viewport, partial route for dynamic destinations, refresh stale data on hover.',
		when: 'Almost always. This is the senior default — leave the prop unset.',
		isDefault: true,
	},
	{
		value: 'true',
		does: 'Always prefetch the full route, static or dynamic, ignoring the partial-route optimization.',
		when: 'A small set of high-intent links to a destination you know is expensive to render and want fully warm before the click.',
		isDefault: false,
	},
	{
		value: 'false',
		does: 'Never prefetch — not on viewport, not on hover.',
		when: 'When prefetching costs more than it saves: many links to heavy or rate-limited endpoints, or a link the user is unlikely to click.',
		isDefault: false,
	},
];

// Outer bordered card. Pins color-scheme so the hand-coded tints render the same
// in dark mode, and resets prose margins on the wrapper itself.
const card = [
	reset,
	'color-scheme: light',
	`background: ${CARD_BG}`,
	`border: 1px solid ${CARD_BRD}`,
	'border-radius: 14px',
	'padding: 14px',
	'box-sizing: border-box',
	'overflow: hidden',
].join('; ');
---

<div class="not-content pvt-root" style={card}>
	<div class="pvt-grid" style={{ '--head-ink': HEAD_INK }}>
		{/* Header row */}
		<div class="pvt-head pvt-head-value">Value</div>
		<div class="pvt-head">What it does</div>
		<div class="pvt-head">When to reach for it</div>

		{/* One grid row per value — three sibling cells so each row reads edge to
		    edge. `display: contents` rows carry the per-row accent via a wrapper
		    class on each cell instead (grid children can't be group-styled), so we
		    set the accent inline per cell below. */}
		{
			rows.map((r) => {
				const stripBg = r.isDefault ? DEF_TINT : OV_TINT;
				const rowEdge = r.isDefault
					? `border-left: 3px solid ${DEF_BRD}`
					: 'border-left: 3px solid transparent';

				// The monospace value tile.
				const valueCell = [
					reset,
					mono,
					'font-size: 14px',
					'font-weight: 700',
					'line-height: 1.2',
					'display: flex',
					'align-items: center',
					'gap: 8px',
					'flex-wrap: wrap',
					'padding: 11px 12px',
					'border-radius: 8px',
					`background: ${stripBg}`,
					rowEdge,
					'box-sizing: border-box',
				].join('; ');

				const valuePill = [
					reset,
					mono,
					'font-size: 13.5px',
					'font-weight: 700',
					'line-height: 1',
					'display: inline-flex',
					'align-items: center',
					'padding: 5px 9px',
					'border-radius: 6px',
					r.isDefault
						? `background: ${DEF_VALUE_BG}; color: ${DEF_VALUE_INK}; border-left: 3px solid ${DEF_BRD}`
						: `background: ${OV_VALUE_BG}; color: ${OV_VALUE_INK}; border-left: 3px solid ${OV_VALUE_BRD}`,
					'white-space: nowrap',
					'box-sizing: border-box',
				].join('; ');

				const badge = [
					reset,
					sans,
					'font-size: 9.5px',
					'font-weight: 700',
					'letter-spacing: 0.04em',
					'text-transform: uppercase',
					'line-height: 1',
					'display: inline-flex',
					'align-items: center',
					'padding: 3px 7px',
					'border-radius: 999px',
					`background: ${DEF_BADGE_BG}`,
					`color: ${DEF_BADGE_INK}`,
					'white-space: nowrap',
					'box-sizing: border-box',
				].join('; ');

				const doesCell = [
					reset,
					sans,
					'font-size: 13px',
					'line-height: 1.45',
					'display: flex',
					'align-items: center',
					'padding: 11px 12px',
					'border-radius: 8px',
					`background: ${stripBg}`,
					`color: ${BODY_INK}`,
					r.isDefault ? 'font-weight: 600' : 'font-weight: 400',
					'box-sizing: border-box',
				].join('; ');

				const whenCell = [
					reset,
					sans,
					'font-size: 12.5px',
					'line-height: 1.45',
					'display: flex',
					'align-items: center',
					'padding: 11px 12px',
					'border-radius: 8px',
					`background: ${stripBg}`,
					`color: ${GLOSS_INK}`,
					'box-sizing: border-box',
				].join('; ');

				return (
					<Fragment>
						<div class="pvt-cell pvt-value" data-label="Value" style={valueCell}>
							<span style={valuePill}>{r.value}</span>
							{r.badge && <span style={badge}>{r.badge}</span>}
						</div>
						<div class="pvt-cell" data-label="What it does" style={doesCell}>
							{r.does}
						</div>
						<div class="pvt-cell" data-label="When to reach for it" style={whenCell}>
							{r.when}
						</div>
					</Fragment>
				);
			})
		}
	</div>
</div>

<style>
	.pvt-root :global(*) {
		margin: 0;
	}

	/* Three columns: value (intrinsic) | what it does (flexes) | when (flexes).
	   Row gap separates rows; column gap separates cells. */
	.pvt-grid {
		display: grid;
		grid-template-columns: minmax(108px, max-content) minmax(0, 1.1fr) minmax(0, 1.2fr);
		align-items: stretch;
		column-gap: 8px;
		row-gap: 6px;
		width: 100%;
		box-sizing: border-box;
		margin: 0;
	}

	.pvt-head {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		line-height: 1.1;
		color: var(--head-ink);
		display: flex;
		align-items: center;
		padding: 4px 12px 6px;
		box-sizing: border-box;
		margin: 0;
	}

	/* Narrow viewport: collapse to a stacked card layout, one card per value. */
	@media (max-width: 640px) {
		.pvt-grid {
			grid-template-columns: 1fr;
			row-gap: 12px;
			column-gap: 0;
		}

		.pvt-head {
			display: none;
		}

		/* Each value's three cells stack inside one bordered card. We can't wrap
		   the three contents siblings in a DOM box (they're grid children), so we
		   round only the first/last of each triple and butt them together. */
		.pvt-cell {
			border-radius: 0 !important;
		}

		.pvt-value {
			border-top-left-radius: 9px !important;
			border-top-right-radius: 9px !important;
			padding-bottom: 4px !important;
		}

		.pvt-cell:not(.pvt-value) {
			padding-top: 4px !important;
			padding-bottom: 4px !important;
			flex-direction: column !important;
			align-items: flex-start !important;
			gap: 3px;
		}

		.pvt-cell:not(.pvt-value):last-of-type {
			border-bottom-left-radius: 9px !important;
			border-bottom-right-radius: 9px !important;
			padding-bottom: 11px !important;
		}

		/* Prefix the stacked body cells with their column label. */
		.pvt-cell:not(.pvt-value)::before {
			content: attr(data-label);
			font-size: 10px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: #94a3b8;
			margin: 0;
		}
	}
</style>
