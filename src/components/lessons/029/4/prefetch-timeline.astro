---
// prefetch-timeline (diagram id: prefetch-timeline, Chapter 029 L4). A three-step
// scrubbable DiagramSequence that makes the INVISIBLE prefetch-then-click timeline
// concrete, so the student trusts the default. One <Link> ("Invoices") in a small
// sidebar-style stack of three link rows is the subject; the timeline plays out as
// the framework warms that destination ahead of the click.
//
//   Step 1  link enters viewport   the row lights up; "prefetching…" — the
//                                   framework fetches its route + data in the
//                                   background, no interaction yet. URL unchanged.
//   Step 2  user hovers / pauses    the row reads "warm — ready"; a pointer sits on
//                                   it; stale prefetch data refreshes now. URL
//                                   unchanged — still no navigation.
//   Step 3  user clicks             the viewport SWAPS to the Invoices page; the URL
//                                   bar updates to /dashboard/invoices; "instant ·
//                                   no spinner" — the bundle + data were already here.
//
// HEIGHT/WIDTH STABILITY (the DiagramSequence grid stack sizes to the tallest step
// and must not reflow as the reader scrubs): all three steps render the SAME mock
// browser at the SAME width with a SINGLE fixed-height viewport region. Steps 1-2
// render the SAME nav stack (three rows, same geometry); only the Invoices row's
// status pill + its trailing glyph change, plus a floating tag. Step 3 replaces the
// viewport content with the Invoices page, but the viewport reserves the exact same
// height, so nothing in flow resizes and the stage never jumps.
//
// House style follows this chapter-cluster's hand-styled figures (029/5
// url-to-slot-mapping, 029/2 nesting-dolls): fixed slate palette, `color-scheme:
// light` pinned so the hand-picked tints survive dark mode, `margin: 0` on every
// node to defeat Starlight's injected prose margin-top, mono for URL/file labels.
// The subject link wears ONE accent across the whole timeline: sky = the Invoices
// destination; amber marks the "in-flight / not-yet-clicked" beat in step 1.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette (fixed — color-scheme pinned light so these survive dark mode).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const FAINT = '#94a3b8'; // slate-400 — placeholder / faint text
const HAIRLINE = '#e2e8f0'; // slate-200 — borders
const SURFACE = '#ffffff'; // viewport / pane surface
const CHROME = '#f1f5f9'; // slate-100 — browser chrome / sidebar fill
const ROW_BG = '#f8fafc'; // slate-50 — resting nav-row fill

// The subject link's accent — sky carries the Invoices destination the whole way.
const LINK = '#0ea5e9'; // sky-500
const LINK_WASH = '#f0f9ff'; // sky-50
const LINK_DEEP = '#075985'; // sky-800 — active row text
const LINK_MED = '#0369a1'; // sky-700

// The "in-flight / not yet clicked" beat (step 1) is amber; "warm" (step 2) green.
const FLIGHT = '#d97706'; // amber-600 — prefetch in flight
const FLIGHT_WASH = '#fffbeb'; // amber-50
const READY = '#059669'; // emerald-600 — warm / ready
const READY_WASH = '#ecfdf5'; // emerald-50

// ---- shared geometry -----------------------------------------------------------
const VIEWPORT_W = 520; // browser box content width
const STAGE_H = 222; // fixed viewport-body height every step reserves

const stage = `display: flex; justify-content: center; margin: 0; padding: 2px 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// Mock browser window: chrome bar (traffic lights + URL) over the viewport body.
const browser = [
	'box-sizing: border-box',
	`width: min(100%, ${VIEWPORT_W}px)`,
	'margin: 0',
	'border-radius: 12px',
	`border: 1px solid ${HAIRLINE}`,
	'overflow: hidden',
	`background: ${SURFACE}`,
	'box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08)',
].join('; ');

const chromeBar = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'gap: 10px',
	'margin: 0',
	'padding: 9px 12px',
	`background: ${CHROME}`,
	`border-bottom: 1px solid ${HAIRLINE}`,
].join('; ');

const dots = 'display: flex; gap: 5px; flex: 0 0 auto; margin: 0;';
const dot = (c: string) => `display: block; width: 9px; height: 9px; margin: 0; border-radius: 999px; background: ${c};`;

const urlBar = [
	'box-sizing: border-box',
	'flex: 1 1 auto',
	'min-width: 0',
	'margin: 0',
	'padding: 4px 11px',
	'border-radius: 6px',
	`border: 1px solid ${HAIRLINE}`,
	`background: ${SURFACE}`,
	`font-family: ${mono}`,
	'font-size: 12.5px',
	'line-height: 1.4',
	'white-space: nowrap',
	'overflow: hidden',
	'text-overflow: ellipsis',
].join('; ');
const urlBase = `color: ${INK_SOFT};`;
const urlSeg = (accent: string, wash: string) =>
	`color: ${accent}; font-weight: 700; background: ${wash}; border-radius: 4px; padding: 1px 4px; margin: 0 -1px;`;

// Viewport body — fixed height in every step so the stage never resizes.
const viewport = [
	'box-sizing: border-box',
	'position: relative',
	`height: ${STAGE_H}px`,
	'margin: 0',
	'overflow: hidden',
	`background: ${SURFACE}`,
].join('; ');

// ---- the dashboard nav (steps 1-2): sidebar + content scaffold -----------------
const dashLayout = 'box-sizing: border-box; display: grid; grid-template-columns: 188px 1fr; height: 100%; margin: 0;';

const sidebar = [
	'box-sizing: border-box',
	'display: flex',
	'flex-direction: column',
	'gap: 8px',
	'margin: 0',
	'padding: 14px 12px',
	`background: ${CHROME}`,
	`border-right: 1px solid ${HAIRLINE}`,
].join('; ');

const navHeading = `margin: 0 0 2px 2px; font-family: ${sans}; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: ${FAINT};`;

// One nav row (a <Link>). The Invoices row is the subject; `accent`/`wash` light it.
const navRow = (active: boolean, accent: string, wash: string) =>
	[
		'box-sizing: border-box',
		'display: flex',
		'align-items: center',
		'justify-content: space-between',
		'gap: 8px',
		'margin: 0',
		'padding: 8px 10px',
		'border-radius: 7px',
		`border: 1px solid ${active ? accent : 'transparent'}`,
		`background: ${active ? wash : ROW_BG}`,
		`box-shadow: ${active ? `inset 2px 0 0 ${accent}` : 'none'}`,
	].join('; ');
const navLabel = (active: boolean, accent: string) =>
	`margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: ${active ? 700 : 600}; color: ${active ? accent : INK};`;

// The status pill that rides the active row: prefetching (amber) → warm (green).
const statusPill = (accent: string, wash: string) =>
	[
		'display: inline-flex',
		'align-items: center',
		'gap: 4px',
		'box-sizing: border-box',
		'margin: 0',
		'padding: 1px 6px',
		'border-radius: 999px',
		`font-family: ${sans}`,
		'font-size: 9.5px',
		'font-weight: 700',
		'letter-spacing: 0.02em',
		`color: ${accent}`,
		`background: ${wash}`,
		`border: 1px solid color-mix(in srgb, ${accent} 35%, #ffffff)`,
		'white-space: nowrap',
	].join('; ');

// The content area to the right of the sidebar (a faint "current page" scaffold).
const contentPane = 'box-sizing: border-box; display: flex; flex-direction: column; gap: 9px; margin: 0; padding: 16px;';
const skelTitle = `margin: 0; width: 42%; height: 13px; border-radius: 4px; background: ${HAIRLINE};`;
const skelLine = (w: string) => `margin: 0; width: ${w}; height: 8px; border-radius: 3px; background: ${ROW_BG};`;
const skelLineHard = (w: string) => `margin: 0; width: ${w}; height: 8px; border-radius: 3px; background: ${HAIRLINE};`;

// A tiny floating annotation tag, bottom-corner of the viewport.
const floatTag = (corner: 'left' | 'right', bg: string) =>
	[
		'position: absolute',
		'bottom: 10px',
		corner === 'left' ? 'left: 12px' : 'right: 12px',
		'box-sizing: border-box',
		'margin: 0',
		'padding: 3px 9px',
		'border-radius: 999px',
		`background: ${bg}`,
		'color: #ffffff',
		`font-family: ${sans}`,
		'font-size: 10px',
		'font-weight: 600',
		'letter-spacing: 0.01em',
		'box-shadow: 0 1px 3px rgba(15, 23, 42, 0.18)',
		'white-space: nowrap',
	].join('; ');

// A cursor/pointer glyph (step 2) — sits at the row's right edge.
const cursorGlyph = `flex: 0 0 auto; margin: 0; font-size: 13px; line-height: 1; color: ${INK};`;

// ---- the Invoices page (step 3): the swapped-in destination --------------------
const invHeader = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 8px',
	'margin: 0',
	'padding: 11px 16px',
	`border-bottom: 1px solid ${HAIRLINE}`,
	`background: ${LINK_WASH}`,
].join('; ');
const invTitle = `margin: 0; font-family: ${sans}; font-size: 15px; font-weight: 800; color: ${LINK_DEEP};`;
const invCrumb = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; color: ${LINK_MED};`;

const invBody = 'box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 14px 16px;';
const invRow = [
	'box-sizing: border-box',
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 8px',
	'margin: 0',
	'padding: 9px 11px',
	'border-radius: 7px',
	`border: 1px solid ${HAIRLINE}`,
	`background: ${ROW_BG}`,
].join('; ');
const invRowId = `margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 600; color: ${INK};`;
const invRowAmount = `margin: 0; font-family: ${mono}; font-size: 11.5px; color: ${INK_SOFT};`;
const invRows = [
	{ id: 'INV-041', amount: '$1,200' },
	{ id: 'INV-042', amount: '$3,480' },
	{ id: 'INV-043', amount: '$760' },
];

// Per-step captions (lifted from the lesson outline, lightly expanded).
const captions = {
	1: 'The link becomes visible. The framework starts fetching its route and data in the background — no interaction needed, the user has not touched anything yet, and the URL has not changed.',
	2: 'The destination is already warm. A hover or a pause is enough; if the prefetched data went stale while it sat there, Next refreshes it now — still before any click, still on /dashboard.',
	3: 'The click lands and the swap is instant — the bundle and data were already here, so there is no loading spinner. Only now does the URL become /dashboard/invoices.',
} as const;

const STEPS = [1, 2, 3] as const;
---

<DiagramSequence>
	{
		STEPS.map((step) => {
			const isSwap = step === 3; // step 3 = the click → page swap
			// On the active (Invoices) row, the status accent walks amber → green.
			const rowAccent = step === 1 ? FLIGHT : LINK;
			const rowWash = step === 1 ? FLIGHT_WASH : LINK_WASH;

			return (
				<DiagramStep caption={captions[step]}>
					<div style={stage}>
						<div style={browser}>
							{/* ---- browser chrome: traffic lights + URL bar ---- */}
							<div style={chromeBar}>
								<div style={dots} aria-hidden="true">
									<span style={dot('#f87171')} />
									<span style={dot('#fbbf24')} />
									<span style={dot('#34d399')} />
								</div>
								<div style={urlBar}>
									<span style={urlBase}>app.example.com</span>
									<span style={urlSeg(LINK, LINK_WASH)}>/dashboard</span>
									{isSwap && <span style={urlSeg(LINK, LINK_WASH)}>/invoices</span>}
								</div>
							</div>

							{/* ---- viewport body (fixed height in every step) ---- */}
							<div style={viewport}>
								{isSwap ? (
									/* STEP 3 — the Invoices page swapped in, no spinner. */
									<Fragment>
										<div style={invHeader}>
											<span style={invTitle}>Invoices</span>
											<span style={invCrumb}>/dashboard/invoices</span>
										</div>
										<div style={invBody}>
											{invRows.map((r) => (
												<div style={invRow}>
													<span style={invRowId}>{r.id}</span>
													<span style={invRowAmount}>{r.amount}</span>
												</div>
											))}
										</div>
										<span style={floatTag('right', READY)}>instant · no spinner</span>
									</Fragment>
								) : (
									/* STEPS 1-2 — the dashboard, Invoices link being warmed. */
									<div style={dashLayout}>
										<div style={sidebar}>
											<span style={navHeading}>Navigation</span>

											{/* Dashboard — a resting link */}
											<div style={navRow(false, LINK, LINK_WASH)}>
												<span style={navLabel(false, LINK_DEEP)}>Dashboard</span>
											</div>

											{/* Invoices — THE subject link being prefetched / warmed */}
											<div style={navRow(true, rowAccent, rowWash)}>
												<span style={navLabel(true, step === 1 ? FLIGHT : LINK_DEEP)}>Invoices</span>
												{step === 1 ? (
													<span style={statusPill(FLIGHT, FLIGHT_WASH)}>
														<span style="margin: 0;" aria-hidden="true">↓</span>
														prefetching…
													</span>
												) : (
													<Fragment>
														<span style={statusPill(READY, READY_WASH)}>
															<span style="margin: 0;" aria-hidden="true">✓</span>
															warm
														</span>
														<span style={cursorGlyph} aria-hidden="true">▾</span>
													</Fragment>
												)}
											</div>

											{/* Settings — a resting link */}
											<div style={navRow(false, LINK, LINK_WASH)}>
												<span style={navLabel(false, LINK_DEEP)}>Settings</span>
											</div>
										</div>

										{/* current page (dashboard) — faint scaffold */}
										<div style={contentPane}>
											<span style={skelTitle} />
											<span style={skelLineHard('88%')} />
											<span style={skelLine('72%')} />
											<span style={skelLine('80%')} />
											<span style={skelLine('60%')} />
										</div>

										{step === 1 ? (
											<span style={floatTag('left', FLIGHT)}>fetched in the background — no click yet</span>
										) : (
											<span style={floatTag('left', READY)}>already warm · stale data refreshed</span>
										)}
									</div>
								)}
							</div>
						</div>
					</div>
				</DiagramStep>
			);
		})
	}
</DiagramSequence>
