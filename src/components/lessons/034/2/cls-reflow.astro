---
// CLS reflow strip (diagram id: cls-reflow, Chapter 034 Lesson 2 — "Images with
// next/image"). The single hardest image concept to land in prose — Cumulative
// Layout Shift — drawn as a literal before/after of the page box.
//
// Two labelled rows stacked vertically:
//   Row 1 "<img>" (the failure): a two-state mini-timeline. State A ("while
//     loading") is a page mock whose image slot has collapsed to a 0px hairline,
//     so the paragraph sits high, directly under the heading. A right arrow leads
//     to State B ("image arrives"): the SAME mock, but the image slot is now a
//     full ~80px box and the paragraph has been shoved down by exactly that box's
//     height — marked with a red "jump" badge so the displacement is literal.
//   Row 2 "next/image" (the fix): one state, no jump. The image slot is drawn as
//     a dashed-outline reserved box at its full ~80px height FROM THE START, the
//     paragraph already sitting below it, a green "no shift" tag. The point the
//     picture lands: the box is reserved before the bytes arrive, so nothing
//     below it ever moves.
//
// Colour convention: RED = the failure / the reflow (the jump); GREEN = the fix /
// the reserved box. Neutral slate page-mock chrome (heading bar, text lines,
// image fill) carries no meaning, so it stays grey. The two mocks in row 1 share
// an identical heading + paragraph so the eye reads the paragraph's downward
// travel as the only change between them.
//
// House style follows the ch 033 family: pinned `color-scheme: light` so the
// hand-picked tints survive dark mode, inline style strings only (a reader can
// copy the source and see exactly what styled it), `margin: 0` on every inner
// element to defeat Starlight's injected prose margin-top, box-sizing:
// border-box throughout. No leader lines, so the figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// page-mock chrome — neutral slate, carries no meaning.
const MOCK_BORDER = '#cbd5e1'; // slate-300
const MOCK_BG = '#f8fafc'; // slate-50
const HEAD_FILL = '#94a3b8'; // slate-400 — the heading bar
const TEXT_FILL = '#cbd5e1'; // slate-300 — paragraph lines
const IMG_FILL = '#64748b'; // slate-500 — the painted image
const IMG_INK = '#ffffff';

// FAILURE / the jump — red.
const RED = '#dc2626'; // red-600
const RED_BG = '#fef2f2'; // red-50 wash
const RED_INK = '#b91c1c'; // red-700

// FIX / reserved box — green.
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_INK = '#15803d'; // green-700

// ---- outer stage: two rows stacked --------------------------------------
const stage = [
  'display: flex',
  'flex-direction: column',
  'gap: 14px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// one row = a tinted band holding a left rail label + the mocks.
const row = (accent: string, bg: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'flex-wrap: wrap',
    'align-items: center',
    'column-gap: 16px',
    'row-gap: 12px',
    'margin: 0',
    'padding: 14px 16px',
    'border-radius: 14px',
    `border: 1.5px solid ${accent}`,
    `background: ${bg}`,
  ].join('; ');

// left rail — the row's identity label (`<img>` / `next/image`) + verdict.
const rail = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: flex-start',
  'gap: 4px',
  'width: 118px',
  'margin: 0',
].join('; ');
const railCode = (ink: string) =>
  [
    'box-sizing: border-box',
    'display: inline-block',
    'margin: 0',
    'padding: 3px 9px',
    'border-radius: 7px',
    `border: 1.5px solid ${ink}`,
    `background: ${SURFACE}`,
    `color: ${ink}`,
    `font-family: ${mono}`,
    'font-size: 13px',
    'font-weight: 800',
    'line-height: 1.2',
    'white-space: nowrap',
  ].join('; ');
const railVerdict = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 11px',
    'font-weight: 700',
    'line-height: 1.3',
    `color: ${ink}`,
  ].join('; ');

// the run of mocks for a row (state A → arrow → state B, or a single mock).
const mockRun = [
  'box-sizing: border-box',
  'flex: 1 1 380px',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 12px',
  'row-gap: 12px',
  'margin: 0',
  'min-width: 0',
].join('; ');

// one page-mock: a small browser-ish frame, heading bar + image slot + paragraph.
const mock = [
  'box-sizing: border-box',
  'flex: 0 1 180px',
  'display: flex',
  'flex-direction: column',
  'align-items: stretch',
  'gap: 8px',
  'margin: 0',
  'padding: 10px 11px 12px',
  'border-radius: 10px',
  `border: 1.5px solid ${MOCK_BORDER}`,
  `background: ${MOCK_BG}`,
  'min-width: 150px',
  'max-width: 210px',
].join('; ');

// caption above each mock state.
const stateCap = (ink: string) =>
  [
    'display: inline-flex',
    'align-items: center',
    'align-self: flex-start',
    'gap: 5px',
    'margin: 0 0 1px',
    'padding: 2px 8px',
    'border-radius: 999px',
    `border: 1px solid ${ink}`,
    `background: ${SURFACE}`,
    `color: ${ink}`,
    `font-family: ${sans}`,
    'font-size: 9.5px',
    'font-weight: 800',
    'text-transform: uppercase',
    'letter-spacing: 0.03em',
    'line-height: 1.4',
    'white-space: nowrap',
  ].join('; ');

// the heading bar at the top of a mock — fixed, identical across all mocks.
const headingBar = [
  'height: 11px',
  'width: 72%',
  'margin: 0',
  'border-radius: 999px',
  `background: ${HEAD_FILL}`,
].join('; ');

// the image slot — collapsed (a hairline), painted (full box), or reserved (dashed).
const slotCollapsed = [
  'box-sizing: border-box',
  'height: 2px',
  'width: 100%',
  'margin: 0',
  'border-radius: 2px',
  `background: ${RED}`,
].join('; ');
const slotPainted = [
  'box-sizing: border-box',
  'position: relative',
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'height: 70px',
  'width: 100%',
  'margin: 0',
  'border-radius: 7px',
  `background: ${IMG_FILL}`,
  `color: ${IMG_INK}`,
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 800',
  'letter-spacing: 0.02em',
].join('; ');
const slotReserved = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'height: 70px',
  'width: 100%',
  'margin: 0',
  'border-radius: 7px',
  `border: 2px dashed ${GREEN}`,
  `background: ${GREEN_BG}`,
  `color: ${GREEN_INK}`,
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 800',
  'letter-spacing: 0.02em',
  'text-align: center',
].join('; ');

// the paragraph block — three grey lines. Highlighted (tinted wrapper) when it is
// the element that moved / is held in place.
const para = (tint: string | null) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'flex-direction: column',
    'gap: 5px',
    'margin: 0',
    'padding: 6px',
    'border-radius: 6px',
    tint ? `background: ${tint}` : 'background: transparent',
  ].join('; ');
const textLine = (w: string) =>
  [
    'height: 6px',
    `width: ${w}`,
    'margin: 0',
    'border-radius: 999px',
    `background: ${TEXT_FILL}`,
  ].join('; ');

// the red "jump" badge pinned to the shoved-down paragraph in state B.
const jumpBadge = [
  'display: inline-flex',
  'align-items: center',
  'align-self: flex-start',
  'gap: 4px',
  'margin: 0',
  'padding: 2px 8px',
  'border-radius: 999px',
  `background: ${RED}`,
  'color: #ffffff',
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 800',
  'line-height: 1.3',
  'white-space: nowrap',
].join('; ');

// the green "no shift" tag for the fix row.
const okTag = [
  'display: inline-flex',
  'align-items: center',
  'align-self: flex-start',
  'gap: 5px',
  'margin: 0',
  'padding: 2px 9px',
  'border-radius: 999px',
  `background: ${GREEN}`,
  'color: #ffffff',
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 800',
  'line-height: 1.3',
  'white-space: nowrap',
].join('; ');

// the connecting arrow between state A and state B.
const arrowWrap = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 3px',
  'margin: 0',
  'align-self: center',
].join('; ');
const arrowGlyph = [
  'margin: 0',
  `color: ${RED}`,
  'font-size: 26px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');
const arrowLabel = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9px',
  'font-weight: 700',
  'text-transform: uppercase',
  'letter-spacing: 0.04em',
  'line-height: 1.2',
  `color: ${INK_SOFT}`,
  'white-space: nowrap',
].join('; ');
---

<Figure
  caption="A plain <img> reserves no space and reflows the page when it loads — that reflow is CLS. next/image reserves the box up front, so nothing jumps."
>
  <div style={stage}>
    {/* ============ Row 1 — <img>: the reflow ============ */}
    <div style={row(RED, RED_BG)}>
      <div style={rail}>
        <span style={railCode(RED_INK)}>{'<img>'}</span>
        <p style={railVerdict(RED_INK)}>page jumps on load</p>
      </div>

      <div style={mockRun}>
        {/* State A — while loading: image slot collapsed to a hairline */}
        <div style={mock}>
          <span style={stateCap(INK_SOFT)}>while loading</span>
          <span style={headingBar} aria-hidden="true"></span>
          <span style={slotCollapsed} aria-hidden="true"></span>
          <div style={para(null)} aria-hidden="true">
            <span style={textLine('100%')}></span>
            <span style={textLine('100%')}></span>
            <span style={textLine('60%')}></span>
          </div>
        </div>

        {/* the jump arrow */}
        <div style={arrowWrap} aria-hidden="true">
          <span style={arrowGlyph}>&rarr;</span>
          <span style={arrowLabel}>image arrives</span>
        </div>

        {/* State B — image arrives: slot is a full box, paragraph shoved down */}
        <div style={mock}>
          <span style={stateCap(RED_INK)}>after load</span>
          <span style={headingBar} aria-hidden="true"></span>
          <span style={slotPainted}>image</span>
          <div style={para(RED_BG)}>
            <span style={jumpBadge}>&darr; pushed down</span>
            <span style={textLine('100%')} aria-hidden="true"></span>
            <span style={textLine('100%')} aria-hidden="true"></span>
            <span style={textLine('60%')} aria-hidden="true"></span>
          </div>
        </div>
      </div>
    </div>

    {/* ============ Row 2 — next/image: the reserved box ============ */}
    <div style={row(GREEN, GREEN_BG)}>
      <div style={rail}>
        <span style={railCode(GREEN_INK)}>next/image</span>
        <p style={railVerdict(GREEN_INK)}>box reserved up front</p>
      </div>

      <div style={mockRun}>
        {/* single state — no before/after, because nothing moves */}
        <div style={mock}>
          <span style={stateCap(GREEN_INK)}>before &amp; after load</span>
          <span style={headingBar} aria-hidden="true"></span>
          <span style={slotReserved}>box reserved</span>
          <div style={para(GREEN_BG)}>
            <span style={okTag}>&check; no shift</span>
            <span style={textLine('100%')} aria-hidden="true"></span>
            <span style={textLine('100%')} aria-hidden="true"></span>
            <span style={textLine('60%')} aria-hidden="true"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Figure>
