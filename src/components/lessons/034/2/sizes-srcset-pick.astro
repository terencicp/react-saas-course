---
// sizes + srcset pick (diagram id: sizes-srcset-pick, Chapter 034 Lesson 2 —
// "Images with next/image"). The conceptual miss this picture fixes: `sizes` is
// an INPUT to the browser's pick, not a CSS size. Same `srcset`, two devices,
// two different files chosen — and `sizes` is what told each device which slot
// width to compute.
//
// Two stacked bands:
//   Band 1 "srcset (one set, shared)": a left rail label + a row of four
//     candidate tiles the optimizer generated — 640w / 1080w / 1920w / 2400w,
//     drawn at increasing widths so the row reads as a size ramp. Two of them
//     are LIT (a coloured ring + a "← phone" / "← desktop" tag) because they're
//     the files actually fetched; the two largest are DIMMED and carry a
//     struck-through "no sizes → grabs largest" note, the contrast the outline
//     asks for.
//   Band 2 "the pick": two device cards side by side. Each names its computed
//     slot — phone "sizes 100vw → ~360px", desktop "sizes 33vw → ~620px" — and
//     a coloured "fetches 640w / 1080w" badge. The badge colour matches the ring
//     on the tile above, so identity (not a leader line) carries the mapping:
//     the eye reads "blue device → blue tile", "amber device → amber tile".
//
// Colour convention: BLUE = the phone path, AMBER = the desktop path — two
// neutral-distinct hues so the two picks never read as good/bad. Tile chrome
// (the candidate rectangles, width labels) is neutral slate and carries no
// meaning until a pick lights it. The dim/struck treatment on 1920w+2400w is
// the "what no sizes does" cautionary note.
//
// House style mirrors the sibling cls-reflow.astro: pinned `color-scheme: light`
// so the hand-picked tints survive dark mode, inline style strings only,
// `margin: 0` on every inner element to defeat Starlight's injected prose
// margin-top, box-sizing: border-box throughout. No leader lines, so the figure
// stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// candidate-tile chrome — neutral slate, no meaning until a pick lights it.
const TILE_BORDER = '#cbd5e1'; // slate-300
const TILE_BG = '#f1f5f9'; // slate-100
const TILE_FILL = '#94a3b8'; // slate-400 — the "image" body of a tile
const TILE_INK = '#ffffff';

// PHONE path — blue.
const BLUE = '#2563eb'; // blue-600
const BLUE_BG = '#eff6ff'; // blue-50
const BLUE_INK = '#1d4ed8'; // blue-700

// DESKTOP path — amber.
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50
const AMBER_INK = '#b45309'; // amber-700

// the "what no sizes does" cautionary note — muted red.
const RED = '#dc2626'; // red-600
const RED_INK = '#b91c1c'; // red-700

// ---- outer stage: two bands stacked --------------------------------------
const stage = [
  'display: flex',
  'flex-direction: column',
  'gap: 12px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// a band = a left rail label + its content area.
const band = (bg: string, border: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'flex-wrap: wrap',
    'align-items: center',
    'column-gap: 16px',
    'row-gap: 12px',
    'margin: 0',
    'padding: 14px 16px',
    'border-radius: 14px',
    `border: 1.5px solid ${border}`,
    `background: ${bg}`,
  ].join('; ');

// left rail — the band's identity label + a one-line gloss.
const rail = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: flex-start',
  'gap: 4px',
  'width: 124px',
  'margin: 0',
].join('; ');
const railTitle = [
  'box-sizing: border-box',
  'display: inline-block',
  'margin: 0',
  'padding: 3px 9px',
  'border-radius: 7px',
  `border: 1.5px solid ${INK}`,
  `background: ${SURFACE}`,
  `color: ${INK}`,
  `font-family: ${mono}`,
  'font-size: 12.5px',
  'font-weight: 800',
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');
const railGloss = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 600',
  'line-height: 1.3',
  `color: ${INK_SOFT}`,
].join('; ');

// ---- band 1: the shared srcset row ---------------------------------------
const tileRow = [
  'box-sizing: border-box',
  'flex: 1 1 360px',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: flex-end',
  'justify-content: center',
  'column-gap: 12px',
  'row-gap: 14px',
  'margin: 0',
  'min-width: 0',
].join('; ');

// one candidate tile. `w` sets its rendered width so the row reads as a ramp;
// `state` controls the chrome: a neutral candidate, a lit pick, or a dimmed one.
const tileWrap = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'gap: 5px',
  'margin: 0',
].join('; ');

const tile = (w: number, ring: string | null, dim: boolean) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    `width: ${w}px`,
    'height: 46px',
    'margin: 0',
    'border-radius: 8px',
    ring ? `border: 2.5px solid ${ring}` : `border: 1.5px solid ${TILE_BORDER}`,
    `background: ${TILE_FILL}`,
    `color: ${TILE_INK}`,
    `font-family: ${mono}`,
    'font-size: 11px',
    'font-weight: 800',
    'letter-spacing: 0.02em',
    dim ? 'opacity: 0.4' : 'opacity: 1',
  ].join('; ');

// the picked-by tag that sits under a lit tile.
const pickTag = (bg: string) =>
  [
    'box-sizing: border-box',
    'display: inline-flex',
    'align-items: center',
    'gap: 4px',
    'margin: 0',
    'padding: 2px 8px',
    'border-radius: 999px',
    `background: ${bg}`,
    'color: #ffffff',
    `font-family: ${sans}`,
    'font-size: 10px',
    'font-weight: 800',
    'line-height: 1.3',
    'white-space: nowrap',
  ].join('; ');

// the muted width caption under a neutral / dimmed tile.
const tileCap = (ink: string, dim: boolean) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 10px',
    'font-weight: 700',
    'line-height: 1.3',
    `color: ${ink}`,
    'white-space: nowrap',
    dim ? 'opacity: 0.7' : 'opacity: 1',
  ].join('; ');

// the struck "no sizes → grabs largest" note pinned under the big tiles.
const noSizesNote = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'gap: 5px',
  'margin: 0',
  'padding: 2px 9px',
  'border-radius: 999px',
  `border: 1px dashed ${RED}`,
  `background: ${SURFACE}`,
  `color: ${RED_INK}`,
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 700',
  'line-height: 1.3',
  'white-space: nowrap',
].join('; ');

// ---- band 2: the two device cards ----------------------------------------
const deviceRow = [
  'box-sizing: border-box',
  'flex: 1 1 360px',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 14px',
  'row-gap: 12px',
  'margin: 0',
  'min-width: 0',
].join('; ');

const deviceCard = (accent: string, bg: string) =>
  [
    'box-sizing: border-box',
    'flex: 1 1 220px',
    'display: flex',
    'align-items: center',
    'gap: 12px',
    'margin: 0',
    'padding: 12px 14px',
    'border-radius: 12px',
    `border: 1.5px solid ${accent}`,
    `background: ${bg}`,
    'max-width: 300px',
    'min-width: 200px',
  ].join('; ');

// the little device glyph frame (phone = tall, desktop = wide).
const glyph = (accent: string, w: number, h: number) =>
  [
    'box-sizing: border-box',
    'flex: 0 0 auto',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    `width: ${w}px`,
    `height: ${h}px`,
    'margin: 0',
    'border-radius: 6px',
    `border: 2px solid ${accent}`,
    `background: ${SURFACE}`,
  ].join('; ');
const glyphInner = (accent: string, w: string, h: string) =>
  [
    'box-sizing: border-box',
    `width: ${w}`,
    `height: ${h}`,
    'margin: 0',
    'border-radius: 2px',
    `background: ${accent}`,
    'opacity: 0.25',
  ].join('; ');

// the text column inside a device card.
const deviceText = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: flex-start',
  'gap: 5px',
  'margin: 0',
  'min-width: 0',
].join('; ');
const deviceName = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 12px',
    'font-weight: 800',
    'line-height: 1.2',
    `color: ${ink}`,
  ].join('; ');
const slotLine = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 11px',
  'font-weight: 600',
  'line-height: 1.35',
  `color: ${INK}`,
].join('; ');
const slotStrong = (ink: string) =>
  [`color: ${ink}`, 'font-weight: 800'].join('; ');

// the "fetches Nw" badge — colour matches the lit tile above.
const fetchBadge = (bg: string) =>
  [
    'box-sizing: border-box',
    'display: inline-flex',
    'align-items: center',
    'gap: 5px',
    'margin: 1px 0 0',
    'padding: 3px 9px',
    'border-radius: 999px',
    `background: ${bg}`,
    'color: #ffffff',
    `font-family: ${sans}`,
    'font-size: 10.5px',
    'font-weight: 800',
    'line-height: 1.3',
    'white-space: nowrap',
  ].join('; ');
---

<Figure
  caption="sizes tells the browser how wide the image will render, so it can fetch the right srcset variant for each device instead of always grabbing the largest. Same set, two devices, two different files."
>
  <div style={stage}>
    {/* ============ Band 1 — the shared srcset row ============ */}
    <div style={band(TILE_BG, TILE_BORDER)}>
      <div style={rail}>
        <span style={railTitle}>srcset</span>
        <p style={railGloss}>one set the optimizer generated</p>
      </div>

      <div style={tileRow}>
        {/* 640w — the phone's pick (lit blue) */}
        <div style={tileWrap}>
          <span style={pickTag(BLUE)}>&uarr; phone</span>
          <span style={tile(58, BLUE, false)} aria-hidden="true">640w</span>
          <span style={tileCap(BLUE_INK, false)}>640w</span>
        </div>

        {/* 1080w — the desktop's pick (lit amber) */}
        <div style={tileWrap}>
          <span style={pickTag(AMBER)}>&uarr; desktop</span>
          <span style={tile(92, AMBER, false)} aria-hidden="true">1080w</span>
          <span style={tileCap(AMBER_INK, false)}>1080w</span>
        </div>

        {/* 1920w — unchosen, dimmed */}
        <div style={tileWrap}>
          <span style={tile(128, null, true)} aria-hidden="true">1920w</span>
          <span style={tileCap(INK_SOFT, true)}>1920w</span>
        </div>

        {/* 2400w — unchosen, dimmed, carries the cautionary note */}
        <div style={tileWrap}>
          <span style={tile(150, null, true)} aria-hidden="true">2400w</span>
          <span style={noSizesNote}>no sizes &rarr; both grab this</span>
        </div>
      </div>
    </div>

    {/* down-arrow: the browser picks from the set above */}
    <div
      style="display: flex; align-items: center; justify-content: center; gap: 8px; margin: 0;"
      aria-hidden="true"
    >
      <span
        style={`margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`}
        >browser picks per device</span
      >
      <span style={`margin: 0; color: ${INK_SOFT}; font-size: 18px; font-weight: 900; line-height: 1;`}>&darr;</span>
    </div>

    {/* ============ Band 2 — the two device picks ============ */}
    <div style={band(SURFACE, TILE_BORDER)}>
      <div style={rail}>
        <span style={railTitle}>sizes</span>
        <p style={railGloss}>the width you hand the browser</p>
      </div>

      <div style={deviceRow}>
        {/* phone → 100vw → ~360px → fetches 640w */}
        <div style={deviceCard(BLUE, BLUE_BG)}>
          <span style={glyph(BLUE, 26, 42)} aria-hidden="true">
            <span style={glyphInner(BLUE, '14px', '24px')}></span>
          </span>
          <div style={deviceText}>
            <p style={deviceName(BLUE_INK)}>Phone</p>
            <p style={slotLine}>
              sizes <span style={slotStrong(BLUE_INK)}>100vw</span> &rarr; slot
              <span style={slotStrong(BLUE_INK)}> &asymp;360px</span>
            </p>
            <span style={fetchBadge(BLUE)}>fetches 640w</span>
          </div>
        </div>

        {/* desktop → 33vw → ~620px → fetches 1080w */}
        <div style={deviceCard(AMBER, AMBER_BG)}>
          <span style={glyph(AMBER, 46, 36)} aria-hidden="true">
            <span style={glyphInner(AMBER, '34px', '20px')}></span>
          </span>
          <div style={deviceText}>
            <p style={deviceName(AMBER_INK)}>Desktop</p>
            <p style={slotLine}>
              sizes <span style={slotStrong(AMBER_INK)}>33vw</span> &rarr; slot
              <span style={slotStrong(AMBER_INK)}> &asymp;620px</span>
            </p>
            <span style={fetchBadge(AMBER)}>fetches 1080w</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Figure>
