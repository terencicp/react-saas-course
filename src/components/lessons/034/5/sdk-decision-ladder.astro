---
// The vendor-integration decision order (diagram id: sdk-decision-recap,
// Chapter 034 Lesson 5 — "Third-party scripts with next/script"). The section's
// takeaway, not new machinery: <Script> is the FLOOR. Before reaching for it,
// the senior asks "does the vendor ship something better than a snippet?" and
// walks three rungs left-to-right, only falling to the next when the prior
// doesn't apply.
//
//   Rung 1 (GREEN — preferred): a typed npm SDK if the vendor ships one
//     (PostHog, Sentry, LaunchDarkly). You `import` it — typed, tree-shakable,
//     React-native. "import it, don't inject it."
//   Rung 2 (BLUE — purpose-built): the dedicated package for Google's GA4/GTM,
//     `@next/third-parties/google` (GoogleAnalytics / GoogleTagManager).
//   Rung 3 (AMBER — fallback): a raw <Script>, only when the vendor offers
//     nothing better.
//
// Colour is load-bearing as a PREFERENCE GRADIENT, reusing the chapter's
// green-=-win convention: GREEN = the best reach, BLUE = the purpose-built
// middle, AMBER = the last-resort floor. The "else — falls through" connector
// between rungs carries the ordering (a senior tries left first). Rank badges
// 1/2/3 reinforce the order so it survives a vertical stack on narrow screens.
//
// House style mirrors the ch-034 HTML/CSS family (MetadataMergeLadder,
// font-pipeline-sequence): pinned `color-scheme: light` so the hand-picked
// tints survive dark mode; inline style strings only (no <style>); margin: 0 +
// box-sizing: border-box throughout to defeat Starlight's injected prose
// margins; fieldset-legend rank pills straddling the card's top border. No
// leader lines, so the figure stays expandable. Wrapped in <Figure>.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text / connectors
const SURFACE = '#ffffff';

// Rung 1 — the preferred reach (typed SDK). Green = the win.
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_EDGE = '#86efac'; // green-300
const GREEN_INK = '#15803d'; // green-700

// Rung 2 — the purpose-built middle (Google package). Blue.
const BLUE = '#2563eb'; // blue-600
const BLUE_BG = '#eff6ff'; // blue-50 wash
const BLUE_EDGE = '#93c5fd'; // blue-300
const BLUE_INK = '#1e40af'; // blue-800

// Rung 3 — the last-resort floor (raw <Script>). Amber.
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 wash
const AMBER_EDGE = '#fcd34d'; // amber-300
const AMBER_INK = '#b45309'; // amber-700

// ---- outer stage: three rungs, left-to-right, wrapping to a stack ----------
const stage = [
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'gap: 0',
  'margin: 0',
  'padding: 6px 2px 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// A rung card. accent tints the frame; a rank pill straddles the top border.
const rung = (edge: string, bg: string) =>
  [
    'box-sizing: border-box',
    'position: relative',
    'flex: 1 1 210px',
    'display: flex',
    'flex-direction: column',
    'gap: 8px',
    'margin: 0',
    'padding: 20px 15px 15px',
    'border-radius: 13px',
    `border: 1.5px solid ${edge}`,
    `background: ${bg}`,
    'min-width: 196px',
    'max-width: 280px',
  ].join('; ');

// "fieldset legend" rank pill (1 / 2 / 3) straddling the card's top-left border.
const rankPill = (accent: string) =>
  [
    'position: absolute',
    'top: 0',
    'left: 14px',
    'transform: translateY(-50%)',
    'display: inline-flex',
    'align-items: center',
    'justify-content: center',
    'width: 22px',
    'height: 22px',
    'margin: 0',
    'padding: 0',
    'border-radius: 999px',
    `background: ${accent}`,
    'color: #ffffff',
    `font-family: ${sans}`,
    'font-size: 12px',
    'font-weight: 800',
    'line-height: 1',
    `box-shadow: 0 0 0 3px var(--sl-color-bg-sidebar, ${SURFACE})`,
  ].join('; ');

// the title line of a rung (the choice).
const title = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 14px',
    'font-weight: 800',
    'line-height: 1.2',
    `color: ${ink}`,
  ].join('; ');

// the one-line condition under the title.
const cond = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'line-height: 1.35',
  `color: ${INK_SOFT}`,
].join('; ');

// the concrete code chip (mono) showing what you actually write.
const codeChip = (edge: string, ink: string) =>
  [
    'box-sizing: border-box',
    'display: block',
    'margin: 2px 0 0',
    'padding: 6px 9px',
    'border-radius: 7px',
    `border: 1px solid ${edge}`,
    `background: ${SURFACE}`,
    `font-family: ${mono}`,
    'font-size: 11px',
    'font-weight: 600',
    'line-height: 1.35',
    `color: ${ink}`,
    'word-break: break-word',
  ].join('; ');

// the small "e.g." vendor row at the bottom of a rung.
const egRow = [
  'margin: auto 0 0',
  'padding: 0',
  `font-family: ${sans}`,
  'font-size: 10.5px',
  'font-weight: 700',
  'line-height: 1.3',
  `color: ${INK_SOFT}`,
].join('; ');
const egVendor = (ink: string) => `font-weight: 800; color: ${ink};`;

// the "else — falls through" connector between two rungs.
const connector = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 3px',
  'margin: 0',
  'padding: 0 7px',
  'align-self: center',
].join('; ');
const connArrow = [
  'margin: 0',
  `color: ${INK_SOFT}`,
  'font-size: 22px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');
const connLabel = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.05em',
  'line-height: 1.3',
  `color: ${INK_SOFT}`,
  'white-space: nowrap',
].join('; ');
---

<Figure
  caption="The vendor-integration order, read left to right: reach for a typed SDK first, then Google's dedicated package, and drop to a raw <Script> only when the vendor ships nothing better. You only fall to the next rung when the one before it doesn't apply."
>
  <div style={stage}>
    {/* ============ Rung 1 — typed SDK (preferred) ============ */}
    <div style={rung(GREEN_EDGE, GREEN_BG)}>
      <span style={rankPill(GREEN)} aria-hidden="true">1</span>
      <p style={title(GREEN_INK)}>A typed SDK</p>
      <p style={cond}>if the vendor ships one &mdash; import it, don&rsquo;t inject it</p>
      <code style={codeChip(GREEN_EDGE, GREEN_INK)}>import posthog from 'posthog-js'</code>
      <p style={egRow}>
        e.g. <span style={egVendor(GREEN_INK)}>PostHog</span> &middot;{' '}
        <span style={egVendor(GREEN_INK)}>Sentry</span> &middot;{' '}
        <span style={egVendor(GREEN_INK)}>LaunchDarkly</span>
      </p>
    </div>

    <div style={connector} aria-hidden="true">
      <span style={connArrow}>&rarr;</span>
      <span style={connLabel}>else</span>
    </div>

    {/* ============ Rung 2 — the dedicated Google package ============ */}
    <div style={rung(BLUE_EDGE, BLUE_BG)}>
      <span style={rankPill(BLUE)} aria-hidden="true">2</span>
      <p style={title(BLUE_INK)}>The Google package</p>
      <p style={cond}>for GA4 / GTM, which ship a snippet, not an SDK</p>
      <code style={codeChip(BLUE_EDGE, BLUE_INK)}>@next/third-parties/google</code>
      <p style={egRow}>
        gives you <span style={egVendor(BLUE_INK)}>GoogleAnalytics</span> &middot;{' '}
        <span style={egVendor(BLUE_INK)}>GoogleTagManager</span>
      </p>
    </div>

    <div style={connector} aria-hidden="true">
      <span style={connArrow}>&rarr;</span>
      <span style={connLabel}>else</span>
    </div>

    {/* ============ Rung 3 — raw <Script> (the floor / fallback) ============ */}
    <div style={rung(AMBER_EDGE, AMBER_BG)}>
      <span style={rankPill(AMBER)} aria-hidden="true">3</span>
      <p style={title(AMBER_INK)}>A raw &lt;Script&gt;</p>
      <p style={cond}>only when the vendor offers nothing better</p>
      <code style={codeChip(AMBER_EDGE, AMBER_INK)}>&lt;Script src="&hellip;" strategy="&hellip;" /&gt;</code>
      <p style={egRow}>
        the <span style={egVendor(AMBER_INK)}>floor</span> every option above is built on
      </p>
    </div>
  </div>
</Figure>
