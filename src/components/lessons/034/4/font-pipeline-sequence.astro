---
// The next/font build-time pipeline (diagram id: font-pipeline-sequence,
// Chapter 034 Lesson 4 — "Self-hosted fonts with next/font"). The lesson's
// anchor visual. A scrubbable three-step DiagramSequence that makes the spine
// literal: self-host the font once at build, then serve only from your own
// origin with an invisible, shift-free swap.
//
//   Step 1 "Build time": your project runs `next build`; a single round-trip
//     reaches Google Fonts ONCE, pulling the font files + their metrics back
//     into self-hosted /_next assets. Google is GREEN here — this is the one
//     and only moment it is ever contacted. A "fires once" pill rides the arrow.
//   Step 2 "First paint (runtime)": a browser frame talks ONLY to your origin
//     (green link). The Google box is now greyed-out and disconnected
//     ("never contacted at runtime"). Text paints immediately in the adjusted
//     fallback face.
//   Step 3 "Swap": the SAME browser frame, identical size + position, now
//     painting the real brand face with a green "no shift" badge — the line
//     holds its exact spot. Behind it a faint ghost shows where a naive,
//     unadjusted swap would have pushed the text, so the held position reads.
//
// Colour convention mirrors the chapter-034 family (cls-reflow.astro):
//   GREEN = the win (the one build-time fetch / your own origin / no shift),
//   RED   = the failure being avoided (the naive swap's ghost shift),
//   neutral slate = inert chrome (browser frame, page text lines) — no meaning.
// House style: DiagramSequence provides the outer card (never wrap in Figure);
// pinned `color-scheme: light` so the hand-picked tints survive dark mode;
// inline style strings only; box-sizing: border-box and margin: 0 throughout to
// defeat Starlight's injected prose margins. No leader lines.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// The two type faces the swap is drawn with. They must look obviously
// different so "the text changed face" reads, and the real face must be WIDER
// than the fallback so the ghost (naive swap) can show a visible reflow.
const fallbackFace = "Arial, 'Helvetica Neue', Helvetica, sans-serif";
const realFace = "Georgia, 'Times New Roman', serif";

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// inert chrome — neutral slate, carries no meaning.
const CHROME_BORDER = '#cbd5e1'; // slate-300
const CHROME_BG = '#f1f5f9'; // slate-100 — browser title bar
const PAGE_BG = '#f8fafc'; // slate-50 — page body
const TEXT_FILL = '#cbd5e1'; // slate-300 — dummy paragraph lines

// "Your project" / your-origin — slate, the thing you own (neutral-strong).
const OWN = '#334155'; // slate-700
const OWN_BG = '#e2e8f0'; // slate-200 wash

// GOOGLE box — saturated when live (build), dimmed when disconnected (runtime).
const GOOG = '#2563eb'; // blue-600
const GOOG_INK = '#1e3a8a'; // blue-900
const GOOG_BG = '#dbeafe'; // blue-100 wash

// GREEN — the wins (one fetch, own origin, no shift).
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_INK = '#15803d'; // green-700

// RED — the avoided failure (the naive-swap ghost).
const RED = '#dc2626'; // red-600
const RED_INK = '#b91c1c'; // red-700

// ---- outer stage ---------------------------------------------------------
const stage = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'gap: 0',
  'margin: 0',
  'padding: 4px 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
  'min-height: 250px',
  'justify-content: center',
].join('; ');

// a labelled box (rounded card) with a title + optional sub line.
const box = (accent: string, bg: string, dim = false) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'flex-direction: column',
    'align-items: center',
    'justify-content: center',
    'gap: 3px',
    'margin: 0',
    'padding: 11px 13px',
    'border-radius: 11px',
    `border: 1.5px solid ${accent}`,
    `background: ${bg}`,
    'text-align: center',
    'min-width: 0',
    dim ? 'opacity: 0.4' : 'opacity: 1',
  ].join('; ');

const boxTitle = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 13px',
    'font-weight: 800',
    'line-height: 1.2',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

const boxSub = (ink: string, font = mono) =>
  [
    'margin: 0',
    `font-family: ${font}`,
    'font-size: 10.5px',
    'font-weight: 600',
    'line-height: 1.25',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

// pill badge (status tag riding an arrow or sitting on a frame).
const pill = (bg: string, ink: string, solid = true) =>
  [
    'display: inline-flex',
    'align-items: center',
    'gap: 4px',
    'margin: 0',
    'padding: 2px 9px',
    'border-radius: 999px',
    solid ? `background: ${bg}` : `background: ${SURFACE}`,
    solid ? 'color: #ffffff' : `color: ${ink}`,
    solid ? 'border: 1.5px solid transparent' : `border: 1.5px solid ${ink}`,
    `font-family: ${sans}`,
    'font-size: 10px',
    'font-weight: 800',
    'line-height: 1.3',
    'letter-spacing: 0.01em',
    'white-space: nowrap',
  ].join('; ');

// a horizontal arrow connector with an optional label/badge above it.
const arrowCol = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 4px',
  'margin: 0',
].join('; ');
const arrowGlyph = (color: string, big = false) =>
  [
    'margin: 0',
    `color: ${color}`,
    `font-size: ${big ? '26px' : '22px'}`,
    'font-weight: 900',
    'line-height: 1',
  ].join('; ');
const arrowNote = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 9px',
    'font-weight: 700',
    'text-transform: uppercase',
    'letter-spacing: 0.04em',
    'line-height: 1.2',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');

// ---- step 1: build-time round trip ---------------------------------------
const row = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: row',
  'align-items: center',
  'justify-content: center',
  'flex-wrap: wrap',
  'gap: 10px',
  'margin: 0',
].join('; ');

// ---- browser frame (shared by steps 2 + 3, identical geometry) -----------
const browser = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'margin: 0',
  'width: 300px',
  'max-width: 100%',
  'border-radius: 12px',
  `border: 1.5px solid ${CHROME_BORDER}`,
  `background: ${SURFACE}`,
  'overflow: hidden',
  'box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08)',
].join('; ');
const browserBar = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 5px',
  'margin: 0',
  'padding: 7px 11px',
  `background: ${CHROME_BG}`,
  `border-bottom: 1px solid ${CHROME_BORDER}`,
].join('; ');
const dot = (c: string) =>
  ['width: 8px', 'height: 8px', 'margin: 0', 'border-radius: 999px', `background: ${c}`].join('; ');
const browserBody = [
  'box-sizing: border-box',
  'position: relative',
  'display: flex',
  'flex-direction: column',
  'gap: 9px',
  'margin: 0',
  'padding: 14px 15px 16px',
  `background: ${PAGE_BG}`,
].join('; ');
const textLine = (w: string) =>
  ['height: 6px', `width: ${w}`, 'margin: 0', 'border-radius: 999px', `background: ${TEXT_FILL}`].join('; ');

// the headline whose face swaps. position:relative so the naive-swap ghost can
// be drawn DISPLACED to its right at the same baseline. Extra bottom room holds
// the ghost's annotation without crowding the face tag below.
const headlineWrap = [
  'box-sizing: border-box',
  'position: relative',
  'display: flex',
  'align-items: baseline',
  'margin: 0 0 6px',
  'min-height: 48px',
].join('; ');
const headline = (face: string, color: string) =>
  [
    'margin: 0',
    `font-family: ${face}`,
    'font-size: 21px',
    'font-weight: 700',
    'line-height: 1.1',
    `color: ${color}`,
    'white-space: nowrap',
  ].join('; ');
// the faint ghost: where a NAIVE (unadjusted) swap would have pushed the text.
// Drawn in the real face as a faded, DISPLACED copy fully to the right of the
// real word (no overlap), dashed-underlined in red so it reads as "shifted".
const ghost = [
  'position: absolute',
  'left: 78px',
  'top: 0',
  'margin: 0',
  `font-family: ${realFace}`,
  'font-size: 21px',
  'font-weight: 700',
  'line-height: 1.1',
  `color: ${RED}`,
  'opacity: 0.3',
  'white-space: nowrap',
  `border-bottom: 1.5px dashed ${RED}`,
  'pointer-events: none',
].join('; ');
const ghostTag = [
  'position: absolute',
  'left: 78px',
  'top: 28px',
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9px',
  'font-weight: 700',
  'line-height: 1.2',
  `color: ${RED_INK}`,
  'opacity: 0.9',
  'white-space: nowrap',
].join('; ');

// little caption tag under the headline naming which face is painting.
const faceTag = (ink: string) =>
  [
    'display: inline-flex',
    'align-items: center',
    'gap: 5px',
    'align-self: flex-start',
    'margin: 0',
    'padding: 2px 8px',
    'border-radius: 999px',
    `border: 1px solid ${ink}`,
    `background: ${SURFACE}`,
    `color: ${ink}`,
    `font-family: ${sans}`,
    'font-size: 9.5px',
    'font-weight: 800',
    'line-height: 1.3',
    'white-space: nowrap',
  ].join('; ');

// the link line from the browser to "your origin" (step 2) — green, live.
const linkRow = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: row',
  'align-items: center',
  'justify-content: center',
  'flex-wrap: wrap',
  'gap: 8px',
  'margin: 0',
].join('; ');

const BRAND = 'Acme';
---

<DiagramSequence>
  {/* ============ Step 1 — Build time: the single round trip ============ */}
  <DiagramStep caption="At build time the font is fetched once and baked into your own origin. This is the only moment Google is ever contacted.">
    <div style={stage}>
      <div style={row}>
        {/* your project running next build */}
        <div style={box(OWN, OWN_BG)}>
          <span style={boxTitle(INK)}>Your project</span>
          <code style={boxSub(INK_SOFT)}>next build</code>
        </div>

        {/* the ONE round trip out to Google and back */}
        <div style={arrowCol}>
          <span style={pill(GREEN, '#fff')}>&#10003; fires once</span>
          <span style={arrowGlyph(GOOG, true)}>&rlarr;</span>
          <span style={arrowNote(INK_SOFT)}>fetch files + metrics</span>
        </div>

        {/* Google — GREEN/live: contacted this one time */}
        <div style={box(GOOG, GOOG_BG)}>
          <span style={boxTitle(GOOG_INK)}>Google Fonts</span>
          <span style={boxSub(GOOG_INK, sans)}>contacted once, at build</span>
        </div>

        {/* the baked output */}
        <div style={arrowCol}>
          <span style={arrowGlyph(OWN)}>&rarr;</span>
          <span style={arrowNote(INK_SOFT)}>emit</span>
        </div>

        <div style={box(GREEN, GREEN_BG)}>
          <span style={boxTitle(GREEN_INK)}>Self-hosted assets</span>
          <code style={boxSub(GREEN_INK)}>/_next/static/&hellip;</code>
        </div>
      </div>
    </div>
  </DiagramStep>

  {/* ============ Step 2 — First paint: only your origin ============ */}
  <DiagramStep caption="At runtime the visitor's browser only ever talks to your domain. Text paints instantly in a metric-matched fallback — no third-party request, no IP leak.">
    <div style={stage}>
      <div style={linkRow}>
        {/* the browser frame — text painted in the adjusted fallback face */}
        <div style={browser}>
          <div style={browserBar} aria-hidden="true">
            <span style={dot('#f87171')}></span>
            <span style={dot('#fbbf24')}></span>
            <span style={dot('#34d399')}></span>
          </div>
          <div style={browserBody}>
            <div style={headlineWrap}>
              <span style={headline(fallbackFace, INK)}>{BRAND}</span>
            </div>
            <span style={faceTag(INK_SOFT)}>adjusted fallback face</span>
            <span style={textLine('100%')} aria-hidden="true"></span>
            <span style={textLine('92%')} aria-hidden="true"></span>
            <span style={textLine('64%')} aria-hidden="true"></span>
          </div>
        </div>

        {/* live green link to your own origin */}
        <div style={arrowCol}>
          <span style={pill(GREEN, '#fff', false)}>only request</span>
          <span style={arrowGlyph(GREEN)}>&rarr;</span>
        </div>

        <div style={box(GREEN, GREEN_BG)}>
          <span style={boxTitle(GREEN_INK)}>Your origin</span>
          <span style={boxSub(GREEN_INK, sans)}>serves the font</span>
        </div>

        {/* Google — greyed-out, disconnected */}
        <div style={box(GOOG, GOOG_BG, true)}>
          <span style={boxTitle(GOOG_INK)}>Google Fonts</span>
          <span style={boxSub(GOOG_INK, sans)}>never contacted</span>
        </div>
      </div>
    </div>
  </DiagramStep>

  {/* ============ Step 3 — Swap: the real face, no shift ============ */}
  <DiagramStep caption="When the real font arrives, the swap is invisible — the fallback was pre-sized to match, so nothing reflows.">
    <div style={stage}>
      <div style={linkRow}>
        {/* the SAME browser frame, identical geometry — only the face changed */}
        <div style={browser}>
          <div style={browserBar} aria-hidden="true">
            <span style={dot('#f87171')}></span>
            <span style={dot('#fbbf24')}></span>
            <span style={dot('#34d399')}></span>
          </div>
          <div style={browserBody}>
            <div style={headlineWrap}>
              {/* ghost: where a naive, unadjusted swap WOULD have pushed it */}
              <span style={ghost} aria-hidden="true">{BRAND}</span>
              <span style={ghostTag} aria-hidden="true">where a naive swap would jump</span>
              {/* the real face, holding its exact position */}
              <span style={headline(realFace, INK)}>{BRAND}</span>
            </div>
            <span style={faceTag(GREEN_INK)}>&check; real font, no shift</span>
            <span style={textLine('100%')} aria-hidden="true"></span>
            <span style={textLine('92%')} aria-hidden="true"></span>
            <span style={textLine('64%')} aria-hidden="true"></span>
          </div>
        </div>

        <div style={box(GREEN, GREEN_BG)}>
          <span style={pill(GREEN, '#fff')}>&#10003; no layout shift</span>
        </div>
      </div>
    </div>
  </DiagramStep>
</DiagramSequence>
