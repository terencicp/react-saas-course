---
// The three-hop Tailwind bridge (diagram id: tailwind-bridge-flow, Chapter 034
// Lesson 4 — "Self-hosted fonts with next/font"). Makes the data-flow that the
// section's whole argument rests on glanceable, because the student's bug is
// always one broken hop. The hero is the single CSS custom property,
// `--font-display`, threaded as one saturated-teal token through all three
// boxes so the eye tracks the same variable from the font call, onto the
// document root, into the @theme alias that mints the utility.
//
//   Hop 1 "next/font call": `acmeDisplay.variable` is a className that, when
//     applied, sets `--font-display: '__acmeDisplay_abc'`. The variable is
//     BORN here.
//   Hop 2 "<html> element": `className={acmeDisplay.variable}` puts that
//     className on the root, so `--font-display` goes LIVE on the document and
//     inherits to every element.
//   Hop 3 "@theme in globals.css": `@theme inline { --font-display:
//     var(--font-display); }` aliases the live variable into a Tailwind theme
//     token, which MINTS the `font-display` utility class.
//   Terminal: the payoff chip — `<h1 className="font-display">` now resolves to
//     the self-hosted brand face anywhere on the page.
//
// Colour convention: the TEAL token (`--font-display`) is the through-line —
// the one thing that is literally the same across all three hops; everywhere it
// appears it is the same saturated teal so the read is "follow this variable".
// GREEN marks the terminal win (the utility now works), matching the chapter
// family. Neutral slate is inert scaffolding (box chrome, hop numbers, the
// non-variable code) and carries no meaning.
//
// House style follows the chapter-034 family (cls-reflow.astro,
// font-pipeline-sequence.astro): pinned `color-scheme: light` so the
// hand-picked tints survive dark mode, inline style strings only (a reader can
// copy the source and see exactly what styled it), `margin: 0` on every inner
// element to defeat Starlight's injected prose margin-top, box-sizing:
// border-box throughout. No leader lines, so the figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// inert scaffolding — neutral slate, carries no meaning.
const BOX_BORDER = '#cbd5e1'; // slate-300
const BOX_BG = '#f8fafc'; // slate-50
const CODE_BG = '#f1f5f9'; // slate-100 — code snippet plate
const ARROW = '#94a3b8'; // slate-400 — connectors

// TEAL — the through-line: the `--font-display` custom property itself.
const VAR = '#0d9488'; // teal-600
const VAR_INK = '#0f766e'; // teal-700
const VAR_BG = '#f0fdfa'; // teal-50 wash
const VAR_SOFT_BORDER = '#99f6e4'; // teal-200

// GREEN — the terminal win (the utility now resolves).
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_INK = '#15803d'; // green-700

// ---- outer stage: a horizontal strip of hops -----------------------------
const stage = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: row',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 6px',
  'row-gap: 16px',
  'margin: 0',
  'padding: 4px 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// one hop: a tall card, numbered, with a title, a code plate, and a sub line.
const hop = (accent: string, bg: string) =>
  [
    'box-sizing: border-box',
    'flex: 1 1 210px',
    'display: flex',
    'flex-direction: column',
    'align-items: stretch',
    'gap: 9px',
    'margin: 0',
    'padding: 13px 14px 14px',
    'border-radius: 13px',
    `border: 1.5px solid ${accent}`,
    `background: ${bg}`,
    'min-width: 200px',
    'max-width: 280px',
  ].join('; ');

// the header row of a hop: a numbered chip + the artifact name.
const hopHead = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 8px',
  'margin: 0',
].join('; ');
const hopNum = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'justify-content: center',
  'flex: 0 0 auto',
  'width: 20px',
  'height: 20px',
  'margin: 0',
  'border-radius: 999px',
  `background: ${INK}`,
  'color: #ffffff',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 800',
  'line-height: 1',
].join('; ');
const hopTitle = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 13px',
  'font-weight: 800',
  'line-height: 1.2',
  `color: ${INK}`,
].join('; ');

// inline <code> used inside titles / sub-lines: strip Starlight's pill so the
// monospace token sits flush in the sentence. `ink` colours it per context.
const inlineCode = (ink: string, weight = 700) =>
  [
    'margin: 0',
    'padding: 0',
    'background: transparent',
    `font-family: ${mono}`,
    'font-size: 0.95em',
    `font-weight: ${weight}`,
    `color: ${ink}`,
  ].join('; ');

// a code plate inside a hop — monospace snippet on a faint slate ground. A
// column of code lines so we never depend on in-string newlines.
const plate = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: flex-start',
  'gap: 2px',
  'margin: 0',
  'padding: 8px 9px',
  'border-radius: 8px',
  `border: 1px solid ${BOX_BORDER}`,
  `background: ${CODE_BG}`,
  `font-family: ${mono}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'line-height: 1.5',
  `color: ${INK}`,
  'min-width: 0',
  'width: 100%',
].join('; ');
// one code line on the plate — a baseline-aligned run of fragments + tokens.
const codeLine = [
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: baseline',
  'gap: 0',
  'margin: 0',
  'min-width: 0',
].join('; ');
// a neutral code fragment on a line (the non-variable scaffolding code).
const codeNeutral = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'line-height: 1.5',
  `color: ${INK_SOFT}`,
  'white-space: pre-wrap',
  'overflow-wrap: anywhere',
].join('; ');
// THE token — `--font-display` — rendered identically wherever it appears so it
// reads as one variable threading through every hop.
const tokenInline = [
  'box-sizing: border-box',
  'display: inline-block',
  'margin: 0',
  'padding: 1px 5px',
  'border-radius: 5px',
  `border: 1px solid ${VAR_SOFT_BORDER}`,
  `background: ${VAR_BG}`,
  `color: ${VAR_INK}`,
  `font-family: ${mono}`,
  'font-size: 11.5px',
  'font-weight: 800',
  'line-height: 1.4',
  'white-space: nowrap',
].join('; ');

// the one-line "what this hop does" caption under the plate.
const hopSub = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 600',
  'line-height: 1.4',
  `color: ${INK_SOFT}`,
].join('; ');

// a small teal tag naming the variable's state at this hop (born / live).
const stateTag = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'align-self: flex-start',
  'gap: 5px',
  'margin: 0',
  'padding: 2px 8px',
  'border-radius: 999px',
  `background: ${VAR}`,
  'color: #ffffff',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.03em',
  'line-height: 1.3',
  'white-space: nowrap',
].join('; ');
// the terminal win tag (green) — the utility now resolves.
const winTag = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'align-self: flex-start',
  'gap: 5px',
  'margin: 0',
  'padding: 2px 8px',
  'border-radius: 999px',
  `background: ${GREEN}`,
  'color: #ffffff',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.03em',
  'line-height: 1.3',
  'white-space: nowrap',
].join('; ');

// a horizontal arrow connector carrying the variable from one hop to the next.
const arrowCol = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 3px',
  'margin: 0',
  'align-self: center',
].join('; ');
const arrowGlyph = [
  'margin: 0',
  `color: ${VAR}`,
  'font-size: 22px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');
const arrowNote = [
  'box-sizing: border-box',
  'max-width: 64px',
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9px',
  'font-weight: 700',
  'text-transform: uppercase',
  'letter-spacing: 0.03em',
  'line-height: 1.25',
  'text-align: center',
  `color: ${INK_SOFT}`,
].join('; ');

const TOKEN = '--font-display';
---

<Figure
  expandable={false}
  caption="The font call and your Tailwind theme meet at one CSS variable. Set it on <html>, alias it in @theme, then use font-display anywhere."
>
  <div style={stage}>
    {/* ============ Hop 1 — the next/font call mints the variable ============ */}
    <div style={hop(VAR, VAR_BG)}>
      <div style={hopHead}>
        <span style={hopNum}>1</span>
        <p style={hopTitle}>
          <code style={inlineCode(INK, 800)}>next/font</code> call
        </p>
      </div>
      <div style={plate}>
        <div style={codeLine}>
          <span style={codeNeutral}>acmeDisplay.variable</span>
        </div>
        <div style={codeLine}>
          <span style={codeNeutral}>&rarr;&nbsp;</span>
          <span style={tokenInline}>{TOKEN}</span>
          <span style={codeNeutral}>{': '}</span>
          <span style={codeNeutral}>{"'__acmeDisplay_abc'"}</span>
        </div>
      </div>
      <span style={stateTag}>variable born</span>
      <p style={hopSub}>
        The <code style={inlineCode(VAR_INK)}>.variable</code> className carries the custom property.
      </p>
    </div>

    {/* arrow 1 → 2 */}
    <div style={arrowCol} aria-hidden="true">
      <span style={arrowGlyph}>&rarr;</span>
      <span style={arrowNote}>applied to</span>
    </div>

    {/* ============ Hop 2 — <html> makes it live + inherited ============ */}
    <div style={hop(VAR, VAR_BG)}>
      <div style={hopHead}>
        <span style={hopNum}>2</span>
        <p style={hopTitle}>
          <code style={inlineCode(INK, 800)}>{'<html>'}</code> element
        </p>
      </div>
      <div style={plate}>
        <div style={codeLine}>
          <span style={codeNeutral}>{'<html className={'}</span>
        </div>
        <div style={codeLine}>
          <span style={codeNeutral}>&nbsp;&nbsp;acmeDisplay.variable</span>
          <span style={codeNeutral}>{'}>'}</span>
        </div>
      </div>
      <span style={stateTag}>live on the root</span>
      <p style={hopSub}>
        <code style={inlineCode(VAR_INK)}>{TOKEN}</code> is now set on the document and inherits everywhere.
      </p>
    </div>

    {/* arrow 2 → 3 */}
    <div style={arrowCol} aria-hidden="true">
      <span style={arrowGlyph}>&rarr;</span>
      <span style={arrowNote}>read by</span>
    </div>

    {/* ============ Hop 3 — @theme aliases it into a utility ============ */}
    <div style={hop(VAR, VAR_BG)}>
      <div style={hopHead}>
        <span style={hopNum}>3</span>
        <p style={hopTitle}>
          <code style={inlineCode(INK, 800)}>@theme</code> in globals.css
        </p>
      </div>
      <div style={plate}>
        <div style={codeLine}>
          <span style={codeNeutral}>{'@theme inline {'}</span>
        </div>
        <div style={codeLine}>
          <span style={codeNeutral}>&nbsp;&nbsp;</span>
          <span style={tokenInline}>{TOKEN}</span>
          <span style={codeNeutral}>{': var('}</span>
          <span style={tokenInline}>{TOKEN}</span>
          <span style={codeNeutral}>{');'}</span>
        </div>
        <div style={codeLine}>
          <span style={codeNeutral}>{'}'}</span>
        </div>
      </div>
      <span style={winTag}>&check; mints font-display</span>
      <p style={hopSub}>
        Tailwind aliases the variable into a theme token and generates the
        <code style={inlineCode(GREEN_INK)}> font-display</code> class.
      </p>
    </div>
  </div>
</Figure>
