---
// MetadataMergeLadder (diagram id: metadata-merge-ladder, Chapter 034 Lesson 6 —
// "Metadata and dynamic OG cards"). Makes the merge-down model visible: Next
// evaluates `metadata` root-first, shallow-merges each segment down to the leaf,
// and a child key REPLACES the parent's key. The resolved <head> is the
// composite of whichever segment won each key.
//
// Layout — two columns inside one stage:
//   LEFT  = the merge ladder. Three stacked, colour-coded file segments with a
//           downward arrow between each ("merges down"):
//             1. app/layout.tsx       — BRAND DEFAULTS (blue). Sets title.template,
//                metadataBase, openGraph.siteName.
//             2. app/(app)/layout.tsx — ROUTE GROUP, no metadata (slate, muted).
//                Pass-through: it inherits and sets nothing.
//             3. .../invoices/[id]/page.tsx — PAGE-SPECIFIC (violet). Sets a plain
//                title and a description.
//   RIGHT = a single "Resolved <head>" output box (green "output" frame). Each
//           emitted tag is tinted to the SEGMENT that contributed it, so the
//           student can trace provenance: <title> blends the page's title into the
//           root's template (a left blue rule + violet rule on the row), the
//           description is the page's (violet), og:site_name survived from the
//           root (blue). A single arrow bridges the bottom of the ladder across to
//           this box — "resolves to".
//
// Colour is load-bearing (provenance): BLUE = the root layout / brand defaults;
// VIOLET = the leaf page / page-specific; SLATE = the pass-through route group;
// GREEN = the resolved output frame. The provenance rule on each <head> row is
// the whole point — it shows child-replaces-parent (description, title segment)
// AND a parent field surviving untouched (og:site_name).
//
// House style follows the ch 032/033 HTML-CSS family (two-cache-layers,
// StaticChromeDynamicTable): pinned `color-scheme: light` so the hand-picked
// tints survive dark mode, `margin: 0` on every inner element to defeat
// Starlight's injected prose margin-top, inline style strings only (no <style>),
// box-sizing: border-box throughout, fieldset-legend pills straddling segment
// borders. No leader lines, so the figure stays expandable. Wrapped in <Figure>.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// ROOT layout / brand defaults — blue.
const BLUE = '#2563eb'; // blue-600
const BLUE_BG = '#eff6ff'; // blue-50 wash
const BLUE_EDGE = '#93c5fd'; // blue-300
const BLUE_INK = '#1e40af'; // blue-800

// ROUTE GROUP — slate (pass-through, sets nothing).
const SLATE = '#64748b'; // slate-500
const SLATE_BG = '#f8fafc'; // slate-50 wash
const SLATE_EDGE = '#cbd5e1'; // slate-300
const SLATE_INK = '#475569'; // slate-600

// LEAF page / page-specific — violet.
const VIO = '#7c3aed'; // violet-600
const VIO_BG = '#f5f3ff'; // violet-50 wash
const VIO_EDGE = '#c4b5fd'; // violet-300
const VIO_INK = '#5b21b6'; // violet-800

// RESOLVED output frame — green.
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_EDGE = '#86efac'; // green-300
const GREEN_INK = '#15803d'; // green-700

// ---- outer stage: ladder | resolved box -----------------------------------
const stage = [
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 0',
  'row-gap: 22px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// ---- LEFT column: the merge ladder ----------------------------------------
const ladder = [
  'box-sizing: border-box',
  'flex: 1 1 300px',
  'display: flex',
  'flex-direction: column',
  'align-items: stretch',
  'gap: 0',
  'margin: 0',
  'padding: 0',
  'min-width: 268px',
  'max-width: 360px',
].join('; ');

// A file segment in the ladder. accent tints the frame; a legend pill straddles
// the top border.
const segment = (edge: string, bg: string) =>
  [
    'box-sizing: border-box',
    'position: relative',
    'display: flex',
    'flex-direction: column',
    'gap: 6px',
    'margin: 0',
    'padding: 22px 14px 13px',
    'border-radius: 12px',
    `border: 1.5px solid ${edge}`,
    `background: ${bg}`,
  ].join('; ');

// The filename row at the top of each segment.
const fileName = (ink: string) =>
  [
    'box-sizing: border-box',
    'display: inline-flex',
    'align-items: center',
    'gap: 7px',
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 13px',
    'font-weight: 800',
    'line-height: 1.25',
    `color: ${ink}`,
    'word-break: break-word',
  ].join('; ');

// The "fieldset legend" pill that names each segment's role, straddling its top
// border. Background matches the Figure card so it visibly breaks the border.
const rolePill = (accent: string, ink: string) =>
  [
    'position: absolute',
    'top: 0',
    'right: 12px',
    'transform: translateY(-50%)',
    'display: block',
    'width: fit-content',
    'margin: 0',
    'padding: 3px 10px',
    'border-radius: 999px',
    `border: 1.5px solid ${accent}`,
    `background: var(--sl-color-bg-sidebar, ${SURFACE})`,
    `color: ${ink}`,
    `font-family: ${sans}`,
    'font-size: 10px',
    'font-weight: 800',
    'text-transform: uppercase',
    'letter-spacing: 0.04em',
    'line-height: 1.4',
    'white-space: nowrap',
  ].join('; ');

// A body line of metadata inside a segment (mono key: value).
const bodyLine = (ink: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'align-items: baseline',
    'gap: 6px',
    'margin: 0',
    `font-family: ${mono}`,
    'font-size: 11.5px',
    'font-weight: 600',
    'line-height: 1.4',
    `color: ${ink}`,
    'word-break: break-word',
  ].join('; ');
const bodyKey = (accent: string) =>
  [
    'flex: 0 0 auto',
    'margin: 0',
    'font-weight: 800',
    `color: ${accent}`,
  ].join('; ');

// "inherits — sets nothing" note for the pass-through route group.
const inheritNote = [
  'box-sizing: border-box',
  'display: inline-flex',
  'align-items: center',
  'gap: 7px',
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'font-style: italic',
  'line-height: 1.35',
  `color: ${SLATE_INK}`,
].join('; ');
const inheritDash = [
  'flex: 0 0 auto',
  'display: inline-block',
  'width: 14px',
  'height: 0',
  'margin: 0',
  `border-top: 2px dashed ${SLATE}`,
].join('; ');

// The "merges down" connector between two segments — a vertical arrow with a
// micro-label.
const downConnector = [
  'display: flex',
  'align-items: center',
  'justify-content: center',
  'gap: 8px',
  'margin: 0',
  'padding: 6px 0',
].join('; ');
const downArrow = [
  'margin: 0',
  `color: ${INK_SOFT}`,
  'font-size: 18px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');
const downLabel = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.05em',
  'line-height: 1.3',
  `color: ${INK_SOFT}`,
  'white-space: nowrap',
].join('; ');

// ---- the bridge: ladder bottom -> resolved box ----------------------------
// A horizontal "resolves to" arrow that sits between the two columns. On wrap it
// rotates implicitly by reading as a down-arrow row; we keep a right-arrow glyph
// and let it center in the gutter.
const bridge = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'justify-content: center',
  'gap: 3px',
  'margin: 0',
  'padding: 0 6px',
  'align-self: center',
].join('; ');
const bridgeLabel = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.05em',
  'line-height: 1.3',
  `color: ${GREEN_INK}`,
  'white-space: nowrap',
  'text-align: center',
].join('; ');
const bridgeArrow = [
  'margin: 0',
  `color: ${GREEN}`,
  'font-size: 26px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');

// ---- RIGHT column: the resolved <head> ------------------------------------
const resolved = [
  'box-sizing: border-box',
  'position: relative',
  'flex: 1 1 300px',
  'display: flex',
  'flex-direction: column',
  'gap: 9px',
  'margin: 0',
  'padding: 24px 13px 13px',
  'border-radius: 14px',
  `border: 2px solid ${GREEN}`,
  `background: ${GREEN_BG}`,
  'min-width: 268px',
  'max-width: 360px',
].join('; ');
const resolvedPill = [
  'position: absolute',
  'top: 0',
  'left: 14px',
  'transform: translateY(-50%)',
  'display: block',
  'width: fit-content',
  'margin: 0',
  'padding: 4px 12px',
  'border-radius: 999px',
  `background: ${GREEN}`,
  'color: #ffffff',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 800',
  'line-height: 1.3',
  'white-space: nowrap',
  `box-shadow: 0 0 0 3px var(--sl-color-bg-sidebar, ${GREEN_BG})`,
].join('; ');

// A single emitted <head> tag row. A left colour rule (or two stacked rules)
// names the source segment(s) — the provenance signal.
const tagRow = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: stretch',
  'gap: 9px',
  'margin: 0',
  'padding: 0',
].join('; ');
// the provenance rules sit in a fixed-width gutter at the left of each row.
const ruleGutter = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'align-items: stretch',
  'gap: 3px',
  'width: 12px',
  'margin: 0',
  'padding: 0',
].join('; ');
const rule = (c: string) =>
  [
    'display: block',
    'flex: 0 0 auto',
    'width: 4px',
    'margin: 0',
    'border-radius: 999px',
    `background: ${c}`,
  ].join('; ');
const tagBox = [
  'box-sizing: border-box',
  'flex: 1 1 auto',
  'margin: 0',
  'padding: 7px 11px',
  'border-radius: 8px',
  `border: 1px solid ${GREEN_EDGE}`,
  `background: ${SURFACE}`,
  `font-family: ${mono}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'line-height: 1.4',
  `color: ${INK}`,
  'word-break: break-word',
  'min-width: 0',
].join('; ');
// inline span colouring the contributed fragment within a tag.
const frag = (c: string) => `color: ${c}; font-weight: 800;`;

// provenance legend under the resolved box.
const provLegend = [
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'gap: 4px 14px',
  'margin: 3px 0 0',
  'padding: 0',
].join('; ');
const provItem = [
  'display: inline-flex',
  'align-items: center',
  'gap: 6px',
  'margin: 0',
].join('; ');
const provSwatch = (c: string) =>
  [
    'display: inline-block',
    'flex: 0 0 auto',
    'width: 4px',
    'height: 13px',
    'margin: 0',
    'border-radius: 999px',
    `background: ${c}`,
  ].join('; ');
const provText = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 10.5px',
    'font-weight: 700',
    'line-height: 1.3',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');
---

<Figure
  caption="Metadata is evaluated root-first and shallow-merged down to the leaf; a child key replaces the parent's. The resolved <head> is the composite — coloured here by which file contributed each tag. Because the merge is shallow, a page that sets any openGraph field replaces the parent's openGraph wholesale."
>
  <div style={stage}>
    {/* ============ LEFT — the merge ladder ============ */}
    <div style={ladder}>
      {/* 1. root layout — brand defaults (blue) */}
      <div style={segment(BLUE_EDGE, BLUE_BG)}>
        <span style={rolePill(BLUE, BLUE_INK)}>brand defaults</span>
        <p style={fileName(BLUE_INK)}>app/layout.tsx</p>
        <p style={bodyLine(INK)}>
          <span style={bodyKey(BLUE)}>title.template:</span>
          <span>{"'%s — Acme'"}</span>
        </p>
        <p style={bodyLine(INK)}>
          <span style={bodyKey(BLUE)}>metadataBase</span>
        </p>
        <p style={bodyLine(INK)}>
          <span style={bodyKey(BLUE)}>openGraph:</span>
          <span>{'{ siteName }'}</span>
        </p>
      </div>

      <div style={downConnector} aria-hidden="true">
        <span style={downArrow}>&darr;</span>
        <span style={downLabel}>merges down</span>
      </div>

      {/* 2. route group — pass-through (slate) */}
      <div style={segment(SLATE_EDGE, SLATE_BG)}>
        <span style={rolePill(SLATE, SLATE_INK)}>route group</span>
        <p style={fileName(SLATE_INK)}>app/(app)/layout.tsx</p>
        <p style={inheritNote}>
          <span style={inheritDash} aria-hidden="true"></span>
          inherits &mdash; sets nothing
        </p>
      </div>

      <div style={downConnector} aria-hidden="true">
        <span style={downArrow}>&darr;</span>
        <span style={downLabel}>merges down</span>
      </div>

      {/* 3. leaf page — page-specific (violet) */}
      <div style={segment(VIO_EDGE, VIO_BG)}>
        <span style={rolePill(VIO, VIO_INK)}>page-specific</span>
        <p style={fileName(VIO_INK)}>app/(app)/invoices/[id]/page.tsx</p>
        <p style={bodyLine(INK)}>
          <span style={bodyKey(VIO)}>title:</span>
          <span>{"'Invoice INV-1042'"}</span>
        </p>
        <p style={bodyLine(INK)}>
          <span style={bodyKey(VIO)}>description</span>
        </p>
      </div>
    </div>

    {/* ============ the bridge: resolves to ============ */}
    <div style={bridge} aria-hidden="true">
      <span style={bridgeLabel}>resolves<br />to</span>
      <span style={bridgeArrow}>&rarr;</span>
    </div>

    {/* ============ RIGHT — the resolved <head> ============ */}
    <div style={resolved}>
      <span style={resolvedPill}>Resolved &lt;head&gt;</span>

      {/* <title>: page's segment dropped into root's template — both contribute */}
      <div style={tagRow}>
        <div style={ruleGutter} aria-hidden="true">
          <span style={rule(BLUE)}></span>
          <span style={rule(VIO)}></span>
        </div>
        <div style={tagBox}>
          &lt;title&gt;<span style={frag(VIO_INK)}>Invoice INV-1042</span>
          <span style={frag(BLUE_INK)}> &mdash; Acme</span>&lt;/title&gt;
        </div>
      </div>

      {/* description: the page's, replacing the root's */}
      <div style={tagRow}>
        <div style={ruleGutter} aria-hidden="true">
          <span style={rule(VIO)}></span>
        </div>
        <div style={tagBox}>
          &lt;meta name=<span style={frag(VIO_INK)}>"description"</span> &hellip;&gt;
        </div>
      </div>

      {/* og:site_name: survived untouched from the root */}
      <div style={tagRow}>
        <div style={ruleGutter} aria-hidden="true">
          <span style={rule(BLUE)}></span>
        </div>
        <div style={tagBox}>
          &lt;meta property="og:site_name" content=<span style={frag(BLUE_INK)}>"Acme"</span>&gt;
        </div>
      </div>

      {/* provenance legend */}
      <div style={provLegend}>
        <span style={provItem}>
          <span style={provSwatch(BLUE)} aria-hidden="true"></span>
          <span style={provText(BLUE_INK)}>from root layout</span>
        </span>
        <span style={provItem}>
          <span style={provSwatch(VIO)} aria-hidden="true"></span>
          <span style={provText(VIO_INK)}>from the page</span>
        </span>
      </div>
    </div>
  </div>
</Figure>
