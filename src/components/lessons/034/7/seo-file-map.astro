---
// seo-file-map (diagram id: seo-file-map, Chapter 034 Lesson 7 —
// "Robots, sitemaps, icons, viewport"). The anchor / table-of-contents diagram
// for the whole lesson: a glanceable mapping from each framework-named file in
// `app/` to the site-level artifact the platform emits for it. Every later
// section "fills in a cell" of this map.
//
// Layout — a single three-track CSS grid acting as a styled two-column table:
//   LEFT  column  = the file in `app/` (monospace, code-styled).
//   MIDDLE column = a thin neutral arrow (→), aligned in its own track so every
//                   arrow stacks into one vertical lane.
//   RIGHT column  = what the platform emits — the served URL or the injected
//                   <head> tag (muted sans text, code spans for tags/paths).
// A header row spans the two label columns. Rows are separated by hairline
// rules so it reads as a reference table, not prose.
//
// The `opengraph-image.png` row is the RECAP row (covered last lesson, shown
// here for completeness) — it is dimmed and italicised, with a small "recap"
// tag, to signal "already covered." `export const viewport` is not a standalone
// file but an export inside layout.tsx; it sits in the left column in monospace
// like the rest because the student reasons about it as one more entry in the
// same map.
//
// Colour is NOT load-bearing here — this is a neutral reference map, so it uses
// Starlight CSS variables throughout (chrome borders, muted backgrounds, code
// pills) so the whole thing flips cleanly between light and dark and feels
// native to the docs. The lesson pairs this grid (below) with a <FileTree> of
// the same `app/` slice (above), both inside one <Figure>.
//
// House style follows ch 034/1 config-surface-map: inline style strings built
// from a shared `reset` (margin: 0) to defeat Starlight's injected prose
// margin-top, box-sizing: border-box throughout, no <style> tag for layout,
// `not-content` root, Starlight theme variables. No leader lines, so the figure
// stays expandable.

const reset = 'margin: 0';
const mono =
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = 'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';

const ARROW = 'var(--sl-color-gray-3)'; // thin, neutral "emits"

// Outer container — not-content, centered, capped well under the 800px ceiling.
const root = [
  reset,
  sans,
  'box-sizing: border-box',
  'width: 100%',
  'max-width: 680px',
  'margin-inline: auto',
].join('; ');

// The table grid: file | arrow | emitted artifact.
const grid = [
  reset,
  'box-sizing: border-box',
  'display: grid',
  'grid-template-columns: max-content max-content 1fr',
  'align-items: center',
  'column-gap: 14px',
  'row-gap: 0',
].join('; ');

// Header cells — small, uppercase, muted; the left header spans file + arrow.
const headFile = [
  reset,
  sans,
  'grid-column: 1 / 3',
  'font-size: 11px',
  'font-weight: 700',
  'letter-spacing: 0.04em',
  'text-transform: uppercase',
  'color: var(--sl-color-gray-3)',
  'padding: 0 0 7px',
].join('; ');

const headEmit = [
  reset,
  sans,
  'grid-column: 3',
  'font-size: 11px',
  'font-weight: 700',
  'letter-spacing: 0.04em',
  'text-transform: uppercase',
  'color: var(--sl-color-gray-3)',
  'padding: 0 0 7px',
].join('; ');

// A cell in a body row. `dim` softens the recap row.
const fileCell = (dim: boolean) =>
  [
    reset,
    mono,
    'box-sizing: border-box',
    'grid-column: 1',
    'font-size: 13px',
    'font-weight: 600',
    'line-height: 1.3',
    'white-space: nowrap',
    `color: ${dim ? 'var(--sl-color-gray-3)' : 'var(--sl-color-white)'}`,
    `font-style: ${dim ? 'italic' : 'normal'}`,
    'padding: 9px 0',
    `border-top: 1px solid ${'var(--sl-color-gray-5)'}`,
  ].join('; ');

const arrowCell = (dim: boolean) =>
  [
    reset,
    'box-sizing: border-box',
    'grid-column: 2',
    'font-size: 15px',
    'line-height: 1',
    'text-align: center',
    `color: ${dim ? 'var(--sl-color-gray-4)' : ARROW}`,
    'padding: 9px 0',
    'border-top: 1px solid var(--sl-color-gray-5)',
  ].join('; ');

const emitCell = (dim: boolean) =>
  [
    reset,
    sans,
    'box-sizing: border-box',
    'grid-column: 3',
    'display: flex',
    'align-items: center',
    'flex-wrap: wrap',
    'gap: 5px',
    'font-size: 12.5px',
    'line-height: 1.4',
    `color: ${dim ? 'var(--sl-color-gray-3)' : 'var(--sl-color-gray-2)'}`,
    `font-style: ${dim ? 'italic' : 'normal'}`,
    'padding: 9px 0',
    'border-top: 1px solid var(--sl-color-gray-5)',
  ].join('; ');

// A served-at URL or an injected <head> tag, rendered as a code pill.
const codeOut = [
  reset,
  mono,
  'box-sizing: border-box',
  'font-size: 11.5px',
  'font-weight: 500',
  'line-height: 1.35',
  'padding: 1.5px 6px',
  'border-radius: 5px',
  'color: var(--sl-color-gray-1)',
  'background: var(--sl-color-gray-6)',
  'border: 1px solid var(--sl-color-gray-5)',
].join('; ');

const muted = [reset, sans, 'color: var(--sl-color-gray-3)'].join('; ');

const recapTag = [
  reset,
  sans,
  'font-size: 10px',
  'font-weight: 700',
  'letter-spacing: 0.04em',
  'text-transform: uppercase',
  'font-style: normal',
  'padding: 1px 6px',
  'border-radius: 999px',
  'color: var(--sl-color-gray-2)',
  'background: var(--sl-color-gray-6)',
  'border: 1px solid var(--sl-color-gray-5)',
].join('; ');

// Each row: the file on the left, the emitted artifact on the right described as
// a list of parts. A part is either { code } (a code pill) or { text } (muted
// connective prose). `dim` flags the recap row.
type Part = { code: string } | { text: string };
type Row = { file: string; parts: Part[]; dim?: boolean };

const rows: Row[] = [
  { file: 'robots.ts', parts: [{ text: 'served at' }, { code: '/robots.txt' }] },
  { file: 'sitemap.ts', parts: [{ text: 'served at' }, { code: '/sitemap.xml' }] },
  {
    file: 'favicon.ico',
    parts: [{ code: '<link rel="icon" href="/favicon.ico" sizes="any">' }],
  },
  {
    file: 'icon.png',
    parts: [
      { code: '<link rel="icon" href="/icon?…">' },
      { text: '— size + type inferred' },
    ],
  },
  {
    file: 'apple-icon.png',
    parts: [{ code: '<link rel="apple-touch-icon" href="/apple-icon?…">' }],
  },
  {
    file: 'manifest.ts',
    parts: [
      { code: '<link rel="manifest">' },
      { text: '+ served at' },
      { code: '/manifest.webmanifest' },
    ],
  },
  {
    file: 'opengraph-image.png',
    parts: [{ code: 'og:image' }],
    dim: true,
  },
  {
    file: 'export const viewport',
    parts: [
      { code: '<meta name="viewport">' },
      { text: '+' },
      { code: '<meta name="theme-color">' },
    ],
  },
];
---

<div class="not-content sfm" style={root}>
  <div style={grid}>
    {/* ---- header --------------------------------------------------- */}
    <div style={headFile}>
      File in <code style={`${codeOut}; font-size: 10.5px; padding: 0.5px 5px;`}>app/</code>
    </div>
    <div style={headEmit}>What the platform emits</div>

    {/* ---- body rows ------------------------------------------------ */}
    {
      rows.map((r) => (
        <>
          <code style={fileCell(!!r.dim)}>{r.file}</code>
          <div style={arrowCell(!!r.dim)} aria-hidden="true">
            →
          </div>
          <div style={emitCell(!!r.dim)}>
            {r.parts.map((p) =>
              'code' in p ? (
                <code style={codeOut}>{p.code}</code>
              ) : (
                <span style={muted}>{p.text}</span>
              ),
            )}
            {r.dim && <span style={recapTag}>recap</span>}
          </div>
        </>
      ))
    }
  </div>
</div>

<style>
  /* The three-track grid is the whole figure. On narrow viewports let it scroll
     rather than crushing the columns (laptop viewports — the design target —
     show it whole). */
  @media (max-width: 560px) {
    .sfm {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .sfm > div {
      min-width: 480px;
    }
  }
</style>
