---
// icon-conventions-table (diagram id: icon-conventions-table, Chapter 034
// Lesson 7 — "Robots, sitemaps, icons, viewport"). A compact three-column
// reference table for the three icon file conventions: which filename, which
// image formats it accepts, and which <head> tag the platform injects for it.
//
// This is a sibling reference table to `seo-file-map.astro` from earlier in the
// same lesson, so it deliberately reuses that file's house style — a single CSS
// grid acting as a styled table, monospace code pills, Starlight theme
// variables, `not-content` root, inline style strings off a shared `reset` to
// defeat Starlight's injected prose margin-top, `box-sizing: border-box`
// throughout, no <style> tag for layout. Colour is NOT load-bearing (neutral
// reference), so everything flips cleanly between light and dark.
//
// Layout — three grid tracks:
//   LEFT   "Filename"  = the reserved filename (monospace, code pill).
//   MIDDLE "Formats"   = the accepted image extensions, each a small mono pill,
//                        plus a muted qualifier where it matters ("only" for the
//                        single-format favicon, "(raster only)" for apple-icon).
//   RIGHT  "Emits"     = the injected <link> tag, as a code pill; for `icon.*`
//                        a muted "type + sizes inferred from the file" note.
// A header row labels the three tracks. Rows are separated by hairline rules so
// it reads as a reference table, not prose. Every cell carries margin: 0.

const reset = 'margin: 0';
const mono =
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = 'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';

// Outer container — not-content, centered, capped well under the 800px ceiling.
const root = [
  reset,
  sans,
  'box-sizing: border-box',
  'width: 100%',
  'max-width: 720px',
  'margin-inline: auto',
].join('; ');

// The table grid: filename | formats | emitted tag.
const grid = [
  reset,
  'box-sizing: border-box',
  'display: grid',
  'grid-template-columns: max-content max-content 1fr',
  'align-items: start',
  'column-gap: 18px',
  'row-gap: 0',
].join('; ');

// Header cells — small, uppercase, muted.
const head = (col: number) =>
  [
    reset,
    sans,
    `grid-column: ${col}`,
    'font-size: 11px',
    'font-weight: 700',
    'letter-spacing: 0.04em',
    'text-transform: uppercase',
    'color: var(--sl-color-gray-3)',
    'padding: 0 0 7px',
  ].join('; ');

// A body cell. `col` places it; rows get a hairline top rule.
const cell = (col: number) =>
  [
    reset,
    'box-sizing: border-box',
    `grid-column: ${col}`,
    'padding: 10px 0',
    'border-top: 1px solid var(--sl-color-gray-5)',
  ].join('; ');

// Filename pill — monospace, slightly emphasised (it is the row's key).
const fileCell = [
  cell(1),
  mono,
  'font-size: 13px',
  'font-weight: 600',
  'line-height: 1.3',
  'white-space: nowrap',
  'color: var(--sl-color-white)',
].join('; ');

// Formats cell — a flex row of extension pills + an optional qualifier.
const formatsCell = [
  cell(2),
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'gap: 5px',
].join('; ');

// Emits cell — the injected tag pill + an optional muted note.
const emitCell = [
  cell(3),
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'gap: 6px',
].join('; ');

// A small monospace pill for an extension or an injected tag.
const pill = [
  reset,
  mono,
  'box-sizing: border-box',
  'font-size: 11.5px',
  'font-weight: 500',
  'line-height: 1.35',
  'white-space: nowrap',
  'padding: 1.5px 6px',
  'border-radius: 5px',
  'color: var(--sl-color-gray-1)',
  'background: var(--sl-color-gray-6)',
  'border: 1px solid var(--sl-color-gray-5)',
].join('; ');

// The emitted <link> tag wraps on long values, so it relaxes white-space.
const tagPill = [pill, 'white-space: normal', 'word-break: break-word'].join('; ');

// Muted connective / qualifier prose.
const muted = [
  reset,
  sans,
  'font-size: 12px',
  'line-height: 1.4',
  'color: var(--sl-color-gray-3)',
].join('; ');

type Row = {
  file: string;
  formats: string[]; // extension pills
  formatNote?: string; // muted qualifier after the pills
  tag: string; // the injected <link> tag
  emitNote?: string; // muted note after the tag
};

const rows: Row[] = [
  {
    file: 'favicon.ico',
    formats: ['.ico'],
    formatNote: 'only',
    tag: '<link rel="icon" href="/favicon.ico" sizes="any">',
  },
  {
    file: 'icon.*',
    formats: ['.ico', '.jpg', '.jpeg', '.png', '.svg'],
    tag: '<link rel="icon">',
    emitNote: 'type + sizes inferred from the file',
  },
  {
    file: 'apple-icon.*',
    formats: ['.jpg', '.jpeg', '.png'],
    formatNote: '(raster only)',
    tag: '<link rel="apple-touch-icon">',
  },
];
---

<div class="not-content ict" style={root}>
  <div style={grid}>
    {/* ---- header --------------------------------------------------- */}
    <div style={head(1)}>Filename</div>
    <div style={head(2)}>Formats</div>
    <div style={head(3)}>Emits</div>

    {/* ---- body rows ------------------------------------------------ */}
    {
      rows.map((r) => (
        <>
          <code style={fileCell}>{r.file}</code>
          <div style={formatsCell}>
            {r.formats.map((f) => (
              <code style={pill}>{f}</code>
            ))}
            {r.formatNote && <span style={muted}>{r.formatNote}</span>}
          </div>
          <div style={emitCell}>
            <code style={tagPill}>{r.tag}</code>
            {r.emitNote && <span style={muted}>{r.emitNote}</span>}
          </div>
        </>
      ))
    }
  </div>
</div>

<style>
  /* The three-track grid is the whole figure. On narrow viewports let it scroll
     rather than crushing the columns (laptop viewports — the design target —
     show it whole). */
  @media (max-width: 600px) {
    .ict {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .ict > div {
      min-width: 520px;
    }
  }
</style>
