---
// config-surface-map — Chapter 034 Lesson 1, the chapter's table of contents
// drawn as a map. A single central `next.config.ts` hub on the LEFT, five group
// boxes stacked on the RIGHT — one per *kind* of config key — each listing its
// keys and tagged with the lesson that owns it. Thin neutral leader-line arrows
// fan from the hub's right edge to each box's left edge, so the whole surface
// reads as "everything radiates from this one file."
//
// The arrows are deliberately neutral (a single muted slate) — they carry pure
// "belongs to" correspondence, not direction or ordering. The five *kinds* are
// told apart by a per-box accent tone instead: the two boxes this lesson teaches
// (always-on flags, bundling levers) and the `experimental` warning box read
// distinctly at a skim. Each arrow lands in the gap between hub and boxes and
// crosses no text.
//
// This component renders the boxes + styles; the lesson wraps it in
// <Figure expandable={false}> — ArrowDiagram's leader lines are positioned from
// document.body and break if the figure is relocated into the expand lightbox.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const ARROW = "#94a3b8"; // slate — thin, neutral "belongs to next.config.ts"

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — not-content, centered, capped width and height well under
// the 800px ceiling. ~620px wide keeps the two-column geometry whole on a laptop.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 720px",
  "margin-inline: auto",
].join("; ");

// Two-column stage: hub | gap | the five group boxes. ~96px gap gives every
// curve room to fan without crowding (no labels share the gap, so it can be
// tighter than a labelled diagram).
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: max-content 1fr",
  "column-gap: 96px",
  "align-items: center",
].join("; ");

// The central hub box on the left, vertically centered against the stack.
const hub = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "text-align: center",
  "min-width: 132px",
  "padding: 14px 16px",
  "border-radius: 12px",
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
  "border: 2px solid var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6)",
  "box-shadow: 0 0 0 4px color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent)",
].join("; ");

// Right column — the five group boxes, evenly stacked.
const stack = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
].join("; ");

// One group box. `tone` colours the left rail, the kind title, and a faint wash.
const groupBox = (tone: string) =>
  [
    reset,
    sans,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "gap: 6px",
    "padding: 9px 13px",
    "border-radius: 10px",
    `border: 1.5px solid color-mix(in srgb, ${tone} 45%, var(--sl-color-gray-4))`,
    `border-left: 4px solid ${tone}`,
    `background: color-mix(in srgb, ${tone} 7%, var(--sl-color-gray-6))`,
  ].join("; ");

const kindTitle = (tone: string) =>
  [
    reset,
    sans,
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.15",
    `color: color-mix(in srgb, ${tone} 72%, var(--sl-color-text))`,
  ].join("; ");

// Row holding the key chips.
const keyRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "gap: 4px 5px",
].join("; ");

const keyChip = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.3",
  "padding: 1px 5px",
  "border-radius: 5px",
  "color: var(--sl-color-gray-1)",
  "background: var(--sl-color-gray-5)",
  "border: 1px solid var(--sl-color-gray-4)",
].join("; ");

const tagLine = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Per-kind accent tones (mid-tones that read on light and dark).
const TONE = {
  flags: "#16a34a", // green — always-on, taught this lesson
  pipeline: "#0ea5e9", // sky — platform pipeline (next lesson)
  routing: "#8b5cf6", // violet — edge routing rules
  bundling: "#f97316", // orange — bundling levers, this lesson in depth
  experimental: "#d97706", // amber — the churn warning box
} as const;

const groups = [
  {
    id: "grp-flags",
    tone: TONE.flags,
    title: "Always-on flags",
    keys: ["cacheComponents", "typedRoutes"],
    tag: "this lesson, below",
  },
  {
    id: "grp-pipeline",
    tone: TONE.pipeline,
    title: "Platform pipeline",
    keys: ["images"],
    tag: "next lesson",
  },
  {
    id: "grp-routing",
    tone: TONE.routing,
    title: "Edge routing rules",
    keys: ["redirects", "rewrites", "headers", "trailingSlash"],
    tag: "later this chapter — security headers later still",
  },
  {
    id: "grp-bundling",
    tone: TONE.bundling,
    title: "Bundling levers",
    keys: ["serverExternalPackages", "transpilePackages"],
    tag: "this lesson, in depth",
  },
  {
    id: "grp-experimental",
    tone: TONE.experimental,
    title: "experimental",
    keys: ["staging area for unstable options"],
    tag: "changes between releases — check before copying",
    raw: true, // the lone "key" is descriptive prose, not a config key chip
  },
];

// One thin neutral arrow per group, hub → box, fanning from the hub's right edge
// to each box's left edge. Stagger startSocketGravity so the five curves bow into
// distinct lanes instead of piling on the hub's exit point; the far (top/bottom)
// boxes get a vertical component so their curves arch clear of the middle three.
const arrows = [
  {
    from: "cfg-hub",
    to: "grp-flags",
    color: ARROW,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [40, -90],
    endSocketGravity: [-60, 0],
  },
  {
    from: "cfg-hub",
    to: "grp-pipeline",
    color: ARROW,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [70, -40],
    endSocketGravity: [-50, 0],
  },
  {
    from: "cfg-hub",
    to: "grp-routing",
    color: ARROW,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [60, 0],
    endSocketGravity: [-50, 0],
  },
  {
    from: "cfg-hub",
    to: "grp-bundling",
    color: ARROW,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [70, 40],
    endSocketGravity: [-50, 0],
  },
  {
    from: "cfg-hub",
    to: "grp-experimental",
    color: ARROW,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [40, 90],
    endSocketGravity: [-60, 0],
  },
];
---

<div class="not-content csm" style={root}>
  <ArrowDiagram arrows={arrows}>
    <div style={stage}>
      {/* ---- LEFT — the one file everything belongs to ------------------ */}
      <div style="display: flex; justify-content: center;">
        <div id="cfg-hub" style={hub}>next.config.ts</div>
      </div>

      {/* ---- RIGHT — the five kinds of config key ---------------------- */}
      <div style={stack}>
        {
          groups.map((g) => (
            <div id={g.id} style={groupBox(g.tone)}>
              <span style={kindTitle(g.tone)}>{g.title}</span>
              <div style={keyRow}>
                {g.keys.map((k) =>
                  g.raw ? (
                    <span style={tagLine}>{k}</span>
                  ) : (
                    <code style={keyChip}>{k}</code>
                  ),
                )}
              </div>
              <span style={tagLine}>{g.tag}</span>
            </div>
          ))
        }
      </div>
    </div>
  </ArrowDiagram>
</div>

<style>
  /* The hub → stack geometry is the whole figure, so don't collapse it. On
     narrow viewports let the stage scroll horizontally at a slimmer minimum
     width (laptop viewports — the design target — show it whole). */
  @media (max-width: 640px) {
    .csm {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .csm > div {
      min-width: 560px;
    }
  }
</style>
