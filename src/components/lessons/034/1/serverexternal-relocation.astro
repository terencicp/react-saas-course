---
// serverexternal-relocation — Chapter 034 Lesson 1. A three-step scrubbable
// DiagramSequence that makes the ONE thing serverExternalPackages does literal:
// it relocates @acme/pdf-engine from *inside the server bundle* to *required from
// node_modules at runtime*. The teaching point is the transition, so every step
// shows the same two places side by side — the .next server-function output on
// the left, node_modules on the right — and the reader watches the package move
// between them.
//
//   Step 1  Default       Turbopack folds @acme/pdf-engine INTO the .next output
//                          (bundled chip, red/dashed). The native binding it needs
//                          stays behind in node_modules, disconnected. The output
//                          is marked ✗ — at runtime the binding can't be found.
//   Step 2  Add the flag   The serverExternalPackages config line lights up
//                          (orange — the conditional addition). The bundled copy
//                          in the output is struck through: Next stops bundling it.
//   Step 3  External       The output now holds only a thin require('@acme/...').
//                          A link runs to node_modules, where Node resolves the
//                          real package — native binding included — at runtime.
//                          Marked ✓: it works.
//
// node_modules is the constant: the real package + pdf_engine.node lives there in
// every step. What changes is the .next box and whether anything connects them.
//
// Style follows this codebase's other DiagramSequence figures (e.g. 024/2
// StaleFrameSequence): fixed slate ink, color-scheme pinned light so the
// hand-picked red/orange/green semantics survive dark mode, `margin: 0` on every
// inner element to defeat Starlight's injected prose margins. Every step is the
// same shape — a config strip, a two-column "where it lives" stage, and a verdict
// line — so the grid stack sizes to the tallest step once and never reflows.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary chip / box surface
const BORDER = '#cbd5e1'; // ordinary chip / box edge (slate-300)
const BOX_BG = '#f8fafc'; // container wash (slate-50)
const LABEL_BG = '#ffffff'; // box-label chip surface
const DIM_INK = '#94a3b8'; // muted ink (slate-400)

const RED = '#dc2626'; // red-600 — the bundled-and-broken package
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const ORANGE = '#ea580c'; // orange-600 — the conditional config line
const ORANGE_BG = '#ffedd5'; // orange-100
const ORANGE_INK = '#9a3412'; // orange-800

const GREEN = '#16a34a'; // green-600 — the working, externalized state
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all three steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The config strip at the top — a faux line of next.config.ts. `state` swaps it
// between "not set yet" (dim, dashed) and "active" (orange, the conditional add).
const configStrip = (state: 'off' | 'on') =>
	`display: flex; align-items: center; gap: 7px; margin: 0; padding: 6px 11px; border-radius: 8px; min-height: 34px; box-sizing: border-box; ` +
	(state === 'on'
		? `border: 1.5px solid ${ORANGE}; background: ${ORANGE_BG}; box-shadow: 0 1px 3px rgba(234, 88, 12, 0.25);`
		: `border: 1px dashed ${BORDER}; background: ${SURFACE};`);
const configEyebrow = (state: 'off' | 'on') =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; color: ${state === 'on' ? ORANGE : DIM_INK};`;
const configCode = (state: 'off' | 'on') =>
	`margin: 0; font-family: ${mono}; font-size: 11.5px; font-weight: 600; line-height: 1.3; white-space: nowrap; color: ${state === 'on' ? ORANGE_INK : DIM_INK};`;

// The two-column "where the package lives" stage: .next output | bridge | node_modules.
// A fixed middle column reserves room for the connector so the two boxes never
// shift between steps (only the connector's content changes).
const places = `display: grid; grid-template-columns: 1fr 46px 1fr; align-items: stretch; gap: 0; margin: 0; width: 100%; max-width: 552px;`;

// One labelled container box. `tone` accents its border + status; passing
// `neutral` leaves it plain slate (used for node_modules, the constant).
const placeBox = (tone: 'red' | 'green' | 'neutral') => {
	const edge =
		tone === 'red' ? RED : tone === 'green' ? GREEN : BORDER;
	const width = tone === 'neutral' ? '1px' : '1.5px';
	return `display: flex; flex-direction: column; gap: 7px; margin: 0; padding: 10px 11px 11px; border: ${width} solid ${edge}; border-radius: 12px; background: ${BOX_BG}; box-sizing: border-box;`;
};

// The header row of a box: a path label on the left, an optional status mark right.
const boxHead = `display: flex; align-items: center; gap: 6px; margin: 0; min-height: 20px;`;
const boxLabel = `display: inline-flex; flex: 0 1 auto; align-items: center; min-width: 0; margin: 0; padding: 2px 7px; font-family: ${mono}; font-size: 10px; font-weight: 700; line-height: 1.2; color: ${INK_SOFT}; background: ${LABEL_BG}; border: 1px solid ${BORDER}; border-radius: 6px; white-space: nowrap;`;
const statusMark = (tone: 'red' | 'green') =>
	`display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; margin: 0 0 0 auto; width: 19px; height: 19px; border-radius: 999px; font-family: ${sans}; font-size: 12px; font-weight: 800; line-height: 1; color: #ffffff; background: ${tone === 'green' ? GREEN : RED};`;

// A package chip sitting inside a box. Variants carry the relocation story:
//   bundled  → red, dashed, "(bundled)" — the broken state
//   struck   → greyed + line-through — being removed in step 2
//   require  → green-tinted require(...) line — the thin runtime stub
//   resolved → the real package + its native binding, the node_modules constant
const chipBase = `display: flex; flex-direction: column; gap: 2px; margin: 0; padding: 7px 9px; border-radius: 8px; box-sizing: border-box;`;
const bundledChip = `${chipBase} border: 1.5px dashed ${RED}; background: ${RED_BG};`;
const struckChip = `${chipBase} border: 1.5px dashed ${BORDER}; background: ${SURFACE}; opacity: 0.55;`;
const requireChip = `${chipBase} border: 1.5px solid ${GREEN}; background: ${GREEN_BG};`;
const resolvedChip = `${chipBase} border: 1px solid ${BORDER}; background: ${SURFACE};`;

const chipName = (color: string, strike = false) =>
	`margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.25; color: ${color};` +
	(strike ? ' text-decoration: line-through;' : '');
const chipSub = (color: string) =>
	`margin: 0; font-family: ${mono}; font-size: 10px; font-weight: 600; line-height: 1.2; color: ${color};`;
const chipTag = (color: string, bg: string) =>
	`display: inline-flex; align-self: flex-start; align-items: center; margin: 1px 0 0; padding: 0 5px; font-family: ${sans}; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.5; border-radius: 4px; color: ${color}; background: ${bg};`;

// The middle connector column. Step 1 shows a severed link (✗); step 3 a live
// arrow into node_modules. A fixed-height centred cell keeps both boxes aligned.
const bridge = `display: flex; align-items: center; justify-content: center; margin: 0;`;
const bridgeArrow = (tone: 'red' | 'green' | 'none') =>
	`margin: 0; font-family: ${sans}; font-size: 18px; font-weight: 800; line-height: 1; color: ${tone === 'green' ? GREEN : tone === 'red' ? RED : 'transparent'};`;
const bridgeNote = (tone: 'red' | 'green') =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.15; text-align: center; color: ${tone === 'green' ? GREEN : RED};`;

// The one-line verdict under the stage. `tone` picks the ink.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.35; color: ${tone}; max-width: 460px; text-align: center; min-height: 16px;`;
---

<DiagramSequence>
	{/* ---- Step 1: Default — bundled into .next, native binding stranded ---- */}
	<DiagramStep caption="Default: Turbopack bundles the package into the server function. The native binding it depends on doesn't come along, so the function crashes at runtime.">
		<div style={stage}>
			<div style={configStrip('off')}>
				<span style={configEyebrow('off')}>next.config.ts</span>
				<code style={configCode('off')}>{'// nothing yet'}</code>
			</div>

			<div style={places}>
				{/* left — the server function output, holding the bundled copy */}
				<div style={placeBox('red')}>
					<div style={boxHead}>
						<span style={boxLabel}>.next — server function</span>
						<span style={statusMark('red')} aria-label="crashes">&#10007;</span>
					</div>
					<div style={bundledChip}>
						<span style={chipName(RED_INK)}>@acme/pdf-engine</span>
						<span style={chipTag(RED_INK, '#ffffff')}>bundled</span>
					</div>
				</div>

				{/* middle — the severed link to the binding it needs */}
				<div style={bridge}>
					<div style="display: flex; flex-direction: column; align-items: center; gap: 1px;">
						<span style={bridgeArrow('red')} aria-hidden="true">&#8942;</span>
						<span style={bridgeNote('red')}>can't<br />reach</span>
					</div>
				</div>

				{/* right — the real package + its native binding, left behind */}
				<div style={placeBox('neutral')}>
					<div style={boxHead}>
						<span style={boxLabel}>node_modules</span>
					</div>
					<div style={resolvedChip}>
						<span style={chipName(INK)}>@acme/pdf-engine</span>
						<span style={chipSub(INK_SOFT)}>+ pdf_engine.node</span>
					</div>
				</div>
			</div>

			<p style={verdict(RED_INK)}>
				The bundle holds a copy of the package, but the compiled <strong>.node</strong> binding stayed behind &mdash; so the function crashes when it runs.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Add the flag — Next stops bundling the package ---- */}
	<DiagramStep caption="Add the package to serverExternalPackages. Next stops bundling it.">
		<div style={stage}>
			<div style={configStrip('on')}>
				<span style={configEyebrow('on')}>added</span>
				<code style={configCode('on')}>serverExternalPackages: ['@acme/pdf-engine']</code>
			</div>

			<div style={places}>
				{/* left — the bundled copy is on its way out (struck through) */}
				<div style={placeBox('neutral')}>
					<div style={boxHead}>
						<span style={boxLabel}>.next — server function</span>
					</div>
					<div style={struckChip}>
						<span style={chipName(DIM_INK, true)}>@acme/pdf-engine</span>
						<span style={chipTag(DIM_INK, '#ffffff')}>no longer bundled</span>
					</div>
				</div>

				{/* middle — no connector yet; the relocation lands next step */}
				<div style={bridge}>
					<span style={bridgeArrow('none')} aria-hidden="true">&#8942;</span>
				</div>

				{/* right — node_modules is untouched, the constant */}
				<div style={placeBox('neutral')}>
					<div style={boxHead}>
						<span style={boxLabel}>node_modules</span>
					</div>
					<div style={resolvedChip}>
						<span style={chipName(INK)}>@acme/pdf-engine</span>
						<span style={chipSub(INK_SOFT)}>+ pdf_engine.node</span>
					</div>
				</div>
			</div>

			<p style={verdict(ORANGE_INK)}>
				One line in <strong>next.config.ts</strong> opts the package out of bundling. The copy Turbopack was folding in is dropped.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: External — a thin require resolves the real package ---- */}
	<DiagramStep caption="Now the function output holds only a thin require('@acme/pdf-engine'). At runtime Node resolves the real package — native binding included — from node_modules. It works.">
		<div style={stage}>
			<div style={configStrip('on')}>
				<span style={configEyebrow('on')}>in effect</span>
				<code style={configCode('on')}>serverExternalPackages: ['@acme/pdf-engine']</code>
			</div>

			<div style={places}>
				{/* left — only a thin runtime require remains in the output */}
				<div style={placeBox('green')}>
					<div style={boxHead}>
						<span style={boxLabel}>.next — server function</span>
						<span style={statusMark('green')} aria-label="works">&#10003;</span>
					</div>
					<div style={requireChip}>
						<span style={chipName(GREEN_INK)}>require('@acme/pdf-engine')</span>
						<span style={chipTag(GREEN_INK, '#ffffff')}>resolved at runtime</span>
					</div>
				</div>

				{/* middle — a live arrow: Node resolves the package next door */}
				<div style={bridge}>
					<div style="display: flex; flex-direction: column; align-items: center; gap: 1px;">
						<span style={bridgeArrow('green')} aria-hidden="true">&rarr;</span>
						<span style={bridgeNote('green')}>resolves</span>
					</div>
				</div>

				{/* right — the real package, native binding and all, gets loaded */}
				<div style={placeBox('green')}>
					<div style={boxHead}>
						<span style={boxLabel}>node_modules</span>
					</div>
					<div style={resolvedChip}>
						<span style={chipName(GREEN_INK)}>@acme/pdf-engine</span>
						<span style={chipSub(GREEN_INK)}>+ pdf_engine.node</span>
					</div>
				</div>
			</div>

			<p style={verdict(GREEN_INK)}>
				Node loads the real package &mdash; <strong>native binding included</strong> &mdash; from <strong>node_modules</strong>, exactly as a plain Node script would. It works.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
