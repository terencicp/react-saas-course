---
// The storage → domain → edge strip (Chapter 083 L1, the lesson's hero).
// A horizontal three-zone strip — the html-css "colour-coded segments with
// callouts" use case — that fixes the whole chapter's architecture in one
// glance:
//
//   1. ONE instant lives in THREE shapes depending on where it is. Storage
//      (Postgres) holds it as a timestamptz; the Domain (your code) holds it as
//      a Temporal.Instant; the Edge (rendered for a human) holds it as a local
//      string — and ONLY there does the user's timezone enter. Each zone gets a
//      distinct saturated tint (blue / green / orange) so the colour itself is
//      the signal and reads on both light and dark backgrounds.
//   2. The ISO 8601 "Z" string is the CARRIER between layers, not a resident
//      shape. It rides the connector between Storage↔Domain and Domain↔Edge as a
//      double-headed arrow with a pill label.
//   3. Date is a FOREIGN object, not a fourth layer. It floats ABOVE the strip
//      near the Domain zone, neutral grey, tied down by a dashed "seam only"
//      tether — so the eye reads it as an outsider that visits the boundary, not
//      one of the three resident shapes.
//
// Theme-adaptive chrome via Starlight gray vars; the three zone fills are fixed
// Tailwind-600 mid-tones (white text) so colour survives the theme flip. The
// Date chip + tether are built as a plain CSS column (no LeaderLine) so the
// figure stays expandable and survives the lightbox relocation. `margin: 0`
// everywhere defeats Starlight's injected prose margins.

const zones = [
	{
		key: 'storage',
		title: 'Storage',
		sub: 'Postgres',
		value: 'timestamptz',
		note: '8 bytes · µs since 2000 · UTC',
	},
	{
		key: 'domain',
		title: 'Domain',
		sub: 'your code',
		value: 'Temporal.Instant',
		note: null,
	},
	{
		key: 'edge',
		title: 'Edge',
		sub: 'rendered for a human',
		value: '"Mar 8, 2026, 11:47 PM PST"',
		note: 'user timezone enters here',
	},
];
---

<div class="tls not-content">
	{
		zones.map((zone, i) => (
			<>
				<div class:list={['tls-zone', `tls-${zone.key}`]}>
					{zone.key === 'domain' && (
						<div class="tls-foreign" aria-hidden="true">
							<div class="tls-chip">
								<span class="tls-chip-name">Date</span>
								<span class="tls-chip-note">
									seam only — not a layer
								</span>
							</div>
							<div class="tls-tether" />
						</div>
					)}
					<span class="tls-title">{zone.title}</span>
					<span class="tls-sub">{zone.sub}</span>
					<code class="tls-value">{zone.value}</code>
					{zone.note && (
						<span
							class:list={[
								'tls-note',
								{ 'tls-note-edge': zone.key === 'edge' },
							]}
						>
							{zone.note}
						</span>
					)}
				</div>
				{i < zones.length - 1 && (
					<div class="tls-link" aria-hidden="true">
						<span class="tls-link-arrow">↔</span>
						<span class="tls-link-pill">
							ISO 8601 "Z" string
						</span>
					</div>
				)}
			</>
		))
	}
</div>

<style>
	.tls {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 14px 4px;
		/* Top room for the floating Date chip above the Domain zone. */
		padding: 58px 0 0;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* --- the three resident zones --- */
	.tls-zone {
		position: relative;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		gap: 4px;
		flex: 1 1 9rem;
		min-width: 8.5rem;
		max-width: 13rem;
		min-height: 7.5rem;
		padding: 12px 13px;
		border-radius: 12px;
		margin: 0;
		color: #ffffff;
	}

	.tls-storage {
		border: 1px solid #1d4ed8; /* blue 700 */
		background: #2563eb; /* blue 600 */
		box-shadow: 0 1px 3px rgba(37, 99, 235, 0.4);
	}

	.tls-domain {
		border: 1px solid #15803d; /* green 700 */
		background: #16a34a; /* green 600 */
		box-shadow: 0 1px 3px rgba(22, 163, 74, 0.4);
	}

	.tls-edge {
		border: 1px solid #c2410c; /* orange 700 */
		background: #ea580c; /* orange 600 */
		box-shadow: 0 1px 3px rgba(234, 88, 12, 0.4);
	}

	.tls-title {
		font-size: 1.02rem;
		font-weight: 700;
		line-height: 1.1;
		margin: 0;
	}

	.tls-sub {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgba(255, 255, 255, 0.82);
		margin: 0;
	}

	.tls-value {
		align-self: flex-start;
		margin: 6px 0 0;
		padding: 3px 8px;
		border-radius: 7px;
		background: rgba(0, 0, 0, 0.22);
		color: #ffffff;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.78rem;
		line-height: 1.3;
	}

	.tls-note {
		margin: auto 0 0;
		padding-top: 6px;
		font-size: 0.66rem;
		line-height: 1.25;
		color: rgba(255, 255, 255, 0.78);
	}

	/* The edge note carries the lesson's punchline — give it a touch more weight. */
	.tls-note-edge {
		font-weight: 700;
		color: #ffffff;
	}

	/* --- the carrier between layers --- */
	.tls-link {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		flex: 0 0 auto;
		align-self: center;
		margin: 0;
	}

	.tls-link-arrow {
		font-size: 1.15rem;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.tls-link-pill {
		max-width: 4.5rem;
		padding: 2px 7px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-gray-6, #f1f5f9);
		color: var(--sl-color-gray-2, #475569);
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.6rem;
		font-weight: 600;
		line-height: 1.25;
		text-align: center;
		margin: 0;
	}

	/* --- the foreign Date chip, floating above the Domain zone --- */
	.tls-foreign {
		position: absolute;
		bottom: 100%;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
		margin: 0;
		pointer-events: none;
	}

	.tls-chip {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1px;
		padding: 5px 12px;
		border-radius: 9px;
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-gray-6, #f1f5f9);
		margin: 0;
	}

	.tls-chip-name {
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 700;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	.tls-chip-note {
		font-size: 0.6rem;
		line-height: 1.1;
		color: var(--sl-color-gray-3, #64748b);
		white-space: nowrap;
		margin: 0;
	}

	/* The dashed tether tying the chip down to the Domain zone's top border. */
	.tls-tether {
		width: 0;
		height: 16px;
		border-left: 2px dashed var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	/* Narrow viewports: stack into a column; the carrier arrow points down, and
	   the Date chip drops above the Domain zone the same way. */
	@media (max-width: 640px) {
		.tls {
			flex-direction: column;
			align-items: center;
			gap: 0;
			padding-top: 58px;
		}
		.tls-zone {
			flex: 0 0 auto;
			width: 100%;
			max-width: 20rem;
			min-height: 0;
		}
		.tls-link {
			margin: 6px 0;
		}
		.tls-link-arrow {
			transform: rotate(90deg);
		}
	}
</style>
