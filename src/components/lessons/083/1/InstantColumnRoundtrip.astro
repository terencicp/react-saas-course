---
// Chapter 083 L1 — tracing one `createdAt` value across a READ then a WRITE,
// with the Drizzle `instantColumn` (a customType) shown as the conversion point.
//
// Shape: a small horizontal pipeline of four labelled boxes —
//   Postgres → driver → instantColumn → domain
// repeated per step, with the ACTIVE box ringed and the value in flight shown
// in a card below. The pipeline never reflows; only the highlight, the arrow
// direction, and the value card change between steps. This makes the two
// teaching points visible at a glance:
//   1. fromDriver normalizes Postgres's hours-only offset (`+00` → `+00:00`)
//      into canonical ISO 8601 before parsing — the load-bearing read seam.
//      (It also swaps the space for a `T`, but that's cosmetic — a space is a
//      valid separator; the offset shape is what has to be repaired.)
//   2. The conversion lives INSIDE the column, so the call site (domain) does
//      nothing: it already holds a Temporal.Instant.
//
// Read direction (steps 1–3) flows left→right (Postgres → domain); write
// direction (steps 4–5) flows right→left (domain → Postgres). The active
// box is tinted (Postgres blue / domain green, matching the lesson's hero
// strip) so the colour is the signal across the theme flip.
//
// Theme-adaptive chrome via Starlight gray vars; `margin: 0` everywhere defeats
// Starlight's injected prose margins. Rendered inside a DiagramSequence — NOT a
// Figure (DiagramSequence is its own card).

import DiagramSequence from '../../../../components/figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../../components/figures/diagram-sequence/DiagramStep.astro';

// The four pipeline stages, in physical left→right order. `kind` drives the
// tint when a stage is the active one.
const stages = [
	{ key: 'pg', label: 'Postgres', sub: 'timestamptz', kind: 'pg' },
	{ key: 'driver', label: 'driver', sub: 'string on the wire', kind: 'neutral' },
	{ key: 'column', label: 'instantColumn', sub: 'customType', kind: 'neutral' },
	{ key: 'domain', label: 'domain', sub: 'your code', kind: 'domain' },
];
---

<DiagramSequence>
	{/* ---------- STEP 1 · READ ---------- */}
	<DiagramStep caption="Read · Postgres hands the driver its native text — space-separated, with an hours-only +00 offset. Not canonical ISO 8601 yet.">
		<div class="icr not-content">
			<div class="icr-dir icr-dir-read">read &rarr;</div>
			<div class="icr-pipe">
				{
					stages.map((s, i) => (
						<>
							<div
								class:list={[
									'icr-box',
									`icr-${s.kind}`,
									{ 'is-active': s.key === 'pg' },
								]}
							>
								<span class="icr-box-label">{s.label}</span>
								<span class="icr-box-sub">{s.sub}</span>
							</div>
							{i < stages.length - 1 && (
								<span class="icr-arrow">&rarr;</span>
							)}
						</>
					))
				}
			</div>
			<div class="icr-card">
				<span class="icr-card-tag">leaving Postgres</span>
				<code class="icr-val"
					>'2026-03-09<span class="icr-soft">·</span>07:47:00.038<span
						class="icr-flag">+00</span
					>'</code
				>
				<span class="icr-card-note"
					>The hours-only <code>+00</code> offset is the load-bearing problem — a
					clean carrier wants <code>+00:00</code>. (The space is fine on its own;
					a <code>T</code> is just the canonical separator.)</span
				>
			</div>
		</div>
	</DiagramStep>

	{/* ---------- STEP 2 · READ ---------- */}
	<DiagramStep caption="Read · fromDriver pads the hours-only offset to ±HH:mm (and swaps the space for a T), then Temporal.Instant.from parses it.">
		<div class="icr not-content">
			<div class="icr-dir icr-dir-read">read &rarr;</div>
			<div class="icr-pipe">
				{
					stages.map((s, i) => (
						<>
							<div
								class:list={[
									'icr-box',
									`icr-${s.kind}`,
									{ 'is-active': s.key === 'column' },
								]}
							>
								<span class="icr-box-label">{s.label}</span>
								<span class="icr-box-sub">{s.sub}</span>
							</div>
							{i < stages.length - 1 && (
								<span class="icr-arrow">&rarr;</span>
							)}
						</>
					))
				}
			</div>
			<div class="icr-card">
				<span class="icr-card-tag"
					><code>fromDriver</code> · inside the column</span
				>
				<div class="icr-repair">
					<code class="icr-val"
						>'…<span class="icr-repair-on">T</span>07:47:00.038<span
							class="icr-repair-on">+00:00</span
						>'</code
					>
					<span class="icr-repair-arrow">&rarr;</span>
					<code class="icr-val icr-val-instant">Temporal.Instant</code>
				</div>
				<span class="icr-card-note"
					><code>.replace(/([+-]\d&#123;2&#125;)$/, '$1:00')</code> pads the
					hours-only offset to the <code>+00:00</code> that
					<code>Temporal.Instant.from</code> round-trips cleanly (the space
					becomes a <code>T</code> in the same pass).</span
				>
			</div>
		</div>
	</DiagramStep>

	{/* ---------- STEP 3 · READ ---------- */}
	<DiagramStep caption="Read · domain code already holds a Temporal.Instant — no conversion call at the call site.">
		<div class="icr not-content">
			<div class="icr-dir icr-dir-read">read &rarr;</div>
			<div class="icr-pipe">
				{
					stages.map((s, i) => (
						<>
							<div
								class:list={[
									'icr-box',
									`icr-${s.kind}`,
									{ 'is-active': s.key === 'domain' },
								]}
							>
								<span class="icr-box-label">{s.label}</span>
								<span class="icr-box-sub">{s.sub}</span>
							</div>
							{i < stages.length - 1 && (
								<span class="icr-arrow">&rarr;</span>
							)}
						</>
					))
				}
			</div>
			<div class="icr-card">
				<span class="icr-card-tag">read at the call site</span>
				<code class="icr-val icr-val-instant"
					>invoice.createdAt.epochMilliseconds</code
				>
				<span class="icr-card-note"
					>It's a <code>Temporal.Instant</code> already — the column did the
					work. No <code>.fromDb(…)</code> in sight.</span
				>
			</div>
		</div>
	</DiagramStep>

	{/* ---------- STEP 4 · WRITE ---------- */}
	<DiagramStep caption="Write · domain produces a Temporal.Instant and heads back toward storage.">
		<div class="icr not-content">
			<div class="icr-dir icr-dir-write">&larr; write</div>
			<div class="icr-pipe">
				{
					stages.map((s, i) => (
						<>
							<div
								class:list={[
									'icr-box',
									`icr-${s.kind}`,
									{ 'is-active': s.key === 'domain' },
								]}
							>
								<span class="icr-box-label">{s.label}</span>
								<span class="icr-box-sub">{s.sub}</span>
							</div>
							{i < stages.length - 1 && (
								<span class="icr-arrow icr-arrow-rev">&larr;</span>
							)}
						</>
					))
				}
			</div>
			<div class="icr-card">
				<span class="icr-card-tag">leaving the domain</span>
				<code class="icr-val icr-val-instant">Temporal.Now.instant()</code>
				<span class="icr-card-note"
					>An insert accepts a <code>Temporal.Instant</code> directly — the
					same column converts on the way in.</span
				>
			</div>
		</div>
	</DiagramStep>

	{/* ---------- STEP 5 · WRITE ---------- */}
	<DiagramStep caption="Write · toDriver emits an ISO 'Z' string; the driver passes it to Postgres, which stores it as timestamptz.">
		<div class="icr not-content">
			<div class="icr-dir icr-dir-write">&larr; write</div>
			<div class="icr-pipe">
				{
					stages.map((s, i) => (
						<>
							<div
								class:list={[
									'icr-box',
									`icr-${s.kind}`,
									{ 'is-active': s.key === 'column' || s.key === 'pg' },
								]}
							>
								<span class="icr-box-label">{s.label}</span>
								<span class="icr-box-sub">{s.sub}</span>
							</div>
							{i < stages.length - 1 && (
								<span class="icr-arrow icr-arrow-rev">&larr;</span>
							)}
						</>
					))
				}
			</div>
			<div class="icr-card">
				<span class="icr-card-tag"
					><code>toDriver</code> · one line, no repair</span
				>
				<code class="icr-val"
					>'2026-03-09T07:47:00.038<span class="icr-ok">Z</span>'</code
				>
				<span class="icr-card-note"
					><code>Instant.toString()</code> already produces the canonical
					<code>Z</code> string Postgres ingests cleanly — it lands as
					<code>timestamptz</code>.</span
				>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>

<style>
	.icr {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
		margin: 0;
		padding: 4px 0 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* --- direction banner --- */
	.icr-dir {
		align-self: center;
		padding: 2px 12px;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0;
	}
	.icr-dir-read {
		color: #15803d;
		background: rgba(22, 163, 74, 0.13);
		border: 1px solid rgba(22, 163, 74, 0.35);
	}
	.icr-dir-write {
		color: #1d4ed8;
		background: rgba(37, 99, 235, 0.13);
		border: 1px solid rgba(37, 99, 235, 0.35);
	}

	/* --- the four-box pipeline --- */
	.icr-pipe {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
		margin: 0;
	}

	.icr-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		flex: 0 0 auto;
		min-width: 7.5rem;
		padding: 9px 12px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-gray-6, #f1f5f9);
		color: var(--sl-color-gray-2, #475569);
		opacity: 0.6;
		transition:
			opacity 0.15s ease,
			box-shadow 0.15s ease;
		margin: 0;
	}

	.icr-box-label {
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.85rem;
		font-weight: 700;
		line-height: 1.1;
		margin: 0;
	}
	.icr-box-sub {
		font-size: 0.62rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.85;
		margin: 0;
	}

	/* The active box for the step: full opacity + a coloured ring keyed to kind. */
	.icr-box.is-active {
		opacity: 1;
		color: #ffffff;
	}
	.icr-pg.is-active {
		background: #2563eb; /* blue 600 */
		border-color: #1d4ed8;
		box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.3);
	}
	.icr-domain.is-active {
		background: #16a34a; /* green 600 */
		border-color: #15803d;
		box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.3);
	}
	.icr-neutral.is-active {
		background: var(--sl-color-gray-2, #475569);
		border-color: var(--sl-color-gray-3, #64748b);
		color: #ffffff;
		box-shadow: 0 0 0 3px var(--sl-color-gray-5, rgba(100, 116, 139, 0.35));
	}

	.icr-arrow {
		align-self: center;
		font-size: 1.1rem;
		line-height: 1;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* --- the value-in-flight card --- */
	.icr-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 7px;
		width: 100%;
		max-width: 34rem;
		box-sizing: border-box;
		padding: 12px 16px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-hairline, #e2e8f0);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}

	.icr-card-tag {
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.icr-card-tag code {
		font-size: 0.66rem;
		text-transform: none;
		letter-spacing: 0;
	}

	.icr-val {
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1.4;
		text-align: center;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
		word-break: break-word;
	}

	/* The Temporal.Instant value form — tinted domain green so the eye reads
	   "this is the in-memory type" wherever it appears. */
	.icr-val-instant {
		color: #15803d;
	}

	/* The load-bearing non-canonical offender in step 1 (the hours-only offset),
	   underlined red. */
	.icr-flag {
		color: #dc2626;
		font-weight: 800;
		border-bottom: 2px solid #dc2626;
	}

	/* The cosmetic-only difference in step 1 (the space separator): a middot
	   placeholder so the space is visible, but muted — it is NOT the bug. */
	.icr-soft {
		color: var(--sl-color-gray-3, #64748b);
		font-weight: 700;
	}

	/* The Z that makes step 5's output legal ISO, underlined green. */
	.icr-ok {
		color: #15803d;
		font-weight: 800;
		border-bottom: 2px solid #15803d;
	}

	/* Step 2's repair: the inserted T, ringed green. */
	.icr-repair {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 10px;
		margin: 0;
	}
	.icr-repair-on {
		display: inline-block;
		padding: 0 2px;
		border-radius: 3px;
		background: rgba(22, 163, 74, 0.18);
		color: #15803d;
		font-weight: 800;
	}
	.icr-repair-arrow {
		font-size: 1.1rem;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.icr-card-note {
		font-size: 0.78rem;
		line-height: 1.4;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.icr-card-note code {
		font-size: 0.74rem;
	}

	/* --- dark-mode accent lifts ---
	   Green 700 / Blue 700 read fine on light but go muddy on the near-black
	   card. Lift the text accents (not the saturated active-box fills, which
	   already carry white text) to brighter tints that clear contrast on dark. */
	:global([data-theme='dark']) .icr-dir-read {
		color: #4ade80; /* green 400 */
		background: rgba(74, 222, 128, 0.14);
		border-color: rgba(74, 222, 128, 0.4);
	}
	:global([data-theme='dark']) .icr-dir-write {
		color: #60a5fa; /* blue 400 */
		background: rgba(96, 165, 250, 0.14);
		border-color: rgba(96, 165, 250, 0.4);
	}
	:global([data-theme='dark']) .icr-val-instant {
		color: #4ade80; /* green 400 */
	}
	:global([data-theme='dark']) .icr-repair-on {
		background: rgba(74, 222, 128, 0.22);
		color: #4ade80;
	}
	:global([data-theme='dark']) .icr-ok {
		color: #4ade80;
		border-bottom-color: #4ade80;
	}
	:global([data-theme='dark']) .icr-flag {
		color: #f87171; /* red 400 */
		border-bottom-color: #f87171;
	}

	/* Narrow viewports: the pipeline wraps; arrows hide so the wrapped boxes
	   don't read as a broken chain. */
	@media (max-width: 560px) {
		.icr-arrow {
			display: none;
		}
		.icr-box {
			min-width: 6.5rem;
			flex: 1 1 6.5rem;
		}
	}
</style>
