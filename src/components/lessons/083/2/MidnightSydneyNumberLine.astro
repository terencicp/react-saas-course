---
// The midnight-UTC-from-Sydney number line (Chapter 083 L2, the lesson's hero).
//
// A single horizontal UTC time axis carries TWO shaded day-bands behind it —
// "May 14 (UTC)" on the left, "May 15 (UTC)" on the right — split at the
// 2026-05-15T00:00:00Z boundary. Every marker is positioned by its TRUE UTC
// instant on one shared coordinate system, so a marker's calendar day is
// readable purely by which band it sits in. That is the whole point: the day a
// timestamptz reports is decided by which UTC band the instant falls into, and
// midnight-in-Sydney falls into the WRONG band.
//
// Coordinate system: the axis window runs from 2026-05-14T12:00Z (0%) to
// 2026-05-15T06:00Z (100%) — an 18-hour span. Position = (hoursFromStart / 18).
// The pre-computed percentages below come straight from that mapping:
//   - boundary  2026-05-15T00:00Z → 12h → 66.67%   (UTC/London midnight)
//   - sydneyMid 2026-05-14T14:00Z →  2h → 11.11%   (Sydney's LOCAL midnight)
// Both fall on the May-15-Sydney wall clock, yet sit in different UTC bands.
//
// Two rails sit BELOW the axis, aligned to the same x-positions:
//   Rail A — UTC / London: one marker at the boundary, reads "May 15, 00:00".
//     The author's-machine view; it looks correct.
//   Rail B — Sydney (+10): the stored instant read locally (May 15, 10:00, at
//     the boundary x) AND the Sydney user's local midnight (May 15, 00:00 local)
//     which projects straight up into the May-14 UTC band — the bug made visible.
//
// Style mirrors L1's ThreeLayerSplitStrip: theme-adaptive chrome via Starlight
// gray vars, saturated Tailwind-600 day-band tints so the colour is the signal
// on both themes, `margin: 0` everywhere to defeat Starlight's injected prose
// margins. Built as plain CSS (no LeaderLine) so the figure stays expandable.

const BOUNDARY_PCT = 66.67; // 2026-05-15T00:00Z
const SYDNEY_MID_PCT = 11.11; // 2026-05-14T14:00Z = Sydney's local midnight of the 15th
---

<div class="msl not-content">
	<!-- ===== The UTC axis with its two day-bands ===== -->
	<div class="msl-axis-wrap">
		<div class="msl-axis-label">UTC time axis →</div>
		<div class="msl-bands" style={`--boundary: ${BOUNDARY_PCT}%`}>
			<div class="msl-band msl-band-14">
				<span class="msl-band-name">May 14</span>
				<span class="msl-band-sub">(UTC)</span>
			</div>
			<div class="msl-band msl-band-15">
				<span class="msl-band-name">May 15</span>
				<span class="msl-band-sub">(UTC)</span>
			</div>

			<!-- the day boundary line + its tick label -->
			<div class="msl-boundary" style={`left: ${BOUNDARY_PCT}%`}>
				<span class="msl-boundary-tick">2026-05-15T00:00:00Z</span>
			</div>

			<!-- the two UTC reference instants the rails below project onto -->
			<div class="msl-tick" style={`left: ${SYDNEY_MID_PCT}%`}>
				<span class="msl-tick-dot"></span>
				<span class="msl-tick-cap">14:00Z</span>
			</div>
		</div>
	</div>

	<!-- ===== Rail A — UTC / London ===== -->
	<div class="msl-rail">
		<div class="msl-rail-tag">
			<span class="msl-rail-name">UTC / London</span>
			<span class="msl-rail-sub">your machine</span>
		</div>
		<div class="msl-rail-track">
			<div class="msl-marker msl-marker-ok" style={`left: ${BOUNDARY_PCT}%`}>
				<span class="msl-pin"></span>
				<span class="msl-marker-label">
					<strong>May 15</strong>, 00:00
				</span>
			</div>
		</div>
	</div>

	<!-- ===== Rail B — Sydney (UTC+10) ===== -->
	<div class="msl-rail">
		<div class="msl-rail-tag">
			<span class="msl-rail-name">Sydney</span>
			<span class="msl-rail-sub">UTC+10</span>
		</div>
		<div class="msl-rail-track">
			<!-- the stored instant, as a Sydney user reads it: mid-morning the 15th -->
			<div class="msl-marker msl-marker-read" style={`left: ${BOUNDARY_PCT}%`}>
				<span class="msl-pin"></span>
				<span class="msl-marker-label">
					<strong>May 15</strong>, 10:00
				</span>
			</div>

			<!-- the payload: Sydney's LOCAL midnight of May 15, projecting up into
			     the May-14 UTC band -->
			<div class="msl-marker msl-marker-bug" style={`left: ${SYDNEY_MID_PCT}%`}>
				<span class="msl-projection" aria-hidden="true"></span>
				<span class="msl-pin"></span>
				<span class="msl-marker-label">
					<strong>May 15</strong>, 00:00 <span class="msl-local">local</span>
				</span>
				<span class="msl-payload">
					stored as <code>2026-05-14T14:00Z</code> → reads back as
					<strong>May 14</strong>
				</span>
			</div>
		</div>
	</div>
</div>

<style>
	.msl {
		box-sizing: border-box;
		width: 100%;
		margin: 0;
		padding: 4px 0 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		color: var(--sl-color-white, #1e293b);
	}

	.msl *,
	.msl *::before,
	.msl *::after {
		box-sizing: border-box;
	}

	/* ===== UTC axis ===== */
	.msl-axis-wrap {
		margin: 0;
	}

	.msl-axis-label {
		margin: 0 0 4px;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}

	.msl-bands {
		position: relative;
		display: flex;
		height: 58px;
		margin: 0;
		border-radius: 10px;
		overflow: visible;
	}

	.msl-band {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1px;
		margin: 0;
		color: #ffffff;
	}

	.msl-band-14 {
		flex: 0 0 var(--boundary);
		background: #d97706; /* amber 600 */
		border: 1px solid #b45309; /* amber 700 */
		border-right: none;
		border-radius: 10px 0 0 10px;
	}

	.msl-band-15 {
		flex: 1 1 auto;
		background: #2563eb; /* blue 600 */
		border: 1px solid #1d4ed8; /* blue 700 */
		border-left: none;
		border-radius: 0 10px 10px 0;
	}

	.msl-band-name {
		font-size: 0.95rem;
		font-weight: 800;
		line-height: 1;
		margin: 0;
	}

	.msl-band-sub {
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		opacity: 0.85;
		margin: 0;
	}

	/* the hard day boundary, drawn on top of the band seam */
	.msl-boundary {
		position: absolute;
		top: -4px;
		bottom: -4px;
		width: 0;
		border-left: 2px dashed var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	.msl-boundary-tick {
		position: absolute;
		bottom: 100%;
		left: 50%;
		transform: translateX(-50%);
		margin: 0 0 3px;
		padding: 1px 6px;
		border-radius: 6px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg-sidebar, #f1f5f9);
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.6rem;
		font-weight: 600;
		white-space: nowrap;
		color: var(--sl-color-gray-2, #475569);
	}

	/* a plain UTC tick inside the band (the 14:00Z reference) */
	.msl-tick {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-end;
		margin: 0;
	}

	.msl-tick-dot {
		position: absolute;
		bottom: -3px;
		left: 50%;
		transform: translateX(-50%);
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #ffffff;
		border: 1px solid rgba(0, 0, 0, 0.35);
		margin: 0;
	}

	.msl-tick-cap {
		margin: 0 0 4px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.58rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.92);
	}

	/* ===== rails below the axis ===== */
	.msl-rail {
		display: flex;
		align-items: stretch;
		gap: 10px;
		margin: 18px 0 0;
	}

	.msl-rail-tag {
		flex: 0 0 5.2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1px;
		margin: 0;
		text-align: right;
	}

	.msl-rail-name {
		font-size: 0.82rem;
		font-weight: 800;
		line-height: 1.05;
		margin: 0;
		color: var(--sl-color-white, #1e293b);
	}

	.msl-rail-sub {
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.msl-rail-track {
		position: relative;
		flex: 1 1 auto;
		min-height: 46px;
		margin: 0;
		border-top: 2px solid var(--sl-color-gray-4, #94a3b8);
	}

	/* a marker = a pin on the rail's baseline + a label below it */
	.msl-marker {
		position: absolute;
		top: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin: 0;
		transform: translateX(-50%);
	}

	.msl-pin {
		width: 11px;
		height: 11px;
		border-radius: 50%;
		margin: -6px 0 0;
		border: 2px solid var(--sl-color-bg, #ffffff);
	}

	.msl-marker-ok .msl-pin,
	.msl-marker-read .msl-pin {
		background: var(--sl-color-gray-2, #475569);
	}

	.msl-marker-bug .msl-pin {
		background: #dc2626; /* red 600 */
	}

	.msl-marker-label {
		margin: 3px 0 0;
		padding: 2px 7px;
		border-radius: 6px;
		background: var(--sl-color-gray-6, #f1f5f9);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		font-size: 0.7rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
	}

	.msl-marker-label strong {
		font-weight: 800;
	}

	.msl-local {
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* the projection line: from the bug marker on Rail B straight up through
	   Rail A and into the May-14 UTC band above it */
	.msl-projection {
		position: absolute;
		bottom: 100%;
		left: 50%;
		height: 200px;
		width: 0;
		border-left: 2px dashed #dc2626;
		transform: translateX(-50%);
		margin: 0;
		pointer-events: none;
	}

	.msl-marker-bug .msl-marker-label {
		border-color: #dc2626;
		background: var(--sl-color-bg, #fff);
		color: #dc2626;
		font-weight: 700;
	}

	.msl-payload {
		margin: 5px 0 0;
		padding: 3px 8px;
		max-width: 14rem;
		border-radius: 7px;
		background: #dc2626; /* red 600 */
		color: #ffffff;
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.3;
		text-align: center;
	}

	.msl-payload code {
		background: rgba(0, 0, 0, 0.25);
		color: #ffffff;
		padding: 0 4px;
		border-radius: 4px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.62rem;
	}

	.msl-payload strong {
		font-weight: 800;
	}

	/* On narrow viewports, drop the rail tags above their tracks so the axis
	   keeps its full width and the projection stays vertical. */
	@media (max-width: 560px) {
		.msl-rail {
			flex-direction: column;
			gap: 4px;
			margin-top: 22px;
		}
		.msl-rail-tag {
			flex: 0 0 auto;
			text-align: left;
		}
	}
</style>
