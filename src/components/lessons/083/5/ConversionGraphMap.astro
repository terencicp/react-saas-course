---
// ConversionGraphMap — Chapter 083 Lesson 5, "Arithmetic with Temporal".
//
// The conversion graph as a navigable reference card: the four node-types a
// SaaS moves between, with every edge labeled by the EXACT method that crosses
// it. There is no implicit coercion — each edge is a named call.
//
//          ┌──────────┐  toZonedDateTimeISO(tz)  ┌────────────────┐  toPlainDate()  ┌───────────┐
//          │ Instant  │ ───────────────────────▶ │ ZonedDateTime  │ ──────────────▶ │ PlainDate │
//          │ UTC point│ ◀─────────────────────── │   + zone       │ ◀────────────── │ cal. day  │
//          └──────────┘       toInstant()        └────────────────┘  toZonedDateTime└───────────┘
//               ▲  │                                                  ({ tz, plainTime })  ▲  │
//      from(str)│  │toString()                                              toString()│   │PlainDate.from(str)
//               │  ▼                  ┌─────────────────────┐                         │   ▼
//               └───────────────────▶ │ string · ISO 8601   │ ◀───────────────────────┘
//                                     │ the wire            │
//                                     └─────────────────────┘
//
// The two BLUE edges (toZonedDateTimeISO / toZonedDateTime) cross a timezone
// boundary, so they REQUIRE a named zone — they carry a small "needs zone"
// badge so that rule is legible in the picture itself. Every other edge keeps
// the theme-neutral arrow color.
//
// Built with <ArrowDiagram> (LeaderLine): the nodes are two-line custom HTML
// (a monospace type name + a muted subtitle) and the per-edge semantic coloring
// (the blue zone-crossing edges) is the whole point — D2/Mermaid plain-label
// boxes wouldn't carry it. The arrows are positioned from document.body, so the
// wrapping <Figure> MUST be expandable={false}: relocating the body into the
// lightbox breaks the lines.
//
// Bidirectional pairs (Instant↔ZonedDateTime, the two ↔string edges) are split
// onto opposite sockets so their two arrows never share one path and collide.
// Chrome is theme-aware (Starlight gray/white vars). The zone-blue accent
// (#2563eb) is used as-is in both themes — a mid-tone that reads on either bg.
// A margin:0 reset on every node defeats Starlight's injected prose margins.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const ZONE_BLUE = '#2563eb'; // blue-600 — the zone-requiring crossings

// Pin the label badge to a light card so it survives dark mode (the figure
// renders on the page bg; the body-appended badge defaults derive from it).
const labelLight =
	'background: #ffffff; border: 1px solid #cbd5e1; color: #334155;';
const labelBlue =
	'background: #ffffff; border: 1px solid #93c5fd; color: #1d4ed8; font-weight: 700;';

const arrows = [
	// ── Top row: Instant ⇄ ZonedDateTime ────────────────────────────────────
	// Instant → ZonedDateTime — zone-crossing (blue), rides the TOP sockets.
	{
		from: 'cg-instant',
		to: 'cg-zdt',
		label: 'toZonedDateTimeISO(tz) ⚑',
		color: ZONE_BLUE,
		startSocket: 'top',
		endSocket: 'top',
		startSocketGravity: [10, -46],
		endSocketGravity: [-10, -46],
		labelOffset: [0, -16],
		labelStyle: labelBlue,
	},
	// ZonedDateTime → Instant — back along the BOTTOM sockets.
	{
		from: 'cg-zdt',
		to: 'cg-instant',
		label: 'toInstant()',
		startSocket: 'bottom',
		endSocket: 'bottom',
		startSocketGravity: [-10, 40],
		endSocketGravity: [10, 40],
		labelOffset: [0, 16],
		labelStyle: labelLight,
	},

	// ── Top row: ZonedDateTime ⇄ PlainDate ───────────────────────────────────
	// ZonedDateTime → PlainDate — TOP sockets.
	{
		from: 'cg-zdt',
		to: 'cg-plaindate',
		label: 'toPlainDate()',
		startSocket: 'top',
		endSocket: 'top',
		startSocketGravity: [10, -46],
		endSocketGravity: [-10, -46],
		labelOffset: [0, -16],
		labelStyle: labelLight,
	},
	// PlainDate → ZonedDateTime — zone-crossing (blue), BOTTOM sockets.
	{
		from: 'cg-plaindate',
		to: 'cg-zdt',
		label: 'toZonedDateTime({ tz, plainTime }) ⚑',
		color: ZONE_BLUE,
		startSocket: 'bottom',
		endSocket: 'bottom',
		startSocketGravity: [-10, 40],
		endSocketGravity: [10, 40],
		labelOffset: [0, 16],
		labelStyle: labelBlue,
	},

	// ── string node: Instant ⇄ string (left leg) ─────────────────────────────
	// Instant → string — leaves Instant's bottom-left, lands on string's left.
	{
		from: 'cg-instant',
		to: 'cg-string',
		label: 'toString()',
		startSocket: 'bottom',
		endSocket: 'left',
		startSocketGravity: [-30, 70],
		endSocketGravity: [-70, 10],
		labelOffset: [-6, 4],
		labelStyle: labelLight,
	},
	// string → Instant — Instant.from(str), back up the same left leg.
	{
		from: 'cg-string',
		to: 'cg-instant',
		label: 'Instant.from(str)',
		startSocket: 'left',
		endSocket: 'bottom',
		startSocketGravity: [-90, -10],
		endSocketGravity: [-50, 60],
		labelOffset: [-8, -10],
		labelStyle: labelLight,
	},

	// ── string node: PlainDate ⇄ string (right leg) ──────────────────────────
	// PlainDate → string — leaves PlainDate's bottom-right, lands on string's right.
	{
		from: 'cg-plaindate',
		to: 'cg-string',
		label: 'toString()',
		startSocket: 'bottom',
		endSocket: 'right',
		startSocketGravity: [30, 70],
		endSocketGravity: [70, 10],
		labelOffset: [6, 4],
		labelStyle: labelLight,
	},
	// string → PlainDate — PlainDate.from(str), back up the right leg.
	{
		from: 'cg-string',
		to: 'cg-plaindate',
		label: 'PlainDate.from(str)',
		startSocket: 'right',
		endSocket: 'bottom',
		startSocketGravity: [90, -10],
		endSocketGravity: [50, 60],
		labelOffset: [8, -10],
		labelStyle: labelLight,
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="cg not-content">
			{/* ── Top row: the three type nodes, left → right ── */}
			<div class="cg-row">
				<div class="cg-node" id="cg-instant">
					<span class="cg-type">Instant</span>
					<span class="cg-sub">UTC point</span>
				</div>
				<div class="cg-node cg-node-zoned" id="cg-zdt">
					<span class="cg-type">ZonedDateTime</span>
					<span class="cg-sub">+ zone</span>
				</div>
				<div class="cg-node" id="cg-plaindate">
					<span class="cg-type">PlainDate</span>
					<span class="cg-sub">calendar day</span>
				</div>
			</div>

			{/* ── The serialization node every edge above can reach ── */}
			<div class="cg-string-row">
				<div class="cg-node cg-node-string" id="cg-string">
					<span class="cg-type">string</span>
					<span class="cg-sub">ISO 8601 · the wire</span>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		The conversion map. Every edge is an explicit method — there is no implicit
		coercion. The <strong style="color:#2563eb;">blue edges</strong> cross a
		timezone boundary, so they <em>require</em> a named zone (⚑); that's the one
		place "where" enters the picture.
	</Fragment>
</Figure>

<style>
	.cg {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 96px;
		margin: 0;
		padding: 30px 8px 18px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* Top row: three type nodes, generously spaced so the labeled top/bottom
	   curves have room to bow into the gaps without colliding. */
	.cg-row {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: center;
		gap: 130px;
		margin: 0;
	}

	/* The string node is centered under the gap between Instant and PlainDate. */
	.cg-string-row {
		display: flex;
		justify-content: center;
		margin: 0;
	}

	.cg-node {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		min-width: 8.5rem;
		padding: 11px 18px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
		text-align: center;
		margin: 0;
	}

	/* ZonedDateTime is the hub of the top row — a touch heavier border so the
	   eye reads it as the central crossing node. */
	.cg-node-zoned {
		border-color: var(--sl-color-gray-4, #94a3b8);
		border-width: 2px;
		padding: 12px 18px;
	}

	/* string: the serialization node — dashed to read as "off to the wire". */
	.cg-node-string {
		border-style: dashed;
		min-width: 12rem;
	}

	.cg-type {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.cg-sub {
		font-size: 0.68rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: stack the three type nodes. The top/bottom sockets degrade
	   to vertical arcs between stacked boxes — readable, labels still float in the
	   gaps. */
	@media (max-width: 800px) {
		.cg {
			gap: 64px;
		}
		.cg-row {
			flex-direction: column;
			gap: 72px;
		}
		.cg-node {
			width: min(16rem, 100%);
		}
	}
</style>
