---
// Timezone-propagation map (Chapter 083 L4, "Per-tenant schedules and the
// propagation problem"). A profile-zone change does NOT touch all of a user's
// scheduled work uniformly — it splits into three data classes that react in
// three different ways. This is the html-css "colour-coded segments in a
// scannable grid" use case: no real arrows, just a comparison table the
// student reads row-by-row.
//
// Columns: Data class | What it is | Reacts to a zone change? | How.
// The "Reacts?" cell carries the verdict and is tinted to match —
//   green  → future recurring schedule: re-register with the new zone.
//   amber  → future one-shot instant: honoured as-is, explicit rebase only.
//   grey   → past, already-fired instant: immutable, nothing to do.
//
// Desktop renders as a true grid; on narrow viewports each row collapses into
// a stacked card with the column names as labels, so nothing overflows.
// Theme-adaptive chrome via Starlight gray vars; the semantic tints are fixed
// mid-tones so colour survives the light/dark flip. `not-content` defeats
// Starlight's prose table/heading styles.

interface Row {
	tone: 'green' | 'amber' | 'grey';
	dataClass: string;
	what: string;
	icon: string;
	reacts: string;
	how: string;
}

const rows: Row[] = [
	{
		tone: 'green',
		dataClass: 'Future recurring schedule',
		what: 'A pending repeat, e.g. the daily 9 AM summary.',
		icon: '✓',
		reacts: 'Yes',
		how: 'Re-register — schedules.update with the new zone.',
	},
	{
		tone: 'amber',
		dataClass: 'Future one-shot instant',
		what: 'A single delivery already pinned to a Temporal.Instant.',
		icon: '—',
		reacts: 'Honored as-is',
		how: "Don't touch it; offer an explicit rebase prompt if at all.",
	},
	{
		tone: 'grey',
		dataClass: 'Past, already-fired instant',
		what: 'History — a job that already ran.',
		icon: '∅',
		reacts: 'Never',
		how: 'Immutable; nothing to do.',
	},
];

const headers = ['Data class', 'What it is', 'Reacts to a zone change?', 'How'];
---

<div class="tpm not-content">
	<div class="tpm-grid" role="table" aria-label="Timezone-change propagation map">
		<div class="tpm-head" role="row">
			{headers.map((h) => (
				<div class="tpm-th" role="columnheader">
					{h}
				</div>
			))}
		</div>

		{
			rows.map((row) => (
				<div class:list={['tpm-row', `tpm-${row.tone}`]} role="row">
					<div class="tpm-cell tpm-class" role="cell">
						<span class="tpm-colname">Data class</span>
						<span class="tpm-strong">{row.dataClass}</span>
					</div>
					<div class="tpm-cell" role="cell">
						<span class="tpm-colname">What it is</span>
						<span>{row.what}</span>
					</div>
					<div class="tpm-cell tpm-reacts" role="cell">
						<span class="tpm-colname">Reacts?</span>
						<span class:list={['tpm-verdict', `tpm-verdict-${row.tone}`]}>
							<span class="tpm-icon" aria-hidden="true">
								{row.icon}
							</span>
							{row.reacts}
						</span>
					</div>
					<div class="tpm-cell" role="cell">
						<span class="tpm-colname">How</span>
						<span>{row.how}</span>
					</div>
				</div>
			))
		}
	</div>
</div>

<style>
	.tpm {
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.tpm-grid {
		display: grid;
		/* class | what | reacts | how */
		grid-template-columns: 1.2fr 1.5fr 0.9fr 1.6fr;
		gap: 1px;
		background: var(--sl-color-gray-5, #cbd5e1);
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-radius: 12px;
		overflow: hidden;
	}

	.tpm-head,
	.tpm-row {
		display: contents;
	}

	.tpm-th {
		padding: 9px 14px;
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1.2;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #f1f5f9);
	}

	.tpm-cell {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 12px 14px;
		font-size: 0.84rem;
		line-height: 1.4;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-bg, #ffffff);
	}

	/* The leftmost cell of each row carries a tone-tinted accent bar. */
	.tpm-class {
		border-left: 3px solid transparent;
	}

	.tpm-green .tpm-class {
		border-left-color: #16a34a; /* green 600 */
	}
	.tpm-amber .tpm-class {
		border-left-color: #d97706; /* amber 600 */
	}
	.tpm-grey .tpm-class {
		border-left-color: var(--sl-color-gray-4, #94a3b8);
	}

	.tpm-strong {
		font-weight: 700;
	}

	/* The per-row verdict pill, tinted to match the data class. */
	.tpm-verdict {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		align-self: flex-start;
		padding: 3px 10px;
		border-radius: 999px;
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.2;
		border: 1px solid transparent;
	}

	.tpm-icon {
		font-size: 0.86rem;
		line-height: 1;
	}

	.tpm-verdict-green {
		color: #15803d; /* green 700 */
		background: rgba(22, 163, 74, 0.16);
		border-color: rgba(22, 163, 74, 0.45);
	}
	.tpm-verdict-amber {
		color: #b45309; /* amber 700 */
		background: rgba(217, 119, 6, 0.16);
		border-color: rgba(217, 119, 6, 0.45);
	}
	.tpm-verdict-grey {
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-5, #cbd5e1);
		border-color: var(--sl-color-gray-4, #94a3b8);
	}

	/* Per-cell column name — shown only in the stacked (narrow) layout. */
	.tpm-colname {
		display: none;
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* --- narrow viewport: collapse the grid into stacked row-cards --- */
	@media (max-width: 640px) {
		.tpm-grid {
			grid-template-columns: 1fr;
			gap: 0;
		}

		.tpm-head {
			display: none;
		}

		.tpm-row {
			display: flex;
			flex-direction: column;
			border-bottom: 1px solid var(--sl-color-gray-5, #cbd5e1);
		}

		.tpm-row:last-child {
			border-bottom: none;
		}

		.tpm-cell {
			padding: 10px 14px;
		}

		.tpm-class {
			border-left-width: 4px;
		}

		.tpm-colname {
			display: block;
		}
	}
</style>
