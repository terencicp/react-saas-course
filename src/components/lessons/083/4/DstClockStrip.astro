---
// The DST clock-strip panels (Chapter 083 L4, "What DST does to a wall clock").
// One reusable horizontal strip of hour cells, re-skinned per panel of a
// DiagramSequence so the student can scrub one transition at a time. The whole
// point is to make the gap and the repeat *visible* on a wall clock before any
// scheduling code: the html-css "colour-coded segments with callouts" use case.
//
//   step 1 — ordinary day: six neutral cells, evenly spaced, no ambiguity.
//   step 2 — spring forward: the 2 AM cell is struck out / greyed with a red
//            "skipped" badge and a red chevron leaping 1 AM → 3 AM.
//   step 3 — fall back: the single 1 AM cell becomes two stacked tinted cells
//            ("1st" / "2nd") under a "happens twice" badge.
//   step 4 — the operating rule: the 1–3 AM band shaded amber ("never schedule
//            here"), and a second short strip of 9 AM / 12 PM / 5 PM tinted
//            green ("always safe").
//
// Theme-adaptive chrome via Starlight gray vars; the semantic tints (red /
// amber / green / blue / violet) are fixed mid-tones so colour survives the
// light/dark flip. `not-content` + `margin: 0` defeat Starlight's prose styles.

interface Props {
	step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const baseHours = ['12 AM', '1 AM', '2 AM', '3 AM', '4 AM', '5 AM'];
const safeHours = ['9 AM', '12 PM', '5 PM'];
---

<div class="cs not-content" data-step={step}>
	<div class="cs-strip">
		{
			baseHours.map((label) => {
				// Spring forward: the 2 AM hour does not exist.
				if (step === 2 && label === '2 AM') {
					return (
						<div class="cs-cell cs-skipped">
							<span class="cs-label">{label}</span>
							<span class="cs-badge cs-badge-red">skipped</span>
						</div>
					);
				}

				// Fall back: the 1 AM hour happens twice.
				if (step === 3 && label === '1 AM') {
					return (
						<div class="cs-repeat">
							<div class="cs-cell cs-cell-first">
								<span class="cs-label">1 AM</span>
								<span class="cs-occ">1st</span>
							</div>
							<div class="cs-cell cs-cell-second">
								<span class="cs-label">1 AM</span>
								<span class="cs-occ">2nd</span>
							</div>
							<span class="cs-badge cs-badge-twice">happens twice</span>
						</div>
					);
				}

				// The operating rule: amber-shade the 1–3 AM band.
				const inAmberBand =
					step === 4 && (label === '1 AM' || label === '2 AM' || label === '3 AM');

				return (
					<div class:list={['cs-cell', { 'cs-amber': inAmberBand }]}>
						<span class="cs-label">{label}</span>
					</div>
				);
			})
		}

		{/* The red leap 1 AM → 3 AM that skips the missing hour. */}
		{step === 2 && (
			<div class="cs-leap" aria-hidden="true">
				<span class="cs-leap-arrow">⤻</span>
				<span class="cs-leap-text">jumps the gap</span>
			</div>
		)}
	</div>

	{step === 4 && (
		<>
			<div class="cs-band cs-band-amber">
				never schedule in the 1 AM – 3 AM band
			</div>
			<div class="cs-strip cs-strip-safe">
				{safeHours.map((label) => (
					<div class="cs-cell cs-green">
						<span class="cs-label">{label}</span>
					</div>
				))}
			</div>
			<div class="cs-band cs-band-green">always safe — never a gap or a repeat</div>
		</>
	)}
</div>

<style>
	.cs {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		margin: 0;
		padding: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.cs-strip {
		position: relative;
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
		flex-wrap: wrap;
		margin: 0;
	}

	/* The reusable hour cell. */
	.cs-cell {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		flex: 0 0 auto;
		min-width: 4.1rem;
		min-height: 3.4rem;
		padding: 8px 10px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-gray-6, #f1f5f9);
		margin: 0;
	}

	.cs-label {
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.84rem;
		font-weight: 600;
		line-height: 1;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	/* --- step 2: the skipped 2 AM hour --- */
	.cs-skipped {
		border-style: dashed;
		border-color: #dc2626; /* red 600 */
		background: var(--sl-color-gray-6, #f1f5f9);
		opacity: 0.55;
	}

	.cs-skipped .cs-label {
		text-decoration: line-through;
		text-decoration-color: #dc2626;
		text-decoration-thickness: 2px;
	}

	.cs-badge {
		font-size: 0.58rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		line-height: 1;
		padding: 2px 6px;
		border-radius: 999px;
		margin: 0;
	}

	.cs-badge-red {
		color: #ffffff;
		background: #dc2626; /* red 600 */
	}

	.cs-badge-twice {
		color: #ffffff;
		background: #7c3aed; /* violet 600 */
	}

	/* The red leap arrow that bridges 1 AM → 3 AM over the missing hour. */
	.cs-leap {
		position: absolute;
		top: -30px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		gap: 5px;
		margin: 0;
		pointer-events: none;
	}

	.cs-leap-arrow {
		font-size: 1.25rem;
		line-height: 1;
		color: #dc2626; /* red 600 */
		margin: 0;
	}

	.cs-leap-text {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #dc2626;
		margin: 0;
	}

	/* --- step 3: the repeated 1 AM hour, two stacked tinted cells --- */
	.cs-repeat {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 4px;
		flex: 0 0 auto;
		margin: 0;
	}

	.cs-repeat .cs-cell {
		min-height: 2rem;
		padding: 6px 10px;
	}

	.cs-cell-first {
		border-color: #2563eb; /* blue 600 */
		background: rgba(37, 99, 235, 0.16);
	}

	.cs-cell-second {
		border-color: #7c3aed; /* violet 600 */
		background: rgba(124, 58, 237, 0.16);
	}

	.cs-occ {
		font-size: 0.58rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	.cs-repeat .cs-badge-twice {
		position: absolute;
		top: -22px;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
	}

	/* --- step 4: amber danger band + green safe band --- */
	.cs-amber {
		border-color: #d97706; /* amber 600 */
		background: rgba(217, 119, 6, 0.16);
	}

	.cs-amber .cs-label {
		color: var(--sl-color-white, #92400e);
	}

	.cs-green {
		border-color: #16a34a; /* green 600 */
		background: rgba(22, 163, 74, 0.16);
	}

	.cs-strip-safe {
		gap: 6px;
	}

	.cs-band {
		font-size: 0.7rem;
		font-weight: 700;
		text-align: center;
		padding: 3px 12px;
		border-radius: 999px;
		line-height: 1.2;
		margin: 0;
	}

	.cs-band-amber {
		color: #b45309; /* amber 700 */
		background: rgba(217, 119, 6, 0.14);
		border: 1px solid rgba(217, 119, 6, 0.4);
	}

	.cs-band-green {
		color: #15803d; /* green 700 */
		background: rgba(22, 163, 74, 0.14);
		border: 1px solid rgba(22, 163, 74, 0.4);
	}

	@media (max-width: 520px) {
		.cs-cell {
			min-width: 3.4rem;
			min-height: 3rem;
			padding: 6px 7px;
		}
		.cs-label {
			font-size: 0.76rem;
		}
	}
</style>
