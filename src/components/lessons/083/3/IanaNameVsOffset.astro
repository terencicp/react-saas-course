---
// IANA name vs. fixed offset (Chapter 083 L3).
//
// The html-css "colour-coded segments with callouts" use case. One horizontal
// year axis (Jan -> Dec) for a single zone, America/New_York, makes the whole
// "an offset is not a timezone" distinction a picture:
//
//   1. The IANA-NAME band (top) is a RULE that spans the year. It changes value
//      mid-year under one name: -05:00 (EST) in the winter months, -04:00 (EDT)
//      across the summer, EST again at year's end. Two distinct saturated tints
//      carry that change -- the colour is the load-bearing cue. Two thin vertical
//      markers sit on the daylight-saving transitions ("spring forward" mid-March,
//      "fall back" early November).
//
//   2. The FIXED-OFFSET line (bottom) is one FROZEN SAMPLE of that rule: a single
//      flat -05:00 line spanning the whole width. It agrees with the band only
//      until the first transition, then is wrong for ~8 months (the shaded
//      "wrong half the year" stretch) before agreeing again at year's end.
//
// Coordinate system: x = fraction of the year. The two DST transitions for 2026
// in America/New_York are:
//   - spring forward  2026-03-08  ~= day 67/365  -> 18.4%  (rounded to 19%)
//   - fall back       2026-11-01  ~= day 305/365 -> 83.6%  (rounded to 84%)
//
// Theme-adaptive chrome via Starlight gray vars; the two band fills are fixed
// Tailwind-600 mid-tones (white text) so the colour signal survives the theme
// flip, and the fixed-offset line uses red-600 for the "wrong" stretch. Plain
// CSS only (no LeaderLine) so the figure stays expandable. `margin: 0` everywhere
// defeats Starlight's injected prose margins.

const SPRING_PCT = 19; // 2026-03-08 spring forward
const FALL_PCT = 84; // 2026-11-01 fall back

const months = [
	'Jan',
	'Feb',
	'Mar',
	'Apr',
	'May',
	'Jun',
	'Jul',
	'Aug',
	'Sep',
	'Oct',
	'Nov',
	'Dec',
];
---

<div class="ino not-content">
	<div class="ino-zone-label">
		<span class="ino-zone-name">America/New_York</span>
	</div>

	<!-- ===== Row 1: the IANA-name band (a rule across the year) ===== -->
	<div class="ino-row">
		<div class="ino-rail-tag">
			<span class="ino-rail-name">IANA name</span>
			<span class="ino-rail-sub">a rule across the year</span>
		</div>
		<div class="ino-track">
			<div
				class="ino-band"
				style={`--spring: ${SPRING_PCT}%; --fall: ${FALL_PCT}%;`}
			>
				<div class="ino-seg ino-seg-est ino-seg-start">
					<span class="ino-seg-off">−05:00</span>
					<span class="ino-seg-tag">EST</span>
				</div>
				<div class="ino-seg ino-seg-edt">
					<span class="ino-seg-off">−04:00</span>
					<span class="ino-seg-tag">EDT</span>
				</div>
				<div class="ino-seg ino-seg-est ino-seg-end">
					<span class="ino-seg-off">−05:00</span>
					<span class="ino-seg-tag">EST</span>
				</div>

				<!-- the two DST transition markers -->
				<div class="ino-dst" style={`left: ${SPRING_PCT}%`}>
					<span class="ino-dst-cap">spring forward</span>
				</div>
				<div class="ino-dst" style={`left: ${FALL_PCT}%`}>
					<span class="ino-dst-cap">fall back</span>
				</div>
			</div>
		</div>
	</div>

	<!-- ===== Row 2: the fixed-offset line (one frozen sample) ===== -->
	<div class="ino-row ino-row-offset">
		<div class="ino-rail-tag">
			<span class="ino-rail-name">Fixed offset</span>
			<span class="ino-rail-sub">one frozen sample</span>
		</div>
		<div class="ino-track">
			<div
				class="ino-offset"
				style={`--spring: ${SPRING_PCT}%; --fall: ${FALL_PCT}%;`}
			>
				<!-- the stored value: a flat -05:00 line across the whole year -->
				<div class="ino-offset-line">
					<span class="ino-offset-pill">−05:00</span>
				</div>
				<!-- shaded stretch where the frozen sample is wrong -->
				<div class="ino-wrong">
					<span class="ino-wrong-cap">wrong half the year</span>
				</div>
			</div>
		</div>
	</div>

	<!-- ===== the shared year axis ===== -->
	<div class="ino-row ino-row-axis">
		<div class="ino-rail-tag ino-rail-tag-axis"></div>
		<div class="ino-track">
			<div class="ino-axis">
				{months.map((m) => <span class="ino-month">{m}</span>)}
			</div>
		</div>
	</div>
</div>

<style>
	.ino {
		box-sizing: border-box;
		width: 100%;
		margin: 0;
		padding: 2px 0 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		color: var(--sl-color-white, #1e293b);
	}

	.ino *,
	.ino *::before,
	.ino *::after {
		box-sizing: border-box;
	}

	.ino-zone-label {
		margin: 0 0 6px;
		text-align: center;
	}

	.ino-zone-name {
		display: inline-block;
		margin: 0;
		padding: 2px 10px;
		border-radius: 7px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg-sidebar, #f1f5f9);
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}

	/* a row = a left tag + a full-width track that all rows share */
	.ino-row {
		display: flex;
		align-items: stretch;
		gap: 10px;
		margin: 0;
	}

	.ino-row-offset {
		margin: 30px 0 0;
	}

	.ino-row-axis {
		margin: 6px 0 0;
	}

	.ino-rail-tag {
		flex: 0 0 6rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1px;
		margin: 0;
		text-align: right;
	}

	.ino-rail-tag-axis {
		min-height: 0;
	}

	.ino-rail-name {
		font-size: 0.8rem;
		font-weight: 800;
		line-height: 1.05;
		margin: 0;
		color: var(--sl-color-white, #1e293b);
	}

	.ino-rail-sub {
		font-size: 0.6rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.ino-track {
		position: relative;
		flex: 1 1 auto;
		min-width: 0;
		margin: 0;
	}

	/* ===== Row 1: the IANA-name band ===== */
	.ino-band {
		position: relative;
		display: flex;
		height: 52px;
		margin: 0;
		border-radius: 10px;
		overflow: visible;
	}

	.ino-seg {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1px;
		margin: 0;
		color: #ffffff;
		min-width: 0;
		overflow: hidden;
	}

	/* EST winter segments: amber 600 (matches the chapter's L2 palette) */
	.ino-seg-est {
		background: #d97706;
		border: 1px solid #b45309;
	}

	.ino-seg-start {
		flex: 0 0 var(--spring);
		border-right: none;
		border-radius: 10px 0 0 10px;
	}

	.ino-seg-end {
		flex: 0 0 calc(100% - var(--fall));
		border-left: none;
		border-radius: 0 10px 10px 0;
	}

	/* EDT summer segment: blue 600 */
	.ino-seg-edt {
		flex: 0 0 calc(var(--fall) - var(--spring));
		background: #2563eb;
		border: 1px solid #1d4ed8;
		border-left: none;
		border-right: none;
	}

	.ino-seg-off {
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.92rem;
		font-weight: 800;
		line-height: 1;
		margin: 0;
		white-space: nowrap;
	}

	.ino-seg-tag {
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		opacity: 0.85;
		margin: 0;
	}

	/* the two DST transition markers, sitting on the band's seams */
	.ino-dst {
		position: absolute;
		top: -6px;
		bottom: -6px;
		width: 0;
		border-left: 2px dashed var(--sl-color-gray-2, #475569);
		margin: 0;
		z-index: 2;
	}

	.ino-dst-cap {
		position: absolute;
		bottom: 100%;
		left: 50%;
		transform: translateX(-50%);
		margin: 0 0 3px;
		padding: 1px 6px;
		border-radius: 6px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg-sidebar, #f1f5f9);
		font-size: 0.6rem;
		font-weight: 700;
		white-space: nowrap;
		color: var(--sl-color-gray-2, #475569);
	}

	/* ===== Row 2: the fixed-offset line ===== */
	.ino-offset {
		position: relative;
		height: 34px;
		margin: 0;
	}

	/* the shaded stretch (spring -> fall) where -05:00 is wrong */
	.ino-wrong {
		position: absolute;
		top: 0;
		bottom: 0;
		left: var(--spring);
		width: calc(var(--fall) - var(--spring));
		margin: 0;
		border-radius: 6px;
		background: rgba(220, 38, 38, 0.13); /* red 600 tint */
		border: 1px dashed rgba(220, 38, 38, 0.55);
	}

	.ino-wrong-cap {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		margin: 0;
		padding: 1px 7px;
		border-radius: 6px;
		background: #dc2626; /* red 600 */
		color: #ffffff;
		font-size: 0.64rem;
		font-weight: 700;
		white-space: nowrap;
	}

	/* the flat -05:00 line itself, drawn on top of the shaded stretch */
	.ino-offset-line {
		position: absolute;
		top: 50%;
		left: 0;
		right: 0;
		height: 0;
		margin: 0;
		border-top: 3px solid #b45309; /* amber 700 — same family as EST */
		z-index: 1;
	}

	.ino-offset-pill {
		position: absolute;
		top: 50%;
		left: 0;
		transform: translateY(-50%);
		margin: 0;
		padding: 1px 7px;
		border-radius: 6px;
		background: #d97706; /* amber 600 — the stored EST sample */
		color: #ffffff;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.74rem;
		font-weight: 800;
		white-space: nowrap;
		z-index: 2;
	}

	/* ===== shared year axis ===== */
	.ino-axis {
		display: flex;
		margin: 0;
		border-top: 2px solid var(--sl-color-gray-4, #94a3b8);
	}

	.ino-month {
		flex: 1 1 0;
		min-width: 0;
		margin: 0;
		padding: 3px 0 0;
		text-align: center;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* On narrow viewports, drop the rail tags above their tracks so the band
	   keeps its full width. */
	@media (max-width: 560px) {
		.ino-row {
			flex-direction: column;
			gap: 3px;
		}
		.ino-rail-tag {
			flex: 0 0 auto;
			text-align: left;
		}
		.ino-rail-tag-axis {
			display: none;
		}
		.ino-row-offset {
			margin-top: 26px;
		}
	}
</style>
