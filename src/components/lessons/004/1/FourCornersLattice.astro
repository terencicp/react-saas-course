---
// Diagram: the four corners of TypeScript's type system, laid out as a lattice.
// Left column = top of the lattice (any over unknown; both accept every value
// but differ in soundness). Middle = concrete types (string, User, ...) shown
// dim because they're the everyday surface, not the lesson. Right = bottom of
// the lattice (never; no inhabitants). Below the lattice row, separated by a
// thin rule, sits void on its own — it isn't a position in the lattice at all,
// just a marker on function returns.
//
// Pure HTML+CSS (no JS, no <style> tag) so a reader can devtools-inspect the
// flexbox and see the layout. Every nested element resets `margin: 0` to
// dodge Starlight's prose-margin injection (see html-css.md).

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones — readable against both light and dark page backgrounds.
const UNSOUND_RED = '#dc2626'; // any
const SOUND_GREEN = '#16a34a'; // unknown
const NEVER_PURPLE = '#7c3aed'; // never
const VOID_GRAY = '#64748b'; // void

const cornerBoxBase =
	'border-radius: 8px; padding: 14px 16px; background: var(--sl-color-bg-sidebar); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 18px; font-weight: 600; text-align: center; margin: 0;';

const badgeBase =
	'display: inline-block; margin: 8px 0 0; padding: 3px 8px; border-radius: 999px; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 11px; font-weight: 500; line-height: 1.3; color: #ffffff;';

const columnLabel =
	'margin: 0 0 10px; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--sl-color-gray-3); text-align: center;';
---

<Figure caption="The four corners of the type system. `any` and `unknown` accept every value; `never` accepts none. `void` lives outside the lattice — it qualifies a function's return, not a value.">
	<div style="display: flex; flex-direction: column; gap: 18px; margin: 0;">
		{/* Lattice row: top corners (left), concrete middle, bottom corner (right) */}
		<div
			style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; align-items: stretch; margin: 0;"
		>
			{/* LEFT: Top of the lattice — any over unknown */}
			<div style="display: flex; flex-direction: column; margin: 0;">
				<div style={columnLabel}>Top of the lattice</div>
				<div style="display: flex; flex-direction: column; gap: 10px; margin: 0;">
					<div
						style={`${cornerBoxBase} border: 2px solid ${UNSOUND_RED};`}
					>
						<div style="margin: 0;">any</div>
						<div style={`${badgeBase} background: ${UNSOUND_RED};`}>
							unsound — accepts every value, propagates outward
						</div>
					</div>
					<div
						style={`${cornerBoxBase} border: 2px solid ${SOUND_GREEN};`}
					>
						<div style="margin: 0;">unknown</div>
						<div style={`${badgeBase} background: ${SOUND_GREEN};`}>
							sound — accepts every value, requires narrowing to read
						</div>
					</div>
				</div>
			</div>

			{/* MIDDLE: Concrete types (dim — everyday surface, not the lesson) */}
			<div style="display: flex; flex-direction: column; margin: 0;">
				<div style={columnLabel}>Everyday surface</div>
				<div
					style="flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 14px 16px; border-radius: 8px; border: 1px dashed var(--sl-color-gray-4); background: transparent; opacity: 0.7; margin: 0;"
				>
					<div
						style="margin: 0; font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-size: 14px; font-weight: 600; color: var(--sl-color-gray-2);"
					>
						Concrete types
					</div>
					<div
						style="margin: 6px 0 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; color: var(--sl-color-gray-3); text-align: center; line-height: 1.5;"
					>
						string, number, boolean,<br />User, Invoice, …
					</div>
				</div>
			</div>

			{/* RIGHT: Bottom of the lattice — never */}
			<div style="display: flex; flex-direction: column; margin: 0;">
				<div style={columnLabel}>Bottom of the lattice</div>
				<div
					style="flex: 1; display: flex; flex-direction: column; justify-content: center; margin: 0;"
				>
					<div
						style={`${cornerBoxBase} border: 2px solid ${NEVER_PURPLE};`}
					>
						<div style="margin: 0;">never</div>
						<div style={`${badgeBase} background: ${NEVER_PURPLE};`}>
							no inhabitants — uninhabited type
						</div>
					</div>
				</div>
			</div>
		</div>

		{/* Thin separator + "Outside the lattice" row for void */}
		<div
			style="border-top: 1px dashed var(--sl-color-gray-4); padding-top: 14px; display: flex; flex-direction: column; align-items: center; gap: 8px; margin: 0;"
		>
			<div style={columnLabel}>Outside the lattice</div>
			<div
				style={`${cornerBoxBase} border: 2px solid ${VOID_GRAY}; min-width: 220px;`}
			>
				<div style="margin: 0;">void</div>
				<div
					style="margin: 8px 0 0; font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-size: 12px; font-weight: 400; color: var(--sl-color-gray-2); line-height: 1.4;"
				>
					function-return marker,<br />not a position on the lattice
				</div>
			</div>
		</div>
	</div>
</Figure>
