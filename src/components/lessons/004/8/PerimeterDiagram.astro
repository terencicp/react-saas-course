---
// Diagram: the boundary rule, drawn spatially. A single "module" rectangle
// with three regions left-to-right: a thin annotated left edge (Exports), a
// large inferred interior (Internal body), a thin annotated right edge
// (Parameters). The two annotated edges share a "contract blue" so they read
// as one perimeter; the interior is a muted green tone — calm, unannotated,
// "free territory."
//
// Pure HTML+CSS (no JS, no <style> tag) so a reader can devtools-inspect the
// flexbox. Every nested element resets `margin: 0` to dodge Starlight's
// prose-margin injection (see html-css.md).
//
// The small inline SVG arrows on the band labels reinforce flow direction:
// exports flow OUT of the module (leftward chevron on the left edge), parameters
// flow IN from callers (leftward chevron on the right edge — pointing toward
// the interior).

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones — readable against both light and dark page backgrounds.
const CONTRACT_BLUE = '#2563eb'; // exports & parameters — the perimeter
const INFER_GREEN = '#16a34a'; // interior — inference territory

const bandStyle = `display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; padding: 18px 12px; background: ${CONTRACT_BLUE}; color: #ffffff; margin: 0; min-width: 110px;`;

const bandLabelStyle =
	'margin: 0; writing-mode: vertical-rl; transform: rotate(180deg); font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;';

const bandHintStyle =
	'margin: 0; writing-mode: vertical-rl; transform: rotate(180deg); font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 11px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.85;';

const interiorLabelStyle =
	'margin: 0; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 16px; font-weight: 600; color: var(--sl-color-white); text-align: center;';

const interiorHintStyle =
	'margin: 4px 0 0; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--sl-color-gray-3); text-align: center;';

const interiorListStyle =
	'margin: 14px 0 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 6px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px; color: var(--sl-color-gray-2); text-align: center;';
---

<Figure
	caption="Types live at the module's perimeter; inference fills the interior."
>
	{/* The module rectangle. A single bordered card; three flex regions inside. */}
	<div
		style="display: flex; flex-direction: row; align-items: stretch; border-radius: 10px; overflow: hidden; border: 1px solid var(--sl-color-gray-5); margin: 0;"
	>
		{/* LEFT EDGE — Exports (annotate). Contract blue; vertical label;
		    outward chevron pointing left (out of the module). */}
		<div style={bandStyle}>
			<svg
				width="20"
				height="20"
				viewBox="0 0 20 20"
				fill="none"
				aria-hidden="true"
				style="margin: 0; flex-shrink: 0;"
			>
				<path
					d="M14 4 L6 10 L14 16"
					stroke="#ffffff"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				></path>
			</svg>
			<div style={bandLabelStyle}>Exports</div>
			<div style={bandHintStyle}>Annotate</div>
		</div>

		{/* CENTER — Internal body (infer). Muted green; locals, intermediate
		    values, internal helpers. Visually calm — no chrome, no badges. */}
		<div
			style={`flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 36px 28px; background: color-mix(in oklab, ${INFER_GREEN} 16%, var(--sl-color-bg-sidebar)); margin: 0;`}
		>
			<div style={interiorLabelStyle}>Internal body</div>
			<div style={interiorHintStyle}>Infer</div>
			<ul style={interiorListStyle}>
				<li style="margin: 0;">locals</li>
				<li style="margin: 0;">inline callbacks</li>
				<li style="margin: 0;">internal helper returns</li>
			</ul>
		</div>

		{/* RIGHT EDGE — Parameters (annotate). Same contract blue; vertical
		    label; inward chevron pointing left (into the module). */}
		<div style={bandStyle}>
			<svg
				width="20"
				height="20"
				viewBox="0 0 20 20"
				fill="none"
				aria-hidden="true"
				style="margin: 0; flex-shrink: 0;"
			>
				<path
					d="M14 4 L6 10 L14 16"
					stroke="#ffffff"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				></path>
			</svg>
			<div style={bandLabelStyle}>Parameters</div>
			<div style={bandHintStyle}>Annotate</div>
		</div>
	</div>
</Figure>
