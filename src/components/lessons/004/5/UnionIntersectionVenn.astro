---
// Diagram: two Venn-style panels side by side. Left panel shades both circles
// (union — every value in either set). Right panel shades only the overlap
// (intersection — values in both sets at once). Hand-coded SVG so the two
// pictures sit at the same scale and read as one unit.
//
// Style mirrors FourCornersLattice (lesson 1): sl-color tokens for chrome,
// saturated mid-tones for accent fills that read against both light and dark
// backgrounds.

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones — readable against both light and dark backgrounds.
const UNION_FILL = '#0ea5e9'; // sky-500 — both circles
const INTERSECTION_FILL = '#f97316'; // orange-500 — overlap only
const CIRCLE_STROKE = 'currentColor';

// Geometry shared by both panels. viewBox is 220×160 — wide enough for two
// circles of r=50 overlapping by ~40px, tall enough for circle labels above
// and the small caption space below.
const cx_a = 75;
const cx_b = 145;
const cy = 80;
const r = 50;

const panelLabelStyle =
	'margin: 0 0 6px; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--sl-color-gray-3); text-align: center;';

const panelSubtitleStyle =
	'margin: 6px 0 0; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 12px; font-weight: 400; color: var(--sl-color-gray-2); text-align: center; line-height: 1.4;';
---

<Figure
	caption="Two operators, two set operations. The union shades both circles; the intersection shades only the overlap."
>
	<div
		style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: stretch; margin: 0;"
	>
		{/* LEFT PANEL — Union: both circles fully shaded */}
		<div
			style="display: flex; flex-direction: column; padding: 12px; border-radius: 8px; background: var(--sl-color-bg-sidebar); margin: 0;"
		>
			<div style={panelLabelStyle}>
				Union — <code style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px;">A | B</code>
			</div>
			<svg
				viewBox="0 0 220 160"
				role="img"
				aria-label="Two overlapping circles labeled A and B, both fully shaded to represent the union of A and B."
				xmlns="http://www.w3.org/2000/svg"
				style="width: 100%; height: auto; display: block;"
			>
				{/* Circle A — full fill */}
				<circle
					cx={cx_a}
					cy={cy}
					r={r}
					fill={UNION_FILL}
					fill-opacity="0.55"
					stroke={CIRCLE_STROKE}
					stroke-width="1.5"
				/>
				{/* Circle B — full fill (overlap renders darker via additive opacity) */}
				<circle
					cx={cx_b}
					cy={cy}
					r={r}
					fill={UNION_FILL}
					fill-opacity="0.55"
					stroke={CIRCLE_STROKE}
					stroke-width="1.5"
				/>
				{/* Circle labels — placed near the outer edge of each circle */}
				<text
					x={cx_a - r + 12}
					y={cy + 5}
					font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
					font-size="18"
					font-weight="600"
					fill="currentColor"
					text-anchor="middle"
				>
					A
				</text>
				<text
					x={cx_b + r - 12}
					y={cy + 5}
					font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
					font-size="18"
					font-weight="600"
					fill="currentColor"
					text-anchor="middle"
				>
					B
				</text>
			</svg>
			<div style={panelSubtitleStyle}>
				Every value in either circle.<br />The set of inhabitants grows.
			</div>
		</div>

		{/* RIGHT PANEL — Intersection: only the overlap shaded */}
		<div
			style="display: flex; flex-direction: column; padding: 12px; border-radius: 8px; background: var(--sl-color-bg-sidebar); margin: 0;"
		>
			<div style={panelLabelStyle}>
				Intersection — <code style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px;">A & B</code>
			</div>
			<svg
				viewBox="0 0 220 160"
				role="img"
				aria-label="Two overlapping circles labeled A and B, with only the overlapping region shaded to represent the intersection of A and B."
				xmlns="http://www.w3.org/2000/svg"
				style="width: 100%; height: auto; display: block;"
			>
				{/* defs: clip path that constrains a fill to circle A's interior */}
				<defs>
					<clipPath id="clip-circle-a">
						<circle cx={cx_a} cy={cy} r={r} />
					</clipPath>
				</defs>
				{/* Circle A — outline only */}
				<circle
					cx={cx_a}
					cy={cy}
					r={r}
					fill="none"
					stroke={CIRCLE_STROKE}
					stroke-width="1.5"
				/>
				{/* Circle B — outline only */}
				<circle
					cx={cx_b}
					cy={cy}
					r={r}
					fill="none"
					stroke={CIRCLE_STROKE}
					stroke-width="1.5"
				/>
				{/* Overlap fill — circle B drawn filled but clipped to circle A's region.
				    The intersection of two circles equals "inside A AND inside B"; clipping
				    a full B circle to A's path leaves only the overlapping lens. */}
				<circle
					cx={cx_b}
					cy={cy}
					r={r}
					fill={INTERSECTION_FILL}
					fill-opacity="0.7"
					clip-path="url(#clip-circle-a)"
				/>
				{/* Circle labels — placed near the outer edge of each circle */}
				<text
					x={cx_a - r + 12}
					y={cy + 5}
					font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
					font-size="18"
					font-weight="600"
					fill="currentColor"
					text-anchor="middle"
				>
					A
				</text>
				<text
					x={cx_b + r - 12}
					y={cy + 5}
					font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
					font-size="18"
					font-weight="600"
					fill="currentColor"
					text-anchor="middle"
				>
					B
				</text>
			</svg>
			<div style={panelSubtitleStyle}>
				Values in both circles at once.<br />On shape types, the set of fields grows.
			</div>
		</div>
	</div>
</Figure>
