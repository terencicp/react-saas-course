---
// two-attack-contrast — Chapter 074 Lesson 1, "Two layers: edge WAF and
// application limiter", section "One attacker, ten thousand IPs, one victim's
// email".
//
// The load-bearing intuition of the chapter, as two tabs the student flips
// between. The ONLY thing that changes between tabs is WHICH gate trips:
//
//   Tab 1 (Single-source brute force):
//     one [1 IP] box → many requests → [Per-IP gate] (RED, blocks). The crude
//     attack hammers from one address, so counting per-IP catches it. The arrow
//     onward to Sign-in is struck through.
//
//   Tab 2 (Distributed credential stuffing):
//     a stacked cluster [10,000 IPs] → one request each → [Per-IP gate] (GREEN,
//     passes — each IP under budget) → [Per-email gate] keyed on one email (RED,
//     blocks). Per-IP sees nothing; only the per-email gate, counting against the
//     one targeted email, catches the convergence. The arrow onward is struck.
//
// Why NOT <ArrowDiagram> here: its arrows are LeaderLines positioned from
// document.body and built ONCE after `load`. Inside a TabbedContent the inactive
// tab is `hidden` (display:none) at build time, so its boxes measure 0×0 and the
// lines draw as garbage, and there is no reliable tab-switch hook to rebuild
// them. So the arrows are authored as plain CSS rules + inline SVG instead — they
// live in normal flow, need no measuring, and render correctly whether the tab is
// shown or hidden. Same discipline as the sibling 053 phishing-contrast figure.
//
// Palette — mid-tones that read on both themes; color-scheme pinned light so the
// hand-picked accent tints survive dark mode. margin:0 resets defeat Starlight's
// injected prose margins; `not-content` opts the figure out of prose styling.

import Figure from '../../../figures/Figure.astro';
import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const INK_FAINT = '#94a3b8'; // slate-400 — idle / dimmed
const SURFACE = '#ffffff';
const GRID = '#e2e8f0'; // slate-200 — soft borders

const RED = '#dc2626'; // a gate that TRIPS (blocks the attack)
const GREEN = '#16a34a'; // a gate that PASSES (lets the request through)
const SLATE = '#64748b'; // neutral request arrows

const ALT_1 =
	'A single attacker IP fires many sign-in requests at one email. They all pass through the per-IP gate, which counts them against that one IP and trips, blocking the path to sign-in.';
const ALT_2 =
	'Ten thousand attacker IPs each fire one request at one email. The per-IP gate sees each IP under budget and passes them all. Only the second gate, the per-email gate counting against the one targeted email, trips and blocks the path to sign-in.';
---

<TabbedContent>
	<TabbedItem
		label="Single-source brute force"
		caption="A crude brute force comes from one address. The per-IP limit counts every request against that one IP and stops it."
	>
		<Figure expandable={false}>
			<div class="tac not-content" role="img" aria-label={ALT_1}>
				{/* col 1: the one attacker IP */}
				<div class="tac-col tac-col-src">
					<div class="tac-box tac-ip-single">
						<span class="tac-role">Attacker</span>
						<span class="tac-name">1 IP</span>
						<span class="tac-sub">one machine</span>
					</div>
				</div>

				{/* the fan of many requests from one IP → per-IP gate */}
				<div class="tac-flow">
					<span class="tac-flow-label">many from one IP</span>
					<svg class="tac-fan" viewBox="0 0 120 70" preserveAspectRatio="none" aria-hidden="true">
						<line x1="2" y1="35" x2="116" y2="14" stroke={SLATE} stroke-width="2.4"></line>
						<line x1="2" y1="35" x2="116" y2="35" stroke={SLATE} stroke-width="2.4"></line>
						<line x1="2" y1="35" x2="116" y2="56" stroke={SLATE} stroke-width="2.4"></line>
						<polygon points="116,35 107,31 107,39" fill={SLATE}></polygon>
					</svg>
				</div>

				{/* col 2: the per-IP gate — it TRIPS here (red) */}
				<div class="tac-col">
					<div class="tac-box tac-gate tac-gate-block">
						<span class="tac-gate-tag">Per-IP gate</span>
						<span class="tac-name tac-name-block">BLOCKED</span>
						<span class="tac-sub">counts every request from that one IP</span>
					</div>
				</div>

				{/* the struck arrow onward → sign-in never reached */}
				<div class="tac-flow tac-flow-end">
					<svg class="tac-onward" viewBox="0 0 96 30" preserveAspectRatio="none" aria-hidden="true">
						<line x1="2" y1="15" x2="92" y2="15" stroke={INK_FAINT} stroke-width="2.2" stroke-dasharray="5 4"></line>
						<line x1="40" y1="3" x2="56" y2="27" stroke={RED} stroke-width="3.4" stroke-linecap="round"></line>
					</svg>
				</div>

				{/* col 3: sign-in, dimmed — never reached */}
				<div class="tac-col">
					<div class="tac-box tac-signin tac-dim">
						<span class="tac-role">Protected</span>
						<span class="tac-name">Sign-in</span>
					</div>
				</div>
			</div>
		</Figure>
	</TabbedItem>

	<TabbedItem
		label="Distributed credential stuffing"
		caption="A distributed attack spreads one-request-each across thousands of IPs, so the per-IP gate sees nothing. Only a per-email limit — counting against the one email under attack — catches it. And that limit lives inside the app, where the email is visible."
	>
		<Figure expandable={false}>
			<div class="tac tac-wide not-content" role="img" aria-label={ALT_2}>
				{/* col 1: the botnet — a stack of overlapping IP cards with the count */}
				<div class="tac-col tac-col-src">
					<div class="tac-stack">
						<span class="tac-stack-card tac-stack-3"></span>
						<span class="tac-stack-card tac-stack-2"></span>
						<div class="tac-box tac-ip-many tac-stack-1">
							<span class="tac-role">Botnet</span>
							<span class="tac-name">10,000 IPs</span>
							<span class="tac-sub">one request each</span>
						</div>
					</div>
				</div>

				{/* the fan of one-each requests → per-IP gate */}
				<div class="tac-flow">
					<span class="tac-flow-label">one each, 10k IPs</span>
					<svg class="tac-fan" viewBox="0 0 120 70" preserveAspectRatio="none" aria-hidden="true">
						<line x1="2" y1="14" x2="116" y2="32" stroke={SLATE} stroke-width="2.2"></line>
						<line x1="2" y1="35" x2="116" y2="35" stroke={SLATE} stroke-width="2.2"></line>
						<line x1="2" y1="56" x2="116" y2="38" stroke={SLATE} stroke-width="2.2"></line>
						<polygon points="116,35 107,31 107,39" fill={SLATE}></polygon>
					</svg>
				</div>

				{/* col 2: the per-IP gate — it PASSES here (green) */}
				<div class="tac-col">
					<div class="tac-box tac-gate tac-gate-pass">
						<span class="tac-gate-tag">Per-IP gate</span>
						<span class="tac-name tac-name-pass">PASSES</span>
						<span class="tac-sub">each IP is under budget</span>
					</div>
				</div>

				{/* arrow onward → per-email gate (the convergence point) */}
				<div class="tac-flow tac-flow-mid">
					<span class="tac-flow-label">one email targeted</span>
					<svg class="tac-onward" viewBox="0 0 96 30" preserveAspectRatio="none" aria-hidden="true">
						<line x1="2" y1="15" x2="92" y2="15" stroke={SLATE} stroke-width="2.2"></line>
						<polygon points="92,15 83,11 83,19" fill={SLATE}></polygon>
					</svg>
				</div>

				{/* col 3: the per-email gate — it TRIPS here (red) */}
				<div class="tac-col">
					<div class="tac-box tac-gate tac-gate-block">
						<span class="tac-gate-tag">Per-email gate</span>
						<span class="tac-name tac-name-block">BLOCKED</span>
						<span class="tac-sub">counts attempts on the targeted email</span>
					</div>
				</div>

				{/* the struck arrow onward → sign-in never reached */}
				<div class="tac-flow tac-flow-end">
					<svg class="tac-onward" viewBox="0 0 96 30" preserveAspectRatio="none" aria-hidden="true">
						<line x1="2" y1="15" x2="92" y2="15" stroke={INK_FAINT} stroke-width="2.2" stroke-dasharray="5 4"></line>
						<line x1="40" y1="3" x2="56" y2="27" stroke={RED} stroke-width="3.4" stroke-linecap="round"></line>
					</svg>
				</div>

				{/* col 4: sign-in, dimmed — never reached */}
				<div class="tac-col">
					<div class="tac-box tac-signin tac-dim">
						<span class="tac-role">Protected</span>
						<span class="tac-name">Sign-in</span>
					</div>
				</div>
			</div>
		</Figure>
	</TabbedItem>
</TabbedContent>

<style define:vars={{ INK, INK_SOFT, INK_FAINT, SURFACE, GRID, RED, GREEN, sans, mono }}>
	.tac {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: center;
		gap: 0;
		margin: 0;
		padding: 10px 2px;
		color-scheme: light;
		font-family: var(--sans);
		color: var(--INK);
	}

	.tac :global(*) {
		margin: 0;
	}

	/* ── columns hold one box each, vertically centered ── */
	.tac-col {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
	}

	/* ── a node box ── */
	.tac-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		padding: 11px 14px;
		border: 1.5px solid var(--GRID);
		border-radius: 11px;
		background: var(--SURFACE);
		text-align: center;
		min-width: 92px;
	}

	.tac-role {
		font-family: var(--sans);
		font-size: 9.5px;
		font-weight: 600;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--INK-FAINT);
		line-height: 1.2;
	}

	.tac-name {
		font-family: var(--sans);
		font-size: 15px;
		font-weight: 800;
		line-height: 1.15;
		color: var(--INK);
	}

	.tac-sub {
		font-family: var(--mono);
		font-size: 9.5px;
		font-weight: 600;
		line-height: 1.25;
		color: var(--INK-SOFT);
		max-width: 13ch;
	}

	/* ── the botnet stack: two ghost cards peeking behind the real one ── */
	.tac-stack {
		position: relative;
		display: inline-block;
	}
	.tac-stack-card {
		position: absolute;
		inset: 0;
		border: 1.5px solid var(--GRID);
		border-radius: 11px;
		background: color-mix(in srgb, var(--GRID) 30%, var(--SURFACE));
	}
	.tac-stack-2 {
		transform: translate(5px, -5px);
	}
	.tac-stack-3 {
		transform: translate(10px, -10px);
		opacity: 0.7;
	}
	.tac-stack-1 {
		position: relative;
	}

	/* ── gate boxes: pass = green, block = red ── */
	.tac-gate {
		min-width: 116px;
	}
	.tac-gate-tag {
		font-family: var(--mono);
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.02em;
		line-height: 1.2;
		color: var(--INK-SOFT);
	}
	.tac-gate-block {
		border-color: var(--RED);
		background: color-mix(in srgb, var(--RED) 8%, var(--SURFACE));
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--RED) 45%, transparent);
	}
	.tac-gate-pass {
		border-color: var(--GREEN);
		background: color-mix(in srgb, var(--GREEN) 8%, var(--SURFACE));
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--GREEN) 45%, transparent);
	}
	.tac-name-block {
		font-size: 13px;
		letter-spacing: 0.04em;
		color: color-mix(in srgb, var(--RED) 25%, var(--INK));
	}
	.tac-name-pass {
		font-size: 13px;
		letter-spacing: 0.04em;
		color: color-mix(in srgb, var(--GREEN) 30%, var(--INK));
	}

	.tac-dim {
		opacity: 0.6;
	}

	/* ── flow segments between boxes ── */
	.tac-flow {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		flex: 1 1 96px;
		min-width: 64px;
		max-width: 130px;
		padding: 0 4px;
	}
	.tac-flow-end {
		flex: 0 1 80px;
		min-width: 56px;
	}
	.tac-flow-mid {
		flex: 1 1 110px;
	}

	/* ── tab 2 packs four boxes + four flow segments into the same strip width, so
	      it gets tighter gaps, slimmer boxes, and a smaller stack peek than tab 1. ── */
	.tac-wide .tac-flow {
		flex: 1 1 64px;
		min-width: 44px;
		max-width: 96px;
		padding: 0 2px;
	}
	.tac-wide .tac-flow-end {
		flex: 0 1 52px;
		min-width: 40px;
	}
	.tac-wide .tac-flow-mid {
		flex: 1 1 78px;
	}
	.tac-wide .tac-box {
		min-width: 80px;
		padding: 10px 9px;
	}
	.tac-wide .tac-gate {
		min-width: 96px;
	}
	.tac-wide .tac-sub {
		max-width: 12ch;
	}

	.tac-flow-label {
		font-family: var(--mono);
		font-size: 9px;
		font-weight: 700;
		line-height: 1.2;
		text-align: center;
		color: var(--INK-SOFT);
		margin-bottom: 4px;
		white-space: nowrap;
		max-width: 100%;
		overflow: visible;
	}

	.tac-fan {
		display: block;
		width: 100%;
		height: 56px;
		overflow: visible;
	}
	.tac-onward {
		display: block;
		width: 100%;
		height: 26px;
		overflow: visible;
	}

	/* ── medium-narrow viewports: shrink flow segments and boxes so the strip stays
	      one horizontal line without clipping. ── */
	@media (max-width: 720px) {
		.tac-flow {
			min-width: 48px;
			flex-basis: 64px;
		}
		.tac-flow-label {
			font-size: 8px;
		}
		.tac-box {
			min-width: 78px;
			padding: 9px 10px;
		}
		.tac-name {
			font-size: 13px;
		}
		.tac-sub {
			font-size: 8.5px;
		}
	}

	/* ── phones: a 3-to-4-node horizontal strip can't fit ~300px without clipping,
	      so let it scroll horizontally as one intact swipeable line rather than
	      crushing or cropping the boxes. Pin each segment's min so the total
	      overflows and the browser offers the scroll. ── */
	@media (max-width: 560px) {
		.tac {
			justify-content: flex-start;
			overflow-x: auto;
			padding-bottom: 6px;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: thin;
		}
		.tac-col {
			flex: 0 0 auto;
		}
		.tac-flow {
			flex: 0 0 auto;
			min-width: 52px;
			max-width: none;
		}
		.tac-flow-end {
			flex: 0 0 auto;
			min-width: 44px;
		}
		.tac-wide .tac-flow {
			min-width: 48px;
		}
		.tac-flow-label {
			white-space: nowrap;
		}
	}
</style>
