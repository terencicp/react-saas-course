---
// waf-rule-mock — Chapter 074 Lesson 1, "Two layers: edge WAF and application
// limiter", section "Before the public URL: the edge layer is enough".
//
// A non-functional mock of a Vercel WAF rate-limit rule, styled like a dashboard
// rule card, to make "two clicks in the dashboard" concrete WITHOUT writing any
// rule code. The whole point is the SHAPE of a WAF rule: a condition and an
// action.
//
//   WHEN  (condition)
//     request path matches  /api/auth/*
//     AND  requests from one IP exceed  20 requests / 10s
//   THEN  (action)
//     [ Deny ]  ← selected      Log  ← the other option
//
// The two condition rows joined by an explicit AND connector teach that a WAF
// rule sees path + per-IP rate (and nothing in the body). The action row shows
// Deny selected with Log sitting beside it as the sibling alternative — the rule
// can observe OR block. A small "no redeploy / no compute billed" footnote nails
// the senior-relevant property the prose calls out.
//
// Why plain HTML+CSS, not a screenshot: no real asset to maintain, it stays
// theme-aware, and a reader can open devtools on the card. Same palette,
// light-pinned color-scheme, margin:0 resets, and `not-content` opt-out as the
// sibling RequestPathStrip / TwoAttackContrast figures so the chapter reads as
// one consistent map.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const INK_FAINT = '#94a3b8'; // slate-400 — labels / dimmed
const SURFACE = '#ffffff';
const GRID = '#e2e8f0'; // slate-200 — soft borders
const GRID_SOFT = '#f1f5f9'; // slate-100 — inner block fill

const EDGE = '#7c3aed'; // violet-600 — the edge / WAF accent (matches the strip)
const RED = '#dc2626'; // red-600 — the Deny action
const GREEN = '#16a34a'; // green-600 — "enabled" status dot

const ALT =
	'A mock of a Vercel WAF rate-limit rule, shaped like a dashboard card. Title: Rate limit — auth endpoints, status Enabled. A WHEN block holds two conditions joined by AND: request path matches /api/auth/* AND requests from one IP exceed 20 requests per 10 seconds. A THEN block shows the action set to Deny, selected, with Log shown beside it as the alternative option. A footnote notes the rule takes effect with no redeploy and a denied request costs no function compute.';
---

<Figure
	caption="This is configuration, not code — a condition (path + per-IP rate) and an action (deny or log). The value of the edge layer is exactly this: it costs nothing and needs no deploy."
>
	<div class="waf not-content" role="img" aria-label={ALT}>
		<div class="waf-card">
			{/* ── header: rule name + enabled status ── */}
			<div class="waf-head">
				<div class="waf-head-main">
					<span class="waf-kicker">Vercel · Firewall rule</span>
					<span class="waf-title">Rate limit — auth endpoints</span>
				</div>
				<span class="waf-status">
					<span class="waf-dot" aria-hidden="true"></span>
					Enabled
				</span>
			</div>

			{/* ── WHEN: the condition ── */}
			<div class="waf-section">
				<span class="waf-lead">When</span>
				<div class="waf-block">
					<div class="waf-cond">
						<span class="waf-cond-field">Request Path</span>
						<span class="waf-cond-op">matches</span>
						<code class="waf-cond-val">/api/auth/*</code>
					</div>

					<div class="waf-and" aria-hidden="true">
						<span class="waf-and-line"></span>
						<span class="waf-and-word">AND</span>
						<span class="waf-and-line"></span>
					</div>

					<div class="waf-cond">
						<span class="waf-cond-field">Requests per IP</span>
						<span class="waf-cond-op">exceed</span>
						<code class="waf-cond-val">20 requests / 10s</code>
					</div>
				</div>
			</div>

			{/* ── THEN: the action ── */}
			<div class="waf-section">
				<span class="waf-lead">Then</span>
				<div class="waf-block waf-block-action">
					<span class="waf-action-label">Action</span>
					<div class="waf-actions">
						<span class="waf-action waf-action-on">
							<span class="waf-check" aria-hidden="true">✓</span>
							Deny
						</span>
						<span class="waf-action waf-action-off">Log</span>
					</div>
				</div>
			</div>
		</div>

		<p class="waf-foot">
			Takes effect with <strong>no redeploy</strong> · a denied request costs
			<strong>no function compute</strong>
		</p>
	</div>
</Figure>

<style
	define:vars={{
		INK,
		INK_SOFT,
		INK_FAINT,
		SURFACE,
		GRID,
		GRID_SOFT,
		EDGE,
		RED,
		GREEN,
		sans,
		mono,
	}}
>
	.waf {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		margin: 0;
		padding: 8px 2px 4px;
		color-scheme: light;
		font-family: var(--sans);
		color: var(--INK);
	}

	.waf :global(*) {
		margin: 0;
	}

	/* ── the rule card ── */
	.waf-card {
		box-sizing: border-box;
		width: 100%;
		max-width: 480px;
		display: flex;
		flex-direction: column;
		border: 1.5px solid var(--GRID);
		border-radius: 14px;
		background: var(--SURFACE);
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
		overflow: hidden;
	}

	/* ── header ── */
	.waf-head {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 13px 16px;
		border-bottom: 1.5px solid var(--GRID);
		background: var(--GRID_SOFT);
	}
	.waf-head-main {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}
	.waf-kicker {
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--EDGE);
		line-height: 1.2;
	}
	.waf-title {
		font-size: 14px;
		font-weight: 800;
		line-height: 1.2;
		color: var(--INK);
	}
	.waf-status {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		flex: 0 0 auto;
		padding: 3px 9px 3px 8px;
		border: 1px solid color-mix(in srgb, var(--GREEN) 35%, var(--GRID));
		border-radius: 999px;
		background: color-mix(in srgb, var(--GREEN) 9%, var(--SURFACE));
		font-size: 10px;
		font-weight: 700;
		color: color-mix(in srgb, var(--GREEN) 45%, var(--INK));
	}
	.waf-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--GREEN);
	}

	/* ── WHEN / THEN sections ── */
	.waf-section {
		box-sizing: border-box;
		display: flex;
		align-items: flex-start;
		gap: 12px;
		padding: 14px 16px;
	}
	.waf-section + .waf-section {
		border-top: 1.5px dashed var(--GRID);
	}
	.waf-lead {
		flex: 0 0 auto;
		width: 44px;
		padding-top: 6px;
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--INK_FAINT);
		line-height: 1.2;
	}

	.waf-block {
		box-sizing: border-box;
		flex: 1 1 auto;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
		padding: 10px 12px;
		border: 1px solid var(--GRID);
		border-radius: 10px;
		background: var(--GRID_SOFT);
	}

	/* ── one condition row ── */
	.waf-cond {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 6px 8px;
		min-width: 0;
	}
	.waf-cond-field {
		font-size: 12px;
		font-weight: 800;
		color: var(--INK);
		line-height: 1.3;
	}
	.waf-cond-op {
		font-size: 11px;
		font-weight: 600;
		font-style: italic;
		color: var(--INK_SOFT);
		line-height: 1.3;
	}
	.waf-cond-val {
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 700;
		color: var(--INK);
		padding: 2px 7px;
		border: 1px solid var(--GRID);
		border-radius: 6px;
		background: var(--SURFACE);
		white-space: nowrap;
		line-height: 1.4;
	}

	/* ── AND connector between the two conditions ── */
	.waf-and {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 8px 0;
	}
	.waf-and-line {
		flex: 1 1 auto;
		height: 1px;
		background: var(--GRID);
	}
	.waf-and-word {
		flex: 0 0 auto;
		font-size: 9.5px;
		font-weight: 800;
		letter-spacing: 0.08em;
		color: var(--INK_FAINT);
		padding: 1px 7px;
		border: 1px solid var(--GRID);
		border-radius: 999px;
		background: var(--SURFACE);
	}

	/* ── action block ── */
	.waf-block-action {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}
	.waf-action-label {
		font-size: 12px;
		font-weight: 800;
		color: var(--INK);
	}
	.waf-actions {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}
	.waf-action {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 4px 12px;
		border-radius: 8px;
		font-size: 12px;
		font-weight: 800;
		line-height: 1.3;
	}
	.waf-action-on {
		color: #fff;
		background: var(--RED);
		border: 1.5px solid var(--RED);
		box-shadow: 0 1px 2px color-mix(in srgb, var(--RED) 30%, transparent);
	}
	.waf-check {
		font-size: 11px;
		font-weight: 900;
	}
	.waf-action-off {
		color: var(--INK_SOFT);
		background: var(--SURFACE);
		border: 1.5px solid var(--GRID);
		font-weight: 700;
	}

	/* ── footnote: the senior-relevant property ── */
	.waf-foot {
		max-width: 480px;
		font-size: 11px;
		font-weight: 600;
		line-height: 1.4;
		text-align: center;
		color: var(--INK_SOFT);
	}
	.waf-foot strong {
		color: var(--INK);
		font-weight: 800;
	}

	@media (max-width: 520px) {
		.waf-section {
			gap: 8px;
			padding: 12px;
		}
		.waf-lead {
			width: 38px;
			font-size: 10px;
		}
		.waf-block-action {
			flex-direction: column;
			align-items: flex-start;
			gap: 8px;
		}
	}
</style>
