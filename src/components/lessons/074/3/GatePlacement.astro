---
// Gate placement (diagram id: gate-placement, Chapter 074 L3). A static
// two-row HTML/CSS "phase strip" putting the right and wrong limiter placement
// side by side. Each row is the sign-in action's pipeline drawn left -> right as
// a sequence of small labeled boxes; one box in each row is styled as the GATE.
//
//   Row 1  Correct — gate first: parse -> [GATE] (green, right after parse) ->
//          hash + verify -> session. The gate is reached before the expensive
//          work, so over-budget requests are turned away cheaply.
//   Row 2  Wrong — gate late: parse -> hash + verify (marked "cost already
//          paid") -> [GATE] (red, after the work) -> session. The expensive
//          password hash runs before the gate, so every over-budget request
//          still pays the cost the limiter was meant to cap.
//
// The only thing that moves between the two rows is where the gate sits — that
// single move decides whether the limiter does its job.
//
// Style matches this lesson's DualKeyThreatModel scene: pinned light so the
// hand-picked green/red tints survive dark mode, slate ink, and margin:0 on
// every inner element to defeat Starlight's injected prose margins so the rows
// align column-by-column.

import Figure from '../../../figures/Figure.astro';

// Palette (shared with DualKeyThreatModel) -----------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const BORDER = '#cbd5e1'; // ordinary box edge (slate-300)
const SURFACE = '#ffffff'; // ordinary box surface

const GREEN = '#16a34a'; // green-600 — gate placed correctly
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const RED = '#dc2626'; // red-600 — gate placed too late
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const AMBER = '#d97706'; // amber-600 — the expensive work / cost paid
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// The outer stage: pinned light, slate ink, two stacked rows.
const stage = `display: flex; flex-direction: column; gap: 20px; margin: 0; padding: 4px 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// One labeled row (correct / wrong) — a heading line above its pipeline.
const rowWrap = `display: flex; flex-direction: column; gap: 8px; margin: 0;`;
const rowLabel = (tone: string) =>
	`display: inline-flex; align-items: center; gap: 6px; margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${tone};`;
const rowTag = (tone: string, bg: string, accent: string) =>
	`display: inline-flex; align-items: center; margin: 0; padding: 1px 7px; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: ${tone}; background: ${bg}; border: 1px solid ${accent}; border-radius: 999px; white-space: nowrap;`;

// The pipeline: boxes connected left -> right, wrapping on narrow viewports.
const pipeline = `display: flex; flex-wrap: wrap; align-items: stretch; gap: 6px; margin: 0;`;

// An ordinary phase box (parse, session).
const box = `display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; margin: 0; padding: 10px 12px; min-width: 78px; border: 1.5px solid ${BORDER}; border-radius: 10px; background: ${SURFACE}; box-sizing: border-box;`;
const boxLabel = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${INK};`;
const boxSub = `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT};`;

// The expensive-work box — amber-tinted, optionally annotated "cost already paid".
const workBox = (paid: boolean) =>
	`display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; margin: 0; padding: 10px 12px; min-width: 96px; border-radius: 10px; box-sizing: border-box; ` +
	(paid
		? `border: 2px solid ${AMBER}; background: ${AMBER_BG};`
		: `border: 1.5px solid ${BORDER}; background: ${SURFACE};`);
const workLabel = (paid: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${paid ? AMBER_INK : INK};`;
const workSub = (paid: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: ${paid ? AMBER : INK_SOFT};`;

// The gate box — green (early/correct) or red (late/wrong).
const gateBox = (ok: boolean) =>
	`display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; margin: 0; padding: 8px 14px; min-width: 96px; border-radius: 10px; box-sizing: border-box; ` +
	(ok
		? `border: 2px solid ${GREEN}; background: ${GREEN_BG};`
		: `border: 2px solid ${RED}; background: ${RED_BG};`);
const gateBar = (ok: boolean) =>
	`margin: 0; width: 34px; height: 18px; border-radius: 4px; background: ${ok ? GREEN : RED};`;
const gateLabel = (ok: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 800; line-height: 1.2; color: ${ok ? GREEN_INK : RED_INK};`;
const gateState = (ok: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${ok ? GREEN : RED};`;

// The connector arrow between two phase boxes.
const conn = `display: flex; align-items: center; margin: 0; font-family: ${sans}; font-size: 18px; font-weight: 700; line-height: 1; color: ${INK_SOFT};`;
---

<Figure caption="The limiter must run before the work it protects. Gate late and every over-budget request still pays the password-hash cost the limiter was supposed to cap.">
	<div style={stage}>
		{/* ---- Row 1: Correct — gate first ---- */}
		<div style={rowWrap}>
			<span style={rowLabel(GREEN_INK)}>
				Correct &mdash; gate first
				<span style={rowTag(GREEN_INK, GREEN_BG, GREEN)}>over-budget bounced cheap</span>
			</span>
			<div style={pipeline}>
				<div style={box}>
					<span style={boxLabel}>parse</span>
					<span style={boxSub}>form &rarr; input</span>
				</div>
				<span style={conn} aria-hidden="true">&rarr;</span>
				<div style={gateBox(true)}>
					<span style={gateState(true)}>checked first</span>
					<div style={gateBar(true)}></div>
					<span style={gateLabel(true)}>GATE</span>
				</div>
				<span style={conn} aria-hidden="true">&rarr;</span>
				<div style={workBox(false)}>
					<span style={workLabel(false)}>hash + verify</span>
					<span style={workSub(false)}>slow on purpose</span>
				</div>
				<span style={conn} aria-hidden="true">&rarr;</span>
				<div style={box}>
					<span style={boxLabel}>session</span>
					<span style={boxSub}>signed in</span>
				</div>
			</div>
		</div>

		{/* ---- Row 2: Wrong — gate late ---- */}
		<div style={rowWrap}>
			<span style={rowLabel(RED_INK)}>
				Wrong &mdash; gate late
				<span style={rowTag(RED_INK, RED_BG, RED)}>cost paid before reject</span>
			</span>
			<div style={pipeline}>
				<div style={box}>
					<span style={boxLabel}>parse</span>
					<span style={boxSub}>form &rarr; input</span>
				</div>
				<span style={conn} aria-hidden="true">&rarr;</span>
				<div style={workBox(true)}>
					<span style={workLabel(true)}>hash + verify</span>
					<span style={workSub(true)}>cost already paid</span>
				</div>
				<span style={conn} aria-hidden="true">&rarr;</span>
				<div style={gateBox(false)}>
					<span style={gateState(false)}>checked too late</span>
					<div style={gateBar(false)}></div>
					<span style={gateLabel(false)}>GATE</span>
				</div>
				<span style={conn} aria-hidden="true">&rarr;</span>
				<div style={box}>
					<span style={boxLabel}>session</span>
					<span style={boxSub}>signed in</span>
				</div>
			</div>
		</div>
	</div>
</Figure>
