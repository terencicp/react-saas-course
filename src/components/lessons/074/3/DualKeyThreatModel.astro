---
// Dual-key threat model (diagram id: dual-key-threat-model, Chapter 074 L3). A
// three-step scrubbable DiagramSequence that makes the dual-keying rule
// inevitable by walking the two single-key failures before the fix. Each step is
// the same left -> middle -> right scene: an attacker SOURCE on the left, one or
// two GATES in the middle (green = passing, red = tripped), and the target
// ACCOUNT on the right. Reuses the chapter's request-path spine language
// (source -> gate -> account) so all three read as the same world.
//
//   Step 1  Per-IP gate alone. A cloud of botnet IP dots each fires one thin
//           arrow through a single GREEN per-IP gate (each IP under its small
//           budget) and reaches the victim account. The stuffing slips through;
//           the gate never sees the email.
//   Step 2  Per-email gate alone. One attacker IP fires a thick stream at a RED
//           per-email gate that has tripped — but the legitimate owner's own
//           request is bounced off the same red gate. The defense became the
//           attack (lockout).
//   Step 3  Both gates, in series. The stuffing cloud's stream trips the RED
//           per-email gate (blocked on campaign volume); separately a normal
//           user from a normal IP clears the GREEN per-IP gate AND the GREEN
//           per-email gate and reaches the account.
//
// Style follows this arc's DiagramSequence scenes (StaleFrameSequence): fixed
// slate ink, color-scheme pinned light so the hand-picked green/red/amber tints
// survive dark mode, margin:0 on every inner element to defeat Starlight's
// injected prose margins. Every step is the same three-column shape so the grid
// stack sizes to the tallest step and never reflows as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const BORDER = '#cbd5e1'; // ordinary edge (slate-300)
const SURFACE = '#ffffff'; // chip surface

const GREEN = '#16a34a'; // green-600 — gate passing
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const RED = '#dc2626'; // red-600 — gate tripped
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const AMBER = '#d97706'; // amber-600 — the attacker source
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const BLUE = '#2563eb'; // blue-600 — the legitimate / normal actor
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, a centered column
// holding the scene row plus a heading line, so all three steps are the same
// shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 4px 0; color-scheme: light; font-family: ${sans}; color: ${INK}; min-height: 250px;`;

// The step's one-line title above the scene.
const title = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 13.5px; font-weight: 700; line-height: 1.3; text-align: center; color: ${tone}; max-width: 560px;`;

// The scene row: source | gates | account, laid left -> right, wrapping on
// narrow viewports. Fixed min-height so every step lines up.
const scene = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 10px; margin: 0; width: 100%;`;

// A labeled column inside the scene (source / account), stacked vertically.
const col = `display: flex; flex-direction: column; align-items: center; gap: 6px; margin: 0;`;
const colLabel = `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;

// The botnet cloud: a small grid of IP dots.
const cloud = `display: grid; grid-template-columns: repeat(4, auto); gap: 5px; margin: 0; padding: 8px; border: 1.5px dashed ${AMBER}; border-radius: 12px; background: ${AMBER_BG};`;
const ipDot = `display: flex; align-items: center; justify-content: center; margin: 0; width: 26px; height: 18px; font-family: ${mono}; font-size: 8.5px; font-weight: 700; color: ${AMBER_INK}; background: ${SURFACE}; border: 1px solid ${AMBER}; border-radius: 5px;`;
const cloudTag = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.2; color: ${AMBER_INK}; text-align: center;`;

// A single actor node (one attacker IP, one legit owner, one normal user).
const node = (accent: string, bg: string, ink: string) =>
	`display: flex; flex-direction: column; align-items: center; gap: 2px; margin: 0; padding: 8px 12px; border: 1.5px solid ${accent}; border-radius: 10px; background: ${bg}; color: ${ink}; min-width: 96px;`;
const nodeTitle = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${ink};`;
const nodeSub = (ink: string) =>
	`margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 600; line-height: 1.2; color: ${ink};`;

// A gate: a vertical bar tinted green (passing) or red (tripped), with its key
// label below.
const gate = (passing: boolean) =>
	`display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; margin: 0; padding: 14px 10px; min-width: 92px; border-radius: 10px; ` +
	(passing
		? `border: 2px solid ${GREEN}; background: ${GREEN_BG};`
		: `border: 2px solid ${RED}; background: ${RED_BG};`);
const gateBar = (passing: boolean) =>
	`margin: 0; width: 34px; height: 30px; border-radius: 5px; background: ${passing ? GREEN : RED};`;
const gateLabel = (passing: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 700; line-height: 1.15; text-align: center; color: ${passing ? GREEN_INK : RED_INK};`;
const gateState = (passing: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: ${passing ? GREEN : RED};`;

// A horizontal arrow between scene parts. `tone` colors it; `weight` thickens
// it (a thick stream vs a thin attempt). `blocked` strikes it through with an X.
const arrow = (tone: string) =>
	`display: flex; align-items: center; margin: 0; font-family: ${sans}; font-size: 16px; font-weight: 700; line-height: 1; color: ${tone};`;
const stream = (tone: string, thick: boolean) =>
	`display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1px; margin: 0;`;
const streamLine = (tone: string, thick: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: ${thick ? '17px' : '13px'}; font-weight: ${thick ? '900' : '700'}; line-height: 0.9; color: ${tone};`;

// The blocked marker: a small red "X / blocked" pill that sits on a bounced arrow.
const blockedPill = `display: inline-flex; align-items: center; gap: 3px; margin: 0; padding: 2px 7px; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: ${RED_INK}; background: ${RED_BG}; border: 1px solid ${RED}; border-radius: 999px; white-space: nowrap;`;
const passPill = `display: inline-flex; align-items: center; gap: 3px; margin: 0; padding: 2px 7px; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN}; border-radius: 999px; white-space: nowrap;`;

// The target account node on the right.
const account = (reached: boolean) =>
	`display: flex; flex-direction: column; align-items: center; gap: 3px; margin: 0; padding: 10px 12px; border-radius: 10px; min-width: 120px; ` +
	(reached
		? `border: 2px solid ${RED}; background: ${RED_BG};`
		: `border: 1.5px solid ${BORDER}; background: ${SURFACE};`);
const accountTitle = (reached: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${reached ? RED_INK : INK};`;
const accountSub = `margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 600; line-height: 1.2; color: ${INK_SOFT};`;
const accountState = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${tone};`;

// A small "lane" wrapper so a single scene can stack two flows (attacker row +
// legitimate-user row) and keep them aligned.
const lanes = `display: flex; flex-direction: column; gap: 10px; margin: 0; width: 100%;`;
const lane = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 10px; margin: 0;`;
---

<DiagramSequence>
	{/* ---- Step 1: Per-IP gate alone — stuffing slips through ---- */}
	<DiagramStep caption="Per-IP gate alone: a botnet spreads the attempts so thin that no single IP trips the cap. Distributed low-per-IP volume slips straight through — and the gate never sees the email being hammered.">
		<div style={stage}>
			<p style={title(AMBER_INK)}>Per-IP gate alone &mdash; the botnet slips through</p>
			<div style={scene}>
				<div style={col}>
					<span style={colLabel}>botnet &mdash; 10,000 IPs</span>
					<div style={cloud}>
						{Array.from({ length: 8 }).map(() => (
							<span style={ipDot}>IP</span>
						))}
					</div>
					<span style={cloudTag}>each IP: 1&ndash;2 attempts</span>
				</div>

				<div style={stream(AMBER, false)}>
					<span style={streamLine(AMBER, false)} aria-hidden="true">&rarr;</span>
					<span style={streamLine(AMBER, false)} aria-hidden="true">&rarr;</span>
				</div>

				<div style={gate(true)}>
					<span style={gateState(true)}>passes</span>
					<div style={gateBar(true)}></div>
					<span style={gateLabel(true)}>per-IP gate</span>
				</div>

				<span style={arrow(AMBER)} aria-hidden="true">&rarr;</span>

				<div style={account(true)}>
					<span style={accountState(RED)}>hammered</span>
					<span style={accountTitle(true)}>victim&#64;acme.com</span>
					<span style={accountSub}>account</span>
				</div>
			</div>
			<span style={blockedPill}>email never inspected</span>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Per-email gate alone — the limiter becomes the lockout ---- */}
	<DiagramStep caption="Per-email gate alone: one attacker floods the victim's email until the gate trips — and now the real owner is locked out of their own account. The defense became the attack.">
		<div style={stage}>
			<p style={title(RED_INK)}>Per-email gate alone &mdash; the defense becomes the attack</p>
			<div style={lanes}>
				<div style={lane}>
					<div style={node(AMBER, AMBER_BG, AMBER_INK)}>
						<span style={nodeTitle(AMBER_INK)}>attacker</span>
						<span style={nodeSub(AMBER_INK)}>one IP</span>
					</div>
					<div style={stream(RED, true)}>
						<span style={streamLine(RED, true)} aria-hidden="true">&rArr;</span>
						<span style={streamLine(RED, true)} aria-hidden="true">&rArr;</span>
						<span style={streamLine(RED, true)} aria-hidden="true">&rArr;</span>
					</div>
					<div style={gate(false)}>
						<span style={gateState(false)}>tripped</span>
						<div style={gateBar(false)}></div>
						<span style={gateLabel(false)}>per-email gate</span>
					</div>
					<span style={arrow(RED)} aria-hidden="true">&rarr;</span>
					<div style={account(false)}>
						<span style={accountState(INK_SOFT)}>protected?</span>
						<span style={accountTitle(false)}>victim&#64;acme.com</span>
						<span style={accountSub}>account</span>
					</div>
				</div>

				<div style={lane}>
					<div style={node(BLUE, BLUE_BG, BLUE_INK)}>
						<span style={nodeTitle(BLUE_INK)}>real owner</span>
						<span style={nodeSub(BLUE_INK)}>same email</span>
					</div>
					<span style={arrow(BLUE)} aria-hidden="true">&rarr;</span>
					{/* the same tripped gate bounces the legitimate owner too */}
					<div style={gate(false)}>
						<span style={gateState(false)}>tripped</span>
						<div style={gateBar(false)}></div>
						<span style={gateLabel(false)}>per-email gate</span>
					</div>
					<span style={blockedPill}>&times; locked out</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: Both gates — stuffing capped, owner safe ---- */}
	<DiagramStep caption="Both gates, independent, both must pass. The stuffing campaign trips the email gate; a normal user from a normal IP clears both. Each gate closes the hole the other leaves open.">
		<div style={stage}>
			<p style={title(GREEN_INK)}>Both gates &mdash; stuffing capped, owner safe</p>
			<div style={lanes}>
				<div style={lane}>
					<div style={col}>
						<span style={colLabel}>stuffing campaign</span>
						<div style={cloud}>
							{Array.from({ length: 8 }).map(() => (
								<span style={ipDot}>IP</span>
							))}
						</div>
					</div>
					<span style={arrow(AMBER)} aria-hidden="true">&rarr;</span>
					<div style={gate(true)}>
						<span style={gateState(true)}>passes</span>
						<div style={gateBar(true)}></div>
						<span style={gateLabel(true)}>per-IP gate</span>
					</div>
					<span style={arrow(RED)} aria-hidden="true">&rarr;</span>
					<div style={gate(false)}>
						<span style={gateState(false)}>tripped</span>
						<div style={gateBar(false)}></div>
						<span style={gateLabel(false)}>per-email gate</span>
					</div>
					<span style={blockedPill}>&times; blocked</span>
				</div>

				<div style={lane}>
					<div style={node(BLUE, BLUE_BG, BLUE_INK)}>
						<span style={nodeTitle(BLUE_INK)}>normal user</span>
						<span style={nodeSub(BLUE_INK)}>normal IP</span>
					</div>
					<span style={arrow(BLUE)} aria-hidden="true">&rarr;</span>
					<div style={gate(true)}>
						<span style={gateState(true)}>passes</span>
						<div style={gateBar(true)}></div>
						<span style={gateLabel(true)}>per-IP gate</span>
					</div>
					<span style={arrow(BLUE)} aria-hidden="true">&rarr;</span>
					<div style={gate(true)}>
						<span style={gateState(true)}>passes</span>
						<div style={gateBar(true)}></div>
						<span style={gateLabel(true)}>per-email gate</span>
					</div>
					<span style={arrow(BLUE)} aria-hidden="true">&rarr;</span>
					<div style={account(false)}>
						<span style={accountState(GREEN)}>signed in</span>
						<span style={accountTitle(false)}>own account</span>
						<span style={accountSub}>reached</span>
					</div>
					<span style={passPill}>&#10003; both pass</span>
				</div>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
