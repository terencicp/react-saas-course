---
// window-boundary-strip — Chapter 074 Lesson 2,
// "Three algorithms, sliding window by default".
//
// Makes the fixed-vs-sliding difference visible at the WINDOW BOUNDARY. Two
// horizontal time strips of equal width, stacked:
//
//   • Fixed window — split into two clock-aligned segments by a bold vertical
//     boundary line down the middle. Request ticks bunch at the END of the
//     first segment AND the START of the second, so a cluster straddles the
//     boundary. A callout there names the "thundering minute": ~2× the budget
//     slips through where two windows meet.
//   • Sliding window — one continuous strip, NO hard boundary. A soft budget
//     gradient glides along it and ticks sit evenly spaced, so no spike can
//     form. A callout names that the budget glides instead of snapping back.
//
// Plain HTML + CSS per the diagrams index (annotated colour-coded strip shape;
// deliberately NOT a diagram engine and NOT ArrowDiagram). Astro-scoped <style>,
// no LeaderLines → survives the Figure lightbox, so the wrapper stays
// expandable. `not-content` plus a `margin: 0` reset on every node defeats
// Starlight's injected prose margins.
//
// Theme-aware chrome via Starlight gray vars. The boundary line and its cluster
// carry the warning colour (rose/red) because the boundary spike is the
// problem; the sliding strip uses a calm teal gradient because gliding is the
// fix. Ticks are tiny rounded bars sitting on a baseline rail.

// Eight ticks per strip. For the fixed window they bunch around the centre
// boundary (50%); for the sliding window they spread evenly across the strip.
const fixedTicks = [38, 42, 46, 50, 54, 58, 62, 66];
const slidingTicks = [8, 20, 32, 44, 56, 68, 80, 92];
---

<div class="wbs not-content">
	{/* ───────── Fixed window ───────── */}
	<div class="wbs-strip">
		<div class="wbs-head">
			<span class="wbs-title">Fixed window</span>
			<span class="wbs-sub">counter resets on a hard boundary</span>
		</div>

		<div class="wbs-rail wbs-rail-fixed">
			{/* two clock-aligned segments, split by the bold boundary line */}
			<span class="wbs-seg-label wbs-seg-label-l">window 1</span>
			<span class="wbs-seg-label wbs-seg-label-r">window 2</span>

			<span class="wbs-boundary" aria-hidden="true"></span>

			{/* the cluster of ticks straddling the boundary */}
			{
				fixedTicks.map((left) => (
					<span
						class="wbs-tick wbs-tick-warn"
						style={`left: ${left}%`}
						aria-hidden="true"
					/>
				))
			}

			{/* callout pinned to the boundary */}
			<span class="wbs-callout wbs-callout-warn">
				~2× the budget can slip through here
			</span>
		</div>
	</div>

	{/* ───────── Sliding window ───────── */}
	<div class="wbs-strip">
		<div class="wbs-head">
			<span class="wbs-title">Sliding window</span>
			<span class="wbs-sub">budget weighted across windows</span>
		</div>

		<div class="wbs-rail wbs-rail-sliding">
			{/* the gliding budget shade — no hard boundary anywhere */}
			<span class="wbs-glide" aria-hidden="true"></span>

			{/* evenly-spread ticks: no spike can form */}
			{
				slidingTicks.map((left) => (
					<span
						class="wbs-tick wbs-tick-calm"
						style={`left: ${left}%`}
						aria-hidden="true"
					/>
				))
			}

			<span class="wbs-callout wbs-callout-calm">
				budget glides; no boundary spike
			</span>
		</div>
	</div>

	{/* shared legend */}
	<div class="wbs-legend">
		<span class="wbs-legend-item">
			<span class="wbs-legend-tick" aria-hidden="true"></span>
			one request
		</span>
		<span class="wbs-legend-arrow" aria-hidden="true">time →</span>
	</div>
</div>

<style>
	.wbs {
		display: flex;
		flex-direction: column;
		gap: 26px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.wbs-strip {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
	}

	.wbs-head {
		display: flex;
		align-items: baseline;
		gap: 8px;
		margin: 0;
	}
	.wbs-title {
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.wbs-sub {
		font-size: 0.68rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* the time strip itself — a rounded rail the ticks sit on. Position context
	   for the absolutely-placed ticks / boundary / callouts. Top padding leaves
	   room for the callout above; bottom for the segment labels below. */
	.wbs-rail {
		box-sizing: border-box;
		position: relative;
		height: 92px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-4, #94a3b8);
		margin: 0;
		overflow: hidden;
	}
	.wbs-rail-fixed {
		background: var(--sl-color-bg, transparent);
	}
	.wbs-rail-sliding {
		background: var(--sl-color-bg, transparent);
	}

	/* the bold boundary line down the middle of the fixed strip */
	.wbs-boundary {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 3px;
		transform: translateX(-1.5px);
		background: #e11d48; /* rose-600 */
		margin: 0;
	}

	/* the gliding budget shade for the sliding strip — a soft teal gradient that
	   slides across with no hard edge anywhere */
	.wbs-glide {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		right: 0;
		background: linear-gradient(
			90deg,
			color-mix(in srgb, #0d9488 4%, transparent) 0%,
			color-mix(in srgb, #0d9488 20%, transparent) 50%,
			color-mix(in srgb, #0d9488 4%, transparent) 100%
		);
		margin: 0;
	}

	/* clock-aligned segment labels, low in the strip */
	.wbs-seg-label {
		position: absolute;
		bottom: 7px;
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.wbs-seg-label-l {
		left: 0;
		text-align: center;
		width: 50%;
	}
	.wbs-seg-label-r {
		right: 0;
		text-align: center;
		width: 50%;
	}

	/* request ticks: small rounded bars standing on the baseline rail */
	.wbs-tick {
		position: absolute;
		bottom: 30px;
		width: 5px;
		height: 26px;
		border-radius: 3px;
		transform: translateX(-2.5px);
		margin: 0;
	}
	.wbs-tick-warn {
		background: #e11d48; /* rose-600 */
	}
	.wbs-tick-calm {
		background: #0d9488; /* teal-600 */
	}

	/* the callout pinned above the strip */
	.wbs-callout {
		position: absolute;
		top: 9px;
		box-sizing: border-box;
		padding: 3px 9px;
		border-radius: 999px;
		font-size: 0.64rem;
		font-weight: 700;
		line-height: 1.2;
		white-space: nowrap;
		margin: 0;
	}
	.wbs-callout-warn {
		left: 50%;
		transform: translateX(-50%);
		color: #fff;
		background: #e11d48; /* rose-600 */
	}
	.wbs-callout-calm {
		left: 50%;
		transform: translateX(-50%);
		color: #fff;
		background: #0d9488; /* teal-600 */
	}

	/* shared legend below both strips */
	.wbs-legend {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin: 0;
	}
	.wbs-legend-item {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.wbs-legend-tick {
		display: inline-block;
		width: 5px;
		height: 16px;
		border-radius: 3px;
		background: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.wbs-legend-arrow {
		font-size: 0.66rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* narrow viewports: the callouts are the only thing that can overflow the
	   strip width — shrink them a touch so they stay inside. */
	@media (max-width: 520px) {
		.wbs-callout {
			font-size: 0.58rem;
			padding: 3px 7px;
		}
		.wbs-rail {
			height: 96px;
		}
	}
</style>
