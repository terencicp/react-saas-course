---
// result-to-response — Chapter 074 Lesson 2, "What limit(key) returns".
//
// The lesson's payoff: the limit() return shape IS the response source —
// nothing is hand-computed. This figure makes that literal by drawing a line
// from every returned field to the exact place it lands on the wire.
//
// Three-column layout authored as ArrowDiagram boxes (real HTML nodes, lines
// drawn by leader-line):
//   • Left  — the limit() result object, one anchorable row per field
//     (success, limit, remaining, reset, pending).
//   • Mid   — two intermediate transform nodes: a "200 vs 429" branch fed by
//     success, and a "convert to delta-seconds" node fed by reset. Below them,
//     OFF the response, the after(...) background box that pending peels to.
//   • Right — the HTTP response: a status line + the four RateLimit-* / Retry
//     header rows, one anchorable row each.
//
// Per-field colour ties source → destination so the read survives even before
// the eye traces a curve; the lone bit of math (reset → delta-seconds) is the
// only arrow that detours through a transform node, and pending visibly leaves
// the response entirely. The wrapping <Figure> is expandable={false} because
// leader-line positions its curves from document.body and can't be relocated
// into the lightbox.
//
// `not-content` + a margin: 0 reset on every node defeats Starlight's injected
// prose margins. Theme-aware chrome via Starlight gray vars; the per-field
// accent colours are mid-tones picked to read on both light and dark.

import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Mid-tone accents, one per field — reused for the box tint and the arrow.
const C = {
	success: '#0ea5e9', // sky-500
	limit: '#16a34a', // green-600
	remaining: '#16a34a', // green-600 (limit + remaining share the budget hue)
	reset: '#ea580c', // orange-600
	pending: '#9333ea', // violet-600
};

const arrows = [
	// success → branch node → status line
	{
		from: 'r2r-f-success',
		to: 'r2r-branch',
		color: C.success,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-50, 0],
	},
	{
		from: 'r2r-branch',
		to: 'r2r-h-status',
		color: C.success,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-50, 0],
	},
	// limit → RateLimit-Limit (straight across)
	{
		from: 'r2r-f-limit',
		to: 'r2r-h-limit',
		color: C.limit,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [150, 0],
		endSocketGravity: [-50, 0],
		labelOffset: [0, -12],
	},
	// remaining → RateLimit-Remaining (straight across)
	{
		from: 'r2r-f-remaining',
		to: 'r2r-h-remaining',
		color: C.remaining,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [170, 0],
		endSocketGravity: [-50, 0],
		labelOffset: [0, -12],
	},
	// reset → convert node → RateLimit-Reset (the only math)
	{
		from: 'r2r-f-reset',
		to: 'r2r-convert',
		color: C.reset,
		label: 'ms timestamp',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-50, 0],
		labelOffset: [0, -13],
	},
	{
		from: 'r2r-convert',
		to: 'r2r-h-reset',
		color: C.reset,
		label: 'delta-seconds',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-50, 0],
		labelOffset: [0, -13],
	},
	// pending → after box, off the response entirely
	{
		from: 'r2r-f-pending',
		to: 'r2r-wait',
		color: C.pending,
		label: 'background',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 60],
		endSocketGravity: [0, -40],
		labelOffset: [0, 0],
	},
];
---

<ArrowDiagram arrows={arrows}>
	<div class="r2r not-content">
		{/* ───────── Left: the limit() result object ───────── */}
		<div class="r2r-col r2r-col-left">
			<div class="r2r-card">
				<div class="r2r-card-head">
					<span class="r2r-mono">limit()</span> result
				</div>
				<div class="r2r-fields">
					<div class="r2r-field" id="r2r-f-success" style={`--c: ${C.success}`}>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">success</span>
						<span class="r2r-type">boolean</span>
					</div>
					<div class="r2r-field" id="r2r-f-limit" style={`--c: ${C.limit}`}>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">limit</span>
						<span class="r2r-type">number</span>
					</div>
					<div
						class="r2r-field"
						id="r2r-f-remaining"
						style={`--c: ${C.remaining}`}
					>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">remaining</span>
						<span class="r2r-type">number</span>
					</div>
					<div class="r2r-field" id="r2r-f-reset" style={`--c: ${C.reset}`}>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">reset</span>
						<span class="r2r-type">ms epoch</span>
					</div>
					<div class="r2r-field" id="r2r-f-pending" style={`--c: ${C.pending}`}>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">pending</span>
						<span class="r2r-type">Promise</span>
					</div>
				</div>
			</div>
		</div>

		{/* ───────── Middle: transform nodes + the off-response sink ───────── */}
		<div class="r2r-col r2r-col-mid">
			<div
				class="r2r-node r2r-node-branch"
				id="r2r-branch"
				style={`--c: ${C.success}`}
			>
				<span class="r2r-node-title">branch</span>
				<span class="r2r-node-sub">200 vs 429</span>
			</div>

			<div
				class="r2r-node r2r-node-convert"
				id="r2r-convert"
				style={`--c: ${C.reset}`}
			>
				<span class="r2r-node-title">convert</span>
				<span class="r2r-node-sub r2r-mono">
					ceil((reset − now) / 1000)
				</span>
			</div>

			<div class="r2r-wait" id="r2r-wait" style={`--c: ${C.pending}`}>
				<span class="r2r-wait-title r2r-mono">after(…)</span>
				<span class="r2r-wait-sub">analytics write · off the response</span>
			</div>
		</div>

		{/* ───────── Right: the HTTP response ───────── */}
		<div class="r2r-col r2r-col-right">
			<div class="r2r-card r2r-card-res">
				<div class="r2r-card-head">HTTP response</div>
				<div class="r2r-fields">
					<div
						class="r2r-hrow r2r-status"
						id="r2r-h-status"
						style={`--c: ${C.success}`}
					>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">200 OK / 429 Too Many</span>
					</div>
					<div class="r2r-hrow" id="r2r-h-limit" style={`--c: ${C.limit}`}>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">RateLimit-Limit</span>
					</div>
					<div
						class="r2r-hrow"
						id="r2r-h-remaining"
						style={`--c: ${C.remaining}`}
					>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">RateLimit-Remaining</span>
					</div>
					<div class="r2r-hrow" id="r2r-h-reset" style={`--c: ${C.reset}`}>
						<span class="r2r-dot" aria-hidden="true"></span>
						<span class="r2r-mono">RateLimit-Reset</span>
					</div>
					<div class="r2r-hrow r2r-hrow-ghost" aria-hidden="true">
						<span class="r2r-dot r2r-dot-ghost"></span>
						<span class="r2r-mono">Retry-After</span>
						<span class="r2r-type">on 429</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</ArrowDiagram>

<style>
	.r2r {
		display: grid;
		grid-template-columns: minmax(11rem, 1fr) minmax(9.5rem, 0.85fr) minmax(
				12rem,
				1.1fr
			);
		gap: 92px;
		align-items: start;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.r2r-col {
		display: flex;
		flex-direction: column;
		margin: 0;
	}
	.r2r-col-mid {
		gap: 16px;
		justify-content: flex-start;
		padding-top: 26px;
	}

	.r2r-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
	}

	/* the two big cards (result object, response) */
	.r2r-card {
		box-sizing: border-box;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-bg, transparent);
		overflow: hidden;
		margin: 0;
	}
	.r2r-card-head {
		padding: 8px 12px;
		font-size: 0.74rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 45%, transparent);
		border-bottom: 1px solid var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}
	.r2r-card-head .r2r-mono {
		font-weight: 700;
	}

	.r2r-fields {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
	}

	/* one anchorable row per field / header */
	.r2r-field,
	.r2r-hrow {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 7px 12px;
		border-top: 1px solid color-mix(in srgb, var(--sl-color-gray-5, #cbd5e1) 60%, transparent);
		font-size: 0.78rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.r2r-fields > :first-child {
		border-top: none;
	}

	/* the colour dot keys each row to its arrow */
	.r2r-dot {
		flex: none;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--c, var(--sl-color-gray-3, #64748b));
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--c, #64748b) 20%, transparent);
		margin: 0;
	}

	.r2r-type {
		margin-left: auto;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.62rem;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		white-space: nowrap;
	}

	.r2r-status .r2r-mono {
		font-size: 0.72rem;
	}

	/* the greyed-out Retry-After row (present only on 429) */
	.r2r-hrow-ghost {
		color: var(--sl-color-gray-3, #64748b);
	}
	.r2r-hrow-ghost .r2r-mono {
		opacity: 0.7;
	}
	.r2r-dot-ghost {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		border: 1.5px dashed var(--sl-color-gray-4, #94a3b8);
		background: transparent;
		flex: none;
	}

	/* middle transform nodes */
	.r2r-node {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		text-align: center;
		padding: 9px 10px;
		border-radius: 10px;
		border: 1.5px solid var(--c, var(--sl-color-gray-4, #94a3b8));
		background: color-mix(in srgb, var(--c, #64748b) 12%, transparent);
		margin: 0;
	}
	.r2r-node-title {
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.r2r-node-sub {
		font-size: 0.62rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* the off-response background sink */
	.r2r-wait {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		text-align: center;
		padding: 9px 10px;
		border-radius: 10px;
		border: 1.5px dashed var(--c, var(--sl-color-gray-4, #94a3b8));
		background: transparent;
		margin-top: 14px;
	}
	.r2r-wait-title {
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--c, var(--sl-color-white, #1e293b));
		margin: 0;
	}
	.r2r-wait-sub {
		font-size: 0.6rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* narrow viewports: stack the three columns. Cross-region sockets lose their
	   horizontal gap, so the arrows arc between stacked panels — readable but not
	   pretty; the colour dots carry the mapping regardless. */
	@media (max-width: 720px) {
		.r2r {
			grid-template-columns: 1fr;
			gap: 40px;
		}
		.r2r-col-mid {
			padding-top: 0;
			flex-direction: row;
			flex-wrap: wrap;
			gap: 12px;
		}
		.r2r-col-mid > * {
			flex: 1 1 8rem;
		}
	}
</style>
