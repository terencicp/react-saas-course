---
// Upload handoff — a recognition aid for "the bytes skip the server". This is NOT
// the diagram that carries the lesson (the ObjectUrlLifecycle DiagramSequence is);
// it just makes the presigned-PUT seam visible so the student knows where the
// previewed File lands.
//
// Topology is a triangle, chosen so "bytes skip the server" reads geometrically:
//   Client (bottom-left) ── PUT the File ──▶ Object storage (bottom-right)   ← byte path, the base edge
//                       \                  /
//             name·type·size            (no byte arrow ever touches the server)
//                         \              /
//                       Server action (raised, top-centre)
// The two metadata arrows fan UP to the raised server box and the presigned URL
// comes back DOWN, so the heavy byte arrow owns the unobstructed bottom edge and
// the server sits off it entirely. That is the whole point of the figure.
//
// Boxes are authored as real HTML (label + sublabel + the byte arrow needs a
// thicker, accent-coloured treatment), so <ArrowDiagram> over D2/Mermaid. The
// arrow layer is leader-line; this component only lays out and styles the boxes,
// then hands the `arrows` array to <ArrowDiagram> from the lesson MDX so the
// <Figure> wrapper + caption stay in the MDX.
//
// Palette mirrors the chapter's other figures (see ObjectUrlLifecycle): theme-gray
// chrome for the lightweight control plane (the two metadata arrows + the server),
// one saturated accent GREEN reserved for the byte path so the eye locks onto the
// File's real route. `margin: 0` reset on every inner element defeats Starlight's
// prose-margin selector; `not-content` opts the whole thing out of prose styling.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

// The accent green this lesson already uses for the "live / correct" path in
// ObjectUrlLifecycle — reused here for the byte arrow so the two figures rhyme.
const GREEN = "#16a34a";
// The control-plane arrows (metadata up, presigned URL back) are deliberately
// muted: a mid slate that reads on both themes, so they recede behind the byte path.
const SLATE = "#64748b";

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// ---- layout -------------------------------------------------------------
// A 3-row grid. Row 1 holds the raised Server action box, centred. Row 2 is a
// spacer that opens the gap the metadata arrows live in. Row 3 is the baseline
// with Client (left) and Object storage (right) — the byte path runs across it.
const root = [
  reset,
  sans,
  "display: grid",
  "grid-template-columns: 1fr 1fr 1fr",
  "grid-template-rows: auto 26px auto",
  "row-gap: 0",
  "column-gap: 0",
  "align-items: center",
  "width: 100%",
  "max-width: 620px",
  "margin-inline: auto",
  "box-sizing: border-box",
  "padding: 6px 4px 4px",
].join("; ");

// A node card. `accent` switches between the byte-path endpoints (green ring,
// faint green wash) and the lightweight server box (gray chrome).
const card = (accent: boolean) =>
  [
    reset,
    "position: relative",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "gap: 4px",
    "text-align: center",
    "padding: 12px 14px",
    "border-radius: 10px",
    "box-sizing: border-box",
    "background: var(--sl-color-bg)",
    accent
      ? `border: 1.5px solid ${GREEN}; background: color-mix(in srgb, ${GREEN} 9%, var(--sl-color-bg))`
      : "border: 1.5px solid var(--sl-color-gray-4); background: color-mix(in srgb, var(--sl-color-gray-6) 55%, var(--sl-color-bg))",
  ].join("; ");

const title = (accent: boolean) =>
  [
    reset,
    sans,
    "font-size: 13.5px",
    "font-weight: 700",
    "line-height: 1.1",
    accent
      ? `color: color-mix(in srgb, ${GREEN} 78%, var(--sl-color-text))`
      : "color: var(--sl-color-text)",
  ].join("; ");

const sub = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Cell placement helpers (1-indexed grid lines).
const cell = (col: number, row: number, extra = "") =>
  [reset, `grid-column: ${col}`, `grid-row: ${row}`, extra].join("; ");

// The "bytes skip the server" note, pinned just under the byte arrow in the
// centre column of the baseline row so it sits on the File's path. The
// translateY drops it below the arrow line (and the "PUT the File" label
// riding above it) so the three never overlap.
const note = [
  reset,
  sans,
  "grid-column: 2",
  "grid-row: 3",
  "align-self: center",
  "justify-self: center",
  "transform: translateY(16px)",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "line-height: 1.1",
  "text-align: center",
  `color: color-mix(in srgb, ${GREEN} 72%, var(--sl-color-text))`,
].join("; ");

// ---- arrow descriptors --------------------------------------------------
// Three arrows. The byte PUT runs Client(bottom-left) -> Object storage
// (bottom-right) straight across the base, thick + green, owning the bottom edge.
// The two control-plane arrows fan up to the raised server box and back, muted.
const arrows = [
  // Control plane — metadata up to the signer. Leaves Client's TOP, lands the
  // server's LEFT, so it climbs the left flank of the triangle.
  {
    from: "uh-client",
    to: "uh-server",
    label: "name · type · size",
    color: SLATE,
    startSocket: "top" as const,
    endSocket: "left" as const,
    startSocketGravity: [0, -40] as [number, number],
    endSocketGravity: [-46, 0] as [number, number],
    labelOffset: [-6, -2] as [number, number],
  },
  // Control plane — the signed URL comes back down the right flank. It lands on
  // "uh-client-upper", an invisible 1px anchor pinned near the TOP of the client
  // card's right edge, so it stays clear of the byte arrow leaving the edge's centre.
  {
    from: "uh-server",
    to: "uh-client-upper",
    label: "presigned URL",
    color: SLATE,
    startSocket: "bottom" as const,
    endSocket: "right" as const,
    startSocketGravity: [-30, 30] as [number, number],
    endSocketGravity: [40, -8] as [number, number],
    labelOffset: [6, 2] as [number, number],
  },
  // THE BYTE PATH — the visually emphasized arrow. Straight across the base,
  // thick green, bypassing the server entirely.
  {
    from: "uh-client",
    to: "uh-storage",
    label: "PUT the File",
    color: GREEN,
    startSocket: "right" as const,
    endSocket: "left" as const,
    startSocketGravity: [70, 0] as [number, number],
    endSocketGravity: [-70, 0] as [number, number],
    labelOffset: [0, -13] as [number, number],
  },
];
---

<div class="not-content">
  <ArrowDiagram arrows={arrows}>
    <div style={root}>
      {/* Row 1 — the raised signer, off the byte path. */}
      <div style={cell(2, 1)}>
        <div id="uh-server" style={card(false)}>
          <span style={title(false)}>Server action</span>
          <span style={sub}>signs the URL</span>
        </div>
      </div>

      {/* Row 3 — the baseline: Client and Object storage, the byte path's ends. */}
      <div style={cell(1, 3)}>
        <div id="uh-client" style={card(true)}>
          {/* landing anchor for the presigned-URL arrow, above the byte arrow */}
          <span
            id="uh-client-upper"
            style="position: absolute; top: 9px; right: 0; width: 1px; height: 1px;"></span>
          <span style={title(true)}>Client</span>
          <span style={sub}>holds the File</span>
        </div>
      </div>

      <div style={cell(3, 3)}>
        <div id="uh-storage" style={card(true)}>
          <span style={title(true)}>Object storage</span>
          <span style={sub}>receives the bytes</span>
        </div>
      </div>

      {/* the byte arrow's annotation, sitting on the path it labels */}
      <span style={note}>bytes skip the server</span>
    </div>
  </ArrowDiagram>
</div>
