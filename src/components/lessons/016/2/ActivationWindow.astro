---
// Activation window — one frame of the transient-user-activation timeline, used
// inside <DiagramSequence>. Scrubbing the three frames is what makes the INVISIBLE
// activation window visible: a click opens a shaded "activation live (~1s)" band on
// a left-to-right time axis, and a single writeText() call marker lands at a
// different spot each step. Whether the marker sits INSIDE or OUTSIDE that band is
// the whole lesson — inside resolves, outside rejects with NotAllowedError.
//
// The geometry of the axis, the click marker, and the band is IDENTICAL across all
// three steps (same percentage coordinates). Only three things change per step:
//   1  the position of the writeText call marker,
//   2  whether an `await fetch(...)` segment is drawn before it (step 2 only),
//   3  the outcome glyph (green check "resolved" vs red cross "NotAllowedError"),
// plus step 3 drops the band entirely (no gesture ever opened one).
//
//   step 1  call fires straight from the click → INSIDE the band      → resolved
//   step 2  handler awaits fetch first, marker pushed PAST the band    → rejected
//   step 3  no click/band at all; marker under a setTimeout/effect lbl → rejected
//
// Pure HTML + CSS + inline SVG, matching the chapter's other figures (see
// ConstantTimeCompare, FetchResolutionModel): the `not-content` wrapper, theme-gray
// variables for dim chrome (the axis, the spent/never-armed region), one saturated
// accent per outcome (green = resolved, red = rejected), amber for the network gap,
// a `margin: 0` reset on every inner element to defeat Starlight's prose-margin
// selector, height-capped and max-width 600.

interface Props {
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

// ---- timeline coordinate model -----------------------------------------
// Everything is positioned as a percentage of the track width so the axis is
// pixel-identical on every step. The click sits at CLICK_X; the activation band
// runs from there for BAND_W. The call marker x and the fetch segment are the
// only things that move.

const CLICK_X = 10; // where the click gesture fires (and the band opens)
const BAND_W = 34; // width of the live-activation band (~1s)
const BAND_END = CLICK_X + BAND_W; // right edge where activation expires

// Per-step layout. `callX` is the centre of the writeText marker. `fetch` (step 2)
// is an amber network segment drawn from the click to just past the band edge,
// visually shoving the marker out of the window. `band` toggles the green band;
// step 3 never had a gesture so there is no band to draw.
type Layout = {
  callX: number;
  band: boolean;
  fetchSeg: { from: number; to: number } | null;
  resolved: boolean;
  callLabel: string;
  // the small kicker under the call marker naming HOW the call was reached
  callKind: string;
};

const LAYOUT: Record<Props["step"], Layout> = {
  1: {
    callX: CLICK_X + 8, // just inside the band, right after the click
    band: true,
    fetchSeg: null,
    resolved: true,
    callLabel: "writeText()",
    callKind: "from click handler",
  },
  2: {
    callX: BAND_END + 16, // pushed past the right edge by the fetch round-trip
    band: true,
    fetchSeg: { from: CLICK_X, to: BAND_END + 8 },
    resolved: false,
    callLabel: "writeText()",
    callKind: "after await fetch()",
  },
  3: {
    callX: 64, // sits in the open, no gesture under it at all
    band: false,
    fetchSeg: null,
    resolved: false,
    callLabel: "writeText()",
    callKind: "setTimeout / useEffect",
  },
};

const L = LAYOUT[step];

// ---- palette ------------------------------------------------------------

const GREEN = "#16a34a"; // resolved outcome + the live-activation band
const RED = "#dc2626"; // NotAllowedError outcome
const AMBER = "#d97706"; // the network round-trip that outlives the window

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "width: 100%",
  "max-width: 600px",
  "box-sizing: border-box",
  sans,
].join("; ");

// The stage holds the absolutely-positioned timeline furniture. Fixed height so
// the band label (above) and the call marker (below) have reserved lanes and the
// three steps are the same height.
const stage = [
  reset,
  "position: relative",
  "width: 100%",
  "height: 168px",
  "box-sizing: border-box",
].join("; ");

// Vertical lanes inside the stage (top → bottom):
//   band label    (y ~ 8)
//   the axis line (y = 86, the spine everything hangs off)
//   call marker   (y ~ 104+)
const AXIS_Y = 86;

// The horizontal axis line.
const axis = [
  reset,
  "position: absolute",
  `top: ${AXIS_Y}px`,
  "left: 0",
  "right: 0",
  "height: 2px",
  "background: var(--sl-color-gray-4)",
  "border-radius: 999px",
].join("; ");

// "time →" caption pinned to the far right of the axis.
const timeTag = [
  reset,
  sans,
  "position: absolute",
  `top: ${AXIS_Y - 18}px`,
  "right: 0",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The shaded "activation live" band: a green block fading to transparent left →
// right so the eye reads it as decaying. Spans the axis vertically.
const band = [
  reset,
  "position: absolute",
  `left: ${CLICK_X}%`,
  `width: ${BAND_W}%`,
  `top: ${AXIS_Y - 30}px`,
  "height: 60px",
  `background: linear-gradient(to right, color-mix(in srgb, ${GREEN} 26%, transparent), color-mix(in srgb, ${GREEN} 3%, transparent))`,
  `border-left: 2px solid ${GREEN}`,
  "border-radius: 3px",
  "box-sizing: border-box",
].join("; ");

const bandLabel = [
  reset,
  sans,
  "position: absolute",
  `left: calc(${CLICK_X}% + 6px)`,
  `top: ${AXIS_Y - 48}px`,
  "font-size: 10.5px",
  "font-weight: 700",
  "line-height: 1.1",
  "white-space: nowrap",
  `color: ${GREEN}`,
].join("; ");

// Dashed marker for where the activation expires (right edge of the band).
const expireLine = [
  reset,
  "position: absolute",
  `left: ${BAND_END}%`,
  `top: ${AXIS_Y - 30}px`,
  "height: 60px",
  "width: 0",
  `border-left: 1.5px dashed color-mix(in srgb, ${GREEN} 60%, var(--sl-color-gray-3))`,
].join("; ");

const expireTag = [
  reset,
  sans,
  "position: absolute",
  `left: ${BAND_END}%`,
  `top: ${AXIS_Y + 33}px`,
  "transform: translateX(-50%)",
  "font-size: 9px",
  "font-weight: 600",
  "line-height: 1.1",
  "white-space: nowrap",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The click gesture marker: a filled dot on the axis + a stem up to a label.
const clickDot = [
  reset,
  "position: absolute",
  `left: ${CLICK_X}%`,
  `top: ${AXIS_Y - 5}px`,
  "transform: translateX(-50%)",
  "width: 12px",
  "height: 12px",
  "border-radius: 999px",
  `background: ${GREEN}`,
  `border: 2px solid var(--sl-color-bg)`,
  "box-sizing: border-box",
  "z-index: 2",
].join("; ");

const clickLabel = [
  reset,
  sans,
  "position: absolute",
  `left: ${CLICK_X}%`,
  `top: ${AXIS_Y - 66}px`,
  "transform: translateX(-50%)",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 1px",
  "line-height: 1.1",
].join("; ");

const clickWord = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 700",
  `color: ${GREEN}`,
].join("; ");

const clickKind = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The amber network-round-trip segment (step 2): a bracketed bar hugging the axis
// from the click to past the band edge, captioned with the await.
const fetchBar = L.fetchSeg
  ? [
      reset,
      "position: absolute",
      `left: ${L.fetchSeg.from}%`,
      `width: ${L.fetchSeg.to - L.fetchSeg.from}%`,
      `top: ${AXIS_Y - 4}px`,
      "height: 6px",
      `background: repeating-linear-gradient(45deg, ${AMBER}, ${AMBER} 4px, color-mix(in srgb, ${AMBER} 40%, transparent) 4px, color-mix(in srgb, ${AMBER} 40%, transparent) 8px)`,
      "border-radius: 999px",
      "z-index: 1",
    ].join("; ")
  : "";

const fetchLabel = L.fetchSeg
  ? [
      reset,
      sans,
      "position: absolute",
      `left: ${(L.fetchSeg.from + L.fetchSeg.to) / 2}%`,
      `top: ${AXIS_Y + 14}px`,
      "transform: translateX(-50%)",
      "font-size: 10px",
      "font-weight: 700",
      "white-space: nowrap",
      `color: ${AMBER}`,
    ].join("; ")
  : "";

// The writeText call marker: a stem dropping from the axis to a labelled pill, with
// the outcome glyph as a badge on the pill.
const outcomeColor = L.resolved ? GREEN : RED;

const callStem = [
  reset,
  "position: absolute",
  `left: ${L.callX}%`,
  `top: ${AXIS_Y}px`,
  "width: 0",
  "height: 22px",
  `border-left: 2px dashed color-mix(in srgb, ${outcomeColor} 55%, var(--sl-color-gray-3))`,
  "transform: translateX(-1px)",
].join("; ");

const callDot = [
  reset,
  "position: absolute",
  `left: ${L.callX}%`,
  `top: ${AXIS_Y - 5}px`,
  "transform: translateX(-50%)",
  "width: 11px",
  "height: 11px",
  "border-radius: 999px",
  `background: ${outcomeColor}`,
  `border: 2px solid var(--sl-color-bg)`,
  "box-sizing: border-box",
  "z-index: 2",
].join("; ");

// The pill is anchored on its left edge to keep it on-canvas even when the marker
// sits far right; a flex row of the code label + the outcome badge.
const callPill = [
  reset,
  "position: absolute",
  `left: ${L.callX}%`,
  `top: ${AXIS_Y + 26}px`,
  "transform: translateX(-50%)",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 4px",
  "white-space: nowrap",
].join("; ");

const callCodeBox = [
  reset,
  mono,
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1",
  "padding: 4px 7px",
  "border-radius: 5px",
  `border: 1.5px solid ${outcomeColor}`,
  `background: color-mix(in srgb, ${outcomeColor} 12%, var(--sl-color-bg))`,
  `color: color-mix(in srgb, ${outcomeColor} 85%, var(--sl-color-text))`,
].join("; ");

const callKindTag = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");

const outcomeRow = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 4px",
].join("; ");

const outcomeText = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 700",
  "line-height: 1",
  `color: ${outcomeColor}`,
].join("; ");
---

<div class="not-content" style={root}>
  <div style={stage}>
    {/* the time axis everything hangs off */}
    <div style={axis}></div>
    <span style={timeTag}>time &rarr;</span>

    {/* activation furniture — present only when a gesture opened the window */}
    {
      L.band && (
        <>
          <div style={band}></div>
          <span style={bandLabel}>activation live (~1s)</span>
          <div style={expireLine}></div>
          <span style={expireTag}>activation expires</span>
        </>
      )
    }

    {/* the click gesture — only when there is one (steps 1 & 2) */}
    {
      L.band && (
        <>
          <div style={clickLabel}>
            <span style={clickWord}>click</span>
            <span style={clickKind}>user gesture</span>
          </div>
          <div style={clickDot}></div>
        </>
      )
    }

    {/* step 3 has no gesture: name the empty axis so the absence is explicit */}
    {
      !L.band && (
        <span
          style={[
            reset,
            sans,
            `position: absolute`,
            `left: ${CLICK_X}%`,
            `top: ${AXIS_Y - 40}px`,
            "font-size: 10.5px",
            "font-weight: 700",
            "line-height: 1.2",
            "color: var(--sl-color-gray-3)",
          ].join("; ")}
        >
          no gesture &rarr; no activation ever opens
        </span>
      )
    }

    {/* the await fetch(...) round-trip (step 2 only) */}
    {
      L.fetchSeg && (
        <>
          <div style={fetchBar}></div>
          <span style={fetchLabel}>await fetch(&hellip;)</span>
        </>
      )
    }

    {/* the writeText() call marker + its outcome */}
    <div style={callStem}></div>
    <div style={callDot}></div>
    <div style={callPill}>
      <span style={callCodeBox}>{L.callLabel}</span>
      <span style={callKindTag}>{L.callKind}</span>
      <div style={outcomeRow}>
        {
          L.resolved ? (
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke={GREEN}
              stroke-width="3.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 6 9 17l-5-5" />
            </svg>
          ) : (
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke={RED}
              stroke-width="3.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M18 6 6 18M6 6l12 12" />
            </svg>
          )
        }
        <span style={outcomeText}>
          {L.resolved ? "resolved" : "NotAllowedError"}
        </span>
      </div>
    </div>
  </div>
</div>
