---
// Constant-time compare — one frame of the timing-leak side channel, used inside
// <DiagramSequence>. Scrubbing the three frames is what makes the LEAK visible in
// TIME: the top row (naive `===`) short-circuits at the first wrong character, so
// its timing bar grows every step as the attacker's matching prefix gets longer;
// the bottom row (constant-time) scans every byte regardless, so its bar is flat
// on all three frames. The growing top bar IS the side channel.
//
// Both rows compare the SAME incoming signature against the attacker's guess, so
// the only thing the eye has to track between the two rows is how far each scan
// got (cell shading) and the length of the timing bar.
//
// `step` selects the frame (source order = scrub order). The attacker's matching
// prefix grows each step, so the naive short-circuit happens later and later:
//   1  guess differs at char 1  → top examines 1 cell  (bar short  · "fast")
//   2  guess differs at char 5  → top examines 5 cells  (bar medium · "slower")
//   3  guess differs at char 10 → top examines 10 cells (bar long   · "slowest")
// The bottom row examines all 12 cells on every step (bar full · "constant").
//
// Pure HTML + CSS + inline SVG, matching the chapter's other figures (see
// FetchResolutionModel, CryptoThreeSurfaces): the `not-content` wrapper, theme-
// gray variables for dim chrome, one saturated accent per cell state (green =
// matched, red = mismatch, gray = never examined), amber for the leaking top bar
// vs green for the flat bottom bar, a `margin: 0` reset on every inner element to
// defeat Starlight's prose-margin selector, height-capped and max-width 600.

interface Props {
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

// The incoming signature on the wire (a short hex stand-in — real ones are 64
// hex chars, but 12 keeps the cell strip on one line at mobile width). Both rows
// compare against this same string.
const SIG = "9f2c7a1e4b08".split("");
const N = SIG.length;

// How many leading characters the attacker has already locked in this step. The
// guess diverges at exactly this index, so the naive compare examines
// `prefix + 1` cells (every matched char, plus the one mismatch it stops on).
const PREFIX: Record<Props["step"], number> = {
  1: 0, // differs at char 1
  2: 4, // differs at char 5
  3: 9, // differs at char 10
};
const matched = PREFIX[step];
const divergeIndex = matched; // the cell where the guess is wrong
const examined = matched + 1; // cells the naive `===` touches before stopping

// The wrong character the attacker guessed at the divergence point — drawn red
// in the naive row's diverge cell so the mismatch reads as a concrete glyph.
const WRONG = "x";

// Relative-speed tag for the naive timing bar, one per step.
const NAIVE_TAG: Record<Props["step"], string> = {
  1: "fast",
  2: "slower",
  3: "slowest",
};

// ---- palette ------------------------------------------------------------

const GREEN = "#16a34a"; // matched cell + the flat constant-time bar
const RED = "#dc2626"; // the mismatch cell
const AMBER = "#d97706"; // the leaking naive bar (variance = danger)

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 14px",
  "width: 100%",
  "max-width: 600px",
  "box-sizing: border-box",
  sans,
].join("; ");

// A row = label column + character strip + timing meter, laid out as a grid so
// the two rows' strips and meters line up vertically.
const rowGrid = [
  reset,
  "display: grid",
  "grid-template-columns: 92px 1fr",
  "align-items: center",
  "column-gap: 12px",
  "row-gap: 6px",
].join("; ");

// The left label: the comparison the row stands for + a one-word verdict.
const labelCol = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: flex-start",
  "gap: 2px",
  "grid-column: 1",
  "grid-row: 1 / span 2",
].join("; ");

const labelCode = `${reset}; ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2; color: var(--sl-color-text);`;
const labelKind = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1.1",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The horizontal strip of character cells.
const cellStrip = [
  reset,
  "grid-column: 2",
  "grid-row: 1",
  "display: flex",
  "flex-direction: row",
  "gap: 4px",
  "min-width: 0",
].join("; ");

const cellBase = [
  reset,
  "box-sizing: border-box",
  mono,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1",
  "width: 22px",
  "height: 26px",
  "border-radius: 5px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "flex: 0 0 auto",
  "transition: border-color 0.14s, background-color 0.14s, color 0.14s",
].join("; ");

const matchedCell = [
  cellBase,
  `border: 1.5px solid ${GREEN}`,
  `background: color-mix(in srgb, ${GREEN} 14%, transparent)`,
  `color: color-mix(in srgb, ${GREEN} 82%, var(--sl-color-text))`,
].join("; ");

const mismatchCell = [
  cellBase,
  `border: 1.5px solid ${RED}`,
  `background: color-mix(in srgb, ${RED} 16%, transparent)`,
  `color: color-mix(in srgb, ${RED} 82%, var(--sl-color-text))`,
].join("; ");

// Cells the naive compare never reached — greyed flat, no glyph emphasis.
const unexaminedCell = [
  cellBase,
  "border: 1px dashed var(--sl-color-gray-4)",
  "background: transparent",
  "color: var(--sl-color-gray-4)",
].join("; ");

// The constant-time row examines every cell. We keep the matched/mismatch glyph
// colors so the rows align, but every cell carries a solid "examined" ring.
const examinedMatched = matchedCell;
const examinedMismatch = mismatchCell;

// The timing meter: a fixed-width track with a proportional fill + a tag.
const meterWrap = [
  reset,
  "grid-column: 2",
  "grid-row: 2",
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 8px",
].join("; ");

const track = [
  reset,
  "position: relative",
  "flex: 1 1 auto",
  "height: 10px",
  "border-radius: 999px",
  "background: var(--sl-color-gray-6)",
  "border: 1px solid var(--sl-color-gray-5)",
  "overflow: hidden",
  "min-width: 0",
].join("; ");

const fill = (pct: number, color: string) =>
  [
    reset,
    "position: absolute",
    "left: 0",
    "top: 0",
    "bottom: 0",
    `width: ${pct}%`,
    `background: ${color}`,
    "border-radius: 999px",
    "transition: width 0.18s ease",
  ].join("; ");

const meterTag = (color: string) =>
  [
    reset,
    sans,
    "font-size: 10px",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "line-height: 1",
    "white-space: nowrap",
    "flex: 0 0 auto",
    `color: ${color}`,
  ].join("; ");

// Fill percentages. The naive bar is proportional to cells examined; the
// constant-time bar is always full.
const naivePct = Math.round((examined / N) * 100);

// Tiny legend so the cell colors are self-describing without prose.
const legend = [
  reset,
  "display: flex",
  "flex-direction: row",
  "flex-wrap: wrap",
  "align-items: center",
  "gap: 4px 14px",
  "padding-top: 2px",
].join("; ");

const legendItem = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 5px",
].join("; ");

const swatch = (style: string) =>
  [
    reset,
    "width: 12px",
    "height: 12px",
    "border-radius: 3px",
    "flex: 0 0 auto",
    style,
  ].join("; ");

const legendLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "line-height: 1",
  "color: var(--sl-color-gray-2)",
].join("; ");
---

<div class="not-content" style={root}>
  {/* TOP ROW — the naive `===`, short-circuits at the first wrong character. */}
  <div style={rowGrid}>
    <div style={labelCol}>
      <span style={labelCode}>a === b</span>
      <span style={labelKind}>naive compare</span>
    </div>

    {/* character cells: matched (green) up to the divergence, the mismatch
        (red), then every later cell greyed as "never examined". */}
    <div style={cellStrip}>
      {
        SIG.map((ch, i) => {
          if (i < divergeIndex) {
            return <span style={matchedCell}>{ch}</span>;
          }
          if (i === divergeIndex) {
            return <span style={mismatchCell}>{WRONG}</span>;
          }
          return <span style={unexaminedCell}>&middot;</span>;
        })
      }
    </div>

    {/* timing meter: fill grows with cells examined, tinted amber to read as a
        leak; the tag counts the examined cells and names the relative speed. */}
    <div style={meterWrap}>
      <div style={track}>
        <div style={fill(naivePct, AMBER)}></div>
      </div>
      <span style={meterTag(AMBER)}>
        {examined} of {N} checked &middot; {NAIVE_TAG[step]}
      </span>
    </div>
  </div>

  {/* BOTTOM ROW — the constant-time compare, scans every cell regardless. */}
  <div style={rowGrid}>
    <div style={labelCol}>
      <span style={labelCode}>subtle.verify</span>
      <span style={labelKind}>constant time</span>
    </div>

    {/* every cell is examined — same glyph colors, but the strip never greys
        out, so the eye sees a full row no matter how early the guess is wrong. */}
    <div style={cellStrip}>
      {
        SIG.map((ch, i) => {
          if (i === divergeIndex) {
            return <span style={examinedMismatch}>{WRONG}</span>;
          }
          if (i < divergeIndex) {
            return <span style={examinedMatched}>{ch}</span>;
          }
          // Cells past the divergence are still examined; show the real glyph in
          // a neutral matched tint so the row reads as "all checked".
          return <span style={examinedMatched}>{ch}</span>;
        })
      }
    </div>

    {/* timing meter: always full, green, labelled "constant" every step. */}
    <div style={meterWrap}>
      <div style={track}>
        <div style={fill(100, GREEN)}></div>
      </div>
      <span style={meterTag(GREEN)}>
        {N} of {N} checked &middot; constant
      </span>
    </div>
  </div>

  {/* legend — keeps the three cell states self-describing without prose. */}
  <div style={legend}>
    <div style={legendItem}>
      <span style={swatch(`border: 1.5px solid ${GREEN}; background: color-mix(in srgb, ${GREEN} 14%, transparent);`)}></span>
      <span style={legendLabel}>matched</span>
    </div>
    <div style={legendItem}>
      <span style={swatch(`border: 1.5px solid ${RED}; background: color-mix(in srgb, ${RED} 16%, transparent);`)}></span>
      <span style={legendLabel}>first mismatch</span>
    </div>
    <div style={legendItem}>
      <span style={swatch("border: 1px dashed var(--sl-color-gray-4); background: transparent;")}></span>
      <span style={legendLabel}>never examined</span>
    </div>
  </div>
</div>
