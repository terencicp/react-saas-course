---
// One crypto object, three surfaces — the lesson's recognition map. A single
// `crypto` box on the left fans out, through one SVG, to three stacked surface
// boxes on the right:
//
//   crypto.randomUUID()   → "a unique ID"     sync convenience, dim/neutral
//   crypto.getRandomValues() → "random bytes" sync convenience, dim/neutral
//   crypto.subtle         → "algorithms · async"  the ONE async surface, and the
//                            only one taught at depth — tinted with one saturated
//                            accent (violet) and its fan line drawn in that accent.
//
// Static (no `step` prop): this is an at-a-glance index the student returns to as
// each surface is taught, not a sequence to scrub. The whole "one object → three
// branches" topology lives in a single inline <svg> so the three fan lines share
// one coordinate space and stay aligned (no cross-element geometry to drift), and
// it stays flat HTML+CSS+SVG so it survives the <Figure> expand lightbox.
//
// Pure HTML + CSS, matching the chapter's other figures (see FetchResolutionModel,
// BufferVsPull): the `not-content` wrapper, theme-gray variables for dim chrome,
// one saturated accent for the highlighted branch, a `margin: 0` reset on every
// inner element to defeat Starlight's prose-margin selector, height-capped and
// horizontal at max-width 600.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The single saturated accent that marks `crypto.subtle` as both the only async
// surface and the only one this lesson takes to depth. Violet is the chapter's
// established "this is the one that matters" tint (see BufferVsPull's message
// overlay).
const accent = "#7c3aed"; // violet-600

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: grid",
  // Three columns: the crypto box, the fan SVG, the stacked surface boxes.
  "grid-template-columns: auto 64px 1fr",
  "align-items: center",
  "column-gap: 0",
  "width: 100%",
  "max-width: 600px",
  "box-sizing: border-box",
  sans,
].join("; ");

// Shared box chrome.
const boxBase = [
  reset,
  "box-sizing: border-box",
  "border-radius: 10px",
  "display: flex",
  "flex-direction: column",
  "gap: 3px",
].join("; ");

// The source box (left). Lit but neutral — it's the object, not a branch.
const sourceBox = [
  boxBase,
  "align-items: center",
  "justify-content: center",
  "text-align: center",
  "padding: 14px 16px",
  "border: 1.5px solid var(--sl-color-gray-3)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-text)",
].join("; ");

// A dim surface box — the two synchronous conveniences.
const dimSurface = [
  boxBase,
  "align-items: flex-start",
  "text-align: left",
  "padding: 9px 12px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The accented surface box — crypto.subtle.
const litSurface = [
  boxBase,
  "align-items: flex-start",
  "text-align: left",
  "padding: 9px 12px",
  `border: 1.5px solid ${accent}`,
  `background: color-mix(in srgb, ${accent} 12%, transparent)`,
  `color: color-mix(in srgb, ${accent} 82%, var(--sl-color-text))`,
  `box-shadow: 0 0 0 4px color-mix(in srgb, ${accent} 14%, transparent)`,
].join("; ");

// The right column holds the three surface boxes stacked.
const surfaceCol = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "min-width: 0",
].join("; ");

const memberLine = `${reset}; ${mono}; font-size: 13px; font-weight: 700; line-height: 1.25;`;

// The "a unique ID" / "random bytes" / "algorithms" tag under each member.
const tagLine = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.2",
].join("; ");

// A small sync / async pill that rides at the end of each surface row.
const pillBase = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 3px 6px",
  "border-radius: 999px",
  "white-space: nowrap",
  "flex: 0 0 auto",
].join("; ");

const syncPill = [
  pillBase,
  "border: 1px solid var(--sl-color-gray-4)",
  "background: transparent",
  "color: var(--sl-color-gray-3)",
].join("; ");

const asyncPill = [
  pillBase,
  `border: 1px solid ${accent}`,
  `background: color-mix(in srgb, ${accent} 16%, transparent)`,
  `color: color-mix(in srgb, ${accent} 88%, var(--sl-color-text))`,
].join("; ");

// Row inside a surface box: the member + tag on the left, the pill on the right.
const surfaceRow = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "justify-content: space-between",
  "gap: 10px",
  "width: 100%",
].join("; ");

const dimColor = "var(--sl-color-gray-4)";
---

<div class="not-content" style={root}>
  {/* crypto box — column 1, vertically centred against the three surfaces */}
  <div style={`grid-column: 1; ${sourceBox}`}>
    <span style={`${memberLine}; font-size: 15px;`}>crypto</span>
    <span style={`${tagLine}; color: var(--sl-color-gray-3);`}>the global</span>
  </div>

  {/* fan — column 2: one SVG drawing three lines from a single left anchor to
      the three surface rows. Top two dim, the bottom (subtle) in the accent. */}
  <svg
    style={`grid-column: 2; ${reset}; display: block; width: 100%; height: 132px;`}
    viewBox="0 0 64 132"
    preserveAspectRatio="none"
    role="img"
    aria-label="The crypto global branches into three surfaces."
  >
    {/* anchor at left-middle (x=0, y=66); targets at the three row centres
        (y≈24, y=66, y≈108) on the right (x=64). */}
    <path
      d="M 0 66 C 28 66, 30 24, 64 24"
      fill="none"
      stroke={dimColor}
      stroke-width="1.5"></path>
    <path
      d="M 0 66 L 64 66"
      fill="none"
      stroke={dimColor}
      stroke-width="1.5"></path>
    <path
      d="M 0 66 C 28 66, 30 108, 64 108"
      fill="none"
      stroke={accent}
      stroke-width="2"></path>
    {/* node dots at each end keep the fan reading as a branch, not a stray line */}
    <circle cx="0" cy="66" r="2.5" fill="var(--sl-color-gray-3)"></circle>
    <circle cx="64" cy="24" r="2.5" fill={dimColor}></circle>
    <circle cx="64" cy="66" r="2.5" fill={dimColor}></circle>
    <circle cx="64" cy="108" r="3" fill={accent}></circle>
  </svg>

  {/* the three surfaces — column 3 */}
  <div style={`grid-column: 3; ${surfaceCol}`}>
    {/* randomUUID — sync convenience, dim */}
    <div style={dimSurface}>
      <div style={surfaceRow}>
        <span style={memberLine}>crypto.randomUUID()</span>
        <span style={syncPill}>sync</span>
      </div>
      <span style={`${tagLine}; color: var(--sl-color-gray-3);`}>a unique ID</span>
    </div>

    {/* getRandomValues — sync convenience, dim */}
    <div style={dimSurface}>
      <div style={surfaceRow}>
        <span style={memberLine}>crypto.getRandomValues()</span>
        <span style={syncPill}>sync</span>
      </div>
      <span style={`${tagLine}; color: var(--sl-color-gray-3);`}>random bytes</span>
    </div>

    {/* subtle — the accented, async, taught-at-depth surface */}
    <div style={litSurface}>
      <div style={surfaceRow}>
        <span style={memberLine}>crypto.subtle</span>
        <span style={asyncPill}>async</span>
      </div>
      <span style={`${tagLine}; color: color-mix(in srgb, ${accent} 78%, var(--sl-color-text));`}
        >algorithms &middot; sign, verify, digest &mdash; taught at depth</span
      >
    </div>
  </div>
</div>
