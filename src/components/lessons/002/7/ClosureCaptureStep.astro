---
// One step of the "How a closure reads its outer scope" sequence.
// All three steps share the same coordinate system so the boxes, labels,
// and the capture arrow stay in identical positions — the only things that
// change are the value inside `count`, an outgoing call marker (step 3),
// and an output bubble (step 3). That keeps the focus on "the pointer
// doesn't change between steps; the contents the binding holds do."

interface Props {
	step: 1 | 2 | 3;
}

const { step } = Astro.props;

// Per-step variants.
const countValue = step === 1 ? '0' : '5';
const showCallMarker = step === 3;
const showOutput = step === 3;
const showCaptureLabel = step === 1;

// Shared accent colors. The closure arrow stays one identity across steps;
// `count` box keeps a single tint so the eye tracks "same binding."
const bindingColor = '#f97316'; // orange — the `count` binding
const arrowColor = '#0ea5e9'; // sky blue — capture-by-reference arrow
const callColor = '#16a34a'; // green — call/output in step 3
---

<svg
	viewBox="0 0 640 264"
	role="img"
	aria-label={`Step ${step} of three: a closure captures the outer scope's count binding by reference. ${
		step === 1
			? 'Initial state — count holds 0.'
			: step === 2
				? 'Outer scope reassigns count to 5; the closure still points to the same binding.'
				: 'The closure is called and reads the binding through its pointer, printing 5.'
	}`}
	xmlns="http://www.w3.org/2000/svg"
	style="width: 100%; height: auto; display: block;"
>
	<defs>
		<marker
			id={`closure-arrow-${step}`}
			viewBox="0 0 10 10"
			refX="9"
			refY="5"
			markerWidth="7"
			markerHeight="7"
			orient="auto-start-reverse"
		>
			<path d="M 0 0 L 10 5 L 0 10 z" fill={arrowColor} />
		</marker>
		<marker
			id={`call-arrow-${step}`}
			viewBox="0 0 10 10"
			refX="9"
			refY="5"
			markerWidth="7"
			markerHeight="7"
			orient="auto-start-reverse"
		>
			<path d="M 0 0 L 10 5 L 0 10 z" fill={callColor} />
		</marker>
	</defs>

	{/* ===== Outer scope panel (left) ===== */}
	<g font-family="system-ui, -apple-system, 'Segoe UI', sans-serif">
		<text
			x="140"
			y="22"
			font-size="13"
			font-weight="600"
			fill="currentColor"
			text-anchor="middle"
		>
			Outer scope
		</text>
	</g>

	<rect
		x="20"
		y="36"
		width="240"
		height="180"
		rx="10"
		ry="10"
		fill="none"
		stroke="#9ca3af"
		stroke-width="1.5"
		stroke-dasharray="6 4"
	/>

	{/* `count` binding: label + value box. The value box is the "box" half of
		 the binding-vs-box model — the binding name on the left points at the
		 mutable container on the right. */}
	<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13">
		<text x="50" y="130" fill="currentColor" dominant-baseline="central">
			count
		</text>
	</g>

	{/* Value container — fill tinted with the binding color so the eye groups
		 this with the same box across steps. */}
	<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
		<rect
			x="110"
			y="110"
			width="120"
			height="40"
			rx="6"
			ry="6"
			fill={`color-mix(in srgb, ${bindingColor} 14%, transparent)`}
			stroke={bindingColor}
			stroke-width="1.8"
		/>
		<text
			x="170"
			y="130"
			font-size="16"
			font-weight="600"
			fill="currentColor"
			text-anchor="middle"
			dominant-baseline="central"
		>
			{countValue}
		</text>
	</g>

	{/* ===== Inner function panel (right) ===== */}
	<g font-family="system-ui, -apple-system, 'Segoe UI', sans-serif">
		<text
			x="500"
			y="22"
			font-size="13"
			font-weight="600"
			fill="currentColor"
			text-anchor="middle"
		>
			Inner function (closure)
		</text>
	</g>

	<rect
		x="380"
		y="36"
		width="240"
		height="180"
		rx="10"
		ry="10"
		fill="none"
		stroke="currentColor"
		stroke-width="1.5"
	/>

	{/* Function body — single-line code rendered as text. */}
	<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
		<text
			x="500"
			y="130"
			font-size="13"
			fill="currentColor"
			text-anchor="middle"
			dominant-baseline="central"
		>
			{'() => console.log(count)'}
		</text>
	</g>

	{/* ===== Capture arrow: inner function → count binding ===== */}
	{/* Same coordinates in every step. The point of the diagram is that the
		 arrow does not move when `count` is reassigned — only the contents of
		 the box change. */}
	<g>
		<line
			x1="380"
			y1="130"
			x2="234"
			y2="130"
			stroke={arrowColor}
			stroke-width="2"
			marker-end={`url(#closure-arrow-${step})`}
		/>
		{
			showCaptureLabel && (
				<g font-family="system-ui, -apple-system, 'Segoe UI', sans-serif">
					<rect
						x="262"
						y="92"
						width="96"
						height="22"
						rx="11"
						ry="11"
						fill={`color-mix(in srgb, ${arrowColor} 14%, transparent)`}
						stroke={arrowColor}
						stroke-width="1"
					/>
					<text
						x="310"
						y="103"
						font-size="11"
						fill="currentColor"
						text-anchor="middle"
						dominant-baseline="central"
					>
						captures by reference
					</text>
				</g>
			)
		}
	</g>

	{/* ===== Step 3 only: call marker + output bubble ===== */}
	{
		showCallMarker && (
			<g>
				{/* "call" pill above the inner function panel, with an arrow into
					 the function body. */}
				<rect
					x="464"
					y="48"
					width="72"
					height="24"
					rx="12"
					ry="12"
					fill={`color-mix(in srgb, ${callColor} 18%, transparent)`}
					stroke={callColor}
					stroke-width="1.4"
				/>
				<text
					x="500"
					y="60"
					font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
					font-size="12"
					font-weight="600"
					fill="currentColor"
					text-anchor="middle"
					dominant-baseline="central"
				>
					call
				</text>
				<line
					x1="500"
					y1="74"
					x2="500"
					y2="108"
					stroke={callColor}
					stroke-width="1.6"
					stroke-dasharray="4 3"
					marker-end={`url(#call-arrow-${step})`}
				/>

				{/* Output bubble below the inner function panel — the value the
					 closure read from the binding. */}
				<g font-family="ui-monospace, SFMono-Regular, Menlo, monospace">
					<rect
						x="446"
						y="226"
						width="108"
						height="28"
						rx="6"
						ry="6"
						fill="var(--sl-color-bg, #fff)"
						stroke={callColor}
						stroke-width="1.6"
					/>
					<text
						x="500"
						y="240"
						font-size="13"
						fill="currentColor"
						text-anchor="middle"
						dominant-baseline="central"
					>
						{'logs: 5'}
					</text>
				</g>
			</g>
		)
	}
</svg>
