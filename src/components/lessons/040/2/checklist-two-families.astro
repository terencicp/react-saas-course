---
// Diagram: the five-question migration-review checklist, split into its two
// failure families (diagram id: checklist-two-families, Chapter 040 Lesson 2 —
// "Production-safe migrations"). A glanceable reference card the student can
// return to: a visual scaffold, NOT a system graph. The prose just named the
// pattern hiding in the list — questions 1-2 are about LOSING DATA, questions
// 3-5 are about LOCKS AND DOWNTIME — and this figure is the whole checklist
// drawn that way, so the split is the thing the eye sees first.
//
// Layout: two equal cards side by side (wrap to stacked on narrow viewports).
//   LEFT  "Data-loss risks"      — rose family (irreversible: you can't get it
//                                  back). Holds Q1 and Q2.
//   RIGHT "Lock / downtime risks" — amber family (it freezes the table while it
//                                  runs). Holds Q3, Q4, Q5.
// Each question keeps its original checklist number so the card maps 1:1 back to
// the numbered prose above it. Numbers ride in a small circular badge tinted to
// the family; the question text sits to its right, with inline <code> for the
// SQL keywords (DROP, NOT NULL).
//
// House style follows the ch 039 family (seq-scan-vs-index.astro /
// concurrency-anomalies.astro): pinned `color-scheme: light` so the hand-picked
// tints survive dark mode, inline style strings only (copy the source, see what
// styled it), `margin: 0` on every inner element to defeat Starlight's injected
// prose margin-top, box-sizing: border-box throughout, slate chrome that carries
// no meaning. No leader lines, so the figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';
const PANEL_BORDER = '#e2e8f0'; // slate-200 — neutral chrome

// DATA-LOSS family — rose/red. Irreversible: the signal is "you can't undo it".
const ROSE = '#e11d48'; // rose-600
const ROSE_BG = '#fff1f2'; // rose-50 wash
const ROSE_INK = '#be123c'; // rose-700

// LOCK / DOWNTIME family — amber. The table freezes while it runs.
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 wash
const AMBER_INK = '#b45309'; // amber-700

// One question row: its checklist number + the text (with inline <code> bits).
interface Q {
  n: number;
  // parts: a string renders as plain text; { code } renders as inline mono.
  parts: (string | { code: string })[];
}

interface Family {
  title: string;
  lede: string;
  base: string; // the accent color
  bg: string; // the wash behind the number badge
  ink: string; // the darker ink for the title + number
  questions: Q[];
}

const families: Family[] = [
  {
    title: 'Data-loss risks',
    lede: 'Could this delete something I can’t get back?',
    base: ROSE,
    bg: ROSE_BG,
    ink: ROSE_INK,
    questions: [
      { n: 1, parts: [{ code: 'DROP' }, ' — is it safe this deploy?'] },
      { n: 2, parts: ['A rename vs. a silent remove-and-add'] },
    ],
  },
  {
    title: 'Lock / downtime risks',
    lede: 'Could this freeze the table while it runs?',
    base: AMBER,
    bg: AMBER_BG,
    ink: AMBER_INK,
    questions: [
      { n: 3, parts: ['A new index on a hot table'] },
      { n: 4, parts: ['A type change that rewrites the table'] },
      { n: 5, parts: [{ code: 'NOT NULL' }, ' column with no default'] },
    ],
  },
];

// ---- styles ---------------------------------------------------------------
// outer stage: two cards side by side, wrap to stacked when narrow.
const stage = [
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 16px',
  'row-gap: 16px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// one family card.
const card = (base: string) =>
  [
    'box-sizing: border-box',
    'flex: 1 1 320px',
    'display: flex',
    'flex-direction: column',
    'gap: 12px',
    'margin: 0',
    'padding: 16px 18px',
    'border-radius: 14px',
    `border: 1.5px solid ${PANEL_BORDER}`,
    `border-top: 4px solid ${base}`,
    `background: ${SURFACE}`,
    'min-width: 0',
    'max-width: 460px',
  ].join('; ');

// card header block (title + lede question).
const head = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 3px',
  'margin: 0',
  `border-bottom: 1px solid ${PANEL_BORDER}`,
  'padding: 0 0 10px',
].join('; ');

const cardTitle = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 14px',
    'font-weight: 800',
    'letter-spacing: 0.01em',
    'line-height: 1.2',
    `color: ${ink}`,
  ].join('; ');

const cardLede = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'font-style: italic',
  'line-height: 1.35',
  `color: ${INK_SOFT}`,
].join('; ');

// the column of question rows.
const list = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 10px',
  'margin: 0',
].join('; ');

// one question row: number badge + text.
const row = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: flex-start',
  'gap: 10px',
  'margin: 0',
].join('; ');

// the circular checklist-number badge.
const badge = (base: string, bg: string, ink: string) =>
  [
    'box-sizing: border-box',
    'flex: 0 0 auto',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'width: 22px',
    'height: 22px',
    'margin: 0',
    'border-radius: 999px',
    `border: 1.5px solid ${base}`,
    `background: ${bg}`,
    `color: ${ink}`,
    `font-family: ${mono}`,
    'font-size: 12px',
    'font-weight: 800',
    'line-height: 1',
  ].join('; ');

// the question text.
const qText = [
  'box-sizing: border-box',
  'margin: 0',
  'padding-top: 2px',
  `font-family: ${sans}`,
  'font-size: 13px',
  'font-weight: 600',
  'line-height: 1.4',
  `color: ${INK}`,
].join('; ');

// inline code inside a question — sidestep Starlight's prose <code> pill so the
// keyword sits inline with the sentence at the row's font weight.
const qCode = [
  'margin: 0',
  'padding: 0',
  'background: transparent',
  `font-family: ${mono}`,
  'font-size: 12px',
  'font-weight: 800',
  `color: ${INK}`,
  'white-space: nowrap',
].join('; ');
---

<Figure caption="Read every migration twice — once for data loss, once for locks.">
  <div style={stage}>
    {
      families.map((family) => (
        <div style={card(family.base)}>
          <div style={head}>
            <p style={cardTitle(family.ink)}>{family.title}</p>
            <p style={cardLede}>{family.lede}</p>
          </div>
          <div style={list}>
            {family.questions.map((q) => (
              <div style={row}>
                <span style={badge(family.base, family.bg, family.ink)}>
                  {q.n}
                </span>
                <p style={qText}>
                  {q.parts.map((part) =>
                    typeof part === 'string' ? (
                      part
                    ) : (
                      <code style={qCode}>{part.code}</code>
                    ),
                  )}
                </p>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Figure>
