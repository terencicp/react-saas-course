---
// Diagram: the expand-backfill-contract strip (diagram id:
// expand-backfill-contract-strip, Chapter 040 Lesson 2 — "Production-safe
// migrations"). The STATIC summary of the destructive-change shape, placed
// right after the rename-cutover-race scrubber and deliberately NOT a second
// scrubber: one picture the eye takes in whole, so the three-phase pattern
// (Expand → Backfill → Contract) sticks as a single image.
//
// Three equal panels side by side (wrap to stacked on narrow viewports). Each
// panel shows the same `invoices` table's relevant columns plus what the app
// reads/writes that phase — the running example carried over from the scrubber:
// renaming `customer_name` → `client_name`.
//
//   Panel 1  EXPAND   — add `client_name` alongside `customer_name` (still empty).
//                       App still reads/writes `customer_name`. Nothing breaks.
//   Panel 2  BACKFILL — both columns present, `client_name` now filled from
//                       `customer_name`. App dual-writes both columns.
//   Panel 3  CONTRACT — only `client_name` remains; `customer_name` is dropped.
//                       App reads/writes `client_name`. Done, once nothing reads
//                       the old column.
//
// The panels read left-to-right as a progression; the numbered badges (1/2/3)
// and the phase names (Expand → Backfill → Contract) carry the order, so the
// strip survives a wrap to a vertical stack on narrow viewports.
//
// Colour convention mirrors the rename-cutover-race scrubber it summarises:
//   BLUE  = neutral chrome of the database box,
//   GREEN = the new column being introduced / the safe new shape,
//   RED   = the old column on its way out / the drop,
//   slate = inert chrome (the app read/write pill, panel borders, phase badges).
// The OLD column shifts rose-ward across the strip (neutral → kept → dropped) and
// the NEW column shifts green-ward (empty → filled → the only one), so the
// hand-off is legible at a glance without reading the captions.
//
// House style follows the ch 040 L2 family (checklist-two-families.astro /
// rename-cutover-race.astro): pinned `color-scheme: light` so the hand-picked
// tints survive dark mode, inline style strings only (copy the source, see what
// styled it), `margin: 0` on every inner element to defeat Starlight's injected
// prose margin-top, box-sizing: border-box throughout. No leader lines, so the
// figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';
const PANEL_BORDER = '#e2e8f0'; // slate-200 — neutral chrome

// the app you own — neutral slate, carries no meaning on its own.
const OWN = '#334155'; // slate-700
const OWN_BG = '#f1f5f9'; // slate-100 wash

// BLUE — the database box (neutral data store).
const BLUE = '#2563eb'; // blue-600
const BLUE_INK = '#1e3a8a'; // blue-900
const BLUE_BG = '#eff6ff'; // blue-50 wash

// GREEN — the new shape being introduced safely.
const GREEN = '#16a34a'; // green-600
const GREEN_INK = '#15803d'; // green-700
const GREEN_BG = '#f0fdf4'; // green-50 wash

// RED — the old shape on its way out / the drop.
const RED = '#dc2626'; // red-600
const RED_INK = '#b91c1c'; // red-700
const RED_BG = '#fef2f2'; // red-50 wash

// ---- model ---------------------------------------------------------------
// one column chip in the invoices box.
//   'has'     — present, not the one in question (neutral chrome),
//   'kept'    — the OLD column, still present this phase (neutral, faintly rose),
//   'empty'   — the NEW column, present but not yet populated (green ghost),
//   'filled'  — the NEW column, now populated (solid green),
//   'dropped' — the OLD column, gone this phase (red, struck through).
type Tone = 'has' | 'kept' | 'empty' | 'filled' | 'dropped';

interface Col {
  name: string;
  tone: Tone;
  tag?: string; // tiny overline tag riding on the chip ("new", "empty", …)
}

// what the app does with columns this phase: a verb + the column(s).
interface AppAction {
  verb: string; // "reads / writes" or "dual-writes"
  cols: { name: string; accent: string }[];
}

interface Phase {
  n: number;
  name: string;
  accent: string; // the phase badge / header accent
  badgeBg: string;
  badgeInk: string;
  app: AppAction;
  cols: Col[];
  caption: string;
}

const phases: Phase[] = [
  {
    n: 1,
    name: 'Expand',
    accent: GREEN,
    badgeBg: GREEN_BG,
    badgeInk: GREEN_INK,
    app: { verb: 'reads / writes', cols: [{ name: 'customer_name', accent: OWN }] },
    cols: [
      { name: 'customer_name', tone: 'kept' },
      { name: 'client_name', tone: 'empty', tag: 'new · empty' },
    ],
    caption: 'Add the new column. Nothing breaks yet.',
  },
  {
    n: 2,
    name: 'Backfill',
    accent: BLUE,
    badgeBg: BLUE_BG,
    badgeInk: BLUE_INK,
    app: {
      verb: 'dual-writes',
      cols: [
        { name: 'customer_name', accent: OWN },
        { name: 'client_name', accent: GREEN_INK },
      ],
    },
    cols: [
      { name: 'customer_name', tone: 'kept' },
      { name: 'client_name', tone: 'filled', tag: 'now filled' },
    ],
    caption: 'Copy existing rows into the new column, in batches.',
  },
  {
    n: 3,
    name: 'Contract',
    accent: RED,
    badgeBg: RED_BG,
    badgeInk: RED_INK,
    app: { verb: 'reads / writes', cols: [{ name: 'client_name', accent: GREEN_INK }] },
    cols: [
      { name: 'customer_name', tone: 'dropped', tag: 'dropped' },
      { name: 'client_name', tone: 'filled' },
    ],
    caption: 'Drop the old column once nothing reads it.',
  },
];

// ---- styles --------------------------------------------------------------
// outer stage: the three panels in one wrapping row.
const stage = [
  'box-sizing: border-box',
  'display: flex',
  'flex-wrap: wrap',
  'align-items: stretch',
  'justify-content: center',
  'column-gap: 10px',
  'row-gap: 14px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// one phase panel. Sized so all three sit on a single row at the standard
// figure width (~684px body): 3 × ~210px + two 10px gaps. Wraps to a stack only
// on genuinely narrow viewports, where the numbered badges and phase names keep
// the order legible.
const panel = (accent: string) =>
  [
    'box-sizing: border-box',
    'flex: 1 1 200px',
    'display: flex',
    'flex-direction: column',
    'gap: 11px',
    'margin: 0',
    'padding: 13px 12px 11px',
    'border-radius: 14px',
    `border: 1.5px solid ${PANEL_BORDER}`,
    `border-top: 4px solid ${accent}`,
    `background: ${SURFACE}`,
    'min-width: 0',
    'max-width: 240px',
  ].join('; ');

// panel header: the numbered phase badge + the phase name.
const head = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: center',
  'gap: 9px',
  'margin: 0',
].join('; ');

const badge = (bg: string, ink: string, accent: string) =>
  [
    'box-sizing: border-box',
    'flex: 0 0 auto',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'width: 22px',
    'height: 22px',
    'margin: 0',
    'border-radius: 999px',
    `border: 1.5px solid ${accent}`,
    `background: ${bg}`,
    `color: ${ink}`,
    `font-family: ${mono}`,
    'font-size: 12px',
    'font-weight: 800',
    'line-height: 1',
  ].join('; ');

const phaseName = (ink: string) =>
  [
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 14px',
    'font-weight: 800',
    'letter-spacing: 0.01em',
    'line-height: 1.2',
    `color: ${ink}`,
  ].join('; ');

// the "app reads/writes …" pill at the top of the body.
const appPill = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 3px',
  'margin: 0',
  'padding: 8px 10px',
  'border-radius: 10px',
  `border: 1.5px solid ${PANEL_BORDER}`,
  `background: ${OWN_BG}`,
].join('; ');

const appLabel = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: baseline',
  'gap: 4px',
  'flex-wrap: wrap',
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 10.5px',
  'font-weight: 700',
  'line-height: 1.25',
  `color: ${INK_SOFT}`,
].join('; ');

const appOwn = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 800',
  `color: ${OWN}`,
].join('; ');

const appVerb = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 10.5px',
  'font-weight: 600',
  `color: ${INK_SOFT}`,
].join('; ');

// the column name(s) the app touches this phase — stacked vertically so a
// dual-write phase lists both names cleanly instead of wrapping mid-expression.
const appCols = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: flex-start',
  'gap: 2px',
  'margin: 0',
].join('; ');

// one column name inside the app pill, tinted to which column it touches.
// `background: transparent; padding: 0` defeats Starlight's inline-<code> pill
// (a dark fill + padding) so the tint reads against the pill, not a dark chip.
const appCol = (accent: string) =>
  [
    'margin: 0',
    'padding: 0',
    'background: transparent',
    `font-family: ${mono}`,
    'font-size: 10.5px',
    'font-weight: 800',
    `color: ${accent}`,
    'white-space: nowrap',
    'line-height: 1.25',
  ].join('; ');

// the Postgres invoices box.
const dbBox = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 8px',
  'margin: 0',
  'padding: 11px 12px 12px',
  'border-radius: 12px',
  `border: 1.5px solid ${BLUE}`,
  `background: ${BLUE_BG}`,
].join('; ');

const dbHead = [
  'box-sizing: border-box',
  'display: flex',
  'align-items: baseline',
  'justify-content: space-between',
  'gap: 8px',
  'margin: 0',
].join('; ');

const dbTitle = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 800',
  'line-height: 1.2',
  `color: ${BLUE_INK}`,
  'white-space: nowrap',
].join('; ');

const dbSub = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 10px',
  'font-weight: 700',
  'line-height: 1.2',
  `color: ${BLUE}`,
  'white-space: nowrap',
].join('; ');

const colStack = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 6px',
  'margin: 0',
].join('; ');

// one column chip. tone drives border / background / ink and decoration.
const colChip = (tone: Tone) => {
  const map = {
    has: { border: PANEL_BORDER, bg: SURFACE, ink: INK, dash: false, strike: false },
    kept: { border: PANEL_BORDER, bg: SURFACE, ink: INK, dash: false, strike: false },
    empty: { border: GREEN, bg: SURFACE, ink: GREEN_INK, dash: true, strike: false },
    filled: { border: GREEN, bg: GREEN_BG, ink: GREEN_INK, dash: false, strike: false },
    dropped: { border: RED, bg: RED_BG, ink: RED_INK, dash: true, strike: true },
  } as const;
  const c = map[tone];
  return [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'justify-content: space-between',
    'gap: 8px',
    'margin: 0',
    'padding: 5px 9px',
    'border-radius: 8px',
    `border: 1.5px ${c.dash ? 'dashed' : 'solid'} ${c.border}`,
    `background: ${c.bg}`,
    'min-width: 0',
  ].join('; ');
};

const colName = (tone: Tone) => {
  const ink =
    tone === 'filled' || tone === 'empty'
      ? GREEN_INK
      : tone === 'dropped'
        ? RED_INK
        : INK;
  return [
    'margin: 0',
    'padding: 0',
    'background: transparent',
    `font-family: ${mono}`,
    'font-size: 11px',
    'font-weight: 700',
    `color: ${ink}`,
    'line-height: 1.2',
    'white-space: nowrap',
    tone === 'dropped' ? 'text-decoration: line-through' : '',
  ]
    .filter(Boolean)
    .join('; ');
};

// the tiny status tag riding on a chip ("new · empty", "now filled", "dropped").
const chipTag = (tone: Tone) => {
  const ink = tone === 'dropped' ? RED_INK : GREEN_INK;
  return [
    'flex: 0 0 auto',
    'margin: 0',
    `font-family: ${sans}`,
    'font-size: 8.5px',
    'font-weight: 800',
    'letter-spacing: 0.03em',
    'text-transform: uppercase',
    'text-decoration: none',
    `color: ${ink}`,
    'white-space: nowrap',
  ].join('; ');
};

const caption = [
  'box-sizing: border-box',
  'margin: 0',
  'padding: 0',
  `font-family: ${sans}`,
  'font-size: 11.5px',
  'font-weight: 600',
  'line-height: 1.4',
  `color: ${INK_SOFT}`,
  'text-align: center',
].join('; ');
---

<Figure caption="Expand-backfill-contract — three deploys, no broken window.">
  <div style={stage}>
    {
      phases.map((phase) => (
          <div style={panel(phase.accent)}>
            {/* header: numbered phase + name */}
            <div style={head}>
              <span style={badge(phase.badgeBg, phase.badgeInk, phase.accent)}>
                {phase.n}
              </span>
              <p style={phaseName(phase.badgeInk)}>{phase.name}</p>
            </div>

            {/* what the app reads/writes this phase */}
            <div style={appPill}>
              <span style={appLabel}>
                <span style={appOwn}>App</span>
                <span style={appVerb}>{phase.app.verb}</span>
              </span>
              <span style={appCols}>
                {phase.app.cols.map((c) => (
                  <code style={appCol(c.accent)}>{c.name}</code>
                ))}
              </span>
            </div>

            {/* the invoices table this phase */}
            <div style={dbBox}>
              <div style={dbHead}>
                <span style={dbTitle}>Postgres</span>
                <span style={dbSub}>invoices</span>
              </div>
              <div style={colStack}>
                {phase.cols.map((col) => (
                  <span style={colChip(col.tone)}>
                    <code style={colName(col.tone)}>{col.name}</code>
                    {col.tag && <span style={chipTag(col.tone)}>{col.tag}</span>}
                  </span>
                ))}
              </div>
            </div>

            {/* the one-line caption for this phase */}
            <p style={caption}>{phase.caption}</p>
          </div>
        ))
    }
  </div>
</Figure>
