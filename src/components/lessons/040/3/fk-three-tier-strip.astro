---
// fk-three-tier-strip — Chapter 040 Lesson 3 ("Deterministic seeding with
// drizzle-seed"), the one-glance picture for how a single references()
// declaration does double duty: it sets the topological INSERT ORDER
// (organizations -> invoices -> lineItems) and, via `with`, the per-parent
// FANOUT count.
//
// A horizontal three-box strip, each box a table in the FK chain with its
// row-count annotation underneath. The two connecting arrows each carry the
// same label — "references() => insert order" — to make the point that the FK
// declaration is what orders the inserts. The fanout arithmetic (200 invoices
// x 5 line items = 1,000) is rendered on the third box, with the multiplier
// in the one saturated accent colour so the eye lands on it.
//
// A footer pill spells out the count-vs-with distinction in one line — the
// single biggest seeding surprise the prose calls out.
//
// Plain HTML + CSS per the diagram guidance for annotated illustrations
// (NOT ArrowDiagram — kept deliberately simple, capped height, horizontal).
// Inline styles only so a reader can devtools the real flexbox. `margin: 0`
// on every node to defeat Starlight's prose-margin injection.

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const ACCENT = "#0d9488"; // teal — the fanout multiplier signal

// Outer container — not-content, centred, well under the 800px ceiling.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 760px",
  "margin-inline: auto",
  "display: flex",
  "flex-direction: column",
  "gap: 16px",
  "align-items: center",
].join("; ");

// The strip itself: boxes + arrows in one row, wrapping if the card is narrow.
const strip = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "column-gap: 6px",
  "row-gap: 20px",
  "width: 100%",
].join("; ");

// One table box. Split into a name header strip and a count annotation body.
const box = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "overflow: hidden",
  "border-radius: 10px",
  "border: 1.5px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "min-width: 0",
  "flex: 0 1 auto",
  "max-width: 220px",
].join("; ");

const boxHead = [
  reset,
  mono,
  "box-sizing: border-box",
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "padding: 8px 14px",
  "color: var(--sl-color-white)",
  "background: var(--sl-color-gray-5)",
  "border-bottom: 1px solid var(--sl-color-gray-4)",
  "text-align: center",
  "white-space: nowrap",
].join("; ");

const boxBody = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 3px",
  "align-items: center",
  "font-size: 11.5px",
  "font-weight: 500",
  "line-height: 1.3",
  "padding: 8px 12px 10px",
  "color: var(--sl-color-gray-3)",
  "text-align: center",
].join("; ");

// The bold number on each box's first body line.
const countNum = [
  reset,
  "font-size: 15px",
  "font-weight: 700",
  "line-height: 1.15",
  "color: var(--sl-color-text)",
].join("; ");

// Secondary clarifier line under the number (e.g. "total", "per parent").
const countNote = [
  reset,
  "font-size: 10.5px",
  "font-weight: 500",
  "line-height: 1.2",
  "opacity: 0.85",
].join("; ");

// Inline code-ish token inside a body line.
const tok = [mono, "font-size: 11px", "color: var(--sl-color-text)"].join("; ");

// The connector between two boxes: a labelled right arrow.
const connector = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 4px",
  "flex: 0 0 auto",
  "align-self: center",
  "padding: 0 2px",
].join("; ");

const connectorLabel = [
  reset,
  mono,
  "font-size: 9.5px",
  "font-weight: 600",
  "line-height: 1.15",
  "white-space: nowrap",
  "color: var(--sl-color-gray-3)",
  "text-align: center",
].join("; ");

const connectorArrow = [
  reset,
  "font-size: 22px",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "opacity: 0.7",
  "user-select: none",
].join("; ");

// Footer pill spelling out the count-vs-with distinction.
const footer = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "justify-content: center",
  "gap: 6px 14px",
  "padding: 8px 14px",
  "border-radius: 999px",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "font-size: 12px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");

const footerItem = [
  reset,
  "display: inline-flex",
  "align-items: baseline",
  "gap: 5px",
].join("; ");
---

<div class="not-content" style={root}>
  <div style={strip}>
    {/* ---- Box 1: organizations ------------------------------------- */}
    <div style={box}>
      <div style={boxHead}>organizations</div>
      <div style={boxBody}>
        <span style={countNum}>2</span>
        <span style={countNote}>rows</span>
      </div>
    </div>

    {/* connector: references() drives insert order */}
    <div style={connector}>
      <span style={connectorLabel}>references()<br />&rArr; insert order</span>
      <span style={connectorArrow}>&rarr;</span>
    </div>

    {/* ---- Box 2: invoices ------------------------------------------ */}
    <div style={box}>
      <div style={boxHead}>invoices</div>
      <div style={boxBody}>
        <span style={countNum}>200</span>
        <span style={countNote}>
          <span style={tok}>count: 200</span> &middot; total
        </span>
      </div>
    </div>

    {/* connector: references() drives insert order */}
    <div style={connector}>
      <span style={connectorLabel}>references()<br />&rArr; insert order</span>
      <span style={connectorArrow}>&rarr;</span>
    </div>

    {/* ---- Box 3: lineItems ----------------------------------------- */}
    <div style={box}>
      <div style={boxHead}>lineItems</div>
      <div style={boxBody}>
        <span style={countNum}>
          1,000 <span style={`${countNote}; color: ${ACCENT}; opacity: 1; font-weight: 700;`}>total</span>
        </span>
        <span style={countNote}>
          <span style={tok}>with: 5</span>
          <span style={`color: ${ACCENT}; font-weight: 700;`}> per invoice</span>
        </span>
        <span style={`${countNote}; color: ${ACCENT}; opacity: 1; font-weight: 600;`}>
          200 &times; 5 = 1,000
        </span>
      </div>
    </div>
  </div>

  {/* ---- Footer: the count-vs-with distinction in one line ---------- */}
  <div style={footer}>
    <span style={footerItem}>
      <span style={`${tok}; font-weight: 700;`}>count</span>
      <span>= total for the table</span>
    </span>
    <span style={footerItem}>
      <span style={`${tok}; font-weight: 700; color: ${ACCENT};`}>with</span>
      <span>= per parent row</span>
    </span>
  </div>
</div>
