---
// One frame of the interrupt-and-resume timeline, scrubbed inside a
// <DiagramSequence>. The whole point is to show in TIME what a paragraph
// cannot: React abandons an in-progress low-priority (transition) render the
// moment an urgent update arrives, then restarts it for the newer query.
//
// Two stacked lanes, fixed for the whole sequence so nothing jumps as you
// scrub:
//   Urgent     (the controlled <input>)  — blue,  commits first, jumps the queue
//   Transition (the heavy <SlowList>)     — violet, renders in the background
//
// The track is a fixed 3-column time grid (a → b → settle). Each lane holds
// blocks pinned to a column; a block's STATE is the story:
//   pending     queued, not started        (dashed outline)
//   rendering   in-progress background work (striped fill)
//   committed   painted to the screen       (solid fill)
//   discarded   thrown away mid-render      (struck through, faded)
//
// `step` (1–5) selects the frame; source order = scrub order. The payload is
// step 4: the transition's "a" render is discarded while a fresh "ab" render
// begins, the urgent "b" having jumped straight to a commit.
//
// Pure HTML + CSS like the chapter's other figures: `not-content` wrapper,
// theme gray variables for chrome, saturated mid-tones (blue-600 / violet-600)
// with white text so the lane colors read in light and dark, and a `margin: 0`
// reset on every inner element to defeat Starlight's prose-margin selector.

interface Props {
  step: 1 | 2 | 3 | 4 | 5;
}

const { step } = Astro.props;

const reset = 'margin: 0';
const mono =
  'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';
const sans = 'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)';

const URGENT = '#2563eb'; // blue-600  — the urgent lane (input)
const TRANS = '#7c3aed'; // violet-600 — the transition lane (slow list)

type State = 'pending' | 'rendering' | 'committed' | 'discarded';
type Block = { col: 1 | 2 | 3; label: string; state: State };

// Per-frame contents of each lane. A column with no block stays empty so the
// lanes keep a constant width across every frame.
const frames: Record<
  Props['step'],
  { urgent: Block[]; transition: Block[] }
> = {
  // 1 — "a" typed: both updates queued, nothing has run yet.
  1: {
    urgent: [{ col: 1, label: 'set input → a', state: 'pending' }],
    transition: [{ col: 1, label: 'filter → a', state: 'pending' }],
  },
  // 2 — urgent commits instantly; only now does the background render begin.
  2: {
    urgent: [{ col: 1, label: 'input = a', state: 'committed' }],
    transition: [{ col: 1, label: 'filter → a', state: 'rendering' }],
  },
  // 3 — "b" typed mid-render: a new urgent update lands while "a" is still in flight.
  3: {
    urgent: [
      { col: 1, label: 'input = a', state: 'committed' },
      { col: 2, label: 'set input → b', state: 'pending' },
    ],
    transition: [{ col: 1, label: 'filter → a', state: 'rendering' }],
  },
  // 4 — THE PAYLOAD. Urgent "b" jumps the queue and commits; the half-done "a"
  //     render is thrown away; a fresh render starts for "ab".
  4: {
    urgent: [
      { col: 1, label: 'input = a', state: 'committed' },
      { col: 2, label: 'input = b', state: 'committed' },
    ],
    transition: [
      { col: 1, label: 'filter → a', state: 'discarded' },
      { col: 2, label: 'filter → ab', state: 'rendering' },
    ],
  },
  // 5 — typing stops; the "ab" background render runs to completion and commits.
  5: {
    urgent: [{ col: 2, label: 'input = ab', state: 'committed' }],
    transition: [{ col: 3, label: 'list = ab', state: 'committed' }],
  },
};

const frame = frames[step];

// Time-axis column captions, shown under the track as anchors.
const COLS = [
  { key: 1, label: 'types a' },
  { key: 2, label: 'types b' },
  { key: 3, label: 'stops' },
] as const;

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  'display: flex',
  'flex-direction: column',
  'gap: 12px',
  'width: 100%',
  'max-width: 640px',
  'margin-left: auto',
  'margin-right: auto',
  'box-sizing: border-box',
  sans,
].join('; ');

const laneRow = [
  reset,
  'display: grid',
  'grid-template-columns: 132px 1fr',
  'align-items: stretch',
  'gap: 10px',
].join('; ');

// The fixed lane label on the left, color-keyed to its lane.
const laneTag = (accent: string) =>
  [
    reset,
    'display: flex',
    'flex-direction: column',
    'justify-content: center',
    'gap: 3px',
    'padding: 8px 10px',
    'border-radius: 9px',
    'border: 1px solid ' + `color-mix(in srgb, ${accent} 35%, var(--sl-color-hairline))`,
    'background: ' + `color-mix(in srgb, ${accent} 9%, transparent)`,
    'box-sizing: border-box',
  ].join('; ');

const laneTagTitle = (accent: string) =>
  [
    reset,
    sans,
    'font-size: 13px',
    'font-weight: 700',
    'letter-spacing: 0.01em',
    'line-height: 1.1',
    'color: ' + `color-mix(in srgb, ${accent} 70%, var(--sl-color-text))`,
  ].join('; ');

const laneTagSub = [
  reset,
  sans,
  'font-size: 10.5px',
  'font-weight: 500',
  'line-height: 1.1',
  'color: var(--sl-color-gray-3)',
].join('; ');

// The track: a 3-column time grid the blocks sit inside.
const track = [
  reset,
  'display: grid',
  'grid-template-columns: repeat(3, 1fr)',
  'gap: 6px',
  'padding: 6px',
  'border-radius: 9px',
  'border: 1px dashed var(--sl-color-hairline)',
  'background: var(--sl-color-gray-6)',
  'box-sizing: border-box',
  'min-height: 50px',
].join('; ');

// One cell per block; struck-through layering for the discarded case is done
// with an overlaid rule.
const cellBase = (col: number) =>
  [
    reset,
    `grid-column: ${col}`,
    'grid-row: 1',
    'position: relative',
    'display: flex',
    'align-items: center',
    'justify-content: center',
    'padding: 7px 8px',
    'border-radius: 7px',
    'box-sizing: border-box',
    'min-width: 0',
    'text-align: center',
    mono,
    'font-size: 12px',
    'font-weight: 600',
    'line-height: 1.15',
  ].join('; ');

// State → fill. Saturated solid for committed (it's on the screen), a striped
// gradient for the in-flight background render, a dashed ghost for queued work,
// and a faded struck cell for work React threw away.
const cellStyle = (accent: string, state: State, col: number) => {
  const base = cellBase(col);
  if (state === 'committed') {
    return `${base}; background: ${accent}; border: 1.5px solid ${accent}; color: var(--sl-color-white);`;
  }
  if (state === 'rendering') {
    const stripe = `repeating-linear-gradient(135deg, color-mix(in srgb, ${accent} 26%, transparent) 0 7px, color-mix(in srgb, ${accent} 9%, transparent) 7px 14px)`;
    return `${base}; background: ${stripe}; border: 1.5px solid ${accent}; color: color-mix(in srgb, ${accent} 72%, var(--sl-color-text));`;
  }
  if (state === 'discarded') {
    return `${base}; background: var(--sl-color-gray-6); border: 1.5px dashed color-mix(in srgb, ${accent} 40%, var(--sl-color-gray-4)); color: var(--sl-color-gray-3); opacity: 0.72;`;
  }
  // pending
  return `${base}; background: var(--sl-color-bg); border: 1.5px dashed color-mix(in srgb, ${accent} 55%, var(--sl-color-gray-4)); color: color-mix(in srgb, ${accent} 70%, var(--sl-color-text));`;
};

// The struck-through rule drawn over a discarded cell.
const strike = (accent: string) =>
  [
    reset,
    'position: absolute',
    'left: 6px',
    'right: 6px',
    'top: 50%',
    'height: 2px',
    'background: ' + `color-mix(in srgb, ${accent} 65%, var(--sl-color-gray-3))`,
    'transform: rotate(-9deg)',
    'border-radius: 2px',
  ].join('; ');

// A tiny status chip pinned to a cell's corner, naming its state.
const chip = (accent: string, state: State) => {
  const map: Record<State, { bg: string; fg: string; bd: string }> = {
    committed: { bg: accent, fg: 'var(--sl-color-white)', bd: accent },
    rendering: {
      bg: `color-mix(in srgb, ${accent} 16%, var(--sl-color-bg))`,
      fg: `color-mix(in srgb, ${accent} 78%, var(--sl-color-text))`,
      bd: `color-mix(in srgb, ${accent} 45%, transparent)`,
    },
    discarded: {
      bg: 'var(--sl-color-gray-6)',
      fg: 'var(--sl-color-gray-3)',
      bd: 'var(--sl-color-gray-4)',
    },
    pending: {
      bg: 'var(--sl-color-bg)',
      fg: 'var(--sl-color-gray-2)',
      bd: 'var(--sl-color-gray-4)',
    },
  };
  const c = map[state];
  return [
    reset,
    sans,
    'position: absolute',
    'top: -8px',
    'left: 50%',
    'transform: translateX(-50%)',
    'white-space: nowrap',
    'padding: 1px 6px',
    'border-radius: 999px',
    'font-size: 9px',
    'font-weight: 700',
    'letter-spacing: 0.04em',
    'text-transform: uppercase',
    'line-height: 1.3',
    `background: ${c.bg}`,
    `color: ${c.fg}`,
    `border: 1px solid ${c.bd}`,
  ].join('; ');
};

const CHIP_LABEL: Record<State, string> = {
  pending: 'queued',
  rendering: 'rendering',
  committed: 'committed',
  discarded: 'discarded',
};

// Time-axis caption row beneath the track, aligned to the same 3 columns.
const axisRow = [
  reset,
  'display: grid',
  'grid-template-columns: 132px 1fr',
  'gap: 10px',
].join('; ');

const axisCols = [
  reset,
  'display: grid',
  'grid-template-columns: repeat(3, 1fr)',
  'gap: 6px',
].join('; ');

const axisCell = (active: boolean) =>
  [
    reset,
    sans,
    'text-align: center',
    'font-size: 10.5px',
    'font-weight: ' + (active ? '700' : '500'),
    'letter-spacing: 0.02em',
    'line-height: 1.2',
    'color: ' + (active ? 'var(--sl-color-text)' : 'var(--sl-color-gray-3)'),
  ].join('; ');

const axisLabel = [
  reset,
  sans,
  'display: flex',
  'align-items: center',
  'justify-content: flex-end',
  'gap: 5px',
  'font-size: 10px',
  'font-weight: 600',
  'letter-spacing: 0.03em',
  'text-transform: uppercase',
  'color: var(--sl-color-gray-3)',
].join('; ');

// Which time columns are "live" this frame (drives the bold axis caption).
const liveCols = new Set<number>([
  ...frame.urgent.map((b) => b.col),
  ...frame.transition.map((b) => b.col),
]);

const lanes: { title: string; sub: string; accent: string; blocks: Block[] }[] = [
  {
    title: 'Urgent',
    sub: 'the <input>',
    accent: URGENT,
    blocks: frame.urgent,
  },
  {
    title: 'Transition',
    sub: 'the <SlowList>',
    accent: TRANS,
    blocks: frame.transition,
  },
];
---

<div class="not-content" style={root}>
  {
    lanes.map((lane) => (
      <div style={laneRow}>
        <div style={laneTag(lane.accent)}>
          <span style={laneTagTitle(lane.accent)}>{lane.title}</span>
          <span style={laneTagSub} set:html={lane.sub.replace('<', '&lt;')} />
        </div>
        <div style={track}>
          {lane.blocks.map((b) => (
            <div style={cellStyle(lane.accent, b.state, b.col)}>
              <span style={chip(lane.accent, b.state)}>{CHIP_LABEL[b.state]}</span>
              <span style={`${reset}; ${mono}; line-height: 1.15;`} set:html={b.label.replace(/</g, '&lt;')} />
              {b.state === 'discarded' && <span style={strike(lane.accent)} aria-hidden="true" />}
            </div>
          ))}
        </div>
      </div>
    ))
  }

  {/* Time axis — anchors the three moments under the lanes */}
  <div style={axisRow}>
    <div style={axisLabel}>
      <span style={`${reset}; line-height: 1.2;`}>user</span>
    </div>
    <div style={axisCols}>
      {COLS.map((c) => (
        <span style={axisCell(liveCols.has(c.key))}>{c.label}</span>
      ))}
    </div>
  </div>
</div>
