---
// The reconnect storm (diagram id: reconnect-storm, Chapter 025 L3). A four-step
// scrubbable DiagramSequence that makes the cost of putting non-reactive values
// (onMessage, currentUser) in an effect's deps literally visible: three of the
// four reconnects are pure waste, only the last is a real room change.
//
// Every step is the SAME shape so the grid stack never reflows as the reader
// scrubs:
//   - a trigger banner ("what just happened") at the top
//   - a "ChatRoom" box (centered) with its roomId prop
//   - a short down-wire into a full-width "Socket" strip
//   - a one-line verdict under the strip
//
// The Socket strip is where the teardown/rebuild becomes visible. A healthy
// connection is a single GREEN "connected" pill (step 1). A reconnect is a
// left-to-right chain RED "disconnect" -> AMBER "reconnecting" -> GREEN
// "connected", so even a static panel shows the socket being torn down and
// rebuilt at a glance. The strip spans the full card width so the chain always
// stays on one horizontal line. Steps 2 and 3 end on the SAME room ("general")
// to drive home "same room, brand-new connection"; step 4 ends on a DIFFERENT
// room ("random") — the one reconnect we actually wanted.
//
// Style follows this chapter-arc's StaleFrameSequence: fixed slate ink,
// color-scheme pinned light so the hand-picked red/amber/green tints survive
// dark mode, `margin: 0` on every inner element to defeat Starlight's injected
// prose margins. Every step is the same fixed shape so the grid stack holds a
// constant height as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary chip surface
const BORDER = '#cbd5e1'; // ordinary chip edge (slate-300)
const STRIP_BG = '#f8fafc'; // the Socket strip wash (slate-50)
const WIRE = '#94a3b8'; // the connection wire (slate-400)

const GREEN = '#16a34a'; // green-600 — connected
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const AMBER = '#d97706'; // amber-600 — reconnecting
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const RED = '#dc2626'; // red-600 — disconnecting
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const BLUE = '#2563eb'; // blue-600 — the calm "mounted" trigger
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

type Tone = 'wasted' | 'wanted' | 'calm';
type State = 'connected' | 'reconnecting' | 'disconnect';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all four steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The trigger banner: a full-width strip naming the thing that just happened to
// the mounted component. 'wasted' paints it red (a reconnect nobody asked for);
// 'wanted' paints it green (a real room change); 'calm' paints it blue (mount).
const triggerBanner = (tone: Tone) => {
	const [edge, bg, ink] =
		tone === 'wasted' ? [RED, RED_BG, RED_INK] : tone === 'wanted' ? [GREEN, GREEN_BG, GREEN_INK] : [BLUE, BLUE_BG, BLUE_INK];
	return `display: flex; align-items: center; gap: 8px; margin: 0; padding: 8px 12px; width: 100%; max-width: 520px; border: 1px solid ${edge}; border-left-width: 4px; border-radius: 8px; background: ${bg}; color: ${ink}; font-size: 12.5px; font-weight: 600; line-height: 1.3;`;
};
const triggerEyebrow = (tone: Tone) => {
	const ink = tone === 'wasted' ? RED : tone === 'wanted' ? GREEN : BLUE;
	return `flex: 0 0 auto; margin: 0; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: ${ink};`;
};
const monoTag = `font-family: ${mono}; font-weight: 700;`;

// The ChatRoom box: a component card whose roomId prop is shown.
const chatBox = `display: flex; flex-direction: column; align-items: center; gap: 3px; margin: 0; padding: 9px 16px; border: 1.5px solid ${BORDER}; border-radius: 10px; background: ${SURFACE}; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);`;
const chatTitle = `margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 700; color: ${INK};`;
const chatProp = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; color: ${INK_SOFT};`;
const chatRoomName = (changed: boolean) => `color: ${changed ? GREEN_INK : INK}; font-weight: 700;`;
const chatNote = (changed: boolean) => `color: ${changed ? GREEN_INK : INK_SOFT}; font-weight: 600;`;

// The short vertical wire joining the ChatRoom box to the Socket strip.
const downWire = `width: 2px; height: 14px; margin: 0; background: ${WIRE};`;

// The full-width Socket strip. It always spans the card so the reconnect chain
// stays on one horizontal line. A fixed min-height lets the calm single-pill
// step match the taller 3-pill chain steps without reflow.
const socketStrip = `display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: nowrap; margin: 0; padding: 12px; width: 100%; min-height: 60px; border: 1px solid ${BORDER}; border-radius: 12px; background: ${STRIP_BG};`;
const socketLabel = `flex: 0 0 auto; margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;

// A single state pill. `state` selects the color triad.
const pill = (state: State) => {
	const [edge, bg, ink] =
		state === 'connected' ? [GREEN, GREEN_BG, GREEN_INK] : state === 'reconnecting' ? [AMBER, AMBER_BG, AMBER_INK] : [RED, RED_BG, RED_INK];
	return `display: inline-flex; align-items: center; gap: 5px; flex: 0 0 auto; margin: 0; padding: 6px 11px; border: 1.5px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 11.5px; font-weight: 700; line-height: 1.2; white-space: nowrap;`;
};
// The status dot inside a pill.
const dot = (state: State) => {
	const c = state === 'connected' ? GREEN : state === 'reconnecting' ? AMBER : RED;
	return `display: inline-block; flex: 0 0 auto; width: 7px; height: 7px; margin: 0; border-radius: 50%; background: ${c};`;
};
// The arrow between pills in the reconnect chain.
const chainArrow = `flex: 0 0 auto; margin: 0; font-family: ${sans}; font-size: 13px; font-weight: 800; color: ${INK_SOFT};`;

// The one-line verdict under the strip. `tone` picks the ink.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.35; color: ${tone}; max-width: 460px; text-align: center; min-height: 16px;`;
---

<DiagramSequence>
	{/* ---- Step 1: Mount. The socket connects to general. Calm. ---- */}
	<DiagramStep caption="Setup runs once. The socket connects to general. So far so good.">
		<div style={stage}>
			<div style={triggerBanner('calm')}>
				<span style={triggerEyebrow('calm')}>mount</span>
				<span>Component mounted, deps captured for the first time</span>
			</div>
			<div style={chatBox}>
				<span style={chatTitle}>&lt;ChatRoom /&gt;</span>
				<span style={chatProp}>roomId: <span style={chatRoomName(false)}>"general"</span></span>
			</div>
			<div style={downWire} aria-hidden="true"></div>
			<div style={socketStrip}>
				<span style={socketLabel}>socket</span>
				<span style={pill('connected')}>
					<span style={dot('connected')} aria-hidden="true"></span>
					connected to general
				</span>
			</div>
			<p style={verdict(INK_SOFT)}>One connection, exactly as asked. Nothing has re-run yet.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Unrelated parent re-render -> new onMessage -> reconnect ---- */}
	<DiagramStep caption="The parent typed in some other input and re-rendered. onMessage got a fresh identity, the deps changed, and the socket tore down and rebuilt — to the very same room. One keystroke killed a healthy connection.">
		<div style={stage}>
			<div style={triggerBanner('wasted')}>
				<span style={triggerEyebrow('wasted')}>wasted</span>
				<span>Parent re-rendered &rarr; new <code style={monoTag}>onMessage</code> identity</span>
			</div>
			<div style={chatBox}>
				<span style={chatTitle}>&lt;ChatRoom /&gt;</span>
				<span style={chatProp}>roomId: <span style={chatRoomName(false)}>"general"</span> <span style={chatNote(false)}>(unchanged)</span></span>
			</div>
			<div style={downWire} aria-hidden="true"></div>
			<div style={socketStrip}>
				<span style={socketLabel}>socket</span>
				<span style={pill('disconnect')}>
					<span style={dot('disconnect')} aria-hidden="true"></span>
					disconnect general
				</span>
				<span style={chainArrow} aria-hidden="true">&rarr;</span>
				<span style={pill('reconnecting')}>
					<span style={dot('reconnecting')} aria-hidden="true"></span>
					reconnecting&hellip;
				</span>
				<span style={chainArrow} aria-hidden="true">&rarr;</span>
				<span style={pill('connected')}>
					<span style={dot('connected')} aria-hidden="true"></span>
					connected to general
				</span>
			</div>
			<p style={verdict(RED_INK)}>Same room, brand-new connection. The room never changed &mdash; this teardown bought nothing.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: currentUser changes (avatar loads) -> reconnect ---- */}
	<DiagramStep caption="A field on currentUser changed and dropped the socket too. Changing who you are shouldn't disconnect your chat.">
		<div style={stage}>
			<div style={triggerBanner('wasted')}>
				<span style={triggerEyebrow('wasted')}>wasted</span>
				<span><code style={monoTag}>currentUser</code> changed (avatar finished loading)</span>
			</div>
			<div style={chatBox}>
				<span style={chatTitle}>&lt;ChatRoom /&gt;</span>
				<span style={chatProp}>roomId: <span style={chatRoomName(false)}>"general"</span> <span style={chatNote(false)}>(unchanged)</span></span>
			</div>
			<div style={downWire} aria-hidden="true"></div>
			<div style={socketStrip}>
				<span style={socketLabel}>socket</span>
				<span style={pill('disconnect')}>
					<span style={dot('disconnect')} aria-hidden="true"></span>
					disconnect general
				</span>
				<span style={chainArrow} aria-hidden="true">&rarr;</span>
				<span style={pill('reconnecting')}>
					<span style={dot('reconnecting')} aria-hidden="true"></span>
					reconnecting&hellip;
				</span>
				<span style={chainArrow} aria-hidden="true">&rarr;</span>
				<span style={pill('connected')}>
					<span style={dot('connected')} aria-hidden="true"></span>
					connected to general
				</span>
			</div>
			<p style={verdict(RED_INK)}>A profile field moved, so the socket dropped &mdash; still the very same room.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 4: roomId actually changes -> the ONE reconnect we wanted ---- */}
	<DiagramStep caption="Only this last reconnect was the one we wanted — a real room change, a real re-sync. The other three were pure waste.">
		<div style={stage}>
			<div style={triggerBanner('wanted')}>
				<span style={triggerEyebrow('wanted')}>wanted</span>
				<span>roomId changed: <code style={monoTag}>"general" &rarr; "random"</code></span>
			</div>
			<div style={chatBox}>
				<span style={chatTitle}>&lt;ChatRoom /&gt;</span>
				<span style={chatProp}>roomId: <span style={chatRoomName(true)}>"random"</span> <span style={chatNote(true)}>(new room)</span></span>
			</div>
			<div style={downWire} aria-hidden="true"></div>
			<div style={socketStrip}>
				<span style={socketLabel}>socket</span>
				<span style={pill('disconnect')}>
					<span style={dot('disconnect')} aria-hidden="true"></span>
					disconnect general
				</span>
				<span style={chainArrow} aria-hidden="true">&rarr;</span>
				<span style={pill('reconnecting')}>
					<span style={dot('reconnecting')} aria-hidden="true"></span>
					reconnecting&hellip;
				</span>
				<span style={chainArrow} aria-hidden="true">&rarr;</span>
				<span style={pill('connected')}>
					<span style={dot('connected')} aria-hidden="true"></span>
					connected to random
				</span>
			</div>
			<p style={verdict(GREEN_INK)}>A genuine room change &mdash; the destination really is different. This is the only reconnect that earned its keep.</p>
		</div>
	</DiagramStep>
</DiagramSequence>
