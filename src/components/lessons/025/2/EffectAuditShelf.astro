---
// effect-audit-shelf — Chapter 025 Lesson 2, "useEffect as synchronization".
//
// A static, glanceable "sorting shelf" the student can picture: the 2026
// narrowing of useEffect, shown as two columns side by side.
//
//   ┌ Moved away from effects (6) ┐   ┌ Stays in useEffect (3) ┐
//   │ task ──→ its new home        │   │ bold case + example     │
//   │ …six dimmed rows…            │   │ …three green rows…      │
//   └──────────────────────────────┘   └─────────────────────────┘
//
// This is NOT the decision tree (that's lesson 4) — it's a visual summary, a
// mental shelf. The LEFT column is deliberately muted (struck-through task
// labels, gray chrome) to read as "this work has moved out". The RIGHT column
// carries the "keep" signal in saturated green (a left-edge accent + tint),
// so the three residual cases pop against the six that left. A count badge in
// each heading makes "six left, three stayed" legible at a glance.
//
// Plain HTML + CSS, inline styles only, devtools-inspectable — matches the
// chapter's other figures (ReactRightsPanel / StaleFrameSequence): a
// `not-content` wrapper, a `margin: 0` reset on every inner node to defeat
// Starlight's prose-margin selector, theme-aware Starlight gray variables for
// the muted chrome, and a saturated green-600 (reads in light + dark) where
// the color carries the "this stays" signal. No graph engine — per the diagram
// index, a static annotated summary is plain HTML+CSS.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--sl-font-system-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

const KEEP = "#16a34a"; // green-600 — "stays in useEffect", reads in both themes

// LEFT column — the six jobs that moved out of effects. `task` is the work
// (struck through, dimmed); `home` is where it lives in 2026.
const moved = [
  { task: "Initial page data", home: "Server Component / route loader" },
  { task: "Cached server state", home: "TanStack Query / use()" },
  { task: "URL state", home: "nuqs / useSearchParams" },
  { task: "Form submission", home: "Server Actions + useActionState" },
  { task: "Derived value", home: "compute in render" },
  { task: "Reset on prop change", home: "key reset" },
];

// RIGHT column — the three residual cases. `title` is the shape; `example`
// names the concrete APIs so the case isn't abstract.
const stays = [
  {
    title: "Non-React subscriptions",
    example: "WebSocket · EventSource · BroadcastChannel",
  },
  {
    title: "Widgets that take a DOM node",
    example: "chart · map · Stripe Elements",
  },
  {
    title: "Browser APIs React doesn't model",
    example: "IntersectionObserver · ResizeObserver · matchMedia",
  },
];

// ---- styles -------------------------------------------------------------

// Two columns side by side; wrap so the right column drops below the left on a
// narrow figure card instead of overflowing. min-width:0 lets each shrink.
const root = [
  reset,
  sans,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "gap: 16px",
  "width: 100%",
  "max-width: 760px",
  "margin: 0 auto",
  "box-sizing: border-box",
].join("; ");

// A column card. `accent` paints the green "keep" treatment; otherwise muted.
const column = (accent: boolean) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "flex: 1 1 300px",
    "min-width: 0",
    "border-radius: 12px",
    "box-sizing: border-box",
    "overflow: hidden",
    accent
      ? "border: 1px solid " + KEEP
      : "border: 1px solid var(--sl-color-gray-5)",
    accent
      ? "background: color-mix(in srgb, " + KEEP + " 9%, transparent)"
      : "background: var(--sl-color-gray-6, rgba(0,0,0,0.025))",
  ].join("; ");

// Column heading bar: a title + a count badge.
const headBar = (accent: boolean) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "gap: 8px",
    "padding: 9px 12px",
    "box-sizing: border-box",
    accent
      ? "border-bottom: 1px solid color-mix(in srgb, " + KEEP + " 35%, transparent)"
      : "border-bottom: 1px solid var(--sl-color-gray-5)",
    accent
      ? "background: color-mix(in srgb, " + KEEP + " 13%, transparent)"
      : "background: transparent",
  ].join("; ");

const headIcon = (accent: boolean) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "flex: none",
    "width: 24px",
    "height: 24px",
    "border-radius: 6px",
    accent
      ? "background: " + KEEP
      : "background: var(--sl-color-gray-5)",
    accent ? "color: #ffffff" : "color: var(--sl-color-gray-2)",
  ].join("; ");

const headText = (accent: boolean) =>
  [
    reset,
    sans,
    "flex: 1 1 auto",
    "min-width: 0",
    "font-size: 13.5px",
    "font-weight: 700",
    "line-height: 1.2",
    accent ? "color: " + KEEP : "color: var(--sl-color-gray-2)",
  ].join("; ");

// The "6" / "3" count badge in each heading.
const countBadge = (accent: boolean) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "flex: none",
    "min-width: 20px",
    "height: 20px",
    "padding: 0 6px",
    "border-radius: 999px",
    "font-size: 12px",
    "font-weight: 700",
    "line-height: 1",
    accent
      ? "background: " + KEEP + "; color: #ffffff"
      : "background: var(--sl-color-gray-5); color: var(--sl-color-gray-1)",
  ].join("; ");

// The list body inside each column.
const list = [
  reset,
  "display: flex",
  "flex-direction: column",
  "padding: 4px 0",
].join("; ");

// ---- LEFT rows: task ──→ home -------------------------------------------

const movedRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: baseline",
  "gap: 4px 7px",
  "padding: 6px 12px",
  "box-sizing: border-box",
].join("; ");

// The task label — struck through + dimmed, to read as "this left effects".
const taskText = [
  reset,
  sans,
  "flex: none",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.25",
  "text-decoration: line-through",
  "text-decoration-thickness: 1px",
  "color: var(--sl-color-gray-3)",
].join("; ");

const arrowText = [
  reset,
  sans,
  "flex: none",
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1.25",
  "color: var(--sl-color-gray-4)",
].join("; ");

// The "new home" — the live tool the work moved to. Monospace so the API names
// read as code without the Starlight inline-<code> pill quirks.
const homeText = [
  reset,
  mono,
  "flex: 1 1 auto",
  "min-width: 0",
  "font-size: 12px",
  "font-weight: 500",
  "line-height: 1.25",
  "color: var(--sl-color-gray-2)",
].join("; ");

// ---- RIGHT rows: title + example ----------------------------------------

const staysRow = [
  reset,
  "display: flex",
  "align-items: flex-start",
  "gap: 9px",
  "padding: 9px 12px",
  "box-sizing: border-box",
].join("; ");

// A small filled check at the start of each kept row.
const checkDot = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "flex: none",
  "width: 18px",
  "height: 18px",
  "margin-top: 1px",
  "border-radius: 999px",
  "background: " + KEEP,
  "color: #ffffff",
].join("; ");

const staysTextWrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 2px",
  "min-width: 0",
].join("; ");

const staysTitle = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const staysExample = [
  reset,
  mono,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Shared SVG attrs for the heading glyphs.
const iconAttrs = {
  width: "15",
  height: "15",
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "2",
  "stroke-linecap": "round" as const,
  "stroke-linejoin": "round" as const,
  "aria-hidden": "true",
  style: "margin: 0; display: block;",
};
---

<div class="not-content" style={root}>
  {/* LEFT — the six jobs that moved out of effects (muted, struck through) */}
  <div style={column(false)}>
    <div style={headBar(false)}>
      <span style={headIcon(false)}>
        {/* archive / moved-out box */}
        <svg {...iconAttrs}>
          <rect x="3" y="4" width="18" height="4" rx="1" />
          <path d="M5 8v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V8" />
          <line x1="10" y1="12" x2="14" y2="12" />
        </svg>
      </span>
      <span style={headText(false)}>Moved away from effects</span>
      <span style={countBadge(false)}>6</span>
    </div>
    <div style={list}>
      {
        moved.map((m) => (
          <div style={movedRow}>
            <span style={taskText}>{m.task}</span>
            <span style={arrowText} aria-hidden="true">
              &rarr;
            </span>
            <span style={homeText}>{m.home}</span>
          </div>
        ))
      }
    </div>
  </div>

  {/* RIGHT — the three residual cases that stay (green accent) */}
  <div style={column(true)}>
    <div style={headBar(true)}>
      <span style={headIcon(true)}>
        {/* plug / live connection */}
        <svg {...iconAttrs}>
          <path d="M9 2v6" />
          <path d="M15 2v6" />
          <path d="M7 8h10v3a5 5 0 0 1-10 0V8Z" />
          <path d="M12 16v6" />
        </svg>
      </span>
      <span style={headText(true)}>Stays in useEffect</span>
      <span style={countBadge(true)}>3</span>
    </div>
    <div style={list}>
      {
        stays.map((s) => (
          <div style={staysRow}>
            <span style={checkDot}>
              <svg
                width="11"
                height="11"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#ffffff"
                stroke-width="3.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                style="margin: 0; display: block;"
              >
                <polyline points="4 12 10 18 20 6" />
              </svg>
            </span>
            <span style={staysTextWrap}>
              <span style={staysTitle}>{s.title}</span>
              <span style={staysExample}>{s.example}</span>
            </span>
          </div>
        ))
      }
    </div>
  </div>
</div>
