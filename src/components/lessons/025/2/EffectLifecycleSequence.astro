---
// The effect lifecycle as synchronization (diagram id: effect-lifecycle-sequence,
// Chapter 025 L2). THE most important visual in the lesson. A five-step scrubbable
// DiagramSequence that makes the one timing fact every beginner gets wrong literally
// visible: cleanup runs BETWEEN syncs, not only on unmount.
//
// The spine is a single chat component synchronizing a socket to the current room.
// Every step is the SAME fixed shape so the grid stack never reflows as the reader
// scrubs:
//   - a phase banner at the top naming the lifecycle event (SETUP / RENDER / CLEANUP
//     / SETUP / CLEANUP), color-coded so the run of banners alone tells the story:
//     green setup, grey skipped render, red cleanup, green setup, red cleanup.
//   - a horizontal two-box motif: a "Component" card on the LEFT showing its roomId,
//     a connection line in the MIDDLE, and a "Server (room)" card on the RIGHT.
//   - a one-line verdict under the row.
//
// The CONNECTION LINE is where the lifecycle becomes visible:
//   - live      a continuous GREEN bar with a centered "connected" tag — the world
//               matches the current render.
//   - idle      a continuous GREY bar with a "skipped" tag — still connected, but the
//               effect did NOT re-run (deps equal by Object.is). This is the beat that
//               teaches "re-renders alone don't re-run effects".
//   - severed   two stubs with a gap and a centered RED ✕ — the old sync being torn
//               down. Cleanup. The Server card greys out.
//   - none      no bar at all — nothing is left open after unmount.
//
// roomId is tinted BLUE when it changes (echoing the lesson's "blue = the dep that
// triggers resync" convention from the AnnotatedCode walkthrough). On unmount the
// Component card itself goes dashed/dim to read as "gone".
//
// Style follows this chapter-arc's ReconnectStorm / StaleFrameSequence: fixed slate
// ink, color-scheme pinned light so the hand-picked red/green/grey tints survive dark
// mode, `margin: 0` on every inner element to defeat Starlight's injected prose
// margins. The two-box row caps its own height so all five steps line up. Per the
// diagram index this is a temporal sequence the reader scrubs — a DiagramSequence —
// and the panels are plain HTML+CSS.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary card edge (slate-300)
const DIM_BG = '#f1f5f9'; // a greyed / closed card wash (slate-100)
const DIM_INK = '#94a3b8'; // greyed card ink (slate-400)

const GREEN = '#16a34a'; // green-600 — live / setup
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const RED = '#dc2626'; // red-600 — cleanup / severed
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800

const BLUE = '#2563eb'; // blue-600 — the roomId dep that triggers resync
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const GREY = '#94a3b8'; // slate-400 — the idle / skipped wire
const GREY_BG = '#f1f5f9'; // slate-100

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

type Phase = 'setup' | 'render' | 'cleanup';
type Line = 'live' | 'idle' | 'severed' | 'none';

// Outer stage shared by every step: pinned light, slate ink, centered column so all
// five steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The phase banner: a full-width strip naming the lifecycle event. Its color triad is
// the story — green setup, red cleanup, grey skipped render — so scanning the banners
// alone shows cleanup landing BETWEEN the two setups.
const phaseTriad = (phase: Phase, skipped: boolean): [string, string, string] => {
	if (phase === 'cleanup') return [RED, RED_BG, RED_INK];
	if (phase === 'setup') return [GREEN, GREEN_BG, GREEN_INK];
	return skipped ? [GREY, GREY_BG, INK_SOFT] : [BLUE, BLUE_BG, BLUE_INK];
};
const banner = (phase: Phase, skipped = false) => {
	const [edge, bg, ink] = phaseTriad(phase, skipped);
	return `display: flex; align-items: center; gap: 9px; margin: 0; padding: 8px 12px; width: 100%; max-width: 540px; box-sizing: border-box; border: 1px solid ${edge}; border-left-width: 4px; border-radius: 8px; background: ${bg}; color: ${ink}; font-size: 12.5px; font-weight: 600; line-height: 1.3;`;
};
const bannerEyebrow = (phase: Phase, skipped = false) => {
	const ink = phaseTriad(phase, skipped)[0];
	return `flex: 0 0 auto; margin: 0; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: ${ink};`;
};
const monoTag = `font-family: ${mono}; font-weight: 700;`;

// The two-box row: Component — line — Server, on one horizontal line. A fixed
// min-height holds the row constant across steps.
const row = `display: flex; align-items: center; justify-content: center; gap: 0; margin: 0; width: 100%; max-width: 540px; min-height: 84px;`;

// A card (Component or Server). `state` paints it live (green edge), severed/closing
// (red edge, fading), gone (dashed dim), or plain.
type CardState = 'live' | 'closing' | 'gone' | 'plain';
const card = (state: CardState) => {
	const base = `display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 0 0 auto; box-sizing: border-box; width: 132px; margin: 0; padding: 11px 12px; border-radius: 12px; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);`;
	if (state === 'live') return `${base} border: 1.5px solid ${GREEN}; background: ${SURFACE};`;
	if (state === 'closing') return `${base} border: 1.5px solid ${RED}; background: ${SURFACE}; opacity: 0.92;`;
	if (state === 'gone') return `${base} border: 1.5px dashed ${DIM_INK}; background: ${DIM_BG}; opacity: 0.7;`;
	return `${base} border: 1.5px solid ${BORDER}; background: ${SURFACE};`;
};
const cardEyebrow = (muted: boolean) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${muted ? DIM_INK : INK_SOFT};`;
const cardTitle = (muted: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 700; line-height: 1.15; color: ${muted ? DIM_INK : INK};`;
// The roomId line on the Component card; tinted blue when the dep just changed.
const cardProp = (muted: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${muted ? DIM_INK : INK_SOFT};`;
const roomVal = (changed: boolean, muted: boolean) =>
	`font-weight: 700; color: ${muted ? DIM_INK : changed ? BLUE_INK : INK};`;

// The server-room name pill inside the Server card.
const roomPill = (state: 'live' | 'closing' | 'gone') => {
	const [edge, bg, ink] =
		state === 'live' ? [GREEN, GREEN_BG, GREEN_INK] : state === 'closing' ? [RED, RED_BG, RED_INK] : [DIM_INK, DIM_BG, DIM_INK];
	return `display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 3px 9px; border: 1.5px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${mono}; font-size: 11.5px; font-weight: 700; line-height: 1.2; white-space: nowrap;`;
};
const dot = (state: 'live' | 'closing' | 'gone') => {
	const c = state === 'live' ? GREEN : state === 'closing' ? RED : DIM_INK;
	return `display: inline-block; flex: 0 0 auto; width: 7px; height: 7px; margin: 0; border-radius: 50%; background: ${c};`;
};

// --- the connection line, the centerpiece -----------------------------------
// A fixed-width middle column so every step's row is the same width. Inside sits the
// wire + its centered status tag.
const lineWrap = `display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; flex: 1 1 auto; min-width: 0; align-self: center; padding: 0 4px; box-sizing: border-box;`;

// A continuous wire (live = green, idle = grey). A subtle gradient gives it a sense of
// flow without animation.
const solidWire = (live: boolean) => {
	const c = live ? GREEN : GREY;
	return `width: 100%; height: 3px; margin: 0; border-radius: 2px; background: ${c};`;
};
// The severed wire: two stubs with a gap in the middle (the ✕ goes in the gap).
const stubsWrap = `display: flex; align-items: center; justify-content: center; gap: 7px; width: 100%; margin: 0;`;
const stub = `flex: 1 1 auto; height: 3px; margin: 0; border-radius: 2px; background: ${RED};`;
const cutMark = `display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 20px; height: 20px; margin: 0; border-radius: 999px; background: ${RED_BG}; border: 1.5px solid ${RED}; color: ${RED_INK}; font-size: 12px; font-weight: 900; line-height: 1;`;
// A bare gap for the unmount step — no wire at all, just air between the dim cards.
const noWire = `width: 100%; height: 3px; margin: 0; border-radius: 2px; background: repeating-linear-gradient(90deg, ${BORDER} 0 4px, transparent 4px 9px); opacity: 0.6;`;

// The status tag sitting on the wire.
const wireTag = (kind: Line) => {
	const [bg, ink, edge] =
		kind === 'live'
			? [GREEN_BG, GREEN_INK, GREEN]
			: kind === 'idle'
				? [GREY_BG, INK_SOFT, GREY]
				: kind === 'severed'
					? [RED_BG, RED_INK, RED]
					: [DIM_BG, DIM_INK, BORDER];
	return `display: inline-flex; align-items: center; margin: 0; padding: 2px 9px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.3; white-space: nowrap;`;
};

// A small "render pulse" badge that rides on the Component card in step 2, marking
// that a render happened even though the effect was skipped.
const pulseBadge = `display: inline-flex; align-items: center; gap: 4px; margin: 0; padding: 1px 7px; border: 1px solid ${GREY}; border-radius: 999px; background: ${SURFACE}; color: ${INK_SOFT}; font-family: ${sans}; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.4; white-space: nowrap;`;

// The one-line verdict under the row. `tone` picks the ink.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.4; color: ${tone}; max-width: 500px; text-align: center; min-height: 16px;`;
---

<DiagramSequence>
	{/* ---- Step 1: Mount. Setup runs, the socket connects to general. ---- */}
	<DiagramStep caption="Setup runs. The connection to general opens — the outside world now matches the first render.">
		<div style={stage}>
			<div style={banner('setup')}>
				<span style={bannerEyebrow('setup')}>setup</span>
				<span>Mount &mdash; setup runs for the first time</span>
			</div>
			<div style={row}>
				<div style={card('live')}>
					<span style={cardEyebrow(false)}>component</span>
					<span style={cardTitle(false)}>&lt;ChatRoom /&gt;</span>
					<span style={cardProp(false)}>roomId: <span style={roomVal(false, false)}>"general"</span></span>
				</div>
				<div style={lineWrap}>
					<span style={wireTag('live')}>connected</span>
					<div style={solidWire(true)}></div>
				</div>
				<div style={card('live')}>
					<span style={cardEyebrow(false)}>server</span>
					<span style={roomPill('live')}>
						<span style={dot('live')} aria-hidden="true"></span>
						general
					</span>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>One connection, exactly as the first render asked. The socket is live in <strong>general</strong>.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: A re-render where roomId is unchanged — effect is skipped. ---- */}
	<DiagramStep caption="A re-render where roomId is the same. The deps are equal by Object.is, so the effect is skipped — nothing reconnects. Re-renders alone don't re-run effects.">
		<div style={stage}>
			<div style={banner('render', true)}>
				<span style={bannerEyebrow('render', true)}>render</span>
				<span>Re-render &mdash; <code style={monoTag}>roomId</code> unchanged, deps equal by <code style={monoTag}>Object.is</code></span>
			</div>
			<div style={row}>
				<div style={card('live')}>
					<span style={cardEyebrow(false)}>component</span>
					<span style={cardTitle(false)}>&lt;ChatRoom /&gt;</span>
					<span style={cardProp(false)}>roomId: <span style={roomVal(false, false)}>"general"</span></span>
					<span style={pulseBadge}>re-rendered</span>
				</div>
				<div style={lineWrap}>
					<span style={wireTag('idle')}>effect skipped</span>
					<div style={solidWire(false)}></div>
				</div>
				<div style={card('live')}>
					<span style={cardEyebrow(false)}>server</span>
					<span style={roomPill('live')}>
						<span style={dot('live')} aria-hidden="true"></span>
						general
					</span>
				</div>
			</div>
			<p style={verdict(INK_SOFT)}>The component re-rendered, but the dependency didn't move &mdash; so the same connection stays untouched.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: roomId changes — cleanup fires FIRST. ---- */}
	<DiagramStep caption="roomId changed, so the old sync is stale. Cleanup runs first: disconnect from general. The old setup is torn down before the new one is built.">
		<div style={stage}>
			<div style={banner('cleanup')}>
				<span style={bannerEyebrow('cleanup')}>cleanup</span>
				<span><code style={monoTag}>roomId</code> changed &mdash; cleanup runs <strong>first</strong></span>
			</div>
			<div style={row}>
				<div style={card('plain')}>
					<span style={cardEyebrow(false)}>component</span>
					<span style={cardTitle(false)}>&lt;ChatRoom /&gt;</span>
					<span style={cardProp(false)}>roomId: <span style={roomVal(true, false)}>"random"</span></span>
				</div>
				<div style={lineWrap}>
					<span style={wireTag('severed')}>disconnect general</span>
					<div style={stubsWrap}>
						<span style={stub}></span>
						<span style={cutMark} aria-hidden="true">&times;</span>
						<span style={stub}></span>
					</div>
				</div>
				<div style={card('closing')}>
					<span style={cardEyebrow(true)}>server</span>
					<span style={roomPill('closing')}>
						<span style={dot('closing')} aria-hidden="true"></span>
						general
					</span>
				</div>
			</div>
			<p style={verdict(RED_INK)}>The room changed to <strong>random</strong>, so the <strong>general</strong> connection is stale. It is closed <em>before</em> anything new opens.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Setup runs again — connect to random. ---- */}
	<DiagramStep caption="Then setup runs: connect to random. The outside world matches the current render again.">
		<div style={stage}>
			<div style={banner('setup')}>
				<span style={bannerEyebrow('setup')}>setup</span>
				<span>Setup runs again &mdash; connect to the new room</span>
			</div>
			<div style={row}>
				<div style={card('live')}>
					<span style={cardEyebrow(false)}>component</span>
					<span style={cardTitle(false)}>&lt;ChatRoom /&gt;</span>
					<span style={cardProp(false)}>roomId: <span style={roomVal(true, false)}>"random"</span></span>
				</div>
				<div style={lineWrap}>
					<span style={wireTag('live')}>connected</span>
					<div style={solidWire(true)}></div>
				</div>
				<div style={card('live')}>
					<span style={cardEyebrow(false)}>server</span>
					<span style={roomPill('live')}>
						<span style={dot('live')} aria-hidden="true"></span>
						random
					</span>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>A fresh connection opens to <strong>random</strong>. The world matches the current render once more.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 5: Unmount — the same cleanup runs one last time. ---- */}
	<DiagramStep caption="The panel closes. The same cleanup that runs between syncs runs one last time on unmount: disconnect from random. Nothing is left open.">
		<div style={stage}>
			<div style={banner('cleanup')}>
				<span style={bannerEyebrow('cleanup')}>cleanup</span>
				<span>Unmount &mdash; the <strong>same</strong> cleanup runs one last time</span>
			</div>
			<div style={row}>
				<div style={card('gone')}>
					<span style={cardEyebrow(true)}>component</span>
					<span style={cardTitle(true)}>&lt;ChatRoom /&gt;</span>
					<span style={cardProp(true)}>unmounted</span>
				</div>
				<div style={lineWrap}>
					<span style={wireTag('none')}>nothing open</span>
					<div style={noWire}></div>
				</div>
				<div style={card('gone')}>
					<span style={cardEyebrow(true)}>server</span>
					<span style={roomPill('gone')}>
						<span style={dot('gone')} aria-hidden="true"></span>
						closed
					</span>
				</div>
			</div>
			<p style={verdict(INK_SOFT)}>Closing the panel fires the very same cleanup &mdash; the one that also runs between syncs. No socket is left dangling.</p>
		</div>
	</DiagramStep>
</DiagramSequence>
