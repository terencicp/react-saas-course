---
// Strict-Mode interval-leak sequence (diagram id: strict-mode-interval-leak,
// Chapter 025 L1). A four-step scrubbable DiagramSequence walking the dev
// FIRST-MOUNT of an interval effect that has NO cleanup. Strict Mode compresses
// a full mount -> unmount -> mount into the initial render, so the lifecycle
// runs setup #1 -> cleanup -> setup #2. With no cleanup written, the cleanup
// phase is a no-op, the first interval is never torn down, and setup #2 stacks a
// second one. The payoff: two live timers, so `tick` logs twice per second.
//
//   Step 1  setup #1   setInterval registers timer A. Live timers: 1 (red — it
//                        has no cleanup guarding it, but it is the only one yet).
//   Step 2  cleanup    nothing is written to run here, so timer A survives. A
//                        ghost `clearInterval` shows where the fix would have
//                        fired. Live timers: 1, flagged as a leak.
//   Step 3  setup #2   a SECOND setInterval registers timer B. Both A and B are
//                        live. Live timers: 2 — two intervals tick in parallel.
//   Step 4  result     the console shows `tick` twice per second; the doubling
//                        is the symptom, the leak the disease underneath.
//
// Style follows this Unit's KeyChangeRemountSequence: a fixed slate palette,
// color-scheme pinned light so the hand-picked accents survive dark mode, and
// `margin: 0` on every inner element to defeat Starlight's injected prose
// margins. Every step is the same shape — a phase rail on top, the line of code
// running this phase, then a "Live timers" panel below — and the panel reserves
// the height of the tallest content (two timer chips / two console lines) so the
// grid stack never reflows as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary chip surface
const BORDER = '#cbd5e1'; // ordinary chip edge (slate-300)
const PANEL_BG = '#f1f5f9'; // panel wash (slate-100)
const PANEL_BORDER = '#cbd5e1'; // panel edge (slate-300)
const RAIL_IDLE_BG = '#e2e8f0'; // dormant phase pill (slate-200)

const RED = '#dc2626'; // red-600 — a live timer with no cleanup (the leak)
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800
const AMBER = '#d97706'; // amber-600 — the missing-cleanup phase
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800
const GREEN = '#16a34a'; // green-600 — where a real cleanup would fire
const GREEN_INK = '#166534'; // green-800
const BLUE = '#0ea5e9'; // sky-500 — the active "setup" phase

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all four steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The mount -> unmount -> mount phase rail. Three pills (setup / cleanup /
// setup) joined by arrows; the pill for the current phase is lit.
const rail = `display: flex; align-items: center; justify-content: center; gap: 8px; margin: 0; flex-wrap: nowrap;`;
const railPill = (active: boolean, accent: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 5px 12px; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.2; border-radius: 999px; white-space: nowrap; box-sizing: border-box; transition: opacity 180ms ease, transform 180ms ease;` +
	(active
		? ` color: ${ink}; background: ${bg}; border: 1.5px solid ${accent}; box-shadow: 0 0 0 3px color-mix(in srgb, ${accent} 16%, transparent); transform: translateY(-1px); opacity: 1;`
		: ` color: ${INK_SOFT}; background: ${RAIL_IDLE_BG}; border: 1.5px solid transparent; opacity: 0.5;`);
// The small numbered disc inside an active phase pill, tinted by the phase accent.
const railStep = (accent: string) =>
	`display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 15px; height: 15px; margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 800; color: #ffffff; background: ${accent}; border-radius: 50%;`;
const railArrow = `margin: 0; font-family: ${sans}; font-size: 14px; font-weight: 700; line-height: 1; color: ${INK_SOFT}; opacity: 0.5; flex: 0 0 auto;`;

// The line of code that runs in this phase, shown as an editor-ish strip.
const codeStrip = (accent: string) =>
	`display: flex; align-items: center; gap: 10px; margin: 0; padding: 9px 13px; width: 100%; max-width: 380px; box-sizing: border-box; border: 1px solid ${accent}; border-left: 3px solid ${accent}; border-radius: 8px; background: ${SURFACE};`;
const codeTag = (accent: string, ink: string, bg: string) =>
	`display: inline-block; flex: 0 0 auto; margin: 0; padding: 2px 7px; font-family: ${sans}; font-size: 9px; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; color: ${ink}; background: ${bg}; border: 1px solid color-mix(in srgb, ${accent} 45%, transparent); border-radius: 5px; white-space: nowrap;`;
const codeText = (struck = false) =>
	`margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 600; line-height: 1.3; color: ${INK}; white-space: nowrap;${struck ? ` text-decoration: line-through; color: ${INK_SOFT}; opacity: 0.75;` : ''}`;

// The "Live timers" panel below the code. Header carries the running count;
// the body reserves the height of the tallest content (two timer chips).
const panel = `display: flex; flex-direction: column; gap: 9px; margin: 0; padding: 11px 12px; width: 100%; max-width: 380px; box-sizing: border-box; border: 1px solid ${PANEL_BORDER}; border-radius: 12px; background: ${PANEL_BG};`;
const panelHead = `display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 0;`;
const panelLabel = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;
const countBadge = (accent: string, ink: string, bg: string) =>
	`display: inline-flex; align-items: center; gap: 7px; margin: 0; padding: 3px 10px; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2; color: ${ink}; background: ${bg}; border: 1px solid ${accent}; border-radius: 7px; white-space: nowrap;`;
const countNum = (accent: string) =>
	`display: inline-flex; align-items: center; justify-content: center; min-width: 18px; height: 18px; padding: 0 4px; margin: 0; font-size: 12px; font-weight: 800; color: #ffffff; background: ${accent}; border-radius: 5px;`;
// The body region holds the timer chips (or console). A fixed min-height keeps
// every step the same height: two stacked chips set the ceiling.
const panelBody = `display: flex; flex-direction: column; gap: 7px; margin: 0; min-height: 84px;`;

// A single timer chip representing one registered setInterval.
const timerChip = (accent: string, ink: string, bg: string, faded = false) =>
	`display: flex; align-items: center; gap: 9px; margin: 0; padding: 8px 11px; border: 1.5px solid ${accent}; border-radius: 9px; background: ${bg};${faded ? ' opacity: 0.55;' : ''}`;
const timerDot = (accent: string, ring = false) =>
	`flex: 0 0 auto; width: 9px; height: 9px; margin: 0; border-radius: 50%; background: ${accent};${ring ? ` box-shadow: 0 0 0 3px color-mix(in srgb, ${accent} 22%, transparent);` : ''}`;
const timerName = (ink: string) =>
	`margin: 0; flex: 0 0 auto; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2; color: ${ink}; white-space: nowrap;`;
const timerMeta = (ink: string) =>
	`margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${ink}; opacity: 0.85; white-space: nowrap;`;
const timerStatus = (accent: string, ink: string, bg: string) =>
	`display: inline-block; flex: 0 0 auto; margin: 0 0 0 auto; padding: 2px 7px; font-family: ${sans}; font-size: 9px; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: ${ink}; background: ${bg}; border: 1px solid color-mix(in srgb, ${accent} 45%, transparent); border-radius: 5px; white-space: nowrap;`;

// An empty-slot placeholder, used in the cleanup step to show "where a cleanup
// would have torn timer A down" without changing the panel's height.
const ghostSlot = `display: flex; align-items: center; gap: 9px; margin: 0; padding: 8px 11px; border: 1.5px dashed color-mix(in srgb, ${GREEN} 55%, transparent); border-radius: 9px; background: color-mix(in srgb, ${GREEN} 7%, transparent);`;
const ghostText = `margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 600; line-height: 1.3; color: ${GREEN_INK}; text-decoration: line-through; opacity: 0.85; white-space: nowrap;`;

// The console panel (step 4) — same footprint as the timer panel body.
const consoleBox = `display: flex; flex-direction: column; gap: 5px; margin: 0; padding: 9px 11px; border: 1px solid ${BORDER}; border-radius: 9px; background: #0f172a;`;
const consoleLine = `display: flex; align-items: baseline; gap: 9px; margin: 0; font-family: ${mono}; font-size: 12.5px; line-height: 1.4;`;
const consoleArrow = `margin: 0; color: ${RED}; font-weight: 800; flex: 0 0 auto;`;
const consoleText = `margin: 0; color: #e2e8f0; font-weight: 600;`;
const consoleStamp = `margin: 0 0 0 auto; color: #64748b; font-size: 10.5px; flex: 0 0 auto;`;
const consoleNote = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT}; text-align: center;`;
---

<DiagramSequence>
	{/* ---- Step 1: setup #1 — first interval registers, one timer live ---- */}
	<DiagramStep caption="Setup #1 runs. setInterval registers a timer. Live timers: 1 — but nothing yet guards it, because no cleanup was written.">

		<div style={stage}>
			<div style={rail}>
				<span style={railPill(true, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>
					<span style={railStep(BLUE)}>1</span>setup
				</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(false, AMBER, AMBER_BG, AMBER_INK)}>cleanup</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(false, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>setup</span>
			</div>

			<div style={codeStrip(BLUE)}>
				<span style={codeTag(BLUE, INK, `color-mix(in srgb, ${BLUE} 14%, transparent)`)}>runs</span>
				<code style={codeText()}>const id = setInterval(tick, 1000)</code>
			</div>

			<div style={panel}>
				<div style={panelHead}>
					<span style={panelLabel}>Live timers</span>
					<span style={countBadge(RED, RED_INK, RED_BG)}>
						<span style={countNum(RED)}>1</span> ticking
					</span>
				</div>
				<div style={panelBody}>
					<div style={timerChip(RED, RED_INK, SURFACE)}>
						<span style={timerDot(RED, true)}></span>
						<span style={timerName(INK)}>timer&nbsp;A</span>
						<span style={timerMeta(INK)}>every 1000ms</span>
						<span style={timerStatus(RED, RED_INK, RED_BG)}>no cleanup</span>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: cleanup — nothing written runs, timer A leaks ---- */}
	<DiagramStep caption="Cleanup runs. But there is no cleanup written, so nothing is torn down — timer A is still alive. With a cleanup, this is exactly where clearInterval would have fired.">

		<div style={stage}>
			<div style={rail}>
				<span style={railPill(false, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>
					<span style={railStep(BLUE)}>1</span>setup
				</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(true, AMBER, AMBER_BG, AMBER_INK)}>
					<span style={railStep(AMBER)}>2</span>cleanup
				</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(false, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>setup</span>
			</div>

			<div style={codeStrip(AMBER)}>
				<span style={codeTag(AMBER, AMBER_INK, AMBER_BG)}>nothing runs</span>
				<code style={codeText(true)}>return () =&gt; clearInterval(id)</code>
			</div>

			<div style={panel}>
				<div style={panelHead}>
					<span style={panelLabel}>Live timers</span>
					<span style={countBadge(RED, RED_INK, RED_BG)}>
						<span style={countNum(RED)}>1</span> still ticking
					</span>
				</div>
				<div style={panelBody}>
					<div style={timerChip(RED, RED_INK, SURFACE)}>
						<span style={timerDot(RED, true)}></span>
						<span style={timerName(INK)}>timer&nbsp;A</span>
						<span style={timerMeta(INK)}>every 1000ms</span>
						<span style={timerStatus(RED, RED_INK, RED_BG)}>still live</span>
					</div>
					<div style={ghostSlot}>
						<span style={`${timerDot(GREEN)} opacity: 0.55;`}></span>
						<code style={ghostText}>clearInterval(id)</code>
						<span style={timerStatus(GREEN, GREEN_INK, `color-mix(in srgb, ${GREEN} 12%, transparent)`)}>where the fix goes</span>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: setup #2 — a second interval stacks, two timers live ---- */}
	<DiagramStep caption="Setup #2 runs. A second setInterval registers. Live timers: 2 — two intervals now tick in parallel.">

		<div style={stage}>
			<div style={rail}>
				<span style={railPill(false, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>
					<span style={railStep(BLUE)}>1</span>setup
				</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(false, AMBER, AMBER_BG, AMBER_INK)}>cleanup</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(true, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>
					<span style={railStep(BLUE)}>2</span>setup
				</span>
			</div>

			<div style={codeStrip(BLUE)}>
				<span style={codeTag(BLUE, INK, `color-mix(in srgb, ${BLUE} 14%, transparent)`)}>runs again</span>
				<code style={codeText()}>const id = setInterval(tick, 1000)</code>
			</div>

			<div style={panel}>
				<div style={panelHead}>
					<span style={panelLabel}>Live timers</span>
					<span style={countBadge(RED, RED_INK, RED_BG)}>
						<span style={countNum(RED)}>2</span> ticking in parallel
					</span>
				</div>
				<div style={panelBody}>
					<div style={timerChip(RED, RED_INK, SURFACE, true)}>
						<span style={timerDot(RED, true)}></span>
						<span style={timerName(INK)}>timer&nbsp;A</span>
						<span style={timerMeta(INK)}>every 1000ms</span>
						<span style={timerStatus(RED, RED_INK, RED_BG)}>still live</span>
					</div>
					<div style={timerChip(RED, RED_INK, SURFACE)}>
						<span style={timerDot(RED, true)}></span>
						<span style={timerName(INK)}>timer&nbsp;B</span>
						<span style={timerMeta(INK)}>every 1000ms</span>
						<span style={timerStatus(RED, RED_INK, RED_BG)}>new, stacked</span>
					</div>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 4: result — two timers, so `tick` logs twice per second ---- */}
	<DiagramStep caption="The result: the tick logs twice per second. The doubling is the symptom you see; the leak is the disease underneath. A guard that hid the second tick would still leave one timer that never stops.">

		<div style={stage}>
			<div style={rail}>
				<span style={railPill(false, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>setup</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(false, AMBER, AMBER_BG, AMBER_INK)}>cleanup</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(false, BLUE, `color-mix(in srgb, ${BLUE} 18%, transparent)`, INK)}>setup</span>
				<span style={railArrow} aria-hidden="true">&rarr;</span>
				<span style={railPill(true, RED, RED_BG, RED_INK)}>
					<span style={railStep(RED)}>!</span>result
				</span>
			</div>

			<div style={codeStrip(RED)}>
				<span style={codeTag(RED, RED_INK, RED_BG)}>each tick</span>
				<code style={codeText()}>console.log('tick')</code>
			</div>

			<div style={panel}>
				<div style={panelHead}>
					<span style={panelLabel}>Console &mdash; one second</span>
					<span style={countBadge(RED, RED_INK, RED_BG)}>
						<span style={countNum(RED)}>2&times;</span> per second
					</span>
				</div>
				<div style={panelBody}>
					<div style={consoleBox}>
						<p style={consoleLine}>
							<span style={consoleArrow}>&rsaquo;</span><span style={consoleText}>tick</span><span style={consoleStamp}>timer&nbsp;A</span>
						</p>
						<p style={consoleLine}>
							<span style={consoleArrow}>&rsaquo;</span><span style={consoleText}>tick</span><span style={consoleStamp}>timer&nbsp;B</span>
						</p>
					</div>
					<p style={consoleNote}>The doubling is the symptom you see; the leak is the disease underneath.</p>
				</div>
			</div>
		</div>
	</DiagramStep>

</DiagramSequence>
