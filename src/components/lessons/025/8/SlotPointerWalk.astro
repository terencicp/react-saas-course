---
// Slot-pointer walk (diagram id: slot-pointer-walk, Chapter 025 L8). A five-step
// scrubbable DiagramSequence that makes React's hidden call-order pointer
// VISIBLE — the mechanic the whole "rules of hooks" lesson rests on.
//
// The component under inspection never changes (a fixed code card at the top of
// every step). What moves is the pointer and the slots:
//   - three slot cells in a horizontal row (Slot 0 / 1 / 2) — ordinal identity
//   - a pointer marker beneath the row that advances one slot per hook call
//   - the source line that fires on this step is highlighted, tying "this call"
//     to "this slot"
//
// Slot states drive the story:
//   empty   not yet claimed            (dashed outline, dim)
//   filled  claimed on an earlier step (solid, calm)
//   active  claimed on THIS step       (tinted accent, the focus)
//   matched render 2 re-found its slot (green, "the slot remembered")
//
// Steps 1-4 are Render 1: the pointer starts at 0 and walks the three calls,
// claiming one slot each. Step 5 is Render 2: the same walk re-runs, every call
// lands on the slot it claimed last time and reads its own value back — the
// whole row goes green to say "same hooks, same order, each found its slot".
//
// Style mirrors this chapter's sibling figures (InterruptResumeFrame,
// StaleFrameSequence): pinned light color-scheme so the hand-picked tints
// survive dark mode, fixed slate ink, `margin: 0` on every inner element to
// defeat Starlight's injected prose margins, one fixed shape per step so the
// grid stack never reflows as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — secondary text
const BORDER = '#cbd5e1'; // slate-300 — calm edges
const DIM_INK = '#94a3b8'; // slate-400 — empty-slot ink
const CARD_BG = '#f8fafc'; // slate-50  — the code card / stage wash

const BLUE = '#2563eb'; // blue-600  — the active slot + pointer accent
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const GREEN = '#16a34a'; // green-600 — render-2 "matched" accent
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// The component under inspection — the same five lines on every step. `line` is
// the index into this array that the active hook call sits on, so we can tint it.
const CODE_LINES = [
  { text: 'const Counter = () => {', indent: 0, hookLine: -1 },
  { text: 'const [count, setCount] = useState(0);', indent: 1, hookLine: 0 },
  { text: "const [draft, setDraft] = useState('');", indent: 1, hookLine: 1 },
  { text: 'useEffect(connectToServer);', indent: 1, hookLine: 2 },
  { text: '// ...', indent: 1, hookLine: -1 },
  { text: '};', indent: 0, hookLine: -1 },
] as const;

type SlotState = 'empty' | 'filled' | 'active' | 'matched';
type Slot = {
  hook: string; // hook name, shown once the slot is filled
  label: string; // the variable the call bound (count / draft / effect)
  value: string; // the stored value
  state: SlotState;
};

type Frame = {
  // The slots row, left to right. Always three entries so the row never reflows.
  slots: Slot[];
  // Where the pointer sits AFTER this step's narration (0..3). 3 = off the end.
  pointer: number;
  // Which source hookLine is firing this step (-1 = none, e.g. step 1 and 5).
  activeHookLine: number;
  // Render-2 frame paints the whole row green and the pointer green.
  matched: boolean;
};

// Shared slot definitions so values stay consistent across frames.
const COUNT = { hook: 'useState', label: 'count', value: '0' };
const DRAFT = { hook: 'useState', label: 'draft', value: "''" };
const EFFECT = { hook: 'useEffect', label: 'connectToServer', value: '↺' };

const empty: Slot = { hook: '', label: '', value: '', state: 'empty' };

const frames: Frame[] = [
  // 1 — Render 1 begins: array empty, pointer at 0, nothing claimed yet.
  {
    slots: [{ ...empty }, { ...empty }, { ...empty }],
    pointer: 0,
    activeHookLine: -1,
    matched: false,
  },
  // 2 — first call (useState count) claims slot 0; pointer advances to 1.
  {
    slots: [
      { ...COUNT, state: 'active' },
      { ...empty },
      { ...empty },
    ],
    pointer: 1,
    activeHookLine: 0,
    matched: false,
  },
  // 3 — second call (useState draft) claims slot 1; pointer advances to 2.
  {
    slots: [
      { ...COUNT, state: 'filled' },
      { ...DRAFT, state: 'active' },
      { ...empty },
    ],
    pointer: 2,
    activeHookLine: 1,
    matched: false,
  },
  // 4 — useEffect claims slot 2; pointer advances past the end. Walk done.
  {
    slots: [
      { ...COUNT, state: 'filled' },
      { ...DRAFT, state: 'filled' },
      { ...EFFECT, state: 'active' },
    ],
    pointer: 3,
    activeHookLine: 2,
    matched: false,
  },
  // 5 — Render 2: same walk, every call re-finds its slot. Row goes green; the
  //     counter has advanced to 1 to make "the slot remembered" concrete.
  {
    slots: [
      { ...COUNT, value: '1', state: 'matched' },
      { ...DRAFT, state: 'matched' },
      { ...EFFECT, state: 'matched' },
    ],
    pointer: 0,
    activeHookLine: -1,
    matched: true,
  },
];

const captions = [
  'Render 1 begins. The slot array is empty and the pointer sits at 0. React is about to walk the function top to bottom.',
  'The first hook call — useState(0) for count — claims slot 0. React stores 0 there and the pointer advances to 1.',
  "The second call — useState('') for draft — claims slot 1. The pointer advances to 2.",
  'The useEffect call claims slot 2. The pointer advances past the end and the walk is done. React recorded three hooks, in this exact order — and that order is all it knows.',
  'Render 2 runs the same walk: pointer back to 0, the same three calls in the same order. Each call lands on the slot it claimed last time and reads back its own stored value. count has advanced to 1 — the slot remembered.',
] as const;

// ---- styles ---------------------------------------------------------------

// Outer stage shared by every step — pinned light, centered column, fixed shape.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The fixed code card (the component under inspection). Same on every step.
const codeCard = `display: flex; flex-direction: column; gap: 1px; margin: 0; padding: 12px 14px; width: 100%; max-width: 440px; box-sizing: border-box; border: 1px solid ${BORDER}; border-radius: 10px; background: ${CARD_BG};`;
const codeLine = (active: boolean) =>
  `display: block; margin: 0; padding: 2px 6px; border-radius: 5px; font-family: ${mono}; font-size: 12.5px; line-height: 1.55; white-space: pre; color: ${active ? BLUE_INK : INK}; ` +
  (active
    ? `background: ${BLUE_BG}; box-shadow: inset 2px 0 0 ${BLUE};`
    : 'background: transparent;');

// The eyebrow above the slot row naming the render pass.
const passRow = `display: flex; align-items: center; gap: 8px; margin: 0;`;
const passTag = (matched: boolean) =>
  `display: inline-flex; align-items: center; margin: 0; padding: 2px 9px; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; border-radius: 999px; white-space: nowrap; ` +
  (matched
    ? `color: ${GREEN_INK}; background: ${GREEN_BG}; border: 1px solid ${GREEN};`
    : `color: ${BLUE_INK}; background: ${BLUE_BG}; border: 1px solid ${BLUE};`);
const passHint = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; color: ${INK_SOFT};`;

// The slot row + pointer track live in one fixed-width column so the pointer
// always sits dead under its slot.
const slotsWrap = `display: flex; flex-direction: column; gap: 8px; margin: 0; width: 100%; max-width: 440px;`;

// The three slot cells in a row.
const slotRow = `display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 0;`;

const slotCell = (s: SlotState) => {
  const base = `display: flex; flex-direction: column; align-items: center; justify-content: flex-start; gap: 4px; margin: 0; padding: 9px 8px 10px; border-radius: 9px; box-sizing: border-box; min-height: 78px; text-align: center;`;
  if (s === 'active')
    return `${base} border: 1.5px solid ${BLUE}; background: ${BLUE_BG}; box-shadow: 0 2px 8px rgba(37, 99, 235, 0.22);`;
  if (s === 'matched')
    return `${base} border: 1.5px solid ${GREEN}; background: ${GREEN_BG};`;
  if (s === 'filled')
    return `${base} border: 1px solid ${BORDER}; background: #ffffff;`;
  // empty
  return `${base} border: 1.5px dashed ${BORDER}; background: transparent;`;
};

// The "Slot N" index label at the top of each cell.
const slotIndex = (s: SlotState) => {
  const ink =
    s === 'active' ? BLUE : s === 'matched' ? GREEN : DIM_INK;
  return `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: ${ink};`;
};

// The hook name (e.g. useState) — only meaningful once the slot is filled.
const slotHook = (s: SlotState) => {
  const ink =
    s === 'active' ? BLUE_INK : s === 'matched' ? GREEN_INK : INK;
  return `margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.15; color: ${ink};`;
};

// The bound variable, smaller, under the hook name.
const slotLabel = `margin: 0; font-family: ${mono}; font-size: 10px; font-weight: 500; line-height: 1.1; color: ${INK_SOFT};`;

// The stored value pill at the bottom of a filled cell.
const slotValue = (s: SlotState) =>
  `display: inline-flex; align-items: center; margin: 0; padding: 1px 8px; border-radius: 999px; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.4; ` +
  (s === 'matched'
    ? `color: ${GREEN_INK}; background: #ffffff; border: 1px solid ${GREEN};`
    : `color: ${BLUE_INK}; background: #ffffff; border: 1px solid ${BORDER};`);

// The placeholder shown in an empty cell instead of a value.
const slotEmpty = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 600; letter-spacing: 0.03em; color: ${DIM_INK};`;

// The pointer track beneath the row: same 3 columns plus a 4th "off the end"
// position, so the marker can sit under slot 0..2 or past slot 2.
const pointerTrack = `display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 0; position: relative;`;
// One pointer cell. We render an arrow only under the pointer's current column;
// when the pointer is at 3 (off the end) it sits at the right edge, past slot 2.
const pointerCell = `display: flex; flex-direction: column; align-items: center; gap: 2px; margin: 0; min-height: 34px;`;
const pointerCaret = (matched: boolean) =>
  `margin: 0; font-family: ${sans}; font-size: 15px; font-weight: 800; line-height: 1; color: ${matched ? GREEN : BLUE};`;
const pointerLabel = (matched: boolean) =>
  `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; letter-spacing: 0.02em; white-space: nowrap; color: ${matched ? GREEN_INK : BLUE_INK};`;
// The "pointer → past the end" marker when the walk is done (pointer = 3).
const pointerEnd = `position: absolute; right: -2px; top: 0; display: flex; flex-direction: column; align-items: center; gap: 2px; margin: 0;`;

const SLOT_LABELS = ['Slot 0', 'Slot 1', 'Slot 2'] as const;
---

<DiagramSequence>
  {
    frames.map((frame, i) => (
      <DiagramStep caption={captions[i]}>
        <div style={stage}>
          {/* The component under inspection — fixed, only the active line tints */}
          <div style={codeCard} aria-label="The Counter component under inspection">
            {CODE_LINES.map((ln) => (
              <code
                style={`${codeLine(ln.hookLine === frame.activeHookLine && ln.hookLine !== -1)}; padding-left: ${6 + ln.indent * 16}px;`}
              >
                {ln.text}
              </code>
            ))}
          </div>

          {/* Which render pass this frame represents */}
          <div style={passRow}>
            <span style={passTag(frame.matched)}>
              {frame.matched ? 'Render 2' : 'Render 1'}
            </span>
            <span style={passHint}>
              {frame.matched
                ? 'same calls, same order'
                : `pointer at ${frame.pointer > 2 ? 'end' : frame.pointer}`}
            </span>
          </div>

          {/* The slot array + the pointer track underneath it */}
          <div style={slotsWrap}>
            <div style={slotRow}>
              {frame.slots.map((slot, k) => (
                <div style={slotCell(slot.state)}>
                  <span style={slotIndex(slot.state)}>{SLOT_LABELS[k]}</span>
                  {slot.state === 'empty' ? (
                    <span style={slotEmpty}>empty</span>
                  ) : (
                    <>
                      <span style={slotHook(slot.state)}>{slot.hook}</span>
                      <span style={slotLabel} set:html={slot.label.replace(/</g, '&lt;')} />
                      <span style={slotValue(slot.state)}>{slot.value}</span>
                    </>
                  )}
                </div>
              ))}
            </div>

            <div style={pointerTrack}>
              {[0, 1, 2].map((col) => (
                <div style={pointerCell}>
                  {frame.pointer === col && (
                    <>
                      <span style={pointerCaret(frame.matched)} aria-hidden="true">
                        &uarr;
                      </span>
                      <span style={pointerLabel(frame.matched)}>pointer</span>
                    </>
                  )}
                </div>
              ))}
              {frame.pointer === 3 && (
                <div style={pointerEnd}>
                  <span style={pointerCaret(false)} aria-hidden="true">
                    &uarr;
                  </span>
                  <span style={pointerLabel(false)}>pointer · done</span>
                </div>
              )}
            </div>
          </div>
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>
