---
// The use() suspend lifecycle (diagram id: use-suspend-lifecycle, Chapter 025
// L7). The payoff visual of the lesson: a five-step scrubbable DiagramSequence
// that makes the one thing juniors don't believe LITERALLY visible — the page
// never blocks. A slow server read streams into a Client Component through ONE
// Suspense boundary; the reader watches the boundary swap pending -> fallback ->
// resolved -> re-render -> data while the page shell sits there, interactive,
// the whole time.
//
// Fixed two-zone horizontal motif so the grid stack never reflows as the reader
// scrubs:
//   - LEFT  the PAGE SHELL — the dashboard chrome (a title bar, a couple of stat
//           blocks). It is IDENTICAL in all five steps and carries a green
//           "interactive" badge that never dims. That constancy IS the lesson:
//           nothing here ever waited.
//   - RIGHT the SUSPENSE BOUNDARY — an indigo-tinted card whose insides change
//           per step. Two stacked rows inside it:
//             (a) the SOURCE chip — the promise handed down from the server,
//                 amber "pending" then green "resolved".
//             (b) the boundary CONTENT — what <Suspense> is currently showing:
//                 the suspended child marker, the skeleton fallback, or the live
//                 ActivityPanel list.
//   - a one-line verdict under the row, fixed footprint.
//
// The five beats (suspend -> fallback -> resolve -> re-render -> data):
//   1  Server starts the read, returns immediately. Source = pending; the child
//      (ActivityPanel) is marked "suspended" — it stopped rendering. Shell is up.
//   2  React shows the fallback in the boundary's place. The skeleton fills the
//      content row. A pin on the shell says it did NOT wait.
//   3  ~few hundred ms later the promise resolves. Source flips to "resolved" and
//      the value streams across a short arrow tagged "RSC wire" toward the child.
//      The fallback is still on screen (the re-render hasn't happened yet).
//   4  React re-renders the suspended child. use(activityPromise) now RETURNS the
//      array instead of suspending — the content row swaps the skeleton for the
//      panel, headed by a "use() -> [...]" chip.
//   5  Fallback gone, the panel shows the three rows, the page never blocked.
//
// House style matches this chapter's EffectLifecycleSequence / InterruptResume
// and ch.023's SnapshotTimeline: fixed slate ink, color-scheme pinned light so
// the hand-picked amber/green/indigo tints survive dark mode, `margin: 0` on
// every inner element to defeat Starlight's injected prose margins. Per the
// diagram index this is a temporal sequence the reader scrubs — a
// DiagramSequence — and the panels are plain HTML+CSS.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary card edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)
const DIM_INK = '#94a3b8'; // greyed ink (slate-400)

const INDIGO = '#4f46e5'; // indigo-600 — the Suspense boundary accent
const INDIGO_SOFT = '#eef2ff'; // indigo-50 — boundary wash
const INDIGO_INK = '#3730a3'; // indigo-800 — boundary text

const GREEN = '#16a34a'; // green-600 — resolved / interactive / live
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const AMBER = '#d97706'; // amber-600 — the promise still in flight
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all five steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 13px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The two-zone row: [page shell] [suspense boundary]. `wrap` keeps it horizontal
// on a laptop and lets it stack only on a genuinely narrow viewport.
const row = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 12px; margin: 0; width: 100%; max-width: 620px;`;

// --- shared zone-card chrome -------------------------------------------------
const zoneBase = `box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; flex: 1 1 268px; min-width: 250px; min-height: 178px; margin: 0; padding: 11px 12px 12px; border-radius: 12px; background: ${SURFACE};`;
// The page shell: ordinary slate chrome, never changes.
const shellCard = `${zoneBase} border: 1.5px solid ${BORDER};`;
// The Suspense boundary: indigo dashed edge so it reads as "a wrapper", with a
// faint indigo wash.
const boundaryCard = `${zoneBase} border: 1.5px dashed ${INDIGO}; background: ${INDIGO_SOFT};`;

// The eyebrow header line of each zone — a tiny label + a status pill on the right.
const zoneHead = `display: flex; align-items: center; justify-content: space-between; gap: 8px; margin: 0;`;
const zoneEyebrow = (accent: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${accent};`;
// A small status pill (e.g. "interactive", "fallback", "rendered").
const pill = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 2px 8px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.3; white-space: nowrap;`;
const dot = (c: string) => `display: inline-block; flex: 0 0 auto; width: 6px; height: 6px; margin: 0; border-radius: 50%; background: ${c};`;

// --- page-shell internals (constant across all five steps) -------------------
const shellTitle = `margin: 0; font-family: ${sans}; font-size: 13px; font-weight: 700; line-height: 1.15; color: ${INK};`;
const statRow = `display: flex; gap: 8px; margin: 0;`;
const statBlock = `flex: 1 1 0; box-sizing: border-box; margin: 0; padding: 8px 9px; border-radius: 8px; background: ${PANEL_BG}; border: 1px solid ${BORDER};`;
const statLabel = `margin: 0 0 3px; font-family: ${sans}; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT};`;
const statValue = `margin: 0; font-family: ${mono}; font-size: 17px; font-weight: 800; line-height: 1; color: ${INK}; font-variant-numeric: tabular-nums;`;
// A faint "you can click this" hint so "interactive" reads as more than a word.
const shellHint = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 600; line-height: 1.35; color: ${INK_SOFT};`;

// --- the SOURCE chip (the promise from the server) ---------------------------
// Row (a) inside the boundary. A mono "getActivity()" call wired to a state pill.
const sourceWrap = `display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 9px; border-radius: 8px; background: ${SURFACE}; border: 1px solid ${BORDER};`;
const sourceCall = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${INK}; white-space: nowrap;`;
const sourceArrow = (c: string) => `flex: 0 0 auto; margin: 0; font-size: 13px; font-weight: 800; line-height: 1; color: ${c};`;
const promiseState = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; margin: 0 0 0 auto; padding: 2px 8px; border: 1px solid ${edge}; border-radius: 6px; background: ${bg}; color: ${ink}; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.25; white-space: nowrap;`;

// --- the boundary CONTENT region (row b) -------------------------------------
// A fixed-height frame so the content row is the same footprint whether it holds
// the suspended marker, the skeleton, or the live list.
const contentFrame = `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 6px; flex: 1 1 auto; min-height: 86px; margin: 0; padding: 9px 10px; border-radius: 8px; border: 1px dashed ${INDIGO}; background: ${SURFACE};`;
// A label naming what the boundary is currently showing.
const contentTag = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${ink};`;

// The "suspended child" marker (step 1): the component name, paused.
const suspendedRow = `display: flex; align-items: center; gap: 8px; margin: 0;`;
const suspendedName = `margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.2; color: ${DIM_INK};`;

// The skeleton fallback (steps 2 & 3): three grey shimmer bars of unequal width.
const skeletonStack = `display: flex; flex-direction: column; gap: 7px; margin: 0;`;
const skelBar = (w: string) =>
	`height: 9px; width: ${w}; margin: 0; border-radius: 999px; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;

// The live ActivityPanel (steps 4 & 5): a small <ul> of real rows.
const listHead = `display: flex; align-items: center; gap: 7px; margin: 0;`;
const useChip = `display: inline-flex; align-items: center; margin: 0; padding: 2px 8px; border: 1px solid ${GREEN}; border-radius: 6px; background: ${GREEN_BG}; color: ${GREEN_INK}; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.25; white-space: nowrap;`;
const list = `list-style: none; display: flex; flex-direction: column; gap: 4px; margin: 0; padding: 0;`;
const listItem = `display: flex; align-items: center; gap: 7px; margin: 0; padding: 4px 8px; border-radius: 6px; background: ${PANEL_BG}; border: 1px solid ${BORDER}; font-family: ${sans}; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${INK};`;
const itemDot = `display: inline-block; flex: 0 0 auto; width: 5px; height: 5px; margin: 0; border-radius: 50%; background: ${GREEN};`;

// The "RSC wire" delivery tag in step 3 — the resolved value crossing to the child.
const wireRow = `display: flex; align-items: center; gap: 7px; margin: 0;`;
const wireTag = `display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 2px 8px; border: 1px solid ${GREEN}; border-radius: 999px; background: ${GREEN_BG}; color: ${GREEN_INK}; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.3; white-space: nowrap;`;
const wireArrow = `flex: 0 0 auto; margin: 0; font-size: 14px; font-weight: 800; line-height: 1; color: ${GREEN};`;
const wireNote = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT};`;

// The one-line verdict under the row. `tone` picks the ink; fixed min-height so
// the footprint is stable across steps.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.4; color: ${tone}; max-width: 560px; text-align: center; min-height: 16px;`;
---

<DiagramSequence>
	{/* ---- Step 1: server starts the read, returns immediately; child suspends ---- */}
	<DiagramStep caption="The Server Component starts the read and returns immediately — it does not await. The promise is pending and the child (ActivityPanel) suspends, so it stops rendering.">
		<div style={stage}>
			<div style={row}>
				{/* page shell — constant across every step */}
				<div style={shellCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>page shell</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							interactive
						</span>
					</div>
					<p style={shellTitle}>Dashboard</p>
					<div style={statRow}>
						<div style={statBlock}>
							<p style={statLabel}>Revenue</p>
							<p style={statValue}>$48k</p>
						</div>
						<div style={statBlock}>
							<p style={statLabel}>Members</p>
							<p style={statValue}>312</p>
						</div>
					</div>
					<p style={shellHint}>Already painted &mdash; nav and stats respond to clicks.</p>
				</div>

				{/* suspense boundary */}
				<div style={boundaryCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INDIGO_INK)}>&lt;Suspense&gt; boundary</span>
						<span style={pill(INDIGO, '#ffffff', INDIGO_INK)}>child suspended</span>
					</div>
					<div style={sourceWrap}>
						<span style={sourceCall}>getActivity()</span>
						<span style={sourceArrow(AMBER)} aria-hidden="true">&rarr;</span>
						<span style={promiseState(AMBER, AMBER_BG, AMBER_INK)}>Promise (pending)</span>
					</div>
					<div style={contentFrame}>
						<p style={contentTag(INK_SOFT)}>showing</p>
						<div style={suspendedRow}>
							<span style={pill(BORDER, PANEL_BG, INK_SOFT)}>paused</span>
							<span style={suspendedName}>&lt;ActivityPanel /&gt;</span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(INK_SOFT)}>
				The server didn't wait, so the page is already up. Only the panel inside the boundary is paused.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: React shows the fallback; the rest of the page is interactive ---- */}
	<DiagramStep caption="React renders the fallback in the boundary's place. The skeleton fills the slot, and the rest of the page is already interactive — it never blocked on the slow read.">
		<div style={stage}>
			<div style={row}>
				<div style={shellCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>page shell</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							interactive
						</span>
					</div>
					<p style={shellTitle}>Dashboard</p>
					<div style={statRow}>
						<div style={statBlock}>
							<p style={statLabel}>Revenue</p>
							<p style={statValue}>$48k</p>
						</div>
						<div style={statBlock}>
							<p style={statLabel}>Members</p>
							<p style={statValue}>312</p>
						</div>
					</div>
					<p style={shellHint}><strong>Did not wait</strong> &mdash; usable while the panel loads.</p>
				</div>

				<div style={boundaryCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INDIGO_INK)}>&lt;Suspense&gt; boundary</span>
						<span style={pill(INDIGO, '#ffffff', INDIGO_INK)}>fallback</span>
					</div>
					<div style={sourceWrap}>
						<span style={sourceCall}>getActivity()</span>
						<span style={sourceArrow(AMBER)} aria-hidden="true">&rarr;</span>
						<span style={promiseState(AMBER, AMBER_BG, AMBER_INK)}>Promise (pending)</span>
					</div>
					<div style={contentFrame}>
						<p style={contentTag(INDIGO_INK)}>showing fallback &mdash; &lt;ActivitySkeleton /&gt;</p>
						<div style={skeletonStack}>
							<span style={skelBar('90%')}></span>
							<span style={skelBar('72%')}></span>
							<span style={skelBar('80%')}></span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(INDIGO_INK)}>
				The boundary shows its <code style={`font-family: ${mono}; font-weight: 700;`}>fallback</code> while the child waits. The shell around it stays live.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: promise resolves; the value streams over the RSC wire ---- */}
	<DiagramStep caption="A few hundred milliseconds later the promise resolves. React streams the resolved value to the client over the RSC wire. The fallback is still on screen — the re-render hasn't happened yet.">
		<div style={stage}>
			<div style={row}>
				<div style={shellCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>page shell</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							interactive
						</span>
					</div>
					<p style={shellTitle}>Dashboard</p>
					<div style={statRow}>
						<div style={statBlock}>
							<p style={statLabel}>Revenue</p>
							<p style={statValue}>$48k</p>
						</div>
						<div style={statBlock}>
							<p style={statLabel}>Members</p>
							<p style={statValue}>312</p>
						</div>
					</div>
					<p style={shellHint}>Unchanged &mdash; the read finished off to the side.</p>
				</div>

				<div style={boundaryCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INDIGO_INK)}>&lt;Suspense&gt; boundary</span>
						<span style={pill(INDIGO, '#ffffff', INDIGO_INK)}>fallback</span>
					</div>
					<div style={sourceWrap}>
						<span style={sourceCall}>getActivity()</span>
						<span style={sourceArrow(GREEN)} aria-hidden="true">&rarr;</span>
						<span style={promiseState(GREEN, GREEN_BG, GREEN_INK)}>Promise (resolved)</span>
					</div>
					<div style={contentFrame}>
						<div style={wireRow}>
							<span style={wireTag}>
								<span style={dot(GREEN)} aria-hidden="true"></span>
								RSC wire
							</span>
							<span style={wireArrow} aria-hidden="true">&rarr;</span>
							<span style={wireNote}>value streaming to the child</span>
						</div>
						<div style={skeletonStack}>
							<span style={skelBar('90%')}></span>
							<span style={skelBar('72%')}></span>
							<span style={skelBar('80%')}></span>
						</div>
					</div>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>
				The promise settled. Its value crosses the <strong>RSC wire</strong> &mdash; but the fallback is still showing until React re-renders.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 4: React re-renders the child; use() returns the array ---- */}
	<DiagramStep caption="React re-renders the suspended child. use(activityPromise) now returns the array instead of suspending, so the boundary swaps the fallback for the real ActivityPanel.">
		<div style={stage}>
			<div style={row}>
				<div style={shellCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>page shell</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							interactive
						</span>
					</div>
					<p style={shellTitle}>Dashboard</p>
					<div style={statRow}>
						<div style={statBlock}>
							<p style={statLabel}>Revenue</p>
							<p style={statValue}>$48k</p>
						</div>
						<div style={statBlock}>
							<p style={statLabel}>Members</p>
							<p style={statValue}>312</p>
						</div>
					</div>
					<p style={shellHint}>Still the same shell &mdash; it was never re-mounted.</p>
				</div>

				<div style={boundaryCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INDIGO_INK)}>&lt;Suspense&gt; boundary</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							re-rendering
						</span>
					</div>
					<div style={sourceWrap}>
						<span style={sourceCall}>getActivity()</span>
						<span style={sourceArrow(GREEN)} aria-hidden="true">&rarr;</span>
						<span style={promiseState(GREEN, GREEN_BG, GREEN_INK)}>Promise (resolved)</span>
					</div>
					<div style={contentFrame}>
						<div style={listHead}>
							<span style={contentTag(GREEN_INK)}>&lt;ActivityPanel /&gt;</span>
							<span style={useChip}>use() &rarr; [...]</span>
						</div>
						<ul style={list}>
							<li style={listItem}><span style={itemDot} aria-hidden="true"></span>Invited a teammate</li>
							<li style={listItem}><span style={itemDot} aria-hidden="true"></span>Created an invoice</li>
						</ul>
					</div>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>
				On this render <code style={`font-family: ${mono}; font-weight: 700;`}>use(activityPromise)</code> returns the array, so the panel renders in the fallback's place.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 5: the panel shows the data; the page never blocked ---- */}
	<DiagramStep caption="The fallback is gone, the panel shows the data, and the page never blocked. The shell was visible the entire time — the slow read only ever held up the one box that needed it.">
		<div style={stage}>
			<div style={row}>
				<div style={shellCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INK_SOFT)}>page shell</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							interactive
						</span>
					</div>
					<p style={shellTitle}>Dashboard</p>
					<div style={statRow}>
						<div style={statBlock}>
							<p style={statLabel}>Revenue</p>
							<p style={statValue}>$48k</p>
						</div>
						<div style={statBlock}>
							<p style={statLabel}>Members</p>
							<p style={statValue}>312</p>
						</div>
					</div>
					<p style={shellHint}>Visible the whole time &mdash; it never blocked.</p>
				</div>

				<div style={boundaryCard}>
					<div style={zoneHead}>
						<span style={zoneEyebrow(INDIGO_INK)}>&lt;Suspense&gt; boundary</span>
						<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>
							resolved
						</span>
					</div>
					<div style={sourceWrap}>
						<span style={sourceCall}>getActivity()</span>
						<span style={sourceArrow(GREEN)} aria-hidden="true">&rarr;</span>
						<span style={promiseState(GREEN, GREEN_BG, GREEN_INK)}>Promise (resolved)</span>
					</div>
					<div style={contentFrame}>
						<p style={contentTag(GREEN_INK)}>&lt;ActivityPanel /&gt; &mdash; live</p>
						<ul style={list}>
							<li style={listItem}><span style={itemDot} aria-hidden="true"></span>Invited a teammate</li>
							<li style={listItem}><span style={itemDot} aria-hidden="true"></span>Created an invoice</li>
							<li style={listItem}><span style={itemDot} aria-hidden="true"></span>Archived a project</li>
						</ul>
					</div>
				</div>
			</div>
			<p style={verdict(GREEN_INK)}>
				One boundary, one slow read &mdash; and the page was interactive from the first frame to the last.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
