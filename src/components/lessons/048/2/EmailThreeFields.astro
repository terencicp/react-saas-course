---
// email-three-fields — the opening disambiguation artifact of Lesson 48.2.
//
// One email message split into the THREE identity-bearing fields, laid out
// left-to-right so it reads as "three slots inside one message". This is the
// mental model the whole lesson hangs on: the field a human reads (visible
// From:) is NOT the field SPF checks, and NOT the field DKIM checks.
//
//   ┌─ One email message ─────────────────────────────────────────────┐
//   │  [SPF]            [DKIM]            ┊  [DMARC alignment]          │
//   │  Envelope         DKIM d= tag       ┊  Visible From:             │
//   │  MAIL FROM        d=send.yourapp…   ┊  YourApp <hello@…>         │
//   │  bounces@…        "altered? signer?"┊  "match the checks?"       │
//   │  "which server?"  …subtitle…        ┊  …subtitle…                │
//   └─────────────────────────────────────────────────────────────────┘
//
// No arrows (per the outline + the diagram index: an annotated illustration is
// plain HTML+CSS). Each field is a labelled card carrying: the protocol that
// OWNS it (a saturated colour tag), the field name, a tiny example value, the
// one-line question it answers, and a muted subtitle. The colour on each tag
// identifies the PROTOCOL — deliberately teal / violet / amber, NOT the
// green/red that the later alignment figure reuses for pass/fail, so the two
// colour stories never collide.
//
// Box 3 (visible From:) is set slightly apart — a dashed divider before it plus
// a tinted background — to drive home that the human-visible field is a FOURTH
// concern, distinct from the two fields SPF and DKIM each check.
//
// Pure HTML + CSS, devtools-inspectable per the html-css convention. A
// `not-content` wrapper + `margin: 0` reset on every node defeats Starlight's
// prose-margin selector; a <style> block carries the theme-keyed tints
// (color-mix on Starlight vars) and the wrap-don't-scroll responsive behaviour.
// Wrapped in <Figure> here so the caption travels with the component.

import Figure from "../../../figures/Figure.astro";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

// Per-protocol tag colours. Saturated mid-tones that read white-on-fill in both
// light and dark themes, and stay clear of the green/red pass/fail palette the
// alignment tabs use later in the lesson.
const SPF = "#0d9488"; // teal-600
const DKIM = "#7c3aed"; // violet-600
const DMARC = "#d97706"; // amber-600

const fields = [
  {
    key: "spf",
    color: SPF,
    owner: "SPF",
    name: "Envelope MAIL FROM",
    example: "bounces@send.yourapp.com",
    question: "Which server was allowed to send this?",
    sub: "The hidden return address the receiving server bounces failures to — the recipient never sees it.",
    apart: false,
  },
  {
    key: "dkim",
    color: DKIM,
    owner: "DKIM",
    name: "DKIM d= tag",
    example: "d=send.yourapp.com",
    question: "Was this message altered, and who signed it?",
    sub: "Stamped inside a signature header — invisible to the reader.",
    apart: false,
  },
  {
    key: "dmarc",
    color: DMARC,
    owner: "DMARC alignment",
    name: "Visible From:",
    example: "YourApp <hello@send.yourapp.com>",
    question: "Does the visible sender match the checks that passed?",
    sub: "The only field the human actually reads in their inbox.",
    apart: true,
  },
];
---

<Figure
  caption="One message, three identity fields — and they can each hold a different domain. SPF checks the envelope, DKIM checks its d= tag; neither is the From: line the human reads. The gap between them is what the rest of the lesson is about."
>
  <div class="etf-frame not-content" style={sans}>
    <span class="etf-legend" style={sans}>One email message</span>

    <div class="etf-row">
      {
        fields.map((f) => (
          <div
            class={f.apart ? "etf-card etf-card--apart" : "etf-card"}
            style={`--tag: ${f.color}`}
          >
            <span class="etf-tag" style={sans}>
              {f.owner}
            </span>

            <span class="etf-name" style={sans}>
              {f.name}
            </span>

            <code class="etf-example" style={mono}>
              {f.example}
            </code>

            <span class="etf-question" style={sans}>
              <span class="etf-q-label">Answers:</span>
              {f.question}
            </span>

            <span class="etf-sub" style={sans}>
              {f.sub}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</Figure>

<style define:vars={{ spf: SPF, dkim: DKIM, dmarc: DMARC }}>
  /* Outer frame = "one message". The legend pill straddles the top border so
     the three cards inside read as slots within a single envelope. */
  .etf-frame {
    margin: 1.4rem 0 0;
    position: relative;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 12px;
    padding: 22px 16px 16px;
    box-sizing: border-box;
  }

  .etf-legend {
    margin: 0;
    position: absolute;
    top: 0;
    left: 16px;
    transform: translateY(-50%);
    padding: 2px 10px;
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-2);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 999px;
  }

  /* Three field cards across, wrapping (never scrolling) on narrow viewports. */
  .etf-row {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    column-gap: 12px;
    row-gap: 14px;
  }

  .etf-card {
    margin: 0;
    flex: 1 1 220px;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 12px 13px 13px;
    border: 1px solid var(--sl-color-gray-5);
    border-top: 3px solid var(--tag);
    border-radius: 9px;
    background: var(--sl-color-bg);
    box-sizing: border-box;
  }

  /* Box 3 set apart: a tinted wash + a dashed divider before it, so the
     human-visible field reads as a distinct, fourth concern. */
  .etf-card--apart {
    background: color-mix(in srgb, var(--dmarc) 8%, var(--sl-color-bg));
    border-color: color-mix(in srgb, var(--dmarc) 35%, var(--sl-color-gray-5));
    position: relative;
  }
  .etf-card--apart::before {
    content: "";
    position: absolute;
    left: -7px;
    top: 4px;
    bottom: 4px;
    border-left: 2px dashed var(--sl-color-gray-4);
  }

  /* Protocol-owner tag — the colour that says "this field belongs to …". */
  .etf-tag {
    margin: 0;
    align-self: flex-start;
    padding: 2px 9px;
    border-radius: 6px;
    background: var(--tag);
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.4;
    white-space: nowrap;
  }

  .etf-name {
    margin: 0;
    font-size: 13.5px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-white);
  }

  .etf-example {
    margin: 0;
    align-self: flex-start;
    max-width: 100%;
    padding: 2px 7px;
    border-radius: 5px;
    background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
    color: var(--sl-color-text);
    font-size: 12px;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .etf-question {
    margin: 0;
    font-size: 12.5px;
    line-height: 1.35;
    color: var(--sl-color-text);
  }
  .etf-q-label {
    margin: 0 4px 0 0;
    font-weight: 700;
    color: var(--tag);
  }

  .etf-sub {
    margin: 0;
    font-size: 11.5px;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
  }

  /* On the narrowest viewports the dashed divider would float awkwardly above
     the stacked card — drop it and lean on the tint to set the card apart. */
  @media (max-width: 560px) {
    .etf-card--apart::before {
      display: none;
    }
  }
</style>
