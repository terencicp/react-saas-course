---
// dkim-sign-verify — the two-act mechanic of DKIM, scrubbed as a DiagramSequence.
//
// The non-obvious thing students miss: the PRIVATE key never leaves Resend, yet
// the PUBLIC key lives openly in YOUR DNS, and the receiver pulls it down at the
// moment of verification. So the figure is built around that asymmetry rather
// than a generic crypto cartoon.
//
//   Step 1 — Resend signs (send time):
//     [message] → [Resend MTA · 🔒 private key] → [message + DKIM-Signature]
//     the signature carries  s=resend  and  d=send.yourapp.com
//
//   Step 2 — receiver verifies (delivery time):
//     [receiver reads DKIM-Signature] ┄ fetch ┄ (DNS: resend._domainkey…→public key)
//        → [signature valid → DKIM pass]
//
// Label-only boxes per the outline (no dense prose inside). DiagramSequence
// supplies the outer card + per-step captions, so this is NOT wrapped in
// <Figure>. Pure HTML+CSS, devtools-inspectable. Colour language matches the
// lesson's opening EmailThreeFields figure: DKIM === violet (#7c3aed), used for
// the protocol accent; the pass verdict uses the same green the alignment tabs
// will reuse, kept off everything except the final "pass" so the colour reads
// unambiguously. A `not-content` wrapper + margin resets defeat Starlight's
// prose-margin selector.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const DKIM = "#7c3aed"; // violet-600 — the lesson's DKIM accent
const PASS = "#16a34a"; // green-600 — reserved for the final verdict only
---

<DiagramSequence>
  <DiagramStep caption="Resend hashes the chosen headers and body, signs the hash with the private key, and attaches the DKIM-Signature header. The private key never leaves Resend.">
    <div class="dsv not-content" style={sans}>
      <span class="dsv-phase" style={sans}>
        Step 1 — Resend signs · at send time
      </span>

      <div class="dsv-flow">
        <!-- the raw message -->
        <div class="dsv-box">
          <span class="dsv-box-label" style={sans}>Your message</span>
          <span class="dsv-box-sub" style={sans}>headers + body</span>
        </div>

        <span class="dsv-arrow" aria-hidden="true">
          <svg viewBox="0 0 40 16" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="2" y1="8" x2="32" y2="8"></line>
            <polyline points="26 3 33 8 26 13"></polyline>
          </svg>
        </span>

        <!-- the signer, holding the private key -->
        <div class="dsv-box dsv-box--actor">
          <span class="dsv-box-label" style={sans}>Resend's MTA</span>
          <span class="dsv-key dsv-key--private" style={sans}>
            <svg class="dsv-key-ico" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            private key
          </span>
          <span class="dsv-box-sub" style={sans}>kept secret · signs</span>
        </div>

        <span class="dsv-arrow" aria-hidden="true">
          <svg viewBox="0 0 40 16" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="2" y1="8" x2="32" y2="8"></line>
            <polyline points="26 3 33 8 26 13"></polyline>
          </svg>
        </span>

        <!-- the signed message -->
        <div class="dsv-box dsv-box--result">
          <span class="dsv-box-label" style={sans}>Signed message</span>
          <code class="dsv-sig" style={mono}>DKIM-Signature</code>
          <span class="dsv-tags" style={mono}>s=resend · d=send.yourapp.com</span>
        </div>
      </div>
    </div>
  </DiagramStep>

  <DiagramStep caption="The receiver reconstructs the location from the selector + d= domain, fetches the public key, and checks the signature. If anything in the signed content changed in transit, the check fails.">
    <div class="dsv not-content" style={sans}>
      <span class="dsv-phase" style={sans}>
        Step 2 — The receiver verifies · at delivery time
      </span>

      <div class="dsv-flow">
        <!-- the receiver reading the signature -->
        <div class="dsv-box dsv-box--actor">
          <span class="dsv-box-label" style={sans}>Receiving server</span>
          <code class="dsv-sig" style={mono}>reads DKIM-Signature</code>
          <span class="dsv-box-sub" style={sans}>selector + d= domain</span>
        </div>

        <!-- arrow-free DNS lookup callout -->
        <div class="dsv-fetch" aria-hidden="true">
          <span class="dsv-fetch-label" style={sans}>fetch</span>
          <span class="dsv-fetch-line"></span>
        </div>

        <!-- the DNS record returning the public key -->
        <div class="dsv-box dsv-box--dns">
          <span class="dsv-box-tag" style={sans}>DNS</span>
          <code class="dsv-dns-name" style={mono}>resend._domainkey.send.yourapp.com</code>
          <span class="dsv-key dsv-key--public" style={sans}>
            <svg class="dsv-key-ico" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2"></rect>
              <path d="M7 11V8a5 5 0 0 1 9.9-1"></path>
            </svg>
            public key
          </span>
          <span class="dsv-box-sub" style={sans}>published · anyone may read</span>
        </div>

        <span class="dsv-arrow" aria-hidden="true">
          <svg viewBox="0 0 40 16" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="2" y1="8" x2="32" y2="8"></line>
            <polyline points="26 3 33 8 26 13"></polyline>
          </svg>
        </span>

        <!-- the verdict -->
        <div class="dsv-box dsv-box--verdict">
          <span class="dsv-box-label" style={sans}>Signature valid</span>
          <span class="dsv-verdict-pill" style={sans}>
            <svg class="dsv-check" viewBox="0 0 16 16" fill="none"
              stroke="currentColor" stroke-width="2.4" stroke-linecap="round"
              stroke-linejoin="round" aria-hidden="true">
              <polyline points="3 8.5 6.5 12 13 4"></polyline>
            </svg>
            DKIM pass
          </span>
        </div>
      </div>
    </div>
  </DiagramStep>
</DiagramSequence>

<style define:vars={{ dkim: DKIM, pass: PASS }}>
  .dsv {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Phase banner — names which moment in time this step is. */
  .dsv-phase {
    margin: 0;
    align-self: flex-start;
    padding: 3px 11px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--dkim) 14%, var(--sl-color-bg));
    color: color-mix(in srgb, var(--dkim) 72%, var(--sl-color-white));
    border: 1px solid color-mix(in srgb, var(--dkim) 38%, transparent);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  /* The box flow: wraps (never scrolls) on narrow viewports. */
  .dsv-flow {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 10px;
  }

  .dsv-box {
    margin: 0;
    flex: 1 1 0;
    min-width: 150px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px 13px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 9px;
    background: var(--sl-color-bg);
    box-sizing: border-box;
  }

  /* Actors (the two servers) carry the DKIM accent on top. */
  .dsv-box--actor {
    border-top: 3px solid var(--dkim);
  }

  /* The signed-message result + the DNS record get a soft violet wash. */
  .dsv-box--result,
  .dsv-box--dns {
    background: color-mix(in srgb, var(--dkim) 7%, var(--sl-color-bg));
    border-color: color-mix(in srgb, var(--dkim) 30%, var(--sl-color-gray-5));
  }

  /* The verdict box leans on the pass-green, set apart from everything else. */
  .dsv-box--verdict {
    background: color-mix(in srgb, var(--pass) 9%, var(--sl-color-bg));
    border-color: color-mix(in srgb, var(--pass) 38%, var(--sl-color-gray-5));
  }

  .dsv-box-label {
    margin: 0;
    font-size: 13.5px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-white);
  }

  .dsv-box-sub {
    margin: 0;
    font-size: 11.5px;
    line-height: 1.35;
    color: var(--sl-color-gray-2);
  }

  /* Small uppercase tag that labels the DNS box. */
  .dsv-box-tag {
    margin: 0;
    align-self: flex-start;
    padding: 1px 8px;
    border-radius: 6px;
    background: var(--dkim);
    color: #ffffff;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.5;
  }

  /* Key chips — the heart of the figure. Private = solid violet (locked away),
     public = outlined (out in the open). */
  .dsv-key {
    margin: 0;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 9px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.5;
    white-space: nowrap;
  }
  .dsv-key-ico {
    width: 13px;
    height: 13px;
    flex: 0 0 auto;
  }
  .dsv-key--private {
    background: var(--dkim);
    color: #ffffff;
  }
  .dsv-key--public {
    background: transparent;
    color: color-mix(in srgb, var(--dkim) 78%, var(--sl-color-white));
    border: 1.5px dashed color-mix(in srgb, var(--dkim) 55%, transparent);
  }

  /* The DKIM-Signature header / read action, and the d=/s= tags. */
  .dsv-sig {
    margin: 0;
    align-self: flex-start;
    max-width: 100%;
    padding: 2px 7px;
    border-radius: 5px;
    background: color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
    color: var(--sl-color-text);
    font-size: 11.5px;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }
  .dsv-tags {
    margin: 0;
    font-size: 11px;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
    overflow-wrap: anywhere;
  }
  .dsv-dns-name {
    margin: 0;
    font-size: 11px;
    line-height: 1.4;
    color: var(--sl-color-text);
    overflow-wrap: anywhere;
  }

  /* Directional arrows between boxes. */
  .dsv-arrow {
    margin: 0;
    flex: 0 0 auto;
    align-self: center;
    display: inline-flex;
    color: var(--sl-color-gray-3);
  }
  .dsv-arrow svg {
    width: 34px;
    height: 14px;
  }

  /* Arrow-free "fetch" connector for the DNS lookup — a labelled dotted tie
     rather than a directional arrow, since the receiver pulls (a lookup), it
     isn't a message being sent. */
  .dsv-fetch {
    margin: 0;
    flex: 0 0 auto;
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    min-width: 52px;
  }
  .dsv-fetch-label {
    margin: 0;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
  }
  .dsv-fetch-line {
    margin: 0;
    width: 100%;
    border-top: 2px dotted var(--sl-color-gray-4);
  }

  /* The pass verdict pill. */
  .dsv-verdict-pill {
    margin: 0;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 11px;
    border-radius: 999px;
    background: var(--pass);
    color: #ffffff;
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.4;
  }
  .dsv-check {
    width: 14px;
    height: 14px;
    flex: 0 0 auto;
  }

  /* On the narrowest viewports the boxes stack; rotate the inline arrows so the
     flow still reads top-to-bottom, and let the fetch tie span full width. */
  @media (max-width: 540px) {
    .dsv-flow {
      flex-direction: column;
      align-items: stretch;
    }
    .dsv-arrow {
      align-self: center;
      transform: rotate(90deg);
    }
    .dsv-fetch {
      flex-direction: row;
      width: 100%;
      gap: 8px;
    }
    .dsv-fetch-line {
      flex: 1;
      border-top: 2px dotted var(--sl-color-gray-4);
    }
  }
</style>
