---
// dmarc-rollout-timeline — the none→quarantine→reject ramp as a horizontal
// phase strip. The pedagogical point the <Steps> prose can't show on its own is
// that the four stages form ONE deliberate de-risking ramp: each step tightens
// enforcement only after the previous one proved safe. So the figure is a left-
// to-right time axis of four fixed cells, with the RISK escalating in colour as
// the policy hardens — green (nothing at stake) → amber → orange → red (mail
// refused outright). The red endpoint deliberately echoes the lesson's
// AnnotatedCode, where p=reject is the one field flagged red as the dangerous
// dial.
//
// Each cell carries three things the outline asks for:
//   • the policy itself (mono, the literal record value)
//   • "at risk:"     — what enforcement can break at this stage
//   • "watching:"    — what the reports must show clean before advancing
//
//   none ──→ quarantine ──→ quarantine ──→ reject
//   pct: —        pct=10         pct=100
//   risk: none    small slice    all to spam    refused
//
// Chevron connectors between cells imply forward progression along the time
// axis (per the outline's "arrow or gradient implying forward progression").
//
// Plain HTML+CSS so the flex strip is devtools-inspectable; wrapped in <Figure>
// for the card chrome + caption. Palette matches the rest of the lesson
// (green #16a34a / red #dc2626 as the pass/fail poles, amber + orange between).
// `not-content` + margin:0 on every node defeats Starlight's prose-margin
// selector. Cells stack on narrow viewports with the chevrons rotated so the
// ramp still reads top-to-bottom.

import Figure from "../../../figures/Figure.astro";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

// Escalating-risk palette. The accent climbs from safe-green through amber and
// orange to danger-red as the policy hardens and more real mail is at stake.
const stages = [
  {
    step: "Stage 1",
    accent: "#16a34a", // green-600 — nothing at stake yet
    policy: "p=none",
    policySub: "monitor only",
    risk: "nothing — no mail is affected",
    watch: "discover every sender under your domain",
  },
  {
    step: "Stage 2",
    accent: "#ca8a04", // yellow-600 — a thin slice of mail now enforced
    policy: "p=quarantine",
    policySub: "pct=10",
    risk: "a small slice of failing mail goes to spam",
    watch: "any legitimate mail failing (false positives)",
  },
  {
    step: "Stage 3",
    accent: "#ea580c", // orange-600 — full quarantine coverage
    policy: "p=quarantine",
    policySub: "pct=100",
    risk: "all failing mail goes to spam",
    watch: "still no legitimate casualties at full coverage",
  },
  {
    step: "Stage 4",
    accent: "#dc2626", // red-600 — the destination; mail refused outright
    policy: "p=reject",
    policySub: "enforced",
    risk: "all failing mail is refused outright",
    watch: "steady state — spoofing now bounces",
  },
];
---

<Figure caption="The whole strip is one de-risking ramp: at every step you tighten only once the reports show the previous step caused no collateral damage. The accent climbs from green to red as more real mail comes under enforcement.">
  <div class="rt not-content" style={sans}>
    {
      stages.map((s, i) => (
        <>
          <div
            class="rt-cell"
            style={`--accent: ${s.accent};`}
          >
            <span class="rt-step" style={sans}>{s.step}</span>

            <span class="rt-policy" style={mono}>
              {s.policy}
              <span class="rt-policy-sub" style={mono}>{s.policySub}</span>
            </span>

            <div class="rt-ann">
              <span class="rt-ann-label rt-ann-label--risk" style={sans}>
                at risk
              </span>
              <span class="rt-ann-text" style={sans}>{s.risk}</span>
            </div>

            <div class="rt-ann">
              <span class="rt-ann-label rt-ann-label--watch" style={sans}>
                watching
              </span>
              <span class="rt-ann-text" style={sans}>{s.watch}</span>
            </div>
          </div>

          {i < stages.length - 1 && (
            <span class="rt-chevron" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="8 4 16 12 8 20" />
              </svg>
            </span>
          )}
        </>
      ))
    }
  </div>
</Figure>

<style>
  .rt {
    margin: 0;
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: 4px;
  }

  /* One stage of the ramp. The accent (passed per-cell) tints the top bar,
     the policy pill, and the left edge so the escalating risk reads at a
     glance even before the labels are parsed. */
  .rt-cell {
    margin: 0;
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding: 12px 13px 13px;
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--sl-color-gray-5));
    border-top: 3px solid var(--accent);
    border-radius: 9px;
    background: color-mix(in srgb, var(--accent) 7%, var(--sl-color-bg));
    box-sizing: border-box;
  }

  .rt-step {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 70%, var(--sl-color-white));
  }

  /* The literal policy value, carried as a filled pill in the stage accent so
     the policy reads as the headline of each cell. */
  .rt-policy {
    margin: 0;
    align-self: flex-start;
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    max-width: 100%;
    padding: 3px 10px;
    border-radius: 7px;
    background: var(--accent);
    color: #ffffff;
    font-size: 13.5px;
    font-weight: 700;
    line-height: 1.35;
  }
  .rt-policy-sub {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    color: color-mix(in srgb, #ffffff 82%, var(--accent));
    white-space: nowrap;
  }

  /* An annotation row: a tiny uppercase label over the explanatory line. */
  .rt-ann {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .rt-ann-label {
    margin: 0;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }
  .rt-ann-label--risk {
    color: color-mix(in srgb, var(--accent) 66%, var(--sl-color-white));
  }
  .rt-ann-label--watch {
    color: var(--sl-color-gray-3);
  }
  .rt-ann-text {
    margin: 0;
    font-size: 12px;
    line-height: 1.35;
    color: var(--sl-color-white);
  }

  /* Forward-progression chevrons between cells. They sit on the centre line of
     the strip and carry the gray chrome colour so they read as connectors, not
     data. */
  .rt-chevron {
    margin: 0;
    flex: 0 0 auto;
    align-self: center;
    display: inline-flex;
    color: var(--sl-color-gray-3);
  }
  .rt-chevron svg {
    width: 18px;
    height: 18px;
  }

  /* On narrow viewports the four cells can't keep a readable width side by
     side, so stack them and rotate the chevrons to keep the ramp reading
     top-to-bottom. */
  @media (max-width: 720px) {
    .rt {
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
    }
    .rt-cell {
      flex: 1 1 auto;
    }
    .rt-chevron {
      align-self: center;
      transform: rotate(90deg);
    }
  }
</style>
