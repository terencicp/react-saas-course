---
// dmarc-alignment — the lesson's centrepiece: alignment made visible.
//
// Reuses the exact three identity fields from the opening EmailThreeFields
// figure (Envelope MAIL FROM, DKIM d=, Visible From:) but now filled with
// CONCRETE domains and judged. The teaching question — "do the checks that
// passed point at the same domain the human sees?" — is answered purely by
// COLOUR, not arrows (per the outline + the diagram index on crossing/cyclic
// relationships):
//
//   green domain  = matches the visible From: domain  → aligned
//   red domain    = different from the visible From:   → not aligned
//
// Two tabs run the legitimate send and the spoof side by side. In tab one every
// domain is the same (send.yourapp.com) so all three glow green → DMARC pass. In
// tab two SPF and DKIM still PASS, but on evil.com, while the human sees
// yourapp.com → both red → not aligned → DMARC fail → policy applies.
//
//   ┌ Visible From: yourapp.com  (the yardstick) ────────────────────┐
//   │  [SPF]   Envelope MAIL FROM   bounces@<send.yourapp.com>  ✓     │
//   │  [DKIM]  DKIM d=              <send.yourapp.com>          ✓     │
//   │  [From]  Visible From:        hello@<send.yourapp.com>  (ref)   │
//   ├────────────────────────────────────────────────────────────────┤
//   │  SPF aligned ✓   DKIM aligned ✓        →  DMARC PASS  (green)    │
//   └────────────────────────────────────────────────────────────────┘
//
// The green/red here is the pass/fail palette the EmailThreeFields comment
// deliberately kept its teal/violet/amber protocol tags clear of — so the two
// colour stories never collide. The protocol tags (SPF teal, DKIM violet) are
// kept on the rows for continuity, but the DOMAIN carries the alignment signal,
// because alignment is about which domain passed.
//
// TabbedContent supplies the outer card + per-tab captions, so this is NOT
// wrapped in <Figure>. Pure HTML+CSS, devtools-inspectable. A `not-content`
// wrapper + margin resets defeat Starlight's prose-margin selector.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const SPF = "#0d9488"; // teal-600 — matches the lesson's SPF accent
const DKIM = "#7c3aed"; // violet-600 — matches the lesson's DKIM accent

// Two scenarios. `local` is the part before the domain; `domain` is the part
// the alignment check compares; `aligned` drives the green/red colour. The
// visible From: row is the reference (`ref: true`) — it sets the yardstick and
// is never itself coloured pass/fail.
const scenarios = [
  {
    key: "legit",
    label: "Legitimate send",
    fromDomain: "send.yourapp.com",
    rows: [
      {
        tag: "SPF",
        color: SPF,
        field: "Envelope MAIL FROM",
        local: "bounces@",
        domain: "send.yourapp.com",
        aligned: true,
      },
      {
        tag: "DKIM",
        color: DKIM,
        field: "DKIM d=",
        local: "",
        domain: "send.yourapp.com",
        aligned: true,
      },
      {
        tag: "From",
        color: "var(--sl-color-gray-3)",
        field: "Visible From:",
        local: "hello@",
        domain: "send.yourapp.com",
        ref: true,
      },
    ],
    verdict: {
      pass: true,
      spfAligned: true,
      dkimAligned: true,
      banner: "DMARC pass",
    },
  },
  {
    key: "spoof",
    label: "Spoof attempt",
    fromDomain: "yourapp.com",
    rows: [
      {
        tag: "SPF",
        color: SPF,
        field: "Envelope MAIL FROM",
        local: "bounces@",
        domain: "evil.com",
        aligned: false,
        note: "SPF passes — but on evil.com",
      },
      {
        tag: "DKIM",
        color: DKIM,
        field: "DKIM d=",
        local: "",
        domain: "evil.com",
        aligned: false,
        note: "DKIM passes — but on evil.com",
      },
      {
        tag: "From",
        color: "var(--sl-color-gray-3)",
        field: "Visible From:",
        local: "security@",
        domain: "yourapp.com",
        ref: true,
        note: "forged — the human reads this",
      },
    ],
    verdict: {
      pass: false,
      spfAligned: false,
      dkimAligned: false,
      banner: "DMARC fail → policy applies",
    },
  },
];

const captions = {
  legit:
    "Every domain is the same — the two passing checks point at exactly the domain the reader sees. SPF aligned, DKIM aligned, so DMARC passes. Green all the way down.",
  spoof:
    "SPF and DKIM both pass — but on evil.com, the attacker's own domain — while the reader sees yourapp.com. Nothing points at the visible From:, so neither is aligned and DMARC fails. Alignment is just: do the passing checks point at the same domain the human sees?",
};
---

<TabbedContent>
  {
    scenarios.map((s) => (
      <TabbedItem label={s.label} caption={captions[s.key]}>
        <div class={`dma not-content dma--${s.key}`} style={sans}>
          {/* the yardstick: the domain the human actually reads */}
          <div class="dma-ref-bar" style={sans}>
            <span class="dma-ref-eyebrow" style={sans}>
              The reader sees
            </span>
            <code class="dma-ref-domain" style={mono}>
              {s.fromDomain}
            </code>
            <span class="dma-ref-tail" style={sans}>
              — every check is judged against this
            </span>
          </div>

          {/* the three identity fields, domain colour-coded for alignment */}
          <div class="dma-rows">
            {s.rows.map((r) => (
              <div class={r.ref ? "dma-row dma-row--ref" : "dma-row"}>
                <span
                  class="dma-tag"
                  style={`${sans}; --tag: ${r.color}`}
                >
                  {r.tag}
                </span>

                <span class="dma-field" style={sans}>
                  {r.field}
                </span>

                <code class="dma-value" style={mono}>
                  {r.local}
                  <span
                    class={
                      r.ref
                        ? "dma-domain dma-domain--ref"
                        : r.aligned
                          ? "dma-domain dma-domain--ok"
                          : "dma-domain dma-domain--bad"
                    }
                  >
                    {r.domain}
                  </span>
                </code>

                <span
                  class={
                    r.ref
                      ? "dma-status dma-status--ref"
                      : r.aligned
                        ? "dma-status dma-status--ok"
                        : "dma-status dma-status--bad"
                  }
                  style={sans}
                >
                  {r.ref ? (
                    "reference"
                  ) : r.aligned ? (
                    <>
                      <svg
                        class="dma-ico"
                        viewBox="0 0 16 16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polyline points="3 8.5 6.5 12 13 4" />
                      </svg>
                      aligned
                    </>
                  ) : (
                    <>
                      <svg
                        class="dma-ico"
                        viewBox="0 0 16 16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <line x1="4" y1="4" x2="12" y2="12" />
                        <line x1="12" y1="4" x2="4" y2="12" />
                      </svg>
                      not aligned
                    </>
                  )}
                </span>

                {r.note && (
                  <span class="dma-note" style={sans}>
                    {r.note}
                  </span>
                )}
              </div>
            ))}
          </div>

          {/* the verdict: per-check alignment, then the DMARC outcome */}
          <div
            class={
              s.verdict.pass
                ? "dma-verdict dma-verdict--pass"
                : "dma-verdict dma-verdict--fail"
            }
          >
            <div class="dma-checks" style={sans}>
              <span
                class={
                  s.verdict.spfAligned
                    ? "dma-check dma-check--ok"
                    : "dma-check dma-check--bad"
                }
              >
                <span class="dma-check-key">SPF</span>
                {s.verdict.spfAligned ? "aligned" : "not aligned"}
              </span>
              <span
                class={
                  s.verdict.dkimAligned
                    ? "dma-check dma-check--ok"
                    : "dma-check dma-check--bad"
                }
              >
                <span class="dma-check-key">DKIM</span>
                {s.verdict.dkimAligned ? "aligned" : "not aligned"}
              </span>
            </div>

            <span class="dma-verdict-arrow" aria-hidden="true">
              <svg
                viewBox="0 0 40 16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="2" y1="8" x2="32" y2="8" />
                <polyline points="26 3 33 8 26 13" />
              </svg>
            </span>

            <span class="dma-banner" style={sans}>
              {s.verdict.pass ? (
                <svg
                  class="dma-banner-ico"
                  viewBox="0 0 16 16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="3 8.5 6.5 12 13 4" />
                </svg>
              ) : (
                <svg
                  class="dma-banner-ico"
                  viewBox="0 0 16 16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="4" y1="4" x2="12" y2="12" />
                  <line x1="12" y1="4" x2="4" y2="12" />
                </svg>
              )}
              {s.verdict.banner}
            </span>
          </div>
        </div>
      </TabbedItem>
    ))
  }
</TabbedContent>

<style
  define:vars={{
    ok: "#16a34a",
    bad: "#dc2626",
  }}
>
  .dma {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* The yardstick bar — names the one domain everything is judged against. */
  .dma-ref-bar {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 8px;
    padding: 9px 13px;
    border: 1px dashed var(--sl-color-gray-4);
    border-radius: 9px;
    background: color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent);
  }
  .dma-ref-eyebrow {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
  }
  .dma-ref-domain {
    margin: 0;
    padding: 1px 8px;
    border-radius: 5px;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.5;
  }
  .dma-ref-tail {
    margin: 0;
    font-size: 12px;
    color: var(--sl-color-gray-2);
  }

  /* The three field rows. Each is a grid: tag | field | value | status, with an
     optional note spanning the value column below. Wraps gracefully narrow. */
  .dma-rows {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .dma-row {
    margin: 0;
    display: grid;
    grid-template-columns: auto minmax(7.5rem, max-content) 1fr auto;
    align-items: center;
    column-gap: 12px;
    row-gap: 3px;
    padding: 10px 13px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 9px;
    background: var(--sl-color-bg);
    box-sizing: border-box;
  }

  /* The reference row (visible From:) sits apart with a tinted wash, since it's
     the yardstick, not a pass/fail subject. */
  .dma-row--ref {
    background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent);
    border-style: dashed;
    border-color: var(--sl-color-gray-4);
  }

  .dma-tag {
    margin: 0;
    grid-row: 1;
    justify-self: start;
    min-width: 3.1rem;
    padding: 2px 0;
    border-radius: 6px;
    background: var(--tag);
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    text-align: center;
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  .dma-field {
    margin: 0;
    grid-row: 1;
    font-size: 13px;
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1.3;
  }

  .dma-value {
    margin: 0;
    grid-row: 1;
    min-width: 0;
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--sl-color-text);
    overflow-wrap: anywhere;
  }

  /* The domain segment is the carrier of the alignment signal. */
  .dma-domain {
    margin: 0;
    padding: 1px 5px;
    border-radius: 4px;
    font-weight: 700;
  }
  .dma-domain--ok {
    background: color-mix(in srgb, var(--ok) 16%, transparent);
    color: color-mix(in srgb, var(--ok) 82%, var(--sl-color-white));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--ok) 40%, transparent);
  }
  .dma-domain--bad {
    background: color-mix(in srgb, var(--bad) 16%, transparent);
    color: color-mix(in srgb, var(--bad) 82%, var(--sl-color-white));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--bad) 40%, transparent);
  }
  .dma-domain--ref {
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    box-shadow: inset 0 0 0 1px var(--sl-color-gray-4);
  }

  /* Per-row status chip on the right. */
  .dma-status {
    margin: 0;
    grid-row: 1;
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.4;
  }
  .dma-status--ok {
    color: color-mix(in srgb, var(--ok) 82%, var(--sl-color-white));
  }
  .dma-status--bad {
    color: color-mix(in srgb, var(--bad) 82%, var(--sl-color-white));
  }
  .dma-status--ref {
    color: var(--sl-color-gray-3);
    font-weight: 600;
    font-style: italic;
  }
  .dma-ico {
    width: 14px;
    height: 14px;
    flex: 0 0 auto;
  }

  /* The little explanatory note under a value (e.g. "SPF passes — but on
     evil.com"). Spans the middle columns so it sits under the value. */
  .dma-note {
    margin: 0;
    grid-row: 2;
    grid-column: 2 / -1;
    font-size: 11.5px;
    line-height: 1.35;
    color: var(--sl-color-gray-2);
  }

  /* The verdict strip: the two per-check results, an arrow, the DMARC banner. */
  .dma-verdict {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 14px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid;
  }
  .dma-verdict--pass {
    background: color-mix(in srgb, var(--ok) 9%, var(--sl-color-bg));
    border-color: color-mix(in srgb, var(--ok) 40%, var(--sl-color-gray-5));
  }
  .dma-verdict--fail {
    background: color-mix(in srgb, var(--bad) 9%, var(--sl-color-bg));
    border-color: color-mix(in srgb, var(--bad) 40%, var(--sl-color-gray-5));
  }

  .dma-checks {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .dma-check {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.4;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
  }
  .dma-check-key {
    margin: 0;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 1px 6px;
    border-radius: 5px;
    color: #ffffff;
  }
  .dma-check--ok .dma-check-key {
    background: var(--ok);
  }
  .dma-check--bad .dma-check-key {
    background: var(--bad);
  }
  .dma-check--ok {
    color: color-mix(in srgb, var(--ok) 82%, var(--sl-color-white));
  }
  .dma-check--bad {
    color: color-mix(in srgb, var(--bad) 82%, var(--sl-color-white));
  }

  .dma-verdict-arrow {
    margin: 0;
    flex: 0 0 auto;
    display: inline-flex;
    color: var(--sl-color-gray-3);
  }
  .dma-verdict-arrow svg {
    width: 32px;
    height: 14px;
  }

  /* The final DMARC outcome banner — the loudest element in the figure. */
  .dma-banner {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 14px;
    border-radius: 999px;
    color: #ffffff;
    font-size: 13.5px;
    font-weight: 800;
    line-height: 1.4;
  }
  .dma-verdict--pass .dma-banner {
    background: var(--ok);
  }
  .dma-verdict--fail .dma-banner {
    background: var(--bad);
  }
  .dma-banner-ico {
    width: 15px;
    height: 15px;
    flex: 0 0 auto;
  }

  /* On narrow viewports the four-column row collapses to two stacked lines:
     tag + field on top, value + status below. The note still trails. */
  @media (max-width: 560px) {
    .dma-row {
      grid-template-columns: auto 1fr;
    }
    .dma-tag {
      grid-row: 1;
    }
    .dma-field {
      grid-row: 1;
    }
    .dma-value {
      grid-row: 2;
      grid-column: 1 / -1;
    }
    .dma-status {
      grid-row: 3;
      grid-column: 1 / -1;
      justify-self: start;
    }
    .dma-note {
      grid-row: 4;
      grid-column: 1 / -1;
    }
    .dma-verdict-arrow {
      transform: rotate(90deg);
    }
  }
</style>
