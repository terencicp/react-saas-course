---
// diagram-from-anatomy — Chapter 048 Lesson 1, "Resend and the first verified send".
//
// An annotated illustration of one `from` string: 'YourApp <noreply@send.yourapp.com>'.
// The teaching point is that the address is THREE decisions, not one string —
// each segment answers a different question and serves a different audience:
//
//   YourApp            display name      → UX (what the human reads)
//   noreply            local part        → intent signal (routes the user's filters)
//   send.yourapp.com   verified subdomain → the deliverability hard requirement
//
// Built as plain HTML+CSS (the diagrams index's top pick for an annotated
// illustration) rather than a diagram engine: the linkage between a segment and
// its explanation is carried entirely by COLOR, so no leader lines are needed.
// Encapsulated in this component (rather than inline MDX) so the tints/rings live
// in a scoped <style> block and the lesson source stays clean — same house style
// as SendPath.astro in this lesson.
//
// Layout: one monospace string on top with each segment tinted + inset-ringed and
// the literal `<`, `@`, `>` punctuation left un-tinted, so it reads verbatim as
// `YourApp <noreply@send.yourapp.com>`. Below, a single row of three callouts,
// color-matched to the segment above each (left border + heading tint). The row
// wraps on narrow viewports (flex-wrap) so nothing is ever clipped.
//
// `.not-content` opts the whole figure out of Starlight prose styling; a margin:0
// reset on inner elements defeats Starlight's injected prose top-margins. The three
// accent colors are saturated mid-tones (sky/amber/emerald 500) that read on both
// the light and dark Figure card; tints use color-mix so they stay subtle in both.

import Figure from '../../../figures/Figure.astro';

const BLUE = '#0ea5e9'; // sky-500   — display name
const ORANGE = '#f59e0b'; // amber-500 — local part
const GREEN = '#10b981'; // emerald-500 — verified subdomain

// The three meaningful segments, in reading order, with the part name and its role.
const parts = [
	{
		color: BLUE,
		name: 'Display name',
		role: 'what the recipient reads in their inbox list.',
	},
	{
		color: ORANGE,
		name: 'Local part',
		role: "signals the email's intent; routes the user's filters.",
	},
	{
		color: GREEN,
		name: 'Verified subdomain',
		role: 'the mailbox must live here, or the send is rejected.',
	},
];
---

<Figure>
	<div class="fa not-content">
		<!-- The address, read verbatim: YourApp <noreply@send.yourapp.com> -->
		<div class="fa-string">
			<span class="fa-seg" style={`--seg: ${BLUE};`}>YourApp</span>
			<span class="fa-punct">&nbsp;&lt;</span>
			<span class="fa-seg" style={`--seg: ${ORANGE};`}>noreply</span>
			<span class="fa-punct">@</span>
			<span class="fa-seg" style={`--seg: ${GREEN};`}>send.yourapp.com</span>
			<span class="fa-punct">&gt;</span>
		</div>

		<!-- One row of three color-matched callouts. -->
		<div class="fa-callouts">
			{
				parts.map((part) => (
					<div class="fa-callout" style={`--seg: ${part.color};`}>
						<span class="fa-name">{part.name}</span>
						<span class="fa-role">{part.role}</span>
					</div>
				))
			}
		</div>
	</div>
	<Fragment slot="caption">
		Three parts, three decisions. The display name is UX, the local part is
		intent, the subdomain is the deliverability requirement.
	</Fragment>
</Figure>

<style>
	.fa {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 22px;
		margin: 0;
		padding: 10px 4px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The address line. */
	.fa-string {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0;
		margin: 0;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: clamp(1.05rem, 1.7vw, 1.55rem);
		font-weight: 600;
		line-height: 1.5;
		letter-spacing: 0.01em;
	}

	/* A tinted, inset-ringed segment of the address. */
	.fa-seg {
		margin: 0;
		padding: 2px 8px;
		border-radius: 6px;
		color: var(--sl-color-white, #1e293b);
		background: color-mix(in srgb, var(--seg) 20%, transparent);
		box-shadow: inset 0 0 0 1px var(--seg);
	}

	/* Literal punctuation between segments — never tinted. */
	.fa-punct {
		margin: 0;
		padding: 0 1px;
		color: var(--sl-color-gray-2, #475569);
	}

	/* The single row of callouts. Wraps instead of scrolling on narrow widths. */
	.fa-callouts {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: stretch;
		column-gap: 14px;
		row-gap: 12px;
		width: 100%;
		margin: 0;
	}

	.fa-callout {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 3px;
		flex: 1 1 0;
		min-width: 13rem;
		max-width: 17rem;
		margin: 0;
		padding: 9px 12px;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-left: 3px solid var(--seg);
		background: color-mix(in srgb, var(--seg) 8%, transparent);
	}

	.fa-name {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1.25;
		color: var(--seg);
	}

	.fa-role {
		margin: 0;
		font-size: 0.78rem;
		line-height: 1.35;
		color: var(--sl-color-gray-2, #334155);
	}

	/* On a single narrow column, let each callout span the row comfortably. */
	@media (max-width: 560px) {
		.fa-callout {
			flex-basis: 100%;
			max-width: 22rem;
		}
	}
</style>
