---
// diagram-send-path — Chapter 048 Lesson 1, "Resend and the first verified send".
//
// The lesson's spine: deliverability is the APP's responsibility, not the
// vendor's. This figure makes the responsibility boundary visible by tracing one
// email left→right across four boxes and coloring the two arrows that cross a
// boundary:
//
//   Server Action ──(in-process, no label)──▶ sendEmail()
//   sendEmail() ──[your domain · your key · your idempotency key]──▶ Resend API
//                  ↑ BLUE: the app's responsibility — the interesting part
//   Resend API ──[SMTP · IP reputation pool]──▶ recipient inbox
//                  ↑ GREY: the vendor's responsibility — the part you don't own
//
// Built with <ArrowDiagram> (LeaderLine) because each box is two-line custom HTML
// (a monospace title + a muted under-label) and the per-arrow semantic coloring
// is the whole point — D2/Mermaid plain-label boxes wouldn't carry it. The arrows
// are positioned from document.body, so the wrapping <Figure> MUST be
// expandable={false}: relocating the body into the lightbox breaks the leader
// lines.
//
// Sockets are right→left between adjacent boxes in one horizontal row. The two
// labels sit in the gaps; labelOffset lifts them above the wire so they don't
// land on the arrow body. Generous column gap reserves room for the curve+label.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark). The two
// boundary accents (#0ea5e9 blue, a neutral slate grey) are used as-is in both
// themes — mid-tones that read on either background. A margin:0 reset defeats
// Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// The four boxes, left → right. `id` matches the arrow descriptors; `under` is the
// small muted label beneath each box title.
const boxes = [
	{ id: 'send-action', title: 'Server Action', under: 'your code' },
	{ id: 'send-wrapper', title: 'sendEmail()', under: 'lib/email.ts' },
	{ id: 'send-resend', title: 'Resend API', under: 'the vendor' },
	{ id: 'send-inbox', title: 'recipient inbox', under: 'Gmail, Outlook, …' },
];

// Mid-tone accents reused verbatim in light + dark.
const APP_BLUE = '#0ea5e9'; // the app's side of the boundary
const VENDOR_GREY = '#64748b'; // slate-500 — the vendor's side

const arrows = [
	// In-process call — no label, theme-neutral.
	{
		from: 'send-action',
		to: 'send-wrapper',
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
	},
	// Crosses OUT of your process — the app owns everything on this wire. The long
	// label sits ABOVE the row; the two boundary labels are Y-staggered so their
	// wide badges never collide at the widest desktop width.
	{
		from: 'send-wrapper',
		to: 'send-resend',
		label: 'your domain · your key · your idempotency key',
		color: APP_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -42],
	},
	// The vendor's wire — SMTP + the shared IP reputation pool. Sits BELOW the row
	// to clear the long blue label above.
	{
		from: 'send-resend',
		to: 'send-inbox',
		label: 'SMTP · IP reputation pool',
		color: VENDOR_GREY,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, 30],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="sp not-content">
			{
				boxes.map((box) => (
					<div class="sp-box" id={box.id}>
						<span class="sp-title">{box.title}</span>
						<span class="sp-under">{box.under}</span>
					</div>
				))
			}
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		Resend owns the wire and the IP reputation. Everything *interesting* — the
		domain you send from, the key that authorizes the send, the idempotency key
		that stops a retry from sending twice — lives on your side of the boundary.
	</Fragment>
</Figure>

<style>
	.sp {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: space-between;
		gap: 92px;
		margin: 0;
		padding: 14px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.sp-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		flex: 0 1 auto;
		padding: 11px 14px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	.sp-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.86rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.sp-under {
		font-size: 0.66rem;
		line-height: 1.2;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: stack the four boxes; the right→left sockets degrade to
	   vertical arcs between stacked boxes — readable, and the labels still float in
	   the gaps. */
	@media (max-width: 720px) {
		.sp {
			flex-direction: column;
			gap: 54px;
		}
		.sp-box {
			width: min(18rem, 100%);
		}
	}
</style>
