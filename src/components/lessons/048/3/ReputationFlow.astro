---
// ReputationFlow — Chapter 048 Lesson 3 ("The transactional subdomain split"),
// the lesson's payoff figure. An A/B diagram rendered as two variants of one
// component so the contrast reads at a glance and the two panels stay visually
// identical except for the one thing that changes: how many reputation scores
// there are.
//
//   variant="shared"  (the trap): two source streams -> ONE yourapp.com meter
//     pulled into the danger zone by the marketing complaints -> ONE outcome
//     split where the verification email lands in SPAM. The transactional mail
//     did nothing wrong; it paid for the marketing stream's complaints.
//
//   variant="split"   (the fix): the same two streams, now each on its OWN
//     subdomain + meter -> two independent outcomes. send.yourapp.com is healthy
//     and its verification email lands in the INBOX, immune to whatever the
//     marketing score is doing this week.
//
// Pure HTML + CSS per the diagrams guide (colour-coded boxes, a reputation
// "meter" bar, an inbox/spam outcome split). Horizontal left-to-right flow that
// collapses to a vertical stack on narrow viewports. Inline `style` constants so
// the source is copy-pasteable and devtools-inspectable. `not-content` + a
// `margin: 0` reset on every node defeats Starlight's prose-margin injection.
// Goes inside a <TabbedItem> (which supplies the card + per-tab caption), so it
// is NOT wrapped in <Figure>.

interface Props {
	variant: "shared" | "split";
}

const { variant } = Astro.props;

// Saturated mid-tones (Tailwind 600-range) + matching tints. These read on both
// the white and near-black page backgrounds, and the colour itself is the signal:
//   green  = healthy / transactional
//   amber  = marketing / volatile / at-risk
//   red    = spam outcome
const GREEN = "#16a34a";
const AMBER = "#d97706";
const RED = "#dc2626";

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

// --- shared building-block styles ----------------------------------------

// A source box: the origin of one mail stream. Tinted by its accent colour.
const sourceBox = (accent: string) =>
	[
		reset,
		sans,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"gap: 3px",
		"padding: 10px 12px",
		"border-radius: 9px",
		`border: 1px solid color-mix(in srgb, ${accent} 55%, transparent)`,
		`background: color-mix(in srgb, ${accent} 12%, transparent)`,
	].join("; ");

const sourceTitle = (accent: string) =>
	[
		reset,
		sans,
		"font-size: 13px",
		"font-weight: 700",
		`color: color-mix(in srgb, ${accent} 78%, var(--sl-color-text))`,
	].join("; ");

const sourceNote = [
	reset,
	sans,
	"font-size: 11px",
	"color: var(--sl-color-gray-3)",
].join("; ");

// A meter: a domain name above a horizontal bar whose fill width + colour
// encode the reputation score, with a status label below.
const meterCard = [
	reset,
	sans,
	"box-sizing: border-box",
	"display: flex",
	"flex-direction: column",
	"gap: 7px",
	"padding: 12px",
	"border-radius: 10px",
	"border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 70%, transparent)",
	"background: color-mix(in srgb, var(--sl-color-gray-6) 35%, transparent)",
].join("; ");

const meterDomain = [
	reset,
	mono,
	"font-size: 12.5px",
	"font-weight: 600",
	"color: var(--sl-color-text)",
	"white-space: nowrap",
].join("; ");

const meterTrack = [
	reset,
	"box-sizing: border-box",
	"position: relative",
	"width: 100%",
	"height: 12px",
	"border-radius: 999px",
	"background: color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent)",
	"overflow: hidden",
].join("; ");

const meterFill = (accent: string, pct: number) =>
	[
		reset,
		"display: block",
		"height: 100%",
		`width: ${pct}%`,
		"border-radius: 999px",
		`background: ${accent}`,
	].join("; ");

const meterStatus = (accent: string) =>
	[
		reset,
		sans,
		"font-size: 11px",
		"font-weight: 700",
		`color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`,
	].join("; ");

// An outcome panel: two stacked rows, "Inbox" (green) and "Spam" (red). The
// `landsIn` arg decides which row carries the chip.
const outcomeRow = (tone: "inbox" | "spam", active: boolean) => {
	const accent = tone === "inbox" ? GREEN : RED;
	return [
		reset,
		sans,
		"box-sizing: border-box",
		"display: flex",
		"align-items: center",
		"gap: 8px",
		"padding: 8px 10px",
		"border-radius: 8px",
		`border: 1px solid color-mix(in srgb, ${accent} ${active ? 55 : 22}%, transparent)`,
		`background: color-mix(in srgb, ${accent} ${active ? 14 : 4}%, transparent)`,
	].join("; ");
};

const outcomeLabel = (tone: "inbox" | "spam", active: boolean) => {
	const accent = tone === "inbox" ? GREEN : RED;
	return [
		reset,
		sans,
		"font-size: 12px",
		"font-weight: 700",
		active
			? `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`
			: "color: var(--sl-color-gray-3)",
	].join("; ");
};

// The email "chip" that travels through the flow and lands in an outcome row.
const emailChip = (accent: string) =>
	[
		reset,
		sans,
		"box-sizing: border-box",
		"display: inline-flex",
		"align-items: center",
		"gap: 5px",
		"padding: 3px 8px",
		"border-radius: 999px",
		`border: 1px solid ${accent}`,
		`background: ${accent}`,
		"color: #ffffff",
		"font-size: 11px",
		"font-weight: 700",
		"white-space: nowrap",
	].join("; ");

const columnHeader = [
	reset,
	sans,
	"font-size: 10.5px",
	"font-weight: 700",
	"letter-spacing: 0.06em",
	"text-transform: uppercase",
	"color: var(--sl-color-gray-3)",
	"text-align: center",
].join("; ");

// Small inline mail glyph used inside chips and outcome rows.
const mailIcon = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin: 0; flex: 0 0 auto;"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 5L2 7"></path></svg>`;
---

<div class:list={["rf-root not-content", `rf-${variant}`]} style={reset}>
	{/* ---------------- COLUMN 1: the two source streams ---------------- */}
	<div class="rf-col rf-sources" style={reset}>
		<div style={columnHeader}>Your sends</div>
		<div style={sourceBox(GREEN)}>
			<span style={sourceTitle(GREEN)}>Transactional sends</span>
			<span style={sourceNote}>high opens · ~0 complaints</span>
		</div>
		<div style={sourceBox(AMBER)}>
			<span style={sourceTitle(AMBER)}>Marketing sends</span>
			<span style={sourceNote}>complaint churn</span>
		</div>
	</div>

	<div class="rf-arrow rf-arrow-1" aria-hidden="true"></div>

	{
		variant === "shared" ? (
			<>
				{/* ------------ ONE shared meter ------------ */}
				<div class="rf-col rf-meters" style={reset}>
					<div style={columnHeader}>One reputation</div>
					<div style={meterCard}>
						<span style={meterDomain}>yourapp.com</span>
						<span style={meterTrack}>
							<span style={meterFill(AMBER, 42)} />
						</span>
						<span style={meterStatus(RED)}>reputation: at risk</span>
					</div>
					<span class="rf-meter-note" style={sourceNote}>
						marketing complaints drag the shared score down
					</span>
				</div>

				<div class="rf-arrow rf-arrow-2" aria-hidden="true" />

				{/* ------------ ONE outcome split ------------ */}
				<div class="rf-col rf-outcomes" style={reset}>
					<div style={columnHeader}>Gmail decides</div>
					<div style={outcomeRow("inbox", false)}>
						<span style={outcomeLabel("inbox", false)}>Inbox</span>
					</div>
					<div style={outcomeRow("spam", true)}>
						<span style={outcomeLabel("spam", true)}>Spam</span>
						<span style={emailChip(RED)}>
							<Fragment set:html={mailIcon} />
							verification
						</span>
					</div>
				</div>
			</>
		) : (
			<>
				{/* ------------ TWO independent meters ------------ */}
				<div class="rf-col rf-meters" style={reset}>
					<div style={columnHeader}>Two reputations</div>
					<div style={meterCard}>
						<span style={meterDomain}>send.yourapp.com</span>
						<span style={meterTrack}>
							<span style={meterFill(GREEN, 90)} />
						</span>
						<span style={meterStatus(GREEN)}>reputation: healthy</span>
					</div>
					<div style={meterCard}>
						<span style={meterDomain}>marketing.yourapp.com</span>
						<span style={meterTrack}>
							<span style={meterFill(AMBER, 50)} />
						</span>
						<span style={meterStatus(AMBER)}>reputation: volatile</span>
					</div>
				</div>

				<div class="rf-arrow rf-arrow-2" aria-hidden="true" />

				{/* ------------ TWO independent outcomes ------------ */}
				<div class="rf-col rf-outcomes" style={reset}>
					<div style={columnHeader}>Gmail decides</div>
					<div style={outcomeRow("inbox", true)}>
						<span style={outcomeLabel("inbox", true)}>Inbox</span>
						<span style={emailChip(GREEN)}>
							<Fragment set:html={mailIcon} />
							verification
						</span>
					</div>
					<div style={outcomeRow("inbox", true)}>
						<span style={outcomeLabel("inbox", true)}>Inbox</span>
						<span style={emailChip(AMBER)}>
							<Fragment set:html={mailIcon} />
							newsletter
						</span>
					</div>
				</div>
			</>
		)
	}
</div>

<style>
	.rf-root {
		display: grid;
		align-items: center;
		gap: 0;
		padding: 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	/* Five tracks: sources | arrow | meters | arrow | outcomes. The meter and
	   outcome columns take the most room; the arrow tracks are thin. */
	.rf-root {
		grid-template-columns: minmax(140px, 0.95fr) 28px minmax(170px, 1.15fr) 28px minmax(150px, 1fr);
	}

	.rf-col {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin: 0;
		min-width: 0;
	}

	.rf-meter-note {
		text-align: center;
		line-height: 1.35;
	}

	/* Horizontal connector arrows between the columns. */
	.rf-arrow {
		position: relative;
		height: 2px;
		margin: 0 4px;
		background: color-mix(in srgb, currentColor 32%, transparent);
		align-self: center;
	}

	.rf-arrow::after {
		content: "";
		position: absolute;
		top: 50%;
		right: -1px;
		width: 0;
		height: 0;
		border-top: 5px solid transparent;
		border-bottom: 5px solid transparent;
		border-left: 7px solid color-mix(in srgb, currentColor 42%, transparent);
		transform: translateY(-50%);
	}

	/* Vertical-stack fallback: on narrow viewports the five-column grid would
	   crush, so collapse to one column and rotate the arrows to point downward. */
	@media (max-width: 640px) {
		.rf-root {
			grid-template-columns: 1fr;
			gap: 14px;
			justify-items: center;
		}

		.rf-col {
			width: 100%;
			max-width: 320px;
		}

		.rf-arrow {
			width: 2px;
			height: 18px;
			margin: 0;
		}

		.rf-arrow::after {
			top: auto;
			right: 50%;
			bottom: -1px;
			border-top: 7px solid color-mix(in srgb, currentColor 42%, transparent);
			border-bottom: none;
			border-left: 5px solid transparent;
			border-right: 5px solid transparent;
			transform: translateX(50%);
		}
	}
</style>
