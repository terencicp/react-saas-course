---
// DomainZones — Chapter 048 Lesson 3 ("The transactional subdomain split"),
// "The subdomain architecture" section. A compact vertical tree showing one apex
// domain branching into its two sending zones, so the parent/child relationship
// (apex above, subdomains below) reads at a glance.
//
//   yourapp.com            (apex · humans)        -- the parent, neutral
//       |
//   +---+--------------------+
//   |                        |
//   send.yourapp.com    marketing.yourapp.com
//   (transactional)     (marketing, conditional)
//
// The two children are colour-coded to match this lesson's sibling figure
// (ReputationFlow): green = transactional / in-scope, amber = marketing /
// conditional. The marketing box carries a "(only if you send marketing)" note
// because that zone is stood up later, not on day one.
//
// Pure HTML + CSS per the diagrams guide (nested hierarchy, colour-coded boxes,
// CSS-drawn connector lines). Inline `style` constants so the source is
// copy-pasteable and devtools-inspectable; the connectors are real bordered
// divs, not absolute-positioned approximations. `not-content` + a `margin: 0`
// reset on every node defeats Starlight's prose-margin injection. Goes inside a
// <Figure> (supplied by the lesson MDX).

// Saturated mid-tones (Tailwind 600-range), matching ReputationFlow so the two
// figures in this lesson share one colour language: green = healthy /
// transactional / in-scope, amber = marketing / volatile / conditional.
const GREEN = "#16a34a";
const AMBER = "#d97706";

const reset = "margin: 0";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
	"font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace)";

// A zone box. `accent === null` => the neutral apex (gray chrome). Otherwise the
// box is tinted by its accent colour to mark its stream.
const zoneBox = (accent: string | null) =>
	[
		reset,
		"box-sizing: border-box",
		"display: flex",
		"flex-direction: column",
		"align-items: center",
		"gap: 4px",
		"padding: 11px 16px",
		"border-radius: 10px",
		"text-align: center",
		accent === null
			? "border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 80%, transparent)"
			: `border: 1px solid color-mix(in srgb, ${accent} 55%, transparent)`,
		accent === null
			? "background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent)"
			: `background: color-mix(in srgb, ${accent} 12%, transparent)`,
	].join("; ");

const zoneDomain = (accent: string | null) =>
	[
		reset,
		mono,
		"font-size: 14px",
		"font-weight: 700",
		"white-space: nowrap",
		accent === null
			? "color: var(--sl-color-text)"
			: `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-text))`,
	].join("; ");

const zoneRole = [
	reset,
	sans,
	"font-size: 11.5px",
	"font-weight: 600",
	"letter-spacing: 0.02em",
	"color: var(--sl-color-gray-3)",
].join("; ");

const zoneNote = (accent: string) =>
	[
		reset,
		sans,
		"font-size: 10.5px",
		"font-weight: 600",
		`color: color-mix(in srgb, ${accent} 70%, var(--sl-color-gray-2))`,
	].join("; ");

// Connector colour — a hairline that reads on both themes.
const line = "color-mix(in srgb, var(--sl-color-gray-3) 60%, transparent)";
---

<div class="dz-root not-content" style={reset}>
	{/* ---- apex (the parent) ---- */}
	<div class="dz-apex" style={reset}>
		<div style={zoneBox(null)}>
			<span style={zoneDomain(null)}>yourapp.com</span>
			<span style={zoneRole}>apex · humans</span>
		</div>
	</div>

	{/* ---- connector: drop from apex, split, drop into each child ----
	     The two-column grid mirrors .dz-children exactly, so each drop and each
	     half-rail sits at its child's true centre regardless of the gap/max-width.
	     Per cell: a half-rail from the cell centre to the inner edge (left cell
	     extends right, right cell extends left, so the two meet over the gap) plus
	     a vertical drop down into the child. */}
	<div class="dz-connector" aria-hidden="true" style={reset}>
		<span class="dz-stem"></span>
		<span class="dz-cell">
			<span class="dz-halfrail dz-halfrail-r"></span>
			<span class="dz-drop"></span>
		</span>
		<span class="dz-cell">
			<span class="dz-halfrail dz-halfrail-l"></span>
			<span class="dz-drop"></span>
		</span>
	</div>

	{/* ---- children (the two sending subdomains) ---- */}
	<div class="dz-children" style={reset}>
		<div style={zoneBox(GREEN)}>
			<span style={zoneDomain(GREEN)}>send.yourapp.com</span>
			<span style={zoneRole}>transactional · the app</span>
		</div>
		<div style={zoneBox(AMBER)}>
			<span style={zoneDomain(AMBER)}>marketing.yourapp.com</span>
			<span style={zoneRole}>marketing · campaigns</span>
			<span style={zoneNote(AMBER)}>(only if you send marketing)</span>
		</div>
	</div>
</div>

<style define:vars={{ line }}>
	.dz-root {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
		padding: 18px 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	.dz-apex {
		display: flex;
		justify-content: center;
		margin: 0;
	}

	/* The connector occupies a fixed-height band between apex and children. Its
	   grid mirrors .dz-children (same columns, gap, max-width, centring) so each
	   cell's centre coincides with the child box's centre below it. */
	.dz-connector {
		position: relative;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 28px;
		width: 100%;
		max-width: 520px;
		height: 34px;
		margin: 0;
	}

	/* Vertical stem from the apex's centre down to the rail. */
	.dz-stem {
		position: absolute;
		top: 0;
		left: 50%;
		width: 2px;
		height: 17px;
		background: var(--line);
		transform: translateX(-50%);
	}

	.dz-cell {
		position: relative;
		margin: 0;
	}

	/* Half-rails: each runs from its cell's centre to the inner edge plus half the
	   28px gap, so the two halves meet exactly over the gap's midpoint (= the
	   apex stem). Anchored to the cell centre, they stay correct at any width. */
	.dz-halfrail {
		position: absolute;
		top: 16px;
		height: 2px;
		background: var(--line);
	}

	.dz-halfrail-r {
		left: 50%;
		right: -14px;
	}

	.dz-halfrail-l {
		right: 50%;
		left: -14px;
	}

	/* Vertical drop from the rail down into the child box, at the cell centre. */
	.dz-drop {
		position: absolute;
		top: 16px;
		left: 50%;
		width: 2px;
		height: 18px;
		background: var(--line);
		transform: translateX(-50%);
	}

	/* Two equal columns; each child box centre defines the drop position above. */
	.dz-children {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 28px;
		width: 100%;
		max-width: 520px;
		margin: 0;
		justify-items: center;
	}

	.dz-children > div {
		width: 100%;
	}

	/* Narrow viewports: stack the two children and turn the branch into a single
	   straight spine so the rails don't point at empty space. */
	@media (max-width: 460px) {
		.dz-children {
			grid-template-columns: 1fr;
			gap: 12px;
			max-width: 280px;
		}

		.dz-connector {
			grid-template-columns: 1fr;
			height: 18px;
		}

		.dz-stem {
			height: 18px;
		}

		.dz-halfrail,
		.dz-drop {
			display: none;
		}
	}
</style>
