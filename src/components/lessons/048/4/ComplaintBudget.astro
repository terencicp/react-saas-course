---
// ComplaintBudget — Chapter 048 Lesson 4 ("The suppression list as a send-time
// chokepoint"), the "complaint-rate budget" section. A lightweight horizontal
// GAUGE (not a system diagram) whose job is to make the complaint rate feel like
// a dial with a redline rather than a vanity number.
//
// One bar, three colour-coded zones left→right, with the two documented Gmail
// thresholds sitting exactly on the seams between them:
//
//   |   Healthy   |   Warning    |      Throttling →
//   |   < 0.1%    | 0.1% – 0.3%  |       > 0.3%
//                 ^             ^
//               0.1%      0.3% (REDLINE)
//
// The zones use this chapter's pass/fail palette (green #16a34a healthy, amber
// #d97706 warning, red #dc2626 throttling) so it shares one colour language with
// the lesson's other figures (DomainZones, ReputationFlow, DmarcRolloutTimeline).
// The widths are deliberately legibility-weighted, NOT a strict numeric plot:
// this is a categorical reputation budget, and the throttling zone is open-ended
// (a right-edge fade + a ">" hint that it runs off the scale). The 0.3% seam is
// emphasised as the REDLINE — a thicker red tick + a micro-label — because that's
// the line whose crossing triggers throttling and a multi-day recovery.
//
// Plain HTML + CSS per the diagrams guide (colour-coded segments + boundary
// ticks), so the flex bar is devtools-inspectable. `not-content` + a margin:0
// reset on every node defeats Starlight's prose-margin injection. Wrapped in a
// <Figure> by the lesson MDX. Stacks gracefully: at narrow widths the labels
// shrink but the bar stays one strip so the ramp still reads.

const GREEN = "#16a34a"; // green-600 — healthy, inbox reliable
const AMBER = "#d97706"; // amber-600 — warning, newly-added recipients drift to spam
const RED = "#dc2626"; // red-600 — throttling, Gmail's documented redline

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The three zones. `flex` is the legibility-weighted share of the bar (not a
// numeric proportion); `open` marks the unbounded throttling zone.
const zones = [
  {
    accent: GREEN,
    name: "Healthy",
    range: "< 0.1%",
    flex: 3,
    open: false,
  },
  {
    accent: AMBER,
    name: "Warning",
    range: "0.1% – 0.3%",
    flex: 4,
    open: false,
  },
  {
    accent: RED,
    name: "Throttling",
    range: "> 0.3%",
    flex: 3,
    open: true,
  },
];
---

<div class="cb not-content" style={sans}>
  {/* The gauge bar: three coloured zones butting up against each other. */}
  <div class="cb-bar">
    {
      zones.map((z) => (
        <div
          class:list={["cb-zone", { "cb-zone--open": z.open }]}
          style={`--accent: ${z.accent}; flex: ${z.flex} 1 0;`}
        >
          <span class="cb-zone-name">{z.name}</span>
          <span class="cb-zone-range">{z.range}</span>
          {z.open && (
            <span class="cb-zone-arrow" aria-hidden="true">
              &rsaquo;
            </span>
          )}
        </div>
      ))
    }
  </div>

  {/* The tick scale below the bar. Each tick sits on a seam between two zones;
      its position is the cumulative flex up to that seam, as a percentage of the
      total flex (3 / 10 and 7 / 10), so the marks line up with the colour
      boundaries above regardless of the bar's rendered width. */}
  <div class="cb-scale" aria-hidden="true">
    <div class="cb-tick" style="left: 30%;">
      <span class="cb-tick-mark"></span>
      <span class="cb-tick-label">0.1%</span>
    </div>
    <div class="cb-tick cb-tick--redline" style="left: 70%;">
      <span class="cb-tick-mark"></span>
      <span class="cb-tick-label">0.3%</span>
      <span class="cb-tick-redline">redline</span>
    </div>
  </div>
</div>

<style define:vars={{ RED }}>
  .cb {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 4px 2px 0;
  }

  /* The bar itself: a single rounded strip split into the three zones. */
  .cb-bar {
    margin: 0;
    display: flex;
    align-items: stretch;
    height: 62px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
  }

  /* One zone. The accent fills the segment; white text rides on top (saturated
     mid-tones keep contrast in both light and dark mode). A thin lighter inner
     border on the right edge separates adjacent zones crisply. */
  .cb-zone {
    position: relative;
    margin: 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 6px 8px;
    background: var(--accent);
    box-sizing: border-box;
  }
  .cb-zone + .cb-zone {
    border-left: 1.5px solid color-mix(in srgb, #ffffff 60%, transparent);
  }

  /* The open-ended throttling zone fades a touch deeper toward its right edge
     and carries a chevron, hinting the scale runs off past it. */
  .cb-zone--open {
    background: linear-gradient(
      90deg,
      var(--accent) 0%,
      color-mix(in srgb, var(--accent) 78%, #000000) 100%
    );
  }

  .cb-zone-name {
    margin: 0;
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #ffffff;
    text-shadow: 0 1px 1px color-mix(in srgb, #000000 28%, transparent);
    white-space: nowrap;
  }
  .cb-zone-range {
    margin: 0;
    font-size: 12px;
    font-weight: 600;
    color: color-mix(in srgb, #ffffff 92%, transparent);
    white-space: nowrap;
  }
  .cb-zone-arrow {
    position: absolute;
    right: 7px;
    top: 50%;
    margin: 0;
    transform: translateY(-50%);
    font-size: 22px;
    font-weight: 700;
    line-height: 1;
    color: color-mix(in srgb, #ffffff 78%, transparent);
  }

  /* The tick scale. A zero-height row the ticks are absolutely positioned along,
     so each tick's `left:%` lands it on the matching colour seam above. */
  .cb-scale {
    position: relative;
    margin: 0;
    height: 40px;
  }

  .cb-tick {
    position: absolute;
    top: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateX(-50%);
  }

  /* The mark: a short vertical line dropping from the bar's lower edge to its
     number, so the eye connects the number to the seam. */
  .cb-tick-mark {
    margin: 0;
    width: 2px;
    height: 9px;
    background: var(--sl-color-gray-3);
  }
  .cb-tick-label {
    margin: 2px 0 0;
    font-size: 12px;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  /* The redline tick at 0.3% — the line whose crossing means throttling. Thicker
     and red, with a tiny uppercase "redline" caption so the metaphor is explicit. */
  .cb-tick--redline .cb-tick-mark {
    width: 3px;
    height: 13px;
    background: var(--RED);
  }
  .cb-tick--redline .cb-tick-label {
    color: var(--RED);
  }
  .cb-tick-redline {
    margin: 1px 0 0;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--RED) 78%, var(--sl-color-gray-2));
  }

  /* Narrow viewports: shrink the labels so all three zones keep both lines on
     one strip rather than wrapping or clipping. */
  @media (max-width: 520px) {
    .cb-bar {
      height: 58px;
    }
    .cb-zone-name {
      font-size: 12px;
    }
    .cb-zone-range {
      font-size: 10.5px;
    }
    .cb-zone-arrow {
      font-size: 18px;
      right: 4px;
    }
  }
</style>
