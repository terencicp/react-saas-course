---
// InvoiceScreenMock — Chapter 076 Lesson 4
// ("The per-invoice comment thread clears the bar").
//
// The lesson's orienting visual: a hand-built mock of the invoice detail page at
// /invoices/[id]. This screen does not exist yet (ch077 builds it), so this is a
// CSS mock inside a <Figure>, NOT a <Screenshot> pointing at a real asset.
//
// Two columns, the seam the whole lesson is about, made literal:
//   ┌── Invoice summary ─────────┐  ┌── Comment thread ──────────┐
//   │ #INV-1042                  │  │ Dana · 2h   …              │
//   │ Billed to: Acme Corp       │  │ Priya · 1h  …              │
//   │ line items + total         │  │ Dana · 40m  …              │
//   │ Status: Sent · v3          │  │ You · now   …              │
//   └── calm / neutral region ───┘  │ [ post a comment ] [Post]  │
//                                    └── live / active region ────┘
//
// Colour language matches the rest of the chapter (SsrHydrationStage,
// TwoCachesInvalidation): the page-accent blue marks the LIVE region (the
// thread); the summary side is calm neutral chrome. The tint carries the
// "static vs live" split the lesson then turns into every decision.
//
// Pure HTML+CSS per the diagrams guide. `not-content` + a margin:0 reset on every
// node defeats Starlight's injected prose margins. Wrapped in <Figure> by the
// lesson, which supplies the card chrome + caption.

interface Comment {
	author: string;
	when: string;
	body: string;
	mine?: boolean;
}

const comments: Comment[] = [
	{ author: 'Dana', when: '2h', body: 'Customer disputes the design-review line — says it was quoted at half this.' },
	{ author: 'Priya', when: '1h', body: 'Pulled the original SOW. The quote was for one round; this invoice covers two.' },
	{ author: 'Dana', when: '40m', body: 'Got it. I’ll reply and attach the SOW so they can see the second round.' },
	{ author: 'You', when: 'just now', body: 'Sent. Marking this resolved once they confirm.', mine: true },
];

const lineItems = [
	{ label: 'Design review · 2 rounds', amount: '$4,800' },
	{ label: 'Implementation · 40h', amount: '$6,000' },
	{ label: 'Project management', amount: '$1,200' },
];
---

<div class="ism not-content">
	{/* ══ Left column: the static invoice summary (calm / neutral) ══════════ */}
	<section class="ism-col ism-col--summary">
		<span class="ism-col-tag">Invoice summary</span>

		<div class="ism-card ism-head">
			<span class="ism-head-no">Invoice #INV-1042</span>
			<span class="ism-head-due">Due Jun 30, 2026</span>
		</div>

		<div class="ism-card ism-billed">
			<span class="ism-label">Billed to</span>
			<span class="ism-billed-name">Acme Corp</span>
			<span class="ism-billed-sub">billing@acme.example · Net 30</span>
		</div>

		<div class="ism-card ism-items">
			<span class="ism-label">Line items</span>
			{lineItems.map((item) => (
				<div class="ism-row">
					<span class="ism-row-label">{item.label}</span>
					<span class="ism-row-amount">{item.amount}</span>
				</div>
			))}
			<div class="ism-row ism-row--total">
				<span class="ism-row-label">Total</span>
				<span class="ism-row-amount">$12,000</span>
			</div>
		</div>

		<div class="ism-banner">
			<span class="ism-banner-dot"></span>
			<span class="ism-banner-text">Status: Sent <span class="ism-sep">·</span> v3</span>
		</div>
	</section>

	{/* ══ Right column: the live comment thread (active / page accent) ══════ */}
	<section class="ism-col ism-col--thread">
		<span class="ism-col-tag ism-col-tag--live">
			<span class="ism-live-dot"></span>Comment thread
		</span>

		<div class="ism-stream">
			{comments.map((c) => (
				<div class={`ism-bubble${c.mine ? ' ism-bubble--mine' : ''}`}>
					<div class="ism-bubble-meta">
						<span class="ism-bubble-author">{c.author}</span>
						<span class="ism-bubble-when">· {c.when}</span>
					</div>
					<p class="ism-bubble-body">{c.body}</p>
				</div>
			))}
		</div>

		<div class="ism-compose">
			<div class="ism-textarea">Post a comment…</div>
			<button class="ism-post" type="button" tabindex="-1">Post</button>
		</div>
	</section>
</div>

<style>
	.ism {
		box-sizing: border-box;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		align-items: stretch;
		gap: 14px;
		padding: 4px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		--ism-accent: hsl(217, 91%, 56%);
	}
	.ism * {
		box-sizing: border-box;
		margin: 0;
	}

	/* ── Columns ──────────────────────────────────────────────────────────── */
	.ism-col {
		display: flex;
		flex-direction: column;
		gap: 8px;
		min-width: 0;
		padding: 12px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
	}
	.ism-col--thread {
		border-color: color-mix(in srgb, var(--ism-accent) 45%, transparent);
		background: color-mix(in srgb, var(--ism-accent) 7%, transparent);
	}

	.ism-col-tag {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--sl-color-gray-3, #64748b);
	}
	.ism-col-tag--live {
		color: color-mix(in srgb, var(--ism-accent) 75%, var(--sl-color-text));
	}
	.ism-live-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--ism-accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--ism-accent) 22%, transparent);
	}

	/* ── Summary cards ────────────────────────────────────────────────────── */
	.ism-card {
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 10px 12px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
	}
	.ism-label {
		font-size: 9.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3, #64748b);
	}

	.ism-head {
		flex-direction: row;
		align-items: baseline;
		justify-content: space-between;
	}
	.ism-head-no {
		font-size: 15px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}
	.ism-head-due {
		font-size: 11px;
		color: var(--sl-color-gray-3, #64748b);
	}

	.ism-billed-name {
		font-size: 13.5px;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
	}
	.ism-billed-sub {
		font-size: 11px;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── Line-items table ─────────────────────────────────────────────────── */
	.ism-items {
		gap: 5px;
	}
	.ism-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		font-size: 12px;
		color: var(--sl-color-text, #334155);
	}
	.ism-row-label {
		min-width: 0;
		color: var(--sl-color-gray-2, #475569);
	}
	.ism-row-amount {
		flex: 0 0 auto;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-white, #1e293b);
	}
	.ism-row--total {
		margin-top: 4px;
		padding-top: 6px;
		border-top: 1px solid var(--sl-color-gray-5, #cbd5e1);
		font-weight: 700;
		font-size: 13px;
	}
	.ism-row--total .ism-row-label,
	.ism-row--total .ism-row-amount {
		color: var(--sl-color-white, #1e293b);
	}

	/* ── Status / version banner ──────────────────────────────────────────── */
	.ism-banner {
		display: flex;
		align-items: center;
		gap: 7px;
		margin-top: auto;
		padding: 8px 12px;
		border-radius: 9px;
		border: 1px solid color-mix(in srgb, #16a34a 38%, transparent);
		background: color-mix(in srgb, #16a34a 10%, transparent);
	}
	.ism-banner-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #16a34a;
	}
	.ism-banner-text {
		font-size: 12px;
		font-weight: 600;
		color: color-mix(in srgb, #16a34a 65%, var(--sl-color-text));
	}
	.ism-sep {
		color: var(--sl-color-gray-3, #64748b);
		font-weight: 400;
	}

	/* ── Comment stream ───────────────────────────────────────────────────── */
	.ism-stream {
		display: flex;
		flex-direction: column;
		gap: 7px;
		flex: 1 1 auto;
		min-height: 0;
		max-height: 252px;
		overflow-y: auto;
		padding-right: 2px;
	}
	.ism-bubble {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 8px 11px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
	}
	.ism-bubble--mine {
		align-self: stretch;
		border-color: color-mix(in srgb, var(--ism-accent) 40%, transparent);
		background: color-mix(in srgb, var(--ism-accent) 11%, transparent);
	}
	.ism-bubble-meta {
		display: flex;
		align-items: baseline;
		gap: 5px;
	}
	.ism-bubble-author {
		font-size: 11.5px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}
	.ism-bubble-when {
		font-size: 10.5px;
		color: var(--sl-color-gray-3, #64748b);
	}
	.ism-bubble-body {
		font-size: 11.5px;
		line-height: 1.4;
		color: var(--sl-color-text, #334155);
	}

	/* ── Compose box ──────────────────────────────────────────────────────── */
	.ism-compose {
		display: flex;
		align-items: stretch;
		gap: 7px;
		margin-top: 1px;
	}
	.ism-textarea {
		flex: 1 1 auto;
		min-width: 0;
		padding: 9px 11px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-bg, #fff);
		font-size: 11.5px;
		color: var(--sl-color-gray-3, #64748b);
	}
	.ism-post {
		flex: 0 0 auto;
		padding: 0 16px;
		border: none;
		border-radius: 9px;
		background: var(--ism-accent);
		color: #fff;
		font-size: 12px;
		font-weight: 700;
		font-family: inherit;
		cursor: default;
	}

	/* Narrow viewports: stack the two columns. */
	@media (max-width: 560px) {
		.ism {
			grid-template-columns: 1fr;
		}
		.ism-stream {
			max-height: 200px;
		}
	}
</style>
