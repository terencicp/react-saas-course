---
// BoundaryMap — Chapter 076 Lesson 4
// ("The per-invoice comment thread clears the bar").
//
// The chapter's closing visual: the invoice page as a boundary map. One outer
// wrapper (page.tsx — a Server Component that renders a <HydrationBoundary>)
// holds five regions. Four are plain Server Components (neutral chrome); ONE —
// the comment thread — crosses the client boundary into TanStack Query (page
// accent). The single arrow (wired in the MDX) runs from the prefetch node on
// the wrapper to that one leaf, labeled "prefetched + hydrated", so the eye sees
// the server hand the first page to the only client region.
//
//   ┌─ page.tsx · Server Component + <HydrationBoundary> ──── [prefetchInfiniteQuery] ─┐
//   │  ┌ Invoice header ┐ ┌ Customer card ┐ ┌ Line items ┐ ┌ Status / version ┐        │
//   │  │  Server Comp.  │ │  Server Comp. │ │ Server Comp│ │   Server Comp.   │        │
//   │  └────────────────┘ └───────────────┘ └────────────┘ └──────────────────┘        │
//   │  ┌── Comment thread · 'use client' · TanStack Query ───────────────────────────┐ │
//   │  └──────────────────────────────────────────────────────────────────────────────┘ │
//   └────────────────────────────────────────────────────────────────────────────────┘
//
// Colour language matches the chapter (InvoiceScreenMock, TwoCacheLanes):
//   • neutral gray  = Server Component regions (zero client JS for their data)
//   • page-accent blue = the one client leaf on TanStack Query
//
// Boxes only — the <ArrowDiagram> wrapper in the MDX draws the arrow between the
// ids below and supplies the leader-line layer; <Figure> supplies the card.
//
// Pure HTML+CSS per the diagrams guide. `not-content` + a margin:0 reset on every
// node defeats Starlight's injected prose margins.

interface ServerRegion {
	id: string;
	label: string;
}

const serverRegions: ServerRegion[] = [
	{ id: 'bm-header', label: 'Invoice header' },
	{ id: 'bm-customer', label: 'Customer card' },
	{ id: 'bm-items', label: 'Line items' },
	{ id: 'bm-banner', label: 'Status / version banner' },
];
---

<div class="bm not-content">
	<div class="bm-wrap" id="bm-wrap">
		<header class="bm-wrap-head">
			<span class="bm-wrap-tag">
				<code>page.tsx</code> · Server Component + <code>&lt;HydrationBoundary&gt;</code>
			</span>
			<span class="bm-prefetch" id="bm-prefetch">
				<code>prefetchInfiniteQuery</code>
			</span>
		</header>

		<div class="bm-grid">
			{serverRegions.map((region) => (
				<div class="bm-region bm-region--server" id={region.id}>
					<span class="bm-region-label">{region.label}</span>
					<span class="bm-region-kind">Server Component</span>
				</div>
			))}
		</div>

		<div class="bm-region bm-region--client" id="bm-leaf">
			<span class="bm-leaf-label">
				<span class="bm-live-dot"></span>Comment thread
			</span>
			<span class="bm-leaf-kind">
				<code>'use client'</code> · TanStack Query
			</span>
		</div>
	</div>
</div>

<style>
	.bm {
		box-sizing: border-box;
		margin: 0;
		padding: 2px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		--bm-accent: hsl(217, 91%, 56%);
	}
	.bm * {
		box-sizing: border-box;
		margin: 0;
	}
	.bm code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 0.92em;
	}

	/* ── Outer wrapper: the Server-Component page ────────────────────────────── */
	.bm-wrap {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 14px;
		border-radius: 14px;
		border: 1.5px dashed var(--sl-color-gray-4, #94a3b8);
		background: color-mix(in srgb, var(--sl-color-gray-6) 35%, transparent);
	}

	.bm-wrap-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
	}
	.bm-wrap-tag {
		font-size: 11.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
	}
	.bm-wrap-tag code {
		color: var(--sl-color-white, #1e293b);
		font-weight: 700;
	}
	/* The prefetch node — the arrow's start point. */
	.bm-prefetch {
		flex: 0 0 auto;
		padding: 5px 11px;
		border-radius: 999px;
		border: 1.5px solid color-mix(in srgb, var(--bm-accent) 45%, transparent);
		background: color-mix(in srgb, var(--bm-accent) 10%, transparent);
		color: color-mix(in srgb, var(--bm-accent) 80%, var(--sl-color-text));
		white-space: nowrap;
	}
	.bm-prefetch code {
		font-size: 10.5px;
		font-weight: 700;
		color: inherit;
	}

	/* ── Server-Component region cards ───────────────────────────────────────── */
	.bm-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 10px;
	}
	.bm-region {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 0;
		padding: 12px 12px 11px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
	}
	.bm-region-label {
		font-size: 12.5px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		line-height: 1.25;
	}
	.bm-region-kind {
		font-size: 9.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── The one client leaf ─────────────────────────────────────────────────── */
	.bm-region--client {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
		padding: 13px 16px;
		border-width: 1.5px;
		border-color: color-mix(in srgb, var(--bm-accent) 55%, transparent);
		background: color-mix(in srgb, var(--bm-accent) 9%, transparent);
	}
	.bm-leaf-label {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 14px;
		font-weight: 700;
		color: color-mix(in srgb, var(--bm-accent) 30%, var(--sl-color-white));
	}
	.bm-live-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--bm-accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--bm-accent) 22%, transparent);
		flex: 0 0 auto;
	}
	.bm-leaf-kind {
		font-size: 11.5px;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
	}
	.bm-leaf-kind code {
		font-weight: 700;
		color: color-mix(in srgb, var(--bm-accent) 78%, var(--sl-color-text));
	}

	/* Narrow viewports: collapse the region grid to two columns, then one. */
	@media (max-width: 720px) {
		.bm-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	@media (max-width: 460px) {
		.bm-grid {
			grid-template-columns: 1fr;
		}
		.bm-region--client {
			flex-direction: column;
			align-items: flex-start;
			gap: 4px;
		}
	}
</style>
