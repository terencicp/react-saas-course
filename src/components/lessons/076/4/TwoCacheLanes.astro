---
// TwoCacheLanes — Chapter 076 Lesson 4
// ("The per-invoice comment thread clears the bar").
//
// One step-body for the `seq-two-cache-post` DiagramSequence. Renders the SAME
// two-lane stage every step — a left lane (Server Component cache) and a right
// lane (TanStack client cache) — and lights the active lane(s) for the step the
// caller asks for. Keeping every step identical in structure is the whole point:
// the student watches the *same two boxes* and sees which one changes at each
// instant of a single post.
//
//   ┌── Server Component cache ──┐      ┌── TanStack client cache ──┐
//   │  summary cards · count     │      │  useInfiniteQuery thread   │
//   │  [ state pill ]            │      │  [ comment rows ]          │
//   └────────────────────────────┘      └────────────────────────────┘
//
// One `step` prop (1–4) drives lane state via a data attribute, so all the
// per-step logic lives here and the MDX stays a clean list of four <DiagramStep>s.
//
// Colour language matches the chapter (InvoiceScreenMock, TwoCachesInvalidation):
//   • page-accent blue  = the TanStack / live region
//   • green             = fresh / confirmed (a cache that just reconciled, or a
//                         confirmed persisted row)
//   • amber             = "stale, refetch pending" (a cache marked for refetch)
//   • neutral gray      = idle / untouched
//
// Pure HTML+CSS per the diagrams guide. `not-content` + a margin:0 reset on every
// node defeats Starlight's injected prose margins. DiagramSequence supplies the
// outer card; this renders only one step's stage.

interface Props {
	/** Which step of the post sequence (1–4). */
	step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

// ── Per-step lane state ──────────────────────────────────────────────────────
// scState / tqState ∈ 'idle' | 'stale' | 'fresh'  → drives the lane tint + pill.
type LaneState = 'idle' | 'stale' | 'fresh';

const scState: LaneState = step === 1 ? 'idle' : step === 2 ? 'stale' : step === 3 ? 'stale' : 'fresh';
const tqState: LaneState = step < 3 ? 'idle' : step === 3 ? 'stale' : 'fresh';

const stateLabel: Record<LaneState, string> = {
	idle: 'untouched',
	stale: 'stale · refetch pending',
	fresh: 'fresh',
};

// The Server Component summary count ticks from 3 → 4 only once it reconciles (step 4).
const summaryCount = step === 4 ? 4 : 3;

// The optimistic comment row's status across the post.
// step 1: just prepended, unconfirmed. step 4: confirmed (same UUID). 2–3: in-flight.
const optimisticStatus: 'unconfirmed' | 'inflight' | 'confirmed' =
	step === 1 ? 'unconfirmed' : step === 4 ? 'confirmed' : 'inflight';
---

<div class="tcp not-content" data-step={step}>
	{/* ══ Left lane: the Server Component cache ═══════════════════════════════ */}
	<section class={`tcp-lane tcp-lane--${scState}`} data-lane="sc">
		<header class="tcp-lane-head">
			<span class="tcp-lane-title">Server Component cache</span>
			<span class={`tcp-pill tcp-pill--${scState}`}>{stateLabel[scState]}</span>
		</header>
		<div class="tcp-lane-body">
			<div class="tcp-summary">
				<span class="tcp-summary-label">Invoice summary</span>
				<span class="tcp-summary-count">{summaryCount} comments</span>
			</div>
			<span class="tcp-api"><code>updateTag(invoiceTag)</code></span>
		</div>
	</section>

	{/* ══ Right lane: the TanStack client cache ═══════════════════════════════ */}
	<section class={`tcp-lane tcp-lane--${tqState} tcp-lane--tq`} data-lane="tq">
		<header class="tcp-lane-head">
			<span class="tcp-lane-title">
				<span class="tcp-live-dot"></span>TanStack client cache
			</span>
			<span class={`tcp-pill tcp-pill--${tqState}`}>{stateLabel[tqState]}</span>
		</header>
		<div class="tcp-lane-body">
			<div class="tcp-thread">
				<span class="tcp-thread-label"><code>data.pages[0]</code></span>
				<div class={`tcp-row tcp-row--${optimisticStatus}`}>
					<span class="tcp-row-author">You</span>
					<span class="tcp-row-tag">
						{optimisticStatus === 'unconfirmed' && 'optimistic · unconfirmed'}
						{optimisticStatus === 'inflight' && 'optimistic · in flight'}
						{optimisticStatus === 'confirmed' && 'confirmed · same UUID'}
					</span>
				</div>
				<div class="tcp-row tcp-row--old">
					<span class="tcp-row-author">Dana</span>
					<span class="tcp-row-tag tcp-row-tag--muted">40m</span>
				</div>
			</div>
			<span class="tcp-api"><code>invalidateQueries(commentKeys…)</code></span>
		</div>
	</section>
</div>

<style>
	.tcp {
		box-sizing: border-box;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		align-items: stretch;
		gap: 14px;
		padding: 6px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		--tcp-accent: hsl(217, 91%, 56%);
		--tcp-fresh: #16a34a;
		--tcp-stale: #d97706;
	}
	.tcp * {
		box-sizing: border-box;
		margin: 0;
	}
	.tcp code {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
	}

	/* ── Lanes ───────────────────────────────────────────────────────────────── */
	.tcp-lane {
		display: flex;
		flex-direction: column;
		gap: 10px;
		min-width: 0;
		padding: 12px;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
		transition: border-color 0.2s, background 0.2s;
	}
	/* Idle lanes read as dimmed chrome so the lit lane pops. */
	.tcp-lane--idle {
		opacity: 0.62;
	}
	/* Step 1 is the optimistic write: the TanStack lane is the visual focus even
	   though no cache has been *invalidated* yet, so keep it at full strength. */
	.tcp[data-step='1'] .tcp-lane--tq {
		opacity: 1;
	}
	/* A stale lane is the one that just got marked for refetch — amber edge. */
	.tcp-lane--stale {
		border-color: color-mix(in srgb, var(--tcp-stale) 55%, transparent);
		background: color-mix(in srgb, var(--tcp-stale) 8%, transparent);
	}
	/* A fresh lane has reconciled with the server — green edge. */
	.tcp-lane--fresh {
		border-color: color-mix(in srgb, var(--tcp-fresh) 50%, transparent);
		background: color-mix(in srgb, var(--tcp-fresh) 8%, transparent);
	}

	.tcp-lane-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
	}
	.tcp-lane-title {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		line-height: 1.2;
	}
	.tcp-live-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--tcp-accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--tcp-accent) 22%, transparent);
		flex: 0 0 auto;
	}

	/* ── State pills ───────────────────────────────────────────────────────── */
	.tcp-pill {
		flex: 0 0 auto;
		font-size: 9.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding: 2px 7px;
		border-radius: 999px;
		white-space: nowrap;
		border: 1px solid transparent;
	}
	.tcp-pill--idle {
		color: var(--sl-color-gray-3, #64748b);
		border-color: var(--sl-color-gray-5, #cbd5e1);
		background: color-mix(in srgb, var(--sl-color-gray-5) 22%, transparent);
	}
	.tcp-pill--stale {
		color: color-mix(in srgb, var(--tcp-stale) 78%, var(--sl-color-text));
		border-color: color-mix(in srgb, var(--tcp-stale) 45%, transparent);
		background: color-mix(in srgb, var(--tcp-stale) 12%, transparent);
	}
	.tcp-pill--fresh {
		color: color-mix(in srgb, var(--tcp-fresh) 70%, var(--sl-color-text));
		border-color: color-mix(in srgb, var(--tcp-fresh) 45%, transparent);
		background: color-mix(in srgb, var(--tcp-fresh) 12%, transparent);
	}

	/* ── Lane body ─────────────────────────────────────────────────────────── */
	.tcp-lane-body {
		display: flex;
		flex-direction: column;
		gap: 9px;
		flex: 1 1 auto;
	}

	/* Server Component summary card. */
	.tcp-summary {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		padding: 10px 12px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
	}
	.tcp-summary-label {
		font-size: 9.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3, #64748b);
	}
	.tcp-summary-count {
		font-size: 13px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		font-variant-numeric: tabular-nums;
	}

	/* TanStack thread card. */
	.tcp-thread {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 10px 12px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
	}
	.tcp-thread-label {
		font-size: 10px;
		color: var(--sl-color-gray-3, #64748b);
	}
	.tcp-thread-label code {
		font-size: 10.5px;
	}
	.tcp-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		padding: 5px 8px;
		border-radius: 7px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-gray-6, #f1f5f9);
	}
	.tcp-row-author {
		font-size: 11.5px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}
	.tcp-row-tag {
		font-size: 10px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
	}
	.tcp-row-tag--muted {
		font-weight: 500;
	}

	/* The optimistic "You" row changes appearance as the post progresses. */
	.tcp-row--unconfirmed {
		border-color: color-mix(in srgb, var(--tcp-accent) 45%, transparent);
		background: color-mix(in srgb, var(--tcp-accent) 10%, transparent);
		border-style: dashed;
	}
	.tcp-row--unconfirmed .tcp-row-tag {
		color: color-mix(in srgb, var(--tcp-accent) 78%, var(--sl-color-text));
	}
	.tcp-row--inflight {
		border-color: color-mix(in srgb, var(--tcp-accent) 40%, transparent);
		background: color-mix(in srgb, var(--tcp-accent) 8%, transparent);
		border-style: dashed;
	}
	.tcp-row--inflight .tcp-row-tag {
		color: color-mix(in srgb, var(--tcp-accent) 72%, var(--sl-color-text));
	}
	.tcp-row--confirmed {
		border-color: color-mix(in srgb, var(--tcp-fresh) 48%, transparent);
		background: color-mix(in srgb, var(--tcp-fresh) 10%, transparent);
	}
	.tcp-row--confirmed .tcp-row-tag {
		color: color-mix(in srgb, var(--tcp-fresh) 68%, var(--sl-color-text));
	}

	/* ── The invalidation API line per lane ──────────────────────────────────── */
	.tcp-api {
		margin-top: auto;
		font-size: 10.5px;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		text-align: center;
		opacity: 0.7;
	}
	.tcp-api code {
		font-size: 10.5px;
	}
	/* The API line lights up on the step its cache is being invalidated. */
	.tcp-lane--stale .tcp-api {
		opacity: 1;
		color: color-mix(in srgb, var(--tcp-stale) 80%, var(--sl-color-text));
	}

	/* Narrow viewports: stack the two lanes. */
	@media (max-width: 560px) {
		.tcp {
			grid-template-columns: 1fr;
		}
	}
</style>
