---
/**
 * "Two systems, two phases" strip for Lesson 076.1.
 *
 * A horizontal two-band timeline. The left band is the initial paint, owned by
 * the Server Component (prefetch -> hydrate); the right band is the live phase,
 * owned by the TanStack client cache (poll / mutate / scroll). A directional
 * connector between them reads left -> right as time, so the bands register as
 * two *phases* of one screen rather than two systems competing.
 *
 * The pedagogical job is to make one sentence visual: the two caches do not
 * fight, they own different moments of the same surface. Blue marks the
 * Server-Component band, violet the TanStack band, matching the mark palette
 * used by the sibling figures in this lesson.
 */

interface Band {
  /** The phase, rendered as a small kicker above the title. */
  phase: string;
  /** The owning system, the band's heading. */
  title: string;
  /** The work this phase does, a one-line subtitle. */
  work: string;
  /** Mark-palette accent. */
  accent: 'blue' | 'violet';
}

const bands: Band[] = [
  {
    phase: 'Initial paint',
    title: 'Server Component',
    work: 'prefetch → hydrate',
    accent: 'blue',
  },
  {
    phase: 'Live interactions',
    title: 'TanStack client cache',
    work: 'poll · mutate · scroll',
    accent: 'violet',
  },
];
---

<div class="two-phases">
  <ol class="bands" role="list">
    <li class={`band accent-${bands[0].accent}`}>
      <span class="phase">{bands[0].phase}</span>
      <span class="title">{bands[0].title}</span>
      <span class="work">{bands[0].work}</span>
    </li>

    <li class="connector" aria-hidden="true">
      <span class="connector-label">then</span>
      <span class="arrow">→</span>
    </li>

    <li class={`band accent-${bands[1].accent}`}>
      <span class="phase">{bands[1].phase}</span>
      <span class="title">{bands[1].title}</span>
      <span class="work">{bands[1].work}</span>
    </li>
  </ol>

  <p class="axis">
    <span class="axis-start">first paint</span>
    <span class="axis-line" aria-hidden="true"></span>
    <span class="axis-end">over time</span>
  </p>
</div>

<style>
  .two-phases {
    margin: 0;
  }

  .bands {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .band {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 1rem 1.1rem;
    border: 1px solid var(--accent-brd);
    border-radius: 0.6rem;
    background: var(--accent-bg);
  }

  .accent-blue {
    --accent-bg: var(--mark-blue-bg);
    --accent-brd: var(--mark-blue-brd);
  }
  .accent-violet {
    --accent-bg: var(--mark-violet-bg);
    --accent-brd: var(--mark-violet-brd);
  }

  .phase {
    margin: 0;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .title {
    margin: 0.3rem 0 0;
    font-size: var(--sl-text-base);
    font-weight: 600;
    line-height: 1.25;
    color: var(--sl-color-white);
  }

  .work {
    margin: 0.4rem 0 0;
    font-family: var(--__sl-font-mono, ui-monospace, monospace);
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
  }

  /* The directional connector: left -> right reads as time. */
  .connector {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    margin: 0;
    padding: 0;
  }

  .connector-label {
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .arrow {
    font-size: 1.5rem;
    line-height: 1;
    color: var(--sl-color-gray-3);
  }

  /* The time axis under both bands. */
  .axis {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0.7rem 0 0;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }

  .axis-line {
    flex: 1;
    height: 1px;
    background: var(--sl-color-gray-5);
  }

  .axis-end {
    font-style: italic;
  }

  @media (max-width: 32rem) {
    .bands {
      flex-direction: column;
    }
    .connector {
      flex-direction: row;
      gap: 0.4rem;
    }
    .arrow {
      transform: rotate(90deg);
    }
  }
</style>
