---
/**
 * "The four defaults" recap table for Lesson 076.1.
 *
 * Four rows, three columns: the default → the state shape it owns → where the
 * student met it. The pedagogical job is glanceability — make the student feel
 * how much of a SaaS app the four platform defaults already cover, so the
 * upcoming "what's left for TanStack Query" reads as a genuinely narrow band.
 * The first column (the default itself) is the load-bearing axis, rendered as
 * a tinted pill so the four tools register as a set at a glance.
 */

interface Row {
  /** The default, rendered as inline code in a tinted pill. */
  tool: string;
  /** The state shape this default owns. */
  owns: string;
  /** The chapter (named loosely) where the student met it. */
  where: string;
}

const rows: Row[] = [
  {
    tool: 'Server Components',
    owns: 'Server data, read and streamed into the page',
    where: 'the App Router chapters',
  },
  {
    tool: 'Server Actions',
    owns: 'Mutations, with revalidation for read-your-writes',
    where: 'the Server Actions chapter',
  },
  {
    tool: 'useState',
    owns: 'Transient UI state inside one component',
    where: 'the React chapters',
  },
  {
    tool: 'nuqs (URL)',
    owns: 'Shareable, refreshable view state',
    where: 'the URL-state chapter',
  },
];
---

<div class="four-defaults">
  <table>
    <caption class="sr-only">
      The four platform defaults, the state each owns, and where the student met it
    </caption>
    <thead>
      <tr>
        <th scope="col">Default</th>
        <th scope="col">The state it owns</th>
        <th scope="col">Where you met it</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            <th scope="row">
              <code class="tool-pill">{row.tool}</code>
            </th>
            <td>{row.owns}</td>
            <td class="where">{row.where}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .four-defaults {
    overflow-x: auto;
  }

  table {
    width: 100%;
    margin: 0;
    border-collapse: collapse;
    font-size: var(--sl-text-sm);
    line-height: 1.4;
  }

  /* Accessible name lives in <caption>; <Figure> shows the visible caption. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  thead th {
    text-align: left;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding: 0 0.85rem 0.55rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  tbody th,
  tbody td {
    padding: 0.7rem 0.85rem;
    vertical-align: middle;
    border-bottom: 1px solid var(--sl-color-hairline-shade);
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: 0;
  }

  /* Row-identifying cell: the default itself — the load-bearing axis. */
  tbody th {
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
  }

  .tool-pill {
    display: inline-block;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    line-height: 1;
    padding: 0.32rem 0.6rem;
    border-radius: 999px;
    background: var(--mark-blue-bg);
    border: 1px solid var(--mark-blue-brd);
    color: var(--sl-color-white);
    white-space: nowrap;
  }

  tbody td {
    color: var(--sl-color-gray-2);
  }

  .where {
    color: var(--sl-color-gray-3);
  }

  @media (max-width: 30rem) {
    tbody th {
      white-space: normal;
    }
  }
</style>
