---
/**
 * "The four triggers" consolidation card for Lesson 076.1.
 *
 * A 2x2 grid of four cards, one per accepted justification for reaching past
 * the platform defaults. Each card carries a title (the trigger), a one-line
 * workload, and an "instead of <beaten default>" line that renders the beaten
 * default struck-through — the trigger is only legible as the point where one
 * specific default stops pulling its weight, so the foil is shown, not hidden.
 *
 * The pedagogical job is glanceability: one photographable image of the
 * four-slot schema the student drops each workload into. Each card takes a
 * distinct mark color so the four register as a set of four at a glance.
 */

interface Card {
  /** The trigger, the card's heading. */
  title: string;
  /** One-line description of the workload that meets the trigger. */
  workload: string;
  /** The default this trigger beats, rendered struck-through as inline code. */
  instead: string;
  /** Optional note (used to flag the weakest trigger). */
  note?: string;
  /** Mark-palette accent: drives the card's tinted border + title swatch. */
  accent: 'blue' | 'violet' | 'orange' | 'green';
}

const cards: Card[] = [
  {
    title: 'Polling / frequent refetches',
    workload: 'Learn about server changes on a cadence, with no user action.',
    instead: 'router.refresh() on an interval',
    accent: 'blue',
  },
  {
    title: 'Optimistic into a cache',
    workload: 'An optimistic value must land inside a cached query.',
    instead: 'useOptimistic',
    accent: 'violet',
  },
  {
    title: 'Infinite scroll with reuse',
    workload: 'Accumulate pages, then scroll back without a refetch.',
    instead: 'cursor pagination',
    accent: 'orange',
  },
  {
    title: 'Cross-view caching',
    workload: 'Re-mount the same data across views without refetching.',
    instead: 'the Router Cache',
    note: 'weakest trigger',
    accent: 'green',
  },
];
---

<ul class="trigger-cards" role="list">
  {
    cards.map((card) => (
      <li class={`card accent-${card.accent}`}>
        <p class="title">{card.title}</p>
        <p class="workload">{card.workload}</p>
        <p class="instead">
          <span class="instead-label">instead of</span>
          <code class="beaten">{card.instead}</code>
        </p>
        {card.note && <span class="note">{card.note}</span>}
      </li>
    ))
  }
</ul>

<style>
  .trigger-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--accent-brd);
    border-left: 3px solid var(--accent-brd);
    border-radius: 0.6rem;
    background: var(--accent-bg);
  }

  .accent-blue {
    --accent-bg: var(--mark-blue-bg);
    --accent-brd: var(--mark-blue-brd);
  }
  .accent-violet {
    --accent-bg: var(--mark-violet-bg);
    --accent-brd: var(--mark-violet-brd);
  }
  .accent-orange {
    --accent-bg: var(--mark-orange-bg);
    --accent-brd: var(--mark-orange-brd);
  }
  .accent-green {
    --accent-bg: var(--mark-green-bg);
    --accent-brd: var(--mark-green-brd);
  }

  .title {
    margin: 0;
    font-size: var(--sl-text-base);
    font-weight: 600;
    line-height: 1.25;
    color: var(--sl-color-white);
  }

  .workload {
    margin: 0.4rem 0 0;
    font-size: var(--sl-text-sm);
    line-height: 1.4;
    color: var(--sl-color-gray-2);
  }

  .instead {
    margin: 0.6rem 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
    font-size: var(--sl-text-xs);
  }

  .instead-label {
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  /* The beaten default — struck through to read as the thing it replaces. */
  .beaten {
    background: transparent;
    padding: 0;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-decoration: line-through;
    text-decoration-color: var(--accent-brd);
    text-decoration-thickness: 1.5px;
    white-space: nowrap;
  }

  .note {
    margin-top: 0.55rem;
    align-self: flex-start;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    line-height: 1;
    padding: 0.28rem 0.5rem;
    border-radius: 999px;
    background: var(--sl-color-bg);
    border: 1px solid var(--accent-brd);
    color: var(--sl-color-gray-2);
  }

  @media (max-width: 34rem) {
    .trigger-cards {
      grid-template-columns: 1fr;
    }
    .beaten {
      white-space: normal;
    }
  }
</style>
