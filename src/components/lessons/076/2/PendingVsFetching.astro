---
// The isPending / isFetching truth table for useQuery, as a four-column grid:
// Moment · isPending · isFetching · What the user sees. Three data rows — cold
// first load, idle-fresh, background refetch. The two boolean columns carry the
// whole signal: a filled green pill for `true`, a recessive outline pill for
// `false`, so each flag's column reads straight down. The fourth column renders
// a tiny visual of the actual UI state — skeleton bars on the cold row, settled
// content lines on the idle row, content + a small spinner on the refetch row —
// so the abstract booleans land on a concrete screen.
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid with a fixed four-column
// count drives the layout so it never wraps unpredictably; the `margin: 0` reset
// on every inner element defeats Starlight's prose-margin injection. green-600 is
// the only saturated fill (the `true` pill) and reads on both light and dark
// theme; everything else is neutral chrome.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

type UiKind = "skeleton" | "settled" | "refetch";

type Row = {
  moment: string; // the row's identity — the moment in the query lifecycle
  note: string; // the small print under the moment label
  isPending: boolean;
  isFetching: boolean;
  ui: UiKind; // which mini-UI to paint in the last column
  uiLabel: string; // caption under the mini-UI
};

const ROWS: Row[] = [
  {
    moment: "First load",
    note: "cold — nothing cached yet",
    isPending: true,
    isFetching: true,
    ui: "skeleton",
    uiLabel: "Skeleton",
  },
  {
    moment: "Idle, data fresh",
    note: "served from cache",
    isPending: false,
    isFetching: false,
    ui: "settled",
    uiLabel: "The content, sitting still",
  },
  {
    moment: "Background refetch",
    note: "poll / refocus / invalidation",
    isPending: false,
    isFetching: true,
    ui: "refetch",
    uiLabel: "The content, quietly freshening",
  },
];

const HEADERS = ["Moment", "isPending", "isFetching", "What the user sees"];

// ---- styles -------------------------------------------------------------

const grid = [
  reset,
  "display: grid",
  // Moment column carries the row identity; the two boolean columns are narrow
  // (just a pill); the UI column is widest. Fixed column count → no wrap surprises.
  "grid-template-columns: minmax(150px, 1.15fr) minmax(104px, 0.7fr) minmax(104px, 0.7fr) minmax(180px, 1.4fr)",
  "gap: 6px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// Column header cell — small uppercase caption above its column.
const headCell = [
  reset,
  sans,
  "padding: 4px 10px 8px",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The two boolean-column headers are monospace (they name the flag) and centered
// over their centered pills.
const headFlag = [
  reset,
  mono,
  "padding: 4px 6px 8px",
  "font-size: 11.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "text-align: center",
  "color: var(--sl-color-gray-2)",
].join("; ");

// Body cell shell — shared by every data cell.
const cellBase = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 6px",
  "padding: 14px 12px",
  "border-radius: 9px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
  "box-sizing: border-box",
  "min-height: 78px",
].join("; ");

// The Moment cell gets a hairline accent on the left so each row reads as a unit.
const momentCell = [
  cellBase,
  "border-left: 3px solid var(--sl-color-gray-4)",
].join("; ");

const momentText = [
  reset,
  sans,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.25",
  "color: var(--sl-color-white)",
].join("; ");

const momentNote = [
  reset,
  sans,
  "font-size: 11.5px",
  "line-height: 1.3",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The boolean cells center their single pill.
const flagCell = [cellBase, "align-items: center"].join("; ");

// `true` → filled green-600 pill with white text — the saturated signal.
const truePill = [
  reset,
  mono,
  "display: inline-flex",
  "align-items: center",
  "padding: 4px 12px",
  "border-radius: 999px",
  "background: #16a34a",
  "color: #ffffff",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1",
].join("; ");

// `false` → recessive outline pill so the `true` cells pop down the column.
const falsePill = [
  reset,
  mono,
  "display: inline-flex",
  "align-items: center",
  "padding: 4px 12px",
  "border-radius: 999px",
  "background: transparent",
  "color: var(--sl-color-gray-3)",
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1",
  "border: 1px solid var(--sl-color-gray-4)",
].join("; ");

// The UI-preview cell holds the mini mockup + a caption.
const uiCell = [cellBase, "align-items: stretch"].join("; ");

// A tiny window frame the mini-UI paints inside.
const mockFrame = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 5px",
  "padding: 8px 9px",
  "border-radius: 6px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-bg)",
].join("; ");

// A skeleton placeholder bar (no real content).
const skelBar = (w: string) =>
  [
    reset,
    "height: 8px",
    "border-radius: 4px",
    `width: ${w}`,
    "background: var(--sl-color-gray-4)",
  ].join("; ");

// A settled content line (real text stand-in).
const lineBar = (w: string) =>
  [
    reset,
    "height: 8px",
    "border-radius: 4px",
    `width: ${w}`,
    "background: var(--sl-color-gray-2)",
  ].join("; ");

// Header row of the mini-UI: a content line plus an optional spinner on the right.
const mockHeaderRow = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: space-between",
  "gap: 8px",
].join("; ");

const uiLabelText = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");
---

<div class="not-content" style={grid}>
  {/* Header row */}
  {
    HEADERS.map((h, i) => (
      <div style={i === 1 || i === 2 ? headFlag : headCell}>{h}</div>
    ))
  }

  {/* One grid row per moment */}
  {
    ROWS.map((r) => (
      <Fragment>
        <div style={momentCell}>
          <span style={momentText}>{r.moment}</span>
          <span style={momentNote}>{r.note}</span>
        </div>

        <div style={flagCell}>
          <span style={r.isPending ? truePill : falsePill}>
            {r.isPending ? "true" : "false"}
          </span>
        </div>

        <div style={flagCell}>
          <span style={r.isFetching ? truePill : falsePill}>
            {r.isFetching ? "true" : "false"}
          </span>
        </div>

        <div style={uiCell}>
          <div style={mockFrame}>
            {r.ui === "skeleton" && (
              <Fragment>
                <div style={skelBar("70%")} />
                <div style={skelBar("90%")} />
                <div style={skelBar("55%")} />
              </Fragment>
            )}

            {r.ui === "settled" && (
              <Fragment>
                <div style={mockHeaderRow}>
                  <div style={lineBar("60%")} />
                </div>
                <div style={lineBar("90%")} />
                <div style={lineBar("75%")} />
              </Fragment>
            )}

            {r.ui === "refetch" && (
              <Fragment>
                <div style={mockHeaderRow}>
                  <div style={lineBar("55%")} />
                  <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#16a34a"
                    stroke-width="3"
                    stroke-linecap="round"
                    aria-hidden="true"
                    style="margin: 0; display: block; flex: none;"
                  >
                    <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                  </svg>
                </div>
                <div style={lineBar("90%")} />
                <div style={lineBar("75%")} />
              </Fragment>
            )}
          </div>
          <span style={uiLabelText}>{r.uiLabel}</span>
        </div>
      </Fragment>
    ))
  }
</div>
