---
// The useMutation lifecycle as a horizontal timeline, one highlighted stage per
// step. The spine is linear — mutate(input) → onMutate → [request in flight] —
// then forks into the success/error branch (onSuccess on top, onError below)
// and converges on onSettled. The pedagogical load-bearing piece is the
// `context` channel: a labelled connector running from onMutate down to onError,
// drawn as the spine of the rollback story. The `active` prop names which stage
// is lit; the success/error fork lights its winning lane.
//
// Pure HTML + CSS, devtools-inspectable, inline styles so it survives Starlight's
// prose-margin injection. Stage chips use Starlight gray tokens for the resting
// state; the active chip gets the sequence accent (blue), the success lane goes
// green and the error lane red so the fork reads at a glance. The component is
// rendered once per DiagramStep, so every variant occupies the same footprint and
// the DiagramSequence stage never reflows.

type Active =
  | "mutate"
  | "onMutate"
  | "inflight"
  | "onSuccess"
  | "onError"
  | "onSettled";

interface Props {
  active: Active;
}

const { active } = Astro.props;

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const ACCENT = "hsl(217, 91%, 60%)"; // matches the DiagramSequence slider accent
const SUCCESS = "#16a34a"; // green-600
const ERROR = "#dc2626"; // red-600

// Whether the success / error fork lanes are the lit branch this step.
const successLit = active === "onSuccess";
const errorLit = active === "onError";
// The context channel is the story spine; emphasise it whenever onMutate or the
// error lane is the focus, since that is the moment the handoff matters.
const channelLit = active === "onMutate" || active === "onError";

// ---- shared chip styling ------------------------------------------------

type ChipState = "rest" | "active" | "success" | "error";

const chip = (state: ChipState, kind: "code" | "label" = "code") => {
  const base = [
    reset,
    kind === "code" ? mono : sans,
    "display: inline-flex",
    "align-items: center",
    "justify-content: center",
    "text-align: center",
    "padding: 9px 12px",
    "border-radius: 9px",
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.2",
    "box-sizing: border-box",
    "min-width: 0",
    "transition: none",
  ];
  if (state === "active")
    return [
      ...base,
      `background: ${ACCENT}`,
      "color: #ffffff",
      `border: 1px solid ${ACCENT}`,
      `box-shadow: 0 0 0 4px color-mix(in srgb, ${ACCENT} 22%, transparent)`,
    ].join("; ");
  if (state === "success")
    return [
      ...base,
      `background: color-mix(in srgb, ${SUCCESS} 16%, var(--sl-color-gray-6))`,
      `color: var(--sl-color-white)`,
      `border: 1px solid ${SUCCESS}`,
      `box-shadow: 0 0 0 4px color-mix(in srgb, ${SUCCESS} 20%, transparent)`,
    ].join("; ");
  if (state === "error")
    return [
      ...base,
      `background: color-mix(in srgb, ${ERROR} 16%, var(--sl-color-gray-6))`,
      `color: var(--sl-color-white)`,
      `border: 1px solid ${ERROR}`,
      `box-shadow: 0 0 0 4px color-mix(in srgb, ${ERROR} 20%, transparent)`,
    ].join("; ");
  // rest
  return [
    ...base,
    "background: var(--sl-color-gray-6)",
    "color: var(--sl-color-gray-2)",
    "border: 1px solid var(--sl-color-gray-5)",
  ].join("; ");
};

// A short connector arrow between two chips on the same lane. It shrinks on
// narrow viewports (flex-basis with a floor) so the spine stays single-row.
const connector = (lit = false) =>
  [
    reset,
    "flex: 1 1 8px",
    "min-width: 8px",
    "max-width: 22px",
    "align-self: center",
    "height: 2px",
    "border-radius: 1px",
    lit
      ? `background: ${ACCENT}`
      : "background: var(--sl-color-gray-4)",
    "position: relative",
  ].join("; ");

// ---- layout shells ------------------------------------------------------

const root = [
  reset,
  sans,
  "width: 100%",
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 0",
].join("; ");

// The spine: mutate → onMutate → inflight, laid out in a row.
const spine = [
  reset,
  "display: flex",
  "align-items: stretch",
  "gap: 4px",
  "flex-wrap: nowrap",
  "width: 100%",
].join("; ");

// Spine chips may shrink and the long "request in flight" label may wrap.
const spineChip = (s: ChipState, kind: "code" | "label" = "code") =>
  [chip(s, kind), "flex: 0 1 auto", "padding-left: 10px", "padding-right: 10px"].join(
    "; ",
  );

// The fork region: a left "split" rail, then the two stacked branch lanes,
// then a "join" rail into onSettled.
const forkWrap = [
  reset,
  "display: grid",
  "grid-template-columns: auto auto 1fr auto auto",
  "align-items: center",
  "gap: 8px",
  "margin-top: 14px",
].join("; ");

// Vertical rail that splits the spine into two lanes (and the symmetric join).
const railVertical = (topLit: boolean, botLit: boolean) =>
  [
    reset,
    "flex: 0 0 auto",
    "width: 2px",
    "height: 74px",
    "border-radius: 1px",
    "background: linear-gradient(to bottom," +
      ` ${topLit ? SUCCESS : "var(--sl-color-gray-4)"} 0 50%,` +
      ` ${botLit ? ERROR : "var(--sl-color-gray-4)"} 50% 100%)`,
  ].join("; ");

// A short horizontal stub off a rail into a lane chip.
const stub = (lit: boolean, color: string) =>
  [
    reset,
    "width: 16px",
    "height: 2px",
    "border-radius: 1px",
    lit ? `background: ${color}` : "background: var(--sl-color-gray-4)",
  ].join("; ");

const laneStack = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 26px",
  "justify-content: center",
].join("; ");

const lane = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 0",
].join("; ");

// The context channel: a labelled connector dropping from onMutate down toward
// the error lane. Rendered as an absolutely-anchored band under the spine.
const channelRow = [
  reset,
  "display: flex",
  "align-items: center",
  "flex-wrap: wrap",
  "gap: 8px",
  "margin-top: 12px",
  "padding: 8px 10px",
  "border-radius: 9px",
  "border: 1px dashed",
  channelLit
    ? `border-color: ${ACCENT}`
    : "border-color: var(--sl-color-gray-5)",
  channelLit
    ? `background: color-mix(in srgb, ${ACCENT} 8%, transparent)`
    : "background: transparent",
].join("; ");

const channelText = [
  reset,
  sans,
  "font-size: 12px",
  "line-height: 1.4",
  "flex: 1 1 220px",
  "min-width: 180px",
  channelLit ? "color: var(--sl-color-white)" : "color: var(--sl-color-gray-3)",
].join("; ");

const tokenChip = (lit: boolean) =>
  [
    reset,
    mono,
    "display: inline-flex",
    "align-items: center",
    "padding: 3px 8px",
    "border-radius: 6px",
    "font-size: 11.5px",
    "font-weight: 700",
    "flex: 0 0 auto",
    lit
      ? `background: ${ACCENT}`
      : "background: var(--sl-color-gray-5)",
    lit ? "color: #ffffff" : "color: var(--sl-color-gray-2)",
  ].join("; ");

const arrowGlyph = (lit: boolean) =>
  [
    reset,
    sans,
    "font-size: 14px",
    "font-weight: 700",
    "flex: 0 0 auto",
    lit ? `color: ${ACCENT}` : "color: var(--sl-color-gray-4)",
  ].join("; ");
---

<div class="not-content" style={root}>
  {/* Spine: the linear lead-up before the request resolves */}
  <div style={spine}>
    <span style={spineChip(active === "mutate" ? "active" : "rest")}>
      mutate(input)
    </span>
    <span style={connector(active === "mutate" || active === "onMutate")} />
    <span style={spineChip(active === "onMutate" ? "active" : "rest")}>
      onMutate
    </span>
    <span style={connector(active === "onMutate" || active === "inflight")} />
    <span style={spineChip(active === "inflight" ? "active" : "rest", "label")}>
      request in flight
    </span>
  </div>

  {/* Fork: split rail → two stacked lanes → join rail → onSettled */}
  <div style={forkWrap}>
    {/* split rail */}
    <span style={railVertical(successLit, errorLit)} />

    {/* stubs into each lane */}
    <div style={[reset, "display: flex", "flex-direction: column", "gap: 26px"].join("; ")}>
      <span style={stub(successLit, SUCCESS)} />
      <span style={stub(errorLit, ERROR)} />
    </div>

    {/* the two branch lanes */}
    <div style={laneStack}>
      <div style={lane}>
        <span style={chip(successLit ? "success" : "rest")}>onSuccess</span>
      </div>
      <div style={lane}>
        <span style={chip(errorLit ? "error" : "rest")}>onError</span>
      </div>
    </div>

    {/* stubs out of each lane into the join rail */}
    <div style={[reset, "display: flex", "flex-direction: column", "gap: 26px"].join("; ")}>
      <span style={stub(successLit || active === "onSettled", successLit ? SUCCESS : "var(--sl-color-gray-4)")} />
      <span style={stub(errorLit || active === "onSettled", errorLit ? ERROR : "var(--sl-color-gray-4)")} />
    </div>

    {/* join rail + onSettled */}
    <div style={[reset, "display: flex", "align-items: center", "gap: 8px"].join("; ")}>
      <span style={railVertical(successLit || active === "onSettled", errorLit || active === "onSettled")} />
      <span style={connector(active === "onSettled")} />
      <span style={chip(active === "onSettled" ? "active" : "rest")}>
        onSettled
      </span>
    </div>
  </div>

  {/* The rollback channel: onMutate returns context, which rides to onError */}
  <div style={channelRow}>
    <span style={tokenChip(channelLit)}>onMutate</span>
    <span style={arrowGlyph(channelLit)}>→</span>
    <span style={tokenChip(channelLit)}>context</span>
    <span style={arrowGlyph(channelLit)}>→</span>
    <span style={tokenChip(channelLit)}>onError</span>
    <span style={channelText}>
      the rollback channel — the snapshot <code style={[mono, "font-size: 11.5px"].join("; ")}>onMutate</code> stashes rides forward as <code style={[mono, "font-size: 11.5px"].join("; ")}>context</code> to <code style={[mono, "font-size: 11.5px"].join("; ")}>onError</code>
    </span>
  </div>
</div>
