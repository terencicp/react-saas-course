---
// SsrHydrationStage — Chapter 076 Lesson 3
// ("Wiring TanStack Query without leaking the cache across requests").
//
// The lesson's primary diagram: the dehydrate→hydrate data flow across the TWO
// QueryClients. One static scene, re-rendered once per DiagramSequence step with
// a different `active` token, so every step shares the same layout/height and
// only the highlight moves — the slider scrubs the *same* page-1 payload from a
// server-side cache fill, across the wire, into a browser-side cache inherit.
//
//   ┌── Server ──────────┐   RSC payload   ┌── Browser ─────────┐
//   │  QueryClient (req) │ ───────────────▶│ QueryClient (singl)│
//   │  ▸ page 1 ┄ pending│   HTML + state  │  ▸ page 1 inherited │
//   │  dehydrated state  │                 │  CommentThread warm │
//   └────────────────────┘                 └────────────────────┘
//
// The cache-fill on the server and the cache-inherit on the browser are styled
// identically (a "page 1" chip in each client box) so they read as the SAME data
// crossing exactly once — never a re-fetch. Highlight (`is-on`) lifts the one
// element doing the work this step; everything else dims back.
//
// Pure HTML+CSS per the diagrams guide (annotated two-lane illustration, not a
// graph engine). `not-content` + a margin:0 reset on every node defeats
// Starlight's injected prose margins. Lives inside <DiagramSequence>, which
// supplies the card chrome and per-step captions — do NOT wrap in <Figure>.
//
// Colour language: blue (the page accent) = the active element this step;
// neutral grey = inert chrome. The same blue marks the page-1 data in both
// clients so the eye tracks one payload end to end.

interface Props {
	// Which element this step lifts: the active highlight token.
	active: 'server-fill' | 'dehydrate' | 'wire' | 'hydrate' | 'leaf';
}

const { active } = Astro.props;

const on = (...tokens: Props['active'][]) =>
	tokens.includes(active) ? ' is-on' : '';
---

<div class="shy not-content">
	{/* ── Server lane ─────────────────────────────────────────────────── */}
	<div class={`shy-lane shy-lane--server${on('server-fill', 'dehydrate')}`}>
		<div class="shy-lane-head">
			<span class="shy-lane-dot"></span>
			<span class="shy-lane-title">Server</span>
			<span class="shy-lane-sub">one request</span>
		</div>

		<div class="shy-lane-body">
			{/* The request-scoped QueryClient — its cache fills in step 1. */}
			<div class={`shy-client${on('server-fill')}`}>
				<span class="shy-client-label">QueryClient <em>request-scoped</em></span>
				<div class="shy-cache">
					<span class={`shy-chip${on('server-fill')}`}>
						<span class="shy-chip-key">comments · page 1</span>
						<span class="shy-chip-val">prefetched from Drizzle</span>
					</span>
				</div>
			</div>

			{/* The dehydrated snapshot — appears in step 2, rides the wire in step 3. */}
			<div class={`shy-dehydrated${on('dehydrate', 'wire')}`}>
				<span class="shy-dehydrated-label">dehydrated state</span>
				<span class="shy-dehydrated-sub">plain, serializable</span>
			</div>
		</div>
	</div>

	{/* ── The RSC payload wire ────────────────────────────────────────── */}
	<div class={`shy-wire${on('wire')}`}>
		<div class="shy-wire-line">
			<span class="shy-wire-label">RSC payload</span>
			<span class="shy-wire-sub">HTML + dehydrated state</span>
		</div>
		<svg
			class="shy-wire-arrow"
			viewBox="0 0 40 12"
			width="40"
			height="12"
			fill="none"
			stroke="currentColor"
			stroke-width="1.8"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<line x1="2" y1="6" x2="34" y2="6"></line>
			<polyline points="29 2 35 6 29 10"></polyline>
		</svg>
	</div>

	{/* ── Browser lane ────────────────────────────────────────────────── */}
	<div class={`shy-lane shy-lane--browser${on('hydrate', 'leaf')}`}>
		<div class="shy-lane-head">
			<span class="shy-lane-dot"></span>
			<span class="shy-lane-title">Browser</span>
			<span class="shy-lane-sub">one session</span>
		</div>

		<div class="shy-lane-body">
			{/* The singleton QueryClient — inherits the snapshot in step 4. */}
			<div class={`shy-client${on('hydrate')}`}>
				<span class="shy-client-label">QueryClient <em>singleton</em></span>
				<div class="shy-cache">
					<span class={`shy-chip shy-chip--inherited${on('hydrate', 'leaf')}`}>
						<span class="shy-chip-key">comments · page 1</span>
						<span class="shy-chip-val">inherited — never fetched</span>
					</span>
				</div>
			</div>

			{/* The leaf — paints warm in step 5, no skeleton. */}
			<div class={`shy-leaf${on('leaf')}`}>
				<span class="shy-leaf-label">&lt;CommentThread /&gt;</span>
				<span class="shy-leaf-sub">useInfiniteQuery reads the warm cache</span>
			</div>
		</div>
	</div>
</div>

<style>
	.shy {
		box-sizing: border-box;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: stretch;
		gap: 10px;
		padding: 6px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		--shy-accent: hsl(217, 91%, 56%);
	}
	.shy * {
		box-sizing: border-box;
	}

	/* ── Lanes ──────────────────────────────────────────────────────────── */
	.shy-lane {
		display: flex;
		flex-direction: column;
		min-width: 0;
		border: 1.5px solid var(--sl-color-gray-5, #cbd5e1);
		border-radius: 12px;
		background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
		overflow: hidden;
		transition:
			border-color 0.18s,
			box-shadow 0.18s,
			background-color 0.18s;
		margin: 0;
	}
	/* The lane lifts subtly while it owns the active step. */
	.shy-lane.is-on {
		border-color: color-mix(in srgb, var(--shy-accent) 55%, transparent);
		background: color-mix(in srgb, var(--shy-accent) 6%, transparent);
		box-shadow: 0 0 0 1px
			color-mix(in srgb, var(--shy-accent) 22%, transparent);
	}

	.shy-lane-head {
		display: flex;
		align-items: baseline;
		gap: 7px;
		padding: 8px 12px;
		border-bottom: 1px solid
			color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent);
		margin: 0;
	}
	.shy-lane-dot {
		flex: 0 0 auto;
		width: 7px;
		height: 7px;
		border-radius: 999px;
		background: var(--sl-color-gray-3, #64748b);
		align-self: center;
		margin: 0;
		transition: background-color 0.18s;
	}
	.shy-lane.is-on .shy-lane-dot {
		background: var(--shy-accent);
	}
	.shy-lane-title {
		font-size: 13px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.shy-lane-sub {
		font-size: 11px;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.shy-lane-body {
		flex: 1 1 auto;
		display: flex;
		flex-direction: column;
		gap: 9px;
		padding: 11px 12px;
		margin: 0;
	}

	/* ── A QueryClient box ──────────────────────────────────────────────── */
	.shy-client {
		display: flex;
		flex-direction: column;
		gap: 7px;
		padding: 9px 10px;
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		border-radius: 9px;
		background: var(--sl-color-bg, #fff);
		transition:
			border-color 0.18s,
			box-shadow 0.18s;
		margin: 0;
	}
	.shy-client.is-on {
		border-color: var(--shy-accent);
		box-shadow: 0 0 0 3px
			color-mix(in srgb, var(--shy-accent) 16%, transparent);
	}
	.shy-client-label {
		font-size: 11.5px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.shy-client-label em {
		font-style: normal;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
	}

	.shy-cache {
		display: flex;
		flex-direction: column;
		gap: 5px;
		margin: 0;
	}

	/* The page-1 data chip — same blue in both clients so it reads as one payload. */
	.shy-chip {
		display: flex;
		flex-direction: column;
		gap: 1px;
		padding: 6px 9px;
		border-radius: 7px;
		border: 1px dashed
			color-mix(in srgb, var(--shy-accent) 38%, transparent);
		background: color-mix(in srgb, var(--shy-accent) 8%, transparent);
		opacity: 0.45;
		transition:
			opacity 0.18s,
			border-style 0.18s,
			background-color 0.18s,
			box-shadow 0.18s;
		margin: 0;
	}
	.shy-chip.is-on {
		opacity: 1;
		border-style: solid;
		background: color-mix(in srgb, var(--shy-accent) 15%, transparent);
		box-shadow: 0 1px 3px color-mix(in srgb, var(--shy-accent) 22%, transparent);
	}
	.shy-chip-key {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11.5px;
		font-weight: 700;
		color: color-mix(in srgb, var(--shy-accent) 78%, var(--sl-color-text));
		margin: 0;
	}
	.shy-chip-val {
		font-size: 10.5px;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── Dehydrated state object (server lane) ──────────────────────────── */
	.shy-dehydrated {
		display: flex;
		flex-direction: column;
		gap: 1px;
		padding: 7px 10px;
		border-radius: 8px;
		border: 1.5px solid color-mix(in srgb, var(--sl-color-gray-4) 50%, transparent);
		background: color-mix(in srgb, var(--sl-color-gray-5) 18%, transparent);
		opacity: 0.4;
		transition:
			opacity 0.18s,
			border-color 0.18s,
			box-shadow 0.18s,
			background-color 0.18s;
		margin: 0;
	}
	.shy-dehydrated.is-on {
		opacity: 1;
		border-color: var(--shy-accent);
		background: color-mix(in srgb, var(--shy-accent) 9%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--shy-accent) 14%, transparent);
	}
	.shy-dehydrated-label {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11.5px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.shy-dehydrated-sub {
		font-size: 10.5px;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── The RSC payload wire ───────────────────────────────────────────── */
	.shy-wire {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 6px;
		min-width: 96px;
		color: var(--sl-color-gray-4, #94a3b8);
		transition: color 0.18s;
		margin: 0;
	}
	.shy-wire.is-on {
		color: var(--shy-accent);
	}
	.shy-wire-line {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1px;
		text-align: center;
		margin: 0;
	}
	.shy-wire-label {
		font-size: 11.5px;
		font-weight: 700;
		color: var(--sl-color-gray-3, #64748b);
		transition: color 0.18s;
		margin: 0;
	}
	.shy-wire.is-on .shy-wire-label {
		color: color-mix(in srgb, var(--shy-accent) 85%, var(--sl-color-text));
	}
	.shy-wire-sub {
		font-size: 10px;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.shy-wire-arrow {
		display: block;
		flex: 0 0 auto;
		margin: 0;
		opacity: 0.7;
		transition: opacity 0.18s;
	}
	.shy-wire.is-on .shy-wire-arrow {
		opacity: 1;
	}

	/* ── The leaf component (browser lane) ──────────────────────────────── */
	.shy-leaf {
		display: flex;
		flex-direction: column;
		gap: 1px;
		padding: 7px 10px;
		border-radius: 8px;
		border: 1.5px solid color-mix(in srgb, var(--sl-color-gray-4) 50%, transparent);
		background: color-mix(in srgb, var(--sl-color-gray-5) 18%, transparent);
		opacity: 0.45;
		transition:
			opacity 0.18s,
			border-color 0.18s,
			box-shadow 0.18s,
			background-color 0.18s;
		margin: 0;
	}
	.shy-leaf.is-on {
		opacity: 1;
		border-color: var(--shy-accent);
		background: color-mix(in srgb, var(--shy-accent) 9%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--shy-accent) 14%, transparent);
	}
	.shy-leaf-label {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 11.5px;
		font-weight: 700;
		color: color-mix(in srgb, var(--shy-accent) 78%, var(--sl-color-text));
		margin: 0;
	}
	.shy-leaf-sub {
		font-size: 10.5px;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: the two lanes + vertical wire stack into a column. */
	@media (max-width: 640px) {
		.shy {
			grid-template-columns: 1fr;
			gap: 8px;
		}
		.shy-wire {
			flex-direction: row;
			min-width: 0;
			gap: 10px;
			padding: 2px 0;
		}
		.shy-wire-arrow {
			transform: rotate(90deg);
		}
		.shy-wire-line {
			align-items: flex-start;
			text-align: left;
		}
	}
</style>
