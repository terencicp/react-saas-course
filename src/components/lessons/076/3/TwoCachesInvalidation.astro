---
// TwoCachesInvalidation — Chapter 076 Lesson 3
// ("Wiring TanStack Query without leaking the cache across requests").
//
// Static clarifying picture for the "two caches, two invalidations" section:
// ONE mutation in the middle fans an arrow out to each of TWO peer caches. The
// teaching point is that these are two *distinct* caches, not a hierarchy, and a
// write to data both layers hold must hit both — so the two cache boxes are
// styled identically (same size, border, background) and sit symmetrically left
// and right of the hub.
//
//   ┌── Server Component ─┐  ◀─ updateTag(…) ──┌──── Mutation ─────┐── invalidateQueries(…) ─▶ ┌── TanStack client ─┐
//   │  cache              │                    │ addCommentAction  │                           │  cache              │
//   └─────────────────────┘                    └───────────────────┘                          └─────────────────────┘
//
// Pure HTML+CSS per the diagrams guide (annotated hub-and-spoke illustration,
// not a graph engine). `not-content` + margin:0 resets on every node defeat
// Starlight's injected prose margins. Wrapped in <Figure> by the lesson, which
// supplies the card chrome + caption — this component renders only the picture.
//
// Colour language matches the lesson's other figure (SsrHydrationStage): the
// page-accent blue marks the live mutation hub and its arrows; the two caches are
// neutral peers so neither reads as primary.
---

<div class="tci not-content">
	{/* ── Left cache: the Server Component cache ──────────────────────────── */}
	<div class="tci-cache">
		<span class="tci-cache-title">Server Component cache</span>
		<span class="tci-cache-sub">summary cards, server-rendered counts</span>
	</div>

	{/* ── Left arrow: updateTag ───────────────────────────────────────────── */}
	<div class="tci-arrow tci-arrow--left">
		<code class="tci-arrow-label">updateTag(…)</code>
		<svg
			class="tci-arrow-svg"
			viewBox="0 0 56 12"
			width="56"
			height="12"
			fill="none"
			stroke="currentColor"
			stroke-width="1.8"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<line x1="54" y1="6" x2="6" y2="6"></line>
			<polyline points="13 2 5 6 13 10"></polyline>
		</svg>
	</div>

	{/* ── Center hub: the mutation ────────────────────────────────────────── */}
	<div class="tci-hub">
		<span class="tci-hub-kicker">Mutation</span>
		<code class="tci-hub-name">addCommentAction</code>
		<span class="tci-hub-sub">writes shared data</span>
	</div>

	{/* ── Right arrow: invalidateQueries ──────────────────────────────────── */}
	<div class="tci-arrow tci-arrow--right">
		<code class="tci-arrow-label">queryClient.invalidateQueries(…)</code>
		<svg
			class="tci-arrow-svg"
			viewBox="0 0 56 12"
			width="56"
			height="12"
			fill="none"
			stroke="currentColor"
			stroke-width="1.8"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<line x1="2" y1="6" x2="50" y2="6"></line>
			<polyline points="43 2 51 6 43 10"></polyline>
		</svg>
	</div>

	{/* ── Right cache: the TanStack client cache ──────────────────────────── */}
	<div class="tci-cache">
		<span class="tci-cache-title">TanStack client cache</span>
		<span class="tci-cache-sub">the useInfiniteQuery comment thread</span>
	</div>
</div>

<style>
	.tci {
		box-sizing: border-box;
		display: grid;
		grid-template-columns:
			minmax(0, 1fr) minmax(96px, auto) minmax(0, 1.1fr)
			minmax(96px, auto) minmax(0, 1fr);
		align-items: stretch;
		gap: 8px;
		padding: 8px 2px;
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
		--tci-accent: hsl(217, 91%, 56%);
	}
	.tci * {
		box-sizing: border-box;
		margin: 0;
	}

	/* ── The two peer caches ─────────────────────────────────────────────── */
	.tci-cache {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		min-width: 0;
		padding: 14px 14px;
		border: 1.5px solid var(--sl-color-gray-4, #94a3b8);
		border-radius: 11px;
		background: color-mix(in srgb, var(--sl-color-gray-6) 45%, transparent);
		text-align: center;
	}
	.tci-cache-title {
		font-size: 13px;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		line-height: 1.25;
	}
	.tci-cache-sub {
		font-size: 11px;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* ── The arrows leaving the hub ──────────────────────────────────────── */
	.tci-arrow {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 5px;
		min-width: 0;
		color: var(--tci-accent);
	}
	.tci-arrow-label {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 10.5px;
		line-height: 1.25;
		text-align: center;
		font-weight: 600;
		color: color-mix(in srgb, var(--tci-accent) 82%, var(--sl-color-text));
		background: color-mix(in srgb, var(--tci-accent) 9%, transparent);
		border: 1px solid color-mix(in srgb, var(--tci-accent) 30%, transparent);
		border-radius: 6px;
		padding: 2px 6px;
		white-space: nowrap;
	}
	.tci-arrow-svg {
		display: block;
		flex: 0 0 auto;
		width: 100%;
		max-width: 72px;
		height: 12px;
	}

	/* ── The mutation hub ────────────────────────────────────────────────── */
	.tci-hub {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		min-width: 0;
		padding: 14px 12px;
		border: 1.5px solid var(--tci-accent);
		border-radius: 11px;
		background: color-mix(in srgb, var(--tci-accent) 9%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--tci-accent) 13%, transparent);
		text-align: center;
	}
	.tci-hub-kicker {
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3, #64748b);
	}
	.tci-hub-name {
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace
		);
		font-size: 13px;
		font-weight: 700;
		color: color-mix(in srgb, var(--tci-accent) 80%, var(--sl-color-text));
	}
	.tci-hub-sub {
		font-size: 10.5px;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* Narrow viewports: stack into a single column, arrows turn vertical. */
	@media (max-width: 640px) {
		.tci {
			grid-template-columns: 1fr;
			gap: 6px;
		}
		/* Source-order reflow: hub first, then each arrow + its cache. */
		.tci-hub {
			order: -1;
		}
		.tci-arrow--left {
			order: 0;
		}
		.tci-cache:first-child {
			order: 1;
		}
		.tci-arrow-svg {
			max-width: none;
			width: 12px;
			height: 28px;
		}
		.tci-arrow--left .tci-arrow-svg {
			transform: rotate(-90deg);
		}
		.tci-arrow--right .tci-arrow-svg {
			transform: rotate(90deg);
		}
	}
</style>
