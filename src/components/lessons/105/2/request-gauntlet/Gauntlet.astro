---
// One frame of the "request-gauntlet" DiagramSequence (Ch105 L2, "Bounding LLM
// spend"). It reuses the chapter-family horizontal strip grammar (Ch084's
// request-flow, Ch057's authed-action-gates, Ch049's render-pipeline): a row of
// guard nodes with one lit (`is-on`, the accent) and the already-walked nodes
// dimmed (`is-done`). So one LLM POST reads as a single request walking the nine
// ordered guards left to right, in the same visual language as the rest of the
// course.
//
// The nine guards, in request order:
//
//   Incoming request → authedRoute → Rate-limit → Daily quota → Pre-call estimate
//     → Model call (maxOutputTokens) → usage in onFinish → Counter + logAudit
//     → Stream to client
//
// One node is special: the Model call (index 5) is the ONE box that costs money,
// so it carries a distinct amber treatment that persists whether or not it is the
// lit frame, plus a `maxOutputTokens` constraint chip ON the box (the output cap
// is a constraint on the call, not a separate gate in front of it).
//
// The strip is fixed across the nine steps; only the lit node and the already-
// walked dimmed nodes change. The per-step caption lives in the MDX on each
// <DiagramStep>, so it swaps with the frame. The row wraps (never scrolls) on
// short/narrow laptop viewports, keeping the stage height well under the cap.
//
// Pure HTML + CSS, matching the sibling figures: `.not-content` to drop
// Starlight's prose chrome, `margin: 0` resets, theme-aware `color-mix` accents
// that read on light and dark.

interface Props {
	// Index (0-8) of the guard lit this frame. Nodes before it read as `is-done`
	// (the request has already passed through them).
	active: number;
}

const { active } = Astro.props;

// The nine guards, in the order one request walks them. `label` is the headline,
// `sub` the one-line role under it. `cost` flags the single money-spending node.
const nodes: { label: string; sub: string; cost?: boolean; cap?: string }[] = [
	{ label: "Incoming request", sub: "POST · no identity yet" },
	{ label: "authedRoute", sub: "auth + tenancy" },
	{ label: "Rate-limit", sub: "burst · sliding window" },
	{ label: "Daily quota", sub: "counter vs entitlement" },
	{ label: "Pre-call estimate", sub: "reject oversized input" },
	{ label: "Model call", sub: "the call that costs money", cost: true, cap: "maxOutputTokens" },
	{ label: "usage", sub: "read in onFinish" },
	{ label: "Counter + logAudit", sub: "record reality" },
	{ label: "Stream to client", sub: "response + X / N today" },
];

const ACCENT = "#2563eb"; // blue-600 — the chapter family's pipeline accent
const COST = "#d97706"; // amber-600 — the one box that spends money
---

<div class="rg-stage not-content">
	<div
		class="rg-pipe"
		role="img"
		aria-label="One LLM POST walks nine ordered guards: incoming request, authedRoute (auth and tenancy), rate-limit check, daily-quota check, pre-call token estimate, the model call (the one that costs money, capped by maxOutputTokens), reading usage in onFinish, the counter and logAudit write, then streaming to the client. The active guard is highlighted."
	>
		{
			nodes.map((node, i) => {
				const isOn = i === active;
				const isDone = i < active;
				return (
					<>
						<div
							class:list={[
								"rg-node",
								{ "is-on": isOn, "is-done": isDone, "is-cost": node.cost },
							]}
						>
							<span class="rg-node-step">{i + 1}</span>
							<span class="rg-node-label">{node.label}</span>
							<span class="rg-node-sub">{node.sub}</span>
							{node.cap && <span class="rg-node-cap">{node.cap}</span>}
						</div>
						{i < nodes.length - 1 && (
							<span
								class:list={["rg-arrow", { "is-on": i < active }]}
								aria-hidden="true"
							>
								<svg
									viewBox="0 0 34 14"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<line x1="1" y1="7" x2="26" y2="7" />
									<polyline points="21 2.5 27.5 7 21 11.5" />
								</svg>
							</span>
						)}
					</>
				);
			})
		}
	</div>
</div>

<style define:vars={{ accent: ACCENT, cost: COST }}>
	.rg-stage {
		margin: 0;
	}

	/* The gauntlet strip. Wraps (never scrolls) on narrow/short viewports so the
	   nine guard nodes always fit; centered so the wrapped rows read together. */
	.rg-pipe {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
	}

	.rg-node {
		margin: 0;
		flex: 1 1 116px;
		max-width: 168px;
		box-sizing: border-box;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		padding: 11px 9px 10px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s,
			opacity 0.14s;
	}
	/* Guards the request has already passed through: tinted but receded, so the
	   strip reads as a path being walked left to right. */
	.rg-node.is-done {
		border-color: color-mix(in srgb, var(--accent) 32%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--accent) 7%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 45%, var(--sl-color-gray-3));
		opacity: 0.78;
	}
	.rg-node.is-on {
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
		opacity: 1;
	}

	/* The one box that spends money keeps an amber treatment in EVERY frame —
	   dimmed-amber by default, brighter when walked or lit — so the eye always
	   knows which gate is the expensive one. */
	.rg-node.is-cost {
		border-color: color-mix(in srgb, var(--cost) 55%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--cost) 9%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--cost) 60%, var(--sl-color-gray-2));
		opacity: 1;
	}
	.rg-node.is-cost.is-done {
		border-color: color-mix(in srgb, var(--cost) 60%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--cost) 12%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--cost) 70%, var(--sl-color-gray-2));
	}
	.rg-node.is-cost.is-on {
		border: 1.5px solid var(--cost);
		background: color-mix(in srgb, var(--cost) 16%, transparent);
		color: color-mix(in srgb, var(--cost) 88%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--cost) 18%, transparent);
	}

	/* Tiny step-number badge so the order is legible even when the row wraps. */
	.rg-node-step {
		margin: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 17px;
		height: 17px;
		border-radius: 50%;
		font-size: 10px;
		font-weight: 700;
		line-height: 1;
		background: var(--sl-color-gray-5);
		color: var(--sl-color-gray-2);
	}
	.rg-node.is-done .rg-node-step {
		background: color-mix(in srgb, var(--accent) 22%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 60%, var(--sl-color-gray-2));
	}
	.rg-node.is-on .rg-node-step {
		background: var(--accent);
		color: #fff;
	}
	.rg-node.is-cost .rg-node-step {
		background: color-mix(in srgb, var(--cost) 28%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--cost) 70%, var(--sl-color-gray-2));
	}
	.rg-node.is-cost.is-on .rg-node-step {
		background: var(--cost);
		color: #fff;
	}

	.rg-node-label {
		margin: 0;
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.2;
		word-break: break-word;
	}
	.rg-node-sub {
		margin: 0;
		font-size: 10px;
		font-weight: 500;
		line-height: 1.25;
		opacity: 0.92;
	}

	/* The output-cap constraint chip — sits ON the model-call node, a monospace
	   pill that reads as a parameter on the call, not a separate gate. */
	.rg-node-cap {
		margin: 2px 0 0;
		display: inline-flex;
		align-items: center;
		padding: 1px 6px;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--cost) 50%, transparent);
		background: color-mix(in srgb, var(--cost) 14%, transparent);
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1.3;
		color: color-mix(in srgb, var(--cost) 85%, var(--sl-color-text));
	}

	/* Connectors between guards. Edges already crossed light up so the strip reads
	   as a request moving through, not a static row. */
	.rg-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.rg-arrow.is-on {
		color: var(--accent);
	}
	.rg-arrow svg {
		width: 20px;
		height: 12px;
	}

	/* On the narrowest viewports the guards stack; rotate the connectors so the
	   flow still reads top-to-bottom. */
	@media (max-width: 600px) {
		.rg-pipe {
			flex-direction: column;
			align-items: stretch;
		}
		.rg-node {
			max-width: none;
		}
		.rg-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
