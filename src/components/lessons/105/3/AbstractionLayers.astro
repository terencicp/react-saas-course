---
// abstraction-layers — Chapter 105 Lesson 3, "One-line model swaps and the AI Gateway".
//
// The lesson in one picture: a vertical layer cake where each layer absorbs
// exactly one axis of churn, so a change on one axis never ripples to the others.
//
//   Application code          ── imports a role handle, never a model string
//        │
//   lib/llm/models.ts         ── absorbs ROLE changes (the named handle)
//        │
//   AI SDK call               ── absorbs PROVIDER differences (one call shape)
//        │
//   AI Gateway                ── absorbs AVAILABILITY + OBSERVABILITY (failover, metrics)
//        │
//   Providers (1 + fallbacks) ── does the work
//
// Read top→bottom: a new ROLE touches only models.ts; a VENDOR swap is absorbed
// by the SDK's uniform call shape; a provider OUTAGE is absorbed by the gateway's
// failover; the provider itself just does the work.
//
// Built with <ArrowDiagram> (LeaderLine) because each box is multi-line custom
// HTML — a bold title, an optional inline-code seam name, and a color-coded
// "axis of churn" sub-label — and the per-layer accent coloring is the whole
// point. Plain-label D2/Mermaid boxes wouldn't carry the sub-labels or the
// stacked provider fan. The arrows are a single straight downward chain
// (bottom→top sockets) connecting each adjacent pair.
//
// Arrows are positioned from document.body, so the wrapping <Figure> MUST be
// expandable={false}: relocating the body into the lightbox breaks the lines.
//
// Chrome is theme-aware (Starlight gray/white vars flip light/dark). The per-axis
// accents are mid-tones used as-is in both themes. A margin:0 reset on every node
// defeats Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// Per-axis accents — each names a different kind of change a layer absorbs.
const C_ROLE = '#0ea5e9'; // sky-500   — role changes (models.ts)
const C_VENDOR = '#16a34a'; // green-600 — provider/vendor differences (SDK)
const C_AVAIL = '#9333ea'; // violet-600 — availability + observability (gateway)

// A single straight downward chain: each layer flows into the one below it.
const arrows = [
	{
		from: 'layer-app',
		to: 'layer-models',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 36],
		endSocketGravity: [0, -36],
	},
	{
		from: 'layer-models',
		to: 'layer-sdk',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 36],
		endSocketGravity: [0, -36],
	},
	{
		from: 'layer-sdk',
		to: 'layer-gateway',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 36],
		endSocketGravity: [0, -36],
	},
	{
		from: 'layer-gateway',
		to: 'layer-providers',
		startSocket: 'bottom',
		endSocket: 'top',
		startSocketGravity: [0, 36],
		endSocketGravity: [0, -36],
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="layers not-content">
			{/* 1 — Application code: asks for a capability, never names a model. */}
			<div class="layer-box" id="layer-app">
				<span class="layer-title">Application code</span>
				<span class="layer-sub">route handler / Server Action</span>
				<span class="layer-note">imports a role handle, never a model string</span>
			</div>

			{/* 2 — models.ts: the named handle absorbs ROLE changes. */}
			<div class="layer-box" id="layer-models">
				<span class="layer-title"><code>lib/llm/models.ts</code></span>
				<span class="layer-axis" style={`color:${C_ROLE}`}>
					absorbs <strong>role</strong> changes
				</span>
				<span class="layer-note">the named handle — a new role is one new line here</span>
			</div>

			{/* 3 — AI SDK call: the uniform call shape absorbs PROVIDER differences. */}
			<div class="layer-box" id="layer-sdk">
				<span class="layer-title">AI SDK call</span>
				<span class="layer-sub"><code>streamText</code>, <code>generateObject</code>, …</span>
				<span class="layer-axis" style={`color:${C_VENDOR}`}>
					absorbs <strong>provider</strong> differences
				</span>
				<span class="layer-note">one call shape — only the model value moves</span>
			</div>

			{/* 4 — AI Gateway: absorbs AVAILABILITY + OBSERVABILITY. */}
			<div class="layer-box" id="layer-gateway">
				<span class="layer-title">AI Gateway</span>
				<span class="layer-axis" style={`color:${C_AVAIL}`}>
					absorbs <strong>availability + observability</strong>
				</span>
				<span class="layer-note">failover, metrics, unified billing</span>
			</div>

			{/* 5 — Providers: a small fan of primary + fallbacks; does the work. */}
			<div class="layer-box layer-box-providers" id="layer-providers">
				<span class="layer-title">Providers</span>
				<span class="layer-note">does the work</span>
				<div class="provider-fan" aria-hidden="true">
					<span class="provider-chip provider-chip-primary">primary</span>
					<span class="provider-chip">fallback A</span>
					<span class="provider-chip">fallback B</span>
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		Four layers, four kinds of change — each layer absorbs exactly one axis of
		churn, so a change on one axis never ripples to the others.
	</Fragment>
</Figure>

<style>
	.layers {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 38px;
		margin: 0;
		padding: 14px 6px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.layer-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		width: min(24rem, 100%);
		padding: 11px 18px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	/* The providers box is the substrate everything rests on — a touch heavier. */
	.layer-box-providers {
		border-color: var(--sl-color-gray-4, #94a3b8);
		gap: 8px;
	}

	.layer-title {
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.layer-title code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.86rem;
		background: none;
		border: none;
		padding: 0;
		color: inherit;
	}

	.layer-sub {
		font-size: 0.7rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.layer-sub code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.66rem;
		background: none;
		border: none;
		padding: 0;
		color: inherit;
	}

	/* The axis of churn this layer absorbs — the load-bearing label, colored. */
	.layer-axis {
		font-size: 0.74rem;
		line-height: 1.25;
		margin: 1px 0 0;
		font-weight: 500;
	}

	.layer-axis strong {
		font-weight: 700;
	}

	.layer-note {
		font-size: 0.66rem;
		line-height: 1.25;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The provider fan — primary plus two fallbacks, the failover stack. */
	.provider-fan {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 6px;
		margin: 0;
	}

	.provider-chip {
		padding: 2px 9px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-gray-6, #f1f5f9);
		font-size: 0.62rem;
		line-height: 1.3;
		white-space: nowrap;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* The primary is the live target; fallbacks wait behind it. */
	.provider-chip-primary {
		border-color: color-mix(in srgb, #9333ea 55%, var(--sl-color-gray-5, #cbd5e1));
		color: #9333ea;
		font-weight: 600;
	}

	/* Narrow viewports: the column already stacks; just tighten the gaps so the
	   vertical chain stays inside the height cap. */
	@media (max-width: 560px) {
		.layers {
			gap: 32px;
		}
		.layer-box {
			width: 100%;
		}
	}
</style>
