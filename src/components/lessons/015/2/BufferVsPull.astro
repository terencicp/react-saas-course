---
// Buffer vs pull — one frame of the "read to completion vs read chunk-by-chunk"
// contrast, used inside <DiagramSequence>. Scrubbing the three frames is what
// makes the difference visible in TIME: the same horizontal body bar is reused
// across all three steps, so only the BEHAVIOUR changes, never the layout.
//
//   1  BUFFERING  response.json() — the whole bar is lit at once, and exactly
//                 one value chip leaves the END of the bar into a single
//                 consumer. The body fills completely before anything comes out.
//   2  PULLING    response.body — the same bar, now four segments; the first
//                 three are lit and each pops its own chunk chip down to the
//                 consumer the moment it lands, while segment four is still dim
//                 (on the wire). You act on chunk 1 while chunk 4 is in flight.
//   3  CHUNK≠MSG  the pulling bar again, but two "message" brackets in a
//                 contrasting accent are overlaid above it; their boundaries
//                 deliberately cross the segment boundaries — a chunk split
//                 falls in the MIDDLE of a message. Seeds the next section.
//
// Pure HTML + CSS, matching the chapter's other figures (see
// FetchResolutionModel): the `not-content` wrapper, theme-gray variables for dim
// chrome, one saturated accent per step so the active path reads in both light
// and dark themes, and a `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector. Height-capped, horizontal, max-width 640.

interface Props {
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// One accent per step. Steps 2 and 3 share the SAME blue bar — step 3 only adds
// the violet message overlay on top — so the eye sees the same pulling view
// annotated, not a different diagram.
const BAR: Record<Props["step"], string> = {
  1: "#475569", // slate-600 — buffering: lit but neutral, "all at once"
  2: "#2563eb", // blue-600  — pulling: the live, chunk-by-chunk accent
  3: "#2563eb", // blue-600  — same pulling bar, annotated below
};
const bar = BAR[step];
const emit = "#16a34a"; // green-600 — the chip(s) that reach the consumer
const msg = "#7c3aed"; // violet-600 — the application-message overlay (step 3)

const buffering = step === 1;
const pulling = step === 2 || step === 3;
const showMessages = step === 3;

// Four segments. In buffering they read as one continuous fill; in pulling the
// first three are lit and the last is still on the wire.
const segLit = [
  buffering || pulling, // seg 1
  buffering || pulling, // seg 2
  buffering || pulling, // seg 3
  buffering, // seg 4 — dim while pulling (still arriving)
];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 0",
  "width: 100%",
  "max-width: 640px",
  "box-sizing: border-box",
  sans,
].join("; ");

// Caption-style label that rides above the bar.
const topLabel = [
  reset,
  mono,
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: " + bar,
  "align-self: flex-start",
  "margin-bottom: 6px",
].join("; ");

// The bar is a 4-column grid track so segment boundaries are exact and stable
// across every step.
const barTrack = [
  reset,
  "position: relative",
  "display: grid",
  "grid-template-columns: repeat(4, 1fr)",
  "gap: 0",
  "width: 100%",
  "height: 40px",
  "border-radius: 9px",
  "overflow: hidden",
  "box-sizing: border-box",
  "border: 1.5px solid " + (pulling ? bar : "color-mix(in srgb, " + bar + " 75%, transparent)"),
].join("; ");

const segBase = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  mono,
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
].join("; ");

// A lit segment: filled with the bar accent. In buffering we hide the inner
// dividers so the four read as one solid fill; in pulling we keep faint
// dividers so the eye counts four chunks.
const litSeg = (i: number) =>
  [
    segBase,
    "background: color-mix(in srgb, " + bar + " " + (buffering ? "35%" : "22%") + ", transparent)",
    "color: color-mix(in srgb, " + bar + " 85%, var(--sl-color-text))",
    pulling && i > 0
      ? "border-left: 1.5px solid color-mix(in srgb, " + bar + " 55%, transparent)"
      : "",
  ]
    .filter(Boolean)
    .join("; ");

const dimSeg = (i: number) =>
  [
    segBase,
    "background: var(--sl-color-gray-6)",
    "color: var(--sl-color-gray-4)",
    "border-left: 1.5px dashed var(--sl-color-gray-4)",
  ].join("; ");

// The message-bracket overlay sits above the bar in step 3. Two brackets whose
// edges fall mid-segment: A covers seg 1 + half seg 2; B starts mid-seg-2 and
// runs through seg 3. Percentages are of the four-segment (100%) track.
const bracketLayer = [
  reset,
  "position: relative",
  "height: 22px",
  "width: 100%",
  "margin-bottom: 4px",
].join("; ");

const bracket = (leftPct: number, widthPct: number, label: string) =>
  [
    reset,
    "position: absolute",
    "bottom: 0",
    "left: " + leftPct + "%",
    "width: " + widthPct + "%",
    "height: 14px",
    "box-sizing: border-box",
    "border: 1.5px solid " + msg,
    "border-bottom: none",
    "border-radius: 6px 6px 0 0",
    "background: color-mix(in srgb, " + msg + " 9%, transparent)",
  ].join("; ");

const bracketLabel = [
  reset,
  sans,
  "position: absolute",
  "top: -2px",
  "left: 50%",
  "transform: translateX(-50%)",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.02em",
  "line-height: 1",
  "color: " + msg,
  "white-space: nowrap",
].join("; ");

// The arrow layer between the bar and the consumer. Each emitting point drops a
// short arrow straight down. In buffering there is one arrow at the far right
// (the body finished, one value leaves the end); in pulling there are three,
// centred under segments 1–3.
const arrowRow = [
  reset,
  "position: relative",
  "display: grid",
  "grid-template-columns: repeat(4, 1fr)",
  "width: 100%",
  "height: 30px",
].join("; ");

const arrowCell = (col: number, justify: string) =>
  [
    reset,
    "grid-column: " + col,
    "display: flex",
    "align-items: center",
    "justify-content: " + justify,
  ].join("; ");

const chipBase = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "padding: 3px 7px",
  "border-radius: 999px",
  "font-size: 10px",
  "font-weight: 700",
  "line-height: 1",
  "border: 1.5px solid " + emit,
  "background: color-mix(in srgb, " + emit + " 15%, transparent)",
  "color: color-mix(in srgb, " + emit + " 80%, var(--sl-color-text))",
].join("; ");

// A label spanning the whole buffered bar — the fill IS the content in step 1.
const bufferBarLabel = [
  reset,
  mono,
  "position: absolute",
  "inset: 0",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "color: color-mix(in srgb, " + bar + " 70%, var(--sl-color-text))",
].join("; ");

// The consumer box at the bottom — the destination of every chip. While
// pulling it spans segments 1–3 so all three arrows land inside it; while
// buffering it hugs the right edge, under the single end-of-body arrow.
const consumerRow = [
  reset,
  "display: flex",
  "justify-content: " + (buffering ? "flex-end" : "flex-start"),
  "width: 100%",
].join("; ");

const consumerBox = [
  reset,
  pulling ? "width: 75%" : "",
  "box-sizing: border-box",
  "border-radius: 9px",
  "padding: 8px 14px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 2px",
  "border: 1.5px solid " + emit,
  "background: color-mix(in srgb, " + emit + " 11%, transparent)",
  "color: color-mix(in srgb, " + emit + " 80%, var(--sl-color-text))",
].join("; ");

const consumerLabel = `${reset}; ${mono}; font-size: 12px; font-weight: 700; line-height: 1.2;`;
const consumerSub = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "line-height: 1.2",
  "opacity: 0.85",
].join("; ");

// A down-arrow SVG, recoloured to the emit accent.
const downArrow = "M 7 24 L 2 13 L 12 13 Z";
const downLine = { x: 7, y1: 0, y2: 13 };
---

<div class="not-content" style={root}>
  {/* ---- top label: what the bar IS this step ---- */}
  <span style={topLabel}>
    {buffering ? "response.json()" : "response.body"}
  </span>

  {/* ---- message-bracket overlay (step 3 only) ---- */}
  {
    showMessages && (
      <div style={bracketLayer}>
        {/* message A: seg 1 + half of seg 2  (0% → 37.5%) */}
        <div style={bracket(0, 37.5, "message A")}>
          <span style={bracketLabel}>message A</span>
        </div>
        {/* message B: mid-seg-2 through seg 3 (37.5% → 75%) */}
        <div style={bracket(37.5, 37.5, "message B")}>
          <span style={bracketLabel}>message B</span>
        </div>
      </div>
    )
  }

  {/* ---- the body bar, identical footprint every step ---- */}
  <div style={barTrack}>
    {
      [0, 1, 2, 3].map((i) => (
        <div style={segLit[i] ? litSeg(i) : dimSeg(i)}>
          {pulling && segLit[i] && <span>chunk {i + 1}</span>}
          {pulling && !segLit[i] && <span>chunk 4 — on the wire</span>}
        </div>
      ))
    }
    {buffering && <span style={bufferBarLabel}>entire body — read to completion</span>}
  </div>

  {/* ---- arrows dropping to the consumer ---- */}
  <div style={arrowRow}>
    {
      buffering ? (
        // one arrow at the far right — the body finished, one value leaves
        <div style={arrowCell(4, "center")}>
          <svg
            width="14"
            height="24"
            viewBox="0 0 14 24"
            role="img"
            aria-label="One value leaves the end of the buffered body."
            style="margin: 0; display: block;"
          >
            <line
              x1={downLine.x}
              y1={downLine.y1}
              x2={downLine.x}
              y2={downLine.y2}
              stroke={emit}
              stroke-width="2"
            />
            <path d={downArrow} fill={emit} />
          </svg>
        </div>
      ) : (
        // three arrows, centred under segments 1–3, each carrying a chunk
        [1, 2, 3].map((col) => (
          <div style={arrowCell(col, "center")}>
            <svg
              width="14"
              height="24"
              viewBox="0 0 14 24"
              role="img"
              aria-label={`Chunk ${col} reaches the consumer as it lands.`}
              style="margin: 0; display: block;"
            >
              <line
                x1={downLine.x}
                y1={downLine.y1}
                x2={downLine.x}
                y2={downLine.y2}
                stroke={emit}
                stroke-width="2"
              />
              <path d={downArrow} fill={emit} />
            </svg>
          </div>
        ))
      )
    }
  </div>

  {/* ---- the consumer + the chip(s) that reached it ---- */}
  <div style={consumerRow}>
    <div style={consumerBox}>
      <span style={consumerLabel}>consumer</span>
      <span style={consumerSub}>
        {buffering ? "the whole body, at the end" : "one chunk at a time"}
      </span>
      <div style={`${reset}; display: flex; gap: 5px; margin-top: 4px; flex-wrap: wrap; justify-content: center;`}>
        {
          buffering ? (
            <span style={chipBase}>entire body</span>
          ) : (
            [1, 2, 3].map((n) => <span style={chipBase}>chunk {n}</span>)
          )
        }
      </div>
    </div>
  </div>
</div>
