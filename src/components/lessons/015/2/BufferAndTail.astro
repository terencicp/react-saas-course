---
// Buffer-and-tail — one frame of the "append, split, keep the tail, parse the
// rest" reframing pattern, used inside <DiagramSequence>. Scrubbing the two
// frames is what makes the TAIL-CARRY visible in TIME: step 1's tinted tail
// (`event2\npart`) reappears, still tinted, as the PREPENDED head of step 2's
// buffer, so the eye literally watches the held-back fragment get reunited with
// its other half on the next chunk.
//
// Three stacked rows, labelled on the left, identical footprint both steps:
//   TOP     incoming chunk — the raw bytes that just landed off the wire
//   MIDDLE  buffer         — accumulated text, split at the `\n\n` framing
//                            token; the trailing incomplete fragment is the
//                            TAIL, tinted violet; everything before it is
//                            complete (neutral/done tone)
//   BOTTOM  emitted        — one green chip per whole event handled this step
//
//   1  chunk A = `event1\n\nevent2\npart`. Buffer holds it; split on `\n\n`:
//      `event1` is complete → emit it; `event2\npart` has no terminator yet →
//      keep as the tail.
//   2  chunk B = `rest\n\nevent3\n\n`. Buffer = previous tail PREPENDED to B,
//      so `event2\npart` + `rest` reunite into one whole event. Splits cleanly
//      into `event2` and `event3`; buffer ends exactly on `\n\n`, so the new
//      tail is empty ("").
//
// Pure HTML + CSS, matching the chapter's other figures (see BufferVsPull /
// FetchResolutionModel): the `not-content` wrapper, theme-gray variables for
// dim chrome, monospace for every text fragment so the `\n\n` framing reads, a
// distinct violet "tail" accent and green "emit" accent, and a `margin: 0`
// reset on every inner element to defeat Starlight's prose-margin selector.
// Height-capped, max-width 640.

interface Props {
  step: 1 | 2;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Accents. `tail` is the held-back, deliberately-not-yet-emitted fragment;
// `emit` is a whole event that reached the consumer; `done` is buffer content
// that is complete but shown in the buffer row (neutral, not yet a chip).
const tail = "#7c3aed"; // violet-600 — the carried tail
const emit = "#16a34a"; // green-600  — emitted whole events
const done = "#475569"; // slate-600  — complete-but-in-buffer text

// A streamed-token model: each row is built from typed tokens so the same
// renderer draws both steps and the `\n\n` / `\n` glyphs are always legible.
//   text    plain payload bytes, neutral
//   nn      the `\n\n` framing token — the blank line that ends an event
//   n       a single `\n` inside one event's payload (NOT a terminator)
//   carried same as text but rendered in the tail accent (the prepended tail)
type Tok =
  | { kind: "text"; v: string }
  | { kind: "carried"; v: string }
  | { kind: "nn" }
  | { kind: "n" };

const chunk: Record<Props["step"], Tok[]> = {
  1: [
    { kind: "text", v: "event1" },
    { kind: "nn" },
    { kind: "text", v: "event2" },
    { kind: "n" },
    { kind: "text", v: "part" },
  ],
  2: [
    { kind: "text", v: "rest" },
    { kind: "nn" },
    { kind: "text", v: "event3" },
    { kind: "nn" },
  ],
};

// The buffer after appending this step's chunk. In step 2 the leading tokens
// are `carried` — the tail kept from step 1, prepended — so the eye sees the
// reunion `event2\npart` + `rest`.
const buffer: Record<Props["step"], Tok[]> = {
  1: [
    { kind: "text", v: "event1" },
    { kind: "nn" },
    { kind: "text", v: "event2" },
    { kind: "n" },
    { kind: "text", v: "part" },
  ],
  2: [
    { kind: "carried", v: "event2" },
    { kind: "n" },
    { kind: "carried", v: "part" },
    { kind: "text", v: "rest" },
    { kind: "nn" },
    { kind: "text", v: "event3" },
    { kind: "nn" },
  ],
};

// How many leading tokens of the buffer are COMPLETE (everything up to and
// including the last `\n\n`); the remainder is the tail. Step 1: tokens 0–1
// (`event1\n\n`) are complete, 2–4 are the tail. Step 2: the whole buffer is
// complete (ends on `\n\n`), tail is empty.
const completeUpTo: Record<Props["step"], number> = { 1: 2, 2: 7 };

const emitted: Record<Props["step"], string[]> = {
  1: ["event1"],
  2: ["event2", "event3"],
};

const tailEmpty = step === 2;

const tokens = chunk[step];
const bufTokens = buffer[step];
const cut = completeUpTo[step];
const emittedChips = emitted[step];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 12px",
  "width: 100%",
  "max-width: 640px",
  "box-sizing: border-box",
  sans,
].join("; ");

// A labelled row: a fixed-width left label, then the content lane.
const row = [
  reset,
  "display: grid",
  "grid-template-columns: 92px 1fr",
  "align-items: center",
  "column-gap: 12px",
  "width: 100%",
].join("; ");

const rowLabel = (c: string) =>
  [
    reset,
    sans,
    "font-size: 10px",
    "font-weight: 700",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "line-height: 1.2",
    "text-align: right",
    "color: " + c,
  ].join("; ");

// The content lane is a bordered, theme-gray strip that holds the monospace
// token run. Same chrome every row so the three read as one stacked stack.
const lane = (accent: string | null) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-wrap: wrap",
    "align-items: center",
    "gap: 0",
    "min-height: 34px",
    "padding: 6px 9px",
    "border-radius: 8px",
    "border: 1.5px solid " +
      (accent
        ? "color-mix(in srgb, " + accent + " 60%, transparent)"
        : "var(--sl-color-gray-4)"),
    "background: var(--sl-color-gray-6)",
  ].join("; ");

// Plain payload text token.
const textTok = (c: string) =>
  [
    reset,
    mono,
    "font-size: 13px",
    "font-weight: 600",
    "line-height: 1.4",
    "color: " + c,
    "white-space: pre",
  ].join("; ");

// The `\n\n` framing token — a tinted pill so the blank-line terminator pops.
const nnTok = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "margin: 0 3px",
  "padding: 1px 5px",
  "border-radius: 5px",
  "font-size: 11px",
  "font-weight: 700",
  "line-height: 1.3",
  "letter-spacing: 0.02em",
  "border: 1px solid color-mix(in srgb, " + emit + " 55%, transparent)",
  "background: color-mix(in srgb, " + emit + " 16%, transparent)",
  "color: color-mix(in srgb, " + emit + " 80%, var(--sl-color-text))",
].join("; ");

// A single `\n` inside a payload — a literal newline that is NOT a terminator,
// drawn fainter so it does not read as framing.
const nTok = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "margin: 0 2px",
  "padding: 1px 4px",
  "border-radius: 4px",
  "font-size: 10.5px",
  "font-weight: 700",
  "line-height: 1.3",
  "border: 1px dashed var(--sl-color-gray-3)",
  "background: transparent",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The tail marker that rides at the end of the buffer lane.
const tailMarker = (empty: boolean) =>
  [
    reset,
    sans,
    "display: inline-flex",
    "align-items: center",
    "gap: 4px",
    "margin-left: auto",
    "padding: 2px 7px",
    "border-radius: 999px",
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "line-height: 1.2",
    "border: 1.5px " +
      (empty ? "dashed var(--sl-color-gray-4)" : "solid " + tail),
    "background: " +
      (empty
        ? "transparent"
        : "color-mix(in srgb, " + tail + " 13%, transparent)"),
    "color: " +
      (empty
        ? "var(--sl-color-gray-3)"
        : "color-mix(in srgb, " + tail + " 75%, var(--sl-color-text))"),
  ].join("; ");

const tailMarkerCode = [
  reset,
  mono,
  "font-size: 10.5px",
  "font-weight: 700",
  "line-height: 1.2",
].join("; ");

// An emitted-event chip in the bottom lane.
const chip = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "padding: 3px 9px",
  "border-radius: 999px",
  "font-size: 12px",
  "font-weight: 700",
  "line-height: 1.2",
  "border: 1.5px solid " + emit,
  "background: color-mix(in srgb, " + emit + " 15%, transparent)",
  "color: color-mix(in srgb, " + emit + " 80%, var(--sl-color-text))",
].join("; ");

const emptyEmit = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 600",
  "font-style: italic",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// A token's text color in the buffer row depends on whether it sits in the
// complete head (done tone), the tail (tail tone), or is a carried tail token
// prepended from the previous step (also tail tone).
function textColorAt(tok: Tok, index: number): string {
  if (tok.kind === "carried") return tail;
  if (index >= cut) return tail; // in the tail
  return done; // complete head
}
---

<div class="not-content" style={root}>
  {/* ---- TOP: the chunk that just arrived ---- */}
  <div style={row}>
    <span style={rowLabel("var(--sl-color-gray-2)")}>incoming chunk</span>
    <div style={lane(null)}>
      {
        tokens.map((tok) =>
          tok.kind === "nn" ? (
            <span style={nnTok}>\n\n</span>
          ) : tok.kind === "n" ? (
            <span style={nTok}>\n</span>
          ) : (
            <span style={textTok("var(--sl-color-text)")}>{tok.v}</span>
          ),
        )
      }
    </div>
  </div>

  {/* ---- MIDDLE: the running buffer, split at \n\n, tail tinted ---- */}
  <div style={row}>
    <span style={rowLabel(tail)}>buffer</span>
    <div style={lane(tail)}>
      {
        bufTokens.map((tok, i) =>
          tok.kind === "nn" ? (
            <span style={nnTok}>\n\n</span>
          ) : tok.kind === "n" ? (
            <span style={nTok}>\n</span>
          ) : (
            <span style={textTok(textColorAt(tok, i))}>{tok.v}</span>
          ),
        )
      }
      <span style={tailMarker(tailEmpty)}>
        tail
        <span style={tailMarkerCode}>{tailEmpty ? '""' : "event2\\npart"}</span>
      </span>
    </div>
  </div>

  {/* ---- BOTTOM: the whole events emitted this step ---- */}
  <div style={row}>
    <span style={rowLabel(emit)}>emitted</span>
    <div
      style={`${lane(emit)}; gap: 7px; background: color-mix(in srgb, ${emit} 7%, var(--sl-color-gray-6));`}
    >
      {emittedChips.map((label) => <span style={chip}>{label}</span>)}
    </div>
  </div>
</div>
