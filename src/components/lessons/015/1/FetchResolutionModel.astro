---
// Fetch resolution model — one frame of the "resolves vs rejects" split, used
// inside <DiagramSequence>. Scrubbing the four frames is what makes the lesson's
// keystone visible in TIME: a 200 (step 2) and a 422/500 (step 3) travel the
// SAME "resolves" arrow into the SAME Response box and only diverge at the
// `response.ok` check. Only a transport failure (step 4) ever reaches `catch`.
//
// Layout is horizontal to respect the height cap. The fetch box sits top-left;
// from it a "resolves" arrow runs right into the Response box, which forks into
// two stacked path boxes (ok === true → parse, ok === false → error body). A
// separate "rejects" arrow drops down from the fetch box to a catch box that
// sits in its own row underneath — the diverge happens before Response.
//
// `step` selects the frame (source order = scrub order):
//   1  fire     fetch box + its outgoing edge lit, neutral blue
//   2  resolve  resolves arrow + Response + ok===true/parse path lit, green
//   3  resolve  SAME resolves arrow + Response, ok===false/error path lit, orange
//   4  reject   rejects arrow + catch box lit, red
//
// Pure HTML + CSS, matching the chapter's other figures (see EventPhaseWalk):
// the `not-content` wrapper, theme gray variables for dim chrome, one saturated
// mid-tone per step so the active path reads in both light and dark themes, and
// a `margin: 0` reset on every inner element to defeat Starlight's prose-margin
// selector.

interface Props {
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// One accent per step. Steps 2 and 3 deliberately share the resolves arrow and
// Response box but recolor it, so the eye sees the same door used twice.
const ACCENT: Record<Props["step"], string> = {
  1: "#2563eb", // blue-600  — the request fires
  2: "#16a34a", // green-600 — 200, success path
  3: "#d97706", // amber-600 — 422/500, error-body path
  4: "#dc2626", // red-600   — transport failure, catch
};
const lit = ACCENT[step];

// Which elements are active this frame.
const fetchLit = step === 1;
// The resolve leg (arrow + Response box) is lit for both 200 and 4xx/5xx — the
// whole point of the figure.
const resolveLit = step === 2 || step === 3;
const okPathLit = step === 2; // response.ok === true → parse
const errPathLit = step === 3; // response.ok === false → error body
const rejectLit = step === 4; // rejects → catch

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: grid",
  // Three columns: the fetch box, the resolves arrow, the response + branches.
  "grid-template-columns: auto auto 1fr",
  "grid-template-rows: auto auto",
  "align-items: center",
  "column-gap: 10px",
  "row-gap: 0",
  "width: 100%",
  "max-width: 640px",
  "box-sizing: border-box",
  sans,
].join("; ");

// Shared box chrome; `tone` recolors it to the active accent when lit.
const boxBase = [
  reset,
  "box-sizing: border-box",
  "border-radius: 9px",
  "padding: 9px 12px",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "justify-content: center",
  "gap: 3px",
  "text-align: center",
  "transition: border-color 0.14s, background-color 0.14s, color 0.14s, box-shadow 0.14s",
].join("; ");

const dimBox = `${boxBase}; border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6); color: var(--sl-color-gray-3);`;
const litBox = (c: string) =>
  `${boxBase}; border: 1.5px solid ${c}; background: color-mix(in srgb, ${c} 13%, transparent); color: color-mix(in srgb, ${c} 78%, var(--sl-color-text)); box-shadow: 0 0 0 4px color-mix(in srgb, ${c} 16%, transparent);`;

const codeLine = `${reset}; ${mono}; font-size: 13.5px; font-weight: 700; line-height: 1.2;`;
const subLine = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 600",
  "letter-spacing: 0.02em",
  "line-height: 1.2",
  "opacity: 0.85",
].join("; ");

// An edge label that rides above its arrow.
const edgeLabel = (active: boolean) =>
  [
    reset,
    sans,
    "font-size: 10px",
    "font-weight: 700",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "line-height: 1",
    "color: " + (active ? lit : "var(--sl-color-gray-3)"),
  ].join("; ");

// Cell that carries the horizontal "resolves" arrow + its label.
const resolveCell = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 4px",
].join("; ");

// The branch column to the right of Response: two stacked path boxes joined to
// Response by short connectors.
const branchCol = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
  "min-width: 0",
].join("; ");

const branchRow = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "gap: 6px",
  "min-width: 0",
].join("; ");

const pathBoxBase = [
  reset,
  "box-sizing: border-box",
  "border-radius: 8px",
  "padding: 7px 10px",
  "flex: 1 1 auto",
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
  "gap: 2px",
  "transition: border-color 0.14s, background-color 0.14s, color 0.14s, box-shadow 0.14s",
].join("; ");

const dimPath = `${pathBoxBase}; border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6); color: var(--sl-color-gray-3);`;
const litPath = (c: string) =>
  `${pathBoxBase}; border: 1.5px solid ${c}; background: color-mix(in srgb, ${c} 13%, transparent); color: color-mix(in srgb, ${c} 78%, var(--sl-color-text)); box-shadow: 0 0 0 3px color-mix(in srgb, ${c} 14%, transparent);`;

const condLine = `${reset}; ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2;`;
const actLine = `${reset}; ${sans}; font-size: 10.5px; font-weight: 600; line-height: 1.2; opacity: 0.85;`;

// The reject leg sits in the second grid row, under the fetch box: a short
// down-arrow that drops INTO the catch box. Arrow, label, and box share one
// cell and stack vertically — they must not overlap.
const rejectCell = [
  reset,
  "grid-column: 1",
  "grid-row: 2",
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 3px",
  "padding-top: 2px",
].join("; ");
---

<div class="not-content" style={root}>
  {/* fetch box — grid col 1, row 1 */}
  <div style={`grid-column: 1; grid-row: 1; ${fetchLit ? litBox(lit) : dimBox}`}>
    <span style={codeLine}>await fetch(url)</span>
    <span style={subLine}>request leaves the client</span>
  </div>

  {/* resolves arrow — grid col 2, row 1 */}
  <div style={`grid-column: 2; grid-row: 1; ${resolveCell}`}>
    <span style={edgeLabel(resolveLit)}>resolves</span>
    <svg
      width="56"
      height="16"
      viewBox="0 0 56 16"
      role="img"
      aria-label="The promise resolves into a Response."
      style="margin: 0; display: block;"
    >
      <line
        x1="0"
        y1="8"
        x2="46"
        y2="8"
        stroke={resolveLit ? lit : "var(--sl-color-gray-4)"}
        stroke-width={resolveLit ? "2" : "1.5"}></line>
      <path
        d="M 56 8 L 46 3 L 46 13 Z"
        fill={resolveLit ? lit : "var(--sl-color-gray-4)"}></path>
    </svg>
  </div>

  {/* Response + the two-way fork — grid col 3, row 1 */}
  <div
    style={`grid-column: 3; grid-row: 1; display: flex; flex-direction: row; align-items: center; gap: 8px; min-width: 0;`}
  >
    {/* Response box (shared by step 2 and step 3) */}
    <div style={resolveLit ? litBox(lit) : dimBox}>
      <span style={codeLine}>Response</span>
      <span style={subLine}>200 · 404 · 422 · 500</span>
    </div>

    {/* short connector into the fork */}
    <svg
      width="14"
      height="12"
      viewBox="0 0 14 12"
      aria-hidden="true"
      style="margin: 0; display: block; flex: 0 0 auto;"
    >
      <line
        x1="0"
        y1="6"
        x2="10"
        y2="6"
        stroke={resolveLit ? lit : "var(--sl-color-gray-4)"}
        stroke-width="1.5"></line>
      <path
        d="M 14 6 L 8 3 L 8 9 Z"
        fill={resolveLit ? lit : "var(--sl-color-gray-4)"}></path>
    </svg>

    {/* the two paths the response.ok check forks into */}
    <div style={branchCol}>
      <div style={branchRow}>
        <div style={okPathLit ? litPath(lit) : dimPath}>
          <span style={condLine}>response.ok === true</span>
          <span style={actLine}>parse the body</span>
        </div>
      </div>
      <div style={branchRow}>
        <div style={errPathLit ? litPath(lit) : dimPath}>
          <span style={condLine}>response.ok === false</span>
          <span style={actLine}>read the error body</span>
        </div>
      </div>
    </div>
  </div>

  {/* rejects arrow + catch box, stacked under the fetch box — grid col 1, row 2 */}
  <div style={rejectCell}>
    <span style={edgeLabel(rejectLit)}>rejects</span>
    <svg
      width="16"
      height="28"
      viewBox="0 0 16 28"
      role="img"
      aria-label="The promise rejects into the catch block."
      style="margin: 0; display: block;"
    >
      <line
        x1="8"
        y1="0"
        x2="8"
        y2="16"
        stroke={rejectLit ? lit : "var(--sl-color-gray-4)"}
        stroke-width={rejectLit ? "2" : "1.5"}></line>
      <path
        d="M 8 28 L 3 17 L 13 17 Z"
        fill={rejectLit ? lit : "var(--sl-color-gray-4)"}></path>
    </svg>
    <div style={rejectLit ? litBox(lit) : dimBox}>
      <span style={codeLine}>catch (error)</span>
      <span style={subLine}>no response at all</span>
    </div>
  </div>
</div>
