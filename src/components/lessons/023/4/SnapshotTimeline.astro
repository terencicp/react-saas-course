---
// The snapshot timeline (diagram id: snapshot-timeline, Chapter 023 L4). The
// spine visual of the lesson: a three-step scrubbable DiagramSequence that
// follows ONE click from the render holding count = 0 to the render holding
// count = 1, so the +1 bug becomes obvious rather than mysterious.
//
// The motif is a PHOTOGRAPH. Each render is a "photo card" — a polaroid-style
// frame with a "RENDER #N" label pill top-left, a big `count = N` baked into the
// frame, and a small mono block showing the click handler with `count` literally
// substituted. The teaching point falls straight out of the layout: a setter
// does not edit the current photo, it produces the NEXT one.
//
//   Step 1  React calls the component. count is FROZEN at 0 into render #0 and
//           the handler is wired up — `setCount(0 + 1)`, count already baked in.
//           The "next photo" slot is an empty dashed frame; nothing queued yet.
//   Step 2  The user clicks. The handler runs entirely inside render #0's
//           snapshot, so it still sees count as 0; `setCount(1)` is SCHEDULED,
//           not applied. A "queued: set count = 1" chip lights up — but the photo
//           is unchanged (count = 0 stays put). That stillness is the whole point.
//   Step 3  React re-renders. A new render, a new snapshot — render #1 holds
//           count = 1. Render #0 is shown faded ("the previous photo"); the new
//           card is the active one. The setter produced the next card.
//
// Layout: a fixed two-slot horizontal row (slot 1 = the earlier render, slot 2 =
// the later render) plus a reserved status strip below, so all three steps are
// the SAME shape and the grid stack never reflows as the reader scrubs. The
// arrow between slots reads "the setter produces the next card", and it only
// turns solid in step 3 when the next card actually exists.
//
// House style matches this chapter's PositionMatchSequence / TypeMatchTrees:
// fixed slate ink, color-scheme pinned light so the hand-picked accent tints
// survive dark mode, `margin: 0` on every inner element to defeat Starlight's
// injected prose margins. Indigo is the lesson's active-render accent; amber is
// the "queued" chip so it reads as a sticky note distinct from the chrome.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // photo frame surface
const BORDER = '#cbd5e1'; // ordinary edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)

const INDIGO = '#4f46e5'; // indigo-600 — the active render's accent
const INDIGO_SOFT = '#eef2ff'; // indigo-50 — active label pill wash
const INDIGO_INK = '#3730a3'; // indigo-800 — active label text

const AMBER = '#d97706'; // amber-600 — the "queued" chip
const AMBER_BG = '#fef3c7'; // amber-100 — queued wash
const AMBER_INK = '#92400e'; // amber-800 — queued text

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all three steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The two-slot frame row: [photo] [arrow] [photo]. `wrap` keeps it horizontal on
// a laptop and lets it stack only on a genuinely narrow viewport.
const frameRow = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 10px; margin: 0; width: 100%;`;

// One photo card — a polaroid-style frame. `state` swaps the chrome:
//   active   the live render (indigo edge, full opacity)
//   faded    the previous render in step 3 (muted, lower opacity)
//   ghost    an empty "next photo not taken yet" dashed placeholder
const cardBase = `box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; flex: 0 1 248px; min-width: 210px; min-height: 168px; margin: 0; padding: 11px 12px 13px; border-radius: 12px; background: ${SURFACE};`;
const card = {
	active: `${cardBase} border: 2px solid ${INDIGO}; box-shadow: 0 2px 8px rgba(79, 70, 229, 0.22);`,
	faded: `${cardBase} border: 2px solid ${BORDER}; opacity: 0.5;`,
	ghost: `${cardBase} border: 2px dashed ${BORDER}; background: ${PANEL_BG}; align-items: center; justify-content: center; box-shadow: none;`,
};

// The "RENDER #N" label pill, top-left of a photo. `dim` greys it on the faded card.
const pillBase = `display: inline-flex; align-items: center; gap: 6px; width: fit-content; margin: 0; padding: 3px 9px; font-family: ${mono}; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; border-radius: 999px;`;
const pill = {
	active: `${pillBase} color: ${INDIGO_INK}; background: ${INDIGO_SOFT}; border: 1px solid ${INDIGO};`,
	dim: `${pillBase} color: ${INK_SOFT}; background: ${PANEL_BG}; border: 1px solid ${BORDER};`,
};

// The big `count = N` baked into the photo.
const countLine = `display: flex; align-items: baseline; gap: 8px; margin: 0;`;
const countLabel = `margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 600; color: ${INK_SOFT};`;
const countValue = `margin: 0; font-family: ${mono}; font-size: 34px; font-weight: 800; line-height: 1; color: ${INK}; font-variant-numeric: tabular-nums;`;

// The small handler block at the foot of the photo, with count substituted.
const handlerLabel = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;
const handlerBox = `margin: 0; padding: 6px 9px; border-radius: 8px; background: ${PANEL_BG}; border: 1px solid ${BORDER}; font-family: ${mono}; font-size: 12.5px; font-weight: 600; line-height: 1.3; color: ${INK}; white-space: nowrap;`;
// The substituted literal inside the handler, tinted so the eye lands on it.
const sub = `color: ${INDIGO}; font-weight: 800;`;

// The "next photo" placeholder caption inside the ghost frame.
const ghostText = `margin: 0; text-align: center; font-family: ${sans}; font-size: 12px; font-weight: 600; line-height: 1.4; color: ${INK_SOFT};`;

// The arrow joining the two slots. `live` turns it solid indigo in step 3, when
// the next card actually exists; otherwise it is a faint "not yet" arrow.
const arrowBase = `display: flex; flex: 0 0 auto; align-items: center; align-self: center; font-size: 22px; font-weight: 800; line-height: 1; margin: 0;`;
const arrow = {
	idle: `${arrowBase} color: ${BORDER};`,
	live: `${arrowBase} color: ${INDIGO};`,
};

// The reserved status strip under the row — same footprint on every step so the
// height is stable; only its content changes. `tone` swaps neutral / queued / new.
const stripBase = `display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 6px 12px; border-radius: 999px; font-family: ${sans}; font-size: 12.5px; font-weight: 600; line-height: 1.3;`;
const strip = {
	idle: `${stripBase} color: ${INK_SOFT}; background: ${PANEL_BG}; border: 1px solid ${BORDER};`,
	queued: `${stripBase} color: ${AMBER_INK}; background: ${AMBER_BG}; border: 1px solid ${AMBER};`,
	fresh: `${stripBase} color: ${INDIGO_INK}; background: ${INDIGO_SOFT}; border: 1px solid ${INDIGO};`,
};
// The little uppercase tag that prefixes the status strip text.
const stripTag = (bg: string) =>
	`display: inline-block; margin: 0; padding: 1px 6px; font-family: ${mono}; font-size: 9px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #ffffff; background: ${bg}; border-radius: 4px;`;
---

<DiagramSequence>
	{/* ---- Step 1: React calls the component, count frozen at 0 ---- */}
	<DiagramStep caption="React calls your component. It freezes count at 0 into this render and wires up the handler with that value already baked in.">
		<div style={stage}>
			<div style={frameRow}>
				<div style={card.active}>
					<span style={pill.active}>RENDER #0</span>
					<p style={countLine}>
						<span style={countLabel}>count =</span>
						<span style={countValue}>0</span>
					</p>
					<div>
						<p style={handlerLabel}>click handler</p>
						<p style={handlerBox}>setCount(<span style={sub}>0</span> + 1)</p>
					</div>
				</div>
				<span style={arrow.idle} aria-hidden="true">&rarr;</span>
				<div style={card.ghost}>
					<p style={ghostText}>next photo<br />not taken yet</p>
				</div>
			</div>
			<p style={strip.idle}>Nothing queued. This render owns its own frozen count.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: the click; setCount queued, the photo is unchanged ---- */}
	<DiagramStep caption="You click. The handler runs entirely inside render #0's snapshot, so it still sees count as 0. setCount(1) is scheduled, not applied — the photo does not change.">
		<div style={stage}>
			<div style={frameRow}>
				<div style={card.active}>
					<span style={pill.active}>RENDER #0</span>
					<p style={countLine}>
						<span style={countLabel}>count =</span>
						<span style={countValue}>0</span>
					</p>
					<div>
						<p style={handlerLabel}>click handler ran</p>
						<p style={handlerBox}>setCount(<span style={sub}>0</span> + 1)</p>
					</div>
				</div>
				<span style={arrow.idle} aria-hidden="true">&rarr;</span>
				<div style={card.ghost}>
					<p style={ghostText}>still the same<br />photo</p>
				</div>
			</div>
			<p style={strip.queued}>
				<span style={stripTag(AMBER)}>queued</span>set count = 1 &mdash; scheduled, not applied
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: re-render; render #1 is the new photo, #0 fades out ---- */}
	<DiagramStep caption="React re-renders. A new render, a new snapshot — render #1 holds count = 1. The old photo is gone; the setter produced the next card rather than editing the first.">
		<div style={stage}>
			<div style={frameRow}>
				<div style={card.faded}>
					<span style={pill.dim}>RENDER #0</span>
					<p style={countLine}>
						<span style={countLabel}>count =</span>
						<span style={countValue}>0</span>
					</p>
					<div>
						<p style={handlerLabel}>previous photo</p>
						<p style={handlerBox}>setCount(0 + 1)</p>
					</div>
				</div>
				<span style={arrow.live} aria-hidden="true">&rarr;</span>
				<div style={card.active}>
					<span style={pill.active}>RENDER #1</span>
					<p style={countLine}>
						<span style={countLabel}>count =</span>
						<span style={countValue}>1</span>
					</p>
					<div>
						<p style={handlerLabel}>click handler</p>
						<p style={handlerBox}>setCount(<span style={sub}>1</span> + 1)</p>
					</div>
				</div>
			</div>
			<p style={strip.fresh}>
				<span style={stripTag(INDIGO)}>new snapshot</span>count is now 1 for the whole render
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
