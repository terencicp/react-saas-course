---
// The update queue: value vs updater (diagram id: queue-value-vs-updater,
// Chapter 023 L4). The visual HINGE of the lesson — it sits between the
// "why the snapshot holds" section and the updater-form fix, and its whole job
// is to make the asymmetry between the two queues obvious at a glance:
//
//   Pass a VALUE  — setCount(count + 1) ×3 — every entry was computed from the
//   same frozen snapshot (count = 0), and a value entry just *replaces*. So the
//   queue is three IDENTICAL "replace → 1" chips that all land on the same 1.
//   They visibly collapse. This is the bug.
//
//   Pass an UPDATER — setCount((c) => c + 1) ×3 — each entry is a FUNCTION that
//   receives the running result of the one before it. So the queue is three
//   function chips, and a threaded chain runs alongside them: 0 → 1 → 2 → 3.
//   They stack instead of collapsing. This is the fix.
//
// Built as a TabbedContent (its stated use case: alternatives of the same idea
// with per-tab captions; it provides its own figure card, so NO <Figure>
// wrapper). Hand-written HTML/CSS inside each tab.
//
// Layout per tab is a fixed three-zone horizontal row so both tabs are the SAME
// shape and the same height (the lesson calls for matched heights):
//   [ QUEUE column ]  →  [ RESOLUTION lane ]  →  [ RESULT chip ]
// In the value tab the resolution lane is a single "=" (the chips collapse to
// one value). In the updater tab the resolution lane is the threaded chain
// 0 → 1 → 2 → 3, with each hop sitting beside the function chip that produced
// it, so the reader sees each function consuming the previous output.
//
// House style is inherited verbatim from this lesson's SnapshotTimeline so the
// chapter reads as one continuous visual argument: fixed slate ink, color-scheme
// pinned light so the hand-picked tints survive dark mode, margin: 0 on every
// inner element to defeat Starlight's injected prose margins, mono for code,
// indigo as the lesson's active accent. Here the two queues also carry a
// semantic tint — rose for the value queue (the bug) and emerald for the updater
// queue (the fix) — mirroring the red/green of the CodeVariants that follow.

import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // chip / lane surface
const BORDER = '#cbd5e1'; // ordinary edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)

const INDIGO = '#4f46e5'; // indigo-600 — the lesson's active accent (result)
const INDIGO_SOFT = '#eef2ff'; // indigo-50
const INDIGO_INK = '#3730a3'; // indigo-800

const ROSE = '#e11d48'; // rose-600 — the value queue (the bug)
const ROSE_BG = '#fff1f2'; // rose-50
const ROSE_INK = '#9f1239'; // rose-800

const EMERALD = '#059669'; // emerald-600 — the updater queue (the fix)
const EMERALD_BG = '#ecfdf5'; // emerald-50
const EMERALD_INK = '#065f46'; // emerald-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by both tabs: pinned light, slate ink, centered column so
// the two tabs are the same shape and never reflow when switched.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The header line at the top of each tab: the call, repeated ×3.
const header = `display: flex; flex-wrap: wrap; align-items: baseline; justify-content: center; gap: 8px; margin: 0;`;
const headerCall = `margin: 0; padding: 4px 10px; border-radius: 8px; background: ${PANEL_BG}; border: 1px solid ${BORDER}; font-family: ${mono}; font-size: 13.5px; font-weight: 700; color: ${INK}; white-space: nowrap;`;
const headerTimes = `margin: 0; font-family: ${sans}; font-size: 13px; font-weight: 700; color: ${INK_SOFT};`;

// The three-zone row: [queue] → [resolution] → [result]. `wrap` keeps it
// horizontal on a laptop and only stacks on a genuinely narrow viewport.
const row = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 12px; margin: 0; width: 100%;`;

// A zone heading (uppercase tag) above the queue and result columns.
const zoneLabel = `margin: 0 0 8px; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: ${INK_SOFT}; text-align: center;`;

// The QUEUE column — a labeled, tinted frame holding the three stacked entries.
const queueCol = (bg: string, edge: string) =>
	`box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 11px 12px; border-radius: 12px; background: ${bg}; border: 1px solid ${edge};`;

// One queue entry chip. `tone` swaps the accent edge / text per tab.
const chipBase = `box-sizing: border-box; display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 10px; min-width: 188px; border-radius: 8px; background: ${SURFACE};`;
const chipRose = `${chipBase} border: 1.5px solid ${ROSE};`;
const chipEmerald = `${chipBase} border: 1.5px solid ${EMERALD};`;

// The little "#n" index that prefixes each entry, so the order is explicit.
const idxBase = `display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 18px; height: 18px; margin: 0; font-family: ${mono}; font-size: 10px; font-weight: 700; color: #ffffff; border-radius: 999px;`;
const idxRose = `${idxBase} background: ${ROSE};`;
const idxEmerald = `${idxBase} background: ${EMERALD};`;

// The code inside an entry chip (the queued value / function).
const chipCode = `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 700; color: ${INK}; white-space: nowrap;`;
const chipMeta = `margin: 0 0 0 auto; font-family: ${sans}; font-size: 10.5px; font-weight: 600; color: ${INK_SOFT};`;

// The RESOLUTION lane between queue and result.
// Value tab: a single big "=" (the chips collapse to one value).
const eq = `display: flex; flex: 0 0 auto; align-items: center; align-self: center; margin: 0; font-family: ${mono}; font-size: 26px; font-weight: 800; line-height: 1; color: ${INK_SOFT};`;

// Updater tab: the threaded chain 0 → 1 → 2 → 3, one hop per function chip.
const chainCol = `box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; margin: 0;`;
const chainLabel = `margin: 0 0 8px; font-family: ${sans}; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: ${EMERALD_INK}; text-align: center;`;
// One hop row: prev → next, sitting at the same height as its function chip.
const hop = `display: flex; align-items: center; gap: 6px; margin: 0; height: 34px;`;
const hopNum = `display: inline-flex; align-items: center; justify-content: center; min-width: 26px; height: 26px; margin: 0; padding: 0 6px; font-family: ${mono}; font-size: 14px; font-weight: 800; color: ${INK}; background: ${SURFACE}; border: 1.5px solid ${BORDER}; border-radius: 7px; font-variant-numeric: tabular-nums;`;
const hopNumIn = `${hopNum} color: ${INK_SOFT};`; // the incoming "c" value, muted
const hopNumOut = `${hopNum} color: ${EMERALD_INK}; border-color: ${EMERALD};`; // the produced value, emphasized
const hopArrow = `margin: 0; font-family: ${sans}; font-size: 16px; font-weight: 800; line-height: 1; color: ${EMERALD};`;
const hopWho = `margin: 0 0 0 4px; font-family: ${mono}; font-size: 10.5px; font-weight: 600; color: ${EMERALD_INK}; white-space: nowrap;`;

// The arrow joining the chain lane to the result in the updater tab.
const laneArrow = `display: flex; flex: 0 0 auto; align-items: center; align-self: center; margin: 0; font-size: 22px; font-weight: 800; line-height: 1; color: ${INDIGO};`;

// The RESULT chip — the next render's value, in the lesson's indigo accent.
const resultCol = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; margin: 0;`;
const resultChip = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 2px; margin: 0; padding: 12px 16px; border-radius: 12px; background: ${INDIGO_SOFT}; border: 2px solid ${INDIGO};`;
const resultLabel = `margin: 0; font-family: ${mono}; font-size: 11.5px; font-weight: 700; color: ${INDIGO_INK};`;
const resultValue = `margin: 0; font-family: ${mono}; font-size: 32px; font-weight: 800; line-height: 1; color: ${INDIGO_INK}; font-variant-numeric: tabular-nums;`;

// A small summary pill under each row, restating what the queue did.
const noteBase = `display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 6px 12px; border-radius: 999px; font-family: ${sans}; font-size: 12.5px; font-weight: 600; line-height: 1.3; text-align: center;`;
const noteRose = `${noteBase} color: ${ROSE_INK}; background: ${ROSE_BG}; border: 1px solid ${ROSE};`;
const noteEmerald = `${noteBase} color: ${EMERALD_INK}; background: ${EMERALD_BG}; border: 1px solid ${EMERALD};`;
const noteTag = (bg: string) =>
	`display: inline-block; margin: 0; padding: 1px 6px; font-family: ${mono}; font-size: 9px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #ffffff; background: ${bg}; border-radius: 4px;`;
---

<TabbedContent syncKey="queue-value-vs-updater">
	{/* ===== Tab 1: Pass a value — three identical "replace" entries collapse ===== */}
	<TabbedItem label="Pass a value">
		<div style={stage}>
			<div style={header}>
				<span style={headerCall}>setCount(count + 1)</span>
				<span style={headerTimes}>called &times;3</span>
			</div>

			<div style={row}>
				{/* QUEUE: three identical "replace → 1" chips */}
				<div style={resultCol}>
					<p style={zoneLabel}>update queue</p>
					<div style={queueCol(ROSE_BG, ROSE)}>
						<div style={chipRose}>
							<span style={idxRose}>1</span>
							<span style={chipCode}>replace &rarr; 1</span>
							<span style={chipMeta}>count + 1 = 0 + 1</span>
						</div>
						<div style={chipRose}>
							<span style={idxRose}>2</span>
							<span style={chipCode}>replace &rarr; 1</span>
							<span style={chipMeta}>count + 1 = 0 + 1</span>
						</div>
						<div style={chipRose}>
							<span style={idxRose}>3</span>
							<span style={chipCode}>replace &rarr; 1</span>
							<span style={chipMeta}>count + 1 = 0 + 1</span>
						</div>
					</div>
				</div>

				{/* RESOLUTION: they collapse — a single "=" */}
				<span style={eq} aria-hidden="true">=</span>

				{/* RESULT */}
				<div style={resultCol}>
					<p style={zoneLabel}>next render</p>
					<div style={resultChip}>
						<span style={resultLabel}>count =</span>
						<span style={resultValue}>1</span>
					</div>
				</div>
			</div>

			<p style={noteRose}>
				<span style={noteTag(ROSE)}>collapse</span>each entry replaces the last &mdash; all three land on
				1
			</p>
		</div>
		<Fragment slot="caption">
			Every entry was computed from the same snapshot (<code>count</code> is <code>0</code>), and a value
			entry just <em>replaces</em>. Three identical &ldquo;replace with 1&rdquo; entries all land on the
			same <code>1</code>.
		</Fragment>
	</TabbedItem>

	{/* ===== Tab 2: Pass an updater — three functions thread 0 → 1 → 2 → 3 ===== */}
	<TabbedItem label="Pass an updater">
		<div style={stage}>
			<div style={header}>
				<span style={headerCall}>setCount((c) =&gt; c + 1)</span>
				<span style={headerTimes}>called &times;3</span>
			</div>

			<div style={row}>
				{/* QUEUE: three function chips */}
				<div style={resultCol}>
					<p style={zoneLabel}>update queue</p>
					<div style={queueCol(EMERALD_BG, EMERALD)}>
						<div style={chipEmerald}>
							<span style={idxEmerald}>1</span>
							<span style={chipCode}>(c) =&gt; c + 1</span>
							<span style={chipMeta}>function</span>
						</div>
						<div style={chipEmerald}>
							<span style={idxEmerald}>2</span>
							<span style={chipCode}>(c) =&gt; c + 1</span>
							<span style={chipMeta}>function</span>
						</div>
						<div style={chipEmerald}>
							<span style={idxEmerald}>3</span>
							<span style={chipCode}>(c) =&gt; c + 1</span>
							<span style={chipMeta}>function</span>
						</div>
					</div>
				</div>

				{/* RESOLUTION: the threaded chain, one hop beside each function */}
				<div style={chainCol}>
					<p style={chainLabel}>each receives the last result</p>
					<div style={hop}>
						<span style={hopNumIn}>0</span>
						<span style={hopArrow} aria-hidden="true">&rarr;</span>
						<span style={hopNumOut}>1</span>
						<span style={hopWho}>#1</span>
					</div>
					<div style={hop}>
						<span style={hopNumIn}>1</span>
						<span style={hopArrow} aria-hidden="true">&rarr;</span>
						<span style={hopNumOut}>2</span>
						<span style={hopWho}>#2</span>
					</div>
					<div style={hop}>
						<span style={hopNumIn}>2</span>
						<span style={hopArrow} aria-hidden="true">&rarr;</span>
						<span style={hopNumOut}>3</span>
						<span style={hopWho}>#3</span>
					</div>
				</div>

				<span style={laneArrow} aria-hidden="true">&rarr;</span>

				{/* RESULT */}
				<div style={resultCol}>
					<p style={zoneLabel}>next render</p>
					<div style={resultChip}>
						<span style={resultLabel}>count =</span>
						<span style={resultValue}>3</span>
					</div>
				</div>
			</div>

			<p style={noteEmerald}>
				<span style={noteTag(EMERALD)}>thread</span>each function consumes the previous output &mdash;
				they stack to 3
			</p>
		</div>
		<Fragment slot="caption">
			Each function receives the result of the previous one, so they <em>stack</em> instead of collapsing:
			<code>0 &rarr; 1 &rarr; 2 &rarr; 3</code>.
		</Fragment>
	</TabbedItem>
</TabbedContent>
