---
// react-rights-panel — Chapter 023 Lesson 3, "Why React demands this".
//
// A glanceable panel that compresses the four moves React reserves the right
// to make into one visual the student can recall as a unit, each paired with
// the failure it causes against an IMPURE component.
//
//   <title>  React reserves the right to…
//
//   [icon] the right React reserves        →   ⚠ what breaks if you're impure
//
// Four rows, one per reserved right. The left cell is neutral chrome (a small
// inline-SVG glyph + the right, framed as something React is allowed to do);
// the right cell is a saturated red "failure tag" pill (the symptom). A short
// connector between them makes the "right → failure" mapping the through-line.
//
// Plain HTML + CSS, inline styles only, devtools-inspectable — matches the
// chapter's other figures (StateSpaceCollapse / SameSiteMatrix): a
// `not-content` wrapper, a `margin: 0` reset on every inner node to defeat
// Starlight's prose-margin selector, theme-aware Starlight gray variables for
// chrome, and a saturated red-600 fill (reads in light + dark) where the color
// carries the "this is the failure" signal. Icons are inline SVG rather than an
// icon font, consistent with every other lesson figure in the course. No graph
// engine — per the diagram index an annotated illustration is plain HTML+CSS.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const FAIL = "#dc2626"; // red-600 — the failure color, reads in both themes

// The four reserved rights, top → bottom. `right` is the neutral capability
// (left cell); `failure` is the symptom against an impure component (red pill).
// `glyph` selects the inline-SVG icon drawn beside the right.
const rows = [
  {
    glyph: "double",
    right: "Render twice in dev",
    sub: "Strict Mode",
    failure: "Counter increments by 2",
  },
  {
    glyph: "pause",
    right: "Pause and restart a render",
    sub: "concurrent",
    failure: "Side effect fires for a tree that never shipped",
  },
  {
    glyph: "skip",
    right: "Skip a render entirely",
    sub: "Compiler",
    failure: "Counter silently stops",
  },
  {
    glyph: "shuffle",
    right: "Render out of order, or not at all",
    sub: "scheduling",
    failure: "Code that assumed an order is wrong",
  },
];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  sans,
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Title bar across the top — the panel names itself so it reads standalone.
const titleBar = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-2)",
  "padding: 0 2px 8px",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
  "line-height: 1.2",
].join("; ");

// One flex row per right: [left capability cell] → [failure pill]. The row
// wraps (flex-wrap) so on a narrow viewport the pill drops below its cell
// instead of overflowing the figure card. The "right ⇒ failure" arrow lives
// as a leading chevron INSIDE the pill, so it reads correctly whether the two
// cells sit side-by-side or stacked.
const rowGrid = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "column-gap: 12px",
  "row-gap: 6px",
  "box-sizing: border-box",
].join("; ");

// Left cell — neutral chrome: a glyph tile + the right (with a quiet sub-label).
const rightCell = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 10px",
  "flex: 1 1 240px",
  "padding: 9px 12px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.04))",
  "box-sizing: border-box",
  "min-width: 0",
].join("; ");

const glyphTile = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "flex: none",
  "width: 30px",
  "height: 30px",
  "border-radius: 7px",
  "background: var(--sl-color-gray-5)",
  "color: var(--sl-color-gray-1)",
].join("; ");

const rightTextWrap = [reset, "display: flex", "flex-direction: column", "gap: 1px", "min-width: 0"].join("; ");

const rightText = [
  reset,
  sans,
  "font-size: 13.5px",
  "font-weight: 600",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const subText = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 400",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Leading chevron inside the pill — carries the "right ⇒ this failure"
// relationship and reads correctly whether the pill is beside or below the
// capability cell. Drawn in a muted tint so the red pill body stays dominant.
const chevron = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "flex: none",
  "color: rgba(255, 255, 255, 0.7)",
].join("; ");

// Right cell — the saturated red failure pill (chevron + warning glyph + text).
const failPill = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "flex: 1 1 220px",
  "padding: 8px 12px",
  "border-radius: 8px",
  "background: " + FAIL,
  "color: #ffffff",
  "box-sizing: border-box",
  "min-width: 0",
].join("; ");

const failText = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.25",
  "color: #ffffff",
].join("; ");

// Shared SVG attributes for the right-glyphs (drawn in currentColor).
const iconAttrs = {
  width: "18",
  height: "18",
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "2",
  "stroke-linecap": "round" as const,
  "stroke-linejoin": "round" as const,
  "aria-hidden": "true",
  style: "margin: 0; display: block;",
};
---

<div class="not-content" style={root}>
  <div style={titleBar}>React reserves the right to&hellip;</div>

  {
    rows.map((r) => (
      <div style={rowGrid}>
        {/* LEFT — the neutral capability React is allowed to use */}
        <div style={rightCell}>
          <span style={glyphTile}>
            {r.glyph === "double" && (
              <svg {...iconAttrs}>
                <rect x="3" y="3" width="13" height="13" rx="2" />
                <path d="M8 21h11a2 2 0 0 0 2-2V8" />
              </svg>
            )}
            {r.glyph === "pause" && (
              <svg {...iconAttrs}>
                <line x1="9" y1="5" x2="9" y2="14" />
                <line x1="15" y1="5" x2="15" y2="14" />
                <path d="M5 19a8 8 0 0 0 14 0" />
                <polyline points="19 15 19 19 15 19" />
              </svg>
            )}
            {r.glyph === "skip" && (
              <svg {...iconAttrs}>
                <polyline points="5 4 13 12 5 20" />
                <line x1="19" y1="4" x2="19" y2="20" />
              </svg>
            )}
            {r.glyph === "shuffle" && (
              <svg {...iconAttrs}>
                <path d="M4 7h3l9 10h4" />
                <path d="M4 17h3l3-3.5" />
                <path d="M14 9l2-2h4" />
                <polyline points="18 4 21 7 18 10" />
                <polyline points="18 14 21 17 18 20" />
              </svg>
            )}
          </span>
          <span style={rightTextWrap}>
            <span style={rightText}>{r.right}</span>
            <span style={subText}>{r.sub}</span>
          </span>
        </div>

        {/* RIGHT — what breaks when the component is impure. Leading chevron
            carries the "right ⇒ this failure" relationship. */}
        <div style={failPill}>
          <span style={chevron}>
            <svg
              width="20"
              height="14"
              viewBox="0 0 20 14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              style="margin: 0; display: block;"
            >
              <line x1="1" y1="7" x2="15" y2="7" />
              <polyline points="11 2 17 7 11 12" />
            </svg>
          </span>
          <svg
            width="17"
            height="17"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#ffffff"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            style="margin: 0; display: block; flex: none;"
          >
            <path d="M10.29 3.86 1.82 18a1.5 1.5 0 0 0 1.29 2.25h17.78A1.5 1.5 0 0 0 22.18 18L13.71 3.86a1.5 1.5 0 0 0-2.42 0Z" />
            <line x1="12" y1="9" x2="12" y2="13" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
          </svg>
          <span style={failText}>{r.failure}</span>
        </div>
      </div>
    ))
  }
</div>
