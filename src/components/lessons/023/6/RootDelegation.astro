---
// root-delegation-diagram — Chapter 023 Lesson 6, "Delegation happens at the
// React root".
//
// The counterintuitive fact the lesson hangs on: an `onClick` prop is NOT a
// native listener on that button. Since React 17 there is ONE native listener
// per event type at the root container, and React dispatches a synthetic event
// back DOWN through its own component tree. This figure makes that visible and,
// in the same picture, the production-biting consequence: because the listener
// lives at the root (not `document`), a child's `e.stopPropagation()` contains
// the native event BEFORE it reaches a `document`-level listener.
//
// Two lanes, side by side (an annotated-illustration shape → plain HTML+CSS per
// the diagrams index; deliberately NOT ArrowDiagram, whose LeaderLines can't be
// relocated into the Figure lightbox and whose two-lane geometry is fiddly).
//
//   LEFT  "Real DOM"   document ──✕ stopPropagation ✕── root <div id=root>
//                      [React's ONE click listener] ── <form> ── <button> (clicked)
//                      A single bubble arrow runs UP button → form → root; the
//                      segment root → document is struck out (the cut).
//
//   CENTER  a "dispatch" arrow from the root listener INTO the React tree.
//
//   RIGHT "React tree" <App> → <SignupForm> → <SubmitButton onClick> — the tree
//                      React walks to fire the matched handler.
//
// Chrome is theme-aware (Starlight gray vars flip light/dark); the root-listener
// badge is the one saturated accent (React cyan, white text — reads on both
// backgrounds) because that node IS the lesson. The cut is a fixed red-600. A
// `margin: 0` reset on every node defeats Starlight's injected prose margins.
// Plain HTML/CSS, no LeaderLines → survives the Figure lightbox, so the wrapping
// <Figure> stays `expandable`.

// LEFT lane — the real DOM nodes, top (document) → bottom (the clicked button).
// `role` drives the chrome: the root container is the saturated accent, the
// button is the click origin.
const domNodes = [
	{
		label: 'document',
		role: 'document',
		badge: 'native click listener',
		note: 'can be suppressed',
	},
	{
		label: '<div id="root">',
		role: 'root',
		badge: "React's ONE click listener",
		note: 'one per event type',
	},
	{ label: '<form>', role: 'plain' },
	{ label: '<button>', role: 'clicked' },
];

// RIGHT lane — the React component tree React dispatches the synthetic event
// through, top → bottom, ending on the component whose handler matches.
const reactNodes = [
	{ label: '<App>', handler: null },
	{ label: '<SignupForm>', handler: null },
	{ label: '<SubmitButton>', handler: 'onClick' },
];
---

<div class="rd not-content">
	{/* ─────────────── LEFT LANE: real DOM ─────────────── */}
	<div class="rd-lane">
		<span class="rd-lane-title">Real DOM</span>

		<div class="rd-stack">
			{
				domNodes.map((node, i) => (
					<>
						{/* The connector ABOVE this node. The gap above the root
						    node IS the document↔root boundary — the cut where a
						    child's stopPropagation contains the event; every other
						    gap is a plain upward bubble. */}
						{i > 0 && (
							<div
								class:list={[
									'rd-link',
									node.role === 'root' && 'rd-link-cut',
								]}
								aria-hidden="true"
							>
								<span class="rd-link-arrow">↑</span>
								{node.role === 'root' && (
									<span class="rd-cut-tag">
										<span class="rd-cut-x">✕</span>
										stopPropagation
									</span>
								)}
							</div>
						)}

						<div class:list={['rd-node', `rd-node-${node.role}`]}>
							<code class="rd-node-label">{node.label}</code>
							{node.badge && (
								<span class="rd-node-badge">
									<span class="rd-badge-title">{node.badge}</span>
									<span class="rd-badge-note">{node.note}</span>
								</span>
							)}
							{node.role === 'clicked' && (
								<span class="rd-click">
									<span class="rd-cursor">⊕</span> clicked
								</span>
							)}
						</div>
					</>
				))
			}
		</div>

		<span class="rd-lane-foot">
			click bubbles <strong>up</strong> to the one root listener
		</span>
	</div>

	{/* ─────────── CENTER: the dispatch hand-off ─────────── */}
	<div class="rd-dispatch" aria-hidden="true">
		<span class="rd-dispatch-label">React dispatches</span>
		<span class="rd-dispatch-arrow">⟶</span>
		<span class="rd-dispatch-sub">synthetic event</span>
	</div>

	{/* ─────────────── RIGHT LANE: React tree ─────────────── */}
	<div class="rd-lane">
		<span class="rd-lane-title">React tree</span>

		<div class="rd-stack">
			{
				reactNodes.map((node, i) => (
					<>
						{i > 0 && (
							<div class="rd-link rd-link-down" aria-hidden="true">
								<span class="rd-link-arrow">↓</span>
							</div>
						)}
						<div
							class:list={[
								'rd-node',
								'rd-node-react',
								node.handler && 'rd-node-matched',
							]}
						>
							<code class="rd-node-label">{node.label}</code>
							{node.handler && (
								<span class="rd-handler">
									<code class="rd-handler-prop">{node.handler}</code>
									<span class="rd-handler-note">runs</span>
								</span>
							)}
						</div>
					</>
				))
			}
		</div>

		<span class="rd-lane-foot">
			down to the matched <strong>handler</strong>
		</span>
	</div>
</div>

<style>
	.rd {
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 14px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* ── lanes ───────────────────────────────────────────── */
	.rd-lane {
		display: flex;
		flex-direction: column;
		align-items: center;
		flex: 0 1 16rem;
		min-width: 0;
		margin: 0;
	}

	.rd-lane-title {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0 0 7px;
	}

	.rd-lane-foot {
		font-size: 0.68rem;
		line-height: 1.3;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
		margin: 8px 0 0;
		max-width: 15rem;
	}

	.rd-stack {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		width: 100%;
		margin: 0;
	}

	/* ── nodes ───────────────────────────────────────────── */
	.rd-node {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 7px 11px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		margin: 0;
	}

	.rd-node-label {
		box-sizing: border-box;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.84rem;
		font-weight: 600;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	/* document: quiet neutral, dashed — the outer node that may never see the event */
	.rd-node-document {
		border-style: dashed;
		border-color: var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-gray-6, #f1f5f9);
	}

	/* root container: THE node — the one saturated accent (React cyan). */
	.rd-node-root {
		border: 1px solid #0e7490; /* cyan-700 */
		background: #0891b2; /* cyan-600 — reads on light and dark */
		box-shadow: 0 1px 4px rgba(8, 145, 178, 0.42);
	}
	.rd-node-root .rd-node-label {
		color: #ffffff;
	}

	/* the clicked button — origin of the event */
	.rd-node-clicked {
		border-color: var(--sl-color-gray-4, #94a3b8);
	}

	.rd-node-react {
		border-color: var(--sl-color-gray-5, #cbd5e1);
	}

	/* the matched component: subtle cyan tie-back to the root listener */
	.rd-node-matched {
		border-color: #0e7490;
		background: rgba(8, 145, 178, 0.1);
	}

	/* ── badges inside a node ────────────────────────────── */
	.rd-node-badge {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 1px 0 0;
	}
	.rd-badge-title {
		font-size: 0.66rem;
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.rd-badge-note {
		font-size: 0.6rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	/* on the saturated root node the badge text must be light */
	.rd-node-root .rd-badge-title {
		color: #ffffff;
	}
	.rd-node-root .rd-badge-note {
		color: rgba(255, 255, 255, 0.85);
	}

	.rd-click {
		display: inline-flex;
		align-items: center;
		gap: 3px;
		align-self: flex-start;
		margin: 2px 0 0;
		padding: 0 6px;
		border-radius: 999px;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-1, #334155);
		background: var(--sl-color-gray-5, #e2e8f0);
	}
	.rd-cursor {
		font-size: 0.72rem;
		line-height: 1;
	}

	/* the onClick that fires on the matched component */
	.rd-handler {
		display: inline-flex;
		align-items: baseline;
		gap: 5px;
		margin: 1px 0 0;
	}
	.rd-handler-prop {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.74rem;
		font-weight: 700;
		color: #0e7490; /* cyan-700 */
		background: transparent;
		padding: 0;
		margin: 0;
	}
	.rd-handler-note {
		font-size: 0.62rem;
		font-weight: 600;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── connectors between stacked nodes ────────────────── */
	.rd-link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		min-height: 22px;
		margin: 0;
	}
	.rd-link-arrow {
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.rd-link-down .rd-link-arrow {
		color: #0e7490; /* cyan — the dispatch flows down the React tree */
	}

	/* the cut: document never receives the event once a child stops it */
	.rd-link-cut {
		min-height: 30px;
	}
	.rd-link-cut .rd-link-arrow {
		color: #dc2626; /* red-600 */
		text-decoration: line-through;
		opacity: 0.55;
	}
	.rd-cut-tag {
		display: inline-flex;
		align-items: center;
		gap: 3px;
		padding: 1px 7px;
		border-radius: 999px;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		color: #ffffff;
		background: #dc2626; /* red-600 — reads on both themes */
		white-space: nowrap;
		margin: 0;
	}
	.rd-cut-x {
		font-size: 0.66rem;
		line-height: 1;
	}

	/* ── center: the dispatch hand-off ───────────────────── */
	.rd-dispatch {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		gap: 1px;
		margin: 0;
	}
	.rd-dispatch-label {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #0e7490; /* cyan-700 */
		margin: 0;
	}
	.rd-dispatch-arrow {
		font-size: 1.55rem;
		font-weight: 700;
		line-height: 1;
		color: #0891b2; /* cyan-600 */
		margin: 1px 0;
	}
	.rd-dispatch-sub {
		font-size: 0.6rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* ── narrow viewports: stack the two lanes, rotate the hand-off ── */
	@media (max-width: 640px) {
		.rd {
			flex-direction: column;
			align-items: center;
			gap: 6px;
		}
		.rd-lane {
			flex: 0 0 auto;
			width: 100%;
			max-width: 20rem;
		}
		.rd-dispatch {
			flex-direction: row;
			gap: 8px;
		}
		.rd-dispatch-arrow {
			transform: rotate(90deg);
			margin: 0;
		}
	}
</style>
