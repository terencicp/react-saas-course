---
// Type-match vs type-mismatch reconciliation (diagram id: diagram-type-match,
// Chapter 023 L2). Two small before -> after tree pairs, side by side, so the
// contrast is simultaneous:
//
//   LEFT  "Same type — reused":  div.a -> div.b. The parent kept the SAME type,
//         so React keeps the DOM node and patches only the changed attribute;
//         the child underneath survives untouched. The after-tree carries the
//         signal: parent tinted GREEN ("kept · attribute patched"), child a
//         green outline ("kept").
//
//   RIGHT "Different type — rebuilt":  div -> section. The type at the position
//         changed, so React tears the whole old subtree down (the before-tree
//         is stamped RED, "torn down") and builds a brand-new one (the after-
//         tree's section + child are BLUE, "built fresh") — even though the
//         child markup is byte-identical, that node is gone and remade.
//
// Color is the only thing that carries meaning here, so the three signal tints
// are saturated mid-tones (green-600 / red-600 / blue-600) that read on both
// light and dark page backgrounds with white text. The rest of the chrome is
// fixed slate ink with color-scheme pinned light so the hand-picked tints
// survive dark mode — same house style as this chapter's RenderCommitStrip and
// L5's DomVsReactTree. `margin: 0` on every element defeats Starlight's injected
// prose margin-top. Each tree is just 2 nodes (parent + child) to stay tiny and
// short, per the vertical-space constraint.

// Palette ---------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const NODE_BG = '#ffffff'; // ordinary node surface
const NODE_BORDER = '#cbd5e1'; // ordinary node edge (slate-300)
const GUIDE = '#cbd5e1'; // tree connector lines (slate-300)
const PANEL_BG = '#f8fafc'; // panel wash (slate-50)
const PANEL_BORDER = '#e2e8f0'; // panel edge (slate-200)

const GREEN = '#16a34a'; // green-600 — "kept"
const GREEN_SOFT = '#dcfce7'; // green-100 — kept child wash
const GREEN_INK = '#166534'; // green-800 — kept child text
const RED = '#dc2626'; // red-600 — "torn down"
const BLUE = '#2563eb'; // blue-600 — "built fresh"
const BLUE_SOFT = '#dbeafe'; // blue-100 — fresh child wash
const BLUE_INK = '#1e40af'; // blue-800 — fresh child text

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// One node chip: a monospace tag in a rounded box. `tint` picks the surface.
const nodeBase = `display: flex; flex: 0 0 auto; width: fit-content; align-items: center; gap: 6px; margin: 0; padding: 4px 10px; font-family: ${mono}; font-size: 13px; font-weight: 600; line-height: 1.3; border-radius: 7px; white-space: nowrap;`;
const node = {
	plain: `${nodeBase} color: ${INK}; background: ${NODE_BG}; border: 1px solid ${NODE_BORDER};`,
	plainChild: `${nodeBase} color: ${INK_SOFT}; background: ${NODE_BG}; border: 1px solid ${NODE_BORDER};`,
	// "kept" — the reused parent, saturated green with white text.
	keptParent: `${nodeBase} color: #ffffff; background: ${GREEN}; border: 1px solid ${GREEN};`,
	// "kept" child — survived untouched, soft green so it reads as preserved.
	keptChild: `${nodeBase} color: ${GREEN_INK}; background: ${GREEN_SOFT}; border: 1px solid ${GREEN};`,
	// "built fresh" — the new section, saturated blue with white text.
	freshParent: `${nodeBase} color: #ffffff; background: ${BLUE}; border: 1px solid ${BLUE};`,
	freshChild: `${nodeBase} color: ${BLUE_INK}; background: ${BLUE_SOFT}; border: 1px solid ${BLUE};`,
};

// A child indented under its parent: a vertical guide + a short connector stub.
const childWrap = `display: flex; flex-direction: column; margin: 7px 0 0 13px; padding: 0 0 0 13px; border-left: 1.5px solid ${GUIDE}; width: fit-content;`;
const childRow = `display: flex; align-items: center; gap: 0; margin: 0; width: fit-content;`;
const stub = `flex: 0 0 auto; width: 12px; height: 0; margin: 0; border-top: 1.5px solid ${GUIDE};`;

// A small status caption under each after-tree. `tone` colours the text.
const tag = (tone: string) =>
	`display: block; margin: 9px 0 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.3; color: ${tone};`;

// One tree (parent + one child), optionally stamped "torn down" (red overlay
// with a strike) for the old subtree that gets discarded.
const treeWrap = `display: flex; flex-direction: column; align-items: flex-start; margin: 0; padding: 0; width: fit-content;`;
const tornStamp = `display: inline-block; margin: 7px 0 0; padding: 1px 7px; border-radius: 999px; font-family: ${sans}; font-size: 11px; font-weight: 700; letter-spacing: 0.01em; color: #ffffff; background: ${RED};`;

const arrow = `flex: 0 0 auto; align-self: center; margin: 0 2px; font-family: ${sans}; font-size: 16px; font-weight: 700; color: ${INK_SOFT};`;
const renderLabel = `display: block; margin: 0 0 5px; font-family: ${sans}; font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: ${INK_SOFT};`;

const panelStyle = `display: flex; flex-direction: column; gap: 0; flex: 1 1 320px; min-width: 280px; margin: 0; padding: 14px 16px 16px; border: 1px solid ${PANEL_BORDER}; border-radius: 12px; background: ${PANEL_BG};`;
const panelTitle = `display: flex; align-items: baseline; gap: 8px; margin: 0 0 14px; font-family: ${sans}; font-size: 14px; font-weight: 700; color: ${INK};`;
const panelSwatch = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 11px; height: 11px; border-radius: 3px; margin: 0; background: ${c};`;
const pairRow = `display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: center; gap: 10px; margin: 0;`;
const colWrap = `display: flex; flex-direction: column; align-items: flex-start; margin: 0; width: fit-content;`;
---

<div
	class="not-content"
	style={`display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 16px; margin: 0; color-scheme: light; font-family: ${sans}; color: ${INK};`}
>
	{/* ---- LEFT: same type, node reused ---- */}
	<div style={panelStyle}>
		<div style={panelTitle}>
			<span style={panelSwatch(GREEN)}></span>
			<span style="margin: 0;">Same type &mdash; reused</span>
		</div>
		<div style={pairRow}>
			{/* before */}
			<div style={colWrap}>
				<span style={renderLabel}>before</span>
				<div style={treeWrap}>
					<div style={node.plain}>{'<div className="a">'}</div>
					<div style={childWrap}>
						<div style={childRow}>
							<div style={stub}></div>
							<div style={node.plainChild}>{'<input>'}</div>
						</div>
					</div>
				</div>
			</div>
			<span style={arrow} aria-hidden="true">&rarr;</span>
			{/* after */}
			<div style={colWrap}>
				<span style={renderLabel}>after</span>
				<div style={treeWrap}>
					<div style={node.keptParent}>{'<div className="b">'}</div>
					<div style={childWrap}>
						<div style={childRow}>
							<div style={stub}></div>
							<div style={node.keptChild}>{'<input>'}</div>
						</div>
					</div>
					<span style={tag(GREEN)}>
						node kept &middot; only <code style={`background: transparent; padding: 0; font-family: ${mono}; color: ${GREEN};`}>className</code> patched
					</span>
				</div>
			</div>
		</div>
	</div>

	{/* ---- RIGHT: different type, subtree rebuilt ---- */}
	<div style={panelStyle}>
		<div style={panelTitle}>
			<span style={panelSwatch(RED)}></span>
			<span style="margin: 0;">Different type &mdash; rebuilt</span>
		</div>
		<div style={pairRow}>
			{/* before — torn down */}
			<div style={colWrap}>
				<span style={renderLabel}>before</span>
				<div style={treeWrap}>
					<div style={`${node.plain} opacity: 0.55; text-decoration: line-through; text-decoration-color: ${RED};`}>{'<div>'}</div>
					<div style={`${childWrap} opacity: 0.55;`}>
						<div style={childRow}>
							<div style={stub}></div>
							<div style={`${node.plainChild} text-decoration: line-through; text-decoration-color: ${RED};`}>{'<input>'}</div>
						</div>
					</div>
					<span style={tornStamp}>whole subtree torn down</span>
				</div>
			</div>
			<span style={arrow} aria-hidden="true">&rarr;</span>
			{/* after — built fresh */}
			<div style={colWrap}>
				<span style={renderLabel}>after</span>
				<div style={treeWrap}>
					<div style={node.freshParent}>{'<section>'}</div>
					<div style={childWrap}>
						<div style={childRow}>
							<div style={stub}></div>
							<div style={node.freshChild}>{'<input>'}</div>
						</div>
					</div>
					<span style={tag(BLUE)}>built fresh &middot; child state &amp; DOM reset</span>
				</div>
			</div>
		</div>
	</div>
</div>
