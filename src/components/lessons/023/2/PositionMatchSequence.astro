---
// Position-matching before -> after sequence (diagram id: diagram-position-match,
// Chapter 023 L2). A three-step scrubbable DiagramSequence. The subject is a
// parent with three fixed slots (indices 0/1/2). Each slot is a persistent
// "frame" (the position) that survives all three steps; what changes is the
// item label sitting inside it. A sticky-note "state" badge is physically glued
// to slot 0 the entire time — so when the data reverses and slot 0 merely
// relabels Milk -> Bread, the note visibly stays put on the slot while the item
// it belonged to (Milk) walks down to slot 2 carrying nothing. That is the whole
// point: state belongs to the SLOT, not the ITEM.
//
//   Step 1  initial render        slot0 = Milk (+ note), slot1 = Eggs, slot2 = Bread
//   Step 2  reverse requested     new data [Bread, Eggs, Milk] lines up against the
//                                  SAME slots 0/1/2 by index, not by item
//   Step 3  position wins         slot0 keeps the note, relabels to Bread; Milk
//                                  moved to slot2 with no note — note is stranded
//
// Style matches this chapter's TypeMatchTrees: fixed slate ink, color-scheme
// pinned light so the hand-picked accent tints survive dark mode, `margin: 0` on
// every inner element to defeat Starlight's injected prose margins. The note uses
// a warm amber so it reads as a sticky note distinct from the structural chrome.
// Height is capped by keeping all three steps the same shape (three slot rows +
// one data strip line) so the grid stack never reflows as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary chip surface
const BORDER = '#cbd5e1'; // ordinary chip edge (slate-300)
const SLOT_BG = '#f1f5f9'; // slot frame wash (slate-100)
const SLOT_BORDER = '#cbd5e1'; // slot frame edge (slate-300)
const IDX_BG = '#475569'; // slot-index chip (slate-600)

const AMBER = '#d97706'; // amber-600 — the note's accent
const AMBER_BG = '#fef3c7'; // amber-100 — sticky-note wash
const AMBER_INK = '#92400e'; // amber-800 — note text

const RED = '#dc2626'; // red-600 — "stranded on the wrong item"
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800
const BLUE = '#2563eb'; // blue-600 — "the item that owned the note"
const BLUE_BG = '#dbeafe'; // blue-100
const BLUE_INK = '#1e40af'; // blue-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// One slot row: a fixed-width frame holding [index chip] [item chip] [note?].
const stackWrap = `display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 0; width: 100%; max-width: 340px;`;
const slotRow = `display: flex; align-items: center; gap: 10px; margin: 0; padding: 7px 10px; border: 1px solid ${SLOT_BORDER}; border-radius: 10px; background: ${SLOT_BG};`;
const idxChip = `display: inline-flex; flex: 0 0 auto; align-items: center; justify-content: center; min-width: 54px; margin: 0; padding: 3px 8px; font-family: ${mono}; font-size: 11.5px; font-weight: 700; line-height: 1.3; color: #ffffff; background: ${IDX_BG}; border-radius: 6px; white-space: nowrap;`;

// The item chip — the data sitting in the slot. `tint` swaps the surface.
const itemBase = `display: inline-flex; flex: 1 1 auto; align-items: center; margin: 0; padding: 5px 12px; font-family: ${sans}; font-size: 14px; font-weight: 600; line-height: 1.3; border-radius: 7px; white-space: nowrap;`;
const item = {
	plain: `${itemBase} color: ${INK}; background: ${SURFACE}; border: 1px solid ${BORDER};`,
	// step 3: slot 0 relabeled to the wrong item — flagged red.
	wrong: `${itemBase} color: ${RED_INK}; background: ${RED_BG}; border: 1px solid ${RED};`,
	// step 3: the item that owned the note and walked away — flagged blue.
	owner: `${itemBase} color: ${BLUE_INK}; background: ${BLUE_BG}; border: 1px solid ${BLUE};`,
};

// The sticky-note "state" badge, glued to a slot.
const noteBadge = `display: inline-flex; flex: 0 0 auto; align-items: center; gap: 5px; margin: 0; padding: 4px 9px; font-family: ${sans}; font-size: 12px; font-weight: 600; line-height: 1.2; color: ${AMBER_INK}; background: ${AMBER_BG}; border: 1px solid ${AMBER}; border-radius: 7px; white-space: nowrap;`;
const noteTag = `display: inline-block; margin: 0; padding: 1px 5px; font-family: ${mono}; font-size: 9px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #ffffff; background: ${AMBER}; border-radius: 4px;`;
// A tiny status pin under a slot's item (step 3).
const pin = (bg: string, ink: string) =>
	`display: inline-block; flex: 0 0 auto; margin: 0; padding: 2px 7px; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.2; color: ${ink}; background: ${bg}; border-radius: 999px; white-space: nowrap;`;

// The "incoming data" strip (step 2): the reversed array about to be matched.
const dataStrip = `display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin: 0; padding: 9px 12px; border: 1px dashed ${INK_SOFT}; border-radius: 10px; background: ${SURFACE}; max-width: 340px;`;
const dataLabel = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;
const dataChip = `display: inline-flex; align-items: center; margin: 0; padding: 3px 9px; font-family: ${sans}; font-size: 13px; font-weight: 600; line-height: 1.2; color: ${INK}; background: ${SLOT_BG}; border: 1px solid ${BORDER}; border-radius: 6px; white-space: nowrap;`;

// The vertical down-arrow joining the data strip to the slots (step 2).
const downArrow = `margin: 0; font-family: ${sans}; font-size: 18px; font-weight: 700; line-height: 1; color: ${INK_SOFT};`;
const byIndexNote = `margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT};`;

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all three steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;
// A spacer that reserves the data-strip's vertical footprint on steps 1 & 3 so
// the three panels stay the same height (data strip + arrow ~= one slot row gap).
const spacerLine = `margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT};`;
---

<DiagramSequence>
	{/* ---- Step 1: initial render, everything lines up ---- */}
	<DiagramStep caption="Initial render. Slot 0 holds Milk plus the note you typed into it; each slot lines up with its item one-to-one.">
		<div style={stage}>
			<p style={spacerLine}>Three slots, one item each.</p>
			<div style={stackWrap}>
				<div style={slotRow}>
					<span style={idxChip}>slot 0</span>
					<span style={item.plain}>Milk</span>
					<span style={noteBadge}><span style={noteTag}>note</span>&larr; grab two</span>
				</div>
				<div style={slotRow}>
					<span style={idxChip}>slot 1</span>
					<span style={item.plain}>Eggs</span>
				</div>
				<div style={slotRow}>
					<span style={idxChip}>slot 2</span>
					<span style={item.plain}>Bread</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: reverse requested, new data matched by index ---- */}
	<DiagramStep caption="You reverse the list. The data is now Bread, Eggs, Milk — but with index keys React still matches by slot index, not by item.">
		<div style={stage}>
			<div style={dataStrip}>
				<span style={dataLabel}>new data</span>
				<span style={dataChip}>Bread</span>
				<span style={dataChip}>Eggs</span>
				<span style={dataChip}>Milk</span>
			</div>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={stackWrap}>
				<div style={slotRow}>
					<span style={idxChip}>slot 0</span>
					<span style={item.plain}>Milk</span>
					<span style={noteBadge}><span style={noteTag}>note</span>&larr; grab two</span>
				</div>
				<div style={slotRow}>
					<span style={idxChip}>slot 1</span>
					<span style={item.plain}>Eggs</span>
				</div>
				<div style={slotRow}>
					<span style={idxChip}>slot 2</span>
					<span style={item.plain}>Bread</span>
				</div>
			</div>
			<p style={byIndexNote}>Index keys say &ldquo;slot 0 is still slot 0&rdquo; &mdash; match by position.</p>
		</div>
	</DiagramStep>

	{/* ---- Step 3: position wins, the note is stranded ---- */}
	<DiagramStep caption="Position wins. Slot 0 keeps its note and merely relabels to Bread, so your note is now stranded on the wrong item.">
		<div style={stage}>
			<p style={spacerLine}>The note never moved. The labels did.</p>
			<div style={stackWrap}>
				<div style={slotRow}>
					<span style={idxChip}>slot 0</span>
					<span style={item.wrong}>Bread</span>
					<span style={noteBadge}><span style={noteTag}>note</span>&larr; grab two</span>
				</div>
				<div style={slotRow}>
					<span style={idxChip}>slot 1</span>
					<span style={item.plain}>Eggs</span>
				</div>
				<div style={slotRow}>
					<span style={idxChip}>slot 2</span>
					<span style={item.owner}>Milk</span>
					<span style={pin(BLUE_BG, BLUE_INK)}>owned the note</span>
				</div>
			</div>
			<p style={byIndexNote}>
				<span style={pin(RED_BG, RED_INK)}>stranded</span> the note stayed on slot 0; Milk left without it.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
