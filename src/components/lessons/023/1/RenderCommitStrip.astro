---
// The render → commit strip (Chapter 023 L1). A horizontal sequential phase
// strip — the html-css "timeline without parallelism" use case — that splits
// ONE re-render into its cause and its phases so two teaching points read
// straight off the picture:
//
//   1. Trigger is the CAUSE, not a phase. It sits first but is styled apart: a
//      quiet dashed/muted box with a "cause" eyebrow, so the eye reads it as
//      what *starts* the sequence rather than one of the phases. The three
//      phase boxes carry a "phase" eyebrow and a shared solid treatment.
//   2. Render + Reconcile are PURE COMPUTATION (call the function, get a tree,
//      diff it — no DOM touched); only COMMIT writes the real DOM. Commit gets
//      the one saturated fill on the strip, so "render is cheap, commit is the
//      expense" is obvious here and pays off later in the lesson.
//
// All four boxes sit on ONE horizontal row at the Figure's content width
// (~790px desktop), connected by short arrows; they wrap to a stacked column
// only on a genuinely narrow viewport. Theme-adaptive chrome (Starlight gray
// vars flip with light/dark); the single saturated accent on Commit is the one
// place colour carries meaning, so it's a fixed mid-tone (teal-600) with white
// text that reads on both backgrounds. `margin: 0` everywhere defeats
// Starlight's injected prose margins.

// The four cells, left to right. `kind` styles the cause apart from the phases;
// `dom` flags the only phase that touches the DOM.
const cells = [
	{
		kind: 'cause',
		eyebrow: 'cause',
		name: 'Trigger',
		sub: 'state, ancestor, or context changed',
		dom: false,
	},
	{
		kind: 'phase',
		eyebrow: 'phase 1',
		name: 'Render',
		sub: 'call your function, get a JSX tree',
		dom: false,
	},
	{
		kind: 'phase',
		eyebrow: 'phase 2',
		name: 'Reconcile',
		sub: 'diff against the previous tree',
		dom: false,
	},
	{
		kind: 'phase',
		eyebrow: 'phase 3',
		name: 'Commit',
		sub: 'apply changes to the DOM',
		dom: true,
	},
];
---

<div class="rcs not-content">
	{
		cells.map((cell, i) => (
			<>
				<div
					class:list={[
						'rcs-box',
						`rcs-${cell.kind}`,
						{ 'rcs-commit': cell.dom },
					]}
				>
					<span class="rcs-eyebrow">{cell.eyebrow}</span>
					<span class="rcs-name">{cell.name}</span>
					<span class="rcs-sub">{cell.sub}</span>
					<span
						class:list={['rcs-tag', { 'rcs-tag-pure': !cell.dom }]}
					>
						{cell.dom ? 'touches the DOM' : 'no DOM'}
					</span>
				</div>
				{i < cells.length - 1 && (
					<span class="rcs-arrow" aria-hidden="true">
						→
					</span>
				)}
			</>
		))
	}
</div>

<style>
	.rcs {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 10px 5px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* --- shared box chrome --- */
	.rcs-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		gap: 3px;
		flex: 0 1 8.75rem;
		min-width: 7.5rem;
		max-width: 10.5rem;
		min-height: 6.25rem;
		padding: 9px 11px;
		border-radius: 10px;
		margin: 0;
	}

	/* The cause: a quiet, dashed neutral box — clearly NOT one of the phases. */
	.rcs-cause {
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
		background: var(--sl-color-gray-6, #f1f5f9);
	}

	/* Render + Reconcile + Commit share a solid treatment as the phases; Commit
	   then overrides to the saturated fill below. */
	.rcs-phase {
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
	}

	/* Commit: the only saturated box — the one phase that writes the DOM. */
	.rcs-commit {
		border: 1px solid #0f766e; /* teal 700 */
		background: #0d9488; /* teal 600 — reads on light and dark */
		box-shadow: 0 1px 3px rgba(13, 148, 136, 0.4);
	}

	.rcs-eyebrow {
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.rcs-name {
		font-size: 0.96rem;
		font-weight: 700;
		line-height: 1.1;
		color: var(--sl-color-white, #1e293b);
		margin: 1px 0 0;
	}

	.rcs-sub {
		font-size: 0.72rem;
		line-height: 1.28;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* On the saturated Commit box, eyebrow + text must be light for contrast. */
	.rcs-commit .rcs-eyebrow {
		color: rgba(255, 255, 255, 0.85);
	}
	.rcs-commit .rcs-name,
	.rcs-commit .rcs-sub {
		color: #ffffff;
	}

	/* The per-box DOM flag, pinned to the bottom of the box. */
	.rcs-tag {
		align-self: flex-start;
		margin: auto 0 0;
		padding: 1px 7px;
		border-radius: 999px;
		font-size: 0.64rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		background: rgba(255, 255, 255, 0.22);
		color: #ffffff;
	}

	.rcs-tag-pure {
		background: var(--sl-color-gray-5, #e2e8f0);
		color: var(--sl-color-gray-2, #475569);
	}

	.rcs-arrow {
		align-self: center;
		flex: 0 0 auto;
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Narrow viewports: stack into a column, rotate the arrows to point down. */
	@media (max-width: 560px) {
		.rcs {
			flex-direction: column;
			align-items: center;
			gap: 0;
		}
		.rcs-box {
			flex: 0 0 auto;
			width: 100%;
			max-width: 18rem;
			min-height: 0;
		}
		.rcs-arrow {
			transform: rotate(90deg);
			margin: 4px 0;
		}
	}
</style>
