---
// Key-change-as-remount sequence (diagram id: key-change-remount, Chapter 023
// L5). A four-step scrubbable DiagramSequence following ONE slot — the detail
// pane that holds <UserForm> — across the selection change from Alice to Bob.
// The slot frame (the position) is the persistent thing; what changes is the
// component instance sitting in it and the local-state badge glued to that
// instance. The payoff is the Reconcile step: React compares the incoming
// element's key (bob) against the instance already in the slot (alice), finds
// no match, so it unmounts the alice instance (state discarded, struck through
// in red) and mounts a fresh bob instance (state back to its initial value,
// green). The whole point: key change = new instance = state reset.
//
//   Step 1  Render A     slot holds <UserForm key="alice"> with edited state
//   Step 2  Render B     a NEW element <UserForm key="bob"> is produced; the
//                         alice instance is still sitting in the slot — mismatch
//   Step 3  Reconcile    alice != bob -> unmount alice (state gone), mount a
//                         fresh bob (state at initial, from props)
//   Step 4  Commit        old DOM torn down, new one built; the form shows Bob's
//                         clean data with no leaked edits
//
// Style matches this chapter's PositionMatchSequence / TypeMatchTrees: fixed
// slate ink, color-scheme pinned light so the hand-picked accent tints survive
// dark mode, `margin: 0` on every inner element to defeat Starlight's injected
// prose margins. Height is capped by keeping all four steps the same shape — an
// "incoming element" line (reserved by a spacer when absent), a down-arrow, and
// one slot frame below — so the grid stack never reflows as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary chip surface
const BORDER = '#cbd5e1'; // ordinary chip edge (slate-300)
const SLOT_BG = '#f1f5f9'; // slot frame wash (slate-100)
const SLOT_BORDER = '#cbd5e1'; // slot frame edge (slate-300)
const IDX_BG = '#475569'; // slot-label chip (slate-600)

const AMBER = '#d97706'; // amber-600 — the edited-draft state badge
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const RED = '#dc2626'; // red-600 — the discarded (unmounted) instance
const RED_BG = '#fee2e2'; // red-100
const RED_INK = '#991b1b'; // red-800
const GREEN = '#16a34a'; // green-600 — the fresh (mounted) instance
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by every step: pinned light, slate ink, centered column so
// all four steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The "incoming element" strip (the JSX element React is about to reconcile),
// echoing the chapter's "new data" strip. `tint` swaps the key chip's accent.
const elementStrip = (accent: string, bg: string) =>
	`display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin: 0; padding: 8px 12px; border: 1px dashed ${accent}; border-radius: 10px; background: ${bg}; max-width: 360px;`;
const elementLabel = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;
const elementCode = (accent: string, ink: string, bg: string) =>
	`display: inline-flex; align-items: center; margin: 0; padding: 3px 9px; font-family: ${mono}; font-size: 12.5px; font-weight: 600; line-height: 1.3; color: ${ink}; background: ${bg}; border: 1px solid ${accent}; border-radius: 6px; white-space: nowrap;`;

// The vertical down-arrow joining the element strip to the slot.
const downArrow = `margin: 0; font-family: ${sans}; font-size: 18px; font-weight: 700; line-height: 1; color: ${INK_SOFT};`;

// The persistent slot frame (the position). It survives every step; the
// instance inside it is what changes.
const slotFrame = `display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 10px; border: 1px solid ${SLOT_BORDER}; border-radius: 12px; background: ${SLOT_BG}; width: 100%; max-width: 360px;`;
const slotLabel = `display: inline-flex; flex: 0 0 auto; align-self: flex-start; align-items: center; margin: 0; padding: 3px 8px; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.3; color: #ffffff; background: ${IDX_BG}; border-radius: 6px; white-space: nowrap;`;

// A component-instance box that sits in the slot. `accent`/`bg`/`ink` tint the
// edge for the discarded (red) vs fresh (green) instances; default is neutral.
const instanceBox = (accent: string, bg: string) =>
	`display: flex; flex-direction: column; gap: 7px; margin: 0; padding: 9px 11px; border: 1.5px solid ${accent}; border-radius: 9px; background: ${bg};`;
const instanceTitle = (ink: string, struck = false) =>
	`display: flex; align-items: center; gap: 8px; margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 700; line-height: 1.3; color: ${ink};${struck ? ' text-decoration: line-through;' : ''}`;

// The local-state badge glued to an instance. `flavor` picks the wash:
//   draft  — amber, the half-typed edited value
//   gone   — red + struck, discarded on unmount
//   fresh  — green, the initial value from props
const stateBadge = (accent: string, bg: string, ink: string, struck = false) =>
	`display: inline-flex; flex: 0 0 auto; align-items: center; gap: 6px; margin: 0; padding: 4px 9px; font-family: ${sans}; font-size: 12px; font-weight: 600; line-height: 1.2; color: ${ink}; background: ${bg}; border: 1px solid ${accent}; border-radius: 7px; white-space: nowrap;${struck ? ' text-decoration: line-through;' : ''}`;
const stateTag = (accent: string) =>
	`display: inline-block; margin: 0; padding: 1px 5px; font-family: ${mono}; font-size: 9px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #ffffff; background: ${accent}; border-radius: 4px;`;
const stateValue = `font-family: ${mono}; font-size: 11.5px; font-weight: 600;`;

// A small phase / status pill.
const pill = (bg: string, ink: string) =>
	`display: inline-block; flex: 0 0 auto; margin: 0; padding: 2px 8px; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.2; color: ${ink}; background: ${bg}; border-radius: 999px; white-space: nowrap;`;
const verdictLine = `margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT}; max-width: 360px; text-align: center;`;
// A spacer that reserves the element-strip + arrow footprint on steps where no
// strip is shown, so all four panels stay the same height.
const spacerLine = `margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT}; text-align: center;`;
---

<DiagramSequence>
	{/* ---- Step 1: Render A — Alice is selected, instance holds her edits ---- */}
	<DiagramStep caption="Render A — Alice is selected. The form instance in the detail slot holds her half-typed edits in local state.">
		<div style={stage}>
			<p style={spacerLine}><span style={pill(SLOT_BG, INK_SOFT)}>Render</span> the slot holds Alice's instance.</p>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={slotFrame}>
				<span style={slotLabel}>slot: detail pane</span>
				<div style={instanceBox(BORDER, SURFACE)}>
					<p style={instanceTitle(INK)}>&lt;UserForm key=&quot;alice&quot;&gt;</p>
					<span style={stateBadge(AMBER, AMBER_BG, AMBER_INK)}>
						<span style={stateTag(AMBER)}>state</span>
						<span style={stateValue}>email: &quot;a@new&hellip;&quot;</span> (edited)
					</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 2: Render B — a new element is produced, key is now "bob" ---- */}
	<DiagramStep caption='Selection changes to Bob. Render B produces a new element — same slot, but the key is now "bob". The Alice instance is still sitting in the slot from the last render.'>
		<div style={stage}>
			<div style={elementStrip(GREEN, '#ffffff')}>
				<span style={elementLabel}>new element</span>
				<span style={elementCode(GREEN, GREEN_INK, GREEN_BG)}>&lt;UserForm key=&quot;bob&quot;&gt;</span>
			</div>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={slotFrame}>
				<span style={slotLabel}>slot: detail pane</span>
				<div style={instanceBox(BORDER, SURFACE)}>
					<p style={instanceTitle(INK)}>
						&lt;UserForm key=&quot;alice&quot;&gt;
						<span style={pill(SLOT_BG, INK_SOFT)}>still mounted</span>
					</p>
					<span style={stateBadge(AMBER, AMBER_BG, AMBER_INK)}>
						<span style={stateTag(AMBER)}>state</span>
						<span style={stateValue}>email: &quot;a@new&hellip;&quot;</span> (edited)
					</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 3: Reconcile — keys mismatch, unmount alice, mount fresh bob ---- */}
	<DiagramStep caption="Reconcile — React compares keys. alice ≠ bob, so there is nothing to reuse: the Alice instance unmounts (its state is discarded) and a fresh Bob instance mounts with state at its initial value, from props.">
		<div style={stage}>
			<p style={spacerLine}><span style={pill(RED_BG, RED_INK)}>Reconcile</span> key &quot;alice&quot; &ne; &quot;bob&quot; &mdash; no match to reuse.</p>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={slotFrame}>
				<span style={slotLabel}>slot: detail pane</span>
				<div style={instanceBox(RED, RED_BG)}>
					<p style={instanceTitle(RED_INK, true)}>&lt;UserForm key=&quot;alice&quot;&gt;</p>
					<span style={stateBadge(RED, '#ffffff', RED_INK, true)}>
						<span style={stateTag(RED)}>unmount</span>
						<span style={stateValue}>email: &quot;a@new&hellip;&quot;</span> discarded
					</span>
				</div>
				<div style={instanceBox(GREEN, GREEN_BG)}>
					<p style={instanceTitle(GREEN_INK)}>&lt;UserForm key=&quot;bob&quot;&gt;</p>
					<span style={stateBadge(GREEN, '#ffffff', GREEN_INK)}>
						<span style={stateTag(GREEN)}>mount</span>
						<span style={stateValue}>email: &quot;bob@corp&hellip;&quot;</span> (initial)
					</span>
				</div>
			</div>
		</div>
	</DiagramStep>

	{/* ---- Step 4: Commit — old DOM torn down, new one built, clean form ---- */}
	<DiagramStep caption="Commit — the old DOM node is torn down and a new one built. The form now shows Bob's data with no leaked edits.">
		<div style={stage}>
			<p style={spacerLine}><span style={pill(GREEN_BG, GREEN_INK)}>Commit</span> old DOM torn down, fresh node built.</p>
			<span style={downArrow} aria-hidden="true">&darr;</span>
			<div style={slotFrame}>
				<span style={slotLabel}>slot: detail pane</span>
				<div style={instanceBox(GREEN, SURFACE)}>
					<p style={instanceTitle(GREEN_INK)}>&lt;UserForm key=&quot;bob&quot;&gt;</p>
					<span style={stateBadge(GREEN, GREEN_BG, GREEN_INK)}>
						<span style={stateTag(GREEN)}>state</span>
						<span style={stateValue}>email: &quot;bob@corp&hellip;&quot;</span> (clean)
					</span>
				</div>
			</div>
			<p style={verdictLine}>A different key meant a different instance &mdash; so the form starts fresh.</p>
		</div>
	</DiagramStep>
</DiagramSequence>
