---
// why-client-validation-three-doors (one door / one tab).
//
// Each tab of the lesson's TabbedContent renders the SAME idea — a hostile or
// off-contract payload reaching `createInvoice`, with the browser's HTML5
// constraint-validation layer absent or stale. To make the three tabs read as
// variations on one theme, every door uses this one component: a two-column
// panel, the offending REQUEST on the left and the constraint-validation
// VERDICT on the right.
//
// The left column changes shape per door (`kind`):
//   - "shell"     a terminal posting a hostile body straight to the action URL.
//   - "timeline"  two clock-stamped events: a deploy tightens the schema, then a
//                 stale tab submits the old shape.
//   - "form"      a native <form> submit with the JS bundle failing to load.
//
// The right column is always a "Constraint validation" card whose verdict line
// is struck through (it did not run / it ran against stale rules), with a short
// supporting note underneath.
//
// Pure HTML + CSS, no interactivity. Starlight theme variables keep it native in
// light and dark; `margin: 0` on inner elements defeats Starlight's prose-margin
// selector. Goes INSIDE a TabbedItem — never wrapped in <Figure> (the tab strip
// already provides the outer card).

interface RequestLine {
  // A single line of the left-hand request artifact. `tone` tints the text:
  //   prompt   – a shell prompt / muted scaffolding
  //   command  – the literal command or payload (foreground mono)
  //   danger   – the hostile values worth calling out (red)
  //   time     – a clock stamp on a timeline row
  //   event    – the prose of a timeline event
  //   note     – a faint annotation
  text: string;
  tone?: 'prompt' | 'command' | 'danger' | 'time' | 'event' | 'note';
}

interface Props {
  kind: 'shell' | 'timeline' | 'form';
  // Left-panel heading, e.g. "Terminal", "Deploy timeline", "Native submit".
  requestHeading: string;
  // The artifact lines. For "shell"/"form" these stack as code-ish rows; for
  // "timeline" they're grouped two-per-event (a time row then an event row).
  lines: RequestLine[];
  // The struck-through verdict, e.g. "did not run".
  verdict: string;
  // A short label above the verdict, defaults to the layer's name.
  verdictLabel?: string;
  // Supporting sentence(s) under the verdict.
  note: string;
}

const {
  kind,
  requestHeading,
  lines,
  verdict,
  verdictLabel = 'HTML5 constraint validation',
  note,
} = Astro.props;
---

<div class="cvd not-content">
  {/* LEFT — the offending request */}
  <section class={`cvd-panel cvd-request cvd-request--${kind}`}>
    <h4 class="cvd-heading">{requestHeading}</h4>
    <div class="cvd-artifact">
      {
        kind === 'timeline' ? (
          <ol class="cvd-timeline">
            {lines.map((line) => (
              <li class={`cvd-tl-row cvd-tl-row--${line.tone ?? 'event'}`}>
                <span class="cvd-dot" aria-hidden="true" />
                <span class="cvd-tl-text">{line.text}</span>
              </li>
            ))}
          </ol>
        ) : (
          <pre class="cvd-code"><code>{lines.map((line) => (
            <span class={`cvd-line cvd-line--${line.tone ?? 'command'}`}>{line.text}</span>
          ))}</code></pre>
        )
      }
    </div>
  </section>

  {/* CENTER — the seam the request crosses */}
  <div class="cvd-gap" aria-hidden="true">
    <span class="cvd-arrow">&rarr;</span>
  </div>

  {/* RIGHT — the constraint-validation verdict */}
  <section class="cvd-panel cvd-verdict">
    <h4 class="cvd-heading">{verdictLabel}</h4>
    <p class="cvd-verdict-line">
      <span class="cvd-strike">{verdict}</span>
    </p>
    <p class="cvd-note">{note}</p>
  </section>
</div>

<style>
  .cvd {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) auto minmax(0, 1fr);
    align-items: stretch;
    gap: 0;
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- shared panel chrome --------------------------------------------- */

  .cvd-panel {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px 14px 16px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    background: var(--sl-color-bg);
    box-sizing: border-box;
    margin: 0;
  }

  .cvd-heading {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
  }

  /* ---- LEFT: the request artifact -------------------------------------- */

  .cvd-artifact {
    margin: 0;
    flex: 1;
    display: flex;
  }

  .cvd-code {
    margin: 0;
    width: 100%;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 80%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-6, var(--sl-color-gray-5)) 55%, transparent);
    overflow-x: auto;
  }

  .cvd-code code {
    display: flex;
    flex-direction: column;
    gap: 3px;
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 12.5px;
    line-height: 1.5;
    background: none;
    padding: 0;
    border: 0;
  }

  .cvd-line {
    margin: 0;
    white-space: pre;
  }

  .cvd-line--prompt {
    color: var(--sl-color-gray-3);
  }

  .cvd-line--command {
    color: var(--sl-color-text);
  }

  .cvd-line--danger {
    color: #dc2626;
    font-weight: 600;
  }

  .cvd-line--note {
    color: var(--sl-color-gray-3);
    font-style: italic;
    white-space: pre-wrap;
  }

  /* ---- LEFT (timeline variant) ----------------------------------------- */

  .cvd-timeline {
    list-style: none;
    margin: 0;
    padding: 0 0 0 4px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
  }

  .cvd-tl-row {
    margin: 0;
    padding: 0 0 0 18px;
    position: relative;
    line-height: 1.45;
  }

  .cvd-dot {
    display: none;
  }

  .cvd-tl-row--time {
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--sl-color-text-accent);
    margin-top: 6px;
  }

  .cvd-tl-row--time:first-child {
    margin-top: 0;
  }

  /* the bullet marker only on the time rows */
  .cvd-tl-row--time .cvd-dot {
    display: block;
    position: absolute;
    left: 0;
    top: 4px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--sl-color-text-accent);
  }

  /* connecting spine between the two time dots */
  .cvd-tl-row--time:first-child .cvd-dot::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 9px;
    width: 1.5px;
    height: 46px;
    background: color-mix(in srgb, var(--sl-color-text-accent) 40%, transparent);
  }

  .cvd-tl-row--event {
    font-size: 12.5px;
    color: var(--sl-color-text);
  }

  .cvd-tl-text {
    margin: 0;
  }

  /* ---- CENTER: the seam ------------------------------------------------ */

  .cvd-gap {
    width: 46px;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
  }

  .cvd-arrow {
    margin: 0;
    font-size: 22px;
    line-height: 1;
    font-weight: 700;
    color: var(--sl-color-gray-3);
  }

  /* ---- RIGHT: the verdict ---------------------------------------------- */

  .cvd-verdict {
    background: color-mix(in srgb, #dc2626 7%, var(--sl-color-bg));
    border-color: color-mix(in srgb, #dc2626 35%, var(--sl-color-hairline, var(--sl-color-gray-5)));
  }

  .cvd-verdict-line {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .cvd-strike {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: #dc2626;
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    text-decoration-color: color-mix(in srgb, #dc2626 75%, transparent);
  }

  .cvd-note {
    margin: 0;
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
  }

  /* ---- narrow viewports: stack, rotate the arrow ----------------------- */

  @media (max-width: 640px) {
    .cvd {
      grid-template-columns: minmax(0, 1fr);
    }

    .cvd-gap {
      width: auto;
      height: 40px;
    }

    .cvd-arrow {
      transform: rotate(90deg);
    }
  }
</style>
