---
// commit-vs-rollback (diagram id: commit-vs-rollback, Ch 043 L5).
//
// Makes "all-or-nothing" visual for a two-insert transaction. A 2-step
// DiagramSequence (self-carding — NOT wrapped in <Figure>) the reader scrubs:
//
//   STEP 1 (commit):   [insert header ✓] [insert lines ✓]  ->  COMMIT, both saved
//   STEP 2 (rollback): [insert header ✗] [insert lines ✗]  ->  ROLLBACK, nothing saved
//
// The load-bearing teaching point lives in step 2: the header insert *ran and
// succeeded on its own*, yet the rollback reaches BACK and undoes it too. So the
// header box is drawn as written-then-struck — a green "wrote" state crossed out
// in red with an "undone by rollback" label and a back-pointing motion cue — not
// as a box that simply failed. The lines box is the genuine failure (red, throws).
//
// Both rows live inside a dashed "db.transaction" frame so the eye reads them as
// one atomic unit, and the outcome box is the unit's single verdict.
//
// Colour language is the course standard: GREEN = the write that committed,
// RED = the throw + the rollback (the failure channel). Neutral slate for chrome.
//
// House style (cf. 032/6 StaleAfterWriteTimeline): pinned `color-scheme: light`
// so the hand-picked tints survive dark mode; inline style strings (no <style>
// block); `box-sizing: border-box`; `margin: 0` on every inner node to defeat
// Starlight's injected prose margins. Both steps reserve the same heights (frame
// rows + outcome) so the grid-stacked panels never jump as the reader scrubs.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ------------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const SURFACE = '#ffffff';

const GREEN = '#16a34a'; // green-600 — the write that commits
const GREEN_BG = '#f0fdf4'; // green-50
const GREEN_INK = '#15803d'; // green-700

const RED = '#dc2626'; // red-600 — the throw + the rollback
const RED_BG = '#fef2f2'; // red-50
const RED_INK = '#b91c1c'; // red-700

// ---- shared atoms ----------------------------------------------------------
// Stage: the transaction frame, then the arrow + outcome, then a fixed-height
// note row reserved on every step so panels stack without height jumps.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 0; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The whole horizontal machine: [transaction frame] -> [outcome].
const machine = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 10px; margin: 0;`;

// The dashed "db.transaction" frame that wraps the two insert boxes, tinted by
// the step's verdict so the unit itself reads green (commit) or red (rollback).
// The wash is a very light tint over white so the inner boxes still pop.
const txFrame = (tone: 'green' | 'red') => {
	const edge = tone === 'green' ? GREEN : RED;
	const bg = tone === 'green' ? GREEN_BG : RED_BG;
	return `box-sizing: border-box; position: relative; display: flex; align-items: stretch; gap: 8px; margin: 0; padding: 18px 12px 12px; border: 1.5px dashed ${edge}; border-radius: 13px; background: color-mix(in srgb, ${bg} 45%, ${SURFACE});`;
};

// The little "db.transaction" tab sitting on the frame's top edge.
const txTab = (tone: 'green' | 'red') => {
	const edge = tone === 'green' ? GREEN : RED;
	const fg = tone === 'green' ? GREEN_INK : RED_INK;
	const bg = tone === 'green' ? GREEN_BG : RED_BG;
	return `box-sizing: border-box; position: absolute; top: -10px; left: 14px; margin: 0; padding: 1px 9px; border: 1.5px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${fg}; font-family: ${mono}; font-size: 10px; font-weight: 800; line-height: 1.5; white-space: nowrap;`;
};

// An insert box. `state` drives the whole look:
//   'wrote'  green, checked — the insert succeeded
//   'undone' green-then-struck — it succeeded but the rollback undid it
//   'failed' red, crossed — the insert threw
type Ins = 'wrote' | 'undone' | 'failed';
const insBox = (state: Ins) => {
	const edge = state === 'failed' ? RED : GREEN;
	const bg = state === 'failed' ? RED_BG : GREEN_BG;
	const op = state === 'undone' ? '0.6' : '1';
	return `box-sizing: border-box; position: relative; display: flex; flex-direction: column; justify-content: center; gap: 5px; width: 132px; min-height: 78px; margin: 0; padding: 10px 11px; border: 1.5px solid ${edge}; border-radius: 11px; background: ${bg}; opacity: ${op}; transition: none;`;
};
const insEyebrow = (state: Ins) => {
	const c = state === 'failed' ? RED_INK : GREEN_INK;
	return `margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; line-height: 1.2; color: ${c};`;
};
const insTitle = (state: Ins) => {
	const c = state === 'failed' ? RED_INK : GREEN_INK;
	const struck = state === 'undone';
	return `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 800; line-height: 1.25; color: ${c};${
		struck ? ` text-decoration: line-through; text-decoration-color: ${RED}; text-decoration-thickness: 2px;` : ''
	}`;
};
const insRow = (state: Ins) => {
	const c = state === 'failed' ? RED_INK : GREEN_INK;
	const struck = state === 'undone';
	return `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.25; color: ${c};${
		struck ? ' opacity: 0.85;' : ''
	}`;
};

// The status glyph pinned to an insert box's top-right corner:
//   wrote  -> green check, failed -> red cross, undone -> red "undo" arrow.
const insGlyph = (state: Ins) => {
	const c = state === 'failed' ? RED : state === 'undone' ? RED : GREEN;
	const bg = state === 'failed' ? RED_BG : state === 'undone' ? RED_BG : GREEN_BG;
	return `box-sizing: border-box; position: absolute; top: -9px; right: -9px; display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; margin: 0; border: 1.5px solid ${c}; border-radius: 50%; background: ${bg}; color: ${c}; font-family: ${sans}; font-size: 12px; font-weight: 900; line-height: 1;`;
};
const glyphChar = (state: Ins) => (state === 'failed' ? '✗' : state === 'undone' ? '↶' : '✓');

// The connector between the two insert boxes inside the frame.
const innerConn = `display: flex; align-items: center; justify-content: center; align-self: center; margin: 0; min-width: 16px;`;
const innerArrow = (c: string) =>
	`margin: 0; font-size: 17px; font-weight: 900; line-height: 0.7; color: ${c};`;

// The arrow from the transaction frame to the outcome verdict.
const outConn = `display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; align-self: center; margin: 0; min-width: 30px;`;
const outArrow = (c: string) =>
	`margin: 0; font-size: 22px; font-weight: 900; line-height: 0.7; color: ${c};`;
const outConnLabel = (c: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.2; text-align: center; color: ${c};`;

// The outcome verdict box — the transaction's single all-or-nothing result.
const outcomeBox = (tone: 'green' | 'red') => {
	const edge = tone === 'green' ? GREEN : RED;
	const bg = tone === 'green' ? GREEN_BG : RED_BG;
	return `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 4px; width: 150px; min-height: 78px; margin: 0; padding: 10px 12px; border: 2px solid ${edge}; border-radius: 11px; background: ${bg}; text-align: center;`;
};
const outcomeWord = (tone: 'green' | 'red') => {
	const c = tone === 'green' ? GREEN_INK : RED_INK;
	return `margin: 0; font-family: ${mono}; font-size: 15px; font-weight: 900; letter-spacing: 0.04em; line-height: 1.1; color: ${c};`;
};
const outcomeSub = (tone: 'green' | 'red') => {
	const c = tone === 'green' ? GREEN_INK : RED_INK;
	return `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${c};`;
};

// The note row beneath the machine — reserved at a fixed height on both steps so
// the grid-stacked panels never change height as the reader scrubs.
const noteRow = `display: flex; align-items: center; justify-content: center; min-height: 38px; margin: 13px 0 0;`;
const note = (tone: 'green' | 'red') => {
	const edge = tone === 'green' ? GREEN : RED;
	const bg = tone === 'green' ? GREEN_BG : RED_BG;
	const fg = tone === 'green' ? GREEN_INK : RED_INK;
	return `box-sizing: border-box; display: inline-flex; align-items: center; gap: 8px; max-width: 100%; margin: 0; padding: 7px 14px; border: 1.5px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${fg}; font-family: ${sans}; font-size: 12px; font-weight: 700; line-height: 1.35;`;
};
const noteDot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 8px; height: 8px; margin: 0; border-radius: 50%; background: ${c};`;
---

<DiagramSequence>
	{/* ============ STEP 1 — both inserts succeed -> COMMIT ============ */}
	<DiagramStep caption="Both inserts succeed — the transaction commits, and both rows are persisted together.">
		<div style={stage}>
			<div style={machine}>
				{/* The transaction unit: both writes land */}
				<div style={txFrame('green')}>
					<span style={txTab('green')}>db.transaction</span>
					<div style={insBox('wrote')}>
						<span style={insGlyph('wrote')} aria-hidden="true">{glyphChar('wrote')}</span>
						<p style={insEyebrow('wrote')}>step 1</p>
						<p style={insTitle('wrote')}>insert header</p>
						<p style={insRow('wrote')}>wrote &mdash; ok</p>
					</div>
					<div style={innerConn}>
						<span style={innerArrow(GREEN)} aria-hidden="true">&rarr;</span>
					</div>
					<div style={insBox('wrote')}>
						<span style={insGlyph('wrote')} aria-hidden="true">{glyphChar('wrote')}</span>
						<p style={insEyebrow('wrote')}>step 2</p>
						<p style={insTitle('wrote')}>insert lines</p>
						<p style={insRow('wrote')}>wrote &mdash; ok</p>
					</div>
				</div>
				{/* -> verdict */}
				<div style={outConn}>
					<span style={outArrow(GREEN)} aria-hidden="true">&rarr;</span>
					<span style={outConnLabel(GREEN_INK)}>returns</span>
				</div>
				<div style={outcomeBox('green')}>
					<p style={outcomeWord('green')}>COMMIT</p>
					<p style={outcomeSub('green')}>both rows saved</p>
				</div>
			</div>
			<div style={noteRow}>
				<span style={note('green')}>
					<span style={noteDot(GREEN)} aria-hidden="true"></span>
					Either both rows exist&hellip;
				</span>
			</div>
		</div>
	</DiagramStep>

	{/* ============ STEP 2 — second insert throws -> ROLLBACK ============ */}
	<DiagramStep caption="The second insert throws — the transaction rolls back, and neither row persists. The header insert ran first, but the rollback reaches back and undoes it too.">
		<div style={stage}>
			<div style={machine}>
				{/* The transaction unit: the throw rolls the whole thing back */}
				<div style={txFrame('red')}>
					<span style={txTab('red')}>db.transaction</span>
					{/* header: it WROTE, then the rollback undid it (the teaching point) */}
					<div style={insBox('undone')}>
						<span style={insGlyph('undone')} aria-hidden="true">{glyphChar('undone')}</span>
						<p style={insEyebrow('undone')}>step 1</p>
						<p style={insTitle('undone')}>insert header</p>
						<p style={insRow('undone')}>wrote &rarr; undone</p>
					</div>
					<div style={innerConn}>
						<span style={innerArrow(RED)} aria-hidden="true">&rarr;</span>
					</div>
					{/* lines: the genuine failure */}
					<div style={insBox('failed')}>
						<span style={insGlyph('failed')} aria-hidden="true">{glyphChar('failed')}</span>
						<p style={insEyebrow('failed')}>step 2</p>
						<p style={insTitle('failed')}>insert lines</p>
						<p style={insRow('failed')}>throws</p>
					</div>
				</div>
				{/* -> verdict */}
				<div style={outConn}>
					<span style={outArrow(RED)} aria-hidden="true">&rarr;</span>
					<span style={outConnLabel(RED_INK)}>throws</span>
				</div>
				<div style={outcomeBox('red')}>
					<p style={outcomeWord('red')}>ROLLBACK</p>
					<p style={outcomeSub('red')}>nothing saved</p>
				</div>
			</div>
			<div style={noteRow}>
				<span style={note('red')}>
					<span style={noteDot(RED)} aria-hidden="true"></span>
					&hellip;or neither does. No in-between.
				</span>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
