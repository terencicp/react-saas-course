---
// double-submit-race (diagram id: double-submit-race, Ch 043 L5).
//
// The closing visual for the idempotency beat. The point is NOT that the key
// blocks the second submit — it's that the key COLLAPSES the duplicate: the
// second submit, carrying the same key, returns the FIRST result instead of
// writing a new row. Two panels, stacked, read top-to-bottom as a contrast:
//
//   WITHOUT A KEY:  [click] [retry click]  ->  action  ->  Invoice #1 / Invoice #2
//                   two clicks, two writes, TWO rows  (the bug)
//
//   WITH A KEY:     [click key:a1f3…] [retry key:a1f3…]  ->  action  ->  Invoice #1
//                   two clicks, same key — first writes, second is matched against
//                   the ledger and RETURNS the existing row  (the fix)
//
// The load-bearing teaching point lives in the second panel: both arrows still
// fire (the second click is NOT blocked), but they CONVERGE on one row, and the
// second arrow is labelled "returns existing" so the eye reads "matched, not
// written again". The single row carries its key stub so the match is legible.
//
// Built as a hand-laid HTML/CSS strip wrapped in <Figure> (NOT a DiagramSequence
// — this is a side-by-side contrast, not a temporal scrub; both states want to
// be visible at once). One-line Figure caption states the thesis.
//
// Colour language is the course standard (cf. CommitVsRollback in this lesson):
// RED = the duplicate / the bug channel, GREEN = the key / the collapse / the fix.
// Neutral slate for the click events and inert chrome.
//
// House style (cf. CommitVsRollback, StaleAfterWriteTimeline): pinned
// `color-scheme: light` so the hand-picked tints survive dark mode; inline style
// strings (no <style> block); `box-sizing: border-box`; `margin: 0` on every
// inner node to defeat Starlight's injected prose margins; `flex-wrap` so the
// strip never scrolls off the card on a narrow viewport.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ------------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';
const BORDER = '#cbd5e1'; // slate-300 — inert edge
const SLATE_BG = '#f8fafc'; // slate-50 — inert wash

const GREEN = '#16a34a'; // green-600 — the key / the collapse / the fix
const GREEN_BG = '#f0fdf4'; // green-50
const GREEN_INK = '#15803d'; // green-700

const RED = '#dc2626'; // red-600 — the duplicate / the bug
const RED_BG = '#fef2f2'; // red-50
const RED_INK = '#b91c1c'; // red-700

const KEY = 'a1f3…'; // the shared idempotency-key stub

// ---- shared atoms ----------------------------------------------------------
const wrap = `display: flex; flex-direction: column; gap: 14px; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A panel: a labelled card holding one horizontal machine.
const panel = (tone: 'red' | 'green') => {
	const edge = tone === 'green' ? GREEN : RED;
	const bg = tone === 'green' ? GREEN_BG : RED_BG;
	return `box-sizing: border-box; position: relative; margin: 0; padding: 22px 14px 14px; border: 1.5px solid ${edge}; border-radius: 13px; background: color-mix(in srgb, ${bg} 40%, ${SURFACE});`;
};
const panelTab = (tone: 'red' | 'green') => {
	const edge = tone === 'green' ? GREEN : RED;
	const fg = tone === 'green' ? GREEN_INK : RED_INK;
	const bg = tone === 'green' ? GREEN_BG : RED_BG;
	return `box-sizing: border-box; position: absolute; top: -11px; left: 14px; margin: 0; padding: 2px 11px; border: 1.5px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${fg}; font-family: ${sans}; font-size: 11px; font-weight: 800; line-height: 1.5; white-space: nowrap;`;
};

// The horizontal machine: [clicks column] -> [action] -> [rows column].
const machine = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 8px; margin: 0;`;

// The stacked pair of click events on the left.
const clicksCol = `display: flex; flex-direction: column; gap: 9px; margin: 0;`;
const clickBox = `box-sizing: border-box; display: flex; flex-direction: column; gap: 2px; width: 116px; margin: 0; padding: 7px 10px; border: 1.5px solid ${BORDER}; border-radius: 10px; background: ${SLATE_BG};`;
const clickTitle = `display: flex; align-items: center; gap: 5px; margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 800; line-height: 1.2; color: ${INK};`;
const clickKey = (tone: 'none' | 'green') => {
	const c = tone === 'green' ? GREEN_INK : INK_SOFT;
	return `margin: 0; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.2; color: ${c};`;
};
const cursorGlyph = `font-size: 12px; line-height: 1;`;

// An arrow connector. Two stacked arrows fan from the clicks into the action;
// the column reserves a fixed width so both panels align.
const arrowsCol = `display: flex; flex-direction: column; justify-content: center; gap: 26px; margin: 0; min-width: 34px;`;
const arrow = (tone: 'red' | 'green', label?: string) => {
	const c = tone === 'green' ? GREEN : RED;
	const fg = tone === 'green' ? GREEN_INK : RED_INK;
	return { line: `margin: 0; font-size: 20px; font-weight: 900; line-height: 0.7; text-align: center; color: ${c};`, lbl: `margin: 1px 0 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.1; text-align: center; color: ${fg};` };
};

// The action box in the middle — the same createInvoice action both times.
const actionBox = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; width: 124px; min-height: 70px; margin: 0; padding: 10px; border: 1.5px solid ${BORDER}; border-radius: 11px; background: ${SURFACE};`;
const actionEyebrow = `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; line-height: 1.2; color: ${INK_SOFT};`;
const actionName = `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 800; line-height: 1.2; color: ${INK};`;
const actionSub = (tone: 'red' | 'green') => {
	const c = tone === 'green' ? GREEN_INK : RED_INK;
	return `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; line-height: 1.2; text-align: center; color: ${c};`;
};

// The middle connector from action -> rows.
const midConn = (tone: 'red' | 'green') => {
	const c = tone === 'green' ? GREEN : RED;
	return `margin: 0; min-width: 22px; font-size: 22px; font-weight: 900; line-height: 0.7; text-align: center; color: ${c};`;
};

// The result column on the right — invoice rows the action produced.
const rowsCol = `display: flex; flex-direction: column; gap: 8px; margin: 0;`;
const rowBox = (tone: 'red' | 'green', emphasis = false) => {
	const edge = tone === 'green' ? GREEN : RED;
	const bg = tone === 'green' ? GREEN_BG : RED_BG;
	const c = tone === 'green' ? GREEN_INK : RED_INK;
	return `box-sizing: border-box; display: flex; flex-direction: column; gap: 1px; width: 120px; margin: 0; padding: 7px 10px; border: ${emphasis ? 2 : 1.5}px solid ${edge}; border-radius: 10px; background: ${bg}; color: ${c};`;
};
const rowTitle = (tone: 'red' | 'green') => {
	const c = tone === 'green' ? GREEN_INK : RED_INK;
	return `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 800; line-height: 1.2; color: ${c};`;
};
const rowKey = (tone: 'red' | 'green') => {
	const c = tone === 'green' ? GREEN_INK : RED_INK;
	return `margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 700; line-height: 1.2; color: ${c};`;
};

const aR = arrow('red');
const aG1 = arrow('green');
const aG2 = arrow('green');
---

<Figure caption="The key doesn't block the second submit — it makes the second submit return the first result.">
	<div style={wrap}>
		{/* ============ WITHOUT A KEY — two clicks, two rows (the bug) ============ */}
		<div style={panel('red')}>
			<span style={panelTab('red')}>Without a key</span>
			<div style={machine}>
				<div style={clicksCol}>
					<div style={clickBox}>
						<p style={clickTitle}><span style={cursorGlyph} aria-hidden="true">🖱</span>click</p>
						<p style={clickKey('none')}>no key</p>
					</div>
					<div style={clickBox}>
						<p style={clickTitle}><span style={cursorGlyph} aria-hidden="true">🖱</span>retry click</p>
						<p style={clickKey('none')}>no key</p>
					</div>
				</div>
				<div style={arrowsCol}>
					<span style={aR.line} aria-hidden="true">&rarr;</span>
					<span style={aR.line} aria-hidden="true">&rarr;</span>
				</div>
				<div style={actionBox}>
					<p style={actionEyebrow}>runs twice</p>
					<p style={actionName}>createInvoice</p>
					<p style={actionSub('red')}>writes each time</p>
				</div>
				<span style={midConn('red')} aria-hidden="true">&rArr;</span>
				<div style={rowsCol}>
					<div style={rowBox('red')}>
						<p style={rowTitle('red')}>Invoice #1</p>
						<p style={rowKey('red')}>written</p>
					</div>
					<div style={rowBox('red')}>
						<p style={rowTitle('red')}>Invoice #2</p>
						<p style={rowKey('red')}>duplicate</p>
					</div>
				</div>
			</div>
		</div>

		{/* ============ WITH A KEY — same two clicks, ONE row (the fix) ============ */}
		<div style={panel('green')}>
			<span style={panelTab('green')}>With a key</span>
			<div style={machine}>
				<div style={clicksCol}>
					<div style={clickBox}>
						<p style={clickTitle}><span style={cursorGlyph} aria-hidden="true">🖱</span>click</p>
						<p style={clickKey('green')}>key: {KEY}</p>
					</div>
					<div style={clickBox}>
						<p style={clickTitle}><span style={cursorGlyph} aria-hidden="true">🖱</span>retry click</p>
						<p style={clickKey('green')}>key: {KEY}</p>
					</div>
				</div>
				<div style={arrowsCol}>
					<div>
						<p style={aG1.line} aria-hidden="true">&rarr;</p>
						<p style={aG1.lbl}>writes</p>
					</div>
					<div>
						<p style={aG2.line} aria-hidden="true">&rarr;</p>
						<p style={aG2.lbl}>returns existing</p>
					</div>
				</div>
				<div style={actionBox}>
					<p style={actionEyebrow}>checks the key</p>
					<p style={actionName}>createInvoice</p>
					<p style={actionSub('green')}>matches the ledger</p>
				</div>
				<span style={midConn('green')} aria-hidden="true">&rArr;</span>
				<div style={rowsCol}>
					<div style={rowBox('green', true)}>
						<p style={rowTitle('green')}>Invoice #1</p>
						<p style={rowKey('green')}>key: {KEY}</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</Figure>
