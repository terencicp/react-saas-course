---
// two-channels-figure — the spine image of Lesson 043.3.
//
// The whole lesson hangs off one sentence: "return the expected, throw the
// unexpected." This figure makes that literal — the action body is one box with
// two exits, and the exit you pick is what decides where the user lands.
//
// Layout (horizontal, capped height):
//   LEFT   a single neutral "Action body" box (chrome only — this is the place
//          the failure happens, not a colored signal).
//   RIGHT  three labeled arrows leaving it, stacked vertically:
//            GREEN  `return Result` → "Form renders the failure inline · the
//                   user stays on the page".
//            RED    `throw`         → "error.tsx · global error page".
//            BLUE   `redirect()` / `notFound()` → "Framework convention →
//                   303 / 404 · not an error".
//
//   The blue row is visually tucked just beneath the red one and tied to it by a
//   short bracket, so the student reads it as "rides the throw mechanism, but a
//   different meaning" — exactly the distinction the prose draws. Green sits on
//   its own as the genuinely separate channel.
//
// Color language is the course standard: green = the returned-value channel,
// red = the genuine-error throw channel, blue = the framework-convention raise.
// Saturated mid-tones with white text on the arrow heads keep the *color* the
// signal in both light and dark; Starlight gray variables carry the chrome.
//
// Pure HTML + CSS. The `not-content` wrapper + a `margin: 0` reset on every
// inner element defeat Starlight's prose-margin selector (which reaches into
// flex/grid children). The <style> block carries the arrow shafts/heads, the
// throw-vs-convention bracket, and the responsive stack for narrow viewports.

import Figure from "../../../figures/Figure.astro";

const GREEN = "#16a34a"; // the returned-value channel
const RED = "#dc2626"; // the genuine-error throw channel
const BLUE = "#2563eb"; // the framework-convention raise (rides throw)
---

<Figure>
  <div class="tc not-content">
    {/* LEFT — where the failure happens */}
    <div class="tc-source">
      <span class="tc-source-name">Action body</span>
      <span class="tc-source-sub">a failure just happened</span>
    </div>

    {/* RIGHT — the two channels (throw's two sub-cases grouped) */}
    <div class="tc-exits">
      {/* Channel one — return */}
      <div class="tc-row">
        <div class="tc-arrow" style={`--c: ${GREEN}`}>
          <span class="tc-label">return Result</span>
        </div>
        <div class="tc-dest" style={`--c: ${GREEN}`}>
          <span class="tc-dest-title">Form renders the failure inline</span>
          <span class="tc-dest-sub">the user stays on the page</span>
        </div>
      </div>

      {/* Channel two — throw, with its two sub-cases bracketed together */}
      <div class="tc-throw">
        <span class="tc-throw-tag">throw channel</span>

        <div class="tc-row">
          <div class="tc-arrow" style={`--c: ${RED}`}>
            <span class="tc-label">throw</span>
          </div>
          <div class="tc-dest" style={`--c: ${RED}`}>
            <span class="tc-dest-title"><code>error.tsx</code></span>
            <span class="tc-dest-sub">global error page</span>
          </div>
        </div>

        <div class="tc-row tc-row--sub">
          <div class="tc-arrow tc-arrow--dashed" style={`--c: ${BLUE}`}>
            <span class="tc-label">redirect() / notFound()</span>
          </div>
          <div class="tc-dest" style={`--c: ${BLUE}`}>
            <span class="tc-dest-title">Framework convention → 303 / 404</span>
            <span class="tc-dest-sub">not an error</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="caption">
    Two exits from an action body — the destination drives the choice. <code>return</code> hands a
    value back to the form; <code>throw</code> heads to <code>error.tsx</code>; <code>redirect()</code>{" "}
    / <code>notFound()</code> ride the throw mechanism but aren&rsquo;t errors at all.
  </Fragment>
</Figure>

<style>
  .tc {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- Left: the action body ------------------------------------------- */

  .tc-source {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    width: 132px;
    padding: 18px 14px;
    border-radius: 11px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-sidebar);
    box-shadow: 0 1px 2px color-mix(in srgb, currentColor 8%, transparent);
    box-sizing: border-box;
    margin: 0;
  }

  .tc-source-name {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .tc-source-sub {
    margin: 0;
    font-size: 10.5px;
    font-style: italic;
    text-align: center;
    line-height: 1.25;
    color: var(--sl-color-gray-3);
  }

  /* ---- Right: the stacked exits --------------------------------------- */

  .tc-exits {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
    margin: 0;
  }

  /* The two throw sub-cases share one tinted lane + a left rail, so they read
     as one mechanism with two meanings. */
  .tc-throw {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding: 10px 0 10px 12px;
    border-left: 3px solid color-mix(in srgb, var(--sl-color-gray-3) 60%, transparent);
    border-radius: 3px;
    margin: 0;
  }

  .tc-throw-tag {
    position: absolute;
    top: -8px;
    left: 12px;
    padding: 1px 7px;
    border-radius: 999px;
    background: var(--sl-color-bg-sidebar);
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  .tc-row {
    display: flex;
    align-items: stretch;
    gap: 0;
    min-width: 0;
    margin: 0;
  }

  /* The arrow: a colored shaft (its label sits on it) ending in a chevron. */
  .tc-arrow {
    position: relative;
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    min-height: 38px;
    padding: 0 26px 0 14px;
    border-radius: 7px 0 0 7px;
    background: color-mix(in srgb, var(--c) 14%, transparent);
    border: 1.5px solid color-mix(in srgb, var(--c) 55%, transparent);
    border-right: none;
    margin: 0;
  }

  .tc-arrow--dashed {
    border-style: dashed;
  }

  /* Chevron head, drawn from the arrow's right edge. */
  .tc-arrow::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -11px;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    border-left: 12px solid var(--c);
    z-index: 1;
  }

  .tc-label {
    margin: 0;
    font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 12px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--c);
    white-space: nowrap;
  }

  /* The destination box the arrow points into. */
  .tc-dest {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1px;
    min-width: 0;
    padding: 7px 12px 7px 18px;
    border-radius: 0 9px 9px 0;
    border: 1.5px solid color-mix(in srgb, var(--c) 45%, var(--sl-color-hairline));
    border-left: none;
    background: var(--sl-color-bg);
    margin: 0;
  }

  .tc-dest-title {
    margin: 0;
    font-size: 12.5px;
    font-weight: 650;
    line-height: 1.3;
    color: var(--sl-color-text);
  }

  /* Inline code inside a destination title: strip the prose pill, keep mono. */
  .tc-dest-title code {
    background: transparent;
    padding: 0;
    border: none;
    font-size: 12.5px;
    color: var(--c);
  }

  .tc-dest-sub {
    margin: 0;
    font-size: 11px;
    line-height: 1.3;
    color: var(--sl-color-gray-2);
  }

  /* Narrow viewports: drop the side-by-side source/exits into a stack, and let
     each row keep its arrow→destination read. */
  @media (max-width: 640px) {
    .tc {
      flex-direction: column;
      align-items: stretch;
      gap: 16px;
    }
    .tc-source {
      width: 100%;
      flex-direction: row;
      justify-content: center;
      gap: 8px;
      padding: 12px 14px;
    }
    .tc-source-sub {
      text-align: left;
    }
  }
</style>
