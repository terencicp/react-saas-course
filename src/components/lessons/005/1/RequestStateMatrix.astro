---
// Diagram: 4x4 matrix of every combination the flag-set RequestState type admits.
//
// Rows encode the four (isLoading, error) combinations; columns encode data
// presence (the first column is `data: undefined`, the other three are concrete
// User values, illustrating that "data present" is one boolean but admits many
// distinct values). 16 cells total — the type signs off on all of them. Only
// four cells correspond to states the runtime ever produces (idle, loading,
// success, error); the rest are impossible-by-construction.
//
// Style mirrors UnionIntersectionVenn (chapter 4 lesson 5): sl-color tokens
// for chrome, saturated mid-tones for accent fills that read against both
// light and dark backgrounds.

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones — readable against both light and dark backgrounds.
const LEGAL_FILL = '#10b981'; // emerald-500 — runtime-legal cells
const IMPOSSIBLE_FILL = '#ef4444'; // red-500 — impossible cells

// Row keys, top to bottom. `il` = isLoading, `e` = error presence.
type Row = {
	id: string;
	il: boolean;
	e: boolean;
};

const rows: Row[] = [
	{ id: 'r1', il: true, e: false },
	{ id: 'r2', il: true, e: true },
	{ id: 'r3', il: false, e: false },
	{ id: 'r4', il: false, e: true },
];

// Column keys, left to right. The first column is `data: undefined`; the
// remaining three are distinct User values to make the "data present is one
// boolean but admits many concrete values" point visible.
type Col = {
	id: string;
	dataLabel: string;
	dataPresent: boolean;
};

const cols: Col[] = [
	{ id: 'c1', dataLabel: 'data: undef', dataPresent: false },
	{ id: 'c2', dataLabel: 'data: User A', dataPresent: true },
	{ id: 'c3', dataLabel: 'data: User B', dataPresent: true },
	{ id: 'c4', dataLabel: 'data: User C', dataPresent: true },
];

// The four runtime-legal cells, keyed by `${rowId}-${colId}`. Each carries the
// canonical state name the runtime would produce.
const legal: Record<string, string> = {
	'r1-c1': 'loading',
	'r3-c1': 'idle',
	'r3-c2': 'success',
	'r4-c1': 'error',
};

const axisLabelStyle =
	'font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--sl-color-gray-3);';

const rowLabelStyle =
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 10.5px; line-height: 1.35; color: var(--sl-color-gray-2); text-align: right; padding-right: 8px; white-space: nowrap;';

const colLabelStyle =
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 10.5px; color: var(--sl-color-gray-2); text-align: center; padding-bottom: 6px;';
---

<Figure caption="The type admits 16 cells; the runtime ever produces 4.">
	<div class="rsm-root">
		{/* Top axis caption */}
		<div class="rsm-top-caption" style={axisLabelStyle}>
			data field
		</div>

		{/* Column headers */}
		<div class="rsm-col-headers">
			{cols.map((c) => <div style={colLabelStyle}>{c.dataLabel}</div>)}
		</div>

		{/* Left axis caption */}
		<div class="rsm-left-caption" style={axisLabelStyle}>
			isLoading / error
		</div>

		{/* Body: row labels + 4x4 cell grid */}
		<div class="rsm-body">
			{
				rows.map((r) => (
					<>
						<div style={rowLabelStyle}>
							isLoading: {String(r.il)}
							<br />
							error: {r.e ? 'Error' : 'undef'}
						</div>
						<div class="rsm-row">
							{cols.map((c) => {
								const cellKey = `${r.id}-${c.id}`;
								const stateName = legal[cellKey];
								const isLegal = stateName !== undefined;
								return (
									<div
										class={`rsm-cell ${isLegal ? 'rsm-legal' : 'rsm-impossible'}`}
									>
										{isLegal ? (
											<>
												<svg
													class="rsm-check"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="3"
													stroke-linecap="round"
													stroke-linejoin="round"
													aria-hidden="true"
												>
													<polyline points="4 12 10 18 20 6" />
												</svg>
												<div class="rsm-state-badge">{stateName}</div>
											</>
										) : (
											<>
												<svg
													class="rsm-cross"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="3"
													stroke-linecap="round"
													aria-hidden="true"
												>
													<line x1="6" y1="6" x2="18" y2="18" />
													<line x1="18" y1="6" x2="6" y2="18" />
												</svg>
												<div class="rsm-impossible-tag">impossible</div>
											</>
										)}
									</div>
								);
							})}
						</div>
					</>
				))
			}
		</div>

		{/* Footer counts */}
		<div class="rsm-footer">
			<div class="rsm-count">
				<span class="rsm-swatch rsm-swatch-legal" />
				<span>Runtime states: <strong>4</strong></span>
			</div>
			<div class="rsm-count">
				<span class="rsm-swatch rsm-swatch-impossible" />
				<span>Impossible cells: <strong>12</strong></span>
			</div>
			<div class="rsm-count">
				<span>Total cells admitted by the type: <strong>16</strong></span>
			</div>
		</div>
	</div>
</Figure>

<style define:vars={{ LEGAL_FILL, IMPOSSIBLE_FILL }}>
	.rsm-root {
		display: grid;
		grid-template-columns: auto 1fr;
		grid-template-rows: auto auto 1fr auto;
		grid-template-areas:
			'. top-caption'
			'. col-headers'
			'left-caption body'
			'footer footer';
		gap: 0;
		padding: 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
	}

	.rsm-top-caption {
		grid-area: top-caption;
		text-align: center;
		padding-bottom: 4px;
	}

	.rsm-col-headers {
		grid-area: col-headers;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 6px;
	}

	.rsm-left-caption {
		grid-area: left-caption;
		writing-mode: vertical-rl;
		transform: rotate(180deg);
		text-align: center;
		padding-right: 6px;
		align-self: center;
		justify-self: center;
	}

	.rsm-body {
		grid-area: body;
		display: grid;
		grid-template-columns: auto 1fr;
		row-gap: 6px;
		column-gap: 8px;
		align-items: center;
	}

	.rsm-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 6px;
	}

	.rsm-cell {
		aspect-ratio: 1 / 1;
		min-height: 72px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		border-radius: 6px;
		border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
		padding: 6px;
		text-align: center;
	}

	.rsm-legal {
		background: color-mix(in srgb, var(--LEGAL_FILL) 22%, transparent);
		border-color: color-mix(in srgb, var(--LEGAL_FILL) 60%, transparent);
		color: var(--sl-color-text);
	}

	.rsm-impossible {
		background: color-mix(in srgb, var(--IMPOSSIBLE_FILL) 12%, transparent);
		border-color: color-mix(in srgb, var(--IMPOSSIBLE_FILL) 40%, transparent);
		color: var(--sl-color-gray-3);
	}

	.rsm-check {
		width: 22px;
		height: 22px;
		color: var(--LEGAL_FILL);
	}

	.rsm-cross {
		width: 18px;
		height: 18px;
		color: color-mix(in srgb, var(--IMPOSSIBLE_FILL) 75%, transparent);
		opacity: 0.85;
	}

	.rsm-state-badge {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		font-weight: 600;
		color: var(--sl-color-text);
		background: color-mix(in srgb, var(--LEGAL_FILL) 40%, transparent);
		padding: 1px 6px;
		border-radius: 999px;
	}

	.rsm-impossible-tag {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 10px;
		font-weight: 500;
		color: color-mix(in srgb, var(--IMPOSSIBLE_FILL) 90%, var(--sl-color-text));
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.rsm-footer {
		grid-area: footer;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 18px;
		margin-top: 14px;
		padding-top: 12px;
		border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 12px;
		color: var(--sl-color-gray-2);
	}

	.rsm-count {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.rsm-count strong {
		color: var(--sl-color-text);
	}

	.rsm-swatch {
		display: inline-block;
		width: 12px;
		height: 12px;
		border-radius: 3px;
		border: 1px solid color-mix(in srgb, currentColor 25%, transparent);
	}

	.rsm-swatch-legal {
		background: color-mix(in srgb, var(--LEGAL_FILL) 60%, transparent);
		border-color: color-mix(in srgb, var(--LEGAL_FILL) 70%, transparent);
	}

	.rsm-swatch-impossible {
		background: color-mix(in srgb, var(--IMPOSSIBLE_FILL) 35%, transparent);
		border-color: color-mix(in srgb, var(--IMPOSSIBLE_FILL) 55%, transparent);
	}

	@media (max-width: 640px) {
		.rsm-cell {
			min-height: 58px;
			padding: 4px;
		}
		.rsm-check {
			width: 18px;
			height: 18px;
		}
		.rsm-state-badge {
			font-size: 10px;
			padding: 1px 4px;
		}
	}
</style>
