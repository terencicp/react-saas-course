---
// Diagram: 4x4 matrix of every combination the flag-set RequestState type admits.
//
// Rows encode the four (isLoading, error) combinations; columns encode data
// presence (the first column is `data: undefined`, the other three are concrete
// User values, illustrating that "data present" is one boolean but admits many
// distinct values). 16 cells total — the type signs off on all of them. Only
// four cells correspond to states the runtime ever produces (idle, loading,
// success, error); the rest are impossible-by-construction.
//
// Per documentation/diagrams/html-css.md: inline styles only, `margin: 0` on
// every inner element to defeat Starlight's prose `margin-top` injection, and
// kept vertically compact (cells are short rows of icon + label, not square).

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones — readable against both light and dark backgrounds.
const LEGAL_FILL = '#10b981'; // emerald-500 — runtime-legal cells
const IMPOSSIBLE_FILL = '#ef4444'; // red-500 — impossible cells

type Row = { id: string; il: boolean; e: boolean };
type Col = { id: string; dataLabel: string };

const rows: Row[] = [
	{ id: 'r1', il: true, e: false },
	{ id: 'r2', il: true, e: true },
	{ id: 'r3', il: false, e: false },
	{ id: 'r4', il: false, e: true },
];

const cols: Col[] = [
	{ id: 'c1', dataLabel: 'data: undef' },
	{ id: 'c2', dataLabel: 'data: User A' },
	{ id: 'c3', dataLabel: 'data: User B' },
	{ id: 'c4', dataLabel: 'data: User C' },
];

// The four runtime-legal cells, keyed by `${rowId}-${colId}`.
const legal: Record<string, string> = {
	'r1-c1': 'loading',
	'r3-c1': 'idle',
	'r3-c2': 'success',
	'r4-c1': 'error',
};

const legalBg = `color-mix(in srgb, ${LEGAL_FILL} 22%, transparent)`;
const legalBorder = `color-mix(in srgb, ${LEGAL_FILL} 60%, transparent)`;
const legalBadgeBg = `color-mix(in srgb, ${LEGAL_FILL} 40%, transparent)`;
const impossibleBg = `color-mix(in srgb, ${IMPOSSIBLE_FILL} 12%, transparent)`;
const impossibleBorder = `color-mix(in srgb, ${IMPOSSIBLE_FILL} 40%, transparent)`;
const impossibleTagColor = `color-mix(in srgb, ${IMPOSSIBLE_FILL} 90%, var(--sl-color-text))`;
const crossColor = `color-mix(in srgb, ${IMPOSSIBLE_FILL} 75%, transparent)`;

const axisLabelStyle =
	'font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--sl-color-gray-3); margin: 0;';

const rowLabelStyle =
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 10.5px; line-height: 1.4; color: var(--sl-color-gray-2); text-align: right; padding-right: 8px; white-space: nowrap; margin: 0;';

const colLabelStyle =
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 10.5px; color: var(--sl-color-gray-2); text-align: center; margin: 0;';

const cellBaseStyle =
	'display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 6px; min-height: 38px; padding: 4px 8px; border-radius: 6px; border: 1px solid; text-align: center; margin: 0;';

const stateBadgeStyle = `font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 600; color: var(--sl-color-text); background: ${legalBadgeBg}; padding: 1px 6px; border-radius: 999px; margin: 0;`;

const impossibleTagStyle = `font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-size: 10px; font-weight: 500; color: ${impossibleTagColor}; text-transform: uppercase; letter-spacing: 0.04em; margin: 0;`;
---

<Figure caption="The type admits 16 cells; the runtime ever produces 4.">
	<div
		style="display: grid; grid-template-columns: auto auto 1fr; grid-template-rows: auto auto repeat(4, auto) auto; column-gap: 8px; row-gap: 6px; padding: 14px; border-radius: 8px; background: var(--sl-color-bg-sidebar); margin: 0;"
	>
		{/* Top axis caption — spans the cells column */}
		<div
			style={`${axisLabelStyle} grid-column: 3; grid-row: 1; text-align: center; padding-bottom: 2px;`}
		>
			data field
		</div>

		{/* Column headers */}
		<div
			style="grid-column: 3; grid-row: 2; display: grid; grid-template-columns: repeat(4, 1fr); column-gap: 6px; margin: 0;"
		>
			{cols.map((c) => <div style={colLabelStyle}>{c.dataLabel}</div>)}
		</div>

		{/* Left axis caption — spans all 4 body rows */}
		<div
			style={`${axisLabelStyle} grid-column: 1; grid-row: 3 / span 4; writing-mode: vertical-rl; transform: rotate(180deg); align-self: center; justify-self: center; padding-right: 4px;`}
		>
			isLoading / error
		</div>

		{
			rows.map((r, ri) => (
				<>
					<div
						style={`${rowLabelStyle} grid-column: 2; grid-row: ${3 + ri};`}
					>
						isLoading: {String(r.il)}
						<br />
						error: {r.e ? 'Error' : 'undef'}
					</div>
					<div
						style={`grid-column: 3; grid-row: ${3 + ri}; display: grid; grid-template-columns: repeat(4, 1fr); column-gap: 6px; margin: 0;`}
					>
						{cols.map((c) => {
							const stateName = legal[`${r.id}-${c.id}`];
							const isLegal = stateName !== undefined;
							const cellStyle = isLegal
								? `${cellBaseStyle} background: ${legalBg}; border-color: ${legalBorder}; color: var(--sl-color-text);`
								: `${cellBaseStyle} background: ${impossibleBg}; border-color: ${impossibleBorder}; color: var(--sl-color-gray-3);`;
							return (
								<div style={cellStyle}>
									{isLegal ? (
										<>
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="3"
												stroke-linecap="round"
												stroke-linejoin="round"
												aria-hidden="true"
												style={`width: 16px; height: 16px; flex-shrink: 0; color: ${LEGAL_FILL}; margin: 0;`}
											>
												<polyline points="4 12 10 18 20 6" />
											</svg>
											<span style={stateBadgeStyle}>{stateName}</span>
										</>
									) : (
										<>
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="3"
												stroke-linecap="round"
												aria-hidden="true"
												style={`width: 14px; height: 14px; flex-shrink: 0; color: ${crossColor}; opacity: 0.85; margin: 0;`}
											>
												<line x1="6" y1="6" x2="18" y2="18" />
												<line x1="18" y1="6" x2="6" y2="18" />
											</svg>
											<span style={impossibleTagStyle}>impossible</span>
										</>
									)}
								</div>
							);
						})}
					</div>
				</>
			))
		}

		{/* Footer counts — span all three columns */}
		<div
			style="grid-column: 1 / -1; grid-row: 7; display: flex; flex-wrap: wrap; justify-content: center; column-gap: 18px; row-gap: 6px; margin: 10px 0 0; padding-top: 10px; border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent); font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-size: 12px; color: var(--sl-color-gray-2);"
		>
			<div style="display: flex; align-items: center; gap: 6px; margin: 0;">
				<span
					style={`display: inline-block; width: 12px; height: 12px; border-radius: 3px; background: color-mix(in srgb, ${LEGAL_FILL} 60%, transparent); border: 1px solid color-mix(in srgb, ${LEGAL_FILL} 70%, transparent); margin: 0;`}
				/>
				<span style="margin: 0;">
					Runtime states: <strong style="color: var(--sl-color-text); margin: 0;">4</strong>
				</span>
			</div>
			<div style="display: flex; align-items: center; gap: 6px; margin: 0;">
				<span
					style={`display: inline-block; width: 12px; height: 12px; border-radius: 3px; background: color-mix(in srgb, ${IMPOSSIBLE_FILL} 35%, transparent); border: 1px solid color-mix(in srgb, ${IMPOSSIBLE_FILL} 55%, transparent); margin: 0;`}
				/>
				<span style="margin: 0;">
					Impossible cells: <strong style="color: var(--sl-color-text); margin: 0;">12</strong>
				</span>
			</div>
			<div style="display: flex; align-items: center; gap: 6px; margin: 0;">
				<span style="margin: 0;">
					Total cells admitted by the type:{' '}
					<strong style="color: var(--sl-color-text); margin: 0;">16</strong>
				</span>
			</div>
		</div>
	</div>
</Figure>
