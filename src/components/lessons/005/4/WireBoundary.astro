---
// Diagram: brands erase at the wire boundary.
//
// Three-stage horizontal flow:
//   1. Codebase A (left) — a rounded container with one value tile,
//      `'usr_abc'` carrying the `UserId` pill. The brand exists in
//      the codebase.
//   2. Wire boundary (middle) — a horizontal arrow labelled
//      `JSON / fetch / DB / URL`. A faded, strike-through `UserId`
//      pill sits at the midpoint of the arrow to convey the brand
//      "falling off" the value in transit.
//   3. Codebase B (right) — a rounded container with a small inner
//      flow stacked top-to-bottom: plain `'usr_abc'` typed `string`,
//      then a `userId()` factory gate, then the same value with the
//      `UserId` pill restored.
//
// Visual story, left to right: tagged → tag falls off → arrives as
// plain string → factory re-tags.
//
// Pure HTML+CSS, no interactivity. Style mirrors StructuralVsNominal
// for chapter consistency — sl-color tokens for chrome, the same
// sky-500 brand accent used for `UserId`.

import Figure from '../../../figures/Figure.astro';

const USER_BRAND = '#0ea5e9'; // sky-500 — matches StructuralVsNominal

const codebaseHeaderStyle = [
	'margin: 0 0 10px',
	'font-family: system-ui, -apple-system, "Segoe UI", sans-serif',
	'font-size: 11px',
	'font-weight: 600',
	'text-transform: uppercase',
	'letter-spacing: 0.06em',
	'color: var(--sl-color-gray-3)',
	'text-align: center',
].join('; ');

const captionStyle = [
	'margin: 12px 0 0',
	'font-family: system-ui, -apple-system, "Segoe UI", sans-serif',
	'font-size: 12px',
	'color: var(--sl-color-gray-2)',
	'text-align: center',
	'line-height: 1.4',
].join('; ');

const typeLabelStyle =
	'margin: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; color: var(--sl-color-gray-3);';

const valueStyle =
	'margin: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 14px; font-weight: 600; color: var(--sl-color-text);';

// Codebase container — rounded box with dashed-ish hairline that
// frames the "scope" of a codebase.
const codebaseBoxStyle = [
	'display: flex',
	'flex-direction: column',
	'gap: 10px',
	'padding: 14px',
	'border-radius: 10px',
	'border: 1px solid color-mix(in srgb, currentColor 22%, transparent)',
	'background: color-mix(in srgb, currentColor 3%, transparent)',
	'min-height: 120px',
	'justify-content: center',
].join('; ');

// Plain string tile — no brand.
const plainTileStyle = [
	'margin: 0',
	'padding: 10px 12px',
	'border-radius: 8px',
	'border: 1px solid color-mix(in srgb, currentColor 18%, transparent)',
	'background: color-mix(in srgb, currentColor 4%, transparent)',
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 12px',
].join('; ');

// Branded tile — tinted border + background by the brand color.
const brandedTileStyle = [
	'margin: 0',
	'padding: 10px 12px',
	'border-radius: 8px',
	`border: 1px solid color-mix(in srgb, ${USER_BRAND} 55%, transparent)`,
	`background: color-mix(in srgb, ${USER_BRAND} 10%, transparent)`,
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 12px',
].join('; ');

const tileLeftStyle =
	'display: flex; flex-direction: column; gap: 4px; margin: 0; min-width: 0;';

const pillStyle = [
	'margin: 0',
	'padding: 2px 8px',
	'border-radius: 999px',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 10.5px',
	'font-weight: 600',
	'letter-spacing: 0.02em',
	'color: #fff',
	`background: ${USER_BRAND}`,
	`border: 1px solid ${USER_BRAND}`,
	'white-space: nowrap',
].join('; ');

// Faded / strike-through pill in transit — same brand color but
// drained of saturation and crossed out, to read as "the brand is
// falling off the value".
const fadedPillStyle = [
	'margin: 0',
	'padding: 2px 8px',
	'border-radius: 999px',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 10.5px',
	'font-weight: 600',
	'letter-spacing: 0.02em',
	`color: color-mix(in srgb, ${USER_BRAND} 60%, transparent)`,
	'background: transparent',
	`border: 1px dashed color-mix(in srgb, ${USER_BRAND} 45%, transparent)`,
	'white-space: nowrap',
	'text-decoration: line-through',
	`text-decoration-color: color-mix(in srgb, ${USER_BRAND} 80%, transparent)`,
	'text-decoration-thickness: 1.5px',
].join('; ');

// Wire-boundary label above the arrow.
const wireLabelStyle = [
	'margin: 0',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 11px',
	'color: var(--sl-color-gray-3)',
	'text-align: center',
	'letter-spacing: 0.02em',
].join('; ');

// Factory gate — small inline element with a funnel icon and the
// factory name.
const factoryGateStyle = [
	'margin: 0',
	'padding: 6px 12px',
	'border-radius: 8px',
	'border: 1px solid color-mix(in srgb, currentColor 28%, transparent)',
	'background: color-mix(in srgb, currentColor 6%, transparent)',
	'display: inline-flex',
	'align-items: center',
	'gap: 6px',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 12px',
	'font-weight: 600',
	'color: var(--sl-color-text)',
	'align-self: center',
].join('; ');
---

<Figure
	caption="The brand erases over the wire. The receiving end re-brands at the factory seam."
>
	<div class="wb-root">
		{/* STAGE 1 — Codebase A */}
		<div class="wb-stage wb-stage-codebase">
			<div style={codebaseHeaderStyle}>Codebase A</div>
			<div style={codebaseBoxStyle}>
				<div style={brandedTileStyle}>
					<div style={tileLeftStyle}>
						<div style={typeLabelStyle}>string</div>
						<div style={valueStyle}>{"'usr_abc'"}</div>
					</div>
					<div style={pillStyle}>UserId</div>
				</div>
			</div>
			<div style={captionStyle}>branded</div>
		</div>

		{/* STAGE 2 — Wire boundary */}
		<div class="wb-stage wb-stage-wire">
			<div style={wireLabelStyle}>JSON / fetch / DB / URL</div>
			<div class="wb-arrow">
				<div class="wb-arrow-line" aria-hidden="true"></div>
				<div class="wb-arrow-head" aria-hidden="true"></div>
				<div class="wb-arrow-pill">
					<div style={fadedPillStyle}>UserId</div>
				</div>
			</div>
			<div style={captionStyle}>brand erases</div>
		</div>

		{/* STAGE 3 — Codebase B */}
		<div class="wb-stage wb-stage-codebase">
			<div style={codebaseHeaderStyle}>Codebase B</div>
			<div style={codebaseBoxStyle}>
				<div style={plainTileStyle}>
					<div style={tileLeftStyle}>
						<div style={typeLabelStyle}>string</div>
						<div style={valueStyle}>{"'usr_abc'"}</div>
					</div>
				</div>
				<div class="wb-down-arrow" aria-hidden="true"></div>
				<div style={factoryGateStyle}>
					<svg
						width="14"
						height="14"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M3 3h18l-7 9v7l-4 2v-9z"></path>
					</svg>
					<span>userId()</span>
				</div>
				<div class="wb-down-arrow" aria-hidden="true"></div>
				<div style={brandedTileStyle}>
					<div style={tileLeftStyle}>
						<div style={typeLabelStyle}>string</div>
						<div style={valueStyle}>{"'usr_abc'"}</div>
					</div>
					<div style={pillStyle}>UserId</div>
				</div>
			</div>
			<div style={captionStyle}>re-branded at the factory seam</div>
		</div>
	</div>
</Figure>

<style>
	.wb-root {
		display: grid;
		grid-template-columns: 1fr 1.1fr 1fr;
		align-items: stretch;
		gap: 8px;
		padding: 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	.wb-stage {
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		padding: 0 8px;
		margin: 0;
	}

	.wb-stage-wire {
		justify-content: center;
		padding: 0 4px;
	}

	/* The arrow itself — horizontal line + arrowhead + a pill perched on top. */
	.wb-arrow {
		position: relative;
		margin: 10px 0 8px;
		height: 36px;
	}

	.wb-arrow-line {
		position: absolute;
		top: 50%;
		left: 0;
		right: 8px;
		height: 1.5px;
		background: color-mix(in srgb, currentColor 35%, transparent);
		transform: translateY(-50%);
	}

	.wb-arrow-head {
		position: absolute;
		top: 50%;
		right: 0;
		width: 0;
		height: 0;
		border-top: 5px solid transparent;
		border-bottom: 5px solid transparent;
		border-left: 8px solid color-mix(in srgb, currentColor 45%, transparent);
		transform: translateY(-50%);
	}

	.wb-arrow-pill {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		padding: 0 6px;
		background: var(--sl-color-bg-sidebar);
	}

	/* Small vertical connector between the three rows inside Codebase B. */
	.wb-down-arrow {
		width: 1.5px;
		height: 14px;
		background: color-mix(in srgb, currentColor 35%, transparent);
		align-self: center;
		margin: 0;
		position: relative;
	}

	.wb-down-arrow::after {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 50%;
		width: 0;
		height: 0;
		border-left: 4px solid transparent;
		border-right: 4px solid transparent;
		border-top: 5px solid color-mix(in srgb, currentColor 45%, transparent);
		transform: translateX(-50%);
	}

	@media (max-width: 720px) {
		.wb-root {
			grid-template-columns: 1fr;
			gap: 16px;
		}

		.wb-stage-wire {
			padding: 0 16px;
		}

		.wb-arrow {
			height: 36px;
		}
	}
</style>
</content>
</invoke>