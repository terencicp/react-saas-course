---
// Diagram: structural vs. nominal split, side by side. Two columns; each
// holds the same pair of string values (`'usr_abc'`, `'inv_xyz'`).
//
// Left column — "What the runtime sees". Both tiles are typed `string`,
// same chrome, same colors. The point is that the runtime cannot tell
// them apart — there is no brand at the runtime level.
//
// Right column — "What the type system sees". Same values, but each
// tile now carries a brand pill (UserId in sky-blue, InvoiceId in
// violet). The tiles are tinted by their brand color and the borders
// pick up the brand hue too, so the "distinct types" point reads
// at a glance.
//
// A vertical hairline separates the columns. Pure HTML+CSS, no
// interactivity. Style mirrors RequestStateMatrix and
// UnionIntersectionVenn — sl-color tokens for chrome, saturated
// mid-tones for the brand accents (readable on both light and dark
// backgrounds).

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones — readable against both light and dark backgrounds.
const USER_BRAND = '#0ea5e9'; // sky-500
const INVOICE_BRAND = '#8b5cf6'; // violet-500

const headerStyle =
	'margin: 0 0 12px; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--sl-color-gray-3); text-align: center;';

const annotationStyle =
	'margin: 12px 0 0; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; font-size: 12px; color: var(--sl-color-gray-2); text-align: center; line-height: 1.4;';

// Plain value tile (runtime side) — both tiles are visually identical.
const runtimeTileStyle = [
	'margin: 0',
	'padding: 12px 14px',
	'border-radius: 8px',
	'border: 1px solid color-mix(in srgb, currentColor 18%, transparent)',
	'background: color-mix(in srgb, currentColor 4%, transparent)',
	'display: flex',
	'align-items: center',
	'justify-content: space-between',
	'gap: 12px',
].join('; ');

const typeLabelStyle =
	'margin: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; color: var(--sl-color-gray-3);';

const valueStyle =
	'margin: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 14px; font-weight: 600; color: var(--sl-color-text);';

const pillStyle = (color: string) =>
	[
		'margin: 0',
		'padding: 2px 8px',
		'border-radius: 999px',
		'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
		'font-size: 10.5px',
		'font-weight: 600',
		'letter-spacing: 0.02em',
		'color: #fff',
		`background: ${color}`,
		`border: 1px solid ${color}`,
		'white-space: nowrap',
	].join('; ');

// Branded tile (type-system side) — border + background tinted by the brand color.
const brandedTileStyle = (color: string) =>
	[
		'margin: 0',
		'padding: 12px 14px',
		'border-radius: 8px',
		`border: 1px solid color-mix(in srgb, ${color} 55%, transparent)`,
		`background: color-mix(in srgb, ${color} 10%, transparent)`,
		'display: flex',
		'align-items: center',
		'justify-content: space-between',
		'gap: 12px',
	].join('; ');
---

<Figure
	caption="At runtime, both are strings. At compile time, the brand makes them distinct."
>
	<div class="svn-root">
		{/* LEFT — what the runtime sees */}
		<div class="svn-panel">
			<div style={headerStyle}>What the runtime sees</div>
			<div class="svn-stack">
				<div style={runtimeTileStyle}>
					<div class="svn-tile-left">
						<div style={typeLabelStyle}>string</div>
						<div style={valueStyle}>{"'usr_abc'"}</div>
					</div>
				</div>
				<div style={runtimeTileStyle}>
					<div class="svn-tile-left">
						<div style={typeLabelStyle}>string</div>
						<div style={valueStyle}>{"'inv_xyz'"}</div>
					</div>
				</div>
			</div>
			<div style={annotationStyle}>
				Same type. Interchangeable.
			</div>
		</div>

		{/* divider */}
		<div class="svn-divider" aria-hidden="true"></div>

		{/* RIGHT — what the type system sees */}
		<div class="svn-panel">
			<div style={headerStyle}>What the type system sees</div>
			<div class="svn-stack">
				<div style={brandedTileStyle(USER_BRAND)}>
					<div class="svn-tile-left">
						<div style={typeLabelStyle}>string</div>
						<div style={valueStyle}>{"'usr_abc'"}</div>
					</div>
					<div style={pillStyle(USER_BRAND)}>UserId</div>
				</div>
				<div style={brandedTileStyle(INVOICE_BRAND)}>
					<div class="svn-tile-left">
						<div style={typeLabelStyle}>string</div>
						<div style={valueStyle}>{"'inv_xyz'"}</div>
					</div>
					<div style={pillStyle(INVOICE_BRAND)}>InvoiceId</div>
				</div>
			</div>
			<div style={annotationStyle}>
				Distinct types. The compiler refuses<br />to cross the lanes.
			</div>
		</div>
	</div>
</Figure>

<style>
	.svn-root {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: stretch;
		gap: 0;
		padding: 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	.svn-panel {
		display: flex;
		flex-direction: column;
		padding: 0 20px;
		margin: 0;
	}

	.svn-stack {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
	}

	.svn-tile-left {
		display: flex;
		flex-direction: column;
		gap: 4px;
		margin: 0;
		min-width: 0;
	}

	.svn-divider {
		width: 1px;
		background: color-mix(in srgb, currentColor 18%, transparent);
		margin: 0;
		align-self: stretch;
	}

	@media (max-width: 640px) {
		.svn-root {
			grid-template-columns: 1fr;
			gap: 16px;
		}
		.svn-divider {
			width: 100%;
			height: 1px;
		}
		.svn-panel {
			padding: 0;
		}
	}
</style>
