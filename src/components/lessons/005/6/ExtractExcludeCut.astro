---
// Diagram: Extract<T, U> and Exclude<T, U> as complementary slices of a union.
//
// Three stacked rows of a unified 4-column grid. Vertical alignment between
// rows is the load-bearing visual: the Extract slice sits under the first two
// (green) source boxes; the Exclude slice sits under the last two (orange)
// source boxes. Color carries the relationship — no arrows needed.
//
//   row 1 — source label spanning all 4 columns (centered, monospace)
//   row 2 — the four source boxes 'draft' 'sent' 'paid' 'void'
//                                  green   green orange orange
//   row 3 — divider line
//   row 4 — Extract<…, 'draft' | 'sent'>  label  | green | green | (empty) | (empty)
//   row 5 — Exclude<…, 'draft' | 'sent'>  label  | (empty) | (empty) | orange | orange
//
// The utility-expression labels sit in a separate left column outside the
// 4-column box grid; they're aligned right and sit at the same vertical level
// as their slice boxes.
//
// Pure HTML+CSS, no interactivity. Uses the project's `--mark-green-*` /
// `--mark-orange-*` palette so tints flip with the theme.

import Figure from '../../../figures/Figure.astro';

// Small monospace box for a single literal member of the union.
const memberBoxBase = [
	'margin: 0',
	'padding: 8px 0',
	'border-radius: 6px',
	'font-family: ui-monospace, SFMono-Regular, Menlo, monospace',
	'font-size: 13px',
	'font-weight: 500',
	'color: var(--sl-color-text)',
	'text-align: center',
	'border: 1px solid',
].join('; ');

const greenBoxStyle = [
	memberBoxBase,
	'background: var(--mark-green-bg)',
	'border-color: var(--mark-green-brd)',
].join('; ');

const orangeBoxStyle = [
	memberBoxBase,
	'background: var(--mark-orange-bg)',
	'border-color: var(--mark-orange-brd)',
].join('; ');
---

<Figure
	caption="Two ways to name the same cut — Extract keeps the green slice, Exclude keeps the orange one."
>
	<div class="eec-root">
		{/* Row 1: source label, spans all four box columns */}
		<div class="eec-source-label">
			InvoiceStatus = <span class="eec-green">'draft'</span> | <span class="eec-green">'sent'</span> | <span class="eec-orange">'paid'</span> | <span class="eec-orange">'void'</span>
		</div>

		{/* Row 2: source row — the four union members */}
		<div class="eec-source-row">
			<div style={greenBoxStyle}>'draft'</div>
			<div style={greenBoxStyle}>'sent'</div>
			<div style={orangeBoxStyle}>'paid'</div>
			<div style={orangeBoxStyle}>'void'</div>
		</div>

		{/* Row 3: divider */}
		<div class="eec-divider" aria-hidden="true"></div>

		{/* Row 4: Extract — label on the left, two green boxes in the left half */}
		<div class="eec-cut-label">Extract&lt;…, 'draft' | 'sent'&gt;</div>
		<div class="eec-cut-row eec-cut-row-extract">
			<div style={greenBoxStyle}>'draft'</div>
			<div style={greenBoxStyle}>'sent'</div>
		</div>

		{/* Row 5: Exclude — label on the left, two orange boxes in the right half */}
		<div class="eec-cut-label">Exclude&lt;…, 'draft' | 'sent'&gt;</div>
		<div class="eec-cut-row eec-cut-row-exclude">
			<div style={orangeBoxStyle}>'paid'</div>
			<div style={orangeBoxStyle}>'void'</div>
		</div>
	</div>
</Figure>

<style>
	/* Outer grid:
	 *   col 1 — utility-expression label (right-aligned, max-content)
	 *   col 2 — four-column inner grid containing the source row and cut rows
	 * Row layout uses grid auto-flow so we can place per-row spans.
	 */
	.eec-root {
		display: grid;
		grid-template-columns: max-content minmax(0, 1fr);
		column-gap: 16px;
		row-gap: 0;
		padding: 22px 18px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	/* Row 1: source label, spans both columns, centered above the source row. */
	.eec-source-label {
		grid-column: 1 / -1;
		margin: 0 0 14px;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 13px;
		color: var(--sl-color-text);
		text-align: center;
	}

	/* Row 2: source row — sits only in the right column (column 2), as a
	 * 4-equal-column grid so we have a stable coordinate system for the
	 * cut rows below to align to. */
	.eec-source-row {
		grid-column: 2 / 3;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		column-gap: 10px;
		margin: 0;
	}

	/* Row 3: divider line, full width. */
	.eec-divider {
		grid-column: 1 / -1;
		height: 1px;
		background: color-mix(in srgb, currentColor 14%, transparent);
		margin: 14px 0;
	}

	/* Utility-expression labels (Extract / Exclude lines). Right-aligned to
	 * sit immediately to the left of their cut row. */
	.eec-cut-label {
		grid-column: 1 / 2;
		margin: 0;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		color: var(--sl-color-gray-2);
		text-align: right;
		white-space: nowrap;
		align-self: center;
	}

	/* Cut rows — also a 4-equal-column grid so each box sits exactly under
	 * its corresponding source box. */
	.eec-cut-row {
		grid-column: 2 / 3;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		column-gap: 10px;
		margin: 10px 0 0;
	}

	/* Extract row — first two cells filled with the green slice, last two empty. */
	.eec-cut-row-extract > :nth-child(1) {
		grid-column: 1 / 2;
	}
	.eec-cut-row-extract > :nth-child(2) {
		grid-column: 2 / 3;
	}

	/* Exclude row — first two cells empty, last two filled with the orange slice. */
	.eec-cut-row-exclude > :nth-child(1) {
		grid-column: 3 / 4;
	}
	.eec-cut-row-exclude > :nth-child(2) {
		grid-column: 4 / 5;
	}

	/* Inline color hits for the source label. Use mid-tone, not the bg/brd
	 * tokens, so the text reads clearly against the figure background. */
	.eec-green {
		color: light-dark(#16a34a, #4ade80);
	}
	.eec-orange {
		color: light-dark(#d97706, #fbbf24);
	}

	@media (max-width: 640px) {
		.eec-root {
			grid-template-columns: 1fr;
			row-gap: 4px;
		}
		.eec-source-row,
		.eec-cut-row {
			grid-column: 1 / -1;
		}
		.eec-cut-label {
			grid-column: 1 / -1;
			text-align: left;
			margin-top: 10px;
		}
	}
</style>

