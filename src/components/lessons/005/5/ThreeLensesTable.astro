---
// Diagram: three-row reference table mapping each type-level operator on
// `ROUTES` to what it reads and what it returns.
//
// Three rows (one per lens):
//   1. `typeof ROUTES`                       → the shape
//   2. `keyof typeof ROUTES`                 → the keys
//   3. `(typeof ROUTES)[keyof typeof ROUTES]` → the values
//
// Each row carries a different accent (amber / blue / violet) so the
// "three lenses" framing is visible at a glance. Style follows the
// sibling TwoRegistersTable in this same lesson — sl-color tokens for
// chrome, color-mix tints for backgrounds, monospace cells for code.

import Figure from '../../../figures/Figure.astro';

const SHAPE_ACCENT = '#f59e0b'; // amber-500 — typeof (the shape lens)
const KEYS_ACCENT = '#3b82f6'; // blue-500 — keyof (the keys lens)
const VALUES_ACCENT = '#a855f7'; // violet-500 — indexed access (the values lens)

type Row = {
	operator: string;
	reads: string;
	returns: string[];
	accent: 'shape' | 'keys' | 'values';
};

const rows: Row[] = [
	{
		operator: 'typeof ROUTES',
		reads: "the value's full shape",
		returns: [
			"{ readonly home: '/';",
			"  readonly invoices: '/invoices';",
			"  readonly settings: '/settings' }",
		],
		accent: 'shape',
	},
	{
		operator: 'keyof typeof ROUTES',
		reads: 'the property names',
		returns: ["'home' | 'invoices' | 'settings'"],
		accent: 'keys',
	},
	{
		operator: '(typeof ROUTES)[keyof typeof ROUTES]',
		reads: 'the value types across keys',
		returns: ["'/' | '/invoices' | '/settings'"],
		accent: 'values',
	},
];
---

<Figure caption="Each operator reads a different layer of the same value.">
	<div class="tlt-root">
		<div class="tlt-title">
			Three lenses on <span class="tlt-mono-inline">ROUTES</span>
		</div>

		{/* Header row */}
		<div class="tlt-row tlt-header">
			<div class="tlt-cell tlt-head-cell">Operator</div>
			<div class="tlt-cell tlt-head-cell">Reads</div>
			<div class="tlt-cell tlt-head-cell">Returns</div>
		</div>

		{/* Data rows */}
		{
			rows.map((r) => (
				<div class={`tlt-row tlt-accent-${r.accent}`}>
					<div class="tlt-cell tlt-operator">
						<span class="tlt-dot" aria-hidden="true" />
						<span class="tlt-mono-inline">{r.operator}</span>
					</div>
					<div class="tlt-cell tlt-reads">
						<span class="tlt-prose">{r.reads}</span>
					</div>
					<div class="tlt-cell tlt-returns">
						<div class="tlt-mono-block">
							{r.returns.map((line) => (
								<div class="tlt-mono-line">{line}</div>
							))}
						</div>
					</div>
				</div>
			))
		}
	</div>
</Figure>

<style define:vars={{ SHAPE_ACCENT, KEYS_ACCENT, VALUES_ACCENT }}>
	.tlt-root {
		display: grid;
		grid-template-columns: max-content max-content max-content;
		row-gap: 1px;
		padding: 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
		overflow-x: auto;
	}

	.tlt-title {
		grid-column: 1 / -1;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3);
		text-align: center;
		padding-bottom: 12px;
		margin: 0;
	}

	.tlt-row {
		display: contents;
	}

	.tlt-cell {
		padding: 10px 14px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.tlt-head-cell {
		font-size: 11.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		padding-top: 8px;
		padding-bottom: 8px;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.tlt-operator {
		flex-direction: row;
		align-items: center;
		gap: 10px;
	}

	.tlt-dot {
		display: inline-block;
		flex-shrink: 0;
		width: 8px;
		height: 8px;
		border-radius: 999px;
		background: currentColor;
	}

	.tlt-accent-shape .tlt-dot {
		color: var(--SHAPE_ACCENT);
	}
	.tlt-accent-keys .tlt-dot {
		color: var(--KEYS_ACCENT);
	}
	.tlt-accent-values .tlt-dot {
		color: var(--VALUES_ACCENT);
	}

	.tlt-accent-shape .tlt-operator,
	.tlt-accent-shape .tlt-reads,
	.tlt-accent-shape .tlt-returns {
		background: color-mix(in srgb, var(--SHAPE_ACCENT) 7%, transparent);
		border-left: 2px solid color-mix(in srgb, var(--SHAPE_ACCENT) 55%, transparent);
	}
	.tlt-accent-keys .tlt-operator,
	.tlt-accent-keys .tlt-reads,
	.tlt-accent-keys .tlt-returns {
		background: color-mix(in srgb, var(--KEYS_ACCENT) 7%, transparent);
		border-left: 2px solid color-mix(in srgb, var(--KEYS_ACCENT) 55%, transparent);
	}
	.tlt-accent-values .tlt-operator,
	.tlt-accent-values .tlt-reads,
	.tlt-accent-values .tlt-returns {
		background: color-mix(in srgb, var(--VALUES_ACCENT) 7%, transparent);
		border-left: 2px solid color-mix(in srgb, var(--VALUES_ACCENT) 55%, transparent);
	}

	.tlt-accent-shape .tlt-reads,
	.tlt-accent-shape .tlt-returns,
	.tlt-accent-keys .tlt-reads,
	.tlt-accent-keys .tlt-returns,
	.tlt-accent-values .tlt-reads,
	.tlt-accent-values .tlt-returns {
		border-left: none;
	}

	.tlt-mono-inline {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		color: var(--sl-color-text);
	}

	.tlt-prose {
		margin: 0;
	}

	.tlt-mono-block {
		display: flex;
		flex-direction: column;
		gap: 2px;
		margin: 0;
	}

	.tlt-mono-line {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		color: var(--sl-color-text);
		margin: 0;
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.tlt-root {
			grid-template-columns: 1fr;
		}
		.tlt-row.tlt-header {
			display: none;
		}
		.tlt-cell {
			padding: 8px 12px;
		}
		.tlt-accent-shape .tlt-operator,
		.tlt-accent-keys .tlt-operator,
		.tlt-accent-values .tlt-operator {
			padding-top: 12px;
		}
		.tlt-accent-shape .tlt-returns,
		.tlt-accent-keys .tlt-returns,
		.tlt-accent-values .tlt-returns {
			padding-bottom: 12px;
		}
		.tlt-reads::before {
			content: 'Reads — ';
			font-weight: 600;
			color: var(--sl-color-gray-2);
			font-size: 11px;
			text-transform: uppercase;
			letter-spacing: 0.04em;
			margin-right: 4px;
		}
	}
</style>
