---
// Diagram: side-by-side comparison of the value-level and type-level registers.
//
// Five-row table with a left "key" column (Lives in, Operates on, Erased at
// runtime?, `typeof` here means, Examples) and two register columns. Each
// register column is tinted by a saturated mid-tone (amber for value-level,
// blue for type-level) so the parallel-worlds reading is visible at a glance.
//
// Style follows the chapter 5 family (RequestStateMatrix, StructuralVsNominal):
// sl-color tokens for chrome, color-mix for tinted backgrounds, monospace
// spans for code samples (no <code> pill — keeps cell layout predictable).

import Figure from '../../../figures/Figure.astro';

// Saturated mid-tones — readable against both light and dark backgrounds.
const VALUE_ACCENT = '#f59e0b'; // amber-500 — runtime / value-level
const TYPE_ACCENT = '#3b82f6'; // blue-500 — compile-time / type-level

type Cell = {
	text?: string;
	monoLines?: string[]; // monospace block; each entry on its own line
};

type Row = {
	key: string;
	value: Cell;
	type: Cell;
};

const rows: Row[] = [
	{
		key: 'Lives in',
		value: { text: 'Runtime (the JavaScript engine)' },
		type: { text: 'Compile time (the TypeScript checker)' },
	},
	{
		key: 'Operates on',
		value: { text: 'Values: numbers, strings, objects, functions' },
		type: { text: 'Types: shapes, unions, parameters' },
	},
	{
		key: 'Erased at runtime?',
		value: { text: 'No — it runs' },
		type: { text: 'Yes — disappears before runtime' },
	},
	{
		key: '`typeof` here means',
		value: { text: 'Predicate: "what kind of value is this?"' },
		type: { text: 'Extractor: "what type does this value have?"' },
	},
	{
		key: 'Examples',
		value: {
			monoLines: ['const x = 1;', 'if (a) { … }', 'arr.map(…)'],
		},
		type: {
			monoLines: ['type X = string;', 'keyof User;', 'T[K]'],
		},
	},
];

// Strip backticks from the key labels — render inline `…` as a styled span
// so the table layout isn't dominated by Starlight's prose <code> pill.
const renderKey = (raw: string) => {
	const parts: { text: string; mono: boolean }[] = [];
	let i = 0;
	while (i < raw.length) {
		const tick = raw.indexOf('`', i);
		if (tick === -1) {
			parts.push({ text: raw.slice(i), mono: false });
			break;
		}
		if (tick > i) parts.push({ text: raw.slice(i, tick), mono: false });
		const close = raw.indexOf('`', tick + 1);
		if (close === -1) {
			parts.push({ text: raw.slice(tick), mono: false });
			break;
		}
		parts.push({ text: raw.slice(tick + 1, close), mono: true });
		i = close + 1;
	}
	return parts;
};
---

<Figure caption="The split that determines what each operator can do.">
	<div class="trt-root">
		<div class="trt-title">Two registers</div>

		{/* Header row */}
		<div class="trt-row trt-header">
			<div class="trt-key" aria-hidden="true"></div>
			<div class="trt-cell trt-value trt-head-cell">
				<span class="trt-dot trt-dot-value" aria-hidden="true"></span>
				Value-level
			</div>
			<div class="trt-cell trt-type trt-head-cell">
				<span class="trt-dot trt-dot-type" aria-hidden="true"></span>
				Type-level
			</div>
		</div>

		{/* Data rows */}
		{
			rows.map((r) => (
				<div class="trt-row">
					<div class="trt-key">
						{renderKey(r.key).map((p) =>
							p.mono ? <span class="trt-mono-inline">{p.text}</span> : <span>{p.text}</span>,
						)}
					</div>
					<div class="trt-cell trt-value">
						{r.value.text && <span class="trt-prose">{r.value.text}</span>}
						{r.value.monoLines && (
							<div class="trt-mono-block">
								{r.value.monoLines.map((ln) => (
									<div class="trt-mono-line">{ln}</div>
								))}
							</div>
						)}
					</div>
					<div class="trt-cell trt-type">
						{r.type.text && <span class="trt-prose">{r.type.text}</span>}
						{r.type.monoLines && (
							<div class="trt-mono-block">
								{r.type.monoLines.map((ln) => (
									<div class="trt-mono-line">{ln}</div>
								))}
							</div>
						)}
					</div>
				</div>
			))
		}
	</div>
</Figure>

<style define:vars={{ VALUE_ACCENT, TYPE_ACCENT }}>
	.trt-root {
		display: grid;
		grid-template-columns: minmax(140px, max-content) 1fr 1fr;
		row-gap: 1px;
		padding: 16px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		margin: 0;
	}

	.trt-title {
		grid-column: 1 / -1;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3);
		text-align: center;
		padding-bottom: 12px;
		margin: 0;
	}

	.trt-row {
		display: contents;
	}

	.trt-key,
	.trt-cell {
		padding: 10px 12px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.trt-key {
		text-align: right;
		justify-content: flex-end;
		align-items: flex-end;
		font-weight: 600;
		color: var(--sl-color-gray-2);
		font-size: 12.5px;
		padding-right: 16px;
		border-right: 1px solid color-mix(in srgb, currentColor 18%, transparent);
	}

	.trt-mono-inline {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		color: var(--sl-color-text);
	}

	.trt-cell {
		gap: 4px;
	}

	.trt-value {
		background: color-mix(in srgb, var(--VALUE_ACCENT) 8%, transparent);
		border-left: 2px solid color-mix(in srgb, var(--VALUE_ACCENT) 55%, transparent);
	}

	.trt-type {
		background: color-mix(in srgb, var(--TYPE_ACCENT) 8%, transparent);
		border-left: 2px solid color-mix(in srgb, var(--TYPE_ACCENT) 55%, transparent);
	}

	.trt-head-cell {
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 11.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-text);
		flex-direction: row;
		align-items: center;
		justify-content: flex-start;
		gap: 8px;
		padding-top: 8px;
		padding-bottom: 8px;
		background: color-mix(in srgb, currentColor 4%, transparent);
	}

	.trt-row.trt-header .trt-value,
	.trt-row.trt-header .trt-type {
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.trt-row.trt-header .trt-value {
		border-left-color: color-mix(in srgb, var(--VALUE_ACCENT) 70%, transparent);
	}

	.trt-row.trt-header .trt-type {
		border-left-color: color-mix(in srgb, var(--TYPE_ACCENT) 70%, transparent);
	}

	.trt-dot {
		display: inline-block;
		width: 8px;
		height: 8px;
		border-radius: 999px;
		margin: 0;
	}

	.trt-dot-value {
		background: var(--VALUE_ACCENT);
	}

	.trt-dot-type {
		background: var(--TYPE_ACCENT);
	}

	.trt-prose {
		margin: 0;
	}

	.trt-mono-block {
		display: flex;
		flex-direction: column;
		gap: 2px;
		margin: 0;
	}

	.trt-mono-line {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		color: var(--sl-color-text);
		margin: 0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	@media (max-width: 640px) {
		.trt-root {
			grid-template-columns: 1fr;
		}
		.trt-key {
			text-align: left;
			justify-content: flex-start;
			align-items: flex-start;
			padding: 12px 12px 4px;
			border-right: none;
			border-top: 1px solid color-mix(in srgb, currentColor 18%, transparent);
		}
		.trt-row.trt-header .trt-key {
			display: none;
		}
		.trt-value,
		.trt-type {
			padding-left: 14px;
		}
	}
</style>
