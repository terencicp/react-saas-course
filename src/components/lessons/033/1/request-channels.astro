---
// request-channels — Chapter 033 Lesson 1, the lesson's opening mental-model
// figure. Makes "a route's only inputs are the URL, the headers, and the
// cookies — there is no hidden fourth channel" a picture the student can recall.
//
// Three small source boxes stacked on the LEFT (URL / Headers / Cookies), one
// Server Component target on the RIGHT, and three leader-line arrows converging
// left → right. The URL arrow is muted grey ("lessons ahead" — the URL channel
// is taught later in the chapter); the Headers and Cookies arrows are a blue
// accent ("this lesson"), so the figure both states the model and scopes the
// lesson to two of the three channels.
//
// The three arrows land on three stacked sub-anchors INSIDE the target box (per
// the ArrowDiagram "splitting an endpoint" guidance) so the arrowheads don't
// stack on a single contact point. This component renders the boxes + styles;
// the lesson wraps it in <Figure expandable={false}> (ArrowDiagram requirement).

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const MUTED = "#94a3b8"; // slate — the URL channel, taught in later lessons
const ACCENT = "#0ea5e9"; // sky blue — headers + cookies, this lesson

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — the same not-content / max-width / centered convention as
// this chapter's sibling figures, height-capped well under the 800px ceiling.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 640px",
  "margin-inline: auto",
].join("; ");

// Two-column stage: source column | gap | target. ~120px of gap so each curve
// and its label badge have room (three labels share this gap, Y-staggered).
const stage = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: max-content 1fr",
  "column-gap: 120px",
  "align-items: center",
].join("; ");

// Left column — the three channel boxes, evenly stacked.
const sourceCol = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 16px",
].join("; ");

// A source channel box. `tone` colours the border + a faint wash and the
// monospace label; the URL box is muted, the header/cookie boxes accented.
const sourceBox = (tone: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "min-width: 116px",
    "min-height: 40px",
    "padding: 8px 14px",
    "border-radius: 9px",
    `border: 1.5px solid color-mix(in srgb, ${tone} 60%, var(--sl-color-gray-4))`,
    `background: color-mix(in srgb, ${tone} 9%, var(--sl-color-gray-6))`,
  ].join("; ");

const sourceLabel = (tone: string) =>
  [
    reset,
    mono,
    "font-size: 13px",
    "font-weight: 600",
    "line-height: 1.2",
    `color: color-mix(in srgb, ${tone} 78%, var(--sl-color-text))`,
  ].join("; ");

// The single target box on the right. Stretches taller than the sources so the
// three sub-anchors inside it sit at clearly distinct heights.
const targetBox = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 8px",
  "width: max-content",
  "padding: 16px 18px",
  "border-radius: 12px",
  `border: 2px solid ${ACCENT}`,
  `background: color-mix(in srgb, ${ACCENT} 10%, var(--sl-color-gray-6))`,
  `box-shadow: 0 0 0 4px color-mix(in srgb, ${ACCENT} 12%, transparent)`,
].join("; ");

const targetTitle = [
  reset,
  sans,
  "font-size: 14px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-gray-1)",
].join("; ");

const targetSub = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 500",
  "line-height: 1.2",
  "color: var(--sl-color-gray-3)",
].join("; ");

// Three thin invisible landing rows inside the target box — one per channel —
// so each arrowhead lands at its own Y. They carry no visible chrome; they are
// pure anchor geometry stacked over the title/subtitle.
const targetRows = [
  reset,
  "box-sizing: border-box",
  "position: absolute",
  "inset: 0",
  "display: flex",
  "flex-direction: column",
  "pointer-events: none",
].join("; ");

const targetRow = [
  reset,
  "box-sizing: border-box",
  "flex: 1 1 0",
].join("; ");

const arrows = [
  // URL — muted grey, lands on the TOP sub-anchor. Taught in later lessons.
  {
    from: "ch-url",
    to: "ch-route-1",
    label: "lessons ahead",
    color: MUTED,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [90, 0],
    endSocketGravity: [-70, -10],
    labelOffset: [0, -20],
  },
  // Headers — blue accent, lands on the MIDDLE sub-anchor. This lesson.
  {
    from: "ch-headers",
    to: "ch-route-2",
    label: "this lesson",
    color: ACCENT,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [60, 0],
    endSocketGravity: [-60, 0],
    labelOffset: [0, -12],
  },
  // Cookies — blue accent, lands on the BOTTOM sub-anchor. This lesson.
  {
    from: "ch-cookies",
    to: "ch-route-3",
    label: "this lesson",
    color: ACCENT,
    startSocket: "right",
    endSocket: "left",
    startSocketGravity: [90, 0],
    endSocketGravity: [-70, 10],
    labelOffset: [0, 18],
  },
];
---

<div class="not-content rch" style={root}>
  <ArrowDiagram arrows={arrows}>
    <div style={stage}>
      {/* ---- LEFT — the three request channels -------------------------- */}
      <div style={sourceCol}>
        <div id="ch-url" style={sourceBox(MUTED)}>
          <span style={sourceLabel(MUTED)}>URL</span>
        </div>
        <div id="ch-headers" style={sourceBox(ACCENT)}>
          <span style={sourceLabel(ACCENT)}>Headers</span>
        </div>
        <div id="ch-cookies" style={sourceBox(ACCENT)}>
          <span style={sourceLabel(ACCENT)}>Cookies</span>
        </div>
      </div>

      {/* ---- RIGHT — the single Server Component target ---------------- */}
      <div style="position: relative; justify-self: start;">
        <div style={targetBox}>
          <span style={targetTitle}>Server Component</span>
          <span style={targetSub}>renders for this user</span>
        </div>
        {/* Three stacked landing zones split the arrowheads vertically. */}
        <div style={targetRows} aria-hidden="true">
          <span id="ch-route-1" style={targetRow}></span>
          <span id="ch-route-2" style={targetRow}></span>
          <span id="ch-route-3" style={targetRow}></span>
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>

<style>
  /* The two-column source → target geometry is the whole point of the figure,
     so don't collapse it. On narrow viewports let the stage scroll horizontally
     at a slimmer minimum width (laptop viewports — the design target — show it
     whole). */
  @media (max-width: 560px) {
    .rch {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .rch > div {
      min-width: 480px;
    }
  }
</style>
