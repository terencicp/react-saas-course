---
// StaticChromeDynamicTable (diagram id: static-chrome-dynamic-table, Chapter 033
// Lesson 4 — "URL state with searchParams and route params"). The spatial
// companion to ch 032's route-tree-dispositions: the SAME cached-chrome /
// dynamic-invoice-table split, drawn here not as a component tree but as a
// literal page-frame mock, so "lift the cached chrome outside the dynamic read"
// becomes a thing the student can SEE. Reinforces PPR from ch 032 without
// re-teaching it.
//
// Layout:
//   A page-frame mock laid out with CSS grid (header row across the top, a
//   sidebar rail down the left, the main content cell bottom-right):
//     - OUTER frame = the static shell. Tinted TEAL ("cached"), a fieldset-legend
//       pill on its top border reads "Static shell · cached, streams instantly".
//       Inside it a slim header bar (org nav · search · avatar) and a sidebar rail
//       (nav links), both TEAL — they're the same for every filter.
//     - INNER panel = the dynamic hole, nested in the main content cell. Tinted
//       AMBER ("dynamic, request-time"), labelled "Invoice table", with a
//       "reads searchParams" line and a faint sketch of table rows.
//   To the right, a `searchParams` token connects by a dashed AMBER arrow whose
//   tip lands ON the inner panel and nowhere else — the arrow visibly crosses the
//   shell's edge to reach only the dynamic hole. A small TEAL "no URL read here"
//   tag on the shell makes the negative space explicit.
//
// Colour convention is lifted VERBATIM from ch 032 (route-tree-dispositions /
// two-cache-layers) for cross-chapter continuity: TEAL = cached / static /
// "served from cache"; AMBER = dynamic / "rendered every request" / the dynamic
// hole. The searchParams arrow is AMBER because its destination is the dynamic
// node and it is "the most request-specific input there is".
//
// House style follows the ch 032 family: pinned `color-scheme: light` so the
// hand-picked tints survive dark mode, `margin: 0` on every inner element to
// defeat Starlight's injected prose margin-top, inline style strings only,
// box-sizing: border-box throughout. No leader lines, so the figure stays
// expandable. Wrapped in <Figure> per the diagram index.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// CACHED / static shell — teal (verbatim from ch 032).
const TEAL = '#0d9488'; // teal-600
const TEAL_BG = '#f0fdfa'; // teal-50 wash
const TEAL_EDGE = '#5eead4'; // teal-300
const TEAL_INK = '#0f766e'; // teal-700

// DYNAMIC hole — amber (verbatim from ch 032; "dynamic holes" colour).
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 wash
const AMBER_EDGE = '#fcd34d'; // amber-300
const AMBER_INK = '#b45309'; // amber-700

// ---- outer stage: page-frame | arrow + searchParams token -----------------
const stage = [
  'display: flex',
  'flex-wrap: wrap',
  'align-items: center',
  'justify-content: center',
  'column-gap: 0',
  'row-gap: 18px',
  'margin: 0',
  'padding: 2px',
  'color-scheme: light',
  `font-family: ${sans}`,
  `color: ${INK}`,
].join('; ');

// ---- the static shell (outer frame) ---------------------------------------
// A CSS grid: a header row spanning both columns, then a sidebar rail beside the
// main content cell. The shell is tinted teal; a fieldset-legend pill straddles
// its top border.
const shell = [
  'box-sizing: border-box',
  'position: relative',
  'flex: 1 1 420px',
  'min-width: 320px',
  'max-width: 560px',
  'display: grid',
  'grid-template-columns: 116px 1fr',
  'grid-template-rows: auto 1fr',
  'gap: 12px',
  'margin: 0',
  'padding: 30px 16px 16px',
  'border-radius: 16px',
  `border: 2px solid ${TEAL}`,
  `background: ${TEAL_BG}`,
].join('; ');

const shellPill = [
  'position: absolute',
  'top: 0',
  'left: 16px',
  'transform: translateY(-50%)',
  'display: block',
  'width: fit-content',
  'margin: 0',
  'padding: 4px 12px',
  'border-radius: 999px',
  `border: 1.5px solid ${TEAL}`,
  `background: ${TEAL_BG}`,
  `color: ${TEAL_INK}`,
  'font-size: 12px',
  'font-weight: 800',
  'line-height: 1.3',
  'white-space: nowrap',
  `box-shadow: 0 0 0 4px var(--sl-color-bg-sidebar, ${SURFACE})`,
].join('; ');

// header bar — spans both columns of the shell.
const header = [
  'box-sizing: border-box',
  'grid-column: 1 / -1',
  'display: flex',
  'align-items: center',
  'gap: 8px',
  'margin: 0',
  'padding: 8px 11px',
  'border-radius: 9px',
  `border: 1.5px solid ${TEAL_EDGE}`,
  `background: ${SURFACE}`,
].join('; ');
const headerDot = [
  'display: inline-block',
  'flex: 0 0 auto',
  'width: 9px',
  'height: 9px',
  'margin: 0',
  'border-radius: 50%',
  `background: ${TEAL}`,
].join('; ');
const headerLabel = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 11px',
  'font-weight: 800',
  'line-height: 1.2',
  `color: ${TEAL_INK}`,
  'white-space: nowrap',
].join('; ');
const headerFill = [
  'flex: 1 1 auto',
  'height: 8px',
  'margin: 0',
  'border-radius: 999px',
  `background: ${TEAL_EDGE}`,
].join('; ');
const avatar = [
  'flex: 0 0 auto',
  'width: 16px',
  'height: 16px',
  'margin: 0',
  'border-radius: 50%',
  `border: 1.5px solid ${TEAL}`,
  `background: ${TEAL_BG}`,
].join('; ');

// sidebar rail — left column, below the header.
const sidebar = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 7px',
  'margin: 0',
  'padding: 10px 9px',
  'border-radius: 9px',
  `border: 1.5px solid ${TEAL_EDGE}`,
  `background: ${SURFACE}`,
].join('; ');
const sidebarHead = [
  'margin: 0 0 1px',
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.04em',
  'line-height: 1.3',
  `color: ${TEAL_INK}`,
].join('; ');
const navRow = (w: string, active = false) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'gap: 6px',
    'margin: 0',
    'padding: 4px 7px',
    'border-radius: 6px',
    active ? `background: ${TEAL_BG}` : 'background: transparent',
    active ? `border: 1px solid ${TEAL_EDGE}` : '1px solid transparent',
  ].join('; ');
const navGlyph = [
  'display: inline-block',
  'flex: 0 0 auto',
  'width: 7px',
  'height: 7px',
  'margin: 0',
  'border-radius: 2px',
  `background: ${TEAL}`,
].join('; ');
const navBar = (w: string) =>
  [
    'height: 6px',
    `width: ${w}`,
    'margin: 0',
    'border-radius: 999px',
    `background: ${TEAL_EDGE}`,
  ].join('; ');

// main content cell — holds the dynamic hole.
const main = [
  'box-sizing: border-box',
  'display: flex',
  'margin: 0',
  'padding: 0',
  'min-width: 0',
].join('; ');

// ---- the dynamic hole (inner panel) ---------------------------------------
const hole = [
  'box-sizing: border-box',
  'position: relative',
  'flex: 1 1 auto',
  'display: flex',
  'flex-direction: column',
  'gap: 9px',
  'margin: 0',
  'padding: 26px 13px 13px',
  'border-radius: 12px',
  `border: 2px solid ${AMBER}`,
  `background: ${AMBER_BG}`,
  'min-width: 0',
].join('; ');
const holePill = [
  'position: absolute',
  'top: 0',
  'left: 12px',
  'transform: translateY(-50%)',
  'display: block',
  'width: fit-content',
  'margin: 0',
  'padding: 3px 10px',
  'border-radius: 999px',
  `background: ${AMBER}`,
  'color: #ffffff',
  'font-size: 11px',
  'font-weight: 800',
  'line-height: 1.3',
  'white-space: nowrap',
  `box-shadow: 0 0 0 3px ${AMBER_BG}`,
].join('; ');
const holeTag = [
  'display: inline-flex',
  'align-items: center',
  'align-self: flex-start',
  'gap: 6px',
  'margin: 0',
  'padding: 2px 9px',
  'border-radius: 999px',
  `border: 1px solid ${AMBER}`,
  `background: ${SURFACE}`,
  `color: ${AMBER_INK}`,
  `font-family: ${sans}`,
  'font-size: 9.5px',
  'font-weight: 800',
  'text-transform: uppercase',
  'letter-spacing: 0.03em',
  'line-height: 1.4',
  'white-space: nowrap',
].join('; ');
const holeReads = [
  'display: inline-flex',
  'align-items: center',
  'gap: 6px',
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 11px',
  'font-weight: 700',
  'line-height: 1.3',
  `color: ${AMBER_INK}`,
].join('; ');
const readsDot = [
  'display: inline-block',
  'flex: 0 0 auto',
  'width: 6px',
  'height: 6px',
  'margin: 0',
  'border-radius: 50%',
  `background: ${AMBER}`,
].join('; ');
// faint sketch of table rows inside the dynamic hole.
const tableSketch = [
  'display: flex',
  'flex-direction: column',
  'gap: 5px',
  'margin: 1px 0 0',
].join('; ');
const tableRow = (w: string) =>
  [
    'box-sizing: border-box',
    'display: flex',
    'align-items: center',
    'gap: 7px',
    'margin: 0',
    'padding: 5px 8px',
    'border-radius: 6px',
    `border: 1px solid ${AMBER_EDGE}`,
    `background: ${SURFACE}`,
  ].join('; ');
const cellPill = [
  'flex: 0 0 auto',
  'width: 38px',
  'height: 7px',
  'margin: 0',
  'border-radius: 999px',
  `background: ${AMBER_EDGE}`,
].join('; ');
const cellFill = (w: string) =>
  [
    'height: 7px',
    `width: ${w}`,
    'margin: 0',
    'border-radius: 999px',
    `background: ${AMBER_EDGE}`,
  ].join('; ');

// ---- the searchParams input: arrow + token --------------------------------
// A vertical group sitting to the right of the frame. A dashed amber arrow points
// LEFT, its tip aimed at the dynamic hole; the token below names the input.
const inputGroup = [
  'box-sizing: border-box',
  'flex: 0 0 auto',
  'display: flex',
  'flex-direction: column',
  'align-items: stretch',
  'gap: 8px',
  'width: 168px',
].join('; ');
// the arrow row spans the full group width; the head sits at the far-left edge
// (nearest the frame) so it always points at the hole, at any card width. A
// negative left margin bridges the shell's fixed right padding so the head
// crosses the shell edge and lands on the dynamic hole; the token below stays
// clear in the gutter. The header+gap above the hole is a fixed offset, so the
// downward nudge that centres the arrow on the hole body is width-robust.
const arrowWrap = [
  'display: flex',
  'align-items: center',
  'gap: 0',
  'margin: 46px 0 0 -22px',
  'width: calc(100% + 22px)',
].join('; ');
const arrowHead = [
  'flex: 0 0 auto',
  'margin: 0',
  `color: ${AMBER}`,
  'font-size: 22px',
  'font-weight: 900',
  'line-height: 1',
].join('; ');
const arrowShaft = [
  'display: block',
  'flex: 1 1 auto',
  'height: 0',
  'margin: 0',
  `border-top: 2.5px dashed ${AMBER}`,
].join('; ');
const token = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'gap: 3px',
  'margin: 0',
  'padding: 9px 13px',
  'border-radius: 11px',
  `border: 2px solid ${AMBER}`,
  `background: ${SURFACE}`,
].join('; ');
const tokenCode = [
  'margin: 0',
  `font-family: ${mono}`,
  'font-size: 13.5px',
  'font-weight: 800',
  'line-height: 1.2',
  `color: ${AMBER_INK}`,
  'white-space: nowrap',
].join('; ');
const tokenSub = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 10px',
  'font-weight: 600',
  'line-height: 1.3',
  'text-align: center',
  `color: ${INK_SOFT}`,
].join('; ');

// ---- legend ----------------------------------------------------------------
const legend = [
  'box-sizing: border-box',
  'flex-basis: 100%',
  'display: flex',
  'flex-wrap: wrap',
  'justify-content: center',
  'align-items: center',
  'column-gap: 20px',
  'row-gap: 8px',
  'margin: 4px 0 0',
  'padding: 0',
].join('; ');
const legendItem = [
  'display: inline-flex',
  'align-items: center',
  'gap: 7px',
  'margin: 0',
].join('; ');
const legendSwatch = (bg: string, edge: string) =>
  [
    'display: inline-block',
    'flex: 0 0 auto',
    'width: 15px',
    'height: 15px',
    'margin: 0',
    'border-radius: 5px',
    `background: ${bg}`,
    `border: 1.5px solid ${edge}`,
  ].join('; ');
const legendText = [
  'margin: 0',
  `font-family: ${sans}`,
  'font-size: 12px',
  'font-weight: 600',
  'line-height: 1.3',
  `color: ${INK}`,
].join('; ');
const legendStrong = (c: string) => `color: ${c}; font-weight: 800;`;
---

<Figure caption="Cache the shell. Read the URL only where the data is dynamic.">
  <div style={stage}>
    {/* ============ the static shell ============ */}
    <div style={shell}>
      <span style={shellPill}>Static shell &middot; cached, streams instantly</span>

      {/* header bar — spans both columns */}
      <div style={header}>
        <span style={headerDot} aria-hidden="true"></span>
        <span style={headerLabel}>org nav</span>
        <span style={headerFill} aria-hidden="true"></span>
        <span style={avatar} aria-hidden="true"></span>
      </div>

      {/* sidebar rail */}
      <div style={sidebar}>
        <p style={sidebarHead}>sidebar</p>
        <span style={navRow('70%', true)}>
          <span style={navGlyph} aria-hidden="true"></span>
          <span style={navBar('64px')} aria-hidden="true"></span>
        </span>
        <span style={navRow('55%')}>
          <span style={navGlyph} aria-hidden="true"></span>
          <span style={navBar('48px')} aria-hidden="true"></span>
        </span>
        <span style={navRow('62%')}>
          <span style={navGlyph} aria-hidden="true"></span>
          <span style={navBar('56px')} aria-hidden="true"></span>
        </span>
      </div>

      {/* main content cell — the dynamic hole lives here */}
      <div style={main}>
        <div style={hole} data-hole>
          <span style={holePill}>Invoice table &middot; dynamic, request-time</span>
          <span style={holeReads}>
            <span style={readsDot} aria-hidden="true"></span>
            reads searchParams
          </span>
          <div style={tableSketch} aria-hidden="true">
            <span style={tableRow('80%')}>
              <span style={cellPill}></span><span style={cellFill('70%')}></span>
            </span>
            <span style={tableRow('80%')}>
              <span style={cellPill}></span><span style={cellFill('55%')}></span>
            </span>
            <span style={tableRow('80%')}>
              <span style={cellPill}></span><span style={cellFill('62%')}></span>
            </span>
          </div>
        </div>
      </div>
    </div>

    {/* ============ the searchParams input ============ */}
    <div style={inputGroup} data-input>
      <div style={arrowWrap} aria-hidden="true">
        <span style={arrowHead}>&larr;</span>
        <span style={arrowShaft}></span>
      </div>
      <div style={token}>
        <p style={tokenCode}>searchParams</p>
        <p style={tokenSub}>flows into the dynamic hole only</p>
      </div>
    </div>

    {/* ============ legend ============ */}
    <div style={legend}>
      <span style={legendItem}>
        <span style={legendSwatch(TEAL_BG, TEAL)} aria-hidden="true"></span>
        <span style={legendText}>
          <span style={legendStrong(TEAL_INK)}>Cached shell</span> &mdash; same for every filter, served from cache
        </span>
      </span>
      <span style={legendItem}>
        <span style={legendSwatch(AMBER_BG, AMBER)} aria-hidden="true"></span>
        <span style={legendText}>
          <span style={legendStrong(AMBER_INK)}>Dynamic hole</span> &mdash; reads the URL, runs every request
        </span>
      </span>
    </div>
  </div>
</Figure>
