---
// UrlAnatomy — Chapter 033 Lesson 4 ("URL state with searchParams and route
// params"). Dissects one real URL into its two information-carrying zones so the
// params / searchParams split is visual before any syntax.
//
// URL dissected:
//   /orgs/acme/invoices?status=paid&sort=-date&cursor=eyJpZCI6NDJ9
//
// Layout (top → bottom), one shared coordinate system per zone:
//   1. Two zone caps — "params · identity" over the path, "searchParams · view
//      state" over the query — each a tab sitting on the top border of its zone.
//   2. The URL itself on one monospace line: a BLUE path group and an ORANGE
//      query group, contiguous so the strip still reads as a single URL. The
//      `acme` segment is emphasised inside the path (the [org] dynamic segment);
//      `?` and `&` are tinted as the query's structural punctuation.
//   3. Per-zone readouts beneath each group: the resolved object each zone maps
//      to, monospace, tinted to its zone — params.org === 'acme' on the left,
//      the searchParams object on the right.
//   4. A thin punctuation legend under the query: ? begins the query, & separates
//      each key=value pair.
//
// Pure HTML + CSS, inline styles only. `margin: 0` reset on every inner element
// to defeat Starlight's prose-margin selector. BLUE (#2563eb) for the path keeps
// continuity with this chapter's worked-example thread; ORANGE (#ea580c) for the
// query is a distinct warm hue not used by the lesson-1 anatomy strip. The figure
// has no leader lines, so it stays expandable.

const PATH = "#2563eb"; // blue-600 — the path / params zone (worked-example thread)
const QUERY = "#ea580c"; // orange-600 — the query string / searchParams zone

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Outer container — centered, height-capped well under the 800px ceiling, and
// fluid so it scales with the figure card.
const root = [
  reset,
  sans,
  "box-sizing: border-box",
  "width: 100%",
  "max-width: 720px",
  "margin-inline: auto",
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 22px",
].join("; ");

// The two-zone row: path group | query group, sharing one baseline so the URL
// reads continuously. Wraps on narrow viewports so neither group is clipped.
const urlRow = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "gap: 14px",
].join("; ");

// A zone = a tinted, bordered panel with a "legend" tab on its top border. The
// tab names the prop; the panel body carries that zone's slice of the URL and,
// under a hairline divider, the object it maps to.
const zone = (tone: string) =>
  [
    reset,
    "box-sizing: border-box",
    "position: relative",
    "display: flex",
    "flex-direction: column",
    "gap: 10px",
    "padding: 18px 16px 14px",
    "border-radius: 12px",
    `border: 2px solid ${tone}`,
    `background: color-mix(in srgb, ${tone} 8%, var(--sl-color-gray-6))`,
  ].join("; ");

// The legend tab straddling the zone's top border. display:block + fit-content
// + negative margin-top centres it on the border line (per the html-css doc's
// fieldset-legend pattern); its background matches the Figure card so it visually
// breaks the border.
const cap = (tone: string) =>
  [
    reset,
    sans,
    "display: block",
    "width: fit-content",
    "margin: -28px 0 0 12px",
    "padding: 3px 10px",
    "border-radius: 999px",
    "background: var(--sl-color-bg-sidebar)",
    `border: 1.5px solid ${tone}`,
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.02em",
    "line-height: 1.3",
    "white-space: nowrap",
    `color: color-mix(in srgb, ${tone} 78%, var(--sl-color-text))`,
  ].join("; ");

// `params` / `searchParams` rendered in monospace inside the otherwise-sans cap.
const capCode = [
  reset,
  mono,
  "font-weight: 700",
].join("; ");

const capRole = (tone: string) =>
  [
    reset,
    sans,
    "font-weight: 600",
    `color: color-mix(in srgb, ${tone} 55%, var(--sl-color-gray-2))`,
  ].join("; ");

// The URL slice — one monospace line, the whole point of the figure.
const urlLine = (tone: string) =>
  [
    reset,
    mono,
    "font-size: clamp(14px, 2.4vw, 17px)",
    "font-weight: 600",
    "line-height: 1.1",
    "white-space: nowrap",
    `color: color-mix(in srgb, ${tone} 82%, var(--sl-color-text))`,
  ].join("; ");

// The emphasised dynamic segment (`acme`) inside the path: a filled chip.
const dynSeg = [
  reset,
  mono,
  "font-weight: 700",
  "padding: 1px 5px",
  "border-radius: 5px",
  "color: #ffffff",
  `background: ${PATH}`,
].join("; ");

// The query's structural punctuation (? and &) — filled chips in the query tone,
// so the eye reads them as the separators the callout legend explains.
const punct = [
  reset,
  mono,
  "font-weight: 700",
  "padding: 1px 5px",
  "border-radius: 5px",
  "color: #ffffff",
  `background: ${QUERY}`,
].join("; ");

// Hairline divider between the URL slice and its readout.
const divider = (tone: string) =>
  [
    reset,
    "height: 0",
    "border: none",
    `border-top: 1px dashed color-mix(in srgb, ${tone} 45%, transparent)`,
  ].join("; ");

// The "maps to" readout under each zone.
const mapsTo = (tone: string) =>
  [
    reset,
    mono,
    "font-size: 13px",
    "font-weight: 600",
    "line-height: 1.45",
    "white-space: normal",
    "overflow-wrap: anywhere",
    `color: color-mix(in srgb, ${tone} 70%, var(--sl-color-text))`,
  ].join("; ");

// Punctuation legend under the query zone: two tiny notes, each a tinted chip +
// its one-line meaning.
const legend = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "flex-wrap: wrap",
  "justify-content: center",
  "gap: 10px 22px",
].join("; ");

const legendItem = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "gap: 8px",
].join("; ");

const legendChip = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1",
  "padding: 4px 8px",
  "border-radius: 6px",
  "color: #ffffff",
  `background: ${QUERY}`,
].join("; ");

const legendText = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 500",
  "line-height: 1.3",
  "color: var(--sl-color-gray-2)",
].join("; ");
---

<div class="not-content url-anatomy" style={root}>
  {/* ---- the two zones, sharing the URL's baseline -------------------- */}
  <div style={urlRow}>
    {/* PATH — params, identity */}
    <div style={zone(PATH)}>
      <span style={cap(PATH)}>
        <span style={capCode}>params</span>
        <span style={capRole(PATH)}>&nbsp;·&nbsp;identity</span>
      </span>
      <span style={urlLine(PATH)}>
        /orgs/<span style={dynSeg}>acme</span>/invoices
      </span>
      <hr style={divider(PATH)} />
      <span style={mapsTo(PATH)}>
        the <span style={dynSeg}>[org]</span> dynamic segment →{" "}
        {"params.org === 'acme'"}
      </span>
    </div>

    {/* QUERY — searchParams, view state */}
    <div style={zone(QUERY)}>
      <span style={cap(QUERY)}>
        <span style={capCode}>searchParams</span>
        <span style={capRole(QUERY)}>&nbsp;·&nbsp;view state</span>
      </span>
      <span style={urlLine(QUERY)}>
        <span style={punct}>?</span>status=paid<span style={punct}>&amp;</span
        >sort=-date<span style={punct}>&amp;</span>cursor=eyJpZCI6NDJ9
      </span>
      <hr style={divider(QUERY)} />
      <span style={mapsTo(QUERY)}>
        reads as {"{ status: 'paid', sort: '-date', cursor: 'eyJpZCI6NDJ9' }"}
      </span>
    </div>
  </div>

  {/* ---- punctuation legend, scoped to the query zone ----------------- */}
  <div style={legend}>
    <span style={legendItem}>
      <span style={legendChip}>?</span>
      <span style={legendText}>begins the query string</span>
    </span>
    <span style={legendItem}>
      <span style={legendChip}>&amp;</span>
      <span style={legendText}>separates each <code style={`${mono}; background: transparent; padding: 0; font-weight: 600;`}>key=value</code> pair</span>
    </span>
  </div>
</div>
