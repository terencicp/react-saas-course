---
// denormalized-invoices-table (diagram id: denormalized-invoices-table,
// Chapter 036 Lesson 1 — "Tables, rows, and 3NF"). The anti-pattern table: one
// `invoices` table that crams facts about *other things* onto every row. Its job
// is to make duplication viscerally obvious — the same organization name and
// billing email are stored once PER INVOICE, so a single fact about Acme sits on
// the table four times, ready to drift out of sync (the update anomaly the prose
// then names).
//
// Layout — a real HTML <table> matching the house style of this lesson's
// OrganizationsTable (border-collapse, inline style strings, Starlight theme
// vars, `margin: 0` resets to defeat Starlight's injected prose margins, flips
// clean light/dark). Six columns: id, number, organization_name,
// organization_email, tags, total. Four rows where Acme repeats three times.
//
// The teaching move is the highlight: the duplicated `organization_name` and
// `organization_email` cells (the three Acme rows) get an amber/caution tint and
// a left accent rule, so the eye lands on the same fact stored four times. Amber
// (--sl-color-orange) reads as "duplication smell" here; saturated red is held
// back for the actual normal-form *violations* highlighted in the later
// AnnotatedCode walkthrough, so the two visuals stay distinct. The `tags` cells
// are monospace to read as the packed-string blob they are.

import Figure from '../../../figures/Figure.astro';

const mono =
	'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const columns = ['id', 'number', 'organization_name', 'organization_email', 'tags', 'total'];

// `dupOrg` marks the cells holding the repeated Acme fact — those get the tint.
const rows = [
	{
		id: 'a1f3…',
		number: 'INV-001',
		org: 'Acme Inc.',
		email: 'billing@acme.example',
		tags: 'urgent,paid',
		total: '1200.00',
		dupOrg: true,
	},
	{
		id: 'b7c2…',
		number: 'INV-002',
		org: 'Acme Inc.',
		email: 'billing@acme.example',
		tags: 'paid',
		total: '340.00',
		dupOrg: true,
	},
	{
		id: 'c9d4…',
		number: 'INV-003',
		org: 'Acme Inc.',
		email: 'billing@acme.example',
		tags: 'q3,paid',
		total: '980.00',
		dupOrg: true,
	},
	{
		id: 'd5e6…',
		number: 'INV-004',
		org: 'Globex',
		email: 'ap@globex.example',
		tags: 'urgent',
		total: '5600.00',
		dupOrg: false,
	},
];

// --- Header cell ---
const thStyle = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.55rem 0.85rem',
	'text-align: left',
	'vertical-align: bottom',
	'border-bottom: 2px solid var(--sl-color-hairline)',
	'background: var(--sl-color-bg)',
	mono,
	'font-size: 0.875rem',
	'font-weight: 600',
	'color: var(--sl-color-white)',
	'white-space: nowrap',
].join('; ');

// The two crammed-in columns get an amber header label so the source of the
// smell is named up top, not only down in the body.
const thDup = [thStyle, 'color: var(--sl-color-orange, #b45309)'].join('; ');

// --- Body cells ---
const tdBase = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.5rem 0.85rem',
	'text-align: left',
	'font-size: 0.875rem',
	'color: var(--sl-color-text)',
	'white-space: nowrap',
];

const border = (isLast: boolean) =>
	isLast ? 'border-bottom: 0' : 'border-bottom: 1px solid var(--sl-color-hairline)';

const tdData = (isLast: boolean) => [...tdBase, border(isLast)].join('; ');

// id cells are opaque keys → monospace, dimmed.
const tdId = (isLast: boolean) =>
	[...tdBase, border(isLast), mono, 'color: var(--sl-color-gray-2)'].join('; ');

// tags cells are a packed string → monospace, to read as the blob they are.
const tdTags = (isLast: boolean) =>
	[...tdBase, border(isLast), mono, 'color: var(--sl-color-gray-2)'].join('; ');

// total cells are numeric → monospace, right-aligned.
const tdTotal = (isLast: boolean) =>
	[
		...tdBase.filter((s) => s !== 'text-align: left'),
		'text-align: right',
		border(isLast),
		mono,
	].join('; ');

// The highlighted duplicate cell: amber tint + left accent rule. `mid` keeps the
// vertical accent unbroken across the three stacked Acme rows so they read as one
// repeated block, not three unrelated cells.
const tdDup = (isLast: boolean, mid: boolean) =>
	[
		...tdBase,
		border(isLast),
		'font-weight: 600',
		'color: var(--sl-color-orange, #b45309)',
		'background: color-mix(in srgb, var(--sl-color-orange, #f59e0b) 14%, transparent)',
		'border-left: 3px solid var(--sl-color-orange, #f59e0b)',
		mid ? 'border-top: 1px solid color-mix(in srgb, var(--sl-color-orange, #f59e0b) 25%, transparent)' : '',
	]
		.filter(Boolean)
		.join('; ');
---

<Figure>
	<div style="display: flex; justify-content: center; margin: 0; overflow-x: auto;">
		<table
			style="border-collapse: collapse; margin: 0; background: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); border-radius: 7px; overflow: hidden;"
		>
			<thead>
				<tr style="margin: 0;">
					{
						columns.map((col) => (
							<th
								scope="col"
								style={col === 'organization_name' || col === 'organization_email' ? thDup : thStyle}
							>
								{col}
							</th>
						))
					}
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row, i) => {
						const isLast = i === rows.length - 1;
						// A duplicate cell is "mid" when the row above also duplicates,
						// so the amber accent runs unbroken down the Acme block.
						const prevDup = i > 0 && rows[i - 1].dupOrg;
						const mid = row.dupOrg && prevDup;
						return (
							<tr style="margin: 0;">
								<td style={tdId(isLast)}>{row.id}</td>
								<td style={tdData(isLast)}>{row.number}</td>
								<td style={row.dupOrg ? tdDup(isLast, mid) : tdData(isLast)}>{row.org}</td>
								<td style={row.dupOrg ? tdDup(isLast, mid) : tdData(isLast)}>{row.email}</td>
								<td style={tdTags(isLast)}>{row.tags}</td>
								<td style={tdTotal(isLast)}>{row.total}</td>
							</tr>
						);
					})
				}
			</tbody>
		</table>
	</div>
	<Fragment slot="caption">
		One <code>invoices</code> table that crams in facts about other things. Acme's
		name and billing email (highlighted) are stored once <em>per invoice</em> — the
		same fact, four times over. This is the design to avoid.
	</Fragment>
</Figure>
