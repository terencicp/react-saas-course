---
// organizations-table-figure (diagram id: organizations-table-figure,
// Chapter 036 Lesson 1 — "Tables, rows, and 3NF"). The first concrete picture
// in the lesson: a literal `organizations` table, rendered as a real HTML
// <table> so a reader can open devtools and see an actual table element. Its
// only job is to make "a table is a set of rows; a row is a set of typed
// columns" literal before any SQL or ER notation appears.
//
// Layout — a single <table> with one <thead> row and three <tbody> rows:
//   HEADER cell  = the column NAME (prominent) stacked above its TYPE, where the
//                  type is rendered as a muted monospace pill. Stacking the type
//                  under the name is the load-bearing move: it shows that "every
//                  column declares a type" as a visual fact, and the muted
//                  monospace styling reads the type as metadata, distinct from
//                  the data values below.
//   BODY cells   = the actual values. The `id` column holds opaque UUIDs, so
//                  those cells are monospace (they read as keys, not prose); the
//                  `name` and `billing_email` cells are plain sans data.
//
// House style follows ch 001/4 ThreeCountsTable: a real <table> with
// border-collapse, inline style strings only (no <style> tag), box-sizing:
// border-box, `margin: 0` resets on every element to defeat Starlight's
// injected prose margin-top, and Starlight theme variables so it flips cleanly
// between light and dark. No leader lines, so the Figure stays expandable.

import Figure from '../../../figures/Figure.astro';

const mono =
	'font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const columns = [
	{ name: 'id', type: 'uuid' },
	{ name: 'name', type: 'text' },
	{ name: 'billing_email', type: 'text' },
];

// Each row's three values, parallel to `columns` above.
const rows = [
	{ id: 'a1f3…', name: 'Acme Inc.', email: 'billing@acme.example' },
	{ id: 'b7c2…', name: 'Globex', email: 'ap@globex.example' },
	{ id: 'c9d4…', name: 'Initech', email: 'finance@initech.example' },
];

// --- Header cell: column name stacked over its type pill ---
const thStyle = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.55rem 0.85rem',
	'text-align: left',
	'vertical-align: bottom',
	'border-bottom: 2px solid var(--sl-color-hairline)',
	'background: var(--sl-color-bg)',
].join('; ');

const colNameStyle = [
	'margin: 0',
	mono,
	'font-size: 0.9375rem',
	'font-weight: 600',
	'color: var(--sl-color-white)',
	'white-space: nowrap',
].join('; ');

// The type, set apart as muted monospace metadata under the column name.
const typePillStyle = [
	'margin: 0.3rem 0 0',
	'display: inline-block',
	mono,
	'font-size: 0.75rem',
	'font-weight: 400',
	'color: var(--sl-color-gray-3)',
	'background: var(--sl-color-gray-6)',
	'border: 1px solid var(--sl-color-gray-5)',
	'border-radius: 4px',
	'padding: 0.05rem 0.4rem',
	'white-space: nowrap',
].join('; ');

// --- Body cells ---
const tdBase = [
	'margin: 0',
	'box-sizing: border-box',
	'padding: 0.5rem 0.85rem',
	'text-align: left',
	'font-size: 0.875rem',
	'color: var(--sl-color-text)',
	'white-space: nowrap',
];

const tdData = (isLast: boolean) =>
	[...tdBase, isLast ? 'border-bottom: 0' : 'border-bottom: 1px solid var(--sl-color-hairline)'].join(
		'; ',
	);

// The id cells are opaque keys — monospace so they read as identifiers.
const tdId = (isLast: boolean) => `${tdData(isLast)}; ${mono}; color: var(--sl-color-gray-2)`;
---

<Figure>
	<div style="display: flex; justify-content: center; margin: 0;">
		<table
			style="border-collapse: collapse; margin: 0; background: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); border-radius: 7px; overflow: hidden;"
		>
			<thead>
				<tr style="margin: 0;">
					{
						columns.map((col) => (
							<th scope="col" style={thStyle}>
								<div style={colNameStyle}>{col.name}</div>
								<span style={typePillStyle}>{col.type}</span>
							</th>
						))
					}
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row, i) => {
						const isLast = i === rows.length - 1;
						return (
							<tr style="margin: 0;">
								<td style={tdId(isLast)}>{row.id}</td>
								<td style={tdData(isLast)}>{row.name}</td>
								<td style={tdData(isLast)}>{row.email}</td>
							</tr>
						);
					})
				}
			</tbody>
		</table>
	</div>
	<Fragment slot="caption">
		An <code>organizations</code> table: a header row naming each column and its
		type, then the rows themselves.
	</Fragment>
</Figure>
