---
// production-topology — the synthesis recap of Lesson 036.3.
//
// One glanceable picture of the whole environment: everything the lesson built,
// pulled into the shape a student should be able to read off a real Neon
// project. Deliberately reuses the established vocabulary (project / production
// / staging / preview) and the same colour language as the lesson's other three
// figures, so it reads as a summary, not new material.
//
// Shape: a small horizontal tree inside one "Neon project" container.
//   LEFT   the two SOLID long-lived branches, stacked:
//            - production (teal "primary") — annotated "DATABASE_URL points here
//              · kept warm". This is the branch the warm-vs-cold knob protects.
//            - staging (gray "long-lived").
//   RIGHT  off production, a DASHED, lighter cluster of ephemeral preview
//          branches — a labelled front card `preview/*` with two faint ghost
//          cards offset behind it to read as "a fan of many", annotated
//          "one per PR · created & destroyed automatically · scale to zero".
//   A branch connector runs from production rightward into the preview fan.
//   The whole project sits on a shared-storage base strip — the copy-on-write
//   callback that ties branching, scale-to-zero, and this recap together.
//
// The single glance to land: two solid long-lived branches + a fan of dashed
// disposable ones, all under one project.
//
// Pure HTML + CSS, scoped <style>. `not-content` wrapper + a `margin: 0` reset
// on every inner element defeat Starlight's prose-margin selector. Starlight
// theme variables (plus the lesson's teal #0d9488 for production) keep it native
// in light and dark. Horizontal and capped-height per the vertical-space
// constraint; companion in style to StorageComputeSplit, PointInTimeTimeline,
// and PrPreviewLifecycle.

import Figure from "../../../figures/Figure.astro";
---

<Figure
  caption="One project: two long-lived branches (production kept warm, staging), and a fan of ephemeral preview branches that the integration creates and destroys per pull request."
>
  <div class="pt not-content">
    <div class="pt-project">
      <span class="pt-project-name">Neon project</span>

      <div class="pt-tree">
        {/* LEFT — the two solid, long-lived branches */}
        <div class="pt-longlived">
          <div class="pt-branch pt-branch--prod">
            <span class="pt-branch-name">production</span>
            <span class="pt-branch-tag pt-branch-tag--prod">primary</span>
            <span class="pt-branch-note">
              <code>DATABASE_URL</code> points here · kept warm
            </span>
          </div>

          <div class="pt-branch pt-branch--staging">
            <span class="pt-branch-name">staging</span>
            <span class="pt-branch-tag">long-lived</span>
          </div>
        </div>

        {/* CONNECTOR — branches off production into the ephemeral fan */}
        <div class="pt-connector" aria-hidden="true">
          <span class="pt-connector-line"></span>
          <span class="pt-connector-label">branches off</span>
        </div>

        {/* RIGHT — the dashed fan of ephemeral preview branches */}
        <div class="pt-fan">
          <span class="pt-fan-ghost pt-fan-ghost--back" aria-hidden="true"></span>
          <span class="pt-fan-ghost pt-fan-ghost--mid" aria-hidden="true"></span>
          <div class="pt-branch pt-branch--preview">
            <span class="pt-branch-name">preview/*</span>
            <span class="pt-branch-tag pt-branch-tag--preview">ephemeral</span>
            <span class="pt-branch-note">
              one per PR · created &amp; destroyed automatically · scale to zero
            </span>
          </div>
        </div>
      </div>

      <div class="pt-storage">shared storage · page log</div>
    </div>
  </div>
</Figure>

<style>
  .pt {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ── The project container that wraps everything ───────────────────────── */

  .pt-project {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px 14px 12px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-4) 18%, var(--sl-color-bg));
    box-sizing: border-box;
    margin: 0;
  }

  .pt-project-name {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  /* ── The horizontal tree: long-lived pair → connector → ephemeral fan ──── */

  .pt-tree {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    margin: 0;
  }

  .pt-longlived {
    flex: 1 1 250px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
    margin: 0;
  }

  /* ── Branch boxes (shared base) ────────────────────────────────────────── */

  .pt-branch {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 12px;
    border-radius: 9px;
    box-sizing: border-box;
    margin: 0;
  }

  .pt-branch-name {
    font-size: 13.5px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
  }

  .pt-branch-tag {
    align-self: flex-start;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1px 6px;
    border-radius: 999px;
    color: var(--sl-color-gray-1);
    background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    border: 1px solid var(--sl-color-hairline);
    margin: 1px 0 0;
  }

  .pt-branch-note {
    font-size: 10.5px;
    line-height: 1.3;
    color: var(--sl-color-gray-2);
    margin: 4px 0 0;
  }

  /* Inline code in the note reads as plain mono — drop the prose pill so it
     doesn't break the line or balloon the box. */
  .pt-branch-note code {
    background: transparent;
    padding: 0;
    font-size: 10px;
    color: var(--sl-color-text);
  }

  /* production: solid, heavy, teal — the accent that marks it across this
     lesson's figures. */
  .pt-branch--prod {
    border: 2px solid color-mix(in srgb, #0d9488 65%, transparent);
    background: color-mix(in srgb, #0d9488 14%, transparent);
  }

  .pt-branch--prod .pt-branch-name {
    color: color-mix(in srgb, #0d9488 60%, var(--sl-color-white));
  }

  .pt-branch-tag--prod {
    color: color-mix(in srgb, #0d9488 70%, var(--sl-color-white));
    background: color-mix(in srgb, #0d9488 16%, transparent);
    border-color: color-mix(in srgb, #0d9488 45%, transparent);
  }

  /* staging: solid, grounded, gray. */
  .pt-branch--staging {
    border: 1.5px solid var(--sl-color-gray-3);
    background: color-mix(in srgb, var(--sl-color-gray-4) 35%, transparent);
  }

  .pt-branch--staging .pt-branch-name {
    color: var(--sl-color-white);
  }

  /* ── Connector from production into the fan ────────────────────────────── */

  .pt-connector {
    position: relative;
    flex: 0 0 88px;
    align-self: center;
    height: 2px;
    margin: 0;
  }

  .pt-connector-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    transform: translateY(-50%);
    background: color-mix(in srgb, var(--sl-color-text-accent) 55%, transparent);
    margin: 0;
  }

  /* Arrowhead at the fan end. */
  .pt-connector-line::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -1px;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid color-mix(in srgb, var(--sl-color-text-accent) 55%, transparent);
  }

  .pt-connector-label {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    margin: 0 0 4px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--sl-color-text-accent);
  }

  /* ── The ephemeral preview fan ─────────────────────────────────────────── */

  .pt-fan {
    position: relative;
    flex: 1 1 230px;
    min-width: 0;
    /* Room above/right for the offset ghost cards. */
    padding: 8px 8px 0 0;
    margin: 0;
  }

  /* Two faint dashed cards offset behind the labelled one, so the single front
     card reads as "one of many". */
  .pt-fan-ghost {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    border-radius: 9px;
    border: 1.5px dashed
      color-mix(in srgb, var(--sl-color-text-accent) 35%, var(--sl-color-gray-4));
    background: color-mix(in srgb, var(--sl-color-text-accent) 4%, transparent);
    margin: 0;
  }

  .pt-fan-ghost--back {
    transform: translate(14px, -14px);
    opacity: 0.45;
  }

  .pt-fan-ghost--mid {
    transform: translate(7px, -7px);
    opacity: 0.7;
  }

  /* The labelled front preview branch: dashed accent = "disposable". */
  .pt-branch--preview {
    position: relative;
    border: 1.5px dashed
      color-mix(in srgb, var(--sl-color-text-accent) 60%, var(--sl-color-gray-4));
    background: color-mix(in srgb, var(--sl-color-text-accent) 9%, var(--sl-color-bg));
  }

  .pt-branch--preview .pt-branch-name {
    color: var(--sl-color-text-accent);
  }

  .pt-branch-tag--preview {
    color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-text-accent) 40%, transparent);
  }

  /* ── Shared-storage base ───────────────────────────────────────────────── */

  .pt-storage {
    text-align: center;
    padding: 6px 8px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-2) 35%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* ── Narrow viewports: stack the fan under the long-lived pair ──────────── */
  @media (max-width: 640px) {
    .pt-tree {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }
    .pt-longlived {
      flex: none;
    }
    /* A horizontal connector doesn't map to a stacked layout; drop it and let
       the "branches off" relationship ride on the shared "ephemeral" framing. */
    .pt-connector {
      display: none;
    }
    .pt-fan {
      flex: none;
      /* Ghost cards offset up/right would overflow the card edge once stacked;
         keep a touch of right room, the front card carries the label. */
      padding: 10px 14px 0 0;
    }
  }
</style>
