---
// pr-preview-lifecycle — the centerpiece diagram of Lesson 036.3, rendered one
// frame at a time inside <DiagramSequence>. Walks a single pull request from
// "opened" to "merged → branch deleted", making the branch-per-preview pattern
// a felt sequence rather than a recited feature.
//
// `step` (1..5) selects the frame; the same persistent stage renders every
// time so DiagramSequence sizes to the tallest step and never reflows as the
// reader scrubs. The "new/active" element of each step carries an amber glow.
//
// Layout, left → right (CI/Git on the left, the database on the right):
//   LEFT  a stacked pair of branded actor boxes — a GitHub "Pull request" box
//         over a Vercel "Preview deployment" box. Their captions change per
//         step; the Vercel box is a reserved ghost until step 3.
//   RIGHT a "Neon project" zone holding the two long-lived branch boxes
//         (`production` kept warm, `staging`) plus the ephemeral
//         `preview/feature-x` branch, all sitting on a shared-storage base.
//         The preview branch is a reserved ghost in step 1, appears in 2,
//         is wired to the Vercel box in 3–4, and is torn down (dashed, struck)
//         in 5. The shared-storage base is the copy-on-write callback.
//
// A connector spans the gap from the Vercel box to the preview branch in steps
// 3–4, labelled "DATABASE_URL → preview branch".
//
// Pure HTML + CSS + two brand icons. `not-content` wrapper + `margin: 0` resets
// defeat Starlight's prose-margin selector; Starlight theme variables keep it
// native in light and dark. Companion in style to StorageComputeSplit and
// PointInTimeTimeline.

import { Icon } from "astro-icon/components";

interface Props {
  step: 1 | 2 | 3 | 4 | 5;
}

const { step } = Astro.props;

// Per-step copy for the two actor boxes on the left.
const prState =
  step === 1
    ? "opened"
    : step === 5
      ? "merged / closed"
      : step === 4
        ? "+commits pushed"
        : "open";

const vercelState =
  step === 5
    ? "torn down"
    : step === 4
      ? "iterating safely"
      : step === 3
        ? "deployed"
        : "—";

// Which element gets the amber "this is what changed" glow this step.
const prActive = step === 1 || step === 5;
const previewActive = step === 2;
const wireActive = step === 3;
const iterateActive = step === 4;

// The preview branch is absent before it is cut and after it is deleted.
const previewPresent = step >= 2;
const previewDeleted = step === 5;
const wired = step === 3 || step === 4;
const vercelPresent = step >= 3;
---

<div
  class:list={[
    "ppl",
    "not-content",
    `ppl--s${step}`,
    { "is-wired": wired },
  ]}
>
  {/* ── LEFT: the Git / CI actors ─────────────────────────────────────── */}
  <div class="ppl-actors">
    <div class:list={["ppl-actor ppl-actor--gh", { "is-active": prActive }]}>
      <Icon name="simple-icons:github" class="ppl-actor-icon" aria-hidden="true" />
      <span class="ppl-actor-body">
        <span class="ppl-actor-name">Pull request</span>
        <span class="ppl-actor-sub">{prState}</span>
      </span>
    </div>

    <div
      class:list={[
        "ppl-actor ppl-actor--vercel",
        { "is-ghost": !vercelPresent, "is-active": iterateActive },
      ]}
    >
      <Icon name="simple-icons:vercel" class="ppl-actor-icon" aria-hidden="true" />
      <span class="ppl-actor-body">
        <span class="ppl-actor-name">Preview deployment</span>
        <span class="ppl-actor-sub">{vercelState}</span>
      </span>
      {
        iterateActive && (
          <span class="ppl-iter" aria-hidden="true">
            <span class="ppl-chip">migrations</span>
            <span class="ppl-chip">QA</span>
          </span>
        )
      }
    </div>
  </div>

  {/* ── MIDDLE: the connector that wires the deployment to its branch ──── */}
  <div class="ppl-link" aria-hidden="true">
    <span class:list={["ppl-wire", { "is-on": wired, "is-active": wireActive }]}>
      <span class="ppl-wire-label">DATABASE_URL → preview branch</span>
    </span>
  </div>

  {/* ── RIGHT: the Neon project and its branches ──────────────────────── */}
  <div class="ppl-project">
    <span class="ppl-project-name">Neon project</span>

    <div class="ppl-branches">
      <div class="ppl-branch ppl-branch--prod">
        <span class="ppl-branch-name">production</span>
        <span class="ppl-branch-tag">primary · warm</span>
      </div>

      <div class="ppl-branch ppl-branch--staging">
        <span class="ppl-branch-name">staging</span>
        <span class="ppl-branch-tag">long-lived</span>
      </div>

      <div
        class:list={[
          "ppl-branch ppl-branch--preview",
          {
            "is-ghost": !previewPresent,
            "is-active": previewActive,
            "is-deleted": previewDeleted,
          },
        ]}
      >
        <span class="ppl-branch-name">preview/feature-x</span>
        <span class="ppl-branch-tag">
          {
            previewDeleted
              ? "deleted · storage reclaimed"
              : "copy-on-write · ~0 storage"
          }
        </span>
      </div>
    </div>

    <div class="ppl-storage">shared storage · page log</div>
  </div>
</div>

<style>
  .ppl {
    margin: 0;
    display: grid;
    grid-template-columns: minmax(0, 215px) 116px minmax(0, 1fr);
    align-items: center;
    gap: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ── LEFT: actor stack ─────────────────────────────────────────────── */

  .ppl-actors {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0;
  }

  .ppl-actor {
    position: relative;
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 10px 11px;
    border-radius: 10px;
    border: 1.5px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-sidebar);
    box-sizing: border-box;
    margin: 0;
    transition:
      opacity 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;
  }

  .ppl-actor-icon {
    flex: 0 0 auto;
    width: 19px;
    height: 19px;
    color: var(--sl-color-white);
  }

  .ppl-actor-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
    margin: 0;
  }

  .ppl-actor-name {
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--sl-color-white);
    margin: 0;
  }

  .ppl-actor-sub {
    font-size: 10.5px;
    line-height: 1.2;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* Iteration chips that fan off the Vercel box on step 4. */
  .ppl-iter {
    position: absolute;
    top: 50%;
    left: 100%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 8px;
    margin: 0;
  }

  .ppl-chip {
    white-space: nowrap;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 2px 6px;
    border-radius: 999px;
    color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-text-accent) 40%, transparent);
    margin: 0;
  }

  /* A ghost reserves layout so the stage never jumps between steps. */
  .ppl-actor.is-ghost {
    visibility: hidden;
  }

  /* The amber "this is what changed" treatment, shared with the other figures. */
  .ppl-actor.is-active {
    border-color: #f59e0b;
    box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 20%, transparent);
  }

  /* ── MIDDLE: the DATABASE_URL connector ────────────────────────────── */

  .ppl-link {
    position: relative;
    align-self: center;
    height: 100%;
    min-height: 56px;
    margin: 0;
  }

  /* The wire is invisible until the deployment is pointed at its branch. */
  .ppl-wire {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    transform: translateY(-50%);
    background: color-mix(in srgb, var(--sl-color-text-accent) 70%, transparent);
    opacity: 0;
    transition: opacity 200ms ease;
    margin: 0;
  }

  .ppl-wire.is-on {
    opacity: 1;
  }

  /* Arrowhead pointing at the branch (right end). */
  .ppl-wire::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -1px;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid color-mix(in srgb, var(--sl-color-text-accent) 70%, transparent);
  }

  .ppl-wire.is-active {
    background: var(--sl-color-text-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, #f59e0b 22%, transparent);
  }

  .ppl-wire.is-active::after {
    border-left-color: var(--sl-color-text-accent);
  }

  .ppl-wire-label {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    margin: 0 0 5px;
    padding: 0 2px;
    font-size: 9.5px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--sl-color-text-accent);
  }

  /* ── RIGHT: the Neon project ───────────────────────────────────────── */

  .ppl-project {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px 12px 10px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-gray-4) 18%, var(--sl-color-bg));
    box-sizing: border-box;
    margin: 0;
  }

  .ppl-project-name {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .ppl-branches {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
  }

  .ppl-branch {
    flex: 1 1 120px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    border-radius: 9px;
    box-sizing: border-box;
    margin: 0;
    transition:
      opacity 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;
  }

  .ppl-branch-name {
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
  }

  .ppl-branch-tag {
    font-size: 9.5px;
    line-height: 1.2;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* The two long-lived branches: solid, grounded. Production carries the teal
     accent that marks it across this lesson's figures. */
  .ppl-branch--prod {
    border: 2px solid color-mix(in srgb, #0d9488 65%, transparent);
    background: color-mix(in srgb, #0d9488 14%, transparent);
  }

  .ppl-branch--prod .ppl-branch-name {
    color: color-mix(in srgb, #0d9488 60%, var(--sl-color-white));
  }

  .ppl-branch--staging {
    border: 1.5px solid var(--sl-color-gray-3);
    background: color-mix(in srgb, var(--sl-color-gray-4) 35%, transparent);
  }

  .ppl-branch--staging .ppl-branch-name {
    color: var(--sl-color-white);
  }

  /* The ephemeral preview branch: dashed accent, to read as "disposable". */
  .ppl-branch--preview {
    flex-basis: 100%;
    border: 1.5px dashed
      color-mix(in srgb, var(--sl-color-text-accent) 60%, var(--sl-color-gray-4));
    background: color-mix(in srgb, var(--sl-color-text-accent) 8%, transparent);
  }

  .ppl-branch--preview .ppl-branch-name {
    color: var(--sl-color-text-accent);
  }

  .ppl-branch.is-ghost {
    visibility: hidden;
  }

  .ppl-branch.is-active {
    border-style: solid;
    border-color: #f59e0b;
    box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 20%, transparent);
  }

  /* Torn down: faded, struck through, no longer drawn as a live branch. */
  .ppl-branch.is-deleted {
    opacity: 0.5;
  }

  .ppl-branch.is-deleted .ppl-branch-name {
    text-decoration: line-through;
    color: var(--sl-color-gray-3);
  }

  .ppl-storage {
    text-align: center;
    padding: 6px 8px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-2) 35%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  /* ── Narrow viewports: stack actors above the project ──────────────── */
  @media (max-width: 640px) {
    .ppl {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .ppl-actors {
      flex-direction: row;
      gap: 10px;
    }
    .ppl-actor {
      flex: 1 1 0;
    }
    /* The horizontal wire doesn't map to a stacked layout — drop it and let the
       branch tag carry the "this branch is the preview's DB" point. */
    .ppl-link {
      display: none;
    }
    /* Iteration chips would overflow off the stacked Vercel box; hide them, the
       "iterating safely" sub-label still carries step 4. */
    .ppl-iter {
      display: none;
    }
  }
</style>
