---
// point-in-time-timeline — the misconception killer of Lesson 036.3.
//
// Makes point-in-time branch semantics visible: a branch captures its parent at
// the instant of creation, and after that the two diverge and never exchange
// anything. Production's later row C is invisible to the branch; the branch's
// own row Z is invisible to production.
//
// Shape: two diverging horizontal lanes sharing one time axis (left → right).
//   - PRODUCTION lane (top, solid, "primary"): Mon holds {A, B}; on Tue gains C.
//   - BRANCH lane (bottom, accent, peels off at the fork): copies {A, B} at the
//     fork moment, then on Tue gains its own Z.
//   - A vertical fork connector drops from production into the branch lane at
//     the Mon branch-creation moment.
//   - The two Tuesday writes (C, Z) are highlighted, and a small "does not
//     cross" cue between the lanes drives home that neither row reaches the
//     other side.
//
// Pure HTML + CSS, scoped <style>. `not-content` wrapper + `margin: 0` reset on
// every inner element defeat Starlight's prose-margin selector. Starlight theme
// variables keep it native in light and dark. Horizontal and capped-height per
// the vertical-space constraint; companion in style to StorageComputeSplit.

import Figure from "../../../figures/Figure.astro";
---

<Figure
  caption="A branch is a snapshot, not a live mirror. After the fork, new rows on either side stay on their own side."
>
  <div class="pit not-content">
    {/* Time axis ----------------------------------------------------------- */}
    <div class="pit-axis" aria-hidden="true">
      <span class="pit-tick pit-tick--mon">Mon</span>
      <span class="pit-tick pit-tick--tue">Tue</span>
      <span class="pit-axisline"></span>
    </div>

    <div class="pit-lanes">
      {/* PRODUCTION lane (top) ------------------------------------------- */}
      <div class="pit-lane pit-lane--prod">
        <span class="pit-lane-name pit-lane-name--prod">production <span class="pit-tag">primary</span></span>
        <div class="pit-track">
          <div class="pit-event">
            <span class="pit-when">Mon</span>
            <span class="pit-rows">
              <span class="pit-row">A</span>
              <span class="pit-row">B</span>
            </span>
          </div>
          <div class="pit-gap" aria-hidden="true"></div>
          <div class="pit-event pit-event--new">
            <span class="pit-when">Tue</span>
            <span class="pit-rows">
              <span class="pit-row">A</span>
              <span class="pit-row">B</span>
              <span class="pit-row pit-row--add pit-row--add-prod">C</span>
            </span>
          </div>
        </div>
      </div>

      {/* Fork + isolation band between the two lanes --------------------- */}
      <div class="pit-mid" aria-hidden="true">
        <span class="pit-fork"></span>
        <span class="pit-fork-label">branch created (Mon)</span>
        <span class="pit-barrier"></span>
        <span class="pit-barrier-label">after the fork, no row crosses — C stays on production, Z stays on the branch</span>
      </div>

      {/* BRANCH lane (bottom) ------------------------------------------- */}
      <div class="pit-lane pit-lane--branch">
        <span class="pit-lane-name pit-lane-name--branch">branch</span>
        <div class="pit-track pit-track--branch">
          <div class="pit-event">
            <span class="pit-when">Mon</span>
            <span class="pit-rows">
              <span class="pit-row pit-row--copied">A</span>
              <span class="pit-row pit-row--copied">B</span>
            </span>
            <span class="pit-copied-note">copied at fork</span>
          </div>
          <div class="pit-gap" aria-hidden="true"></div>
          <div class="pit-event pit-event--new">
            <span class="pit-when">Tue</span>
            <span class="pit-rows">
              <span class="pit-row pit-row--copied">A</span>
              <span class="pit-row pit-row--copied">B</span>
              <span class="pit-row pit-row--add pit-row--add-branch">Z</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Figure>

<style>
  .pit {
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- Time axis ------------------------------------------------------- */

  .pit-axis {
    position: relative;
    height: 20px;
    /* Align the two ticks to the centres of the Mon and Tue event columns:
       track is [event 1fr][gap 1.4fr][event 1fr]; tick Mon sits over the first
       third, tick Tue over the last. Lane names occupy a fixed left gutter. */
    margin: 0 0 2px 96px;
  }

  .pit-axisline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--sl-color-gray-4);
    margin: 0;
  }

  .pit-tick {
    position: absolute;
    bottom: 4px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-2);
    transform: translateX(-50%);
    margin: 0;
  }

  .pit-tick--mon {
    left: 14%;
  }

  .pit-tick--tue {
    left: 86%;
  }

  /* ---- Lanes ----------------------------------------------------------- */

  .pit-lanes {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .pit-lane {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
  }

  .pit-lane-name {
    flex: 0 0 86px;
    text-align: right;
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
  }

  .pit-lane-name--prod {
    color: var(--sl-color-text);
  }

  .pit-lane-name--branch {
    color: var(--sl-color-text-accent);
  }

  .pit-tag {
    display: inline-block;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1px 5px;
    border-radius: 999px;
    vertical-align: 1px;
    color: var(--sl-color-gray-1);
    background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    border: 1px solid var(--sl-color-hairline);
    margin: 0;
  }

  /* The horizontal track that carries the event boxes for one lane. */
  .pit-track {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr 1fr;
    align-items: center;
    padding: 9px 12px;
    border-radius: 10px;
    border: 2px solid color-mix(in srgb, var(--sl-color-gray-2) 45%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-4) 28%, var(--sl-color-bg));
    box-sizing: border-box;
    margin: 0;
  }

  /* Branch track reads as the accent-coloured offshoot. */
  .pit-track--branch {
    border-color: color-mix(in srgb, var(--sl-color-text-accent) 55%, transparent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 8%, transparent);
  }

  .pit-event {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    margin: 0;
  }

  .pit-event--new {
    justify-self: end;
    align-items: flex-end;
  }

  .pit-gap {
    /* Empty middle column — pure spacing so Mon sits left, Tue sits right. */
    margin: 0;
  }

  .pit-when {
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .pit-rows {
    display: flex;
    gap: 5px;
    margin: 0;
  }

  .pit-row {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 7px;
    font-size: 13px;
    font-weight: 700;
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-gray-2) 78%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-1) 50%, transparent);
    margin: 0;
  }

  /* Rows that exist because the branch copied them at fork time — outlined,
     not filled, to read as "shared, not freshly written". */
  .pit-row--copied {
    color: var(--sl-color-text-accent);
    background: transparent;
    border: 1.5px solid color-mix(in srgb, var(--sl-color-text-accent) 45%, transparent);
  }

  /* The Tuesday writes — the whole point of the figure. Saturated + ring. */
  .pit-row--add {
    color: #fff;
    box-shadow: 0 0 0 3px color-mix(in srgb, currentColor 22%, transparent);
  }

  .pit-row--add-prod {
    background: #0d9488; /* teal-600 — production's new row C */
    border-color: #0d9488;
  }

  .pit-row--add-branch {
    background: #7c3aed; /* violet-600 — the branch's new row Z */
    border-color: #7c3aed;
  }

  .pit-copied-note {
    font-size: 9px;
    font-style: italic;
    color: color-mix(in srgb, var(--sl-color-text-accent) 80%, var(--sl-color-gray-2));
    margin: 1px 0 0;
  }

  /* ---- Middle band: fork connector + "does not cross" cues -------------- */

  .pit-mid {
    position: relative;
    height: 34px;
    /* Match the track's left gutter (lane name 86px + 10px gap) so the fork
       drops inside the track area, under the Monday column. */
    margin: 0 12px 0 96px;
  }

  /* Vertical line from the production lane down into the branch lane, sitting
     under the Monday (fork) column ≈ 14% across the track. */
  .pit-fork {
    position: absolute;
    top: -2px;
    bottom: -2px;
    left: 14%;
    width: 2px;
    background: var(--sl-color-text-accent);
    margin: 0;
  }

  .pit-fork::after {
    /* Down-arrowhead at the branch end of the fork. */
    content: "";
    position: absolute;
    bottom: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid var(--sl-color-text-accent);
  }

  .pit-fork-label {
    position: absolute;
    top: 50%;
    left: calc(14% + 12px);
    transform: translateY(-50%);
    white-space: nowrap;
    font-size: 10px;
    font-weight: 600;
    color: var(--sl-color-text-accent);
    margin: 0;
  }

  /* A dashed horizontal "membrane" spanning the band between the two lanes:
     the barrier nothing crosses after the fork. One label, right-aligned so it
     clears the fork label on the left. */
  .pit-barrier {
    position: absolute;
    top: 50%;
    left: calc(14% + 4px);
    right: 0;
    height: 0;
    border-top: 1.5px dashed color-mix(in srgb, var(--sl-color-gray-2) 60%, transparent);
    transform: translateY(-50%);
    margin: 0;
  }

  .pit-barrier-label {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    max-width: 64%;
    padding: 1px 8px;
    text-align: right;
    font-size: 9.5px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--sl-color-gray-2);
    background: var(--sl-color-bg-sidebar);
    margin: 0;
  }

  /* ---- Narrow viewports ------------------------------------------------- */

  @media (max-width: 620px) {
    .pit-lane {
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
    }
    .pit-lane-name {
      flex: none;
      text-align: left;
    }
    .pit-axis {
      margin-left: 0;
    }
    .pit-mid {
      margin-left: 0;
      height: 30px;
    }
    /* Lanes are stacked vertically now, so the fork connector and the dashed
       membrane no longer map to a left gutter — drop them and keep the single
       takeaway label, centred. The colour-coded C/Z rows still carry the
       "stays on its side" point on their own. */
    .pit-fork,
    .pit-fork-label,
    .pit-barrier {
      display: none;
    }
    .pit-barrier-label {
      position: static;
      display: block;
      max-width: none;
      text-align: center;
      padding: 6px 4px 0;
      background: transparent;
    }
  }
</style>
