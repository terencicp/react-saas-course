---
// spike-exhaustion — the motivating-failure figure of Lesson 036.4.
//
// One body of a DiagramSequence frame, parameterised by `step` (1..4). The
// lesson scrubs the four frames to watch serverless connection exhaustion
// happen and then watch a pooler flatten it. The pedagogical goal is to make
// the failure *visceral and temporal*: a live gauge climbs from calm, races a
// spike toward the cap, slams red at the wall, then drops back to flat-and-low
// once a pooler stands in front.
//
// Shape (horizontal, capped height): a column of small "function" boxes on the
// LEFT → arrows pointing RIGHT → a "Postgres" box on the right, with a prominent
// "connections: N / 100" gauge. Step 4 inserts a "Pooler" box in the middle and
// thins the arrows reaching Postgres to a small fixed few.
//
// Height stability: every frame reserves the same vertical band for the function
// crowd (the tallest frame, step 2/3, sets it) and the same middle lane width
// (so the step-4 Pooler box doesn't shift the others). DiagramSequence already
// stacks steps in one grid cell and sizes to the tallest, but matching the band
// keeps the eye from jumping.
//
// Colour language: the gauge is the signal, so it uses saturated mid-tones that
// read in both themes — green under the cap (calm), amber climbing (spike), red
// at/over the cap (wall), green again once the pooler holds it low (fix). The
// lesson's teal #0d9488 marks the Postgres box and the Pooler so they read as
// "the database side". Pure HTML + CSS, scoped <style>; `not-content` + a
// `margin: 0` reset on every inner element defeat Starlight's prose-margin
// selector.

interface Props {
	/** Which frame of the sequence to render. */
	step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

// Gauge state per frame: the connection count *to Postgres* and the tone.
const cap = 100;
const gauge = {
	1: { count: 3, tone: "calm" as const, label: "well under the cap" },
	2: { count: 90, tone: "warn" as const, label: "racing the wall" },
	3: { count: 100, tone: "wall" as const, label: "at the wall" },
	4: { count: 3, tone: "calm" as const, label: "flat, no matter the spike" },
}[step];

const pct = Math.min(100, Math.round((gauge.count / cap) * 100));

// The crowd of function boxes. Step 1 is calm (3); steps 2–4 are the spike.
// Steps 2/3/4 show the same dense crowd so the height is identical and the eye
// stays on the gauge and the arrows, not a reshuffling left column.
const spike = step !== 1;
const fnCount = step === 1 ? 3 : 10;
// In step 3 the last two functions are rejected at the wall.
const rejectedFrom = step === 3 ? 8 : -1;
const fns = Array.from({ length: fnCount }, (_, i) => ({
	rejected: rejectedFrom >= 0 && i >= rejectedFrom,
}));
---

<div class={`spk not-content spk--step${step}`}>
	{/* LEFT — the crowd of serverless functions */}
	<div class="spk-left">
		<span class="spk-col-label">serverless functions</span>
		<div class="spk-fns">
			{
				fns.map((f) => (
					<div class={`spk-fn${f.rejected ? " spk-fn--rejected" : ""}`}>
						<span class="spk-fn-text">fn</span>
						{f.rejected && (
							<span class="spk-fn-x" aria-hidden="true">
								✕
							</span>
						)}
					</div>
				))
			}
		</div>
		{spike && <span class="spk-more">+ hundreds more</span>}
	</div>

	{/* MIDDLE — arrows, plus the Pooler box in step 4. The lane keeps a fixed
	    width in every frame so inserting the Pooler doesn't shift the columns. */}
	<div class="spk-mid">
		<div class={`spk-arrows${spike ? " spk-arrows--many" : ""}`} aria-hidden="true">
			<span class="spk-arrow"></span>
			<span class="spk-arrow"></span>
			<span class="spk-arrow"></span>
			{spike && <span class="spk-arrow"></span>}
			{spike && <span class="spk-arrow"></span>}
		</div>

		{
			step === 4 && (
				<div class="spk-pooler">
					<span class="spk-pooler-name">Pooler</span>
					<span class="spk-pooler-sub">PgBouncer</span>
				</div>
			)
		}

		{
			step === 4 && (
				<div class="spk-arrows spk-arrows--few" aria-hidden="true">
					<span class="spk-arrow spk-arrow--thin" />
					<span class="spk-arrow spk-arrow--thin" />
					<span class="spk-arrow spk-arrow--thin" />
				</div>
			)
		}
	</div>

	{/* RIGHT — Postgres, with the live connection gauge. */}
	<div class="spk-right">
		<div class={`spk-pg spk-pg--${gauge.tone}`}>
			<span class="spk-pg-name">Postgres</span>
			{
				step === 3 && (
					<span class="spk-pg-fatal">FATAL: too many connections</span>
				)
			}
		</div>

		<div class={`spk-gauge spk-gauge--${gauge.tone}`}>
			<span class="spk-gauge-label">connections</span>
			<span class="spk-gauge-count">
				{gauge.count}
				<span class="spk-gauge-cap"> / {cap}</span>
			</span>
			<div class="spk-gauge-bar">
				<div class="spk-gauge-fill" style={`width: ${pct}%;`}></div>
				<div class="spk-gauge-wall" aria-hidden="true"></div>
			</div>
			<span class="spk-gauge-note">{gauge.label}</span>
		</div>
	</div>
</div>

<style>
	.spk {
		display: flex;
		align-items: stretch;
		gap: 0;
		/* Fixed band so all four frames are the same height — the dense crowd
		   (steps 2–4) sets it; step 1 just leaves the lower part empty. */
		min-height: 248px;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
		margin: 0;
	}

	/* ── LEFT: the function crowd ─────────────────────────────────────────── */

	.spk-left {
		flex: 0 0 168px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		min-width: 0;
		margin: 0;
	}

	.spk-col-label,
	.spk-pg-name + .spk-gauge-label {
		margin: 0;
	}

	.spk-col-label {
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-3);
		text-align: center;
		margin: 0;
	}

	.spk-fns {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 7px 9px;
		width: 100%;
		max-width: 150px;
		margin: 0;
	}

	/* Step 1 is calm — three boxes, single tidy column so "three" reads clearly. */
	.spk--step1 .spk-fns {
		grid-template-columns: 1fr;
		max-width: 86px;
	}

	.spk-fn {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		height: 30px;
		border-radius: 7px;
		border: 1.5px solid color-mix(in srgb, var(--sl-color-gray-2) 55%, transparent);
		background: color-mix(in srgb, var(--sl-color-gray-4) 35%, var(--sl-color-bg));
		box-sizing: border-box;
		margin: 0;
	}

	.spk-fn-text {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--sl-color-gray-2);
		margin: 0;
	}

	/* Rejected functions at the wall: red outline + an ✕. */
	.spk-fn--rejected {
		border-color: color-mix(in srgb, #dc2626 70%, transparent);
		background: color-mix(in srgb, #dc2626 15%, transparent);
	}
	.spk-fn--rejected .spk-fn-text {
		color: color-mix(in srgb, #dc2626 75%, var(--sl-color-white));
	}
	.spk-fn-x {
		position: absolute;
		top: -7px;
		right: -7px;
		width: 16px;
		height: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: #dc2626;
		color: #fff;
		font-size: 9px;
		font-weight: 700;
		line-height: 1;
		box-shadow: 0 0 0 2px var(--sl-color-bg-sidebar);
		margin: 0;
	}

	.spk-more {
		font-size: 10.5px;
		font-weight: 600;
		font-style: italic;
		color: var(--sl-color-gray-3);
		text-align: center;
		margin: 2px 0 0;
	}

	/* ── MIDDLE: arrows + the optional Pooler box ─────────────────────────── */

	.spk-mid {
		flex: 1 1 0;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0;
		min-width: 90px;
		margin: 0;
	}

	.spk-arrows {
		flex: 1 1 0;
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 9px;
		min-width: 26px;
		margin: 0;
	}

	.spk-arrow {
		position: relative;
		height: 2px;
		background: color-mix(in srgb, var(--sl-color-gray-2) 60%, transparent);
		border-radius: 2px;
		margin: 0;
	}
	.spk-arrow::after {
		content: "";
		position: absolute;
		top: 50%;
		right: -1px;
		transform: translateY(-50%);
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-left: 6px solid color-mix(in srgb, var(--sl-color-gray-2) 60%, transparent);
	}

	/* The dense spike: many arrows, tinted amber to read as "pressure". */
	.spk-arrows--many .spk-arrow {
		background: color-mix(in srgb, #d97706 60%, transparent);
	}
	.spk-arrows--many .spk-arrow::after {
		border-left-color: color-mix(in srgb, #d97706 60%, transparent);
	}

	/* Step 4: the few thin arrows from the pooler to Postgres — calm teal. */
	.spk-arrows--few {
		flex: 0 0 40px;
		gap: 11px;
		min-width: 30px;
	}
	.spk-arrow--thin {
		height: 2px;
		background: color-mix(in srgb, #0d9488 70%, transparent);
	}
	.spk-arrow--thin::after {
		border-left-color: color-mix(in srgb, #0d9488 70%, transparent);
	}

	.spk-pooler {
		flex: 0 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1px;
		padding: 14px 12px;
		border-radius: 10px;
		border: 2px solid color-mix(in srgb, #0d9488 60%, transparent);
		background: color-mix(in srgb, #0d9488 12%, var(--sl-color-bg));
		box-sizing: border-box;
		margin: 0;
	}
	.spk-pooler-name {
		font-size: 13px;
		font-weight: 700;
		color: color-mix(in srgb, #0d9488 60%, var(--sl-color-white));
		margin: 0;
	}
	.spk-pooler-sub {
		font-size: 9px;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* ── RIGHT: Postgres + the gauge ──────────────────────────────────────── */

	.spk-right {
		flex: 0 0 168px;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		justify-content: center;
		gap: 12px;
		min-width: 0;
		margin: 0;
	}

	.spk-pg {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		min-height: 56px;
		padding: 12px 10px;
		border-radius: 10px;
		border: 2px solid color-mix(in srgb, #0d9488 55%, transparent);
		background: color-mix(in srgb, #0d9488 12%, var(--sl-color-bg));
		box-sizing: border-box;
		text-align: center;
		margin: 0;
	}
	.spk-pg-name {
		font-size: 14px;
		font-weight: 700;
		color: color-mix(in srgb, #0d9488 60%, var(--sl-color-white));
		margin: 0;
	}
	/* At the wall, the Postgres box itself goes red to match the gauge. */
	.spk-pg--wall {
		border-color: color-mix(in srgb, #dc2626 60%, transparent);
		background: color-mix(in srgb, #dc2626 12%, var(--sl-color-bg));
	}
	.spk-pg--wall .spk-pg-name {
		color: color-mix(in srgb, #dc2626 70%, var(--sl-color-white));
	}
	.spk-pg-fatal {
		font-size: 9.5px;
		font-weight: 700;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		color: color-mix(in srgb, #dc2626 78%, var(--sl-color-white));
		line-height: 1.25;
		margin: 0;
	}

	/* The gauge — the figure's focal point. */
	.spk-gauge {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		padding: 10px 10px 11px;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-hairline);
		background: var(--sl-color-bg);
		box-sizing: border-box;
		margin: 0;
	}
	.spk-gauge-label {
		font-size: 9px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--sl-color-gray-3);
		margin: 0;
	}
	.spk-gauge-count {
		font-size: 28px;
		font-weight: 800;
		line-height: 1;
		font-variant-numeric: tabular-nums;
		margin: 0;
	}
	.spk-gauge-cap {
		font-size: 15px;
		font-weight: 700;
		color: var(--sl-color-gray-3);
	}
	.spk-gauge-bar {
		position: relative;
		width: 100%;
		height: 7px;
		border-radius: 4px;
		background: color-mix(in srgb, var(--sl-color-gray-4) 60%, transparent);
		overflow: hidden;
		margin: 3px 0 0;
	}
	.spk-gauge-fill {
		height: 100%;
		border-radius: 4px;
		margin: 0;
	}
	/* The cap line at the right edge of the bar. */
	.spk-gauge-wall {
		position: absolute;
		top: -1px;
		bottom: -1px;
		right: 0;
		width: 2px;
		background: var(--sl-color-gray-2);
		margin: 0;
	}
	.spk-gauge-note {
		font-size: 10px;
		font-weight: 600;
		line-height: 1.2;
		text-align: center;
		margin: 1px 0 0;
	}

	/* Gauge tones — the signal. */
	.spk-gauge--calm .spk-gauge-count {
		color: color-mix(in srgb, #16a34a 72%, var(--sl-color-white));
	}
	.spk-gauge--calm .spk-gauge-fill {
		background: #16a34a;
	}
	.spk-gauge--calm .spk-gauge-note {
		color: color-mix(in srgb, #16a34a 70%, var(--sl-color-white));
	}

	.spk-gauge--warn .spk-gauge-count {
		color: color-mix(in srgb, #d97706 78%, var(--sl-color-white));
	}
	.spk-gauge--warn .spk-gauge-fill {
		background: #d97706;
	}
	.spk-gauge--warn .spk-gauge-note {
		color: color-mix(in srgb, #d97706 76%, var(--sl-color-white));
	}

	.spk-gauge--wall {
		border-color: color-mix(in srgb, #dc2626 45%, transparent);
	}
	.spk-gauge--wall .spk-gauge-count {
		color: color-mix(in srgb, #dc2626 78%, var(--sl-color-white));
	}
	.spk-gauge--wall .spk-gauge-fill {
		background: #dc2626;
	}
	.spk-gauge--wall .spk-gauge-note {
		color: color-mix(in srgb, #dc2626 78%, var(--sl-color-white));
	}

	/* ── Narrow viewports: keep it horizontal but tighten the side rails. ─── */
	@media (max-width: 560px) {
		.spk {
			min-height: 268px;
		}
		.spk-left {
			flex-basis: 128px;
		}
		.spk-right {
			flex-basis: 138px;
		}
		.spk-gauge-count {
			font-size: 24px;
		}
	}
</style>
