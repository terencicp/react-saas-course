---
// merge-gate-funnel — the six baseline rules compose into ONE gate (Lesson 96.4).
//
// "Require a pull request" is the entry: it's why the PR chip exists at all, so
// it sits to the LEFT of the strip, not as a gate. The remaining five baseline
// rules become five gates the PR must clear in sequence before merge unlocks:
//
//   1 approval → no stale approval → code-owner approved → 4 checks green →
//   linear history → [Merge]
//
// Pedagogical point: the gates are not independent toggles, they're a single
// sequential gate. One unmet gate keeps merge LOCKED even when others are green.
// Here `code-owner approved` is blocked (red ✕): the two gates before it read as
// passed (green check), the two after it as not-yet-reached (neutral grey), and
// the Merge button is rendered disabled/grey rather than green.
//
// Layout: horizontal flex strip, chevron glyphs between gates, capped height.
// Class-based scoped <style> matching the lesson's TwoSurfaces component;
// `not-content` + a margin reset defeat Starlight's prose-margin selector,
// Starlight theme variables keep pass/blocked/neutral readable in both themes.
// Wraps to two rows on narrow viewports (column-gap / row-gap split).

import Figure from "../../../figures/Figure.astro";

// The five gates, in clearance order, each with a visual state:
//   "pass"     — cleared (green tint, check glyph)
//   "blocked"  — the unmet gate (red tint, ✕ glyph)
//   "pending"  — not yet reached (neutral grey, dim)
const gates = [
  { label: "1 approval", state: "pass" },
  { label: "no stale approval", state: "pass" },
  { label: "code-owner approved", state: "blocked" },
  { label: "4 checks green", state: "pending" },
  { label: "linear history", state: "pending" },
];

const glyph = { pass: "✓", blocked: "✕", pending: "" } as const;
const stateLabel = {
  pass: "passed",
  blocked: "blocked here",
  pending: "not reached",
} as const;
---

<Figure caption="Once a change arrives as a PR, the baseline rules compose into one gate. The merge button stays locked until every gate passes — here a missing code-owner approval blocks it, even though approvals and CI are green.">
  <div class="mgf not-content">
    {/* ---- Entry: the PR chip (the "require a PR" rule is what makes it exist) ---- */}
    <div class="mgf-entry">
      <span class="mgf-entry-label">PR</span>
      <span class="mgf-entry-sub">enters</span>
    </div>

    <span class="mgf-chev" aria-hidden="true">&rsaquo;</span>

    {/* ---- The five gates in sequence ---- */}
    {
      gates.map((g, i) => (
        <>
          <div class={`mgf-gate mgf-gate--${g.state}`}>
            <span class="mgf-gate-mark" aria-hidden="true">
              {glyph[g.state as keyof typeof glyph]}
            </span>
            <span class="mgf-gate-label">{g.label}</span>
            <span class="mgf-gate-state">{stateLabel[g.state as keyof typeof stateLabel]}</span>
          </div>
          <span class="mgf-chev" aria-hidden="true">&rsaquo;</span>
        </>
      ))
    }

    {/* ---- Exit: the Merge button, disabled because a gate is unmet ---- */}
    <div class="mgf-merge" aria-disabled="true">
      <span class="mgf-merge-lock" aria-hidden="true">&#128274;</span>
      <span class="mgf-merge-label">Merge</span>
    </div>
  </div>
</Figure>

<style>
  .mgf {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    column-gap: 4px;
    row-gap: 14px;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --mgf-green: var(--sl-color-green, #16a34a);
    --mgf-green-hi: var(--sl-color-green-high, #15803d);
    --mgf-red: var(--sl-color-red, #dc2626);
    --mgf-red-hi: var(--sl-color-red-high, #b91c1c);
  }

  /* ---- Entry PR chip ---- */
  .mgf-entry {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 8px 11px;
    border-radius: 10px;
    border: 1.5px solid var(--sl-color-gray-4);
    background: var(--sl-color-bg-sidebar);
    box-sizing: border-box;
  }

  .mgf-entry-label {
    margin: 0;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--sl-color-white);
  }

  .mgf-entry-sub {
    margin: 0;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
  }

  /* ---- Chevron between cells ---- */
  .mgf-chev {
    margin: 0;
    display: flex;
    align-items: center;
    font-size: 17px;
    line-height: 1;
    color: var(--sl-color-gray-4);
  }

  /* ---- A gate segment ---- */
  .mgf-gate {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    min-width: 78px;
    padding: 8px 8px;
    border-radius: 10px;
    border: 1.5px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-sidebar);
    box-sizing: border-box;
  }

  .mgf-gate-mark {
    margin: 0;
    font-size: 14px;
    font-weight: 800;
    line-height: 1;
  }

  .mgf-gate-label {
    margin: 0;
    font-size: 11.5px;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    color: var(--sl-color-white);
    white-space: nowrap;
  }

  .mgf-gate-state {
    margin: 0;
    font-size: 9.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  /* ---- Passed gate: green ---- */
  .mgf-gate--pass {
    border-color: color-mix(in srgb, var(--mgf-green) 60%, transparent);
    background: color-mix(in srgb, var(--mgf-green) 12%, var(--sl-color-bg-sidebar));
  }
  .mgf-gate--pass .mgf-gate-mark,
  .mgf-gate--pass .mgf-gate-state {
    color: var(--mgf-green-hi);
  }

  /* ---- Blocked gate: red ---- */
  .mgf-gate--blocked {
    border-color: var(--mgf-red);
    border-width: 2px;
    background: color-mix(in srgb, var(--mgf-red) 16%, var(--sl-color-bg-sidebar));
  }
  .mgf-gate--blocked .mgf-gate-mark,
  .mgf-gate--blocked .mgf-gate-state {
    color: var(--mgf-red-hi);
  }

  /* ---- Not-yet-reached gate: neutral / dim ---- */
  .mgf-gate--pending {
    border-style: dashed;
    border-color: var(--sl-color-gray-5);
    opacity: 0.6;
  }
  .mgf-gate--pending .mgf-gate-label {
    color: var(--sl-color-gray-2);
  }
  .mgf-gate--pending .mgf-gate-state {
    color: var(--sl-color-gray-3);
  }

  /* ---- Merge button: disabled (grey, not green) because a gate is unmet ---- */
  .mgf-merge {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    min-width: 72px;
    padding: 8px 13px;
    border-radius: 10px;
    border: 1.5px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-5) 35%, var(--sl-color-bg-sidebar));
    color: var(--sl-color-gray-3);
    cursor: not-allowed;
    box-sizing: border-box;
  }

  .mgf-merge-lock {
    margin: 0;
    font-size: 14px;
    line-height: 1;
    color: var(--sl-color-gray-3);
  }

  .mgf-merge-label {
    margin: 0;
    font-size: 13px;
    font-weight: 800;
    color: var(--sl-color-gray-2);
  }

  /* Narrow viewports: let the strip wrap; the chevrons keep the read order. */
  @media (max-width: 640px) {
    .mgf {
      column-gap: 4px;
    }
    .mgf-gate {
      min-width: 84px;
      padding: 8px 10px;
    }
  }
</style>
