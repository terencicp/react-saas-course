---
// two-surfaces — the load-bearing mental model for Lesson 96.4.
//
// Repo policy lives in TWO different places that behave completely differently:
//
//   LEFT  — the .github/ directory: in the repo tree, version-controlled,
//           reviewed in PRs like code. Holds *configuration* (the data).
//   RIGHT — Repo Settings → Rules → Rulesets: NOT in the tree, lives in
//           GitHub's settings. Holds the *enforcement* (the switch).
//
// The whole point is the relationship: the ruleset on the right *references*
// files on the left. Two thin arrows point back from the ruleset zone into the
// left zone — one to CODEOWNERS ("activates"), one to workflows/ci.yml
// ("references checks by name"). Those two referenced chips carry an accent
// border so the eye lands on them.
//
// Layout: a 2-zone CSS grid. The left zone is itself a chip|connector inner
// grid so each connector arrow lines up on the same row as the chip it points
// at. Pure HTML + CSS so it's devtools-inspectable. `not-content` + a margin
// reset on inner elements defeat Starlight's prose-margin selector; Starlight
// theme variables keep it native in light and dark. Blue tints the .github/
// zone, purple tints the ruleset zone.

import Figure from "../../../figures/Figure.astro";

// Left-zone file chips. `ref` marks the two the ruleset reaches back to.
const files = [
  { name: "CODEOWNERS", ref: "activates" },
  { name: "pull_request_template.md", ref: null },
  { name: "workflows/ci.yml", ref: "references checks by name" },
  { name: "dependabot.yml", ref: null },
];

const rules = [
  "Require a pull request",
  "Require 1 approval",
  "Dismiss stale approvals",
  "Require code-owner review",
  "Require status checks",
  "Require linear history",
];
---

<Figure caption="Configuration lives in the repo and is reviewed like code; enforcement lives in repo settings. The ruleset is the switch that wires the two together.">
  <div class="ts not-content">
    {/* ---- Left zone: the .github/ directory ---- */}
    <section class="ts-zone ts-zone--repo" aria-label="In the repo">
      <header class="ts-zhead">
        <span class="ts-ztitle">In the repo (<code class="ts-code">.github/</code>)</span>
        <span class="ts-zsub">reviewed in PRs like code</span>
      </header>

      <div class="ts-files">
        {
          files.map((f) => (
            <div class="ts-row">
              <div class={`ts-chip${f.ref ? " ts-chip--ref" : ""}`}>
                <code class="ts-filename">{f.name}</code>
              </div>
              {f.ref ? (
                <div class="ts-connector">
                  <span class="ts-conn-label">{f.ref}</span>
                  <span class="ts-arrow" aria-hidden="true">&larr;</span>
                </div>
              ) : (
                <div class="ts-connector" aria-hidden="true" />
              )}
            </div>
          ))
        }
      </div>
    </section>

    {/* ---- Right zone: the ruleset in repo settings ---- */}
    <section class="ts-zone ts-zone--settings" aria-label="In repo settings">
      <header class="ts-zhead">
        <span class="ts-ztitle">In repo settings</span>
        <span class="ts-zsub">not in the tree</span>
      </header>

      <div class="ts-card">
        <div class="ts-card-head">
          <span class="ts-card-icon" aria-hidden="true">&#9881;</span>
          <span class="ts-card-title">Ruleset: <code class="ts-code ts-code--on-card">main</code></span>
        </div>
        <ul class="ts-rules">
          {rules.map((r) => (
            <li class="ts-rule">{r}</li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</Figure>

<style>
  .ts {
    margin: 0;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: 18px;
    align-items: stretch;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --ts-blue: var(--sl-color-blue, #3b82f6);
    --ts-blue-hi: var(--sl-color-blue-high, #2563eb);
    --ts-purple: var(--sl-color-purple, #a855f7);
    --ts-purple-hi: var(--sl-color-purple-high, #9333ea);
  }

  /* ---- Zones ---- */
  .ts-zone {
    margin: 0;
    display: flex;
    flex-direction: column;
    padding: 14px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-gray-5);
    box-sizing: border-box;
  }

  .ts-zone--repo {
    border-color: color-mix(in srgb, var(--ts-blue) 45%, transparent);
    background: color-mix(in srgb, var(--ts-blue) 7%, transparent);
  }

  .ts-zone--settings {
    border-color: color-mix(in srgb, var(--ts-purple) 45%, transparent);
    background: color-mix(in srgb, var(--ts-purple) 7%, transparent);
  }

  .ts-zhead {
    margin: 0 0 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ts-ztitle {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--sl-color-white);
  }

  .ts-zsub {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
  }

  /* ---- Left zone: file chips + connectors ---- */
  .ts-files {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ts-row {
    margin: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 8px;
  }

  .ts-chip {
    margin: 0;
    padding: 9px 12px;
    border-radius: 9px;
    border: 1px solid color-mix(in srgb, var(--ts-blue) 35%, transparent);
    background: var(--sl-color-bg-sidebar);
    box-sizing: border-box;
    min-width: 0;
  }

  /* The two chips the ruleset reaches back to — accent border + tint. */
  .ts-chip--ref {
    border-color: var(--ts-blue-hi);
    border-width: 1.5px;
    background: color-mix(in srgb, var(--ts-blue) 12%, var(--sl-color-bg-sidebar));
  }

  .ts-filename {
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 12.5px;
    color: var(--sl-color-white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  .ts-connector {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 5px;
    min-height: 18px;
  }

  .ts-conn-label {
    margin: 0;
    font-size: 10.5px;
    font-weight: 600;
    line-height: 1.15;
    text-align: right;
    color: var(--ts-purple-hi);
  }

  .ts-arrow {
    margin: 0;
    font-size: 16px;
    line-height: 1;
    color: var(--ts-purple-hi);
  }

  /* ---- Right zone: the ruleset card ---- */
  .ts-card {
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    border: 1.5px solid color-mix(in srgb, var(--ts-purple) 55%, transparent);
    background: var(--sl-color-bg-sidebar);
    overflow: hidden;
  }

  .ts-card-head {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 12px;
    border-bottom: 1px solid color-mix(in srgb, var(--ts-purple) 35%, transparent);
    background: color-mix(in srgb, var(--ts-purple) 14%, transparent);
  }

  .ts-card-icon {
    margin: 0;
    font-size: 14px;
    line-height: 1;
    color: var(--ts-purple-hi);
  }

  .ts-card-title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .ts-rules {
    margin: 0;
    padding: 6px 0;
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .ts-rule {
    margin: 0;
    padding: 7px 12px;
    font-size: 12.5px;
    line-height: 1.25;
    color: var(--sl-color-text);
    border-top: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
  }

  .ts-rule:first-child {
    border-top: none;
  }

  /* ---- Shared inline code (zone titles / "main") ---- */
  .ts-code {
    margin: 0;
    padding: 1px 5px;
    border-radius: 5px;
    background: color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent);
    border: none;
    font-family: var(
      --__sl-font-mono,
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 0.9em;
    color: var(--sl-color-white);
  }

  .ts-code--on-card {
    background: color-mix(in srgb, var(--ts-purple) 18%, transparent);
    color: var(--ts-purple-hi);
  }

  /* Narrow viewports: stack the two zones; arrows still read as "back into the
     repo zone above". */
  @media (max-width: 560px) {
    .ts {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }
</style>
