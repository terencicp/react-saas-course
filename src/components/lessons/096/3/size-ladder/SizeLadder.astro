---
// size-ladder — Chapter 096 Lesson 3, "The pull request as designed artifact".
//
// Makes the "small" half of small/reviewable/reversible concrete: a single
// horizontal bar split into three size bands — green (~under 400 lines), amber
// (400–800), red (800+) — read left-to-right as the diff grows. Below the bar,
// one callout per band names what happens to review quality there.
//
// The pedagogical point the SHAPE must carry: this is a slope, not a cliff.
// Review quality degrades GRADUALLY as the diff grows, which is exactly why 400
// is a heuristic and not a hard gate. So the band fills blend into each other at
// the seams (a left-to-right gradient that crossfades green → amber → red across
// the whole bar) rather than meeting at hard edges, and the ~400 / ~800 marks sit
// ON the bar as soft thresholds, not walls.
//
// Layout: ONE three-column CSS grid so the bar segments and the callouts beneath
// them share the same coordinate system and stay column-aligned. The three
// columns are proportional to the size ranges they stand for (400 : 400 : ~400+),
// so the eye reads "each band is roughly another 400 lines." On narrow viewports
// the callouts drop under a full-width bar so nothing collides.
//
// Pure HTML + CSS per the diagrams guide (a small fixed graphic, color is the
// signal). Saturated mid-tones with white labels read in both themes. The diagram
// is wrapped in <Figure> here so the MDX stays a single import + tag.

import Figure from '../../../../figures/Figure.astro';

const bands = [
	{
		key: 'green',
		color: '#16a34a',
		size: '~ under 400 lines',
		name: 'Reviews well',
		callout:
			'A reviewer holds the whole diff in their head and traces every change to the code that calls it.',
	},
	{
		key: 'amber',
		color: '#d97706',
		size: '400–800 lines',
		name: 'Review degrades',
		callout:
			'Attention thins. Some lines get a glance instead of a read, and the read turns into a skim.',
	},
	{
		key: 'red',
		color: '#dc2626',
		size: '800+ lines',
		name: 'Rubber-stamped',
		callout:
			'Too big to hold. The approval is a thumbs-up nobody could honestly give — the bug ships.',
	},
] as const;
---

<Figure caption="Line count isn't a gate — it's a proxy for how much attention a reviewer can actually give. The bigger the diff, the more review quality slides from real to ceremonial.">
	<div
		class="sl not-content"
		role="img"
		aria-label="A pull request size ladder. Under roughly 400 changed lines reviews well; 400 to 800 lines, review quality degrades; 800-plus lines gets rubber-stamped. Review quality slides down gradually as the diff grows."
	>
		{/* The bar itself: one continuous crossfade behind three labelled
		    segments, so the bands blend rather than meeting at a hard edge. */}
		<div class="sl-bar" aria-hidden="true">
			{
				bands.map((band) => (
					<div class="sl-seg">
						<span class="sl-seg-size">{band.size}</span>
						<span class="sl-seg-name">{band.name}</span>
					</div>
				))
			}
			{/* Soft thresholds sitting on the bar — heuristics, not walls. */}
			<span class="sl-tick sl-tick-400" aria-hidden="true">~400</span>
			<span class="sl-tick sl-tick-800" aria-hidden="true">~800</span>
		</div>

		{/* Axis hint: the read direction is "the diff grows". */}
		<div class="sl-axis" aria-hidden="true">
			<span>fewer changed lines</span>
			<span class="sl-axis-arrow">
				<svg
					viewBox="0 0 28 8"
					fill="none"
					stroke="currentColor"
					stroke-width="1.4"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<line x1="1" y1="4" x2="24" y2="4"></line>
					<polyline points="20 1.5 24.5 4 20 6.5"></polyline>
				</svg>
			</span>
			<span>more changed lines</span>
		</div>

		{/* Callouts, column-aligned under their band. */}
		<div class="sl-callouts">
			{
				bands.map((band) => (
					<div class="sl-callout">
						<span class="sl-dot" style={`background:${band.color}`} />
						<p class="sl-callout-text">{band.callout}</p>
					</div>
				))
			}
		</div>
	</div>
</Figure>

<style>
	.sl {
		margin: 0;
		display: grid;
		gap: 14px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The bar: three proportional columns (roughly 400 : 400 : 400-and-up worth
	   of lines), over a single continuous green→amber→red crossfade so the bands
	   slide into one another instead of butting at a hard edge. */
	.sl-bar {
		position: relative;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr 1fr 1.15fr;
		height: 76px;
		border-radius: 10px;
		overflow: hidden;
		background: linear-gradient(
			90deg,
			#16a34a 0%,
			#16a34a 22%,
			#d97706 50%,
			#dc2626 78%,
			#dc2626 100%
		);
		box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.12);
	}

	.sl-seg {
		margin: 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		padding: 6px 8px;
		text-align: center;
		color: #fff;
		/* Keep the white labels legible over the lighter amber middle. */
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
	}

	.sl-seg-size {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: 0.01em;
		white-space: nowrap;
	}
	.sl-seg-name {
		margin: 2px 0 0;
		font-size: 0.7rem;
		font-weight: 600;
		line-height: 1.1;
		opacity: 0.95;
		white-space: nowrap;
	}

	/* Threshold marks sitting on the bar — soft, not walls. */
	.sl-tick {
		position: absolute;
		top: 0;
		bottom: 0;
		display: flex;
		align-items: flex-start;
		padding-top: 3px;
		font-size: 0.6rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.92);
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
		border-left: 1px dashed rgba(255, 255, 255, 0.6);
		padding-left: 4px;
		pointer-events: none;
	}
	/* Land each mark on the matching segment boundary. The bar's columns are
	   1fr : 1fr : 1.15fr (total 3.15), so the seams sit at 1/3.15 and 2/3.15. */
	.sl-tick-400 {
		left: 31.746%;
	}
	.sl-tick-800 {
		left: 63.492%;
	}

	.sl-axis {
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-size: 0.64rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}
	.sl-axis-arrow {
		display: inline-flex;
		color: var(--sl-color-gray-4);
	}
	.sl-axis-arrow svg {
		width: 28px;
		height: 8px;
	}

	/* Callouts, aligned column-for-column under the bands above. */
	.sl-callouts {
		margin: 0;
		display: grid;
		/* Match the bar's column ratio so each callout sits under its band. */
		grid-template-columns: 1fr 1fr 1.15fr;
		gap: 12px;
	}
	.sl-callout {
		margin: 0;
		display: flex;
		align-items: flex-start;
		gap: 7px;
	}
	.sl-dot {
		margin: 4px 0 0;
		flex: 0 0 auto;
		width: 9px;
		height: 9px;
		border-radius: 999px;
	}
	.sl-callout-text {
		margin: 0;
		font-size: 0.8rem;
		line-height: 1.4;
		color: var(--sl-color-gray-2);
	}

	/* Narrow viewports: keep the bar full-width but stack the callouts so the
	   text never gets crushed into a too-thin column. */
	@media (max-width: 600px) {
		.sl-seg-size {
			font-size: 0.72rem;
		}
		.sl-seg-name {
			font-size: 0.62rem;
		}
		.sl-callouts {
			grid-template-columns: 1fr;
			gap: 9px;
		}
	}
</style>
