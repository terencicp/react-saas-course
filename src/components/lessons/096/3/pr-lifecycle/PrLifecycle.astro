---
// pr-lifecycle — Chapter 096 Lesson 3, "The pull request as designed artifact".
//
// The load-bearing mental scaffold for the whole lesson: a pull request is not a
// single event but a short pipeline of checkpoints, and every later section of
// the lesson lives at one of these stages (fixups → discuss, CODEOWNERS →
// reviewers, and so on). The student scrubs the DiagramSequence and watches ONE
// strip of nodes light up stage-by-stage, left to right.
//
// The geometry is FIXED across all nine steps — the same nine-node strip is
// rendered every frame; only which node is lit (and which edges read as
// "already crossed") changes. That keeps DiagramSequence's grid stack sized once
// to the tallest step so it never reflows as the reader scrubs.
//
// Each node also carries an ACTOR sub-label (you / GitHub / CI / reviewer) so the
// strip itself shows the hand-off the captions narrate — the work moves between
// people and machines as the PR advances, which is the senior point of the map.
//
// Two stages — CI and preview — are forward-referenced to later chapters; they
// render with a dashed "later" border so the student sees at a glance that those
// mechanics arrive elsewhere, without breaking the chain.
//
// Pure HTML + CSS per the diagrams guide (a small fixed strip with per-step
// emphasis; no ArrowDiagram leader lines, which break inside DiagramSequence's
// visibility:hidden grid stack). The lit node carries the chapter's blue accent;
// the SVG chevrons between nodes light up once an edge has been crossed so the
// strip reads as progress, not a static chain. DiagramSequence supplies the outer
// card, so there is NO <Figure> wrapper.

import DiagramSequence from '../../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../../figures/diagram-sequence/DiagramStep.astro';

// The nine lifecycle stages, in order. `label` is the node headline (mono for the
// command-ish ones), `actor` is who does the work at that stage, and `later`
// flags the two stages whose mechanics belong to a future chapter.
const nodes: {
	label: string;
	actor: string;
	mono?: boolean;
	later?: boolean;
}[] = [
	{ label: 'push', actor: 'you', mono: true },
	{ label: 'open PR', actor: 'you' },
	{ label: 'reviewers', actor: 'GitHub' },
	{ label: 'CI', actor: 'next chapter', later: true },
	{ label: 'preview', actor: 'later chapter', later: true },
	{ label: 'discuss', actor: 'you + reviewer' },
	{ label: 'approve', actor: 'reviewer' },
	{ label: 'squash-merge', actor: 'you', mono: true },
	{ label: 'branch deleted', actor: 'GitHub' },
];

const captions = [
	'You push the finished branch: `git push -u origin feat/invoice-status`. The remote now has your commits, but nothing is proposed yet.',
	'You open the PR against `main`, on the web or with `gh pr create`. This is where the diff and the description come together into a proposal.',
	'Reviewers get requested — automatically, if a CODEOWNERS file maps the changed files to a team (covered later this lesson).',
	"CI runs its checks against the PR's commits. Wiring CI to run on every PR is the next chapter's job — for now, just know this stage exists.",
	'A preview deployment of the branch goes live at its own URL, so reviewers click through the real feature. The mechanics arrive in a later chapter.',
	"Reviewers leave comments; you push fixup commits in response. This is the negotiation, and it's where most of the back-and-forth happens.",
	'A reviewer approves. The proposal is now ratified — but not yet on `main`.',
	'You squash-merge. Every commit on the branch collapses into one clean commit on `main`.',
	'The merged branch is auto-deleted. The work is on `main`; the branch has served its purpose.',
];

const BLUE = '#3b82f6';
---

<DiagramSequence>
	{
		nodes.map((_, active) => (
			<DiagramStep>
				<div
					class="prl not-content"
					role="img"
					aria-label={`Pull request lifecycle: ${nodes
						.map((n) => n.label)
						.join(' to ')}. Active stage: ${nodes[active].label}.`}
				>
					{nodes.map((node, i) => (
						<>
							<div
								class:list={[
									'prl-node',
									{ 'is-on': i === active, 'is-later': node.later },
								]}
							>
								<span class="prl-step">{i + 1}</span>
								<span
									class:list={['prl-label', { 'prl-mono': node.mono }]}
								>
									{node.label}
								</span>
								<span class="prl-actor">{node.actor}</span>
							</div>
							{i < nodes.length - 1 && (
								<span
									class:list={['prl-arrow', { 'is-on': i < active }]}
									aria-hidden="true"
								>
									<svg
										viewBox="0 0 20 14"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<polyline points="6 2.5 13 7 6 11.5" />
									</svg>
								</span>
							)}
						</>
					))}
				</div>
				<Fragment slot="caption" set:html={captions[active]} />
			</DiagramStep>
		))
	}
</DiagramSequence>

<style define:vars={{ 'prl-blue': BLUE }}>
	.prl {
		margin: 0;
		display: flex;
		align-items: stretch;
		justify-content: center;
		flex-wrap: wrap;
		gap: 4px;
		row-gap: 8px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.prl-node {
		box-sizing: border-box;
		flex: 0 1 auto;
		min-width: 70px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2px;
		padding: 8px 7px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		text-align: center;
		transition:
			border-color 0.16s,
			background-color 0.16s,
			color 0.16s,
			box-shadow 0.16s;
	}
	/* Forward-referenced stages (CI, preview): dashed edge = "mechanics later". */
	.prl-node.is-later {
		border-style: dashed;
	}
	.prl-node.is-on {
		border: 1.5px solid var(--prl-blue);
		border-style: solid;
		background: color-mix(in srgb, var(--prl-blue) 13%, transparent);
		color: color-mix(in srgb, var(--prl-blue) 82%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--prl-blue) 13%, transparent);
	}

	.prl-step {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 16px;
		height: 16px;
		border-radius: 999px;
		font-size: 0.62rem;
		font-weight: 800;
		line-height: 1;
		color: var(--sl-color-gray-2);
		background: var(--sl-color-gray-5);
	}
	.prl-node.is-on .prl-step {
		color: var(--sl-color-white);
		background: color-mix(in srgb, var(--prl-blue) 80%, transparent);
	}

	.prl-label {
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1.15;
		white-space: nowrap;
	}
	.prl-mono {
		font-family:
			ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.73rem;
	}
	.prl-actor {
		font-size: 0.6rem;
		font-weight: 600;
		line-height: 1.15;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		opacity: 0.78;
		white-space: nowrap;
	}

	/* Connectors. Edges left of the active node light up so the strip reads as
	   progress through the pipeline rather than a static chain. */
	.prl-arrow {
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.16s;
	}
	.prl-arrow.is-on {
		color: var(--prl-blue);
	}
	.prl-arrow svg {
		width: 16px;
		height: 14px;
	}

	/* Narrow viewports: the strip already wraps; shrink the gaps a touch. */
	@media (max-width: 560px) {
		.prl {
			gap: 3px;
		}
		.prl-node {
			min-width: 64px;
			padding: 7px 5px;
		}
	}
</style>
