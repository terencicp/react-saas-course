---
// Before/after of the interactive rebase taught just above: the five scrappy
// commits of feat/invoice-status collapsing into two that read as a logical
// change. Two tabs (Before / After), each a vertical commit-graph column with
// newest at the top to match `git log --oneline` reading order — the reverse
// of the rebase-todo buffer, where oldest is at the top.
//
// Each node reuses the lesson's "snapshot box" idiom (short hash + subject)
// joined by downward connectors, echoing ReflogPointerMotion's node styling.
// "Before" nodes carry a verb tag (drop / fixup / reword / pick) so the reader
// can map this graph back to the rebase-todo verbs; the noise commits are
// dimmed to make the signal-to-noise contrast visible at a glance. "After"
// nodes are clean and emphasized.
//
// Pure HTML + CSS inside TabbedContent (which provides its own figure card, so
// no <Figure> wrapper). Vertical column keeps height modest and reads like a
// log; collapses gracefully on narrow viewports.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

// Newest first, to read like `git log --oneline`.
const before = [
  { hash: "b2e8a14", subject: "debug logging, remove later", verb: "drop", tone: "drop", noise: true },
  { hash: "9f2c1ab", subject: "fix typo in label", verb: "fixup", tone: "fold", noise: true },
  { hash: "7c4d2e9", subject: "fix", verb: "reword", tone: "edit", noise: true },
  { hash: "3d8e4c7", subject: "wip", verb: "fixup", tone: "fold", noise: true },
  { hash: "a1b9f02", subject: "Add invoice status filter", verb: "pick", tone: "keep", noise: false },
];

const after = [
  { hash: "c1f3a07", subject: "Validate the status filter against allowed values" },
  { hash: "e4d9b21", subject: "Add invoice status filter" },
];
---

<TabbedContent>
  <TabbedItem
    label="Before"
    caption="Five commits as they were actually written — honest, but noise for a reviewer."
  >
    <div class="rba not-content">
      <ol class="rba-col" aria-label="Branch history before rebase, newest first">
        {
          before.map((c) => (
            <li class={`rba-node${c.noise ? " is-noise" : ""}`}>
              <span class={`rba-verb rba-verb-${c.tone}`}>{c.verb}</span>
              <span class="rba-hash">{c.hash}</span>
              <span class="rba-subject">{c.subject}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </TabbedItem>

  <TabbedItem
    label="After"
    caption="After rebase -i: two commits that read as a logical change. Same final code, a history a reviewer can follow."
  >
    <div class="rba not-content">
      <ol class="rba-col" aria-label="Branch history after rebase, newest first">
        {
          after.map((c) => (
            <li class="rba-node is-clean">
              <span class="rba-hash">{c.hash}</span>
              <span class="rba-subject">{c.subject}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </TabbedItem>
</TabbedContent>

<style>
  .rba {
    --rba-green: #16a34a;
    --rba-blue: #2563eb;
    --rba-amber: #d97706;
    --rba-red: #dc2626;

    display: flex;
    justify-content: center;
    width: 100%;
    padding: 4px 0;
  }

  /* Vertical commit column, newest at the top (reads like git log). */
  .rba-col {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    max-width: 460px;
  }

  .rba-node {
    position: relative;
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: baseline;
    column-gap: 10px;
    padding: 12px 14px;
    border-radius: 10px;
    background: var(--sl-color-bg);
    border: 2px solid var(--sl-color-gray-4);
  }

  /* Downward connector between snapshots (child -> parent). */
  .rba-node:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 26px;
    bottom: -14px;
    width: 2px;
    height: 14px;
    background: var(--sl-color-gray-4);
    z-index: 0;
  }
  /* Stack vertical gaps so the connectors have room. */
  .rba-node + .rba-node {
    margin-top: 14px;
  }

  /* Verb tag, color-coded to the rebase-todo verb actions above. */
  .rba-verb {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    padding: 4px 7px;
    border-radius: 6px;
    color: #fff;
    white-space: nowrap;
  }
  .rba-verb-keep { background: var(--rba-green); }
  .rba-verb-fold { background: var(--rba-amber); }
  .rba-verb-edit { background: var(--rba-blue); }
  .rba-verb-drop { background: var(--rba-red); }

  .rba-hash {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--sl-color-gray-3);
  }

  .rba-subject {
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--sl-color-white);
  }

  /* Noise commits read dimmer so the one real "Before" commit stands out. */
  .rba-node.is-noise {
    opacity: 0.62;
    border-style: dashed;
  }
  /* The surviving feature commit in "Before" — solid and full strength. */
  .rba-node:not(.is-noise) {
    opacity: 1;
  }

  /* Clean "After" nodes: no verb column, green emphasis. */
  .rba-node.is-clean {
    grid-template-columns: auto 1fr;
    border-color: color-mix(in srgb, var(--rba-green) 55%, var(--sl-color-gray-4));
    background: color-mix(in srgb, var(--rba-green) 7%, var(--sl-color-bg));
  }
  .rba-node.is-clean::after {
    background: color-mix(in srgb, var(--rba-green) 55%, var(--sl-color-gray-4));
  }

  @media (max-width: 460px) {
    .rba-node {
      grid-template-columns: auto 1fr;
      row-gap: 4px;
    }
    .rba-verb {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
</style>
