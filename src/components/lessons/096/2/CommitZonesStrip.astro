---
// Compact reference strip for the three "where does this commit live?"
// zones, laid out left-to-right from most mutable to immutable:
//   1. Local only        — freely mutable  (green)
//   2. Pushed feature br. — mutable w/ care (amber)
//   3. Merged to main     — immutable       (red, locked)
// Each panel stacks: the zone heading, a one-line "who has it", and an
// allowed-move pill pinned to the bottom. Panel 3 carries a lock glyph
// to reinforce immutability. The trio forms a gradient that encodes the
// single decision the lesson revolves around.
//
// Pure HTML + CSS. `margin: 0` reset on every inner element to defeat
// Starlight's prose-margin selector. Saturated mid-tone fills with white
// text read in both light and dark themes; same palette idiom as the
// chapter's other reference strips. Collapses to one column on narrow
// viewports so no pill ever clips.

import { Icon } from "astro-icon/components";

const reset = "margin: 0";

const root = [
  reset,
  "display: grid",
  "grid-template-columns: repeat(3, minmax(0, 1fr))",
  "column-gap: 10px",
  "row-gap: 10px",
  "width: 100%",
  "padding: 0",
  "box-sizing: border-box",
].join("; ");

const cellBase = [
  reset,
  "min-width: 0",
  "position: relative",
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
  "padding: 16px 16px 16px",
  "border-radius: 12px",
  "color: #ffffff",
  "box-sizing: border-box",
].join("; ");

const stageStyle = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.1em",
  "text-transform: uppercase",
  "line-height: 1",
  "opacity: 0.85",
].join("; ");

const headingStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 16px",
  "font-weight: 700",
  "line-height: 1.2",
].join("; ");

const whoStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 13px",
  "font-weight: 500",
  "line-height: 1.4",
  "opacity: 0.95",
].join("; ");

const moveLabelStyle = [
  reset,
  "margin-top: 6px",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 10px",
  "font-weight: 600",
  "letter-spacing: 0.07em",
  "text-transform: uppercase",
  "line-height: 1",
  "opacity: 0.8",
].join("; ");

const pillStyle = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "gap: 6px",
  "align-self: flex-start",
  "max-width: 100%",
  "padding: 6px 10px",
  "border-radius: 8px",
  "background: rgba(255, 255, 255, 0.2)",
  "border: 1px solid rgba(255, 255, 255, 0.35)",
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1.3",
  "color: #ffffff",
].join("; ");

const monoStyle = [
  reset,
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
  "font-size: 12px",
  "font-weight: 600",
].join("; ");

const lockStyle = [
  reset,
  "position: absolute",
  "top: 14px",
  "right: 14px",
  "opacity: 0.9",
].join("; ");
---

<div class="not-content commit-zones" style={root}>
  {/* Zone 1 — local only: freely mutable (green-600) */}
  <div style={`${cellBase}; background: #16a34a;`}>
    <span style={stageStyle}>Freely mutable</span>
    <span style={headingStyle}>Local only</span>
    <span style={whoStyle}>Only on your machine</span>
    <div style="flex: 1 1 auto; min-height: 0; margin: 0;"></div>
    <span style={moveLabelStyle}>Allowed move</span>
    <span style={pillStyle}>Rewrite freely</span>
  </div>

  {/* Zone 2 — pushed feature branch: mutable with care (amber-600) */}
  <div style={`${cellBase}; background: #d97706;`}>
    <span style={stageStyle}>Mutable with care</span>
    <span style={headingStyle}>Pushed to my feature branch</span>
    <span style={whoStyle}>On the remote, on your branch</span>
    <div style="flex: 1 1 auto; min-height: 0; margin: 0;"></div>
    <span style={moveLabelStyle}>Allowed move</span>
    <span style={pillStyle}>
      Rewrite, then <span style={monoStyle}>--force-with-lease</span>
    </span>
  </div>

  {/* Zone 3 — merged to main: immutable (red-600) */}
  <div style={`${cellBase}; background: #dc2626;`}>
    <Icon name="lucide:lock" size={20} style={lockStyle} />
    <span style={stageStyle}>Immutable</span>
    <span style={headingStyle}>
      Merged to <span style={monoStyle}>main</span>
    </span>
    <span style={whoStyle}>Everyone has pulled it</span>
    <div style="flex: 1 1 auto; min-height: 0; margin: 0;"></div>
    <span style={moveLabelStyle}>Allowed move</span>
    <span style={pillStyle}>
      <span style={monoStyle}>git revert</span> only — never rewrite
    </span>
  </div>
</div>

<style>
  /* Drop to a single column on narrow viewports — only three cells, so no
     orphan-row situation arises and every pill stays intact. */
  @media (max-width: 620px) {
    .commit-zones {
      grid-template-columns: 1fr !important;
    }
  }
</style>
