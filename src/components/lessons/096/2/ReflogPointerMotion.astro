---
// Four-step scrub showing that `reset --hard` only moves pointers, never
// deletes snapshots — and that the reflog remembers the abandoned hash so a
// second reset brings everything back. Drives a <DiagramSequence>:
//
//   1. A <- B <- C, HEAD + branch both on C, all solid.       (work present)
//   2. reset --hard HEAD~2 slides both pointers back to A;     (pointer moved)
//      B and C lose their label, drawn dimmed + dashed but still on disk.
//   3. Same dimmed graph + a reflog panel; C's hash highlighted to show the
//      snapshot is still listed, only unreferenced.
//   4. reset --hard <C's hash> returns both pointers to C;     (work back)
//      B and C are solid again.
//
// The commit graph is a flex row of node "snapshots" (boxes) joined by
// connector arrows, with pointer pills (HEAD, the branch) floated above the
// node they target. Reuses the "node = snapshot, label = pointer" language
// from the lesson and the saturated-mid-tone palette of CommitZonesStrip.
//
// Pure HTML + CSS, scoped <style>. The graph keeps a fixed three-column
// width across every step so the stage never reflows as the reader scrubs;
// the pointer pills just slide between columns and the dimmed state is a
// class toggle, no layout change.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

// Per-commit short hashes, shown under each node and echoed in the reflog
// panel so "this snapshot, by this hash" is the same object across steps.
const HASHES = ["7c4d2e9", "a1b9f02", "3d8e4c7"];
---

<DiagramSequence>
  {/* ---- Step 1: at C, everything present -------------------------------- */}
  <DiagramStep caption="You're at commit C, on branch feat/invoice-status — B and C hold your latest work.">
    <div class="rpm not-content">
      <div class="rpm-graph">
        <div class="rpm-pointers">
          <span class="rpm-ptr rpm-ptr-branch" data-col="2">feat/invoice-status</span>
          <span class="rpm-ptr rpm-ptr-head" data-col="2">HEAD</span>
        </div>
        <div class="rpm-row">
          <div class="rpm-node"><span class="rpm-node-id">A</span><span class="rpm-hash">{HASHES[0]}</span></div>
          <div class="rpm-link"></div>
          <div class="rpm-node"><span class="rpm-node-id">B</span><span class="rpm-hash">{HASHES[1]}</span></div>
          <div class="rpm-link"></div>
          <div class="rpm-node"><span class="rpm-node-id">C</span><span class="rpm-hash">{HASHES[2]}</span></div>
        </div>
      </div>
    </div>
  </DiagramStep>

  {/* ---- Step 2: reset --hard HEAD~2 — pointers slide to A --------------- */}
  <DiagramStep>
    <div class="rpm not-content">
      <div class="rpm-cmd"><span class="rpm-prompt">$</span> git reset --hard HEAD~2</div>
      <div class="rpm-graph">
        <div class="rpm-pointers">
          <span class="rpm-ptr rpm-ptr-branch" data-col="0">feat/invoice-status</span>
          <span class="rpm-ptr rpm-ptr-head" data-col="0">HEAD</span>
        </div>
        <div class="rpm-row">
          <div class="rpm-node"><span class="rpm-node-id">A</span><span class="rpm-hash">{HASHES[0]}</span></div>
          <div class="rpm-link is-dim"></div>
          <div class="rpm-node is-dangling"><span class="rpm-node-id">B</span><span class="rpm-hash">{HASHES[1]}</span></div>
          <div class="rpm-link is-dim"></div>
          <div class="rpm-node is-dangling"><span class="rpm-node-id">C</span><span class="rpm-hash">{HASHES[2]}</span></div>
        </div>
      </div>
    </div>
    <Fragment slot="caption">
      The pointers slid back to A. B and C lost their label — but they're <strong>still on disk</strong>, just dimmed and unreferenced.
    </Fragment>
  </DiagramStep>

  {/* ---- Step 3: the reflog still lists C by hash ------------------------ */}
  <DiagramStep>
    <div class="rpm not-content">
      <div class="rpm-split">
        <div class="rpm-graph">
          <div class="rpm-pointers">
            <span class="rpm-ptr rpm-ptr-branch" data-col="0">feat/invoice-status</span>
            <span class="rpm-ptr rpm-ptr-head" data-col="0">HEAD</span>
          </div>
          <div class="rpm-row">
            <div class="rpm-node"><span class="rpm-node-id">A</span><span class="rpm-hash">{HASHES[0]}</span></div>
            <div class="rpm-link is-dim"></div>
            <div class="rpm-node is-dangling"><span class="rpm-node-id">B</span><span class="rpm-hash">{HASHES[1]}</span></div>
            <div class="rpm-link is-dim"></div>
            <div class="rpm-node is-dangling"><span class="rpm-node-id">C</span><span class="rpm-hash">{HASHES[2]}</span></div>
          </div>
        </div>
        <div class="rpm-reflog" aria-label="git reflog output">
          <div class="rpm-reflog-title">git reflog</div>
          <div class="rpm-reflog-line">
            <span class="rpm-reflog-hash">{HASHES[0]}</span>
            <span class="rpm-reflog-ref">HEAD@&#123;0&#125;</span>
            <span class="rpm-reflog-msg">reset: moving to HEAD~2</span>
          </div>
          <div class="rpm-reflog-line is-target">
            <span class="rpm-reflog-hash">{HASHES[2]}</span>
            <span class="rpm-reflog-ref">HEAD@&#123;1&#125;</span>
            <span class="rpm-reflog-msg">commit: C</span>
          </div>
        </div>
      </div>
    </div>
    <Fragment slot="caption">
      The reflog still lists C by its hash <code>{HASHES[2]}</code>. The snapshot was never deleted — only unreferenced.
    </Fragment>
  </DiagramStep>

  {/* ---- Step 4: reset to C's hash — work is back ------------------------ */}
  <DiagramStep>
    <div class="rpm not-content">
      <div class="rpm-cmd"><span class="rpm-prompt">$</span> git reset --hard {HASHES[2]}</div>
      <div class="rpm-graph">
        <div class="rpm-pointers">
          <span class="rpm-ptr rpm-ptr-branch" data-col="2">feat/invoice-status</span>
          <span class="rpm-ptr rpm-ptr-head" data-col="2">HEAD</span>
        </div>
        <div class="rpm-row">
          <div class="rpm-node"><span class="rpm-node-id">A</span><span class="rpm-hash">{HASHES[0]}</span></div>
          <div class="rpm-link"></div>
          <div class="rpm-node"><span class="rpm-node-id">B</span><span class="rpm-hash">{HASHES[1]}</span></div>
          <div class="rpm-link"></div>
          <div class="rpm-node is-restored"><span class="rpm-node-id">C</span><span class="rpm-hash">{HASHES[2]}</span></div>
        </div>
      </div>
    </div>
    <Fragment slot="caption">
      Reset to that hash and both pointers return to C. Nothing was ever deleted — the pointer just moved, and the reflog remembered where. Your work is back.
    </Fragment>
  </DiagramStep>
</DiagramSequence>

<style>
  .rpm {
    --rpm-green: #16a34a;
    --rpm-blue: #2563eb;
    --rpm-col: 96px; /* node width */
    --rpm-gap: 34px; /* connector width */

    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    width: 100%;
  }

  /* Command echo above the graph, terminal-flavored. */
  .rpm-cmd {
    align-self: stretch;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 13px;
    font-weight: 600;
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6, var(--sl-color-bg));
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    padding: 7px 12px;
  }
  .rpm-prompt {
    color: var(--rpm-green);
    margin-right: 6px;
    font-weight: 700;
  }

  /* Two-column layout for step 3 (graph + reflog panel). Wraps on narrow. */
  .rpm-split {
    display: flex;
    flex-wrap: wrap;
    gap: 20px 28px;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  /* ---- Commit graph ---------------------------------------------------- */
  .rpm-graph {
    flex: 0 0 auto;
  }

  /* Pointer pills float above the node row, each translated to its column. */
  .rpm-pointers {
    position: relative;
    height: 56px;
  }
  .rpm-ptr {
    position: absolute;
    /* Anchor at the center of column 0 (half a node in), then translateX by
       whole columns; the -50% keeps the auto-width pill centered on the node
       it points at, so the full branch name never gets clipped. */
    left: calc(var(--rpm-col) / 2);
    text-align: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    padding: 4px 8px;
    border-radius: 6px;
    color: #fff;
    white-space: nowrap;
    transition: transform 0.25s ease;
  }
  /* Column offset = col * (node width + connector width), centered (-50%). */
  .rpm-ptr[data-col="0"] { transform: translateX(-50%); }
  .rpm-ptr[data-col="1"] { transform: translateX(calc(-50% + var(--rpm-col) + var(--rpm-gap))); }
  .rpm-ptr[data-col="2"] { transform: translateX(calc(-50% + (var(--rpm-col) + var(--rpm-gap)) * 2)); }

  .rpm-ptr-head {
    top: 26px;
    background: var(--rpm-blue);
  }
  .rpm-ptr-branch {
    top: 0;
    background: var(--rpm-green);
  }
  /* Little stem connecting each pill down toward its node. */
  .rpm-ptr::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -8px;
    width: 2px;
    height: 8px;
    transform: translateX(-50%);
    background: currentColor;
    opacity: 0.55;
  }

  .rpm-row {
    display: flex;
    align-items: center;
  }

  .rpm-node {
    width: var(--rpm-col);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 12px 6px;
    border-radius: 10px;
    background: var(--sl-color-bg);
    border: 2px solid var(--sl-color-gray-4);
    transition: opacity 0.25s ease, border-color 0.25s ease, border-style 0.25s ease;
  }
  .rpm-node-id {
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    font-size: 20px;
    font-weight: 800;
    line-height: 1;
    color: var(--sl-color-white);
  }
  .rpm-hash {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--sl-color-gray-3);
  }

  /* Dangling: snapshot still drawn, but detached — dashed border, dimmed. */
  .rpm-node.is-dangling {
    opacity: 0.4;
    border-style: dashed;
    border-color: var(--sl-color-gray-4);
  }
  /* Restored node gets a brief emphasis ring so the "it's back" reads. */
  .rpm-node.is-restored {
    border-color: var(--rpm-green);
  }

  /* Connector arrow between snapshots (parent <- child). */
  .rpm-link {
    width: var(--rpm-gap);
    height: 2px;
    background: var(--sl-color-gray-4);
    position: relative;
    transition: opacity 0.25s ease;
  }
  .rpm-link::before {
    /* Arrowhead pointing left, toward the parent (Git's pointer direction). */
    content: "";
    position: absolute;
    left: -1px;
    top: 50%;
    transform: translateY(-50%);
    border: 5px solid transparent;
    border-right-color: var(--sl-color-gray-4);
  }
  .rpm-link.is-dim {
    opacity: 0.3;
  }

  /* ---- Reflog panel (step 3) ------------------------------------------- */
  .rpm-reflog {
    flex: 0 0 auto;
    min-width: 0;
    background: var(--sl-color-gray-6, var(--sl-color-bg));
    border: 1px solid var(--sl-color-hairline);
    border-radius: 10px;
    padding: 12px 14px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    line-height: 1;
  }
  .rpm-reflog-title {
    font-size: 11px;
    font-weight: 700;
    color: var(--sl-color-gray-3);
    margin-bottom: 10px;
  }
  .rpm-reflog-line {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 5px 6px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .rpm-reflog-line + .rpm-reflog-line {
    margin-top: 2px;
  }
  .rpm-reflog-hash {
    font-weight: 700;
    color: var(--sl-color-gray-3);
  }
  .rpm-reflog-ref {
    color: var(--sl-color-gray-4);
  }
  .rpm-reflog-msg {
    color: var(--sl-color-white);
  }
  /* The line whose hash brings C back, highlighted green. */
  .rpm-reflog-line.is-target {
    background: color-mix(in srgb, var(--rpm-green) 18%, transparent);
    outline: 1px solid color-mix(in srgb, var(--rpm-green) 55%, transparent);
  }
  .rpm-reflog-line.is-target .rpm-reflog-hash {
    color: var(--rpm-green);
  }

  @media (max-width: 520px) {
    .rpm {
      --rpm-col: 76px;
      --rpm-gap: 26px;
    }
  }
</style>
