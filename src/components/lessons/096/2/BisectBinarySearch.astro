---
// Five-step scrub of `git bisect`'s binary search over a row of 16 commit
// dots laid left (oldest) to right (newest). Drives a <DiagramSequence>:
//
//   1. Endpoints fixed: #1 green (known good baseline), #16 red (HEAD,
//      broken now), the 14 dots between grey/unknown.
//   2. Git checks out the midpoint of the suspect window (#8) — a ring marks
//      "the commit being tested right now"; the student runs the test.
//   3. #8 was good → 1..8 turn green, the suspect window halves to 9..15 and
//      the new midpoint (#12) gets the ring.
//   4. #12 was bad → 12..16 turn red, the window halves to 9..11 and the
//      midpoint (#10) gets the ring.
//   5. The search lands on a single culprit (#10), neighbours resolved green
//      (#9) / red (#11). Four tests, sixteen commits — log2(N), not N.
//
// Each step shows the same 16-column row plus a fixed legend and a
// "suspects left" badge that shrinks (14 -> 7 -> 3 -> 1), making the
// halving quantitative. The row is a fixed-width flex grid so the stage
// never reflows as the reader scrubs; per-step state is pure class swaps.
//
// Pure HTML + CSS, scoped <style>. Reuses the saturated-mid-tone palette and
// the "node = commit" language from the chapter's other figures.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

const N = 16;
const indices = Array.from({ length: N }, (_, i) => i + 1);

// Per-step state for each commit dot. Keys are 1-based commit numbers; any
// dot not listed in a step is "unknown" (grey). `ring` marks the commit Git
// is currently testing; `cul` marks the final culprit.
type Dot = "good" | "bad" | "ring-good" | "ring-bad" | "cul";

const steps: {
  state: Record<number, Dot>;
  suspects: number;
  caption: string;
}[] = [
  // Step 1 — endpoints only.
  {
    state: { 1: "good", 16: "bad" },
    suspects: 14,
    caption:
      "Sixteen commits between a known-good baseline and the broken present. The bug is in one of the grey, untested dots.",
  },
  // Step 2 — testing the midpoint (#8) of 2..15.
  {
    state: { 1: "good", 8: "ring-good", 16: "bad" },
    suspects: 14,
    caption:
      "Git checks out the midpoint, #8, and asks: good or bad? You run the test. Say it still passes — #8 is good.",
  },
  // Step 3 — #8 good, window 9..15, testing midpoint (#12).
  {
    state: {
      1: "good", 2: "good", 3: "good", 4: "good", 5: "good", 6: "good",
      7: "good", 8: "good", 12: "ring-bad", 16: "bad",
    },
    suspects: 7,
    caption:
      "Good — so the break is newer than #8, and everything up to it clears. Suspects halved. Test the midpoint of what's left, #12.",
  },
  // Step 4 — #12 bad, window 9..11, testing midpoint (#10).
  {
    state: {
      1: "good", 2: "good", 3: "good", 4: "good", 5: "good", 6: "good",
      7: "good", 8: "good", 10: "ring-good", 12: "bad", 13: "bad",
      14: "bad", 15: "bad", 16: "bad",
    },
    suspects: 3,
    caption:
      "Bad — the break is at or before #12, so everything from it on is tainted. Halve again. Three suspects left; test #10.",
  },
  // Step 5 — culprit isolated at #10.
  {
    state: {
      1: "good", 2: "good", 3: "good", 4: "good", 5: "good", 6: "good",
      7: "good", 8: "good", 9: "good", 10: "cul", 11: "bad", 12: "bad",
      13: "bad", 14: "bad", 15: "bad", 16: "bad",
    },
    suspects: 1,
    caption:
      "#10 is the first bad commit — #9 still passes, #10 fails. Four tests, sixteen commits, one culprit: that's log₂(N), not N. The reason you never bisect by hand.",
  },
];

function dotClass(dot: Dot | undefined): string {
  switch (dot) {
    case "good":
      return "is-good";
    case "bad":
      return "is-bad";
    case "ring-good":
      return "is-good is-ring";
    case "ring-bad":
      return "is-bad is-ring";
    case "cul":
      return "is-cul is-ring";
    default:
      return "is-unknown";
  }
}
---

<DiagramSequence>
  {
    steps.map((step) => (
      <DiagramStep caption={step.caption}>
        <div class="bbs not-content">
          {/* Legend — fixed across every step. */}
          <div class="bbs-legend">
            <span class="bbs-key"><span class="bbs-swatch is-good" /> known good</span>
            <span class="bbs-key"><span class="bbs-swatch is-bad" /> known bad</span>
            <span class="bbs-key"><span class="bbs-swatch is-unknown" /> untested</span>
            <span class="bbs-key"><span class="bbs-swatch is-ring" /> testing now</span>
          </div>

          {/* The 16-commit row, oldest (left) to newest (right). */}
          <div class="bbs-rail">
            <span class="bbs-axis bbs-axis-l">oldest</span>
            <div class="bbs-row">
              {indices.map((i) => (
                <div class:list={["bbs-dot", dotClass(step.state[i])]}>
                  <span class="bbs-num">{i}</span>
                </div>
              ))}
            </div>
            <span class="bbs-axis bbs-axis-r">newest</span>
          </div>

          {/* Endpoint captions sit under the two fixed ends. */}
          <div class="bbs-ends">
            <span class="bbs-end is-good-text">#1 — known good (last week)</span>
            <span class="bbs-end is-bad-text">#16 — HEAD, broken now</span>
          </div>

          {/* Suspects-remaining badge — the quantitative halving. */}
          <div class="bbs-meter">
            <span class="bbs-meter-num">{step.suspects}</span>
            <span class="bbs-meter-label">
              suspect{step.suspects === 1 ? "" : "s"} left
            </span>
          </div>
        </div>
      </DiagramStep>
    ))
  }
</DiagramSequence>

<style>
  .bbs {
    --bbs-good: #16a34a;
    --bbs-bad: #dc2626;
    --bbs-ring: #2563eb;
    --bbs-dot: 30px;

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    width: 100%;
  }

  /* ---- Legend --------------------------------------------------------- */
  .bbs-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 18px;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }
  .bbs-key {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .bbs-swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    box-sizing: border-box;
    flex: 0 0 auto;
  }
  .bbs-swatch.is-good {
    background: var(--bbs-good);
  }
  .bbs-swatch.is-bad {
    background: var(--bbs-bad);
  }
  .bbs-swatch.is-unknown {
    background: var(--sl-color-bg);
    border: 2px solid var(--sl-color-gray-4);
  }
  .bbs-swatch.is-ring {
    background: var(--sl-color-bg);
    border: 2px solid var(--bbs-ring);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--bbs-ring) 35%, transparent);
  }

  /* ---- Commit rail ---------------------------------------------------- */
  .bbs-rail {
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 100%;
  }
  .bbs-axis {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
  }
  .bbs-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bbs-dot {
    width: var(--bbs-dot);
    height: var(--bbs-dot);
    flex: 0 0 auto;
    border-radius: 50%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--sl-color-gray-4);
    background: var(--sl-color-bg);
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }
  .bbs-num {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    color: var(--sl-color-gray-3);
  }

  .bbs-dot.is-unknown {
    background: var(--sl-color-bg);
    border-color: var(--sl-color-gray-4);
  }
  .bbs-dot.is-good {
    background: var(--bbs-good);
    border-color: var(--bbs-good);
  }
  .bbs-dot.is-bad {
    background: var(--bbs-bad);
    border-color: var(--bbs-bad);
  }
  .bbs-dot.is-good .bbs-num,
  .bbs-dot.is-bad .bbs-num {
    color: #fff;
  }

  /* Testing ring — a blue halo on the commit Git is checking right now. */
  .bbs-dot.is-ring {
    transform: scale(1.18);
    box-shadow:
      0 0 0 3px var(--sl-color-bg),
      0 0 0 6px var(--bbs-ring);
  }

  /* Final culprit — amber fill so it reads as the answer, with the ring. */
  .bbs-dot.is-cul {
    background: #d97706;
    border-color: #d97706;
  }
  .bbs-dot.is-cul .bbs-num {
    color: #fff;
  }

  /* ---- Endpoint labels ------------------------------------------------ */
  .bbs-ends {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    max-width: 560px;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
  }
  .bbs-end {
    line-height: 1.3;
  }
  .bbs-end.is-good-text {
    color: var(--bbs-good);
  }
  .bbs-end.is-bad-text {
    color: var(--bbs-bad);
    text-align: right;
  }

  /* ---- Suspects-remaining meter --------------------------------------- */
  .bbs-meter {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--sl-color-gray-6, var(--sl-color-bg));
    border: 1px solid var(--sl-color-hairline);
  }
  .bbs-meter-num {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
    color: var(--sl-color-white);
  }
  .bbs-meter-label {
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  /* Narrow viewports: shrink the dots and drop the axis words so the full
     16-dot row still fits without horizontal scroll. */
  @media (max-width: 640px) {
    .bbs {
      --bbs-dot: 22px;
    }
    .bbs-row {
      gap: 5px;
    }
    .bbs-num {
      font-size: 9px;
    }
    .bbs-axis {
      display: none;
    }
  }
</style>
