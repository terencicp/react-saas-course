---
// One frame of the rebase-vs-merge sequence, drawn as a hand-positioned commit
// graph so the *motion* across the three DiagramSequence steps reads cleanly:
// the same commits keep the same coordinates frame-to-frame, and the feature
// commits visibly lift off the old fork and replay on main's tip. A Mermaid
// gitGraph would re-lay-out every frame and snap, killing the "lift and replay"
// read; hand-positioned nodes are what make the animation legible.
//
// Three frames, selected by `step`:
//   1 Divergence — main gained C4·C5 (teammates) after you forked at C2; your
//                  feature branch (a1·b2) still hangs off the old commit.
//   2 Merge      — a two-parent merge commit M joins the two lines on main; both
//                  histories are preserved, a1·b2 keep their original hashes.
//   3 Rebase     — a1·b2 are replayed onto C5 as NEW commits a1'·b2' (orange,
//                  "new hashes"); the originals are ghosted to show they were
//                  copied-and-abandoned, with a lift arrow from old to new.
//
// All three frames share one fixed-size canvas (relative box + absolutely
// positioned nodes over an SVG edge layer) so the DiagramSequence stage, which
// sizes to the tallest step, never reflows as the reader scrubs.
//
// Pure HTML + CSS + inline SVG, devtools-inspectable, matching the chapter's
// sibling figures (CnPipeline et al.): `not-content` + a margin reset defeat
// Starlight's prose-margin injection; Starlight gray/white variables flip the
// chrome with light/dark; --mark-* accents (custom.css) flip too. Blue = main,
// green = your feature branch, orange = the replayed (new-hash) commits. Red is
// deliberately avoided so nothing reads as an error.

interface Props {
  /** Which frame of the sequence to draw, 1-3. */
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

// Fixed canvas. Every frame paints into the same box so nodes that don't move
// stay pinned and the eye tracks the ones that do.
const W = 560;
const H = 230;

// The in-flow SVG (with width/height *attributes*) is what gives this block its
// intrinsic size, so the DiagramSequence grid cell — which sizes to content —
// resolves to a real width instead of collapsing to 0. The wrapper just hosts
// the absolutely-positioned HTML ref labels over the SVG; max-width on the SVG
// keeps it fluid on narrow viewports.
const wrap = [
  "margin: 0",
  "position: relative",
  "display: block",
  `max-width: ${W}px`,
  "margin-inline: auto",
  "box-sizing: border-box",
].join("; ");

// --- geometry -------------------------------------------------------------
// Two lanes: main on top, feature below. Columns are evenly spaced so commits
// line up across frames.
const yMain = 64;
const yFeat = 168;
const col = (i: number) => 70 + i * 74; // column x for index i

// main commits: C2 is the fork point, C4·C5 are the teammates' new work.
const mainNodes = [
  { id: "C2", x: col(0), label: "C2", role: "fork" },
  { id: "C4", x: col(1), label: "C4", role: "main" },
  { id: "C5", x: col(2), label: "C5", role: "main" },
];
const forkX = col(0);
const tipX = col(2);

// The merge commit (step 2) and the two replayed commits (step 3) land just past
// the main tip: one column ahead for the first replayed commit, two for the
// merge / second replayed commit. Derived from tipX so they stay adjacent to the
// main lane no matter how many commits it has.
const replayMidX = tipX + 74;
const replayTipX = tipX + 148;

const R = 16; // node radius

// Where the `main` ref label sits — over the rightmost node on the main lane:
// C5 in step 1, the merge commit M in step 2, the replayed b2' in step 3.
const mainTipX = step === 1 ? tipX : replayTipX;

// Where the `feat/invoice-status` ref label sits — under the original green
// commits in steps 1-2, on the replayed tip (orange) in step 3.
const featRefX = step === 3 ? replayTipX : col(2);
const featRefY = step === 3 ? yMain + R + 10 : yFeat + R + 8;

// --- node / edge styling --------------------------------------------------
type Tone = "main" | "feat" | "replay" | "ghost" | "merge";

const nodeFill: Record<Tone, string> = {
  main: "var(--mark-blue-bg)",
  feat: "var(--mark-green-bg)",
  replay: "var(--mark-orange-bg)",
  ghost: "transparent",
  merge: "var(--mark-blue-bg)",
};
const nodeStroke: Record<Tone, string> = {
  main: "var(--mark-blue-brd)",
  feat: "var(--mark-green-brd)",
  replay: "var(--mark-orange-brd)",
  ghost: "var(--sl-color-gray-4)",
  merge: "var(--mark-blue-brd)",
};
const edgeColor = {
  main: "var(--mark-blue-brd)",
  feat: "var(--mark-green-brd)",
  replay: "var(--mark-orange-brd)",
  ghost: "var(--sl-color-gray-4)",
};

// A branch-name label pill (like Git's ref labels).
const refLabel = (color: "blue" | "green" | "orange") =>
  [
    "margin: 0",
    sans,
    "position: absolute",
    "transform: translate(-50%, 0)",
    "font-size: 12px",
    "font-weight: 700",
    "line-height: 1",
    "padding: 4px 8px",
    "border-radius: 6px",
    "white-space: nowrap",
    "color: var(--sl-color-white)",
    `background: var(--mark-${color}-bg)`,
    `border: 1.5px solid var(--mark-${color}-brd)`,
  ].join("; ");

const commitText = [
  mono,
  "font-size: 12.5px",
  "font-weight: 700",
  "fill: var(--sl-color-white)",
].join("; ");

const ghostText = [
  mono,
  "font-size: 12px",
  "font-weight: 600",
  "fill: var(--sl-color-gray-3)",
].join("; ");
---

<div class="not-content rvm-root" style={wrap} data-step={step}>
  <svg
    width={W}
    height={H}
    viewBox={`0 0 ${W} ${H}`}
    preserveAspectRatio="xMidYMid meet"
    style="display: block; width: 100%; height: auto; overflow: visible;"
    role="presentation"
  >
    <defs>
      <marker
        id={`rvm-arrow-${step}`}
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="7"
        markerHeight="7"
        orient="auto-start-reverse"
      >
        <path d="M0,0 L10,5 L0,10 z" fill="var(--mark-orange-brd)" />
      </marker>
    </defs>

    {/* ---- main lane: C2 → C4 → C5 (all frames) ---- */}
    {
      mainNodes.slice(1).map((n, i) => (
        <line
          x1={mainNodes[i].x}
          y1={yMain}
          x2={n.x}
          y2={yMain}
          stroke={edgeColor.main}
          stroke-width="3"
        />
      ))
    }

    {/* ---- STEP 1: feature forks from C2, hangs below ---- */}
    {
      step === 1 && (
        <Fragment>
          <path
            d={`M ${forkX} ${yMain} C ${forkX} ${(yMain + yFeat) / 2}, ${col(1)} ${yFeat}, ${col(1)} ${yFeat}`}
            fill="none"
            stroke={edgeColor.feat}
            stroke-width="3"
          />
          <line
            x1={col(1)}
            y1={yFeat}
            x2={col(2)}
            y2={yFeat}
            stroke={edgeColor.feat}
            stroke-width="3"
          />
        </Fragment>
      )
    }

    {/* ---- STEP 2: feature still forks from C2; merge commit M joins b2 + C5 ---- */}
    {
      step === 2 && (
        <Fragment>
          <path
            d={`M ${forkX} ${yMain} C ${forkX} ${(yMain + yFeat) / 2}, ${col(1)} ${yFeat}, ${col(1)} ${yFeat}`}
            fill="none"
            stroke={edgeColor.feat}
            stroke-width="3"
          />
          <line
            x1={col(1)}
            y1={yFeat}
            x2={col(2)}
            y2={yFeat}
            stroke={edgeColor.feat}
            stroke-width="3"
          />
          {/* main parent edge: C5 → M */}
          <line
            x1={tipX}
            y1={yMain}
            x2={replayTipX}
            y2={yMain}
            stroke={edgeColor.main}
            stroke-width="3"
          />
          {/* feature parent edge: b2 → M */}
          <path
            d={`M ${col(2)} ${yFeat} C ${replayMidX} ${yFeat}, ${replayTipX} ${(yMain + yFeat) / 2}, ${replayTipX} ${yMain}`}
            fill="none"
            stroke={edgeColor.feat}
            stroke-width="3"
          />
        </Fragment>
      )
    }

    {/* ---- STEP 3: originals ghosted; a1'·b2' replayed on C5's tip in a line ---- */}
    {
      step === 3 && (
        <Fragment>
          {/* ghosted original fork */}
          <path
            d={`M ${forkX} ${yMain} C ${forkX} ${(yMain + yFeat) / 2}, ${col(1)} ${yFeat}, ${col(1)} ${yFeat}`}
            fill="none"
            stroke={edgeColor.ghost}
            stroke-width="2"
            stroke-dasharray="4 4"
          />
          <line
            x1={col(1)}
            y1={yFeat}
            x2={col(2)}
            y2={yFeat}
            stroke={edgeColor.ghost}
            stroke-width="2"
            stroke-dasharray="4 4"
          />
          {/* replayed commits in a straight line off C5 */}
          <line
            x1={tipX}
            y1={yMain}
            x2={replayTipX}
            y2={yMain}
            stroke={edgeColor.replay}
            stroke-width="3"
          />
          {/* lift-and-replay arrows from ghosts up to the new commits */}
          <path
            d={`M ${col(1)} ${yFeat - R - 4} C ${col(2)} ${yFeat - 50}, ${replayMidX} ${yMain + 50}, ${replayMidX} ${yMain + R + 6}`}
            fill="none"
            stroke="var(--mark-orange-brd)"
            stroke-width="2"
            stroke-dasharray="2 5"
            stroke-linecap="round"
            marker-end={`url(#rvm-arrow-${step})`}
          />
          <path
            d={`M ${col(2)} ${yFeat - R - 4} C ${col(3)} ${yFeat - 40}, ${replayTipX} ${yMain + 50}, ${replayTipX} ${yMain + R + 6}`}
            fill="none"
            stroke="var(--mark-orange-brd)"
            stroke-width="2"
            stroke-dasharray="2 5"
            stroke-linecap="round"
            marker-end={`url(#rvm-arrow-${step})`}
          />
        </Fragment>
      )
    }

    {/* ---- nodes ---- */}
    {/* main commits, every frame */}
    {
      mainNodes.map((n) => (
        <Fragment>
          <circle
            cx={n.x}
            cy={yMain}
            r={R}
            fill={nodeFill.main}
            stroke={nodeStroke.main}
            stroke-width="2.5"
          />
          <text
            x={n.x}
            y={yMain + 1}
            text-anchor="middle"
            dominant-baseline="middle"
            style={commitText}
          >
            {n.label}
          </text>
        </Fragment>
      ))
    }

    {/* STEP 1 + 2: original feature commits a1·b2 (green) */}
    {
      (step === 1 || step === 2) && (
        <Fragment>
          {[
            { x: col(1), label: "a1" },
            { x: col(2), label: "b2" },
          ].map((n) => (
            <Fragment>
              <circle
                cx={n.x}
                cy={yFeat}
                r={R}
                fill={nodeFill.feat}
                stroke={nodeStroke.feat}
                stroke-width="2.5"
              />
              <text
                x={n.x}
                y={yFeat + 1}
                text-anchor="middle"
                dominant-baseline="middle"
                style={commitText}
              >
                {n.label}
              </text>
            </Fragment>
          ))}
        </Fragment>
      )
    }

    {/* STEP 2: merge commit M (diamond, two parents) */}
    {
      step === 2 && (
        <Fragment>
          <rect
            x={replayTipX - R}
            y={yMain - R}
            width={R * 2}
            height={R * 2}
            rx="4"
            transform={`rotate(45 ${replayTipX} ${yMain})`}
            fill={nodeFill.merge}
            stroke={nodeStroke.merge}
            stroke-width="2.5"
          />
          <text
            x={replayTipX}
            y={yMain + 1}
            text-anchor="middle"
            dominant-baseline="middle"
            style={commitText}
          >
            M
          </text>
        </Fragment>
      )
    }

    {/* STEP 3: ghosted originals + replayed a1'·b2' */}
    {
      step === 3 && (
        <Fragment>
          {[
            { x: col(1), label: "a1" },
            { x: col(2), label: "b2" },
          ].map((n) => (
            <Fragment>
              <circle
                cx={n.x}
                cy={yFeat}
                r={R}
                fill={nodeFill.ghost}
                stroke={nodeStroke.ghost}
                stroke-width="2"
                stroke-dasharray="4 4"
              />
              <text
                x={n.x}
                y={yFeat + 1}
                text-anchor="middle"
                dominant-baseline="middle"
                style={ghostText}
              >
                {n.label}
              </text>
            </Fragment>
          ))}
          {[
            { x: replayMidX, label: "a1'" },
            { x: replayTipX, label: "b2'" },
          ].map((n) => (
            <Fragment>
              <circle
                cx={n.x}
                cy={yMain}
                r={R}
                fill={nodeFill.replay}
                stroke={nodeStroke.replay}
                stroke-width="2.5"
              />
              <text
                x={n.x}
                y={yMain + 1}
                text-anchor="middle"
                dominant-baseline="middle"
                style={commitText}
              >
                {n.label}
              </text>
            </Fragment>
          ))}
        </Fragment>
      )
    }
  </svg>

  {/* ---- ref labels (HTML, so they pick up the font cleanly) ---- */}
  <span
    style={`${refLabel("blue")}; left: ${(mainTipX / W) * 100}%; top: ${((yMain - R - 22) / H) * 100}%;`}
  >
    main
  </span>

  {/* On step 3 the branch ref rides its replayed (orange) commits on main's tip;
      otherwise it sits under the original green feature commits. */}
  <span
    style={`${refLabel(step === 3 ? "orange" : "green")}; left: ${(featRefX / W) * 100}%; top: ${(featRefY / H) * 100}%;`}
  >
    feat/invoice-status
  </span>
</div>
