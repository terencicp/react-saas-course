---
// Structural-parallel diagram for the treeify-mirror beat.
//
// Two side-by-side panels show that z.treeifyError(error) returns an object with
// the SAME skeleton as the input you parsed. The left panel is the input object,
// the right panel is the treeify output. The three running fields (email,
// password, lines) are laid out on ONE shared grid so each field occupies a
// single grid row across BOTH panels — `email` literally sits in the same row as
// `properties.email`. A faint dashed connector in the centre gutter of each
// field row makes the mirror a visible fact.
//
// The scaffolding around the fields differs (the tree wraps them in `errors` /
// `properties`), so each panel's pre/post lines live in their own grid rows that
// span only that panel's column — they don't need to align. Only the field rows
// align, which is the whole point.
//
// Authored as a CSS grid (not a graph engine) so a reader can open devtools and
// see the real layout.

const accent = '#dc2626'; // red — the error signal carried at each field

// The three running fields, in input order. `tail` is what trails the key on the
// left (input) side; `treeValue` is the printed `properties.<field>` body on the
// right (tree) side.
const fields = [
  {
    name: 'email',
    tail: ',',
    treeValue: "{ errors: ['Enter a valid email address'] },",
  },
  {
    name: 'password',
    tail: ',',
    treeValue: "{ errors: ['Password must be at least 8 characters'] },",
  },
  {
    name: 'lines',
    tail: ': [ … ],',
    treeValue: '{ errors: [], items: [ … ] },',
  },
] as const;

const mono = 'var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace)';
const fieldKeyColor = 'var(--sl-color-text-accent, var(--sl-color-text))';
const punctColor = 'var(--sl-color-gray-3)';

// --- outer grid ----------------------------------------------------------
// Columns: left panel | connector gutter | right panel.
// Rows: a header row, then one row per field, then a footer row. Every field row
// is shared by all three columns, so alignment is automatic.
const gridRows = ['auto', ...fields.map(() => 'minmax(30px, auto)'), 'auto'];

const outerStyle = [
  'margin: 0',
  'display: grid',
  'grid-template-columns: minmax(0, 1fr) 54px minmax(0, 1fr)',
  `grid-template-rows: ${gridRows.join(' ')}`,
  'column-gap: 0',
  'row-gap: 0',
  'width: 100%',
  'max-width: 780px',
  'margin-inline: auto',
  'font-family: ' + mono,
  'font-size: 13px',
  'line-height: 1.5',
].join('; ');

// Panel cells share a left/right border + background; top and bottom cells round
// the corners and carry the panel's open/close scaffold.
const panelBorder = '1px solid var(--sl-color-gray-5)';
const panelBg = 'background: color-mix(in srgb, currentColor 3%, transparent)';

const sideBorders = (side: 'left' | 'right') =>
  side === 'left'
    ? `border-left: ${panelBorder}; border-right: ${panelBorder}`
    : `border-left: ${panelBorder}; border-right: ${panelBorder}`;

// header cell (row 1) — panel title + opening lines
const headerCell = (side: 'left' | 'right') =>
  [
    'margin: 0',
    panelBg,
    sideBorders(side),
    'border-top: ' + panelBorder,
    'border-radius: 10px 10px 0 0',
    'overflow: hidden',
  ].join('; ');

const titleStyle = [
  'margin: 0',
  'padding: 7px 12px',
  'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
  'font-size: 11.5px',
  'font-weight: 600',
  'letter-spacing: 0.02em',
  'color: var(--sl-color-gray-2)',
  'background: color-mix(in srgb, currentColor 5%, transparent)',
  'border-bottom: ' + panelBorder,
].join('; ');

const scaffoldLine = (indent: number) =>
  [
    'margin: 0',
    `padding: 0 14px 0 ${14 + indent}px`,
    'color: ' + punctColor,
  ].join('; ');

// a body field cell (one of the field rows)
const fieldCell = (side: 'left' | 'right') =>
  [
    'margin: 0',
    panelBg,
    sideBorders(side),
    'display: flex',
    'align-items: center',
    `padding: 0 14px 0 ${side === 'left' ? 30 : 46}px`,
  ].join('; ');

const footerCell = (side: 'left' | 'right') =>
  [
    'margin: 0',
    panelBg,
    sideBorders(side),
    'border-bottom: ' + panelBorder,
    'border-radius: 0 0 10px 10px',
    'padding: 0 14px',
    'color: ' + punctColor,
  ].join('; ');

const keyStyle = [
  'margin: 0',
  'font-weight: 600',
  'color: ' + accent,
].join('; ');

const tailStyle = 'margin: 0; color: ' + punctColor + ';';
const treeKeyTail = 'margin: 0; color: ' + punctColor + ';';
const treeValueStyle = 'margin: 0; color: var(--sl-color-gray-2); font-size: 12px;';

// connector gutter cells — one per field row, a dashed rule across the gap
const connectorCell = [
  'margin: 0',
  'display: flex',
  'align-items: center',
  'padding: 0 6px',
].join('; ');

const connectorLine = [
  'margin: 0',
  'width: 100%',
  'border-top: 1.5px dashed color-mix(in srgb, ' + accent + ' 55%, transparent)',
].join('; ');

// empty gutter cells for the header and footer rows
const gutterFiller = 'margin: 0;';
---

<div style={outerStyle}>
  {/* ===== ROW 1: headers + opening scaffold ===== */}
  <div style={headerCell('left')}>
    <div style={titleStyle}>The input you parsed</div>
    <div style={scaffoldLine(0) + '; padding-top: 8px;'}>{'{'}</div>
  </div>
  <div style={gutterFiller}></div>
  <div style={headerCell('right')}>
    <div style={titleStyle}>treeifyError(error)</div>
    <div style={scaffoldLine(0) + '; padding-top: 8px;'}>{'{'}</div>
    <div style={scaffoldLine(16)}>errors: [],</div>
    <div style={scaffoldLine(16)}>properties: {'{'}</div>
  </div>

  {/* ===== FIELD ROWS (one grid row each, shared across all three columns) ===== */}
  {fields.map((field) => (
    <>
      <div style={fieldCell('left')}>
        <span style={keyStyle}>{field.name}</span>
        <span style={tailStyle}>{field.tail}</span>
      </div>
      <div style={connectorCell}>
        <div style={connectorLine}></div>
      </div>
      <div style={fieldCell('right')}>
        <span style={keyStyle}>{field.name}</span>
        <span style={treeKeyTail}>:&nbsp;</span>
        <span style={treeValueStyle}>{field.treeValue}</span>
      </div>
    </>
  ))}

  {/* ===== FOOTER ROW: closing scaffold ===== */}
  <div style={footerCell('left') + '; padding-bottom: 8px;'}>{'}'}</div>
  <div style={gutterFiller}></div>
  <div style={footerCell('right') + '; padding-bottom: 8px;'}>
    <div style={scaffoldLine(16) + '; padding-left: 30px;'}>{'}'},</div>
    <div style={scaffoldLine(0)}>{'}'}</div>
  </div>
</div>
