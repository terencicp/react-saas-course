---
// 2x2 reference-card grid for the four parse methods.
// The cross product of two binary choices:
//   columns -> {throws on failure, returns a result}
//   rows    -> {synchronous, asynchronous}
// The "returns a result" column carries a faint green tint because safeParse /
// safeParseAsync are the course default at boundaries. Authored as a CSS grid
// (not a graph engine) so a reader can open devtools and see the real layout.
//
// Layout is a 3-column x 3-row grid: an empty corner, two column headers, two
// row headers down the left edge, and four method cells in the body.

const columns = [
  { id: 'throws', header: 'Throws on failure', tinted: false },
  { id: 'returns', header: 'Returns a result', tinted: true },
] as const;

const rows = ['Synchronous', 'Asynchronous'] as const;

// cells[rowIndex][columnIndex]
const cells = [
  [
    { method: 'parse', trigger: 'the value came back, or an exception did.' },
    { method: 'safeParse', trigger: 'the result is { success }; you branch on it.' },
  ],
  [
    { method: 'parseAsync', trigger: 'same as parse, but awaits async checks.' },
    { method: 'safeParseAsync', trigger: 'same as safeParse, but awaits async checks.' },
  ],
] as const;

const accent = '#16a34a'; // green — the "returns a result" / course-default signal

// --- shared chrome -------------------------------------------------------

const gridStyle = [
  'margin: 0',
  'display: grid',
  // narrow row-header column, then two equal method columns
  'grid-template-columns: minmax(74px, auto) 1fr 1fr',
  'gap: 6px',
  'width: 100%',
  'max-width: 620px',
  'margin-inline: auto',
  'font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)',
].join('; ');

const cornerStyle = 'margin: 0;'; // empty top-left cell

const colHeaderBase = [
  'margin: 0',
  'padding: 6px 10px',
  'border-radius: 7px 7px 0 0',
  'text-align: center',
  'font-size: 12px',
  'font-weight: 600',
  'letter-spacing: 0.01em',
].join('; ');

const colHeaderPlain = `${colHeaderBase}; color: var(--sl-color-gray-2); background: color-mix(in srgb, currentColor 6%, transparent);`;
const colHeaderTinted = `${colHeaderBase}; color: ${accent}; background: color-mix(in srgb, ${accent} 14%, transparent);`;

const rowHeaderStyle = [
  'margin: 0',
  'padding: 0 6px',
  'display: flex',
  'align-items: center',
  'justify-content: flex-end',
  'text-align: right',
  'font-size: 12px',
  'font-weight: 600',
  'color: var(--sl-color-gray-2)',
  'line-height: 1.2',
].join('; ');

const cellBase = [
  'margin: 0',
  'padding: 11px 13px',
  'border-radius: 9px',
  'display: flex',
  'flex-direction: column',
  'gap: 5px',
  'min-width: 0',
].join('; ');

const cellPlain = `${cellBase}; border: 1px solid var(--sl-color-gray-5); background: color-mix(in srgb, currentColor 3%, transparent);`;
const cellTinted = `${cellBase}; border: 1px solid color-mix(in srgb, ${accent} 38%, transparent); background: color-mix(in srgb, ${accent} 8%, transparent);`;

const methodBase = [
  'margin: 0',
  'font-family: var(--sl-font-mono, ui-monospace, monospace)',
  'font-size: 14px',
  'font-weight: 700',
  'line-height: 1.2',
].join('; ');

const methodPlain = `${methodBase}; color: currentColor;`;
const methodTinted = `${methodBase}; color: ${accent};`;

const triggerStyle = 'margin: 0; font-size: 11.5px; line-height: 1.35; opacity: 0.72;';
---

<div style={gridStyle}>
  {/* header row: empty corner + two column headers */}
  <div style={cornerStyle}></div>
  {columns.map((col) => (
    <div style={col.tinted ? colHeaderTinted : colHeaderPlain}>{col.header}</div>
  ))}

  {/* two body rows, each: row header + two method cells */}
  {rows.map((rowLabel, rowIndex) => (
    <>
      <div style={rowHeaderStyle}>{rowLabel}</div>
      {cells[rowIndex].map((cell, colIndex) => {
        const tinted = columns[colIndex].tinted;
        return (
          <div style={tinted ? cellTinted : cellPlain}>
            <div style={tinted ? methodTinted : methodPlain}>{cell.method}</div>
            <div style={triggerStyle}>{cell.trigger}</div>
          </div>
        );
      })}
    </>
  ))}
</div>
