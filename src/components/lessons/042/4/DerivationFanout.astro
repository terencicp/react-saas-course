---
// "Derive, don't duplicate" fan-out: one canonical `userSchema` on the left
// radiating to four derived contracts on the right, each arrow labelled with the
// method that produced it (.pick / .omit / .pick + .extend / .partial).
//
// The boxes are real HTML so the schema name reads in mono and carries a small
// role subtitle; the arrows are leader-line curves drawn by <ArrowDiagram>.
// Wrapped in <Figure expandable={false}> because leader-line positions from
// document.body and breaks when the figure is relocated into the lightbox.
//
// Layout: a two-column flex row — the source box is vertically centred against
// the stack of four leaves. The arrows leave the source on the right and land on
// each leaf's left; their startSocketGravity Y-components are staggered so the
// four curves fan into separate lanes and the labels sit clear of one another in
// the gap.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

// --- box chrome -------------------------------------------------------------

const boxBase = [
  'box-sizing: border-box',
  'display: flex',
  'flex-direction: column',
  'gap: 3px',
  'padding: 9px 14px',
  'border-radius: 9px',
  'text-align: center',
  'white-space: nowrap',
].join('; ');

// The one canonical source, tinted amber to read as "the original".
const sourceStyle = `${boxBase}; border: 1.5px solid #f59e0b; background: color-mix(in srgb, #f59e0b 14%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 12%, transparent);`;

// The derived leaves, neutral slate so the source stands out as the root.
const leafStyle = `${boxBase}; border: 1px solid color-mix(in srgb, currentColor 26%, transparent); background: color-mix(in srgb, currentColor 6%, transparent);`;

const nameStyle =
  'margin: 0; font-family: var(--sl-font-mono, ui-monospace, monospace); font-size: 13px; font-weight: 600; line-height: 1.2;';
const roleStyle = 'margin: 0; font-size: 10px; opacity: 0.6; line-height: 1.2;';

// One mid-tone colour per arrow so the four labels are easy to tell apart on
// both themes (Tailwind 500/600 shades read on light and dark).
const leaves = [
  { id: 'fan-create', name: 'createUserSchema', role: 'create-input', method: '.pick', color: '#0ea5e9' },
  { id: 'fan-public', name: 'publicUserSchema', role: 'public response', method: '.omit', color: '#dc2626' },
  { id: 'fan-signup', name: 'signupSchema', role: 'signup form', method: '.pick + .extend', color: '#16a34a' },
  { id: 'fan-update', name: 'updateUserSchema', role: 'PATCH body', method: '.partial', color: '#9333ea' },
] as const;

// Stagger the start gravity Y so the four curves leave the source in distinct
// lanes; bias each label up/down with labelOffset so they never collide.
const gravity = {
  'fan-create': { start: [70, -90] as [number, number], label: [4, -12] as [number, number] },
  'fan-public': { start: [90, -30] as [number, number], label: [4, -12] as [number, number] },
  'fan-signup': { start: [90, 30] as [number, number], label: [4, 12] as [number, number] },
  'fan-update': { start: [70, 90] as [number, number], label: [4, 12] as [number, number] },
} as const;

const arrows = leaves.map((leaf) => ({
  from: 'fan-source',
  to: leaf.id,
  label: leaf.method,
  color: leaf.color,
  startSocket: 'right' as const,
  endSocket: 'left' as const,
  startSocketGravity: gravity[leaf.id].start,
  endSocketGravity: [-60, 0] as [number, number],
  labelOffset: gravity[leaf.id].label,
}));
---

<Figure expandable={false}>
  <ArrowDiagram arrows={arrows}>
    <div
      style="display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 150px; padding: 6px 4px; min-width: 0; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
    >
      <div style="flex: 0 0 auto;">
        <div style={sourceStyle} id="fan-source">
          <p style={nameStyle}>userSchema</p>
          <p style={roleStyle}>canonical source</p>
        </div>
      </div>
      <div style="flex: 0 0 auto; display: flex; flex-direction: column; gap: 14px;">
        {
          leaves.map((leaf) => (
            <div style={leafStyle} id={leaf.id}>
              <p style={nameStyle}>{leaf.name}</p>
              <p style={roleStyle}>{leaf.role}</p>
            </div>
          ))
        }
      </div>
    </div>
  </ArrowDiagram>
  <Fragment slot="caption">
    One canonical schema, four derived contracts. Add a field to <code>userSchema</code> and every arrow carries it downstream — or deliberately doesn't, where a <code>.pick</code> or <code>.omit</code> mask leaves it out.
  </Fragment>
</Figure>
