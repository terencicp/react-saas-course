---
// One frame of the `.pipe` staged-validation flow, used inside <DiagramSequence>.
// Three schema stages run left to right:
//   z.string()  ->  .transform(Number)  ->  z.number().int().positive()
// A value chip sits under whichever stage currently owns the value, morphing
// from the string "42" to the number 42, so the reader watches the transform
// reshape the value and the piped schema run a *second* validation pass on it.
//
// `step` selects which stage is highlighted (1, 2, or 3). The chip is absolutely
// positioned below its owning pill, so it stays centred on that pill regardless
// of width and never reflows the strip.

interface Props {
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const arrow = '▸'; // ▸

const stages = [
  { label: 'z.string()', sub: 'is it a string?', value: '"42"', type: 'string', pass: false },
  { label: '.transform(Number)', sub: 'reshape the value', value: '42', type: 'number', pass: false },
  { label: 'z.number().int().positive()', sub: 'second validation pass', value: '42', type: 'number', pass: true },
] as const;

// Shared chrome for the stage pills.
const pillBase = [
  'position: relative',
  'margin: 0',
  'padding: 7px 12px',
  'border-radius: 8px',
  'min-width: 0',
  'text-align: center',
  'display: flex',
  'flex-direction: column',
  'align-items: center',
  'gap: 2px',
  'white-space: nowrap',
  'transition: opacity 200ms ease, transform 200ms ease, border-color 200ms ease, background-color 200ms ease, box-shadow 200ms ease',
].join('; ');

const pillDim = `${pillBase}; border: 1px solid color-mix(in srgb, #38bdf8 30%, transparent); background: color-mix(in srgb, #38bdf8 5%, transparent); opacity: 0.4;`;
const pillActive = `${pillBase}; border: 1.5px solid #f59e0b; background: color-mix(in srgb, #f59e0b 20%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 16%, transparent); transform: translateY(-1px); opacity: 1;`;

const labelStyle =
  'margin: 0; font-family: var(--sl-font-mono, ui-monospace, monospace); font-size: 12.5px; font-weight: 600; line-height: 1.2;';
const subStyle = 'margin: 0; font-size: 10px; opacity: 0.62; line-height: 1.2;';

const arrowStyle = [
  'margin: 0',
  'color: currentColor',
  'opacity: 0.32',
  'font-size: 14px',
  'line-height: 1',
  'user-select: none',
  'flex: 0 0 auto',
  'align-self: center',
].join('; ');

// Vertical connector dropping from a pill to its value chip.
const connectorStyle = [
  'position: absolute',
  'top: 100%',
  'left: 50%',
  'transform: translateX(-50%)',
  'width: 1.5px',
  'height: 11px',
  'background: color-mix(in srgb, currentColor 30%, transparent)',
].join('; ');

// The value chip — absolutely positioned below its pill so it never reflows the
// strip and always reads centred under the stage that owns the value.
const chipBase = [
  'position: absolute',
  'top: calc(100% + 11px)',
  'left: 50%',
  'transform: translateX(-50%)',
  'display: inline-flex',
  'align-items: center',
  'gap: 6px',
  'padding: 4px 10px',
  'border-radius: 999px',
  'font-family: var(--sl-font-mono, ui-monospace, monospace)',
  'font-size: 12px',
  'line-height: 1.2',
  'white-space: nowrap',
].join('; ');

const chipNeutral = `${chipBase}; border: 1px solid color-mix(in srgb, currentColor 24%, transparent); background: color-mix(in srgb, currentColor 7%, transparent);`;
const chipPass = `${chipBase}; border: 1px solid color-mix(in srgb, #22c55e 60%, transparent); background: color-mix(in srgb, #22c55e 15%, transparent);`;

const typeTagStyle = 'opacity: 0.6; font-size: 10.5px;';
const checkStyle = 'color: #16a34a; font-weight: 700;';
---

<div
  style="margin: 0; padding-bottom: 48px; display: flex; flex-direction: row; align-items: stretch; justify-content: center; flex-wrap: nowrap; gap: 6px; min-width: 0; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);"
>
  {stages.map((stage, index) => {
    const isActive = step === index + 1;
    return (
      <>
        {index > 0 && <div style={arrowStyle}>{arrow}</div>}
        <div style={isActive ? pillActive : pillDim}>
          <div style={labelStyle}>{stage.label}</div>
          <div style={subStyle}>{stage.sub}</div>
          {isActive && (
            <>
              <div style={connectorStyle}></div>
              <div style={stage.pass ? chipPass : chipNeutral}>
                <span>{stage.value}</span>
                <span style={typeTagStyle}>{stage.type}</span>
                {stage.pass && (
                  <span style={checkStyle} aria-label="passes">{'✓'}</span>
                )}
              </div>
            </>
          )}
        </div>
      </>
    );
  })}
</div>
