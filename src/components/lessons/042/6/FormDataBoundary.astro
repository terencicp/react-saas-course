---
// formdata-boundary-figure — the keystone visual of Lesson 042.6.
//
// The one fact the whole lesson works around: a browser <form> serializes
// every control to text, so on the server every value off `formData` is a
// string (files aside). The diagram is a left/right contrast across a single
// vertical divider — a layout idea, not a graph — so it's hand-coded HTML+CSS.
//
//   LEFT  "Browser — <form>": five rows of typed-LOOKING controls — a number
//         spinner showing 3, a checked "archived" checkbox, a date input with a
//         calendar value, a "notes" text field, a "customer" select. They read
//         as real, typed inputs.
//
//   RIGHT "Server — formData": the SAME five fields, now each a quoted
//         monospace string — "3", "on", "2026-01-15T10:30:00Z", "net 30 terms",
//         "550e8400-…". Same vertical positions, so each control sits directly
//         across from its stringified value: the type is visibly gone.
//
//   CENTER a vertical divider with a right-pointing arrow labeled
//         "HTTP / multipart — everything serialized to text", and a subtle
//         highlighted "schema" band straddling the divider — pre-placing where
//         the bridge (taught next) sits, touching both sides.
//
// Pure HTML + CSS, no interactivity. Rows on both panels share one CSS grid so
// a control and its string stay aligned. Starlight theme variables keep it
// native in light and dark; `margin: 0` on every inner element defeats
// Starlight's prose-margin selector. On narrow viewports the two panels stack
// and the divider rotates to a horizontal arrow.

import Figure from '../../../figures/Figure.astro';

// Five fields, paired so each control lines up with its server-side string.
const fields = [
  { name: 'quantity', control: 'number', value: '3', wire: '"3"' },
  { name: 'archived', control: 'checkbox', value: '', wire: '"on"' },
  { name: 'issuedAt', control: 'date', value: '2026-01-15 10:30', wire: '"2026-01-15T10:30:00Z"' },
  { name: 'notes', control: 'text', value: 'net 30 terms', wire: '"net 30 terms"' },
  { name: 'customerId', control: 'select', value: 'Acme Corp', wire: '"550e8400-…"' },
] as const;
---

<Figure
  caption="A browser <form> can only carry text. Every typed-looking control on the left arrives on the server as a quoted string — the schema, straddling the divider, is where those strings become typed again."
>
  <div class="fdb not-content">
    {/* LEFT — the browser form: typed-looking controls */}
    <section class="fdb-panel fdb-panel--browser">
      <h4 class="fdb-heading">
        Browser — <code class="fdb-heading-code">&lt;form&gt;</code>
      </h4>
      <div class="fdb-rows">
        {fields.map((field) => (
          <div class="fdb-row">
            <span class="fdb-name">{field.name}</span>
            {field.control === 'number' && (
              <span class="fdb-control fdb-number">
                <span class="fdb-number-value">{field.value}</span>
                <span class="fdb-spinner" aria-hidden="true">
                  <span class="fdb-spinner-up"></span>
                  <span class="fdb-spinner-down"></span>
                </span>
              </span>
            )}
            {field.control === 'checkbox' && (
              <span class="fdb-control fdb-checkbox">
                <span class="fdb-checkbox-box" aria-hidden="true">&#10003;</span>
                <span class="fdb-checkbox-label">checked</span>
              </span>
            )}
            {field.control === 'date' && (
              <span class="fdb-control fdb-date">
                <span class="fdb-date-value">{field.value}</span>
                <span class="fdb-date-icon" aria-hidden="true">&#128197;</span>
              </span>
            )}
            {field.control === 'text' && (
              <span class="fdb-control fdb-text">
                <span class="fdb-text-value">{field.value}</span>
                <span class="fdb-caret" aria-hidden="true"></span>
              </span>
            )}
            {field.control === 'select' && (
              <span class="fdb-control fdb-select">
                <span class="fdb-select-value">{field.value}</span>
                <span class="fdb-select-chevron" aria-hidden="true">&#9662;</span>
              </span>
            )}
          </div>
        ))}
      </div>
    </section>

    {/* CENTER — the wire: divider, arrow, and the schema band */}
    <div class="fdb-divider" aria-hidden="true">
      <div class="fdb-line"></div>
      <div class="fdb-band">
        <span class="fdb-band-label">schema</span>
      </div>
      <div class="fdb-arrow">
        <span class="fdb-arrow-text">
          HTTP / multipart<br />everything serialized to text
        </span>
        <span class="fdb-arrow-glyph">&rarr;</span>
      </div>
    </div>

    {/* RIGHT — the server: the same fields as quoted strings */}
    <section class="fdb-panel fdb-panel--server">
      <h4 class="fdb-heading">
        Server — <code class="fdb-heading-code">formData</code>
      </h4>
      <div class="fdb-rows">
        {fields.map((field) => (
          <div class="fdb-row">
            <span class="fdb-name">{field.name}</span>
            <span class="fdb-wire">{field.wire}</span>
          </div>
        ))}
      </div>
    </section>
  </div>
</Figure>

<style>
  .fdb {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: stretch;
    gap: 0;
    margin: 0;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }

  /* ---- Panels ---------------------------------------------------------- */

  .fdb-panel {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px 16px 18px;
    border-radius: 12px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-sidebar);
    box-sizing: border-box;
    margin: 0;
  }

  .fdb-heading {
    margin: 0;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .fdb-heading-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    text-transform: none;
    letter-spacing: 0;
    padding: 1px 6px;
    border-radius: 5px;
    background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    color: var(--sl-color-text);
  }

  .fdb-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
  }

  .fdb-row {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: 34px;
    align-content: center;
    align-items: center;
    gap: 3px;
    margin: 0;
  }

  .fdb-name {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10.5px;
    color: var(--sl-color-gray-3);
    margin: 0;
    line-height: 1.2;
  }

  /* ---- Left: typed-looking controls ------------------------------------ */

  .fdb-control {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    height: 28px;
    padding: 0 8px;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-3) 55%, transparent);
    background: var(--sl-color-bg);
    box-sizing: border-box;
    margin: 0;
    font-size: 13px;
    color: var(--sl-color-text);
  }

  .fdb-number-value,
  .fdb-date-value,
  .fdb-text-value,
  .fdb-select-value {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* number input: value + up/down spinner */
  .fdb-number-value {
    font-variant-numeric: tabular-nums;
  }

  .fdb-spinner {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: none;
    margin: 0;
  }

  .fdb-spinner-up,
  .fdb-spinner-down {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    margin: 0;
  }

  .fdb-spinner-up {
    border-bottom: 5px solid var(--sl-color-gray-3);
  }

  .fdb-spinner-down {
    border-top: 5px solid var(--sl-color-gray-3);
  }

  /* checkbox: a checked box + label, left-aligned */
  .fdb-checkbox {
    justify-content: flex-start;
    border-color: transparent;
    background: transparent;
    padding-left: 0;
  }

  .fdb-checkbox-box {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background: var(--sl-color-text-accent);
    color: var(--sl-color-bg);
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    margin: 0;
  }

  .fdb-checkbox-label {
    margin: 0;
    font-size: 12.5px;
    color: var(--sl-color-gray-2);
  }

  /* date input: value + calendar glyph */
  .fdb-date-icon,
  .fdb-select-chevron {
    flex: none;
    font-size: 12px;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .fdb-date-value {
    font-variant-numeric: tabular-nums;
  }

  /* text input: value + a blinking-style caret */
  .fdb-caret {
    flex: none;
    width: 1px;
    height: 15px;
    background: var(--sl-color-text-accent);
    margin: 0;
  }

  /* ---- Center: divider, schema band, arrow ----------------------------- */

  .fdb-divider {
    position: relative;
    width: 132px;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
  }

  .fdb-line {
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: color-mix(in srgb, var(--sl-color-gray-3) 70%, transparent);
    margin: 0;
  }

  /* the subtle highlighted band straddling the divider — where the schema sits */
  .fdb-band {
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 50%;
    width: 92px;
    transform: translateX(-50%);
    border-radius: 8px;
    border: 1px dashed color-mix(in srgb, var(--sl-color-text-accent) 55%, transparent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 8%, transparent);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    margin: 0;
  }

  .fdb-band-label {
    margin: 4px 0 0;
    padding: 1px 8px;
    border-radius: 999px;
    background: var(--sl-color-text-accent);
    color: var(--sl-color-bg);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fdb-arrow {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    margin: 0;
  }

  .fdb-arrow-text {
    margin: 0;
    padding: 3px 6px;
    border-radius: 6px;
    background: var(--sl-color-bg-sidebar);
    text-align: center;
    font-size: 9.5px;
    line-height: 1.3;
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }

  .fdb-arrow-glyph {
    margin: 0;
    font-size: 20px;
    line-height: 1;
    font-weight: 700;
    color: var(--sl-color-text-accent);
  }

  /* ---- Right: the same fields as quoted strings ------------------------ */

  .fdb-wire {
    display: flex;
    align-items: center;
    height: 28px;
    padding: 0 10px;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 80%, transparent);
    background: color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent);
    box-sizing: border-box;
    margin: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    color: var(--sl-color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ---- Narrow viewports: stack the panels, rotate the divider ---------- */

  @media (max-width: 640px) {
    .fdb {
      grid-template-columns: minmax(0, 1fr);
      gap: 0;
    }

    .fdb-divider {
      width: auto;
      height: 76px;
    }

    .fdb-line {
      top: 50%;
      bottom: auto;
      left: 8px;
      right: 8px;
      width: auto;
      height: 2px;
      transform: translateY(-50%);
    }

    .fdb-band {
      top: 50%;
      bottom: auto;
      left: 8px;
      right: 8px;
      width: auto;
      height: 52px;
      transform: translateY(-50%);
      align-items: center;
    }

    .fdb-band-label {
      margin: 0 0 0 6px;
    }

    .fdb-arrow {
      flex-direction: row;
    }

    .fdb-arrow-glyph {
      transform: rotate(90deg);
    }
  }
</style>
