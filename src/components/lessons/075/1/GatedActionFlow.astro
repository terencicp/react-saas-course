---
// gated-action-flow — Chapter 075 Lesson 1, "Project overview" → Architecture.
//
// The request flow for ONE gated Server Action, made spatial. Reads top→bottom
// down a linear spine on the left, then FORKS at the gate into two sinks on the
// right: the pass path (green, the budget rides the Result) and the reject path
// (red, the opaque rate_limited message). The whole point of the figure is the
// two-way branch at the gate and the pass-vs-reject distinction in what each
// sink carries out — prose alone blurs both.
//
//   form post ─▶ Server Action ─▶ Zod parse ─▶ resolve ip+email ─▶ safeLimit
//   gate(s) ──┬──(pass)──▶ auth.api.* → ok({ … rateLimit: rateLimitBudget(…) })
//             └──(reject)─▶ rateLimited(…) → err('rate_limited', opaque message)
//
// Built with <ArrowDiagram> (LeaderLine) because the sink boxes are two-line
// custom HTML (a monospace call + a muted note) and the per-arrow semantic
// coloring (green pass, red reject) is load-bearing — D2/Mermaid plain-label
// boxes wouldn't carry it verbatim. The arrows are positioned from
// document.body, so the wrapping <Figure> MUST be expandable={false}.
//
// A subordinate annotation strip under the diagram carries the four "shape"
// notes (budget-on-Result, after() flush, single enforcement point, the
// RateLimit-* headers live only on the route-handler twin) so they don't crowd
// the boxes. Chrome is theme-aware; the green/red accents are mid-tones that
// read on both light and dark backgrounds. margin:0 resets defeat Starlight's
// injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const PASS_GREEN = '#15803d'; // green-700 — the happy path: action runs, budget rides the Result
const REJECT_RED = '#dc2626'; // red-600  — the gate tripped: opaque rate_limited error

// The five spine boxes, in order, top→bottom on the left.
const spine = [
	{ id: 'gf-post', title: 'form post', note: 'client submit' },
	{ id: 'gf-action', title: 'Server Action', note: "'use server'" },
	{ id: 'gf-zod', title: 'Zod parse', note: 'validate input' },
	{ id: 'gf-resolve', title: 'resolve ip + normalized email', note: 'getClientIp · normalizeEmail' },
	{ id: 'gf-gate', title: 'safeLimit gate(s)', note: 'ordered, shared limiter' },
];

// The four subordinate "shape" notes under the diagram.
const annotations = [
	'The budget rides the Result, never an HTTP header — a Server Action calls headers() read-only.',
	'pending analytics flush off the response path via after().',
	"Better Auth's built-in limiter is off, so this wrapper is the single enforcement point.",
	'The literal RateLimit-* headers live only on the /api/limit-demo route-handler twin.',
];

const arrows = [
	// The linear spine: each box flows down to the next.
	{ from: 'gf-post', to: 'gf-action', startSocket: 'bottom', endSocket: 'top', startSocketGravity: [0, 32], endSocketGravity: [0, -32] },
	{ from: 'gf-action', to: 'gf-zod', startSocket: 'bottom', endSocket: 'top', startSocketGravity: [0, 32], endSocketGravity: [0, -32] },
	{ from: 'gf-zod', to: 'gf-resolve', startSocket: 'bottom', endSocket: 'top', startSocketGravity: [0, 32], endSocketGravity: [0, -32] },
	{ from: 'gf-resolve', to: 'gf-gate', startSocket: 'bottom', endSocket: 'top', startSocketGravity: [0, 32], endSocketGravity: [0, -32] },
	// The fork: gate → pass sink (up-right, green) and gate → reject sink (down-right, red).
	{
		from: 'gf-gate',
		to: 'gf-pass',
		label: 'pass',
		color: PASS_GREEN,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [90, -40],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -16],
		labelStyle: 'background:#fff;',
	},
	{
		from: 'gf-gate',
		to: 'gf-reject',
		label: 'reject',
		color: REJECT_RED,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [90, 40],
		endSocketGravity: [-70, 0],
		labelOffset: [0, 16],
		labelStyle: 'background:#fff;',
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="gf not-content">
			{/* ── Column 1: the linear spine, top→bottom ── */}
			<div class="gf-spine">
				{
					spine.map((box) => (
						<div class="gf-box" id={box.id}>
							<span class="gf-title">{box.title}</span>
							<span class="gf-note">{box.note}</span>
						</div>
					))
				}
			</div>

			{/* ── Column 2: the two sinks the gate forks into ── */}
			<div class="gf-sinks">
				<div class="gf-box gf-box-pass" id="gf-pass">
					<span class="gf-tag gf-tag-pass">pass</span>
					<span class="gf-title">auth.api.*</span>
					<span class="gf-code">ok(&#123; …, rateLimit: rateLimitBudget(ipLimit) &#125;)</span>
				</div>
				<div class="gf-box gf-box-reject" id="gf-reject">
					<span class="gf-tag gf-tag-reject">reject</span>
					<span class="gf-title">rateLimited(…)</span>
					<span class="gf-code">err('rate_limited', opaque message)</span>
				</div>
			</div>
		</div>

		{/* ── Subordinate shape notes, under the boxes ── */}
		<ul class="gf-annotations not-content">
			{annotations.map((a) => <li>{a}</li>)}
		</ul>
	</ArrowDiagram>
	<Fragment slot="caption">
		One gated Server Action. The gate forks <strong>pass</strong> /
		<strong>reject</strong>; on pass the budget rides the <code>Result</code>'s
		<code>ok</code> payload, never an HTTP header.
	</Fragment>
</Figure>

<style>
	.gf {
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: space-between;
		gap: 120px;
		margin: 0;
		padding: 16px 6px 8px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* Column 1: the five spine boxes stacked vertically, connected top→bottom. */
	.gf-spine {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 14px;
		margin: 0;
		flex: 0 1 auto;
	}

	/* Column 2: the two sinks, stacked and centered on the spine's gate row. */
	.gf-sinks {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 26px;
		margin: 0;
		flex: 0 1 auto;
	}

	.gf-box {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		padding: 10px 16px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, transparent);
		text-align: center;
		margin: 0;
	}

	/* The gate is the focal box — a touch heavier border so the eye lands on the fork. */
	#gf-gate {
		border-color: var(--sl-color-gray-4, #94a3b8);
		border-width: 2px;
	}

	/* Sink boxes are wider (they carry a line of code) and tinted by outcome. */
	.gf-box-pass,
	.gf-box-reject {
		align-items: flex-start;
		text-align: left;
		padding: 11px 16px;
	}
	.gf-box-pass {
		border-color: color-mix(in srgb, #15803d 55%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #15803d 7%, var(--sl-color-bg, #fff));
	}
	.gf-box-reject {
		border-color: color-mix(in srgb, #dc2626 55%, var(--sl-color-gray-5, #cbd5e1));
		background: color-mix(in srgb, #dc2626 7%, var(--sl-color-bg, #fff));
	}

	.gf-tag {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.6rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 1px 6px;
		border-radius: 999px;
		line-height: 1.3;
		margin: 0 0 1px;
	}
	.gf-tag-pass {
		color: #15803d;
		background: color-mix(in srgb, #15803d 14%, transparent);
	}
	.gf-tag-reject {
		color: #dc2626;
		background: color-mix(in srgb, #dc2626 14%, transparent);
	}

	.gf-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.84rem;
		font-weight: 600;
		line-height: 1.25;
		white-space: nowrap;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.gf-note {
		font-size: 0.64rem;
		line-height: 1.25;
		white-space: nowrap;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.gf-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.66rem;
		line-height: 1.3;
		white-space: nowrap;
		color: var(--sl-color-gray-2, #475569);
		margin: 1px 0 0;
	}

	/* Subordinate shape notes — small, muted, two-up grid under the diagram. */
	.gf-annotations {
		list-style: none;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4px 28px;
		margin: 4px 4px 0;
		padding: 12px 4px 0;
		border-top: 1px solid var(--sl-color-gray-6, #e2e8f0);
	}
	.gf-annotations li {
		position: relative;
		padding-left: 14px;
		font-size: 0.72rem;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.gf-annotations li::before {
		content: '›';
		position: absolute;
		left: 0;
		top: -1px;
		color: var(--sl-color-gray-4, #94a3b8);
		font-weight: 700;
	}

	/* Narrow viewports: stack the spine above the sinks. The right→left sockets
	   degrade to vertical arcs between the stacked groups — readable, and the
	   pass/reject labels still float in the gap. Annotations go single-column. */
	@media (max-width: 760px) {
		.gf {
			flex-direction: column;
			align-items: center;
			gap: 64px;
		}
		.gf-spine,
		.gf-sinks {
			width: 100%;
			max-width: 24rem;
		}
		.gf-box-pass,
		.gf-box-reject {
			align-items: center;
			text-align: center;
		}
		.gf-title,
		.gf-note,
		.gf-code {
			white-space: normal;
		}
		.gf-annotations {
			grid-template-columns: 1fr;
		}
	}
</style>
