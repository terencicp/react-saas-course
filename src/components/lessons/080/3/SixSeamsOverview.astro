---
// six-seams-overview — Chapter 080 Lesson 3, "Walking the six error seams".
//
// The chapter's spatial anchor: the whole catalog of six error seams on screen
// at once, BEFORE the walk begins. Its value is orientation, not flow — this is
// a labeled reference strip, not a graph.
//
// Layout — three labeled BANDS laid out as a horizontal-wrapping row, grouped by
// where the caller comes from:
//   [ Inbound from the browser ]  [ Inbound from a third party ]  [ Cross-cutting ]
//        seams 1–3                         seam 4                     seams 5–6
// Each band is a bordered group with a "fieldset legend" header pill; inside,
// the seam cards wrap. On narrow viewports the bands stack.
//
// Each card carries: number, name, subtitle (boundary), file, and two pills —
// "fail-closed" + "split" — to signal both commitments land there. Seam #5
// (safeLimit) is the documented fail-open carve-out: it gets an amber accent and
// its "fail-closed" pill is struck-through / amber to flag the exception.
//
// Palette pinned to chapter 080's ThreeOutcomes figure (green / amber) so the
// chapter reads as one consistent map. margin:0 resets defeat Starlight's
// injected prose margins; `not-content` opts the figure body out of prose styling.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

const GREEN = '#16a34a'; // fail-closed pill
const TEAL = '#0d9488'; // split pill
const AMBER = '#d97706'; // the documented fail-open carve-out (seam #5)
const CARD_BG = 'var(--sl-color-bg-sidebar)'; // what the legend pills paint over

type Seam = {
	n: number;
	name: string;
	sub: string;
	file: string;
	carveOut?: boolean;
};

const browser: Seam[] = [
	{ n: 1, name: 'authedAction', sub: 'Server Action boundary', file: 'actions.ts' },
	{ n: 2, name: 'authedRoute', sub: 'Route-handler boundary', file: 'route.ts' },
	{
		n: 3,
		name: 'requireOrgUser()',
		sub: 'Server Component boundary',
		file: 'page.tsx / layout.tsx',
	},
];

const thirdParty: Seam[] = [
	{ n: 4, name: 'webhook receiver', sub: 'verify-then-dedup', file: 'app/api/webhooks/*' },
];

const crossCutting: Seam[] = [
	{
		n: 5,
		name: 'safeLimit',
		sub: 'rate-limit decision',
		file: 'lib/rate-limit.ts',
		carveOut: true,
	},
	{ n: 6, name: 'error.tsx', sub: 'page boundary (the catcher)', file: 'error.tsx / global-error.tsx' },
];

const ALT =
	'A catalog of six error seams in three bands. Inbound from the browser: authedAction (Server Action boundary, actions.ts), authedRoute (route-handler boundary, route.ts), and requireOrgUser() (Server Component boundary, page.tsx / layout.tsx). Inbound from a third party: the webhook receiver (verify-then-dedup, app/api/webhooks/*). Cross-cutting: safeLimit (rate-limit decision, lib/rate-limit.ts) which is the one documented fail-open carve-out, and error.tsx (the page boundary that catches, error.tsx / global-error.tsx). Every seam carries two commitments: fail-closed and split. Only safeLimit deliberately does not fail closed.';
---

<Figure
	caption="For each seam: does it fail closed, and is what the user sees safe to read aloud on a support call? safeLimit is the one documented exception — it fails open on a Redis outage, on purpose."
>
	<div class="sso not-content" role="img" aria-label={ALT}>
		<div class="sso-band">
			<span class="sso-legend">Inbound from the browser</span>
			<div class="sso-cards">
				{
					browser.map((s) => (
						<article class="sso-card">
							<header class="sso-head">
								<span class="sso-num">{s.n}</span>
								<span class="sso-name">{s.name}</span>
							</header>
							<p class="sso-sub">{s.sub}</p>
							<p class="sso-file">{s.file}</p>
							<div class="sso-pills">
								<span class="sso-pill sso-pill-closed">fail-closed</span>
								<span class="sso-pill sso-pill-split">split</span>
							</div>
						</article>
					))
				}
			</div>
		</div>

		<div class="sso-band">
			<span class="sso-legend">Inbound from a third party</span>
			<div class="sso-cards">
				{
					thirdParty.map((s) => (
						<article class="sso-card">
							<header class="sso-head">
								<span class="sso-num">{s.n}</span>
								<span class="sso-name">{s.name}</span>
							</header>
							<p class="sso-sub">{s.sub}</p>
							<p class="sso-file">{s.file}</p>
							<div class="sso-pills">
								<span class="sso-pill sso-pill-closed">fail-closed</span>
								<span class="sso-pill sso-pill-split">split</span>
							</div>
						</article>
					))
				}
			</div>
		</div>

		<div class="sso-band">
			<span class="sso-legend">Cross-cutting</span>
			<div class="sso-cards">
				{
					crossCutting.map((s) => (
						<article class={s.carveOut ? 'sso-card sso-card-carve' : 'sso-card'}>
							<header class="sso-head">
								<span class={s.carveOut ? 'sso-num sso-num-carve' : 'sso-num'}>{s.n}</span>
								<span class="sso-name">{s.name}</span>
							</header>
							<p class="sso-sub">{s.sub}</p>
							<p class="sso-file">{s.file}</p>
							<div class="sso-pills">
								{
									s.carveOut ? (
										<span class="sso-pill sso-pill-carve">fail-closed</span>
									) : (
										<span class="sso-pill sso-pill-closed">fail-closed</span>
									)
								}
								<span class="sso-pill sso-pill-split">split</span>
							</div>
							{s.carveOut && <p class="sso-carve-note">documented fail-open carve-out</p>}
						</article>
					))
				}
			</div>
		</div>
	</div>
</Figure>

<style define:vars={{ GREEN, TEAL, AMBER, CARD_BG, sans, mono }}>
	.sso {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		column-gap: 14px;
		row-gap: 22px;
		margin: 0;
		padding: 22px 2px 8px;
		font-family: var(--sans);
		color: var(--sl-color-white);
	}

	.sso :global(*) {
		margin: 0;
	}

	/* ── a band: a bordered group with a legend pill on its top border ── */
	.sso-band {
		position: relative;
		box-sizing: border-box;
		flex: 0 1 auto;
		display: flex;
		flex-direction: column;
		gap: 10px;
		padding: 18px 12px 13px;
		border: 1px solid var(--sl-color-gray-5, #353c4a);
		border-radius: 14px;
		background: color-mix(in srgb, var(--sl-color-gray-6, #1a1f29) 35%, transparent);
	}

	.sso-legend {
		display: block;
		width: fit-content;
		align-self: center;
		margin-top: -28px;
		padding: 2px 11px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-5, #353c4a);
		background: var(--CARD-BG);
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		line-height: 1.5;
		white-space: nowrap;
		color: var(--sl-color-gray-2, #c0c7d1);
	}

	/* ── the cards inside a band ── */
	.sso-cards {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		justify-content: center;
	}

	.sso-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 5px;
		flex: 0 0 auto;
		width: 152px;
		padding: 10px 11px 11px;
		border: 1.5px solid var(--sl-color-gray-4, #4d5666);
		border-radius: 11px;
		background: var(--sl-color-bg-sidebar);
	}
	.sso-card-carve {
		border-color: var(--AMBER);
		background: color-mix(in srgb, var(--AMBER) 9%, var(--sl-color-bg-sidebar));
	}

	.sso-head {
		display: flex;
		align-items: center;
		gap: 7px;
	}
	.sso-num {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		border-radius: 999px;
		background: var(--sl-color-gray-5, #353c4a);
		color: var(--sl-color-white);
		font-size: 10.5px;
		font-weight: 800;
		line-height: 1;
	}
	.sso-num-carve {
		background: var(--AMBER);
		color: #fff;
	}
	.sso-name {
		font-family: var(--mono);
		font-size: 13px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white);
		word-break: break-word;
	}

	.sso-sub {
		font-size: 11px;
		font-weight: 600;
		line-height: 1.25;
		color: var(--sl-color-gray-2, #c0c7d1);
	}
	.sso-file {
		font-family: var(--mono);
		font-size: 10px;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #9aa3b1);
		word-break: break-word;
	}

	/* ── the two-commitment pills ── */
	.sso-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 5px;
		margin-top: 1px;
	}
	.sso-pill {
		display: inline-block;
		padding: 1.5px 7px;
		border-radius: 999px;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1.4;
		white-space: nowrap;
	}
	.sso-pill-closed {
		color: var(--GREEN);
		border: 1px solid color-mix(in srgb, var(--GREEN) 55%, transparent);
		background: color-mix(in srgb, var(--GREEN) 14%, transparent);
	}
	.sso-pill-split {
		color: var(--TEAL);
		border: 1px solid color-mix(in srgb, var(--TEAL) 55%, transparent);
		background: color-mix(in srgb, var(--TEAL) 14%, transparent);
	}
	/* seam #5 only: fail-closed struck-through + amber to mark the carve-out */
	.sso-pill-carve {
		color: var(--AMBER);
		border: 1px dashed color-mix(in srgb, var(--AMBER) 60%, transparent);
		background: color-mix(in srgb, var(--AMBER) 12%, transparent);
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
		opacity: 0.95;
	}
	.sso-carve-note {
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		line-height: 1.25;
		color: var(--AMBER);
	}

	/* ── narrow viewports: bands stack, cards still wrap inside ── */
	@media (max-width: 720px) {
		.sso-band {
			flex: 1 1 100%;
		}
	}
</style>
