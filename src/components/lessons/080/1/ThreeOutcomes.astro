---
// The three-outcomes mental model for a gate (Ch080 L1, "Refuse by default").
//
// A single gate (`requireRole('admin')`) fans out to three outcomes:
//   Allow  (green, settled)  — role proven sufficient
//   Deny   (red,   settled)  — role proven insufficient
//   Check failed (amber, dashed, unstable) — the check itself broke
//
// The fail-closed move: a curved connector folds the uncertain amber outcome
// UP into the red Deny box. Every doubt is a deny.
//
// Layout — a flex row of FIXED-size lanes so the SVG connectors map 1:1 to
// pixels and never chase box centres:
//   [ gate ] [ fan-lane SVG ] [ outcomes column ] [ fold-lane SVG + label ]
// Outcome boxes have a fixed height; the fan/fold SVGs are sized to the exact
// stack height with a matching viewBox, so every endpoint lands on a box
// centre at any card width.

const green = "#16a34a";
const red = "#dc2626";
const amber = "#d97706";

const reset = "margin: 0; box-sizing: border-box;";
const mono = "font-family: ui-monospace, SFMono-Regular, Menlo, monospace;";

// stack geometry (px) — the single source of truth for box + SVG layout
const BOX_H = 70;
const GAP = 14;
const STACK_H = BOX_H * 3 + GAP * 2; // 220
const cyAllow = BOX_H / 2; // 32
const cyDeny = BOX_H + GAP + BOX_H / 2; // 110
const cyCheck = (BOX_H + GAP) * 2 + BOX_H / 2; // 188
const cyGate = STACK_H / 2; // 110

const fanW = 46;
const foldW = 26;

const boxBase = [
  reset,
  "height: " + BOX_H + "px",
  "border-radius: 10px",
  "padding: 7px 12px",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 2px",
  "line-height: 1.2",
  "overflow: hidden",
].join("; ");

const settled = (c: string) =>
  `${boxBase}; border: 1.5px solid ${c}; background: color-mix(in srgb, ${c} 12%, transparent);`;
const uncertain = (c: string) =>
  `${boxBase}; border: 1.5px dashed ${c}; background: color-mix(in srgb, ${c} 9%, transparent);`;

const titleStyle = (c: string) =>
  `${reset} font-size: 14px; font-weight: 700; color: ${c}; letter-spacing: 0.01em;`;
const subStyle = `${reset} font-size: 11px; opacity: 0.74; line-height: 1.25;`;
const subMono = `${reset} ${mono} font-size: 10px; opacity: 0.74; line-height: 1.3;`;
---

<div
  style={`${reset} width: 100%; max-width: 520px; margin-inline: auto; font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif); color: var(--sl-color-white); display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 0;`}
>
  {/* the gate */}
  <div
    style={`${reset} flex: 0 0 auto; border: 1.5px solid var(--sl-color-gray-4, #94a3b8); border-radius: 10px; padding: 10px 11px; display: flex; flex-direction: column; gap: 4px;`}
  >
    <div style={`${reset} font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.6;`}>
      A gate
    </div>
    <div style={`${reset} ${mono} font-size: 12px; font-weight: 600; white-space: nowrap;`}>
      {"requireRole('admin')"}
    </div>
  </div>

  {/* fan lane: gate (left, mid) -> three outcome left-edges (right) */}
  <svg
    width={fanW}
    height={STACK_H}
    viewBox={`0 0 ${fanW} ${STACK_H}`}
    aria-hidden="true"
    style={`${reset} flex: 0 0 ${fanW}px; overflow: visible;`}
  >
    <defs>
      <marker id="fan-green" markerWidth="7" markerHeight="7" refX="5.5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill={green}></path>
      </marker>
      <marker id="fan-red" markerWidth="7" markerHeight="7" refX="5.5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill={red}></path>
      </marker>
      <marker id="fan-amber" markerWidth="7" markerHeight="7" refX="5.5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill={amber}></path>
      </marker>
    </defs>
    <path
      d={`M0,${cyGate} C${fanW * 0.6},${cyGate} ${fanW * 0.4},${cyAllow} ${fanW},${cyAllow}`}
      fill="none" stroke={green} stroke-width="2" opacity="0.9" marker-end="url(#fan-green)"
    ></path>
    <path
      d={`M0,${cyGate} L${fanW},${cyDeny}`}
      fill="none" stroke={red} stroke-width="2" opacity="0.9" marker-end="url(#fan-red)"
    ></path>
    <path
      d={`M0,${cyGate} C${fanW * 0.6},${cyGate} ${fanW * 0.4},${cyCheck} ${fanW},${cyCheck}`}
      fill="none" stroke={amber} stroke-width="2" stroke-dasharray="4 4" opacity="0.9" marker-end="url(#fan-amber)"
    ></path>
  </svg>

  {/* the three outcomes */}
  <div style={`${reset} flex: 0 1 270px; min-width: 0; display: flex; flex-direction: column; gap: ${GAP}px;`}>
    <div style={settled(green)}>
      <div style={titleStyle(green)}>Allow</div>
      <div style={subStyle}>role proven sufficient → proceed</div>
    </div>

    <div style={settled(red)}>
      <div style={titleStyle(red)}>Deny</div>
      <div style={subStyle}>role proven insufficient → refuse</div>
    </div>

    <div style={uncertain(amber)}>
      <div style={`${reset} display: flex; align-items: baseline; gap: 6px;`}>
        <span style={titleStyle(amber)}>Check failed</span>
        <span style={`${reset} font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: ${amber}; opacity: 0.85;`}>
          uncertain
        </span>
      </div>
      <div style={subMono}>{"DB threw · unexpected null · impossible state"}</div>
    </div>
  </div>

  {/* fold lane: amber box (bottom) folds UP into the red Deny box (middle) */}
  <svg
    width={foldW}
    height={STACK_H}
    viewBox={`0 0 ${foldW} ${STACK_H}`}
    aria-hidden="true"
    style={`${reset} flex: 0 0 ${foldW}px; overflow: visible;`}
  >
    <defs>
      <marker id="fold-red" markerWidth="7" markerHeight="7" refX="5.5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill={red}></path>
      </marker>
    </defs>
    {/* from amber box right edge, bow out and up into the red box right edge */}
    <path
      d={`M0,${cyCheck} C${foldW * 1.3},${cyCheck - 4} ${foldW * 1.3},${cyDeny + 4} 0,${cyDeny}`}
      fill="none" stroke={amber} stroke-width="2.25" marker-end="url(#fold-red)"
    ></path>
  </svg>

  {/* fail-closed label, vertically centred on the fold */}
  <div style={`${reset} flex: 0 0 auto; align-self: stretch; display: flex; align-items: center; padding-left: 3px;`}>
    <span
      style={`${reset} ${mono} font-size: 10.5px; font-weight: 700; color: ${amber}; writing-mode: vertical-rl; letter-spacing: 0.03em;`}
    >
      fail-closed
    </span>
  </div>
</div>
