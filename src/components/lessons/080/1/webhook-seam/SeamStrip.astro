---
// One frame of the "webhook-seam" DiagramSequence (Ch080 L1, "Refuse by
// default"). It reuses the chapter-family horizontal strip grammar (Ch057's
// authed-action-gates, Ch049's render-pipeline): a row of nodes with one lit
// (`is-on`, the accent), already-passed nodes dimmed (`is-done`), and SVG arrow
// connectors that light as they're crossed. So the webhook receiver reads in the
// same visual language as the rest of the course.
//
// The three stages a Stripe event flows through, in execution order:
//
//   Verify signature → Claim event (dedup) → Run business work
//
// The strip is fixed across the four steps; only the lit node, the dimmed
// already-passed nodes, and the detail panel beneath change. On the final step
// every node is `is-done` (all three gates passed) — there is no further lit node
// because the work is committed.
//
// The detail panel under the strip carries this stage's BRANCH OUTCOMES, each
// tagged with the HTTP status the provider sees. That status is the teaching beat:
// a refusal of a forged/malformed request (400/401) reads red, a transient failure
// that the provider will retry (500) reads amber, and a genuine success (200,
// including the already-processed short-circuit) reads green. A fixed min-height
// keeps every frame the same height so DiagramSequence's grid-stack never jumps.
//
// Pure HTML + CSS, matching the sibling figures: `.not-content` to drop
// Starlight's prose chrome, `margin: 0` resets, theme-aware `color-mix` accents
// that read on light and dark.

interface Props {
	// Index (0-2) of the stage lit this frame. Pass `done` for the committed final
	// frame where every stage is `is-done` and nothing is lit.
	active?: number;
	done?: boolean;
}

const { active, done = false } = Astro.props;

// The three stages, in order. `label` is the node's headline, `sub` the one-line
// mechanism under it.
const nodes: { label: string; sub: string }[] = [
	{ label: "Verify signature", sub: "HMAC compare" },
	{ label: "Claim event", sub: "dedup ledger" },
	{ label: "Run business work", sub: "same txn" },
];

const ACCENT = "#2563eb"; // blue-600 — the chapter's "gate" accent
---

<div class="ws-stage not-content">
	<div
		class="ws-strip"
		role="img"
		aria-label="A Stripe webhook flows through three gates in order: Verify signature, Claim the event in the dedup ledger, Run the business work. Active gate highlighted."
	>
		{
			nodes.map((node, i) => {
				const isOn = !done && i === active;
				const isDone = done || (active !== undefined && i < active);
				return (
					<>
						<div class:list={["ws-node", { "is-on": isOn, "is-done": isDone }]}>
							<span class="ws-node-label">{node.label}</span>
							<span class="ws-node-sub">{node.sub}</span>
						</div>
						{i < nodes.length - 1 && (
							<span
								class:list={[
									"ws-arrow",
									{ "is-on": done || (active !== undefined && i < active) },
								]}
								aria-hidden="true"
							>
								<svg
									viewBox="0 0 34 14"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<line x1="1" y1="7" x2="26" y2="7" />
									<polyline points="21 2.5 27.5 7 21 11.5" />
								</svg>
							</span>
						)}
					</>
				);
			})
		}
	</div>

	<div class="ws-detail">
		<slot />
	</div>
</div>

<style define:vars={{ accent: ACCENT }}>
	.ws-stage {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* The horizontal stage strip. Wraps (never scrolls) on narrow viewports. */
	.ws-strip {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 5px;
	}

	.ws-node {
		margin: 0;
		flex: 1 1 0;
		min-width: 124px;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3px;
		padding: 11px 10px;
		border-radius: 9px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s,
			opacity 0.14s;
	}
	/* Gates already crossed: tinted but receded, so the strip reads as a path
	   already walked. On the final frame all three are `is-done`. */
	.ws-node.is-done {
		border-color: color-mix(in srgb, var(--accent) 32%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--accent) 7%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 45%, var(--sl-color-gray-3));
		opacity: 0.78;
	}
	.ws-node.is-on {
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
		opacity: 1;
	}

	.ws-node-label {
		margin: 0;
		font-size: 13.5px;
		font-weight: 700;
		line-height: 1.2;
	}
	.ws-node-sub {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.2;
		opacity: 0.9;
	}

	/* Connectors between stages. Edges already crossed light up so the strip reads
	   as a request moving through, not a static row. */
	.ws-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.ws-arrow.is-on {
		color: var(--accent);
	}
	.ws-arrow svg {
		width: 26px;
		height: 13px;
	}

	/* Detail panel under the strip — carries this stage's branch outcomes. Fixed
	   min-height so every frame matches and the grid-stacked sequence never changes
	   height between steps. */
	.ws-detail {
		margin: 0;
		box-sizing: border-box;
		min-height: 132px;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		justify-content: center;
		gap: 9px;
		padding: 14px 16px;
		border-radius: 10px;
		border: 1px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
	}

	/* On the narrowest viewports the stages stack; rotate the connectors so the
	   flow still reads top-to-bottom. */
	@media (max-width: 640px) {
		.ws-strip {
			flex-direction: column;
			align-items: stretch;
		}
		.ws-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
