---
// webhook-seam — Ch080 L1 "Refuse by default", the section figure for "The
// webhook seam — refuse aggressively, retry safely".
//
// One Stripe event scrubbed through the receiver's three gates, one lit at a time:
//
//   Verify signature → Claim event (dedup) → Run business work
//
// The teaching goal, straight from the lesson: the whole receiver fails closed —
// when anything is uncertain it refuses — but it refuses with a DIFFERENT status
// code at each gate, because the provider reads the status to decide what to do
// next. So the detail panel under the strip lists this gate's branch outcomes,
// each tagged with the HTTP status, and the pill colour encodes the meaning:
//   - refuse (red)    400 / 401 — a forged or malformed request, refused outright
//   - retry  (amber)  500       — a transient failure; refused, and the provider retries
//   - success (green) 200       — genuine success, INCLUDING the already-processed
//                                 dedup short-circuit (a success, not a refusal)
//
// The pairing the lesson lands: fail-closed is safe here precisely because the
// retry is idempotent — a 500 is refused work the provider re-runs, and the dedup
// ledger + transaction guarantee the business work runs exactly once.
//
// It reuses the chapter's horizontal strip grammar via <SeamStrip> (lit/dimmed
// node strip + arrow connectors that light as crossed). DiagramSequence supplies
// the outer card + per-step captions, so this is NOT wrapped in <Figure>.

import DiagramSequence from "../../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../figures/diagram-sequence/DiagramStep.astro";
import SeamStrip from "./SeamStrip.astro";

const ACCENT = "#2563eb"; // blue-600 — matches the lit node in <SeamStrip>
---

<DiagramSequence>
	{/* 0 — Verify signature */}
	<DiagramStep caption="Signature verify is the gate. Read the raw body, recompute the HMAC, constant-time compare against the Stripe-Signature header. Nothing past this line runs until we have proven the event is really from Stripe.">
		<SeamStrip active={0}>
			<div class="ws-branch">
				<span class="ws-status ws-status--refuse">400 refuse</span>
				<span class="ws-out"
					>A <strong>throw</strong> — malformed header, unparseable timestamp. The
					verifier broke, so the request is refused.</span
				>
			</div>
			<div class="ws-branch">
				<span class="ws-status ws-status--refuse">401 refuse</span>
				<span class="ws-out"
					>A real <strong>mismatch</strong> — the signature does not match. Forged
					or tampered; refused.</span
				>
			</div>
		</SeamStrip>
	</DiagramStep>

	{/* 1 — Claim event (dedup) */}
	<DiagramStep caption="Claim the event id in the processed_events ledger with INSERT ... ON CONFLICT DO NOTHING. An already-claimed id is a duplicate retry — that 200 is a success, not a refusal. A DB blip throws, and the provider retries.">
		<SeamStrip active={1}>
			<div class="ws-branch">
				<span class="ws-status ws-status--ok">200 success</span>
				<span class="ws-out"
					>The id is <strong>already there</strong> — a duplicate retry. Short-circuit
					and report success; the work already ran once.</span
				>
			</div>
			<div class="ws-branch">
				<span class="ws-status ws-status--retry">500 retry</span>
				<span class="ws-out"
					>A <strong>throw</strong> — the DB blipped claiming the id. Refused, and
					the provider will retry the event.</span
				>
			</div>
		</SeamStrip>
	</DiagramStep>

	{/* 2 — Run business work */}
	<DiagramStep caption="Inside the same transaction as the claim, do the actual work — project the subscription change. A throw rolls back the work AND the claim with it, so the provider retries the whole event cleanly later.">
		<SeamStrip active={2}>
			<div class="ws-branch">
				<span class="ws-status ws-status--retry">500 retry</span>
				<span class="ws-out"
					>A <strong>throw</strong> — projecting the change failed. The
					transaction rolls back; the claim rolls back <strong>with it</strong>;
					the provider retries.</span
				>
			</div>
		</SeamStrip>
	</DiagramStep>

	{/* 3 — Committed: all three gates passed */}
	<DiagramStep caption="All three gates passed: verified, claimed, processed. Commit the transaction and return 200. The event ran exactly once, and any retry from here forward hits the dedup and short-circuits at the claim stage.">
		<SeamStrip done={true}>
			<div class="ws-branch ws-branch--final">
				<span class="ws-status ws-status--ok">200</span>
				<span class="ws-out"
					><strong>Commit and return 200.</strong> Verified, claimed, processed —
					the event ran <strong>exactly once</strong>. Refuse aggressively, retry
					safely.</span
				>
			</div>
		</SeamStrip>
	</DiagramStep>
</DiagramSequence>

<style define:vars={{ accent: ACCENT }}>
	/* One branch outcome: a status pill + the one-line description of that branch.
	   Rows are left-aligned so the pills form a scannable status column. */
	.ws-branch {
		margin: 0;
		display: flex;
		align-items: baseline;
		gap: 11px;
	}
	.ws-branch--final {
		align-items: baseline;
	}

	/* The status pill — the glanceable HTTP status the provider sees. Colour is the
	   teaching beat: red = refused (forged/malformed), amber = refused-but-retried
	   (transient), green = genuine success (including already-processed). */
	.ws-status {
		flex: 0 0 auto;
		display: inline-block;
		min-width: 84px;
		text-align: center;
		padding: 2px 9px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.02em;
		line-height: 1.5;
		white-space: nowrap;
	}
	/* Refuse: a forged or malformed request, refused outright. Red. */
	.ws-status--refuse {
		border-color: color-mix(in srgb, #dc2626 52%, transparent);
		background: color-mix(in srgb, #dc2626 13%, var(--sl-color-bg));
		color: color-mix(in srgb, #b91c1c 80%, var(--sl-color-text));
	}
	/* Retry: a transient failure — still refused, but the provider re-runs. Amber. */
	.ws-status--retry {
		border-color: color-mix(in srgb, #d97706 55%, transparent);
		background: color-mix(in srgb, #d97706 14%, var(--sl-color-bg));
		color: color-mix(in srgb, #b45309 80%, var(--sl-color-text));
	}
	/* Success: genuine 200, including the already-processed short-circuit. Green. */
	.ws-status--ok {
		border-color: color-mix(in srgb, #16a34a 52%, transparent);
		background: color-mix(in srgb, #16a34a 13%, var(--sl-color-bg));
		color: color-mix(in srgb, #15803d 82%, var(--sl-color-text));
	}

	.ws-out {
		margin: 0;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
	}
	.ws-out strong {
		font-weight: 700;
		color: color-mix(in srgb, var(--accent) 72%, var(--sl-color-text));
	}
</style>
