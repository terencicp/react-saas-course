---
// ComponentProps <-> ComponentType — the dual relationship, made directional.
//
// Two rows, each a single left-to-right arrow, so the two helpers never share a
// gap (no crossing curves — the ArrowDiagram "one arrow per row" safe pattern):
//
//   ROW 1  [ Button ] --ComponentProps<typeof Button>--> [ its props ]
//          component                                       props type
//   ROW 2  [ WidgetProps ] --ComponentType<WidgetProps>--> [ a component ]
//          props type                                        component
//
// The duality is carried by *colour, not arrow direction*: every box is tagged
// and tinted by its KIND — a component is blue, a props type is purple — so the
// top row reads blue -> purple and the bottom row reads purple -> blue. The
// mirror IS the point: one helper turns a component into its props, its dual
// turns a props type into a component. Each arrow is coloured the kind it
// *yields* (top arrow purple = "produces props", bottom arrow blue = "produces a
// component"), reinforcing the direction without adding a third colour.
//
// Engine: <ArrowDiagram> (leader-line) — the nodes are styled HTML pills with a
// kind tag, and the lesson's TODO calls for it. Cross-region layout per row:
// source on the left (socket 'right'), target on the right (socket 'left'), a
// wide centre gap that holds the curve + its helper label.
//
// MUST live inside <Figure expandable={false}> — leader-line positions arrows
// from document.body, so relocating the figure into the expand lightbox breaks
// them.
//
// Styling mirrors the chapter's sibling figures (FreeBehaviorMap.astro,
// StateSpaceCollapse.astro): inline style arrays joined with ';', theme-aware
// color-mix mid-tones, `not-content` to drop Starlight prose chrome, `margin: 0`
// reset to defeat the prose-margin selector. The grid lives one level *below*
// .arrow-stage (a flex column wraps the two row-grids) so the column tracks
// survive — a display:grid on an ancestor of .arrow-stage would collapse them.

import ArrowDiagram from "../../../figures/ArrowDiagram.astro";

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// One hue per KIND. Blue = a component; purple = a props type. The same two
// colours the chapter's StateSpaceCollapse uses for its primary chip / accents,
// kept mid-tone so they read on both light and dark theme.
const COMPONENT = "#2563eb"; // blue-600
const PROPS = "#9333ea"; // purple-600

// A kind-tagged pill: the identifier (mono) over a tiny uppercase kind tag,
// the whole thing tinted by the kind's hue.
const tile = (color: string) =>
  [
    reset,
    "box-sizing: border-box",
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "gap: 5px",
    "padding: 11px 16px",
    "border-radius: 11px",
    "border: 1.5px solid",
    `border-color: color-mix(in srgb, ${color} 55%, var(--sl-color-gray-4))`,
    `background: color-mix(in srgb, ${color} 11%, transparent)`,
  ].join("; ");

const tileName = (color: string) =>
  [
    reset,
    mono,
    "font-size: 15px",
    "font-weight: 700",
    "line-height: 1.1",
    "white-space: nowrap",
    `color: color-mix(in srgb, ${color} 78%, var(--sl-color-text))`,
  ].join("; ");

const tileKind = (color: string) =>
  [
    reset,
    sans,
    "font-size: 9.5px",
    "font-weight: 700",
    "letter-spacing: 0.06em",
    "text-transform: uppercase",
    "line-height: 1",
    "white-space: nowrap",
    `color: color-mix(in srgb, ${color} 62%, var(--sl-color-gray-3))`,
  ].join("; ");

// Each row is its own 3-track grid: source | gap (curve + label) | target.
// A generous centre track reserves room for the helper label badge so it sits
// clear of the curve. The two source columns and the two target columns line up
// across rows so the blue/purple swap reads cleanly down the figure.
const rows = [
  reset,
  sans,
  "box-sizing: border-box",
  "display: flex",
  "flex-direction: column",
  "gap: 26px",
  "max-width: 560px",
  "margin: 0 auto",
].join("; ");

const row = [
  reset,
  "box-sizing: border-box",
  "display: grid",
  "grid-template-columns: minmax(150px, 1fr) 150px minmax(150px, 1fr)",
  "align-items: center",
].join("; ");

// The grid cell that centres a tile inside its track (so the arrow socket lands
// on the tile's true edge, centred against its row partner).
const cell = [
  reset,
  "box-sizing: border-box",
  "display: flex",
  "align-items: center",
  "justify-content: center",
].join("; ");

// ROW 1: component -> props.  ROW 2: props -> component.
// `arrowColor` is the colour of what the helper *yields*.
const arrows = [
  {
    from: "dual-button",
    to: "dual-buttonprops",
    label: "ComponentProps<typeof Button>",
    color: PROPS,
    startSocket: "right" as const,
    endSocket: "left" as const,
    startSocketGravity: [70, 0] as [number, number],
    endSocketGravity: [-70, 0] as [number, number],
    labelOffset: [0, -16] as [number, number],
  },
  {
    from: "dual-widgetprops",
    to: "dual-widgetcomponent",
    label: "ComponentType<WidgetProps>",
    color: COMPONENT,
    startSocket: "right" as const,
    endSocket: "left" as const,
    startSocketGravity: [70, 0] as [number, number],
    endSocketGravity: [-70, 0] as [number, number],
    labelOffset: [0, -16] as [number, number],
  },
];
---

<div class="not-content">
  <ArrowDiagram arrows={arrows}>
    {/* The flex column is a *descendant* of .arrow-stage, so each row-grid's
        three tracks lay out as real columns (source | gap | target). */}
    <div style={rows}>
      {/* ROW 1 — a component yields its props */}
      <div style={row}>
        <div style={cell}>
          <div id="dual-button" style={tile(COMPONENT)}>
            <span style={tileName(COMPONENT)}>Button</span>
            <span style={tileKind(COMPONENT)}>a component</span>
          </div>
        </div>
        <div></div>
        <div style={cell}>
          <div id="dual-buttonprops" style={tile(PROPS)}>
            <span style={tileName(PROPS)}>ButtonProps</span>
            <span style={tileKind(PROPS)}>a props type</span>
          </div>
        </div>
      </div>

      {/* ROW 2 — a props type yields a component (the dual) */}
      <div style={row}>
        <div style={cell}>
          <div id="dual-widgetprops" style={tile(PROPS)}>
            <span style={tileName(PROPS)}>WidgetProps</span>
            <span style={tileKind(PROPS)}>a props type</span>
          </div>
        </div>
        <div></div>
        <div style={cell}>
          <div id="dual-widgetcomponent" style={tile(COMPONENT)}>
            <span style={tileName(COMPONENT)}>Widget</span>
            <span style={tileKind(COMPONENT)}>a component</span>
          </div>
        </div>
      </div>
    </div>
  </ArrowDiagram>
</div>
