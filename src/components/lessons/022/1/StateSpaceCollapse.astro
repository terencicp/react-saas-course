---
// State-space collapse — three independent booleans vs one variant union.
//
// LEFT: a truth table of the 2^3 = 8 combinations of (isPrimary,
// isDestructive, isGhost). Exactly the three rows with a single flag on are
// legal; the other five (two-or-more flags on, or all off) are nonsense and
// are greyed + struck. RIGHT: the union collapses that to three chips —
// primary / destructive / ghost — every one legal, nothing illegal left to
// spell. Each legal row is color-coded to the chip it survives as, so the
// "these three, and only these three, are real" mapping reads visually.
//
// Pure HTML + CSS, devtools-inspectable, matching the chapter's other figures
// (see DefaultVsPropagationGrid / SameSiteMatrix): a `not-content` wrapper,
// saturated mid-tone fills (Tailwind ~600 range) with white text that read on
// both light and dark theme where the color carries meaning, Starlight gray
// variables for chrome, and a `margin: 0` reset on every inner element to
// defeat Starlight's prose-margin selector.

const reset = "margin: 0";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// The three boolean flags, in column order.
const flags = ["isPrimary", "isDestructive", "isGhost"];

// One accent per legal variant. Each is the color shared by a legal table row
// and its surviving chip, so the collapse is a visible color mapping.
const PRIMARY = "#2563eb"; // blue-600
const DESTRUCTIVE = "#dc2626"; // red-600
const GHOST = "#64748b"; // slate-500 — the "subtle" variant

// All 2^3 combinations, in counting order (FFF, FFT, ..., TTT). A row is legal
// only when exactly one flag is true; that lone true flag names the variant
// the row collapses into. Illegal rows carry the reason they're nonsense.
type Combo = {
  bits: [boolean, boolean, boolean];
  variant: string | null; // the surviving variant when legal, else null
  color: string | null; // accent shared with that variant's chip
  reason: string; // why it's illegal (empty when legal)
};

const onCount = (bits: boolean[]) => bits.filter(Boolean).length;

const combos: Combo[] = Array.from({ length: 8 }, (_, i) => {
  const bits: [boolean, boolean, boolean] = [
    Boolean(i & 0b100),
    Boolean(i & 0b010),
    Boolean(i & 0b001),
  ];
  const n = onCount(bits);
  const legal = n === 1;
  const variant = legal ? flags[bits.indexOf(true)].replace(/^is/, "").toLowerCase() : null;
  const color = !legal ? null : variant === "primary" ? PRIMARY : variant === "destructive" ? DESTRUCTIVE : GHOST;
  const reason = legal ? "" : n === 0 ? "no appearance" : "two appearances at once";
  return { bits, variant, color, reason };
});

// The three chips on the right, in the same color order as the legal rows.
const chips = [
  { label: "primary", color: PRIMARY },
  { label: "destructive", color: DESTRUCTIVE },
  { label: "ghost", color: GHOST },
];

// ---- styles -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "justify-content: center",
  "column-gap: 26px",
  "row-gap: 22px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// A titled panel (left table / right chips share the same chrome).
const panel = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "box-sizing: border-box",
].join("; ");

const panelTitle = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "text-align: center",
  "line-height: 1.2",
].join("; ");

// Left table: a column-header row of the three flag names, then 8 combo rows.
const table = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
  "padding: 10px",
  "border-radius: 12px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "box-sizing: border-box",
].join("; ");

// Header row + body rows share this grid: three fixed flag columns, then a
// flexible trailing column for the verdict (variant name or reason).
const rowGrid =
  "display: grid; grid-template-columns: repeat(3, 30px) minmax(130px, 1fr); align-items: center; gap: 6px";

const headCell = [
  reset,
  mono,
  "font-size: 10px",
  "font-weight: 600",
  "color: var(--sl-color-gray-3)",
  "text-align: center",
  "line-height: 1.1",
  "white-space: nowrap",
  // each header sits over its 30px column; let the long names lean out evenly
  "transform: rotate(-32deg)",
  "transform-origin: center",
].join("; ");

// A legal row: tinted to its variant color, the surviving variant named.
const legalRow = (color: string) =>
  [
    reset,
    rowGrid,
    "padding: 5px 8px",
    "border-radius: 8px",
    "border: 1px solid " + `color-mix(in srgb, ${color} 55%, transparent)`,
    "background: " + `color-mix(in srgb, ${color} 14%, transparent)`,
  ].join("; ");

// An illegal row: muted, the whole thing reads as struck-out scaffolding.
const illegalRow = [
  reset,
  rowGrid,
  "padding: 5px 8px",
  "border-radius: 8px",
  "border: 1px solid transparent",
  "opacity: 0.5",
].join("; ");

// A single T/F bit. Legal-row bits are crisp; illegal-row bits stay neutral.
const bit = (on: boolean, color: string | null) =>
  [
    reset,
    mono,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "width: 30px",
    "height: 22px",
    "border-radius: 5px",
    "font-size: 12px",
    "font-weight: 700",
    "box-sizing: border-box",
    color && on
      ? `background: ${color}; color: #ffffff;`
      : color
        ? `background: color-mix(in srgb, ${color} 10%, transparent); color: var(--sl-color-gray-2); border: 1px solid color-mix(in srgb, ${color} 25%, transparent);`
        : on
          ? "background: var(--sl-color-gray-4); color: var(--sl-color-white);"
          : "background: var(--sl-color-gray-6); color: var(--sl-color-gray-3); border: 1px solid var(--sl-color-gray-5);",
  ].join("; ");

// Trailing verdict on a legal row — the surviving variant name.
const verdictLegal = (color: string) =>
  [
    reset,
    mono,
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1.1",
    "white-space: nowrap",
    "color: " + `color-mix(in srgb, ${color} 72%, var(--sl-color-white))`,
  ].join("; ");

// Trailing verdict on an illegal row — struck reason, muted.
const verdictIllegal = [
  reset,
  sans,
  "font-size: 11.5px",
  "font-style: italic",
  "line-height: 1.1",
  "white-space: nowrap",
  "text-decoration: line-through",
  "text-decoration-color: var(--sl-color-gray-3)",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The "collapses to" connector between the two panels.
const connector = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 4px",
  "color: var(--sl-color-gray-3)",
].join("; ");

const connectorLabel = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

// Right panel: a clean vertical strip of the three legal variant chips.
const chipStrip = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 8px",
  "padding: 10px",
  "border-radius: 12px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "box-sizing: border-box",
].join("; ");

const chip = (color: string) =>
  [
    reset,
    mono,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "min-width: 130px",
    "padding: 8px 14px",
    "border-radius: 8px",
    "background: " + color,
    "color: #ffffff",
    "font-size: 13px",
    "font-weight: 700",
    "line-height: 1.1",
    "box-sizing: border-box",
  ].join("; ");
---

<div class="not-content" style={root}>
  {/* LEFT — three booleans, eight rows, five of them struck */}
  <div style={panel}>
    <span style={panelTitle}>Three booleans &rarr; 8 states</span>
    <div style={table}>
      {/* column headers: the three flag names */}
      <div style={`${reset}; ${rowGrid}; padding: 0 8px 4px;`}>
        {flags.map((f) => <span style={headCell}>{f}</span>)}
        <span></span>
      </div>
      {/* one row per combination */}
      {
        combos.map((c) =>
          c.variant && c.color ? (
            <div style={legalRow(c.color)}>
              {c.bits.map((b) => (
                <span style={bit(b, c.color)}>{b ? "T" : "F"}</span>
              ))}
              <span style={verdictLegal(c.color)}>{c.variant}</span>
            </div>
          ) : (
            <div style={illegalRow}>
              {c.bits.map((b) => (
                <span style={bit(b, null)}>{b ? "T" : "F"}</span>
              ))}
              <span style={verdictIllegal}>{c.reason}</span>
            </div>
          ),
        )
      }
    </div>
  </div>

  {/* CONNECTOR — collapses to */}
  <div style={connector}>
    <span style={connectorLabel}>collapses to</span>
    <svg
      width="46"
      height="20"
      viewBox="0 0 46 20"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      style="margin: 0; display: block;"
    >
      <line x1="2" y1="10" x2="40" y2="10" />
      <polyline points="33 4 41 10 33 16" />
    </svg>
  </div>

  {/* RIGHT — one union, three chips, all legal */}
  <div style={panel}>
    <span style={panelTitle}>One union &rarr; 3 states</span>
    <div style={chipStrip}>
      {chips.map((c) => <div style={chip(c.color)}>{c.label}</div>)}
    </div>
  </div>
</div>
