---
// The ref-callback lifecycle figure: makes "setup at attach / cleanup at detach"
// tangible, and lands the one counter-intuitive React 19 fact — on unmount the
// callback is NOT re-called with null; the returned cleanup runs instead.
//
// Shape: a scrubbable three-step sequence (DiagramSequence). Each step shows the
// SAME small diagram in a different state — a "node" box on the left, an arrow,
// and an "observer" box on the right — plus a compact 4-line code strip with the
// LINE that is "active" for that step highlighted. Reading the three steps in
// order is the lesson: create → observe → disconnect.
//
//   Mount     — node solid, observer forming (dim/dashed), arrow forming.
//               The observe(node) setup line is active (green).
//   Observing — both boxes solid, a steady link, an "observing" badge.
//               Nothing re-runs; the setup happened once.
//   Unmount   — node fading out, the link broken (X), observer disconnected.
//               The returned-cleanup line is active (red); a prominent callout
//               states the callback is NOT re-called with null.
//
// Why DiagramSequence and not a static strip: the value here is the TRANSITION
// between states over the node's life, which the scrubber makes felt. Why HTML +
// CSS boxes and not <ArrowDiagram>: the single straight connector per step is
// trivial as a flex row, and the three states need per-step restyling (dashed /
// solid / broken) that plain CSS does cleanly without LeaderLine bookkeeping.
//
// Styling follows the sibling figures in this chapter (SlotPropMerge / CvaLookup):
// `not-content` + a `margin: 0` reset on every node defeat Starlight's prose
// margins; Starlight gray/white variables flip with light/dark; the --mark-*
// accents (custom.css) flip too. The component owns its DiagramSequence + steps
// so the MDX stays a single import.

import DiagramSequence from "../../../figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../figures/diagram-sequence/DiagramStep.astro";

const reset = "margin: 0";

const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// ── stage: the node — arrow — observer row ────────────────────────────────────

const stage = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "gap: 0",
  "padding: 18px 8px 6px",
  "box-sizing: border-box",
].join("; ");

type BoxState = "solid" | "forming" | "fading";

// A labelled box (the DOM node, or the observer). `accent` picks its colour band;
// `state` controls whether it reads as present (solid), being created (forming,
// dashed + dim), or leaving (fading, dashed + very dim).
const box = (accent: "blue" | "green", state: BoxState) => {
  const bg =
    accent === "blue" ? "var(--mark-blue-bg)" : "var(--mark-green-bg)";
  const brd =
    accent === "blue" ? "var(--mark-blue-brd)" : "var(--mark-green-brd)";
  return [
    reset,
    "display: flex",
    "flex-direction: column",
    "align-items: center",
    "gap: 4px",
    "min-width: 132px",
    "padding: 12px 14px",
    "border-radius: 10px",
    "background: " + bg,
    "border: 2px " + (state === "solid" ? "solid" : "dashed") + " " + brd,
    "box-sizing: border-box",
    "transition: opacity 0.2s",
    state === "forming"
      ? "opacity: 0.5"
      : state === "fading"
        ? "opacity: 0.32"
        : "opacity: 1",
  ].join("; ");
};

const boxTitle = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const boxSub = [
  reset,
  sans,
  "font-size: 11px",
  "line-height: 1.25",
  "text-align: center",
  "color: var(--sl-color-gray-2)",
].join("; ");

// A small status pill sitting under a box's label (e.g. "watching").
const badge = (tone: "green" | "red") =>
  [
    reset,
    sans,
    "margin-top: 2px",
    "font-size: 10px",
    "font-weight: 700",
    "letter-spacing: 0.04em",
    "text-transform: uppercase",
    "line-height: 1",
    "padding: 3px 7px",
    "border-radius: 999px",
    "color: var(--sl-color-white)",
    tone === "green"
      ? "background: var(--mark-green-bg); border: 1px solid var(--mark-green-brd)"
      : "background: var(--mark-red-bg); border: 1px solid var(--mark-red-brd)",
  ].join("; ");

// The connector between the two boxes. Three flavours: forming (dashed, dim),
// live (solid), broken (a gap with a red × marker over it).
const connectorWrap = [
  reset,
  "position: relative",
  "flex: 0 0 auto",
  "width: 96px",
  "height: 28px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "box-sizing: border-box",
].join("; ");

const line = (kind: "forming" | "live" | "broken") =>
  [
    reset,
    "width: 100%",
    "height: 0",
    "border-top: 2px " +
      (kind === "live" ? "solid" : "dashed") +
      " " +
      (kind === "broken"
        ? "var(--mark-red-brd)"
        : "var(--sl-color-gray-3)"),
    kind === "forming" ? "opacity: 0.55" : "opacity: 1",
    "box-sizing: border-box",
  ].join("; ");

// The little × that sits over a broken connector to read "link torn down".
const breakMark = [
  reset,
  sans,
  "position: absolute",
  "top: 50%",
  "left: 50%",
  "transform: translate(-50%, -50%)",
  "width: 20px",
  "height: 20px",
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "font-size: 14px",
  "font-weight: 800",
  "line-height: 1",
  "color: var(--sl-color-white)",
  "background: var(--mark-red-bg)",
  "border: 1px solid var(--mark-red-brd)",
  "border-radius: 50%",
  "box-sizing: border-box",
].join("; ");

// The verb riding above the connector — "observe()" while wiring, "disconnect()"
// while tearing down — tinted to match the active operation.
const connectorVerb = (tone: "green" | "red" | "muted") =>
  [
    reset,
    mono,
    "position: absolute",
    "bottom: 100%",
    "left: 50%",
    "transform: translateX(-50%)",
    "margin-bottom: 2px",
    "white-space: nowrap",
    "font-size: 10.5px",
    "font-weight: 600",
    "line-height: 1",
    tone === "green"
      ? "color: var(--mark-green-brd)"
      : tone === "red"
        ? "color: var(--mark-red-brd)"
        : "color: var(--sl-color-gray-3)",
  ].join("; ");

// ── code strip: the 4-line callback, one line active per step ─────────────────

const codeStrip = [
  reset,
  mono,
  "display: flex",
  "flex-direction: column",
  "gap: 0",
  "margin-top: 6px",
  "padding: 10px 0",
  "border-radius: 8px",
  "background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
  "border: 1px solid var(--sl-color-gray-5)",
  "box-sizing: border-box",
  "overflow: hidden",
].join("; ");

type LineState = "dim" | "plain" | "setup" | "cleanup";

const codeLine = (st: LineState) =>
  [
    reset,
    mono,
    "display: block",
    "padding: 3px 12px",
    "font-size: 12px",
    "line-height: 1.55",
    "white-space: pre",
    "box-sizing: border-box",
    st === "dim"
      ? "color: var(--sl-color-gray-4)"
      : st === "plain"
        ? "color: var(--sl-color-gray-2)"
        : "color: var(--sl-color-white)",
    st === "setup"
      ? "background: var(--mark-green-bg); box-shadow: inset 3px 0 0 var(--mark-green-brd)"
      : st === "cleanup"
        ? "background: var(--mark-red-bg); box-shadow: inset 3px 0 0 var(--mark-red-brd)"
        : "",
  ].join("; ");

// The four source lines of the callback, rendered every step with per-step
// `states` deciding which one lights up. Index 3 is the returned cleanup.
const lines = [
  "<div ref={(node) => {",
  "  const observer = new IntersectionObserver(/* … */);",
  "  observer.observe(node);",
  "  return () => observer.disconnect();",
  "}} />",
];

// ── the red "not re-called with null" callout for the unmount step ────────────

const calloutRow = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "margin-top: 10px",
  "padding: 9px 12px",
  "border-radius: 8px",
  "background: var(--mark-red-bg)",
  "border: 1px solid var(--mark-red-brd)",
  "box-sizing: border-box",
].join("; ");

const calloutIcon = [
  reset,
  sans,
  "flex: 0 0 auto",
  "font-size: 13px",
  "line-height: 1",
].join("; ");

const calloutText = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.45",
  "color: var(--sl-color-white)",
].join("; ");

const calloutCode = [
  reset,
  mono,
  "font-size: 12px",
  "font-weight: 600",
  "padding: 1px 4px",
  "border-radius: 4px",
  "background: color-mix(in srgb, var(--mark-red-brd) 22%, transparent)",
  "color: var(--sl-color-white)",
].join("; ");

// A spacer that reserves the callout's height on the first two steps, so the
// stage doesn't reflow when step 3 reveals it. (DiagramSequence keeps every step
// in layout, sizing to the tallest — this just keeps THIS region steady too.)
---

<DiagramSequence>
    {/* ── Step 1: Mount ───────────────────────────────────────────────── */}
    <DiagramStep caption="Mount: the <div> renders, React calls the ref callback with the real node, the IntersectionObserver is created and observe(node) runs.">
      <div class="not-content rcl">
        <div style={stage}>
          <div style={box("blue", "solid")}>
            <span style={boxTitle}>&lt;div&gt; node</span>
            <span style={boxSub}>just attached</span>
          </div>
          <div style={connectorWrap}>
            <span style={connectorVerb("green")}>observe(node)</span>
            <span style={line("forming")}></span>
          </div>
          <div style={box("green", "forming")}>
            <span style={boxTitle}>observer</span>
            <span style={boxSub}>being created</span>
          </div>
        </div>

        <div style={codeStrip} aria-hidden="true">
          <span style={codeLine("plain")}>{lines[0]}</span>
          <span style={codeLine("plain")}>{lines[1]}</span>
          <span style={codeLine("setup")}>{lines[2]}</span>
          <span style={codeLine("dim")}>{lines[3]}</span>
          <span style={codeLine("plain")}>{lines[4]}</span>
        </div>

        <div style="height: 49px; box-sizing: border-box;" aria-hidden="true"></div>
      </div>
    </DiagramStep>

    {/* ── Step 2: Observing ───────────────────────────────────────────── */}
    <DiagramStep caption="Observing: the node is live and the observer is watching it. Nothing re-runs — the setup happened once, on attach.">
      <div class="not-content rcl">
        <div style={stage}>
          <div style={box("blue", "solid")}>
            <span style={boxTitle}>&lt;div&gt; node</span>
            <span style={boxSub}>in the tree</span>
          </div>
          <div style={connectorWrap}>
            <span style={connectorVerb("muted")}>watching</span>
            <span style={line("live")}></span>
          </div>
          <div style={box("green", "solid")}>
            <span style={boxTitle}>observer</span>
            <span style={badge("green")}>observing</span>
          </div>
        </div>

        <div style={codeStrip} aria-hidden="true">
          <span style={codeLine("plain")}>{lines[0]}</span>
          <span style={codeLine("dim")}>{lines[1]}</span>
          <span style={codeLine("dim")}>{lines[2]}</span>
          <span style={codeLine("dim")}>{lines[3]}</span>
          <span style={codeLine("plain")}>{lines[4]}</span>
        </div>

        <div style="height: 49px; box-sizing: border-box;" aria-hidden="true"></div>
      </div>
    </DiagramStep>

    {/* ── Step 3: Unmount ─────────────────────────────────────────────── */}
    <DiagramStep>
      <div class="not-content rcl">
        <div style={stage}>
          <div style={box("blue", "fading")}>
            <span style={boxTitle}>&lt;div&gt; node</span>
            <span style={boxSub}>leaving the tree</span>
          </div>
          <div style={connectorWrap}>
            <span style={connectorVerb("red")}>disconnect()</span>
            <span style={line("broken")}></span>
            <span style={breakMark} aria-hidden="true">&times;</span>
          </div>
          <div style={box("green", "fading")}>
            <span style={boxTitle}>observer</span>
            <span style={badge("red")}>disconnected</span>
          </div>
        </div>

        <div style={codeStrip} aria-hidden="true">
          <span style={codeLine("plain")}>{lines[0]}</span>
          <span style={codeLine("dim")}>{lines[1]}</span>
          <span style={codeLine("dim")}>{lines[2]}</span>
          <span style={codeLine("cleanup")}>{lines[3]}</span>
          <span style={codeLine("plain")}>{lines[4]}</span>
        </div>

        <div style={calloutRow}>
          <span style={calloutIcon} aria-hidden="true">&#9888;</span>
          <span style={calloutText}>
            The callback is <strong>not</strong> re-called with <span style={calloutCode}>null</span>.
            The returned cleanup runs instead — that return <em>is</em> the unmount signal now.
          </span>
        </div>
      </div>

      <Fragment slot="caption">
        Unmount: the <code>&lt;div&gt;</code> leaves the tree, React runs the returned cleanup, <code>observer.disconnect()</code> tears it down.
      </Fragment>
    </DiagramStep>
  </DiagramSequence>
