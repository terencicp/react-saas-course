---
// The Slot prop-merge figure: the single most clarifying visual in the lesson.
// It answers "what actually happens to my props when Slot merges?" in one glance.
//
// Shape: three vertical panels (parent / child / output) laid over a shared grid
// of FOUR prop rows. Reading ACROSS a row is the lesson — for each prop kind the
// reader sees the Slot's value, the child's value, the merge RULE, and what lands
// on the rendered element. The output cell is colour-coded by ORIGIN so the eye
// can trace each surviving piece back to the panel it came from:
//
//   parent (Slot) contributions  → blue   (--mark-blue)
//   child (<Link>) contributions → green  (--mark-green)
//
//   className → concatenated   (parent's classes THEN child's, both survive)
//   onClick   → composed       (both handlers fire)
//   ref       → forwarded      (parent's ref lands on the child's element)
//   href      → passthrough    (everything else: the child's own props ride along)
//
// Why a grid table and not <ArrowDiagram>: the relationship here is a per-row
// CONVERGENCE of two sources into one output. Drawing it with arrows means many
// curves piling into one narrow centre column (the ArrowDiagram doc's hardest
// case — stacked arrowheads, colliding curves) and the arrows would still only
// say "both flow in", never the per-prop RULE that is the takeaway. Row alignment
// expresses the convergence for free; colour expresses origin; the rule badge
// carries the lesson. So: no arrows — alignment + colour + a rule chip per row.
//
// Pure HTML + CSS, devtools-inspectable, matching the sibling CvaLookup figure in
// this lesson: `not-content` + a `margin: 0` reset on every node defeat
// Starlight's prose-margin injection; Starlight gray/white variables flip the
// chrome with light/dark; the --mark-* accents (custom.css) flip too.

const reset = "margin: 0";

const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// ── data ─────────────────────────────────────────────────────────────────────
// Each row is one prop kind. `parent` / `child` are what each side brings; the
// `rule` is the merge behaviour; `out` is the ordered list of segments that land
// on the rendered <a>, each tagged with the panel it originated from so the
// output reads as "blue piece + green piece" where both survive.

type Origin = "parent" | "child";

interface Row {
  prop: string;
  rule: string;
  ruleWord: string;
  // null = this side contributes nothing for this prop.
  parent: string | null;
  child: string | null;
  out: { text: string; origin: Origin }[];
  note: string;
}

const rows: Row[] = [
  {
    prop: "className",
    ruleWord: "concatenated",
    rule: "parent's, then child's — both survive",
    parent: '"…button classes…"',
    child: '"text-blue-600"',
    out: [
      { text: "…button classes…", origin: "parent" },
      { text: "text-blue-600", origin: "child" },
    ],
    note: "both join",
  },
  {
    prop: "onClick",
    ruleWord: "composed",
    rule: "both handlers fire",
    parent: "{parentHandler}",
    child: "{childHandler}",
    out: [
      { text: "parentHandler()", origin: "parent" },
      { text: "childHandler()", origin: "child" },
    ],
    note: "both run",
  },
  {
    prop: "ref",
    ruleWord: "forwarded",
    rule: "lands on the child's element",
    parent: "{ref}",
    child: null,
    out: [{ text: "ref → the <a>", origin: "parent" }],
    note: "to the <a>",
  },
  {
    prop: "href",
    ruleWord: "passthrough",
    rule: "everything else: child's own prop rides along",
    parent: null,
    child: '"/dashboard"',
    out: [{ text: '"/dashboard"', origin: "child" }],
    note: "untouched",
  },
];

// ── style fragments ───────────────────────────────────────────────────────────

const wrap = [
  reset,
  sans,
  "display: flex",
  "flex-direction: column",
  "gap: 10px",
  "box-sizing: border-box",
].join("; ");

// The three column headers sit above the grid, aligned to the three value
// columns (the leading "prop name" column has no header).
const headerRow = [
  reset,
  "display: grid",
  // prop | parent | child | rule+output
  "grid-template-columns: 92px 1fr 1fr 1.15fr",
  "gap: 8px",
  "align-items: stretch",
  "box-sizing: border-box",
].join("; ");

const panelHead = (origin: Origin | "output") =>
  [
    reset,
    sans,
    "display: flex",
    "flex-direction: column",
    "gap: 1px",
    "padding: 7px 10px",
    "border-radius: 8px 8px 0 0",
    "box-sizing: border-box",
    origin === "parent"
      ? "background: var(--mark-blue-bg); border: 1px solid var(--mark-blue-brd); border-bottom: none"
      : origin === "child"
        ? "background: var(--mark-green-bg); border: 1px solid var(--mark-green-brd); border-bottom: none"
        : "background: var(--sl-color-gray-6, var(--sl-color-gray-7)); border: 1px solid var(--sl-color-gray-5); border-bottom: none",
  ].join("; ");

const panelHeadTitle = [
  reset,
  "font-size: 12.5px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-white)",
].join("; ");

const panelHeadSub = [
  reset,
  mono,
  "font-size: 11px",
  "line-height: 1.2",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The spacer above the leading prop-name column, keeps the header grid aligned.
const headSpacer = [reset, "box-sizing: border-box"].join("; ");

// One row of the body grid.
const bodyRow = (last: boolean) =>
  [
    reset,
    "display: grid",
    "grid-template-columns: 92px 1fr 1fr 1.15fr",
    "gap: 8px",
    "align-items: stretch",
    "box-sizing: border-box",
  ].join("; ");

// The leading cell: the prop name, the row's identity.
const propCell = [
  reset,
  mono,
  "display: flex",
  "align-items: center",
  "justify-content: flex-end",
  "padding: 6px 8px",
  "font-size: 12.5px",
  "font-weight: 600",
  "color: var(--sl-color-white)",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

// A value cell inside the parent or child column. Tinted faintly with the
// column's accent and bordered so the three columns stay visually banded
// top-to-bottom. An empty side renders a muted dash.
const valueCell = (origin: Origin, filled: boolean) =>
  [
    reset,
    mono,
    "display: flex",
    "align-items: center",
    "min-height: 34px",
    "padding: 6px 10px",
    "font-size: 12px",
    "line-height: 1.3",
    "box-sizing: border-box",
    "border-left: 1px solid",
    "border-right: 1px solid",
    origin === "parent"
      ? "border-color: var(--mark-blue-brd); background: color-mix(in srgb, var(--mark-blue-bg) 45%, transparent)"
      : "border-color: var(--mark-green-brd); background: color-mix(in srgb, var(--mark-green-bg) 45%, transparent)",
    filled ? "color: var(--sl-color-gray-1)" : "color: var(--sl-color-gray-4)",
  ].join("; ");

// The fourth column packs the rule chip + the resolved output segments, since
// they describe the same thing: how this row resolves on the rendered element.
const outCell = (last: boolean) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "gap: 6px",
    "justify-content: center",
    "min-height: 34px",
    "padding: 7px 10px",
    "box-sizing: border-box",
    "background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
    "border: 1px solid var(--sl-color-gray-5)",
    "border-bottom: none",
  ].join("; ");

const ruleChip = [
  reset,
  sans,
  "align-self: flex-start",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 3px 6px",
  "border-radius: 5px",
  "color: var(--sl-color-white)",
  "background: var(--sl-color-gray-5)",
  "border: 1px solid var(--sl-color-gray-4)",
  "box-sizing: border-box",
].join("; ");

// The resolved value: one or two segments, each coloured by origin so a reader
// can see which panel each surviving piece came from.
const outSegments = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "gap: 4px",
  "box-sizing: border-box",
].join("; ");

const outSeg = (origin: Origin) =>
  [
    reset,
    mono,
    "font-size: 11.5px",
    "font-weight: 600",
    "line-height: 1.25",
    "padding: 2px 6px",
    "border-radius: 5px",
    "color: var(--sl-color-white)",
    "box-sizing: border-box",
    origin === "parent"
      ? "background: var(--mark-blue-bg); border: 1px solid var(--mark-blue-brd)"
      : "background: var(--mark-green-bg); border: 1px solid var(--mark-green-brd)",
  ].join("; ");

const plus = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 700",
  "color: var(--sl-color-gray-3)",
  "box-sizing: border-box",
].join("; ");

// The output column's foot — a single banded cap that reads "rendered <a>",
// closing the gray column so it visually frames every output cell above it.
const outFoot = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "gap: 6px",
  "padding: 7px 10px",
  "font-size: 12px",
  "color: var(--sl-color-gray-2)",
  "background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 0 0 8px 8px",
  "box-sizing: border-box",
].join("; ");

const outFootStrong = [
  reset,
  mono,
  "font-size: 12px",
  "font-weight: 700",
  "color: var(--sl-color-white)",
].join("; ");

// Close the parent/child banded columns at the bottom so they don't float open.
const colFoot = (origin: Origin) =>
  [
    reset,
    "height: 8px",
    "box-sizing: border-box",
    origin === "parent"
      ? "border: 1px solid var(--mark-blue-brd); border-top: none; background: color-mix(in srgb, var(--mark-blue-bg) 45%, transparent)"
      : "border: 1px solid var(--mark-green-brd); border-top: none; background: color-mix(in srgb, var(--mark-green-bg) 45%, transparent)",
    "border-radius: 0 0 8px 8px",
  ].join("; ");

const propFoot = [reset, "box-sizing: border-box"].join("; ");
---

<div class="not-content slot-prop-merge" style={wrap}>
  {/* Column headers */}
  <div style={headerRow}>
    <div style={headSpacer}></div>
    <div style={panelHead("parent")}>
      <span style={panelHeadTitle}>Slot</span>
      <span style={panelHeadSub}>parent props</span>
    </div>
    <div style={panelHead("child")}>
      <span style={panelHeadTitle}>child &lt;Link&gt;</span>
      <span style={panelHeadSub}>its own props</span>
    </div>
    <div style={panelHead("output")}>
      <span style={panelHeadTitle}>rendered &lt;a&gt;</span>
      <span style={panelHeadSub}>what lands on it</span>
    </div>
  </div>

  {/* One row per prop kind */}
  {
    rows.map((row, i) => {
      const last = i === rows.length - 1;
      return (
        <div style={bodyRow(last)}>
          <div style={propCell}>{row.prop}</div>

          <div style={valueCell("parent", row.parent !== null)}>
            {row.parent ?? <span aria-hidden="true">—</span>}
          </div>

          <div style={valueCell("child", row.child !== null)}>
            {row.child ?? <span aria-hidden="true">—</span>}
          </div>

          <div style={outCell(last)}>
            <span style={ruleChip}>{row.ruleWord}</span>
            <div style={outSegments}>
              {row.out.map((s, j) => (
                <Fragment>
                  {j > 0 && (
                    <span style={plus} aria-hidden="true">
                      +
                    </span>
                  )}
                  <span style={outSeg(s.origin)}>{s.text}</span>
                </Fragment>
              ))}
            </div>
          </div>
        </div>
      );
    })
  }

  {/* Column feet — close the three banded columns */}
  <div style={headerRow}>
    <div style={propFoot}></div>
    <div style={colFoot("parent")}></div>
    <div style={colFoot("child")}></div>
    <div style={outFoot}>
      <span style={outFootStrong}>&lt;a&gt;</span>
      <span>— the Slot is gone</span>
    </div>
  </div>
</div>
