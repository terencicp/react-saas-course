---
// One frame of the cva "table lookup" figure, the body of a DiagramStep in the
// lesson's DiagramSequence. The point is to defuse the idea that cva is magic:
// it is a 2-axis table (rows = variant, columns = size) plus a concatenation.
//
//   step 1 — the empty table. The base string sits above it as the always-on
//            layer that every cell shares; no cell is lit yet. The reader sees
//            "9 possible buttons, one base shared by all of them".
//   step 2 — buttonVariants({ variant: 'destructive', size: 'lg' }) lights ONE
//            cell. The destructive row header and the lg column header light too,
//            so the eye traces row + column to the intersection. Below the grid
//            the resolved string is shown as colour-coded segments —
//            base (neutral) + the destructive row's classes + the lg column's
//            classes — making "lookup, then concat" the literal takeaway.
//
// Pure HTML + CSS, devtools-inspectable, matching the sibling figures in this
// chapter family (CnPipeline et al.): `not-content` + a `margin: 0` reset defeat
// Starlight's prose-margin injection; Starlight gray/white variables flip the
// chrome with light/dark; the --mark-* accents (custom.css) flip too. The lit
// row uses the orange "destructive" accent and the lit column the violet "size"
// accent, so the two axes stay visually distinct and recombine in the result.

interface Props {
  /** Which frame to draw: 1 = empty table, 2 = one cell resolved. */
  step: 1 | 2;
}

const { step } = Astro.props;

const reset = "margin: 0";

const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The two axes of the table. Rows are the three `variant` members, columns the
// three `size` members — exactly the unions from the typed-props lesson.
const variants = ["primary", "destructive", "ghost"] as const;
const sizes = ["sm", "md", "lg"] as const;

// The lit combination in step 2.
const litVariant = "destructive";
const litSize = "lg";

// The classes each axis member contributes, kept short and illustrative so the
// result string stays readable. Only the lit pair's classes are surfaced in the
// result, but defining them here keeps the data honest.
const variantClasses: Record<string, string> = {
  destructive: "bg-destructive text-destructive-foreground",
};
const sizeClasses: Record<string, string> = {
  lg: "h-10 px-6",
};

const baseClasses = "inline-flex items-center justify-center rounded-md text-sm font-medium";

// ── style fragments ────────────────────────────────────────────────────────

// Outer wrapper. A min-height keeps the two frames close in height so the
// DiagramSequence stage (which sizes to the tallest) doesn't jump on scrub.
const wrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 14px",
  "min-height: 232px",
  "box-sizing: border-box",
].join("; ");

const stageTag = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");

const stageTagCode = [
  mono,
  "text-transform: none",
  "letter-spacing: 0",
  "color: var(--sl-color-white)",
  "font-size: 12px",
].join("; ");

// The always-on "base" layer above the grid. A faint panel labelled so the
// reader knows these classes ride on every cell regardless of the pick.
const basePanel = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 4px",
  "padding: 8px 10px",
  "border: 1px dashed var(--sl-color-gray-4)",
  "border-radius: 8px",
  "background: var(--sl-color-gray-6, var(--sl-color-gray-7))",
  "box-sizing: border-box",
].join("; ");

const baseString = [
  reset,
  mono,
  "font-size: 12px",
  "line-height: 1.45",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

// The table itself: a CSS grid with a header column for variant labels and a
// header row for size labels.
const grid = [
  reset,
  "display: grid",
  "grid-template-columns: auto repeat(3, 1fr)",
  "gap: 6px",
  "box-sizing: border-box",
].join("; ");

const cornerCell = [reset, "box-sizing: border-box"].join("; ");

// A column header (size). Lit headers (step 2) take the violet "size" accent.
const colHeader = (lit: boolean) =>
  [
    reset,
    mono,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "font-size: 12px",
    "font-weight: 600",
    "padding: 5px 6px",
    "border-radius: 6px",
    "box-sizing: border-box",
    lit
      ? "color: var(--sl-color-white); background: var(--mark-violet-bg); border: 1.5px solid var(--mark-violet-brd)"
      : "color: var(--sl-color-gray-2); background: transparent; border: 1px solid transparent",
  ].join("; ");

// A row header (variant). Lit headers take the orange "variant" accent.
const rowHeader = (lit: boolean) =>
  [
    reset,
    mono,
    "display: flex",
    "align-items: center",
    "justify-content: flex-end",
    "font-size: 12px",
    "font-weight: 600",
    "padding: 5px 8px",
    "border-radius: 6px",
    "white-space: nowrap",
    "box-sizing: border-box",
    lit
      ? "color: var(--sl-color-white); background: var(--mark-orange-bg); border: 1.5px solid var(--mark-orange-brd)"
      : "color: var(--sl-color-gray-2); background: transparent; border: 1px solid transparent",
  ].join("; ");

// A data cell. The single lit cell (the intersection) gets a green "result"
// fill; every other cell is a quiet placeholder dot so the grid reads as a
// surface of possibilities without 12 competing labels.
const dataCell = (lit: boolean) =>
  [
    reset,
    "display: flex",
    "align-items: center",
    "justify-content: center",
    "min-height: 30px",
    "border-radius: 6px",
    "box-sizing: border-box",
    lit
      ? "background: var(--mark-green-bg); border: 1.5px solid var(--mark-green-brd)"
      : "background: var(--sl-color-gray-6, var(--sl-color-gray-7)); border: 1px solid var(--sl-color-gray-5)",
  ].join("; ");

const dotDim = [
  reset,
  "width: 4px",
  "height: 4px",
  "border-radius: 50%",
  "background: var(--sl-color-gray-4)",
  "box-sizing: border-box",
].join("; ");

const litMark = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-white)",
  "box-sizing: border-box",
].join("; ");

// The call line above the result string in step 2.
const callLine = [
  reset,
  mono,
  "font-size: 12.5px",
  "line-height: 1.4",
  "color: var(--sl-color-white)",
  "box-sizing: border-box",
].join("; ");

const callArg = (kind: "variant" | "size") =>
  [
    "padding: 1px 4px",
    "border-radius: 4px",
    kind === "variant"
      ? "background: var(--mark-orange-bg); border: 1px solid var(--mark-orange-brd)"
      : "background: var(--mark-violet-bg); border: 1px solid var(--mark-violet-brd)",
  ].join("; ");

// The resolved string, shown as three concatenated, colour-coded segments.
const resultRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "gap: 6px",
  "box-sizing: border-box",
].join("; ");

const seg = (kind: "base" | "variant" | "size") =>
  [
    reset,
    mono,
    "font-size: 12px",
    "font-weight: 600",
    "line-height: 1.3",
    "padding: 4px 7px",
    "border-radius: 6px",
    "box-sizing: border-box",
    kind === "base"
      ? "color: var(--sl-color-gray-2); background: var(--sl-color-gray-6, var(--sl-color-gray-7)); border: 1px solid var(--sl-color-gray-5)"
      : kind === "variant"
        ? "color: var(--sl-color-white); background: var(--mark-orange-bg); border: 1.5px solid var(--mark-orange-brd)"
        : "color: var(--sl-color-white); background: var(--mark-violet-bg); border: 1.5px solid var(--mark-violet-brd)",
  ].join("; ");

const plus = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 700",
  "color: var(--sl-color-gray-3)",
  "box-sizing: border-box",
].join("; ");

// The placeholder shown in step 1 where the result lands in step 2, so the two
// frames keep the same footprint and the stage doesn't jump on scrub.
const resultPlaceholder = [
  reset,
  sans,
  "font-size: 12px",
  "font-style: italic",
  "color: var(--sl-color-gray-3)",
  "padding: 4px 0",
  "box-sizing: border-box",
].join("; ");

// A small legend tying each axis to its accent colour. Only meaningful once a
// cell is lit, so it appears in step 2.
const legendRow = [
  reset,
  sans,
  "display: flex",
  "flex-wrap: wrap",
  "gap: 14px",
  "font-size: 11px",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

const legendItem = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "box-sizing: border-box",
].join("; ");

const swatch = (color: string) =>
  [
    reset,
    "width: 11px",
    "height: 11px",
    "border-radius: 3px",
    color,
    "box-sizing: border-box",
  ].join("; ");
---

<div class="not-content cva-lookup" style={wrap} data-step={step}>
  {/* Always-on base layer */}
  <div style={basePanel}>
    <div style={stageTag}>
      Base — on every cell
    </div>
    <div style={baseString}>{baseClasses}</div>
  </div>

  {/* The 2-axis table */}
  <div style={grid}>
    <div style={cornerCell}></div>
    {
      sizes.map((s) => (
        <div style={colHeader(step === 2 && s === litSize)}>{s}</div>
      ))
    }

    {
      variants.map((v) => (
        <Fragment>
          <div style={rowHeader(step === 2 && v === litVariant)}>{v}</div>
          {sizes.map((s) => {
            const lit = step === 2 && v === litVariant && s === litSize;
            return (
              <div style={dataCell(lit)}>
                {lit ? (
                  <span style={litMark}>this one</span>
                ) : (
                  <span style={dotDim} aria-hidden="true" />
                )}
              </div>
            );
          })}
        </Fragment>
      ))
    }
  </div>

  {/* Result area — call + concatenated string in step 2, placeholder in step 1 */}
  {
    step === 1 ? (
      <div style={resultPlaceholder}>
        Pick a (variant, size) pair to resolve one cell into a class string.
      </div>
    ) : (
      <Fragment>
        <div style={callLine}>
          buttonVariants({"{ "}variant: <span style={callArg("variant")}>'destructive'</span>, size: <span style={callArg("size")}>'lg'</span>{" }"})
        </div>
        <div style={resultRow}>
          <span style={seg("base")}>{baseClasses}</span>
          <span style={plus}>+</span>
          <span style={seg("variant")}>{variantClasses[litVariant]}</span>
          <span style={plus}>+</span>
          <span style={seg("size")}>{sizeClasses[litSize]}</span>
        </div>
        <div style={legendRow}>
          <span style={legendItem}>
            <span
              style={swatch(
                "background: var(--mark-orange-bg); border: 1px solid var(--mark-orange-brd)",
              )}
              aria-hidden="true"
            />
            variant row
          </span>
          <span style={legendItem}>
            <span
              style={swatch(
                "background: var(--mark-violet-bg); border: 1px solid var(--mark-violet-brd)",
              )}
              aria-hidden="true"
            />
            size column
          </span>
        </div>
      </Fragment>
    )
  }
</div>
