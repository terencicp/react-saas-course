---
// "DOM moves, React doesn't" — the same little app drawn as two trees, side by
// side in a TabbedContent (diagram id: dom-vs-react-tree, Chapter 022 L5).
//
// The whole point: one node — the portaled <Tooltip> — is rendered in BOTH
// trees with the SAME tint, so the reader's eye tracks the identical node as it
// appears to jump between two homes when they flip tabs.
//   - DOM tree:   the tooltip is a SIBLING of the whole app, hanging directly
//                 off <body>, far from the trigger that owns it.
//   - React tree: the tooltip is a CHILD of <TriggerButton>, exactly where it
//                 was written — which is why context, state, and event bubbling
//                 all behave as if the portal weren't there.
//
// Built as a real, devtools-inspectable indented tree (nested flex rows + a
// left guide line + a short horizontal connector stub per node), not absolute-
// positioned fakery — same house style as this lesson's TrapIllustration:
// fixed slate ink, system-ui sans / monospace for tag names, hairline edges,
// color-scheme pinned light so the hard-coded tints survive dark mode, and an
// explicit margin: 0 on every element so Starlight's prose margin-top injection
// can't distort the layout.
//
// This component renders the whole TabbedContent itself (it provides its own
// figure card), so it must NOT be wrapped in <Figure> at the call site.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

// Palette ---------------------------------------------------------------------
const INK = "#1e293b"; // primary ink (slate-800)
const INK_SOFT = "#64748b"; // secondary text (slate-500)
const NODE_BG = "#ffffff"; // ordinary node surface
const NODE_BORDER = "#cbd5e1"; // ordinary node edge (slate-300)
const GUIDE = "#cbd5e1"; // the tree's vertical guide / connector lines
const ROOT_BG = "#f1f5f9"; // the root node wash (slate-100)
const ROOT_INK = "#334155"; // root node text (slate-700)

// The shared tooltip tint — identical in both panels so the eye tracks it.
const TIP_BG = "#0d9488"; // teal-600 — the portaled <Tooltip>
const TIP_RING = "#5eead4"; // teal-300 — focus-ring halo around it

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// A node chip. `kind` picks the surface; the tooltip is always the same tint in
// both trees. The chip hugs its own text (fit-content + no-shrink) so the tree
// reads as discrete nodes rather than full-width bars, even though Starlight's
// not-content reset rewrites our inline-flex to plain flex.
const nodeBase = `display: flex; flex: 0 0 auto; width: fit-content; align-items: center; gap: 6px; margin: 0; padding: 3px 9px; font-family: ${mono}; font-size: 13px; line-height: 1.3; border-radius: 7px; white-space: nowrap;`;

const chipStyle = {
  root: `${nodeBase} font-weight: 600; color: ${ROOT_INK}; background: ${ROOT_BG}; border: 1px solid ${NODE_BORDER};`,
  node: `${nodeBase} font-weight: 500; color: ${INK}; background: ${NODE_BG}; border: 1px solid ${NODE_BORDER};`,
  tip: `${nodeBase} font-weight: 600; color: #ffffff; background: ${TIP_BG}; border: 1px solid ${TIP_BG}; box-shadow: 0 0 0 3px ${TIP_RING};`,
};

// One row of the tree: an optional connector stub (a short horizontal line that
// joins the node to its parent's vertical guide) + the node chip + an optional
// trailing note. `width: fit-content` keeps the row hugging its contents so it
// never collapses to zero inside the centering flex parent.
const rowStyle = `display: flex; width: fit-content; align-items: center; gap: 0; margin: 0;`;
const stubStyle = `flex: 0 0 auto; width: 14px; height: 0; margin: 0; border-top: 1.5px solid ${GUIDE};`;
const noteStyle = `flex: 0 0 auto; margin: 0 0 0 10px; font-family: ${sans}; font-size: 11.5px; font-weight: 500; line-height: 1.3; white-space: nowrap; color: ${INK_SOFT};`;

// A group of children, indented under their parent. The left border IS the
// vertical guide line the connector stubs join onto; the negative-margin row
// gap is intentional (full shorthand so prose margin-top can't merge in).
const groupStyle = `display: flex; flex-direction: column; gap: 10px; margin: 10px 0 0 11px; padding: 0 0 0 0; border-left: 1.5px solid ${GUIDE};`;
---

<TabbedContent syncKey="dom-vs-react-tree">
  <TabbedItem
    label="DOM tree"
    caption="Where the markup actually lives. The portaled <Tooltip> is a sibling of the whole app, hanging straight off <body> — nowhere near the trigger that owns it."
  >
    <div style={`font-family: ${sans}; color: ${INK}; color-scheme: light; margin: 0; padding: 4px 2px; display: flex; justify-content: center;`}>
      <div style="margin: 0; width: fit-content;">
        {/* <body> */}
        <div style={rowStyle}>
          <div style={chipStyle.root}>{"<body>"}</div>
        </div>

        {/* children of <body> */}
        <div style={groupStyle}>
          {/* the whole app, reparented under <body> as one subtree */}
          <div style={rowStyle}>
            <div style={stubStyle}></div>
            <div style={chipStyle.node}>{"<div id=\"root\">"}</div>
            <span style={noteStyle}>the entire app</span>
          </div>
          <div style={`${groupStyle} margin-left: 25px;`}>
            <div style={rowStyle}>
              <div style={stubStyle}></div>
              <div style={chipStyle.node}>{"<header>"}</div>
            </div>
            <div style={rowStyle}>
              <div style={stubStyle}></div>
              <div style={chipStyle.node}>{"<button>"}</div>
              <span style={noteStyle}>the trigger</span>
            </div>
          </div>

          {/* the portaled tooltip — a SIBLING of the app, directly under body */}
          <div style={rowStyle}>
            <div style={stubStyle}></div>
            <div style={chipStyle.tip}>{"<Tooltip>"}</div>
            <span style={noteStyle}>portaled here &mdash; sibling of the app</span>
          </div>
        </div>
      </div>
    </div>
  </TabbedItem>

  <TabbedItem
    label="React tree"
    caption="Where React thinks it lives. The same <Tooltip> is still a child of <TriggerButton>, exactly where it was written — so context, state, and event bubbling all flow as if the portal weren't there."
  >
    <div style={`font-family: ${sans}; color: ${INK}; color-scheme: light; margin: 0; padding: 4px 2px; display: flex; justify-content: center;`}>
      <div style="margin: 0; width: fit-content;">
        {/* <App> */}
        <div style={rowStyle}>
          <div style={chipStyle.root}>{"<App>"}</div>
        </div>
        <div style={groupStyle}>
          {/* <Toolbar> */}
          <div style={rowStyle}>
            <div style={stubStyle}></div>
            <div style={chipStyle.node}>{"<Toolbar>"}</div>
          </div>
          <div style={`${groupStyle} margin-left: 25px;`}>
            {/* <TriggerButton> */}
            <div style={rowStyle}>
              <div style={stubStyle}></div>
              <div style={chipStyle.node}>{"<TriggerButton>"}</div>
              <span style={noteStyle}>the trigger</span>
            </div>
            {/* the tooltip — a CHILD of the trigger, where it was written */}
            <div style={`${groupStyle} margin-left: 25px;`}>
              <div style={rowStyle}>
                <div style={stubStyle}></div>
                <div style={chipStyle.tip}>{"<Tooltip>"}</div>
                <span style={noteStyle}>still a child &mdash; right where you wrote it</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </TabbedItem>
</TabbedContent>
