---
// "Fighting z-index vs the top layer" — why the browser's top layer makes
// z-index management obsolete for overlays (diagram id: stacking-vs-top-layer,
// Chapter 022 L5). Two TabbedContent panels.
//
// The tracked node is the OVERLAY (violet, identical tint in both panels) so the
// reader watches the same element go from buried to floating-free.
//
//   Panel A — "Fighting z-index": the overlay carries `z-index: 9999` and still
//     loses. The mechanism is real and devtools-inspectable, not painted to look
//     buried: the overlay lives inside a CARD that establishes its own stacking
//     context (`position: relative; z-index: 1`), so the overlay's 9999 is sealed
//     INSIDE that context. A SIBLING panel sits at `z-index: 2` on the shared
//     parent and overlaps the overlay — and because sibling contexts compare by
//     their own root's z-index (2 > 1), the sibling paints on top. The overlay's
//     9999 never gets to compete. A reader can inspect any box and watch the same
//     thing happen.
//
//   Panel B — "The top layer": the SAME overlay (same violet) is lifted into a
//     band drawn above all the boxes, labelled "top layer", annotated
//     `<dialog open>` / `popover`, carrying NO z-index at all. The nested boxes
//     below are the same real boxes, now faint, with the sibling no longer able
//     to cover anything — the overlay was promoted out of the stacking contest
//     entirely.
//
// House style borrowed from this lesson's TrapIllustration / DomVsReactTree:
// fixed slate ink that reads on every tint, system-ui sans + ui-monospace for
// code, hairline edges, fieldset-legend pills straddling box top borders,
// color-scheme pinned light so the hard-coded tints survive dark mode, and an
// explicit margin: 0 on EVERY element so Starlight's prose margin-top injection
// can't distort the layout.
//
// Renders its own TabbedContent (provides its own figure card) — must NOT be
// wrapped in <Figure> at the call site.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

// Palette ---------------------------------------------------------------------
const INK = "#1e293b"; // primary ink (slate-800)
const INK_SOFT = "#64748b"; // secondary / legend text (slate-500)

const FRAME_BORDER = "#94a3b8"; // muted slate — the page/viewport frame edge
const FRAME_FILL = "#f8fafc"; // very faint slate — frame interior

const CARD_FILL = "#ffffff"; // the outer card surface
const CARD_BORDER = "#cbd5e1"; // muted card edge (slate-300)
const CTX_LABEL_BG = "#eef2ff"; // indigo-50 — the stacking-context mechanism pill
const CTX_LABEL_INK = "#4338ca"; // indigo-700 — its text

const SIB_FILL = "#fffbeb"; // amber-50 — the sibling content panel wash
const SIB_BORDER = "#f59e0b"; // amber-500 — the sibling edge
const SIB_INK = "#b45309"; // amber-700 — the sibling label

// The tracked overlay — identical violet in BOTH panels so the eye follows it.
const OVL_FILL = "#7c3aed"; // violet-600 — the overlay surface
const OVL_BORDER = "#6d28d9"; // violet-700 — the overlay edge
const OVL_RING = "#c4b5fd"; // violet-300 — focus-ring halo around it

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// Shared frame geometry (px). A fixed-width box is sanctioned for figures that
// need an internal coordinate system; it centres in the figure card.
const FW = 520; // frame width

// A fieldset-legend pill straddling a box's top border. `display: block` +
// `width: fit-content` self-sizes it; the parent parks its vertical centre on
// the border line. Its background must match what paints behind the border so it
// breaks the line cleanly.
function legend(color: string, bg: string, size = 11) {
  return `position: absolute; display: block; width: fit-content; margin: 0; padding: 1.5px 8px; font-family: ${mono}; font-size: ${size}px; font-weight: 600; line-height: 1.4; color: ${color}; background: ${bg}; border-radius: 999px; white-space: nowrap;`;
}

// A z-index badge that rides the corner of a box.
function zBadge(color: string, bg: string) {
  return `position: absolute; margin: 0; padding: 1px 6px; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.3; color: ${color}; background: ${bg}; border-radius: 6px; white-space: nowrap;`;
}
---

<TabbedContent syncKey="stacking-vs-top-layer">
  <TabbedItem
    label="Fighting z-index"
    caption="A high z-index can't escape its stacking context. The overlay's z-index: 9999 is sealed inside the card (its own context at z-index: 1), so a sibling at z-index: 2 paints right over it — the 9999 never gets to compete. Every box is real CSS: open devtools and inspect the stacking."
  >
    <div
      style={`display: flex; justify-content: center; font-family: ${sans}; color: ${INK}; color-scheme: light; margin: 0; padding: 4px 2px;`}
    >
      {/* ===================== THE PAGE FRAME ===================== */}
      {/* Establishes a positioning context for the two overlapping siblings. */}
      <div
        style={`position: relative; flex: 0 0 auto; width: ${FW}px; height: 252px; margin: 0; border: 1.5px solid ${FRAME_BORDER}; border-radius: 14px; background: ${FRAME_FILL};`}
      >
        <span style={`${legend(INK_SOFT, FRAME_FILL)} font-family: ${sans}; left: 18px; top: -9px;`}>page root</span>

        {/* ---------- SIBLING TWO: the content panel, z-index: 2 ---------- */}
        {/* Real positioned sibling. Its z-index (2) is compared against the */}
        {/* card's z-index (1) at THIS level — 2 wins, so it paints on top of */}
        {/* everything inside the card, the buried overlay included. It overlaps */}
        {/* the card on the right so the covering is literally visible. */}
        <div
          style={`position: absolute; left: 250px; top: 92px; width: 236px; height: 124px; z-index: 2; margin: 0; background: ${SIB_FILL}; border: 1.5px solid ${SIB_BORDER}; border-radius: 11px; box-shadow: 0 6px 16px -8px rgba(15, 23, 42, 0.25);`}
        >
          <span style={`${zBadge(SIB_INK, "#fef3c7")} right: 8px; top: 8px;`}>z-index: 2</span>
          <span
            style={`position: absolute; left: 14px; top: 12px; margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 700; color: ${SIB_INK}; line-height: 1.25;`}
            >Sibling panel</span
          >
          <span
            style={`position: absolute; left: 14px; top: 32px; right: 12px; margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 500; color: ${SIB_INK}; line-height: 1.3;`}
            >its context (2) beats the card's (1), so it paints over the overlay</span
          >
        </div>

        {/* ---------- SIBLING ONE: the card, z-index: 1, a stacking context ---------- */}
        {/* A REAL stacking context (position: relative + z-index). Everything */}
        {/* inside it — including the z-index: 9999 overlay — is sealed in. */}
        <div
          style={`position: absolute; left: 34px; top: 56px; width: 250px; height: 160px; z-index: 1; margin: 0; background: ${CARD_FILL}; border: 1.5px solid ${CARD_BORDER}; border-radius: 12px;`}
        >
          <span style={`${legend(CTX_LABEL_INK, CTX_LABEL_BG)} left: 14px; top: -10px;`}>card · position: relative · z-index: 1</span>

          {/* ---------- THE OVERLAY, z-index: 9999, trapped inside the card ---------- */}
          {/* REAL z-index: 9999. It looks enormous, and inside the card it IS */}
          {/* the topmost child — but the whole card sits at z-index: 1 against */}
          {/* the sibling's 2, so the sibling still wins. It reaches past the */}
          {/* card's right edge to where the sibling overlaps it, so the reader */}
          {/* sees the sibling slicing across the overlay. */}
          <div
            style={`position: absolute; left: 28px; top: 44px; width: 210px; height: 88px; z-index: 9999; margin: 0; background: ${OVL_FILL}; border: 1.5px solid ${OVL_BORDER}; border-radius: 9px; box-shadow: 0 0 0 3px ${OVL_RING};`}
          >
            <span style={`${zBadge("#ffffff", "rgba(255,255,255,0.22)")} right: 7px; top: 7px;`}>z-index: 9999</span>
            <span
              style={`position: absolute; left: 12px; top: 11px; margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 700; color: #ffffff; line-height: 1.2;`}
              >Overlay</span
            >
            <span
              style={`position: absolute; left: 12px; top: 32px; margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; color: ${OVL_RING}; line-height: 1.3;`}
              >buried &mdash; 9999 can't<br />escape its context</span
            >
          </div>
        </div>
      </div>
    </div>
  </TabbedItem>

  <TabbedItem
    label="The top layer"
    caption="showModal() (or the popover attribute) renders into the top layer — above every stacking context, no z-index, no portal, nothing to trap it. The same overlay is promoted clean out of the contest, so the sibling can no longer cover it."
  >
    <div
      style={`display: flex; justify-content: center; font-family: ${sans}; color: ${INK}; color-scheme: light; margin: 0; padding: 4px 2px;`}
    >
      <div style={`flex: 0 0 auto; width: ${FW}px; margin: 0;`}>
        {/* ===================== THE TOP-LAYER BAND ===================== */}
        {/* The same overlay, lifted above everything into its own band. No */}
        {/* z-index anywhere on it — it was promoted out of the stacking contest. */}
        <div
          style={`position: relative; width: 100%; margin: 0; padding: 14px 16px 12px; border: 1.5px dashed ${OVL_BORDER}; border-radius: 13px; background: #faf5ff;`}
        >
          <span style={`${legend(OVL_BORDER, "#faf5ff")} font-family: ${sans}; left: 16px; top: -9px;`}>top layer</span>
          <span
            style={`position: absolute; right: 14px; top: -9px; margin: 0; padding: 1px 8px; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.4; color: ${OVL_BORDER}; background: #faf5ff; border-radius: 999px; white-space: nowrap;`}
            >above every stacking context</span
          >

          <div style={`display: flex; align-items: center; gap: 14px; margin: 0;`}>
            {/* the promoted overlay — same violet as Panel A */}
            <div
              style={`flex: 0 0 auto; width: 218px; margin: 0; padding: 11px 12px; background: ${OVL_FILL}; border: 1.5px solid ${OVL_BORDER}; border-radius: 9px; box-shadow: 0 0 0 3px ${OVL_RING};`}
            >
              <span
                style={`display: block; margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 700; color: #ffffff; line-height: 1.2;`}
                >Overlay</span
              >
              <span
                style={`display: block; margin: 4px 0 0; font-family: ${mono}; font-size: 11px; font-weight: 600; color: ${OVL_RING}; line-height: 1.3;`}
                >no z-index &mdash; nothing to trap it</span
              >
            </div>
            {/* what put it here */}
            <div style={`flex: 1 1 auto; min-width: 0; margin: 0;`}>
              <span
                style={`display: block; margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; color: ${OVL_BORDER}; line-height: 1.4;`}
                >{"<dialog open>"} · {"popover"}</span
              >
              <span
                style={`display: block; margin: 3px 0 0; font-family: ${sans}; font-size: 11.5px; font-weight: 500; color: ${INK_SOFT}; line-height: 1.35;`}
                >rendered here by showModal()</span
              >
            </div>
          </div>
        </div>

        {/* small "below" connector cue */}
        <div style={`display: flex; justify-content: center; margin: 0;`}>
          <div style={`width: 0; height: 14px; margin: 0; border-left: 1.5px dashed ${OVL_BORDER};`}></div>
        </div>

        {/* ===================== THE NESTED BOXES, NOW FAINT ===================== */}
        {/* The same page below — the card (a stacking context) and its sibling — */}
        {/* but the overlay is gone from here: it was promoted to the band above. */}
        {/* Faded back so the band reads as "lifted clear of all of this". */}
        <div
          style={`position: relative; width: 100%; height: 138px; margin: 0; border: 1.5px solid ${FRAME_BORDER}; border-radius: 14px; background: ${FRAME_FILL}; opacity: 0.78;`}
        >
          <span style={`${legend(INK_SOFT, FRAME_FILL)} font-family: ${sans}; left: 18px; top: -9px;`}>page root</span>

          {/* the sibling panel — no longer covering anything */}
          <div
            style={`position: absolute; left: 250px; top: 30px; width: 236px; height: 86px; margin: 0; background: ${SIB_FILL}; border: 1.5px solid ${SIB_BORDER}; border-radius: 11px;`}
          >
            <span style={`${zBadge(SIB_INK, "#fef3c7")} right: 8px; top: 8px;`}>z-index: 2</span>
            <span
              style={`position: absolute; left: 14px; top: 12px; margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 700; color: ${SIB_INK}; line-height: 1.25;`}
              >Sibling panel</span
            >
          </div>

          {/* the card — still a stacking context, but empty now */}
          <div
            style={`position: absolute; left: 34px; top: 30px; width: 250px; height: 86px; margin: 0; background: ${CARD_FILL}; border: 1.5px solid ${CARD_BORDER}; border-radius: 12px;`}
          >
            <span style={`${legend(CTX_LABEL_INK, CTX_LABEL_BG)} left: 14px; top: -10px;`}>z-index: 1 (a stacking context)</span>
            <span
              style={`position: absolute; left: 14px; bottom: 12px; margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 500; color: ${INK_SOFT}; line-height: 1.3;`}
              >overlay no longer lives here</span
            >
          </div>
        </div>
      </div>
    </div>
  </TabbedItem>
</TabbedContent>
