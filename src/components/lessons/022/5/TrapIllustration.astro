---
// The containing-block trap, drawn with REAL, devtools-inspectable CSS — no
// absolute-positioned fakery (diagram id: trap-illustration, Chapter 022 L5).
//
// The whole pedagogical point is that the clipping and mis-sizing the reader
// sees are PRODUCED by the actual mechanism the lesson is about, not painted to
// look that way:
//   - the "card" carries a genuine `transform: translateY(-2px)` (a hover-lift),
//     which makes it the containing block for any `position: fixed` descendant,
//     and a genuine `overflow: hidden`, which clips that descendant;
//   - the "dialog" inside it is a genuine `position: fixed` element with
//     `top/left/right/bottom` offsets. Because the card is now its containing
//     block, those offsets resolve against the CARD, not the browser viewport —
//     so the dialog lands inside the card, fails to reach the card's left / top /
//     bottom edges, and is sliced off at the card's right edge by `overflow`.
// A reader can copy any of these inline styles into devtools and watch the same
// thing happen.
//
// Around the card sits a faint dashed frame labelled "viewport" — purely a
// visual reference so the eye registers that the dialog, which was TOLD to fill
// the screen, never reaches it. The frame draws nothing; it only frames.
//
// Conventions borrowed from this chapter family's other illustrations
// (Ch 020 L7 ContainingBlockDiagram especially): a fixed dark-slate ink that
// reads on every light tint, a system-ui sans stack, hairline edges, fieldset-
// legend pills straddling each box's top border, color-scheme pinned light so
// the hard-coded tints survive dark mode, and an explicit `margin: 0` on EVERY
// element so Starlight's prose `margin-top` injection cannot distort the layout.

import Figure from "../../../figures/Figure.astro";

// Palette ---------------------------------------------------------------------
const INK = "#1e293b"; // primary ink (slate-800)
const INK_SOFT = "#475569"; // secondary / legend text (slate-600)
const FRAME_BORDER = "#94a3b8"; // muted slate — the viewport frame edge
const FRAME_FILL = "#f8fafc"; // very faint slate — viewport interior
const CARD_FILL = "#ffffff"; // the card surface
const CARD_BORDER = "#cbd5e1"; // muted card edge
const CARD_LABEL_BG = "#eef2ff"; // indigo-50 — the card's mechanism pill
const CARD_LABEL_INK = "#4338ca"; // indigo-700 — the card's mechanism pill text
const DANGER = "#dc2626"; // red-600 — the trapped dialog
const DANGER_FILL = "#fef2f2"; // red-50 — dialog interior wash
const DANGER_INK = "#b91c1c"; // red-700 — dialog label text

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = "ui-monospace, SFMono-Regular, Menlo, monospace";

// Frame coordinate system (px) ------------------------------------------------
// The frame is a fixed-width box (sanctioned for figures needing an internal
// coordinate system); it centres in the figure card and never has to wrap.
const FW = 504; // frame width
const FH = 280; // frame height

// The card's place inside the frame. Deliberately small relative to the frame so
// the gap between the (trapped) dialog and the frame's edges reads as "the
// dialog never reaches the screen". The card is centred in the wider frame.
const CARD = { left: 150, top: 122, width: 220, height: 132 };
const LIFT = 2; // the card's translateY(-2px): it paints LIFT px higher.

// A fieldset-legend pill that straddles a box's top border line. `display:
// block` + `width: fit-content` lands a self-sized pill; the parent positions
// it so its vertical centre falls on the border. The pill's background must
// match whatever paints behind the border so it visually breaks the line.
//
// NOTE: the card's mechanism pill is rendered as a SIBLING of the card, not a
// child — because the card's own `overflow: hidden` would otherwise clip the
// very label that announces it. As a frame-level element it straddles the
// card's top border untouched.
function legend(color: string, bg: string, weight = 600, size = 11.5) {
  return `position: absolute; display: block; width: fit-content; margin: 0; padding: 1.5px 8px; font-family: ${sans}; font-size: ${size}px; font-weight: ${weight}; line-height: 1.4; color: ${color}; background: ${bg}; border-radius: 999px; white-space: nowrap;`;
}
---

<Figure caption="The card's transform makes it the containing block, so the dialog's position: fixed resolves against the card — not the viewport. It never reaches the dashed viewport edges, falls short of the card's own bounds, and is sliced off at the right by the card's overflow: hidden. Every box here is real CSS: open devtools and inspect it.">
  <div
    style={`display: flex; justify-content: center; font-family: ${sans}; color: ${INK}; color-scheme: light; margin: 0;`}
  >
    {/* ===================== THE VIEWPORT FRAME ===================== */}
    {/* Visual reference only. It establishes a positioning context for the */}
    {/* card's absolute placement, but it is NOT what `fixed` resolves to — */}
    {/* the card's transform steals that role away. */}
    <div
      style={`position: relative; flex: 0 0 auto; width: ${FW}px; height: ${FH}px; margin: 0; border: 1.5px dashed ${FRAME_BORDER}; border-radius: 14px; background: ${FRAME_FILL};`}
    >
      {/* viewport legend, straddling the frame's top edge */}
      <span style={`${legend(INK_SOFT, FRAME_FILL, 700)} left: 18px; top: -10px;`}>viewport</span>

      {/* what the dialog was AIMING for: a faint hint that `fixed inset-0` was */}
      {/* meant to cover this whole frame. Kept very quiet so it never competes */}
      {/* with the real trapped dialog. */}
      <span
        style={`position: absolute; right: 16px; bottom: 12px; margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; color: ${FRAME_BORDER}; line-height: 1.3; text-align: right;`}
        >fixed inset-0<br />wanted all of this</span
      >

      {/* ===================== THE CARD ===================== */}
      {/* REAL transform (the hover-lift) → becomes the containing block for the */}
      {/* fixed dialog. REAL overflow: hidden → clips the dialog. Both are the */}
      {/* literal mechanism the lesson is about. */}
      <div
        style={`position: absolute; left: ${CARD.left}px; top: ${CARD.top}px; width: ${CARD.width}px; height: ${CARD.height}px; margin: 0; transform: translateY(-${LIFT}px); overflow: hidden; border-radius: 12px; background: ${CARD_FILL}; border: 1.5px solid ${CARD_BORDER}; box-shadow: 0 6px 16px -8px rgba(15, 23, 42, 0.3);`}
      >
        {/* ===================== THE TRAPPED DIALOG ===================== */}
        {/* REAL position: fixed. Its offsets resolve against the CARD because of */}
        {/* the card's transform. The negative `right` pushes its right edge past */}
        {/* the card, where `overflow: hidden` slices it off; the positive top / */}
        {/* left / bottom insets keep it short of the card's other three edges, */}
        {/* so it reads as obviously mis-sized — sized to neither viewport nor */}
        {/* card. These exact numbers are inspectable in devtools. */}
        <div
          style={`position: fixed; top: 30px; left: 24px; right: -68px; bottom: 30px; margin: 0; background: ${DANGER_FILL}; border: 1.5px solid ${DANGER}; border-radius: 9px;`}
        >
          <span
            style={`position: absolute; left: 12px; top: 10px; margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 700; color: ${DANGER_INK}; line-height: 1.2;`}
            >Delete account?</span
          >
          <span
            style={`position: absolute; left: 12px; top: 30px; margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; color: ${DANGER}; line-height: 1.2;`}
            >position: fixed</span
          >
        </div>
      </div>

      {/* ===================== THE CARD'S MECHANISM PILL ===================== */}
      {/* Rendered as a SIBLING of the card (frame coordinate system), straddling */}
      {/* the card's painted top border so the card's own `overflow: hidden` */}
      {/* cannot clip it. The card paints LIFT px higher than CARD.top because of */}
      {/* its transform, so the border line sits at CARD.top - LIFT; the pill's */}
      {/* centre is parked there. As an opaque chip it sits ON the border line, */}
      {/* visually breaking it where the label reads. */}
      <span
        style={`${legend(CARD_LABEL_INK, CARD_LABEL_BG, 600, 11)} font-family: ${mono}; left: ${CARD.left + 12}px; top: ${CARD.top - LIFT - 10}px;`}
        >transform: translateY(-2px) · overflow: hidden</span
      >
    </div>
  </div>
</Figure>
