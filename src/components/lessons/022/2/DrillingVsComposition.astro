---
// drilling-vs-composition — Chapter 022 Lesson 2, the "composition is the first
// answer to prop drilling" figure. Rendered as TWO panels of a sibling
// <TabbedContent> (one component, driven by `variant`), so the only thing that
// changes between tabs is where `user` lives — the four boxes stay put.
//
// Both tabs stack the SAME four components top→bottom:
//
//   Layout  →  Page  →  Header  →  Toolbar
//
// Only the bottom box, <Toolbar>, actually USES `user` (the accent chip,
// "uses it"). Everything above it is the spine the value has to travel.
//
//   variant="drilling"     a `user` chip sits on EVERY box; the three middle
//                          chips are muted ("relays"), and every connector
//                          between boxes is labelled `user` — the value is
//                          threaded by hand through each layer that has no use
//                          for it.
//
//   variant="composition"  `user` is bound ONCE, at the top, inside the
//                          assembled `<Toolbar user={user} />` element that the
//                          consumer hands to <Layout> as a slot. The connectors
//                          between the middle boxes carry an opaque `children`
//                          slot — no `user` on Page or Header. A bypass rail in
//                          the right gutter carries that finished element
//                          straight from the top box to the Toolbar, so `user`
//                          visibly JUMPS past the untouched middle.
//
// The right gutter is reserved (same width) in BOTH variants and the root has a
// fixed min-height, so the card never jumps on a tab switch.
//
// Pure HTML + CSS, inline styles only (devtools-inspectable). `not-content`
// wrapper + `margin: 0` reset on every inner node defeats Starlight's
// prose-margin selector. Chrome rides theme-aware Starlight gray variables; the
// "uses it" accent is the saturated teal-600 family that reads in light + dark.
// No <Figure> wrapper — TabbedContent is its own card.

interface Props {
  variant: "drilling" | "composition";
}

const { variant } = Astro.props;
const drilling = variant === "drilling";

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const accent = "#0d9488"; // teal-600 — "uses it", reads in light + dark

// The four levels, top → bottom. Only the last one consumes `user`.
const levels = ["Layout", "Page", "Header", "Toolbar"] as const;

// ---- layout -------------------------------------------------------------

// Outer row: the box stack (left) + a reserved gutter (right) that holds the
// bypass rail in the composition variant and stays empty in drilling.
const root = [
  reset,
  "display: flex",
  "flex-direction: row",
  "align-items: stretch",
  "justify-content: center",
  "gap: 0",
  "width: 100%",
  "max-width: 380px",
  "min-height: 320px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// The vertical column of boxes + the connectors between them.
const stack = [
  reset,
  "flex: 1 1 auto",
  "min-width: 0",
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "justify-content: center",
].join("; ");

// The reserved right gutter (bypass rail lives here in composition).
const gutter = [
  reset,
  "flex: 0 0 52px",
  "position: relative",
  "display: flex",
].join("; ");

// One component box.
const boxBase = [
  reset,
  "box-sizing: border-box",
  "border-radius: 10px",
  "padding: 9px 12px",
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "justify-content: space-between",
  "gap: 10px",
  "min-height: 44px",
].join("; ");

const boxNeutral = [
  boxBase,
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
].join("; ");

const boxUses = [
  boxBase,
  `border: 1.5px solid ${accent}`,
  `background: color-mix(in srgb, ${accent} 12%, transparent)`,
].join("; ");

const compName = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  "color: var(--sl-color-gray-1)",
].join("; ");

const compNameUses = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 700",
  "line-height: 1.2",
  `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-white))`,
].join("; ");

// "uses it" caption inside the Toolbar box.
const usesNote = [
  reset,
  sans,
  "font-size: 9px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1.1",
  `color: color-mix(in srgb, ${accent} 70%, var(--sl-color-gray-2))`,
].join("; ");

// ---- chips --------------------------------------------------------------

// `user` chip — accent when the box USES it, muted-dashed when it only relays.
const chipUses = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "flex: 0 0 auto",
  "border-radius: 6px",
  "padding: 2px 7px",
  "font-size: 11px",
  "font-weight: 700",
  "line-height: 1.3",
  `border: 1px solid ${accent}`,
  `background: color-mix(in srgb, ${accent} 80%, var(--sl-color-white))`,
  "color: var(--sl-color-white)",
  "white-space: nowrap",
].join("; ");

const chipRelay = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-flex",
  "align-items: center",
  "flex: 0 0 auto",
  "border-radius: 6px",
  "padding: 2px 7px",
  "font-size: 11px",
  "line-height: 1.3",
  "border: 1px dashed var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-7, var(--sl-color-gray-6))",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

// The assembled element handed to <Layout> as a slot, at the call site.
// Plain inline-block (NOT inline-flex): a flex container drops the whitespace
// text nodes between "<Toolbar" and the highlighted token, gluing them
// together — inline-block keeps the spaces and reads as real JSX.
const elementChip = [
  reset,
  mono,
  "box-sizing: border-box",
  "display: inline-block",
  "flex: 0 1 auto",
  "min-width: 0",
  "border-radius: 6px",
  "padding: 2px 7px",
  "font-size: 10.5px",
  "line-height: 1.3",
  `border: 1px solid ${accent}`,
  `background: color-mix(in srgb, ${accent} 12%, transparent)`,
  "color: var(--sl-color-gray-1)",
  "white-space: nowrap",
  "overflow: hidden",
  "text-overflow: ellipsis",
].join("; ");
const elementUser = `color: color-mix(in srgb, ${accent} 80%, var(--sl-color-white)); font-weight: 700`;

// ---- connectors ---------------------------------------------------------

// One connector between two boxes: a centred down-arrow + a side label.
const connector = [
  reset,
  "flex: 0 0 auto",
  "display: flex",
  "flex-direction: row",
  "align-items: center",
  "justify-content: center",
  "gap: 7px",
  "padding: 5px 0",
].join("; ");

// Pill on a connector naming what travels across it (`user` / `children`).
const connLabelUser = [
  reset,
  mono,
  "box-sizing: border-box",
  "border-radius: 5px",
  "padding: 1px 6px",
  "font-size: 10px",
  "line-height: 1.3",
  "border: 1px dashed var(--sl-color-gray-4)",
  "background: var(--sl-color-bg-sidebar, var(--sl-color-gray-6))",
  "color: var(--sl-color-gray-3)",
  "white-space: nowrap",
].join("; ");

const connLabelChildren = [
  reset,
  mono,
  "box-sizing: border-box",
  "border-radius: 5px",
  "padding: 1px 6px",
  "font-size: 10px",
  "line-height: 1.3",
  "border: 1px solid var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6)",
  "color: var(--sl-color-gray-2)",
  "font-weight: 600",
  "white-space: nowrap",
].join("; ");

// A small downward arrow SVG sitting between two boxes.
const downArrow = `<svg width="13" height="22" viewBox="0 0 13 22" role="img" aria-label="passes down to" style="margin: 0; display: block; flex: 0 0 auto;"><line x1="6.5" y1="0" x2="6.5" y2="15" stroke="var(--sl-color-gray-4)" stroke-width="1.6" /><path d="M 6.5 22 L 2 13 L 11 13 Z" fill="var(--sl-color-gray-4)" /></svg>`;
---

<div class="not-content" style={root}>
  <div style={stack}>
    {
      levels.map((name, i) => {
        const isToolbar = name === "Toolbar";
        const isLayout = name === "Layout";
        return (
          <>
            <div style={isToolbar ? boxUses : boxNeutral}>
              <span style={isToolbar ? compNameUses : compName}>
                {name}
              </span>

              {/* What each box holds, per variant. */}
              {isToolbar ? (
                <span style={chipUses}>user</span>
              ) : drilling ? (
                <span style={chipRelay}>user</span>
              ) : isLayout ? (
                <span style={elementChip}>
                  {"<Toolbar "}
                  <span style={elementUser}>{"user={user}"}</span>
                  {" />"}
                </span>
              ) : null}
            </div>

            {/* Toolbar gets a tiny "uses it" caption, stacked under its name —
                rendered as a second row so the box stays compact. */}
            {isToolbar && (
              <div
                style={`${reset}; display: flex; justify-content: flex-start; margin: 3px 0 0; padding: 0 2px;`}
              >
                <span style={usesNote}>uses it</span>
              </div>
            )}

            {/* Connector down to the next box. */}
            {i < levels.length - 1 && (
              <div style={connector}>
                <Fragment set:html={downArrow} />
                <span
                  style={drilling ? connLabelUser : connLabelChildren}
                >
                  {drilling ? "user" : "children"}
                </span>
              </div>
            )}
          </>
        );
      })
    }
  </div>

  {/* Right gutter — the bypass rail, only drawn in the composition variant.
      It carries the assembled <Toolbar user={user} /> straight from the top
      box down to the Toolbar, skipping the untouched middle. */}
  <div style={gutter}>
    {
      !drilling && (
        <svg
          width="52"
          height="100%"
          viewBox="0 0 52 320"
          preserveAspectRatio="none"
          role="img"
          aria-label="user travels straight from Layout to Toolbar, skipping Page and Header"
          style="margin: 0; display: block; position: absolute; inset: 0; overflow: visible;"
        >
          {/* Curve out of the top box, straight down the gutter, back into
              the Toolbar. Endpoints are tuned to the 320px viewBox height. */}
          <path
            d="M 0 30 C 30 30 40 30 40 58 L 40 262 C 40 290 30 290 0 290"
            fill="none"
            stroke={accent}
            stroke-width="1.8"
            stroke-dasharray="4 4"
            stroke-opacity="0.9"
          />
          <path
            d="M 0 290 L 9 285.5 L 9 294.5 Z"
            fill={accent}
            fill-opacity="0.9"
          />
        </svg>
      )
    }
    {
      !drilling && (
        <span
          style={`${reset}; ${mono}; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(90deg); transform-origin: center; font-size: 10px; line-height: 1; color: color-mix(in srgb, ${accent} 80%, var(--sl-color-white)); background: var(--sl-color-bg-sidebar, var(--sl-color-gray-6)); padding: 2px 4px; border-radius: 4px; white-space: nowrap;`}
        >
          user
        </span>
      )
    }
  </div>
</div>
