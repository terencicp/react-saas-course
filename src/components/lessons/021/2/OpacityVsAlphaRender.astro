---
// Two identical "page-with-overlay" mockups rendered side by side so the
// opacity-vs-alpha difference is SEEN, not just read (Chapter 021 L2).
//
// Both panels carry the exact same markup: a small page mockup (a colored
// header bar + skeleton content lines) under a dark overlay whose centered
// white text reads "Saving your changes…".
//
// The only difference is HOW the overlay is dimmed, and it is REAL CSS:
//   - LEFT  ("opacity-50"): the overlay is `background: black; opacity: 0.5`.
//     opacity composites the WHOLE element — backdrop AND the text on top both
//     drop to 50%, so the message goes muddy and the skeleton bleeds through
//     the letters. This is the bug.
//   - RIGHT ("bg-black/50"): the overlay is
//     `background: color-mix(in oklab, black 50%, transparent)` — the exact CSS
//     Tailwind generates for `bg-black/50` — and the text sits at full opacity.
//     Only the background color is faded; the white message stays crisp.
// The browser does the compositing, not us — that is the lesson, made tactile.
//
// FRAMED illustration, NOT project code: hard-coded illustration tints with
// `color-scheme: light` pinned, matching TabularNumsBeforeAfter /
// TextwrapBeforeAfter in this chapter (the sanctioned divergence from @theme
// tokens for figures). `margin: 0` everywhere defeats Starlight's prose margins.
---

<div class="ova-stage not-content">
	<div class="ova-panel">
		{/* Page mockup behind the overlay. */}
		<div class="ova-page" aria-hidden="true">
			<div class="ova-header"></div>
			<div class="ova-line ova-line-1"></div>
			<div class="ova-line ova-line-2"></div>
			<div class="ova-line ova-line-3"></div>
			<div class="ova-line ova-line-4"></div>
		</div>
		{/* The overlay — dimmed with `opacity`, which fades the text too. */}
		<div class="ova-overlay ova-overlay-opacity">
			<span class="ova-message">Saving your changes…</span>
		</div>
	</div>

	<div class="ova-panel">
		{/* Identical page mockup. */}
		<div class="ova-page" aria-hidden="true">
			<div class="ova-header"></div>
			<div class="ova-line ova-line-1"></div>
			<div class="ova-line ova-line-2"></div>
			<div class="ova-line ova-line-3"></div>
			<div class="ova-line ova-line-4"></div>
		</div>
		{/* The overlay — dimmed with a per-property alpha, text stays crisp. */}
		<div class="ova-overlay ova-overlay-alpha">
			<span class="ova-message">Saving your changes…</span>
		</div>
	</div>
</div>

<div class="ova-labels not-content">
	<div class="ova-label">
		<code class="ova-tag ova-tag-bad">opacity-50</code>
		<span class="ova-label-text">text fades</span>
	</div>
	<div class="ova-label">
		<code class="ova-tag ova-tag-good">bg-black/50</code>
		<span class="ova-label-text">text crisp</span>
	</div>
</div>

<style>
	.ova-stage {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 20px;
		margin: 0;
	}

	/* Neutral light panel pinned independent of the site theme so the rendered
	   compositing is the focus — matches the sibling figures in this chapter.
	   A fixed width (not flex) so the mockup keeps its shape in both the prose
	   column and the figure's expand lightbox. */
	.ova-panel {
		position: relative;
		flex: 0 1 260px;
		width: 260px;
		max-width: 100%;
		height: 168px;
		box-sizing: border-box;
		border-radius: 12px;
		border: 1px solid #e2e8f0; /* slate 200 */
		background: #ffffff;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
		overflow: hidden;
		color-scheme: light;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		margin: 0;
	}

	/* The faux page that sits UNDER the overlay. Deliberately colorful so that,
	   on the left panel, the half-transparent backdrop lets it bleed through the
	   faded letters — making the "muddy text" failure unmistakable. */
	.ova-page {
		position: absolute;
		inset: 0;
		padding: 16px;
		margin: 0;
		box-sizing: border-box;
		background: #ffffff;
	}

	.ova-header {
		height: 22px;
		width: 62%;
		border-radius: 6px;
		margin: 0 0 16px;
		background: linear-gradient(90deg, #6366f1, #8b5cf6); /* indigo → violet */
	}

	.ova-line {
		height: 11px;
		border-radius: 5px;
		margin: 0 0 11px;
		background: #cbd5e1; /* slate 300 */
	}

	.ova-line-1 {
		width: 92%;
	}
	.ova-line-2 {
		width: 100%;
	}
	.ova-line-3 {
		width: 84%;
	}
	.ova-line-4 {
		width: 70%;
		background: #93c5fd; /* blue 300 — a touch of color low in the page */
	}

	/* Both overlays cover the whole panel and center the message identically.
	   The ONLY difference is which dimming technique each uses, below. */
	.ova-overlay {
		position: absolute;
		inset: 0;
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.ova-message {
		margin: 0;
		color: #ffffff;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	/* LEFT — `opacity-50`. opacity composites the WHOLE element: the black
	   backdrop AND the white text on top both render, then the finished result
	   is faded to 50%. The text goes translucent and the page bleeds through. */
	.ova-overlay-opacity {
		background: #000000;
		opacity: 0.5;
	}

	/* RIGHT — `bg-black/50`. The exact CSS Tailwind generates: only the
	   background COLOR is mixed toward transparent. The text stays at full
	   opacity and reads crisply over the dimmed backdrop. */
	.ova-overlay-alpha {
		background: color-mix(in oklab, black 50%, transparent);
	}

	/* Per-panel captions, aligned under each panel. */
	.ova-labels {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 20px;
		margin: 12px 0 0;
	}

	.ova-label {
		flex: 0 1 260px;
		width: 260px;
		max-width: 100%;
		display: flex;
		align-items: baseline;
		justify-content: center;
		gap: 8px;
		margin: 0;
	}

	.ova-tag {
		margin: 0;
		padding: 2px 8px;
		border-radius: 6px;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.8rem;
		font-weight: 600;
		white-space: nowrap;
	}

	.ova-tag-bad {
		color: #b91c1c; /* red 700 */
		background: #fef2f2; /* red 50 */
		border: 1px solid #fecaca; /* red 200 */
	}

	.ova-tag-good {
		color: #047857; /* emerald 700 */
		background: #ecfdf5; /* emerald 50 */
		border: 1px solid #a7f3d0; /* emerald 200 */
	}

	.ova-label-text {
		margin: 0;
		font-size: 0.85rem;
		color: #475569; /* slate 600 */
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	@media (max-width: 460px) {
		.ova-stage,
		.ova-labels {
			gap: 12px;
		}
		.ova-message {
			font-size: 0.85rem;
		}
	}
</style>
