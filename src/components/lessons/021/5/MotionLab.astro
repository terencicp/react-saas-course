---
// "The motion lab" — the hands-on playground for Tier 1 (transitions) in ch021 L5.
// A thin wrapper over <ParamPlayground> that hides the preview markup and the
// scoped style-query plumbing so the MDX stays a single self-describing tag.
//
// What the student feels here:
//   - DURATION as a band, not a free dial. Sliding past ~400ms the box visibly
//     drags; around 150ms it snaps. The number is felt, not read.
//   - EASING as a shape. ease-out settles on arrival; ease-in accelerates away;
//     linear is flat. The same travel under different curves feels different.
//   - The transition fires in BOTH directions because the toggle flips --go
//     between two values, so the box also returns when you toggle off.
//
// Mechanics. The box always declares `transition-property: transform, opacity`
// and reads `transition-duration: var(--duration)` + `transition-timing-function:
// var(--easing)` from the controls. Its TARGET state is gated by two custom
// properties the ParamPlayground script writes onto the preview wrapper:
//   --go   : "on" | "off"        (the Animate toggle)
//   --prop : "transform" | "opacity"  (the Property select)
// A CSS selector can't compare a custom-property's *string* value, so the gating
// is done with style container queries — every element is a style-query container
// by default, so the descendant `.ml-box` resolves both vars from the wrapper.
// This mirrors the working OklchTokenLab pattern in ch018 L5.
//
// The box's fill is a literal brand blue (not a site token): the lesson is about
// motion, and the swatch should read identically in both themes. The
// <ParamPlayground> chrome around it already flips with the site theme.

import ParamPlayground from '../../../figures/param-playground/ParamPlayground.astro';
import Param from '../../../figures/param-playground/Param.astro';
import Preview from '../../../figures/param-playground/Preview.astro';
import Readout from '../../../figures/param-playground/Readout.astro';
---

<ParamPlayground caption="The motion lab — flip the toggle and watch the box move under your chosen settings.">
  <Param id="duration" kind="slider" label="Duration" min={0} max={600} step={10} default={300} suffix="ms" />
  <Param id="easing" kind="select" label="Easing" options={['ease-out', 'ease-in', 'ease-in-out', 'linear']} default="ease-out" />
  <Param id="prop" kind="select" label="Property" options={['transform', 'opacity']} default="transform" />
  <Param id="go" kind="toggle" label="Animate" on="on" off="off" default={false} />

  <Preview>
    <div class="ml-track">
      <div class="ml-box">box</div>
    </div>
  </Preview>

  <Readout label="duration" of="duration" suffix="ms" />
  <Readout label="transition" expr="prop + ' ' + duration + 'ms ' + easing" />
</ParamPlayground>

<style is:global>
  /* Register the two gating vars as inherited custom properties so Chromium
     re-evaluates the style queries every time the toggle / select rewrites
     them. Without registration an unregistered inherited property changing on an
     already-rendered subtree leaves the style-container query stale, so toggling
     Animate off would not return the box. `syntax: "*"` forbids an initial-value;
     the ParamPlayground script seeds both on mount. */
  @property --go {
    syntax: "*";
    inherits: true;
  }
  @property --prop {
    syntax: "*";
    inherits: true;
  }

  /* A full-width lane so the box has room to translate rightward and stays
     visible against the preview's left edge. `container-type: inline-size` makes
     the lane a SIZE container so the box can express its travel in `cqw` — the
     translate then scales to whatever width the preview happens to be, and the
     box can never run past the (overflow-hidden) preview edge. */
  .param-playground .ml-track {
    container-type: inline-size;
    width: 100%;
    min-height: 88px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-left: 4px;
  }

  /* The single animated box. It ALWAYS watches transform + opacity and inherits
     the duration / easing from the controls; only its target state changes. Rest
     state is untransformed and fully opaque — the style queries below push it to
     the target while Animate is on. */
  .param-playground .ml-box {
    box-sizing: border-box;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: oklch(0.62 0.19 256);
    color: #ffffff;
    font: 600 0.8rem ui-sans-serif, system-ui, -apple-system, sans-serif;
    letter-spacing: 0.01em;
    box-shadow: 0 4px 12px oklch(0.62 0.19 256 / 0.35);
    transform: none;
    opacity: 1;
    transition-property: transform, opacity;
    transition-duration: var(--duration, 300ms);
    transition-timing-function: var(--easing, ease-out);
  }

  /* Gate the target state on the Animate toggle AND the chosen property. Each
     target is one combined style query — nesting `@container` style queries does
     not apply here (Chromium evaluates only the outer level), whereas a single
     `and`-combined condition matches reliably.

     The selectors deliberately include `.ml-track` so they out-specify the base
     `.param-playground .ml-box` rule above (0,3,0 vs 0,2,0). A style query adds
     no specificity, so without this the conditional and base rules would tie and
     fall back to source order — making the override depend on how the bundler
     emits the block. The extra class makes the win order-independent. */
  @container style(--go: on) and style(--prop: transform) {
    .param-playground .ml-track .ml-box {
      /* Travel = (lane width − box width − the 4px lane padding − a small gutter),
         capped so it never gets cartoonishly large in a wide preview. The box's
         right edge therefore lands inside the lane at any width — no clipping. */
      transform: translateX(min(11rem, calc(100cqw - 56px - 12px))) scale(0.85);
    }
  }
  @container style(--go: on) and style(--prop: opacity) {
    .param-playground .ml-track .ml-box {
      opacity: 0.15;
    }
  }
</style>
