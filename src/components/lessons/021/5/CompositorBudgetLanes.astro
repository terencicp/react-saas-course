---
// The compositor budget as a pipeline + cost tracks (Chapter 021 L5).
//
// A horizontal three-stage rendering pipeline read left-to-right:
//   Layout (red) -> Paint (orange) -> Composite (green).
// The stages run IN ORDER and a property change "reaches down" the chain, so the
// cells a change lights up are always a contiguous SUFFIX of the strip. That makes
// the pedagogy SPATIAL: the green cheap track is one short cell, the red expensive
// track spans the whole strip. Three property rows below the header share the exact
// same three stage columns (one CSS grid drives the whole figure), so each row's lit
// run lines up under the named stages and its length = the per-frame cost.
//
//   geometry (width/height/top/margin) -> all three lit       -> expensive
//   color    (background-color/color/box-shadow) -> paint+composite -> medium
//   transform/opacity -> composite only            -> cheap (60fps)
//
// Lit cells carry their stage's saturated fill (the color IS the signal, so white
// text on a 600-range tint reads in both themes per the html-css diagram notes); dim
// cells are a faint dashed outline so the "doesn't reach here" reading is obvious.
// Purely presentational, devtools-inspectable. `margin: 0` everywhere defeats
// Starlight's injected prose margins, and `not-content` opts the figure out of prose
// styling.

const stages = [
	{ key: 'layout', name: 'Layout', sub: 'recompute geometry' },
	{ key: 'paint', name: 'Paint', sub: 'redraw pixels' },
	{ key: 'composite', name: 'Composite', sub: 'GPU moves layer' },
] as const;

type Reach = 'layout' | 'paint' | 'composite';

const rows: {
	label: string;
	reaches: Reach[];
	tag: string;
	cost: 'expensive' | 'medium' | 'cheap';
}[] = [
	{
		label: 'width / height / top / margin',
		reaches: ['layout', 'paint', 'composite'],
		tag: 'expensive',
		cost: 'expensive',
	},
	{
		label: 'background-color / color / box-shadow',
		reaches: ['paint', 'composite'],
		tag: 'medium',
		cost: 'medium',
	},
	{
		label: 'transform / opacity',
		reaches: ['composite'],
		tag: 'cheap — 60fps',
		cost: 'cheap',
	},
];
---

<div class="cbl not-content">
	{/* The pipeline header: three named stages, arrows showing the forced order. */}
	<div class="cbl-row cbl-head">
		<span class="cbl-rowlabel cbl-headlabel">The rendering pipeline</span>
		{
			stages.map((stage, i) => (
				<div class={`cbl-stage cbl-stage-${stage.key}`}>
					{i > 0 && (
						<span class="cbl-arrow" aria-hidden="true">
							→
						</span>
					)}
					<span class="cbl-stagename">{stage.name}</span>
					<span class="cbl-stagesub">{stage.sub}</span>
				</div>
			))
		}
		<span class="cbl-taghead" aria-hidden="true" />
	</div>

	{/* One row per kind of property change. Cells light up the stages reached. */}
	{
		rows.map((row) => (
			<div class="cbl-row">
				<code class="cbl-rowlabel">{row.label}</code>
				{stages.map((stage) => {
					const lit = row.reaches.includes(stage.key as Reach);
					return (
						<div
							class:list={[
								'cbl-cell',
								lit ? `cbl-lit cbl-lit-${stage.key}` : 'cbl-dim',
							]}
						>
							{lit && <span class="cbl-celltext">{stage.name}</span>}
						</div>
					);
				})}
				<span class={`cbl-tag cbl-tag-${row.cost}`}>{row.tag}</span>
			</div>
		))
	}
</div>

<style>
	.cbl {
		display: flex;
		flex-direction: column;
		gap: 10px;
		width: 100%;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* One shared coordinate grid: property label | 3 stage columns | cost tag.
	   The header row and every property row use the SAME template, so the stage
	   cells stack into three aligned columns down the figure. */
	.cbl-row {
		display: grid;
		grid-template-columns:
			minmax(160px, 1.25fr) repeat(3, minmax(96px, 1fr))
			minmax(96px, auto);
		align-items: stretch;
		gap: 8px;
		margin: 0;
	}

	.cbl-rowlabel {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		text-align: end;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-white);
		background: transparent;
		padding: 0;
		margin: 0;
	}

	/* --- Header pipeline ------------------------------------------------ */
	.cbl-head {
		margin: 0 0 2px;
	}

	.cbl-headlabel {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}

	.cbl-stage {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1px;
		padding: 9px 6px;
		border-radius: 9px;
		color: #ffffff;
		text-align: center;
		margin: 0;
	}

	.cbl-stagename {
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.1;
		margin: 0;
	}

	.cbl-stagesub {
		font-size: 0.64rem;
		font-weight: 500;
		line-height: 1.15;
		opacity: 0.9;
		margin: 0;
	}

	/* The arrow sits in the gap to the left of paint/composite, signalling that
	   the stages run in a forced order. Absolutely positioned so it never steals
	   width from the grid column (alignment stays exact). */
	.cbl-arrow {
		position: absolute;
		left: -11px;
		top: 50%;
		transform: translateY(-50%);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* Stage identity colors — saturated 600-range so white text reads in both
	   light and dark mode; the color itself is the signal. */
	.cbl-stage-layout {
		background: #dc2626; /* red 600 */
	}
	.cbl-stage-paint {
		background: #ea580c; /* orange 600 */
	}
	.cbl-stage-composite {
		background: #16a34a; /* green 600 */
	}

	/* --- Property rows -------------------------------------------------- */
	.cbl-cell {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 34px;
		border-radius: 8px;
		box-sizing: border-box;
		margin: 0;
	}

	/* A lit cell = this change reaches this stage. Carries the stage's color. */
	.cbl-lit {
		color: #ffffff;
	}
	.cbl-lit-layout {
		background: #dc2626;
	}
	.cbl-lit-paint {
		background: #ea580c;
	}
	.cbl-lit-composite {
		background: #16a34a;
	}

	.cbl-celltext {
		font-size: 0.74rem;
		font-weight: 600;
		margin: 0;
	}

	/* A dim cell = the change never reaches this stage. Faint dashed ghost. */
	.cbl-dim {
		background: color-mix(in oklch, var(--sl-color-gray-5) 35%, transparent);
		border: 1px dashed var(--sl-color-gray-4);
	}

	/* --- Cost tags ------------------------------------------------------ */
	.cbl-tag,
	.cbl-taghead {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 34px;
		padding: 0 10px;
		border-radius: 999px;
		font-size: 0.74rem;
		font-weight: 700;
		white-space: nowrap;
		margin: 0;
	}

	.cbl-taghead {
		background: transparent;
	}

	.cbl-tag-expensive {
		color: #b91c1c; /* red 700 */
		background: color-mix(in oklch, #dc2626 16%, transparent);
		border: 1px solid color-mix(in oklch, #dc2626 35%, transparent);
	}
	.cbl-tag-medium {
		color: #c2410c; /* orange 700 */
		background: color-mix(in oklch, #ea580c 16%, transparent);
		border: 1px solid color-mix(in oklch, #ea580c 35%, transparent);
	}
	.cbl-tag-cheap {
		color: #15803d; /* green 700 */
		background: color-mix(in oklch, #16a34a 18%, transparent);
		border: 1px solid color-mix(in oklch, #16a34a 38%, transparent);
	}

	/* Brighten the saturated tag text in dark mode so it doesn't go muddy. */
	:global([data-theme='dark']) .cbl-tag-expensive {
		color: #f87171;
	}
	:global([data-theme='dark']) .cbl-tag-medium {
		color: #fb923c;
	}
	:global([data-theme='dark']) .cbl-tag-cheap {
		color: #4ade80;
	}

	@media (max-width: 640px) {
		.cbl-row {
			grid-template-columns:
				minmax(108px, 1.2fr) repeat(3, minmax(58px, 1fr))
				minmax(66px, auto);
			gap: 6px;
		}
		.cbl-rowlabel {
			font-size: 0.66rem;
		}
		.cbl-stagename {
			font-size: 0.78rem;
		}
		.cbl-stagesub {
			display: none;
		}
		.cbl-celltext {
			font-size: 0.64rem;
		}
		.cbl-tag,
		.cbl-taghead {
			font-size: 0.62rem;
			padding: 0 6px;
		}
		.cbl-arrow {
			left: -9px;
			font-size: 0.8rem;
		}
	}
</style>
