---
// "The choreography seam" — the centerpiece DiagramSequence for ch021 L5.
//
// Makes the lesson's load-bearing idea TANGIBLE: state lives in React, motion
// lives in CSS, and the `data-state` attribute is the seam between them. The
// student scrubs a Dialog through its four-step lifecycle and watches the
// attribute flip in the DOM panel (left) DRIVE the rendered frame (right).
//
//   1 Closed   — content element absent from the DOM; no data-state exists.
//   2 Opening  — Radix mounts it, sets data-state="open"; animate-in mid-play.
//   3 Open      — entrance settled; full scale + opacity.
//   4 Closing   — data-state flips to "closed"; animate-out mid-play; Radix
//                 holds the element mounted until the exit finishes.
//
// Each step is two synced panels:
//   LEFT  (DOM)      — the content <div> with its literal data-state + class
//                      string, the data-state token EMPHASISED. Step 1 shows
//                      only the trigger button (no content element yet).
//   RIGHT (rendered) — a mock page with a "Delete account" trigger and, from
//                      step 2 on, a modal dialog whose scale/opacity and backdrop
//                      dim are frozen at that point in the fade+zoom. The
//                      transform/opacity values are baked in inline so the frame
//                      reads identically in both themes and never animates (a
//                      static panel can't capture motion — that's WHY this is a
//                      scrubbable sequence, per the lesson's live-render note).
//
// All four steps share the same two-panel skeleton so the grid stack sizes to a
// constant height and never jumps as the reader scrubs. Purely presentational;
// `not-content` opts the figure out of Starlight prose styling and `margin: 0`
// defeats injected prose margins.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Each step's rendered-frame geometry. `dim` is the backdrop opacity, `scale`
// and `opacity` freeze the dialog mid fade+zoom. Step 1 has no dialog at all.
type Frame = {
	hasDialog: boolean;
	dim: number;
	scale: number;
	opacity: number;
};

const frames: Record<'closed' | 'opening' | 'open' | 'closing', Frame> = {
	closed: { hasDialog: false, dim: 0, scale: 1, opacity: 0 },
	opening: { hasDialog: true, dim: 0.55, scale: 0.95, opacity: 0.6 },
	open: { hasDialog: true, dim: 1, scale: 1, opacity: 1 },
	closing: { hasDialog: true, dim: 0.5, scale: 0.96, opacity: 0.45 },
};
---

<DiagramSequence>
	{/* ---- Step 1 · Closed -------------------------------------------------- */}
	<DiagramStep>
		<div class="dsc">
			<div class="dsc-panel dsc-dom">
				<span class="dsc-panel-label">DOM</span>
				<div class="dsc-code">
					<div class="dsc-line">
						<span class="dsc-punct">&lt;</span><span class="dsc-tag">button</span><span
							class="dsc-punct">&gt;</span
						>Delete account<span class="dsc-punct">&lt;/</span><span class="dsc-tag"
							>button</span
						><span class="dsc-punct">&gt;</span>
					</div>
					<div class="dsc-absent">
						<span class="dsc-absent-mark" aria-hidden="true">∅</span>
						<span>no dialog content element in the DOM</span>
					</div>
				</div>
			</div>

			<div class="dsc-panel dsc-render">
				<span class="dsc-panel-label">Rendered</span>
				<div class="dsc-stage">
					<div class="dsc-backdrop" style={`opacity:${frames.closed.dim}`}></div>
					<button class="dsc-trigger" type="button">Delete account</button>
				</div>
			</div>
		</div>
		<Fragment slot="caption">
			<strong>Closed.</strong> The trigger is visible; the dialog content is not in the DOM.
			<code>data-state</code> doesn't exist yet because the element doesn't.
		</Fragment>
	</DiagramStep>

	{/* ---- Step 2 · Opening ------------------------------------------------- */}
	<DiagramStep>
		<div class="dsc">
			<div class="dsc-panel dsc-dom">
				<span class="dsc-panel-label">DOM</span>
				<div class="dsc-code">
					<div class="dsc-line">
						<span class="dsc-punct">&lt;</span><span class="dsc-tag">div</span>
						<span class="dsc-attr">data-state</span><span class="dsc-punct">=</span><span
							class="dsc-state dsc-state-open">"open"</span
						>
					</div>
					<div class="dsc-line dsc-indent">
						<span class="dsc-attr">class</span><span class="dsc-punct">=</span><span
							class="dsc-str">"animate-in fade-in-0 zoom-in-95"</span
						><span class="dsc-punct">&gt;</span>
					</div>
				</div>
			</div>

			<div class="dsc-panel dsc-render">
				<span class="dsc-panel-label">Rendered</span>
				<div class="dsc-stage">
					<div class="dsc-backdrop" style={`opacity:${frames.opening.dim}`}></div>
					<div
						class="dsc-dialog"
						style={`transform:scale(${frames.opening.scale});opacity:${frames.opening.opacity}`}
					>
						<span class="dsc-dialog-title">Delete account?</span>
						<span class="dsc-dialog-body">This action can't be undone.</span>
						<span class="dsc-dialog-btn">Delete</span>
					</div>
				</div>
			</div>
		</div>
		<Fragment slot="caption">
			<strong>Opening.</strong> Radix mounts the content and sets <code>data-state="open"</code>.
			The <code>animate-in fade-in-0 zoom-in-95</code> utilities fire — the dialog is mid-entrance.
		</Fragment>
	</DiagramStep>

	{/* ---- Step 3 · Open --------------------------------------------------- */}
	<DiagramStep>
		<div class="dsc">
			<div class="dsc-panel dsc-dom">
				<span class="dsc-panel-label">DOM</span>
				<div class="dsc-code">
					<div class="dsc-line">
						<span class="dsc-punct">&lt;</span><span class="dsc-tag">div</span>
						<span class="dsc-attr">data-state</span><span class="dsc-punct">=</span><span
							class="dsc-state dsc-state-open">"open"</span
						>
					</div>
					<div class="dsc-line dsc-indent">
						<span class="dsc-attr">class</span><span class="dsc-punct">=</span><span
							class="dsc-str">"animate-in fade-in-0 zoom-in-95"</span
						><span class="dsc-punct">&gt;</span>
					</div>
				</div>
			</div>

			<div class="dsc-panel dsc-render">
				<span class="dsc-panel-label">Rendered</span>
				<div class="dsc-stage">
					<div class="dsc-backdrop" style={`opacity:${frames.open.dim}`}></div>
					<div
						class="dsc-dialog"
						style={`transform:scale(${frames.open.scale});opacity:${frames.open.opacity}`}
					>
						<span class="dsc-dialog-title">Delete account?</span>
						<span class="dsc-dialog-body">This action can't be undone.</span>
						<span class="dsc-dialog-btn">Delete</span>
					</div>
				</div>
			</div>
		</div>
		<Fragment slot="caption">
			<strong>Open.</strong> The entrance animation has settled. The dialog sits at full scale and
			full opacity; <code>data-state</code> stays <code>"open"</code>.
		</Fragment>
	</DiagramStep>

	{/* ---- Step 4 · Closing ------------------------------------------------ */}
	<DiagramStep>
		<div class="dsc">
			<div class="dsc-panel dsc-dom">
				<span class="dsc-panel-label">DOM</span>
				<div class="dsc-code">
					<div class="dsc-line">
						<span class="dsc-punct">&lt;</span><span class="dsc-tag">div</span>
						<span class="dsc-attr">data-state</span><span class="dsc-punct">=</span><span
							class="dsc-state dsc-state-closed">"closed"</span
						>
					</div>
					<div class="dsc-line dsc-indent">
						<span class="dsc-attr">class</span><span class="dsc-punct">=</span><span
							class="dsc-str">"animate-out fade-out-0 zoom-out-95"</span
						><span class="dsc-punct">&gt;</span>
					</div>
				</div>
			</div>

			<div class="dsc-panel dsc-render">
				<span class="dsc-panel-label">Rendered</span>
				<div class="dsc-stage">
					<div class="dsc-backdrop" style={`opacity:${frames.closing.dim}`}></div>
					<div
						class="dsc-dialog"
						style={`transform:scale(${frames.closing.scale});opacity:${frames.closing.opacity}`}
					>
						<span class="dsc-dialog-title">Delete account?</span>
						<span class="dsc-dialog-body">This action can't be undone.</span>
						<span class="dsc-dialog-btn">Delete</span>
					</div>
				</div>
			</div>
		</div>
		<Fragment slot="caption">
			<strong>Closing.</strong> <code>data-state</code> flips to <code>"closed"</code> and
			<code>animate-out fade-out-0 zoom-out-95</code> plays. Radix keeps the element mounted until the
			exit animation ends, then removes it.
		</Fragment>
	</DiagramStep>
</DiagramSequence>

<style>
	/* Two synced panels: DOM (the cause) on the left, rendered frame (the effect)
	   on the right, arrowed across the seam. */
	.dsc {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
		align-items: stretch;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The seam: a faint arrow rendered in the gap between the two panels, pointing
	   from DOM to rendered (cause -> effect). */
	.dsc::before {
		content: '→';
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		font-size: 1.3rem;
		font-weight: 700;
		color: var(--sl-color-gray-4);
		z-index: 2;
		pointer-events: none;
	}
	.dsc {
		position: relative;
	}

	.dsc-panel {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 10px;
		min-width: 0;
		padding: 12px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg);
		margin: 0;
	}

	.dsc-panel-label {
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
		margin: 0;
	}

	/* ---- DOM panel (left): the content element as code ----------------- */
	.dsc-code {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		padding: 12px;
		border-radius: 8px;
		background: var(--sl-color-bg-sidebar);
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.82rem;
		line-height: 1.55;
		overflow-x: auto;
		margin: 0;
	}

	.dsc-line {
		white-space: nowrap;
		margin: 0;
	}
	.dsc-indent {
		padding-left: 1.4ch;
	}

	.dsc-punct {
		color: var(--sl-color-gray-3);
	}
	.dsc-tag {
		color: var(--sl-color-text-accent);
		font-weight: 600;
	}
	.dsc-attr {
		color: var(--sl-color-white);
	}
	.dsc-str {
		color: var(--sl-color-gray-2);
	}

	/* The data-state value is the protagonist — boxed and tinted so the eye
	   tracks it as the one thing changing across steps. */
	.dsc-state {
		font-weight: 700;
		padding: 0 5px;
		border-radius: 5px;
	}
	.dsc-state-open {
		color: #15803d;
		background: color-mix(in oklch, #16a34a 16%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in oklch, #16a34a 45%, transparent);
	}
	.dsc-state-closed {
		color: #c2410c;
		background: color-mix(in oklch, #ea580c 16%, transparent);
		box-shadow: inset 0 0 0 1px color-mix(in oklch, #ea580c 45%, transparent);
	}
	:global([data-theme='dark']) .dsc-state-open {
		color: #4ade80;
	}
	:global([data-theme='dark']) .dsc-state-closed {
		color: #fb923c;
	}

	/* When the element doesn't exist yet (step 1). */
	.dsc-absent {
		display: flex;
		align-items: center;
		gap: 8px;
		color: var(--sl-color-gray-4);
		font-style: italic;
		font-size: 0.76rem;
	}
	.dsc-absent-mark {
		font-size: 1rem;
		font-style: normal;
	}

	/* ---- Rendered panel (right): the mock modal frame ----------------- */
	.dsc-stage {
		position: relative;
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 150px;
		padding: 14px;
		border-radius: 8px;
		/* A faint app-window surface so the dimming backdrop reads against it. */
		background: linear-gradient(
			135deg,
			color-mix(in oklch, var(--sl-color-gray-6) 60%, transparent),
			color-mix(in oklch, var(--sl-color-gray-5) 40%, transparent)
		);
		overflow: hidden;
		margin: 0;
	}

	/* The page's resting trigger, sitting under the modal layer. */
	.dsc-trigger {
		position: relative;
		z-index: 1;
		padding: 7px 14px;
		border-radius: 7px;
		border: none;
		background: #dc2626;
		color: #fff;
		font-size: 0.82rem;
		font-weight: 600;
		font-family: inherit;
		cursor: default;
		margin: 0;
	}

	/* The modal scrim. Opacity is frozen per step via an inline style. */
	.dsc-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(15, 23, 42, 0.72);
		z-index: 2;
		transition: opacity 0.2s ease;
	}

	/* The dialog itself. transform: scale() + opacity are frozen per step via an
	   inline style — exactly the two composite-only properties the fade+zoom
	   animates, so the frozen frame mirrors what the real animation produces. */
	.dsc-dialog {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		gap: 6px;
		width: min(78%, 230px);
		padding: 14px 16px;
		border-radius: 10px;
		background: #ffffff;
		box-shadow: 0 16px 40px -12px rgba(0, 0, 0, 0.55);
		text-align: left;
		transition:
			transform 0.2s ease,
			opacity 0.2s ease;
	}
	.dsc-dialog-title {
		font-size: 0.86rem;
		font-weight: 700;
		color: #0f172a;
		margin: 0;
	}
	.dsc-dialog-body {
		font-size: 0.72rem;
		color: #475569;
		line-height: 1.4;
		margin: 0;
	}
	.dsc-dialog-btn {
		align-self: flex-end;
		margin-top: 4px;
		padding: 4px 12px;
		border-radius: 6px;
		background: #dc2626;
		color: #fff;
		font-size: 0.72rem;
		font-weight: 600;
	}

	@media (max-width: 640px) {
		.dsc {
			grid-template-columns: 1fr;
			gap: 26px;
		}
		/* On a single column the seam arrow points downward between the stacked
		   panels instead of across. */
		.dsc::before {
			content: '↓';
			top: calc(50% - 1px);
		}
		.dsc-code {
			font-size: 0.74rem;
		}
		.dsc-stage {
			min-height: 130px;
		}
	}
</style>
