---
// The same column of right-aligned dollar figures rendered twice: once with the
// font's default (proportional) numerals and once with font-variant-numeric:
// tabular-nums. The amounts deliberately mix narrow digits (1) with wide ones
// (8, 9) so that, in the proportional column, equal-length numbers occupy
// different widths and the digits / decimal points drift out of vertical
// alignment. tabular-nums forces every digit to one width, snapping the column
// into a clean grid. Right alignment is the real dashboard pattern, and it is
// what makes the per-row drift visible against the shared right edge.
const figures = ['$1,141.00', '$9,888.10', '$211.18', '$1,010.91'];
---

<div class="tnba-stage">
	<div class="tnba-card">
		<div class="tnba-col">
			<span class="tnba-tag">default</span>
			<div class="tnba-figures tnba-proportional">
				{figures.map((f) => <div class="tnba-figure">{f}</div>)}
			</div>
		</div>

		<div class="tnba-divider" aria-hidden="true"></div>

		<div class="tnba-col">
			<span class="tnba-tag tnba-tag-good">tabular-nums</span>
			<div class="tnba-figures tnba-tabular">
				{figures.map((f) => <div class="tnba-figure">{f}</div>)}
			</div>
		</div>
	</div>
</div>

<style>
	.tnba-stage {
		display: flex;
		justify-content: center;
		padding: 8px 0;
		margin: 0;
	}

	/* Neutral light card so the rendered numerals are the focus, independent of
	   the surrounding site theme — matches the sibling text-wrap figure. */
	.tnba-card {
		display: flex;
		align-items: stretch;
		gap: 0;
		box-sizing: border-box;
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 22px 12px;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		margin: 0;
	}

	.tnba-col {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		padding: 0 26px;
		margin: 0;
	}

	.tnba-divider {
		width: 1px;
		align-self: stretch;
		background: #e2e8f0;
		margin: 0;
	}

	.tnba-tag {
		display: inline-block;
		margin: 0 0 14px;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.04em;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		color: #64748b;
		background: #f1f5f9;
		border-radius: 5px;
		padding: 2px 7px;
	}

	.tnba-tag-good {
		color: #047857;
		background: #ecfdf5;
	}

	/* A hairline rule flush against the shared right edge of the figures gives
	   the eye a reference: in the tabular column every digit sits on a clean
	   grid against it; in the proportional column the rows drift. */
	.tnba-figures {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 10px;
		padding-right: 10px;
		border-right: 1px dashed #cbd5e1;
		margin: 0;
	}

	.tnba-figure {
		margin: 0;
		font-size: 1.375rem;
		line-height: 1.1;
		font-weight: 600;
		color: #0f172a;
		font-variant-numeric: normal;
		/* lining figures so the comparison is purely proportional vs tabular */
		text-align: right;
	}

	/* The two strategies under test. */
	.tnba-proportional .tnba-figure {
		font-variant-numeric: proportional-nums;
	}

	.tnba-tabular .tnba-figure {
		font-variant-numeric: tabular-nums;
	}
</style>
