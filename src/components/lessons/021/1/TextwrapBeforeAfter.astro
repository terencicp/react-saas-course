---
import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

// The same heading text is rendered in tabs 1 and 2 at the same constrained
// width so the orphan word in the default tab and its disappearance under
// text-balance read against each other.
const heading = 'Get paid faster with less busywork';

// Body copy for the text-pretty tab. At the prose panel width the default
// wrap strands "dashboard." alone on the last line; text-wrap: pretty pulls
// "your" down so the last line reads "your dashboard." instead.
const paragraph =
	'Send branded invoices, track exactly what your customers have paid, and chase down whatever is still outstanding from your dashboard.';
---

<TabbedContent>
	<TabbedItem
		label="Default wrap"
		caption="Greedy wrapping strands the last word on its own line — the orphan."
	>
		<div class="twba-stage">
			<div class="twba-panel">
				<span class="twba-tag">heading</span>
				<h3 class="twba-heading twba-wrap-normal">{heading}</h3>
			</div>
		</div>
	</TabbedItem>

	<TabbedItem
		label="text-balance"
		caption="text-balance evens the lines so no word is left stranded."
	>
		<div class="twba-stage">
			<div class="twba-panel">
				<span class="twba-tag twba-tag-good">text-wrap: balance</span>
				<h3 class="twba-heading twba-wrap-balance">{heading}</h3>
			</div>
		</div>
	</TabbedItem>

	<TabbedItem
		label="text-pretty"
		caption="text-pretty avoids a too-short last line in body copy."
	>
		<div class="twba-stage">
			<div class="twba-panel twba-panel-prose">
				<span class="twba-tag">default</span>
				<p class="twba-body twba-wrap-normal">{paragraph}</p>
				<div class="twba-divider"></div>
				<span class="twba-tag twba-tag-good">text-wrap: pretty</span>
				<p class="twba-body twba-wrap-pretty">{paragraph}</p>
			</div>
		</div>
	</TabbedItem>
</TabbedContent>

<style>
	.twba-stage {
		display: flex;
		justify-content: center;
		padding: 8px 0;
	}

	/* A neutral light card so the rendered text is the focus, independent of
	   the surrounding site theme. */
	.twba-panel {
		width: 24rem;
		max-width: 100%;
		box-sizing: border-box;
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 20px 22px;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.twba-tag {
		display: inline-block;
		margin-bottom: 10px;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.04em;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		color: #64748b;
		background: #f1f5f9;
		border-radius: 5px;
		padding: 2px 7px;
	}

	.twba-tag-good {
		color: #047857;
		background: #ecfdf5;
	}

	.twba-heading {
		margin: 0;
		font-size: 1.5rem;
		line-height: 1.2;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: #0f172a;
	}

	.twba-panel-prose {
		width: 31rem;
	}

	.twba-body {
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.55;
		color: #334155;
	}

	.twba-divider {
		height: 1px;
		background: #e2e8f0;
		margin: 16px 0;
	}

	.twba-panel-prose .twba-tag:not(:first-child) {
		margin-top: 0;
	}

	/* The wrapping strategies under test. */
	.twba-wrap-normal {
		text-wrap: normal;
	}
	.twba-wrap-balance {
		text-wrap: balance;
	}
	.twba-wrap-pretty {
		text-wrap: pretty;
	}

	@media (max-width: 32rem) {
		.twba-panel,
		.twba-panel-prose {
			width: 100%;
		}
	}
</style>
