---
// A static reference strip showing the SAME card at four points along the
// radius scale, so the progression reads side by side (Chapter 021 L3).
//
// Cards 1–3 are identical squares — the ONLY thing that changes is the corner
// radius (sm 4px → lg 8px → 2xl 16px), so the eye compares the curve directly.
// Card 4 is deliberately wider-than-tall and carries `rounded-full`, which on a
// non-square box produces a PILL (flat top/bottom, semicircular ends), not a
// circle — that is the lesson's headline radius surprise, made visible.
//
// Each radius is set with a REAL `border-radius` so a reader can open devtools
// and inspect it. FRAMED illustration, not project code: a light surface is
// pinned with `color-scheme: light` and hard-coded slate tints, matching the
// sibling figures in this chapter (the sanctioned divergence from @theme
// tokens for figures). `margin: 0` everywhere defeats Starlight's prose margins.

const steps = [
	{ radius: '4px', util: 'rounded-sm', label: 'sm', pill: false },
	{ radius: '8px', util: 'rounded-lg', label: 'lg', pill: false },
	{ radius: '16px', util: 'rounded-2xl', label: '2xl', pill: false },
	{ radius: '9999px', util: 'rounded-full', label: 'full → pill', pill: true },
];
---

<div class="rs-strip not-content">
	{
		steps.map((step) => (
			<div class="rs-item">
				<div
					class:list={['rs-card', { 'rs-card-wide': step.pill }]}
					style={`border-radius: ${step.radius};`}
				/>
				<code class="rs-util">{step.util}</code>
				<span class="rs-label">{step.label}</span>
			</div>
		))
	}
</div>

<style>
	.rs-strip {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: center;
		gap: 28px;
		margin: 0;
	}

	.rs-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		margin: 0;
	}

	/* The neutral surface under test. A light card pinned independent of the
	   site theme so the rendered corner is the focus, matching the sibling
	   figures in this chapter. Square so the corner shape reads plainly. */
	.rs-card {
		width: 84px;
		height: 84px;
		box-sizing: border-box;
		border: 1px solid #cbd5e1; /* slate 300 — a visible hairline */
		background: #ffffff;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
		color-scheme: light;
		margin: 0;
	}

	/* Wider-than-tall so `rounded-full` resolves to a pill, not a circle. */
	.rs-card-wide {
		width: 132px;
		height: 56px;
	}

	.rs-util {
		margin: 12px 0 0;
		padding: 2px 8px;
		border-radius: 6px;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.8rem;
		font-weight: 600;
		white-space: nowrap;
		color: var(--sl-color-white, #334155);
		background: var(--sl-color-gray-6, #f1f5f9);
		border: 1px solid var(--sl-color-gray-5, #e2e8f0);
	}

	.rs-label {
		margin: 6px 0 0;
		font-size: 0.8rem;
		color: var(--sl-color-gray-3, #64748b);
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	@media (max-width: 460px) {
		.rs-strip {
			gap: 18px;
		}
		.rs-card {
			width: 64px;
			height: 64px;
		}
		.rs-card-wide {
			width: 104px;
			height: 44px;
		}
	}
</style>
