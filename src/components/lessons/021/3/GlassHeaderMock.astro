---
// The glass-morphism header: `bg-background/70 backdrop-blur` over scrolling
// content (Ch021 L3).
//
// A small, self-contained mock of the canonical sticky-header reach. A
// fixed-height frame (a mini "viewport") wraps a vertically SCROLLABLE strip of
// colourful content. Pinned at the top of that frame is a `position: sticky`
// bar styled exactly like the recipe the lesson teaches:
//
//   bg-background/70  → a 70%-opaque surface (semi-transparent, so what's behind
//                       shows through).
//   backdrop-blur     → `backdrop-filter: blur(...)`, which frosts ONLY the
//                       content painted BEHIND the bar — not the bar's own text.
//   + a hairline bottom border to seat the bar on the content.
//
// As the student scrolls the inner strip, each colourful band passes UNDER the
// bar and is visibly blurred-but-present, while the bar's own label stays
// perfectly crisp — the "behind, not inside" distinction made visual. The bands
// are saturated and high-contrast on purpose: backdrop-filter does nothing
// without contrast behind it to blur, so vivid bands make the frost unmistakable
// (and the first band sits under the bar from the very first frame, so the effect
// reads before any scroll).
//
// Everything is REAL CSS (position: sticky + backdrop-filter) so a reader can
// open devtools and confirm the blur lives on the bar's backdrop, not its
// content. The frame is pinned `color-scheme: light` with hard-coded tints to
// match this chapter's sibling figures; `margin: 0` everywhere defeats
// Starlight's injected prose margins.

// The scrolling content: a stack of vivid bands + a couple of plain text rows,
// tall enough to scroll well past the bar. Saturated mid-tones read on the light
// frame and make the frost obvious as they slide under the glass.
const bands = [
	{ label: 'Dashboard', bg: 'linear-gradient(135deg, #6366f1, #8b5cf6)' },
	{ label: 'Revenue', bg: 'linear-gradient(135deg, #0ea5e9, #06b6d4)' },
	{ label: 'Active users', bg: 'linear-gradient(135deg, #10b981, #14b8a6)' },
	{ label: 'Notifications', bg: 'linear-gradient(135deg, #f59e0b, #f97316)' },
	{ label: 'Reports', bg: 'linear-gradient(135deg, #ec4899, #f43f5e)' },
	{ label: 'Settings', bg: 'linear-gradient(135deg, #8b5cf6, #6366f1)' },
];
---

<div class="ghm not-content">
	<div class="ghm-frame">
		{/* The sticky frosted bar — bg-background/70 + backdrop-blur. Its own text
		    stays crisp; content scrolling behind it goes soft. */}
		<div class="ghm-bar">
			<span class="ghm-dot" aria-hidden="true"></span>
			<span class="ghm-brand">Acme</span>
			<span class="ghm-util">bg-background/70 backdrop-blur</span>
		</div>

		{/* The scrollable content strip — what passes UNDER the glass. */}
		<div class="ghm-scroll">
			{
				bands.map((band) => (
					<div class="ghm-band" style={`background:${band.bg}`}>
						{band.label}
					</div>
				))
			}
			<div class="ghm-end">scroll ↑ — watch the bands blur under the bar</div>
		</div>
	</div>
</div>

<style>
	.ghm {
		display: flex;
		justify-content: center;
		margin: 0;
	}

	/* The mini viewport. A fixed height makes the inner strip scroll; the bar is
	   pinned to the top of THIS box. Pinned light + hard tints to match the
	   chapter's sibling figures. overflow: hidden clips content to the rounded
	   frame (the bar's own shadow/border stay inside). */
	.ghm-frame {
		position: relative;
		width: 100%;
		max-width: 420px;
		height: 340px;
		border-radius: 14px;
		border: 1px solid #d8dee7; /* slate 200/300 hairline */
		background: #f1f5f9; /* slate 100 — the page behind the glass */
		overflow: hidden;
		color-scheme: light;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
		margin: 0;
	}

	/* The frosted header. Sticky to the top of the scroll box; 70%-opaque white so
	   the bands behind show through, and backdrop-filter frosts THEM (not this
	   bar's text). A hairline bottom border seats it on the content. */
	.ghm-bar {
		position: sticky;
		top: 0;
		z-index: 2;
		display: flex;
		align-items: center;
		gap: 9px;
		height: 52px;
		padding: 0 16px;
		/* bg-background/70 — a translucent surface. */
		background: rgba(255, 255, 255, 0.7);
		/* backdrop-blur — frost what shows through from behind. */
		backdrop-filter: blur(8px) saturate(1.4);
		-webkit-backdrop-filter: blur(8px) saturate(1.4);
		border-bottom: 1px solid rgba(15, 23, 42, 0.08);
		margin: 0;
	}

	.ghm-dot {
		width: 16px;
		height: 16px;
		border-radius: 5px;
		background: linear-gradient(135deg, #6366f1, #8b5cf6);
		margin: 0;
		flex: none;
	}

	.ghm-brand {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.95rem;
		font-weight: 700;
		/* Crisp dark text — proof the bar's OWN content is not blurred. */
		color: #0f172a; /* slate 900 */
		margin: 0;
	}

	.ghm-util {
		margin: 0 0 0 auto;
		padding: 3px 8px;
		border-radius: 6px;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 600;
		white-space: nowrap;
		color: #334155; /* slate 700 */
		background: rgba(255, 255, 255, 0.65);
		border: 1px solid rgba(15, 23, 42, 0.08);
	}

	/* The scroll container. Holds the bands; scrolls under the sticky bar. */
	.ghm-scroll {
		position: absolute;
		inset: 0;
		overflow-y: auto;
		/* Pull the first band up UNDER the bar so the frost reads before any
		   scroll: the bar (sticky, 52px) overlaps this top padding. */
		padding: 0;
		margin: 0;
	}

	.ghm-band {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		height: 88px;
		padding: 0 18px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 1rem;
		font-weight: 700;
		color: #ffffff;
		text-shadow: 0 1px 2px rgba(15, 23, 42, 0.25);
		margin: 0;
	}

	.ghm-end {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 64px;
		padding: 16px;
		text-align: center;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.78rem;
		line-height: 1.4;
		color: #64748b; /* slate 500 */
		margin: 0;
	}

	@media (max-width: 460px) {
		.ghm-frame {
			height: 300px;
		}
		.ghm-bar {
			height: 48px;
			padding: 0 12px;
			gap: 7px;
		}
		.ghm-util {
			font-size: 0.62rem;
			padding: 2px 6px;
		}
		.ghm-band {
			height: 78px;
			font-size: 0.92rem;
		}
	}
</style>
