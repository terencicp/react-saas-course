---
// The elevation ladder: every surface TIER maps to one shadow RUNG (Ch021 L3).
//
// A vertical ladder read top-to-bottom — top = highest off the page (a dialog),
// bottom = flush with the page. Each row pairs a surface tier (left) with a
// LIVE swatch carrying that rung's real `box-shadow` (centre) and the utility
// name (right), so the student SEES the steps grow rather than reading a list.
//
// The swatches use REAL multi-layer box-shadows mirroring Tailwind v4's scale —
// a tight contact layer + a soft ambient layer per rung — so a reader can open
// devtools and inspect the exact values, and so the "depth is layered" point is
// visible. The ladder sits on a contrasting light slab (pinned `color-scheme:
// light` with hard-coded slate tints, matching this chapter's sibling figures)
// so the white swatches' shadows stay visible at every rung. `margin: 0`
// everywhere defeats Starlight's injected prose margins.

// Top (highest elevation) → bottom (flush). Mirrors the lesson's read-as-a-
// sentence: dialog floats highest, the page sits on the floor.
const rungs = [
	{
		tier: 'Dialog / modal',
		util: 'shadow-lg',
		// Tailwind v4 shadow-lg: ambient + contact.
		shadow:
			'0 10px 15px -3px rgba(15, 23, 42, 0.12), 0 4px 6px -4px rgba(15, 23, 42, 0.12)',
	},
	{
		tier: 'Tooltip',
		util: 'shadow-md',
		shadow:
			'0 4px 6px -1px rgba(15, 23, 42, 0.12), 0 2px 4px -2px rgba(15, 23, 42, 0.10)',
	},
	{
		tier: 'Dropdown / popover',
		util: 'shadow-md',
		shadow:
			'0 4px 6px -1px rgba(15, 23, 42, 0.12), 0 2px 4px -2px rgba(15, 23, 42, 0.10)',
	},
	{
		tier: 'Hover-lifted card',
		util: 'shadow-md',
		shadow:
			'0 4px 6px -1px rgba(15, 23, 42, 0.12), 0 2px 4px -2px rgba(15, 23, 42, 0.10)',
	},
	{
		tier: 'Resting card',
		util: 'shadow-sm',
		// Tailwind v4 shadow-sm: a faint two-layer lift.
		shadow:
			'0 1px 3px 0 rgba(15, 23, 42, 0.10), 0 1px 2px -1px rgba(15, 23, 42, 0.10)',
	},
	{
		tier: 'Page / base surface',
		util: 'shadow-none',
		shadow: 'none',
	},
];
---

<div class="etl not-content">
	{/* Elevation axis: a labelled spine telling the reader top = higher. */}
	<div class="etl-axis" aria-hidden="true">
		<span class="etl-axis-cap etl-axis-top">higher</span>
		<span class="etl-axis-line"></span>
		<span class="etl-axis-cap etl-axis-bottom">flush</span>
	</div>

	<div class="etl-rungs">
		{
			rungs.map((rung) => (
				<div class="etl-row">
					<span class="etl-tier">{rung.tier}</span>
					<div class="etl-stage">
						<div class="etl-swatch" style={`box-shadow: ${rung.shadow};`} />
					</div>
					<code class="etl-util">{rung.util}</code>
				</div>
			))
		}
	</div>
</div>

<style>
	.etl {
		display: flex;
		align-items: stretch;
		gap: 14px;
		/* Contrasting slab so the white swatches' shadows are visible. Pinned
		   light so the rendered shadow is the focus, like the sibling figures. */
		padding: 22px 24px;
		border-radius: 14px;
		background: #eef1f5; /* slate 100-ish */
		color-scheme: light;
		margin: 0;
	}

	/* Vertical "elevation" axis down the left edge. */
	.etl-axis {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		margin: 0;
	}

	.etl-axis-line {
		flex: 1;
		width: 2px;
		margin: 8px 0;
		border-radius: 1px;
		background: linear-gradient(
			to bottom,
			#94a3b8 0%,
			#cbd5e1 100%
		); /* darker at top = higher */
	}

	.etl-axis-cap {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #64748b;
		margin: 0;
	}

	.etl-rungs {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
	}

	/* tier label | swatch stage | utility — one shared coordinate grid so the
	   three columns align across every row. */
	.etl-row {
		display: grid;
		grid-template-columns: minmax(120px, 1.1fr) minmax(96px, 1fr) minmax(
				108px,
				auto
			);
		align-items: center;
		gap: 16px;
		margin: 0;
	}

	.etl-tier {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.9rem;
		font-weight: 600;
		color: #1e293b; /* slate 800 */
		text-align: end;
		margin: 0;
	}

	.etl-stage {
		display: flex;
		justify-content: center;
		margin: 0;
	}

	/* The surface under test. A neutral light card carrying the rung's real,
	   multi-layer box-shadow — this is the part the reader inspects. */
	.etl-swatch {
		width: 100%;
		max-width: 132px;
		height: 38px;
		box-sizing: border-box;
		border-radius: 8px; /* one shared radius, per the lesson's discipline */
		border: 1px solid #e2e8f0; /* faint hairline so the resting card reads */
		background: #ffffff;
		margin: 0;
	}

	.etl-util {
		justify-self: start;
		padding: 3px 10px;
		border-radius: 6px;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		white-space: nowrap;
		color: #334155;
		background: #ffffff;
		border: 1px solid #d8dee7;
		margin: 0;
	}

	@media (max-width: 560px) {
		.etl {
			padding: 18px 16px;
			gap: 10px;
		}
		.etl-row {
			grid-template-columns: minmax(92px, 1.2fr) minmax(72px, 1fr) auto;
			gap: 10px;
		}
		.etl-tier {
			font-size: 0.8rem;
		}
		.etl-util {
			font-size: 0.74rem;
			padding: 2px 7px;
		}
		.etl-swatch {
			height: 32px;
		}
		.etl-axis-cap {
			font-size: 0.62rem;
		}
	}
</style>
