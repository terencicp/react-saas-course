---
// `box-shadow` vs `drop-shadow` — a shadow that follows the SHAPE (Ch021 L3).
//
// The SAME transparent, non-rectangular shape (a 5-pointed star) rendered twice,
// side by side, differing ONLY in which shadow primitive casts the shadow:
//
//   left  → box-shadow. box-shadow is cast from the element's rectangular
//           bounding box, so the star's transparent corners and notches leak a
//           RECTANGULAR halo around the invisible box — the shadow plainly does
//           not match the shape. Visibly wrong.
//   right → drop-shadow (a CSS filter). A filter works on the element's RENDERED
//           pixels, so the shadow traces the star's actual silhouette — points,
//           notches and all. Visibly right.
//
// The vehicle is an inline SVG star, NOT a clip-path star, on purpose: clip-path
// would clip the box-shadow away too, hiding the rectangular halo and defeating
// the demo. An <svg> keeps a real rectangular border box (so box-shadow casts a
// rectangle) while its filled <path> is the only opaque region (so drop-shadow
// traces the star). The star is the vehicle, not taught content — it's just the
// most transparent-heavy shape, which maximises the rectangle-vs-silhouette gap.
//
// Both shadows share identical offset + blur + colour — ONLY the shape differs,
// so the comparison is fair. Real CSS (box-shadow / filter: drop-shadow) so a
// reader can open devtools and confirm one shadows the box and the other the
// shape. The surface is pinned `color-scheme: light` with hard-coded slate tints
// to match this chapter's sibling figures; `margin: 0` everywhere defeats
// Starlight's injected prose margins.

// A 5-pointed star path on a 0..100 viewBox, sized so its points reach near the
// edges (its bounding box is the full square — that square is exactly what
// box-shadow will shadow, and what drop-shadow will NOT).
const starPath =
	'M50 4 L61.8 38.2 L97.6 38.2 L68.9 59.5 L80.6 93.8 L50 72.5 L19.4 93.8 L31.1 59.5 L2.4 38.2 L38.2 38.2 Z';

const panels = [
	{
		primitive: 'box-shadow',
		klass: 'ssc-box',
		note: 'shadows the rectangular box — wrong for this shape',
	},
	{
		primitive: 'drop-shadow',
		klass: 'ssc-drop',
		note: 'shadows the rendered silhouette — right',
	},
];
---

<div class="ssc not-content">
	{
		panels.map((panel) => (
			<div class="ssc-panel">
				<div class="ssc-stage">
					{/* The dashed box marks the star's rectangular BOUNDING BOX — the
					    region box-shadow follows. It's the same square in both panels;
					    the contrast is whether the shadow matches it or the star. */}
					<div class="ssc-bbox" aria-hidden="true" />
					<svg
						class:list={['ssc-star', panel.klass]}
						viewBox="0 0 100 100"
						width="120"
						height="120"
						role="img"
						aria-label={`A star with a ${panel.primitive}`}
					>
						<path d={starPath} />
					</svg>
				</div>
				<code class="ssc-util">{panel.primitive}</code>
				<span class="ssc-note">{panel.note}</span>
			</div>
		))
	}
</div>

<style>
	.ssc {
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 22px;
		margin: 0;
	}

	.ssc-panel {
		display: flex;
		flex-direction: column;
		align-items: center;
		/* Contrasting light slab so the dark shadow reads clearly — and pinned
		   light so the rendered shadow is the focus, like the sibling figures. */
		flex: 1 1 220px;
		max-width: 320px;
		padding: 26px 20px 18px;
		border-radius: 14px;
		background: #eef1f5; /* slate 100-ish */
		color-scheme: light;
		margin: 0;
	}

	.ssc-stage {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		/* Roomy stage so the rectangular halo has space to spill past the star's
		   transparent corners and read as a clear rectangle. */
		width: 168px;
		height: 152px;
		margin: 0;
	}

	/* The star's rectangular bounding box, drawn so the reader can see EXACTLY
	   the rectangle box-shadow follows. Centred on the 120px star inside the
	   168x152 stage. */
	.ssc-bbox {
		position: absolute;
		width: 120px;
		height: 120px;
		border: 1px dashed #b3bdca; /* slate 300/400 — a quiet guide */
		border-radius: 2px;
		margin: 0;
	}

	/* The shape under test. A solid fill so the silhouette reads; the SVG box is
	   transparent, so only the star is opaque. */
	.ssc-star {
		position: relative;
		display: block;
		margin: 0;
	}

	.ssc-star path {
		fill: #6366f1; /* indigo 500 — pops on the light slab */
	}

	/* --- box-shadow: cast from the rectangular border box --- */
	/* No spread, gentle offset + blur, so the RECTANGLE is visible all around the
	   star (especially the straight bottom edge and the empty corners). */
	.ssc-box {
		box-shadow: 0 8px 14px 2px rgba(15, 23, 42, 0.32);
		border-radius: 2px; /* the box's own corners — proof it's the box, not the star */
	}

	/* --- drop-shadow: a filter, cast from the rendered pixels --- */
	/* Identical offset/blur/colour to the box-shadow above — only the SHAPE of
	   the result differs, which is the entire point. */
	.ssc-drop {
		filter: drop-shadow(0 8px 14px rgba(15, 23, 42, 0.45));
	}

	.ssc-util {
		margin: 16px 0 0;
		padding: 3px 10px;
		border-radius: 6px;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 600;
		white-space: nowrap;
		color: #334155;
		background: #ffffff;
		border: 1px solid #d8dee7;
	}

	.ssc-note {
		margin: 8px 0 0;
		max-width: 24ch;
		text-align: center;
		font-size: 0.8rem;
		line-height: 1.35;
		color: #64748b; /* slate 500 */
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	@media (max-width: 460px) {
		.ssc {
			gap: 14px;
		}
		.ssc-panel {
			padding: 20px 14px 14px;
		}
		.ssc-stage {
			width: 140px;
			height: 128px;
		}
		.ssc-star {
			width: 100px;
			height: 100px;
		}
		.ssc-bbox {
			width: 100px;
			height: 100px;
		}
	}
</style>
