---
// "Elevation lab" — the centerpiece interactive of Ch021 L3. A thin wrapper over
// <ParamPlayground> (mirrors L2's OklchTokenLab) that hides the preview markup,
// the card styles, and the readouts so the MDX stays one self-describing tag.
//
// What the student FEELS: one card, three independent layers.
//   - radius  (slider, px)  → the card's `border-radius`, piped straight in.
//   - elevation (select)    → the box-shadow rung. Slide it up the named ladder
//                             (none → 2xl) and the card crosses from flush to
//                             floating. The shadows are REAL multi-layer values
//                             (a tight contact layer + a soft ambient layer)
//                             mirroring Tailwind v4's scale, so "depth is
//                             layered" is devtools-inspectable and the rungs
//                             grow visibly.
//   - border  (toggle)      → a 1px hairline, on/off, so the student feels the
//                             border is a SEPARATE layer from the shadow.
// The className readout is the payoff: every control position is a class string
// the student could paste into real code.
//
// MECHANICS. <Param> pipes each value onto the preview wrapper as a CSS custom
// property. `--radius` carries its `px` suffix and feeds `border-radius` directly
// (a plain value use — no switching needed, and it works). `--elevation`
// (`sm`/`md`/…) and `--border` (`on`/`off`) are discrete STRINGS that must select
// among prebuilt box-shadow / hairline values. CSS style queries are the natural
// tool, but current Chromium fails to recompute an element's style when an
// inherited custom property changes on an already-rendered subtree (style
// queries AND attribute selectors on the affected element both go stale), so the
// card would stick at its first value. So a tiny script reads those two controls
// and writes the chosen box-shadow / hairline as INLINE styles on the card —
// inline writes always apply and dodge the invalidation bug entirely. The shadow
// values are still the real multi-layer ones below, just applied from JS.
//
// All preview colors are LITERAL (pinned light slab + slate tints, matching this
// chapter's sibling figures); they must not follow the reader's site theme. The
// <ParamPlayground> chrome around them flips with the site theme on its own.

import ParamPlayground from '../../../figures/param-playground/ParamPlayground.astro';
import Param from '../../../figures/param-playground/Param.astro';
import Preview from '../../../figures/param-playground/Preview.astro';
import Readout from '../../../figures/param-playground/Readout.astro';

// The class string the student would actually write. `radius` is numeric here
// (the readout env strips the suffix); `border`/`elevation` are the literal
// strings the params emit, so `'shadow-' + elevation` yields `shadow-sm`, etc.
const className =
	"'rounded-[' + radius + 'px] ' + (border === 'on' ? 'border ' : '') + 'shadow-' + elevation";
---

<ParamPlayground caption="One card, three independent layers. Slide the elevation from none up the ladder and watch the card cross from flush to floating; flick the border to feel it's a separate layer; read the exact className off the chip.">
	<Param id="radius" kind="slider" label="Radius" min={0} max={32} step={1} default={8} suffix="px" />
	<Param
		id="elevation"
		kind="select"
		label="Elevation"
		options={['none', 'xs', 'sm', 'md', 'lg', 'xl', '2xl']}
		default="sm"
	/>
	<Param id="border" kind="toggle" label="Border" on="on" off="off" default={true} />

	<Preview>
		<div class="el-stage">
			<article class="el-card" data-el-card>
				<p class="el-title">Monthly revenue</p>
				<p class="el-muted">Updated 3 hours ago</p>
				<p class="el-muted">Across 1,204 accounts</p>
			</article>
		</div>
	</Preview>

	<Readout label="Radius" of="radius" suffix="px" />
	<Readout label="className" expr={className} />
</ParamPlayground>

<style is:global>
	/* The contrasting slab the card rests on — a touch darker than the card so
	   the shadow stays visible at every rung. Pinned light (literal slate tints)
	   so the rendered depth is the focus, like the sibling chapter figures. */
	.param-playground .el-stage {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 40px 24px;
		border-radius: 8px;
		background: #eef1f5; /* slate 100-ish */
		color-scheme: light;
	}

	/* The single surface under test. Radius is piped straight from the slider's
	   `--radius` var (this CSS-var path works fine); the box-shadow and the
	   hairline color are written as inline styles by the script below. The
	   declarations here are the floor the script overrides. */
	.param-playground .el-card {
		width: min(17rem, 100%);
		box-sizing: border-box;
		padding: 16px 18px;
		border-radius: var(--radius, 8px);
		background: #ffffff;
		color: #1e293b; /* slate 800 */
		border: 1px solid transparent; /* reserve the box; the script paints it */
		box-shadow: none;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
		transition: box-shadow 0.16s ease, border-color 0.16s ease;
	}
	.param-playground .el-card > * {
		margin: 0;
	}
	.param-playground .el-title {
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}
	.param-playground .el-muted {
		font-size: 0.78rem;
		color: #64748b; /* slate 500 */
		margin-top: 6px;
	}
</style>

<script>
	// Drive the two switched layers (box-shadow rung + hairline) by writing INLINE
	// styles on the card from the elevation/border controls. Inline writes always
	// apply, sidestepping the Chromium invalidation bug that freezes selector- and
	// style-query-driven recomputation on this subtree. Radius needs none of this
	// — it feeds border-radius directly via its `--radius` var.

	// The elevation ladder: REAL multi-layer box-shadows mirroring Tailwind v4's
	// scale (a tight contact layer + a soft ambient layer), tinted slate with
	// alpha lifted just enough to read on the light slab — open devtools on the
	// card to inspect the layers. One step per rung; `2xl` is modal height.
	const SHADOWS: Record<string, string> = {
		none: 'none',
		xs: '0 1px 2px 0 rgba(15, 23, 42, 0.09)',
		sm: '0 1px 3px 0 rgba(15, 23, 42, 0.1), 0 1px 2px -1px rgba(15, 23, 42, 0.1)',
		md: '0 4px 6px -1px rgba(15, 23, 42, 0.12), 0 2px 4px -2px rgba(15, 23, 42, 0.1)',
		lg: '0 10px 15px -3px rgba(15, 23, 42, 0.12), 0 4px 6px -4px rgba(15, 23, 42, 0.12)',
		xl: '0 20px 25px -5px rgba(15, 23, 42, 0.14), 0 8px 10px -6px rgba(15, 23, 42, 0.12)',
		'2xl': '0 25px 50px -12px rgba(15, 23, 42, 0.3)',
	};
	const HAIRLINE = '#e2e8f0'; // slate 200

	function wireElevationLab(card: HTMLElement) {
		const root = card.closest('[data-pp-root]');
		if (!root) return;
		const elevationInput = root.querySelector<HTMLSelectElement>(
			'[data-pp-param="elevation"] [data-pp-input]',
		);
		const borderInput = root.querySelector<HTMLInputElement>(
			'[data-pp-param="border"] [data-pp-input]',
		);

		const apply = () => {
			const rung = elevationInput?.value ?? 'sm';
			card.style.boxShadow = SHADOWS[rung] ?? 'none';
			const on = borderInput ? borderInput.checked : true;
			card.style.borderColor = on ? HAIRLINE : 'transparent';
		};

		[elevationInput, borderInput].forEach((input) => {
			input?.addEventListener('input', apply);
			input?.addEventListener('change', apply);
		});
		apply(); // seed from the controls' initial values
	}

	document
		.querySelectorAll<HTMLElement>('[data-el-card]')
		.forEach((card) => wireElevationLab(card));
</script>
