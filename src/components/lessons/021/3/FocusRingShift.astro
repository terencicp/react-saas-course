---
// Why focus rings are OUTLINES, not BORDERS (Ch021 L3).
//
// One row of three identical buttons with the MIDDLE one permanently styled as
// if focused. The two `mode`s render the SAME row, differing only in how that
// focused state is drawn:
//
//   mode="border"  → a 2px BORDER on the middle button. A border occupies layout
//                    space, so the button grows 2px on every side: it gets taller
//                    (its top pokes ABOVE the shared dashed guide line) and wider,
//                    shoving its neighbours outward. The row stops being even.
//   mode="outline" → a 2px OUTLINE + offset on the middle button. An outline is
//                    painted on top of the layout and takes NO space, so all three
//                    buttons keep identical geometry: every top sits ON the guide
//                    line and the row stays perfectly even.
//
// The dashed guide line is identical in both tabs — it's the shared anchor that
// makes flipping between the tabs SNAP the neighbours in and out of alignment.
//
// Staged teaching demo, not production shape: :focus-visible can't be triggered
// statically, so the focused state is faked with a fixed style on the middle
// button (a sanctioned divergence, per the lesson outline). Everything is REAL
// CSS (border / outline / outline-offset) so a reader can open devtools and see
// that border changes the box size while outline does not. The surface is pinned
// `color-scheme: light` with hard-coded slate tints to match this chapter's
// sibling figures. `margin: 0` everywhere defeats Starlight's prose margins.

interface Props {
	mode: 'border' | 'outline';
}

const { mode } = Astro.props;

const buttons = ['Cancel', 'Save', 'Delete'];
const focusedIndex = 1; // the middle button wears the simulated focus state
---

<div class:list={['frs', `frs-${mode}`, 'not-content']}>
	{/* Shared dashed guide marking where every button TOP should align. */}
	<div class="frs-guide" aria-hidden="true"></div>

	<div class="frs-row">
		{
			buttons.map((label, i) => (
				<button
					type="button"
					tabindex="-1"
					class:list={['frs-btn', { 'frs-btn-focused': i === focusedIndex }]}
				>
					{label}
				</button>
			))
		}
	</div>
</div>

<style>
	.frs {
		position: relative;
		/* Contrasting slab so the white buttons and their alignment read clearly.
		   Pinned light so the rendered geometry is the focus, like the sibling
		   figures in this chapter. */
		padding: 40px 24px 34px;
		border-radius: 14px;
		background: #eef1f5; /* slate 100-ish */
		color-scheme: light;
		margin: 0;
		overflow: hidden;
	}

	/* The shared reference line: where the top edge of the UNFOCUSED buttons
	   sits. The row has a fixed height and centres its items, so the unfocused
	   buttons' top edge lands at the SAME slab-y in both modes — making this a
	   stable shared anchor. In border mode the grown focused button pokes ABOVE
	   it; in outline mode every top sits on it. Tuned to the rendered geometry. */
	.frs-guide {
		position: absolute;
		left: 16px;
		right: 16px;
		top: 45px;
		height: 0;
		border-top: 1px dashed #94a3b8; /* slate 400 */
		margin: 0;
	}

	.frs-row {
		display: flex;
		align-items: center; /* a grown button breaks symmetrically above & below */
		justify-content: center;
		/* Fixed height so the row's height — and thus each button's vertical
		   centre — is identical across both modes; only the focused button's own
		   size changes. This keeps the guide line a true shared anchor. */
		height: 56px;
		gap: 14px;
		margin: 0;
	}

	/* The button under test. Identical base geometry in both modes. */
	.frs-btn {
		box-sizing: border-box;
		/* A transparent 2px border in the BASE state would reserve the space and
		   defeat the demo; we deliberately DON'T, mirroring the naive "border only
		   on focus" code. The unfocused buttons therefore carry no border box. */
		padding: 10px 18px;
		border: 0;
		border-radius: 8px; /* one shared radius, per the lesson's discipline */
		background: #ffffff;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-size: 0.9rem;
		font-weight: 600;
		color: #1e293b; /* slate 800 */
		cursor: default;
		margin: 0;
	}

	/* --- mode: border — the focused button grows and shifts its neighbours --- */
	.frs-border .frs-btn-focused {
		/* A real 2px border. box-sizing: border-box keeps padding stable, but the
		   border still adds to the element's rendered size on every side: the
		   button becomes 4px taller and 4px wider, so its top rises above the
		   guide line and it pushes the neighbours apart. */
		border: 2px solid #2563eb; /* blue 600 — the simulated focus colour */
	}

	/* --- mode: outline — the focused button keeps its size --- */
	.frs-outline .frs-btn-focused {
		/* An outline is painted on top of the layout, outside the box, taking no
		   space. With an offset it reads as a clean ring — and nothing else moves:
		   every button top still sits on the guide line, the row stays even. */
		outline: 2px solid #2563eb; /* blue 600 */
		outline-offset: 2px;
	}

	@media (max-width: 460px) {
		.frs {
			padding: 36px 14px 30px;
		}
		.frs-guide {
			left: 10px;
			right: 10px;
			top: 36px;
		}
		.frs-row {
			gap: 10px;
		}
		.frs-btn {
			padding: 9px 13px;
			font-size: 0.84rem;
		}
	}
</style>
