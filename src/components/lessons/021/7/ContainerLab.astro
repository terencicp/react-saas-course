---
// The container-query lab — the headline interactive of Chapter 021 L7.
//
// A single slider drives a REAL container's width via the `--w` custom property.
// Inside sits a mock <ProductCard> whose layout is governed by genuine
// container-query CSS authored in the scoped <style> below — NOT Tailwind
// utilities. This is deliberate: the lesson teaches the CSS primitive
// (`container-type: inline-size`, `@container (width >= …)`, `clamp()` + `cqi`)
// first, then names the Tailwind utility that compiles to it. Do not "correct"
// these to utilities.
//
// What the student feels in one loop:
//   • Drag the box wider and the card flips from a vertical stack (image on top)
//     to a horizontal row (image left, text right) at exactly 28rem / 448px —
//     the same threshold Tailwind's `@md` fires at.
//   • The title font scales fluidly the whole way via `clamp(1rem, 6cqi, 1.5rem)`,
//     seeding the cqi section that comes later.
//
// Layout note: a purpose-built shell (slider on top, full-width preview below)
// is used instead of <ParamPlayground> on purpose. ParamPlayground's fixed
// 280px controls column starves its preview on common laptop content widths, so
// the box could never grow to the 448px threshold and the headline flip would
// never fire. Here the preview spans the full content width and scrolls
// horizontally if the box outgrows the frame, so the flip is always reachable
// and the readout never lies about the rendered width.
//
// Course-chrome illustration: theme-aware `--sl-color-*` vars for chrome, a
// hardcoded blue thumbnail + button so the signal reads in both themes.
// `margin: 0` defeats Starlight's injected prose margins.

const MIN = 200;
const MAX = 640;
const DEFAULT = 280;
---

<figure class="cl not-content" data-cl-root>
	{/* Control: a single slider driving the container width. */}
	<div class="cl-control">
		<div class="cl-control-head">
			<label class="cl-label" for="cl-width">Container width</label>
			<span class="cl-value" data-cl-value aria-live="polite">{DEFAULT}px</span>
		</div>
		<input
			class="cl-slider"
			id="cl-width"
			type="range"
			min={MIN}
			max={MAX}
			value={DEFAULT}
			step={1}
			data-cl-input
			aria-label="Container width in pixels"
		/>
	</div>

	{/* The preview frame. Scrolls horizontally if the container outgrows it, so
	    the box always renders at its true `--w` width. */}
	<div class="cl-stage">
		{/*
		  The OUTER box is the container: its width is driven by the slider and it
		  opts in to being measured with `container-type: inline-size`. The inner
		  `.cl-layout` is a descendant that QUERIES that width — never its own.
		*/}
		<div class="cl-card" data-cl-card style={`width: ${DEFAULT}px;`}>
			<div class="cl-panel">
				<div class="cl-layout">
					<div class="cl-thumb" aria-hidden="true">
						<span class="cl-thumb-label">image</span>
					</div>
					<div class="cl-body">
						<h3 class="cl-title">Wireless Headphones</h3>
						<p class="cl-price">$129</p>
						<button class="cl-button" type="button" tabindex="-1">Add to cart</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	{/* Readouts: width, the layout verdict, and the (clamped) title size. */}
	<div class="cl-readouts">
		<span class="cl-chip">
			<span class="cl-chip-label">Container width</span>
			<span class="cl-chip-value" data-cl-readout="width">{DEFAULT}px</span>
		</span>
		<span class="cl-chip">
			<span class="cl-chip-label">Layout</span>
			<span class="cl-chip-value" data-cl-readout="layout">vertical</span>
		</span>
		<span class="cl-chip">
			<span class="cl-chip-label">Title size</span>
			<span class="cl-chip-value" data-cl-readout="title">17px</span>
		</span>
	</div>

	<figcaption class="cl-caption">
		Drag the container — not the window. The card flips layout at its own <code>@md</code>
		width (448px) and the title scales with <code>cqi</code>.
	</figcaption>
</figure>

<style>
	.cl {
		margin: 1.5rem 0;
		padding: 16px 18px 14px;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 12px;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	/* ---- control ---- */
	.cl-control {
		display: flex;
		flex-direction: column;
		gap: 7px;
		margin: 0;
	}
	.cl-control-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
		margin: 0;
	}
	.cl-label {
		font: 600 12px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		margin: 0;
	}
	.cl-value {
		font: 600 11.5px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-gray-3);
		letter-spacing: 0.02em;
		margin: 0;
	}
	.cl-slider {
		appearance: none;
		-webkit-appearance: none;
		width: 100%;
		height: 16px;
		background: transparent;
		outline: none;
		margin: 0;
		cursor: pointer;
		display: block;
	}
	.cl-slider::-webkit-slider-runnable-track {
		height: 4px;
		border-radius: 2px;
		background: color-mix(in srgb, var(--sl-color-text) 20%, transparent);
	}
	.cl-slider::-moz-range-track {
		height: 4px;
		border-radius: 2px;
		background: color-mix(in srgb, var(--sl-color-text) 20%, transparent);
	}
	.cl-slider::-webkit-slider-thumb {
		appearance: none;
		-webkit-appearance: none;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: hsl(217, 91%, 60%);
		border: 2px solid var(--sl-color-bg-sidebar);
		margin-top: -6px;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
	}
	.cl-slider::-moz-range-thumb {
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: hsl(217, 91%, 60%);
		border: 2px solid var(--sl-color-bg-sidebar);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
	}
	.cl-slider:focus-visible::-webkit-slider-thumb {
		outline: 2px solid hsl(217, 91%, 60%);
		outline-offset: 2px;
	}

	/* ---- stage: full-width preview, scrolls if the box outgrows it ---- */
	.cl-stage {
		padding: 16px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-6));
		border-radius: 8px;
		overflow-x: auto;
		margin: 0;
	}

	/* ---- the container: a bare ancestor that only carries the queryable width.
	   Keeping the padding/border on the inner .cl-panel (not here) means the
	   container's content box equals the slider width exactly, so the `@md` query
	   fires at precisely 448px — the number on the slider. ---- */
	.cl-card {
		/* The opt-in. Tailwind's `@container` compiles to exactly this line. */
		container-type: inline-size;
		margin: 0;
	}

	/* ---- the visible card surface, inside the container ---- */
	.cl-panel {
		box-sizing: border-box;
		width: 100%;
		padding: 12px;
		border: 1px solid var(--sl-color-gray-4, #94a3b8);
		border-radius: 10px;
		background: var(--sl-color-bg, #fff);
		margin: 0;
	}

	/* ---- the queried layout: stacked by default ---- */
	.cl-layout {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 0;
	}

	.cl-thumb {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 96px;
		flex: none;
		border-radius: 8px;
		background: linear-gradient(135deg, #3b82f6, #2563eb);
		margin: 0;
	}
	.cl-thumb-label {
		font: 600 11px ui-sans-serif, system-ui, sans-serif;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.85);
		margin: 0;
	}

	.cl-body {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 6px;
		min-width: 0;
		margin: 0;
	}

	.cl-title {
		/* Fluid type: 6% of the CONTAINER's width, clamped between 16px and 24px.
		   This is the one rule the title-size readout echoes. */
		font-size: clamp(1rem, 6cqi, 1.5rem);
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}
	.cl-price {
		font: 600 0.875rem ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.cl-button {
		margin: 2px 0 0;
		padding: 6px 12px;
		font: 600 0.8125rem ui-sans-serif, system-ui, sans-serif;
		color: #fff;
		background: #2563eb;
		border: none;
		border-radius: 6px;
		cursor: default;
	}

	/* ---- the container query: flip to a row once the BOX (not the screen)
	   passes 28rem / 448px — Tailwind's `@md` breakpoint. ---- */
	@container (width >= 28rem) {
		.cl-layout {
			flex-direction: row;
			align-items: flex-start;
		}
		.cl-thumb {
			width: 10rem;
			height: 100px;
		}
		.cl-body {
			flex: 1;
		}
	}

	/* ---- readouts ---- */
	.cl-readouts {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 0;
	}
	.cl-chip {
		display: inline-flex;
		gap: 8px;
		align-items: baseline;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-6));
		border-radius: 999px;
		padding: 4px 12px;
		margin: 0;
	}
	.cl-chip-label {
		font: 600 11px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0;
	}
	.cl-chip-value {
		font: 600 12px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-text);
		margin: 0;
	}

	/* ---- caption ---- */
	.cl-caption {
		margin: 0;
		font-size: 0.8125rem;
		line-height: 1.45;
		color: var(--sl-color-gray-3, #64748b);
	}
	.cl-caption code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.92em;
		padding: 0.1em 0.35em;
		border-radius: 4px;
		background: var(--sl-color-gray-6, #f1f5f9);
		color: var(--sl-color-text, #334155);
	}
</style>

<script>
	// One slider → one container width. The flip and the fluid title are pure CSS
	// (the `@container` rule and `clamp(1rem, 6cqi, 1.5rem)` in the scoped style);
	// this script only pipes the slider value to the box width and updates the
	// echo chips. The title readout mirrors the clamped `6cqi` value so the unit
	// is tangible before it is named in the prose.
	document.querySelectorAll<HTMLElement>('[data-cl-root]').forEach((root) => {
		const slider = root.querySelector<HTMLInputElement>('[data-cl-input]');
		const card = root.querySelector<HTMLElement>('[data-cl-card]');
		const valueChip = root.querySelector<HTMLElement>('[data-cl-value]');
		const widthOut = root.querySelector<HTMLElement>('[data-cl-readout="width"]');
		const layoutOut = root.querySelector<HTMLElement>('[data-cl-readout="layout"]');
		const titleOut = root.querySelector<HTMLElement>('[data-cl-readout="title"]');
		if (!slider || !card) return;

		const update = () => {
			const w = Number(slider.value);
			card.style.width = `${w}px`;
			if (valueChip) valueChip.textContent = `${w}px`;
			if (widthOut) widthOut.textContent = `${w}px`;
			if (layoutOut) layoutOut.textContent = w >= 448 ? 'horizontal (@md)' : 'vertical';
			if (titleOut) {
				const clamped = Math.round(Math.min(24, Math.max(16, w * 0.06)));
				titleOut.textContent = `${clamped}px`;
			}
		};

		slider.addEventListener('input', update);
		slider.addEventListener('change', update);
		update();
	});
</script>
