---
// The container breakpoint scale drawn as a ruler, sibling to L6's
// BreakpointRuler (Chapter 021 L7). The single payoff: a container's
// breakpoints are SMALLER than the viewport's, so a container's "@md" fires
// far to the LEFT of a screen's "md".
//
// Both scales are plotted as ticks on ONE shared pixel axis (0 → axisMax), so
// the horizontal offset between them is literal and faithful — positions are
// real percentages (px / axisMax), exactly like the viewport ruler, so the
// strip is devtools-inspectable and the spacing isn't hand-tuned.
//
// FOREGROUND (solid, the lesson's subject) = the CONTAINER scale, on the lower
// baseline. BACKGROUND (muted, ghosted) = the VIEWPORT scale, on the upper
// reference line. Two anchor ticks are emphasized — container @md (448) and
// viewport md (768) — and a dashed connector spans the gap between them so the
// "448 vs 768" contrast is the thing the eye lands on.
//
// Conceptual course-chrome illustration, not project code: theme-aware
// `--sl-color-*` vars for the chrome, one saturated mid-tone (blue 600) for the
// container ticks to match @md's colour in the L6 ruler, muted grey for the
// viewport reference. `margin: 0` everywhere defeats Starlight's injected prose
// margins.

// A little headroom past the largest mark (viewport 2xl = 1536) so the right
// end reads as "…and wider" rather than ending hard at the last tick.
const axisMax = 1640;

const pct = (px: number) => (px / axisMax) * 100;

// The container scale, @3xs → @7xl. `tier` staggers labels across rows so the
// tight left-hand cluster (@3xs/@2xs/@xs) never collides; `key` marks the @md
// anchor tick for emphasis.
const containerSteps = [
	{ name: '@3xs', rem: '16rem', px: 256, tier: 0 },
	{ name: '@2xs', rem: '18rem', px: 288, tier: 1 },
	{ name: '@xs', rem: '20rem', px: 320, tier: 2 },
	{ name: '@sm', rem: '24rem', px: 384, tier: 0 },
	{ name: '@md', rem: '28rem', px: 448, tier: 1, key: true },
	{ name: '@lg', rem: '32rem', px: 512, tier: 2 },
	{ name: '@xl', rem: '36rem', px: 576, tier: 0 },
	{ name: '@2xl', rem: '42rem', px: 672, tier: 1 },
	{ name: '@3xl', rem: '48rem', px: 768, tier: 2 },
	{ name: '@4xl', rem: '56rem', px: 896, tier: 0 },
	{ name: '@5xl', rem: '64rem', px: 1024, tier: 1 },
	{ name: '@6xl', rem: '72rem', px: 1152, tier: 2 },
	{ name: '@7xl', rem: '80rem', px: 1280, tier: 0 },
];

// The viewport scale (the muted reference row). `key` marks viewport md, the
// other half of the anchor contrast.
const viewportSteps = [
	{ name: 'sm', px: 640 },
	{ name: 'md', px: 768, key: true },
	{ name: 'lg', px: 1024 },
	{ name: 'xl', px: 1280 },
	{ name: '2xl', px: 1536 },
];

const containerMd = containerSteps.find((s) => s.key)!;
const viewportMd = viewportSteps.find((s) => s.key)!;
---

<div class="csr not-content">
	{/* ---- Viewport scale: the muted, ghosted reference, above the axis ---- */}
	<div class="csr-vp">
		<div class="csr-vp-tag">viewport scale (reference)</div>
		<div class="csr-vp-track">
			<div class="csr-vp-line" aria-hidden="true"></div>
			{
				viewportSteps.map((s) => (
					<div
						class:list={['csr-vp-tick', { 'csr-vp-tick-key': s.key }]}
						style={`left: ${pct(s.px)}%;`}
						title={`viewport ${s.name}: — ${s.px}px`}
					>
						<div class="csr-vp-mark" aria-hidden="true" />
						<div class="csr-vp-meta">
							<code class="csr-vp-name">{s.name}:</code>
							<span class="csr-vp-px">{s.px}</span>
						</div>
					</div>
				))
			}
		</div>
	</div>

	{/* ---- The dashed connector spanning @md (448) → viewport md (768) ---- */}
	<div class="csr-gap" aria-hidden="true">
		<div
			class="csr-gap-bar"
			style={`left: ${pct(containerMd.px)}%; right: ${100 - pct(viewportMd.px)}%;`}
		>
			<span class="csr-gap-label">same name, different yardstick</span>
		</div>
	</div>

	{/* ---- Container scale: the solid foreground, the lesson's subject ---- */}
	<div class="csr-ct">
		<div class="csr-ct-line" aria-hidden="true"></div>
		{
			containerSteps.map((s) => (
				<div
					class:list={[
						'csr-ct-tick',
						`csr-tier-${s.tier}`,
						{ 'csr-ct-tick-key': s.key },
					]}
					style={`left: ${pct(s.px)}%;`}
					title={`container ${s.name}: — ${s.rem} / ${s.px}px`}
				>
					<div class="csr-ct-mark" aria-hidden="true" />
					<div class="csr-ct-meta">
						<code class="csr-ct-name">{s.name}</code>
						<span class="csr-ct-px">{s.px}</span>
					</div>
				</div>
			))
		}
		<div class="csr-ct-tag">container scale</div>
	</div>
</div>

<style>
	.csr {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		padding: 10px 14px 6px;
		margin: 0;
	}

	/* ---------- viewport reference (muted, above) ---------- */
	.csr-vp {
		margin: 0;
	}

	.csr-vp-tag {
		font-size: 0.66rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 0 0 4px;
	}

	.csr-vp-track {
		position: relative;
		height: 34px;
		margin: 0;
	}

	.csr-vp-line {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 2px;
		/* dashed + faint: clearly the "ghost" reference, not the subject */
		background-image: linear-gradient(
			to right,
			var(--sl-color-gray-5, #cbd5e1) 0 6px,
			transparent 6px 12px
		);
		background-size: 12px 2px;
		opacity: 0.9;
		margin: 0;
	}

	/* viewport ticks hang DOWN from their (lower) line, labels above the mark */
	.csr-vp-tick {
		position: absolute;
		bottom: 0;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		margin: 0;
		opacity: 0.7;
	}

	.csr-vp-meta {
		display: flex;
		align-items: baseline;
		gap: 3px;
		margin: 0 0 2px;
		white-space: nowrap;
	}

	.csr-vp-name {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.7rem;
		font-weight: 600;
		line-height: 1;
		background: transparent;
		padding: 0;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	.csr-vp-px {
		font-size: 0.62rem;
		line-height: 1;
		color: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	.csr-vp-mark {
		width: 2px;
		height: 9px;
		background: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	/* the viewport md anchor: lifted out of the ghost so the contrast pair pops */
	.csr-vp-tick-key {
		opacity: 1;
	}
	.csr-vp-tick-key .csr-vp-name,
	.csr-vp-tick-key .csr-vp-px {
		color: var(--sl-color-gray-2, #475569);
		font-weight: 700;
	}
	.csr-vp-tick-key .csr-vp-mark {
		height: 13px;
		background: var(--sl-color-gray-2, #475569);
	}

	/* ---------- the gap connector ---------- */
	.csr-gap {
		position: relative;
		height: 22px;
		margin: 0;
	}

	.csr-gap-bar {
		position: absolute;
		top: 10px;
		height: 0;
		border-top: 2px dashed var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* end caps so the span reads as a measured distance, not a stray line */
	.csr-gap-bar::before,
	.csr-gap-bar::after {
		content: '';
		position: absolute;
		top: -5px;
		width: 2px;
		height: 10px;
		background: var(--sl-color-gray-3, #64748b);
	}
	.csr-gap-bar::before {
		left: 0;
	}
	.csr-gap-bar::after {
		right: 0;
	}

	.csr-gap-label {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		padding: 1px 6px;
		font-size: 0.62rem;
		font-weight: 600;
		white-space: nowrap;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-bg, #fff);
		border-radius: 999px;
		margin: 0;
	}

	/* ---------- container scale (solid foreground, below) ---------- */
	.csr-ct {
		position: relative;
		/* room below the line for three staggered tiers of tick labels */
		height: 92px;
		margin: 0;
	}

	.csr-ct-line {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		height: 3px;
		background: var(--sl-color-gray-4, #94a3b8);
		border-radius: 2px;
		margin: 0;
	}

	.csr-ct-tag {
		position: absolute;
		right: 0;
		top: -18px;
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #2563eb; /* blue 600 — matches the container ink */
		margin: 0;
	}

	/* container ticks rise FROM the (upper) line downward; label sits below */
	.csr-ct-tick {
		position: absolute;
		top: 0;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		margin: 0;
	}

	.csr-ct-mark {
		width: 2px;
		height: 10px;
		background: #2563eb; /* blue 600 */
		margin: 0;
	}

	/* three tiers drop the label progressively, so the dense left cluster
	   (@3xs / @2xs / @xs, only 32px apart on the real axis) never overlaps */
	.csr-tier-0 .csr-ct-mark {
		height: 10px;
	}
	.csr-tier-1 .csr-ct-mark {
		height: 30px;
	}
	.csr-tier-2 .csr-ct-mark {
		height: 50px;
	}

	.csr-ct-meta {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1px;
		margin: 3px 0 0;
		white-space: nowrap;
	}

	.csr-ct-name {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.74rem;
		font-weight: 700;
		line-height: 1.1;
		background: transparent;
		padding: 0;
		color: #2563eb; /* blue 600 */
		margin: 0;
	}

	.csr-ct-px {
		font-size: 0.62rem;
		line-height: 1.1;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* the @md anchor: a filled pill so the eye lands on the contrast pair */
	.csr-ct-tick-key .csr-ct-mark {
		width: 3px;
		background: #2563eb;
	}
	.csr-ct-tick-key .csr-ct-name {
		color: #fff;
		background: #2563eb;
		border-radius: 4px;
		padding: 1px 5px;
	}
	.csr-ct-tick-key .csr-ct-px {
		color: #2563eb;
		font-weight: 700;
	}

	/* ---------- narrow figure cards ---------- */
	@media (max-width: 640px) {
		.csr {
			padding: 8px 8px 4px;
		}
		.csr-ct-name {
			font-size: 0.64rem;
		}
		.csr-vp-name {
			font-size: 0.62rem;
		}
		/* the px sub-labels make the dense cluster unreadable when cramped;
		   the prose table carries exact values and each tick keeps its title */
		.csr-ct-px,
		.csr-vp-px {
			display: none;
		}
		.csr-ct {
			height: 74px;
		}
		.csr-tier-1 .csr-ct-mark {
			height: 24px;
		}
		.csr-tier-2 .csr-ct-mark {
			height: 42px;
		}
		.csr-gap-label {
			font-size: 0.58rem;
		}
	}
</style>
