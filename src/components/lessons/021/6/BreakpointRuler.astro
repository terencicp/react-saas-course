---
// The Tailwind breakpoint scale drawn as a ruler, so the mobile-first direction
// is graspable at a glance (Chapter 021 L6).
//
// The axis is viewport width, left → right. The BASE track owns the whole line
// from zero, because an unprefixed utility applies at every width. Each named
// breakpoint switches on at its mark and lays a coloured band that runs to the
// RIGHT edge — and the bands are stacked in rows so they read like sediment:
// every rule layers on top of the ones before it, exactly the cascade the prose
// describes. The arrow underneath is the authoring direction: start at the left
// edge (smallest screen) and ADD as the viewport grows.
//
// Conceptual course-chrome illustration, not project code, so it uses
// theme-aware `--sl-color-*` variables for the ruler and saturated band fills
// (white text) that read in both light and dark themes. Positions are real
// percentages of the axis (px / axisMax), so the spacing is faithful to the
// scale and devtools-inspectable. `margin: 0` everywhere defeats Starlight's
// injected prose margins.

// A touch of headroom past 2xl so its band has a visible width and the axis
// reads as "…and wider" rather than ending hard at the last mark.
const axisMax = 1664;

// Bottom (base, whole width) → up. Each breakpoint adds a band from its mark
// rightward; rows stack so later breakpoints sit higher, like layered rules.
const breakpoints = [
	{ prefix: 'sm', rem: '40rem', px: 640, color: '#0d9488' }, // teal 600
	{ prefix: 'md', rem: '48rem', px: 768, color: '#2563eb' }, // blue 600
	{ prefix: 'lg', rem: '64rem', px: 1024, color: '#7c3aed' }, // violet 600
	{ prefix: 'xl', rem: '80rem', px: 1280, color: '#db2777' }, // pink 600
	{ prefix: '2xl', rem: '96rem', px: 1536, color: '#ea580c' }, // orange 600
];

const pct = (px: number) => (px / axisMax) * 100;
---

<div class="bpr not-content">
	{/* Stacked bands, top (2xl) → down to the base. Each starts at its mark and
	    runs to the right edge; rows make the layering legible. */}
	<div class="bpr-stack">
		{
			[...breakpoints].reverse().map((bp) => (
				<div class="bpr-row">
					<div
						class="bpr-band"
						style={`left: ${pct(bp.px)}%; background: ${bp.color};`}
					>
						<span class="bpr-band-label">{bp.prefix}:</span>
					</div>
				</div>
			))
		}

		{/* The base owns the whole line from zero. */}
		<div class="bpr-row">
			<div class="bpr-base">
				<span class="bpr-band-label bpr-base-label">base · no prefix</span>
			</div>
		</div>
	</div>

	{/* The ruler line with a tick at every breakpoint mark. Each tick carries the
	    prefix and both values below it, staggered across two tiers. */}
	<div class="bpr-axis">
		<div class="bpr-line" aria-hidden="true"></div>
		{
			breakpoints.map((bp, i) => (
				<div
					class:list={['bpr-tick', { 'bpr-tick-low': i % 2 === 1 }]}
					style={`left: ${pct(bp.px)}%;`}
					title={`${bp.prefix}: — ${bp.rem} / ${bp.px}px`}
				>
					{/* sm and md sit close together on the real scale, so labels
					    alternate between two tiers — adjacent ones never share a row. */}
					<div class="bpr-tick-mark" aria-hidden="true" />
					<div class="bpr-tick-meta">
						<code class="bpr-prefix" style={`color: ${bp.color};`}>
							{bp.prefix}:
						</code>
						<span class="bpr-values">
							{bp.rem} · {bp.px}px
						</span>
					</div>
				</div>
			))
		}
	</div>

	{/* Authoring direction: smallest first, add as the viewport grows. */}
	<div class="bpr-arrow" aria-hidden="true">
		<span class="bpr-arrow-text">you author this direction — add as the viewport grows</span>
		<span class="bpr-arrow-line"></span>
		<span class="bpr-arrow-head">▶</span>
	</div>
</div>

<style>
	.bpr {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		padding: 8px 12px 4px;
		margin: 0;
	}

	/* ---- layered bands ---- */
	.bpr-stack {
		display: flex;
		flex-direction: column;
		gap: 4px;
		margin: 0 0 6px;
	}

	.bpr-row {
		position: relative;
		height: 20px;
		margin: 0;
	}

	/* A breakpoint band: pinned to its mark on the left, running to the right
	   edge — "switches on here and stays on rightward". */
	.bpr-band {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		display: flex;
		align-items: center;
		padding-left: 8px;
		border-radius: 4px;
		box-sizing: border-box;
		margin: 0;
	}

	/* The base spans the whole axis from zero. A solid neutral slate (white
	   text), deliberately darker than the coloured bands so it reads as the
	   foundation they layer on top of — and contrasts in both themes. */
	.bpr-base {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		padding-left: 8px;
		border-radius: 4px;
		box-sizing: border-box;
		background: #475569; /* slate 600 — reads in light and dark */
		margin: 0;
	}

	.bpr-band-label {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1;
		color: #ffffff;
		white-space: nowrap;
		margin: 0;
	}

	.bpr-base-label {
		font-weight: 600;
		letter-spacing: 0.01em;
		/* white on the slate base — strong contrast in both themes */
		color: #ffffff;
	}

	/* ---- ruler axis + ticks ---- */
	.bpr-axis {
		position: relative;
		/* room below the line for two staggered tiers of tick labels */
		height: 80px;
		margin: 0;
	}

	.bpr-line {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		height: 2px;
		background: var(--sl-color-gray-4, #cbd5e1);
		border-radius: 1px;
		margin: 0;
	}

	/* Each tick is anchored at its breakpoint percentage; its label column sits
	   below the line, nudged so it centres on the mark without clipping. */
	.bpr-tick {
		position: absolute;
		top: 0;
		transform: translateX(-1px);
		margin: 0;
	}

	.bpr-tick-mark {
		width: 2px;
		height: 9px;
		background: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Low tier: a longer stem drops the label to the second row so it can't
	   collide with its high-tier neighbours (sm vs md, the tight pair). */
	.bpr-tick-low .bpr-tick-mark {
		height: 42px;
	}

	.bpr-tick-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1px;
		margin: 4px 0 0;
		/* centre the label group over the tick mark */
		transform: translateX(-50%);
		padding-left: 1px;
	}

	.bpr-prefix {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.8rem;
		font-weight: 700;
		line-height: 1.1;
		background: transparent;
		padding: 0;
		white-space: nowrap;
		margin: 0;
	}

	.bpr-values {
		font-size: 0.66rem;
		line-height: 1.1;
		color: var(--sl-color-gray-3, #64748b);
		white-space: nowrap;
		margin: 0;
	}

	/* ---- authoring-direction arrow ---- */
	.bpr-arrow {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 2px 0 0;
	}

	.bpr-arrow-text {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
		white-space: nowrap;
		margin: 0;
	}

	.bpr-arrow-line {
		flex: 1;
		height: 2px;
		border-radius: 1px;
		background: linear-gradient(
			to right,
			var(--sl-color-gray-4, #cbd5e1),
			var(--sl-color-gray-2, #475569)
		);
		margin: 0;
	}

	.bpr-arrow-head {
		font-size: 0.7rem;
		line-height: 1;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	/* Narrow figure cards: the rem/px pair is too wide to label every tick
	   inline, so drop it to the prefix only (the lesson's table carries the
	   exact values, and each tick keeps them in its title). Prefixes stay on
	   two tiers, so even the tight sm/md/lg cluster never overlaps. */
	@media (max-width: 640px) {
		.bpr-values {
			display: none;
		}
		.bpr-prefix {
			font-size: 0.74rem;
		}
		.bpr-band-label {
			font-size: 0.64rem;
		}
		.bpr-axis {
			height: 52px;
		}
		.bpr-tick-low .bpr-tick-mark {
			height: 26px;
		}
		.bpr-arrow {
			flex-wrap: wrap;
			row-gap: 4px;
		}
		.bpr-arrow-text {
			white-space: normal;
		}
	}
</style>
