---
// The lesson centrepiece (Chapter 021 L6): a viewport the student physically
// drags, watching a REAL Tailwind-styled layout reflow against the simulated
// width. Columns snap at 640 / 768 / 1024 and the nav flips column → row, so
// "I crossed a breakpoint" becomes "a new min-width rule switched on".
//
// ── Why an <iframe>, and why it must stay one (load-bearing) ──────────────────
// Tailwind's `md:` / `lg:` variants compile to `@media (min-width: …)` queries
// that key off the VIEWPORT, not any container's width. If we rendered the demo
// directly on this page and merely shrank a wrapper div, the page viewport would
// still be ~1280px and every `md:` rule would stay on — the layout would NOT
// reflow. So the demo lives inside an <iframe> whose RENDERED width equals the
// drag value. An iframe is its own browsing context with its own viewport, so
// genuine Tailwind responsive utilities evaluate against the dragged width and
// fire correctly. No JS re-implements breakpoint logic; no classes are swapped
// by hand. The real `md:` classes do the work — which is the whole point.
//
// IMPORTANT: this is explicitly NOT a container query. The iframe has its own
// viewport; the layout inside responds to THAT viewport, not to its slot on the
// page. Lesson 7 pries open exactly this seam (a component responding to its own
// box, not the screen), so the mechanic must remain a true nested viewport —
// do not "simplify" it into a container-query or a class-swap.
//
// The iframe document boots the Tailwind v4 Play CDN (the same build the
// ReactCoding sandboxes use) and carries `width=device-width` so the CDN reads
// the iframe's width as the viewport. The markup uses CDN-resolvable literal
// classes (`bg-white`, `border-slate-200`, …) rather than project semantic
// tokens — the surrounding prose already flags the app-code equivalent — so the
// content renders without a project `globals.css`.
//
// The readout (width px + active breakpoint + the responsible className with the
// live segment lit) is computed in the PARENT from the same width value that
// sizes the iframe, so it can never disagree with what the iframe shows.

// Per-breakpoint accent colours, matched to BreakpointRuler.astro so the two
// figures in this lesson share one visual language.
const breakpoints = [
	{ name: 'base', min: 0, color: '#475569' }, // slate 600
	{ name: 'sm', min: 640, color: '#0d9488' }, // teal 600
	{ name: 'md', min: 768, color: '#2563eb' }, // blue 600
	{ name: 'lg', min: 1024, color: '#7c3aed' }, // violet 600
	{ name: 'xl', min: 1280, color: '#db2777' }, // pink 600
	{ name: '2xl', min: 1536, color: '#ea580c' }, // orange 600
];

const MIN_W = 320;
const MAX_W = 1440;
const START_W = 500; // mid-range, so the first drag immediately crosses 640

// Markup rendered INSIDE the iframe. Literal Tailwind classes only. The two
// artefacts the lesson keeps returning to: the stacked-then-row nav and the
// 1→2→3 card grid, both authored once with genuine responsive variants.
const cards = ['Aurora Lamp', 'Drift Chair', 'Halden Rug', 'Mara Vase'];
const iframeBody = `
<nav class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4 rounded-lg bg-slate-900 px-4 py-3 text-white">
  <span class="font-semibold">Habitat</span>
  <a class="text-slate-300 hover:text-white" href="#">Shop</a>
  <a class="text-slate-300 hover:text-white" href="#">Collections</a>
  <a class="text-slate-300 hover:text-white md:ml-auto" href="#">Account</a>
</nav>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-4">
${cards
	.map(
		(name) => `  <article class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="h-16 rounded-lg bg-slate-100"></div>
    <h3 class="mt-3 font-semibold text-slate-900">${name}</h3>
    <p class="text-sm text-slate-500">In oak and wool.</p>
  </article>`
	)
	.join('\n')}
</div>`;

// The iframe's full document. `width=device-width` is what makes Tailwind read
// the iframe's own width as the viewport — the line the closing thread of the
// lesson calls "the thing that makes mobile-first behave".
const srcdoc = `<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"><\/script>
<style>
  html,body{margin:0;padding:0;overflow:hidden;}
  body{font-family:system-ui,-apple-system,"Segoe UI",sans-serif;padding:16px;background:#f8fafc;}
</style>
</head>
<body>${iframeBody}</body>
</html>`;
---

<div
	class="vps not-content"
	data-min={MIN_W}
	data-max={MAX_W}
	data-start={START_W}
	data-breakpoints={JSON.stringify(breakpoints)}
>
	{/* Readout — current width, active breakpoint, and the live className. */}
	<div class="vps-readout">
		<div class="vps-readout-left">
			<span class="vps-width" data-width-readout>{START_W}px</span>
			<span class="vps-active-wrap">
				active:
				<span class="vps-active" data-active-readout>base</span>
			</span>
		</div>
		<code class="vps-classline" aria-label="The responsive class driving the grid">
			grid-cols-1
			<span class="vps-seg" data-seg="md">md:grid-cols-2</span>
			<span class="vps-seg" data-seg="lg">lg:grid-cols-3</span>
		</code>
	</div>

	{/* The resizable stage. The frame is given its TRUE pixel width (so the
	    iframe is a real viewport at exactly that width and genuine Tailwind
	    breakpoints fire), and when that width is wider than the column the frame
	    is visually scaled down with a CSS transform to fit. The transform is
	    purely cosmetic — it does not change the iframe's measured width — so the
	    layout inside still reflows at the real breakpoints while the handle stays
	    on screen. The stage clips any sub-pixel transform overshoot. */}
	<div class="vps-stage" data-stage>
		<div class="vps-frame" data-frame style={`width:${START_W}px`}>
			<iframe
				class="vps-iframe"
				data-iframe
				srcdoc={srcdoc}
				title="A live viewport you can drag — the layout inside reflows at real Tailwind breakpoints"
				scrolling="no"
				loading="lazy"></iframe>
			<button
				class="vps-handle"
				data-handle
				type="button"
				aria-label="Drag to resize the viewport"
				title="Drag to resize"
			>
				<span class="vps-handle-grip" aria-hidden="true"></span>
			</button>
		</div>
		<span class="vps-scale-note" data-scale-note hidden>shown to scale</span>
	</div>

	{/* Accessible / fallback control — keyboard-operable, mirrors the drag. */}
	<div class="vps-slider-row">
		<span class="vps-slider-label">{MIN_W}px</span>
		<input
			class="vps-slider"
			data-slider
			type="range"
			min={MIN_W}
			max={MAX_W}
			value={START_W}
			step="1"
			aria-label="Viewport width"
		/>
		<span class="vps-slider-label">{MAX_W}px</span>
	</div>
</div>

<style>
	.vps {
		font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		margin: 0;
	}

	/* ── readout strip ─────────────────────────────────────────────────────── */
	.vps-readout {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 8px 16px;
		padding: 8px 12px;
		margin: 0 0 10px;
		border: 1px solid var(--sl-color-gray-5, #e2e8f0);
		border-radius: 8px;
		/* gray-6 inverts between themes (light surface in light mode, dark surface
		   in dark mode); gray-7 does not exist in Starlight's scale, so its
		   fallback would leak a light background into dark mode. */
		background: var(--sl-color-gray-6, #f1f5f9);
	}

	.vps-readout-left {
		display: flex;
		align-items: baseline;
		gap: 14px;
		margin: 0;
	}

	.vps-width {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 1.05rem;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-white, #1e293b);
		font-variant-numeric: tabular-nums;
		min-width: 5.2ch; /* keep the strip from jittering as digits change */
		display: inline-block;
		margin: 0;
	}

	.vps-active-wrap {
		font-size: 0.78rem;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The active-breakpoint pill — background colour is set inline from JS to the
	   matching BreakpointRuler accent, so the two figures agree. */
	.vps-active {
		display: inline-block;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1;
		color: #ffffff;
		background: #475569;
		padding: 3px 8px;
		border-radius: 999px;
		margin-left: 2px;
		transition: background-color 0.12s ease;
	}

	.vps-classline {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.8rem;
		line-height: 1.4;
		color: var(--sl-color-gray-2, #475569);
		background: transparent;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}

	/* A `md:` / `lg:` segment of the class line. Dim by default; lit (its accent
	   colour, bold) when that breakpoint is currently active. */
	.vps-seg {
		opacity: 0.42;
		font-weight: 600;
		border-radius: 4px;
		padding: 1px 3px;
		transition:
			opacity 0.12s ease,
			color 0.12s ease,
			background-color 0.12s ease;
	}
	.vps-seg[data-on='true'] {
		opacity: 1;
		color: #ffffff;
	}

	/* ── resizable stage ───────────────────────────────────────────────────── */
	/* The stage is the visible window; its width follows the column. The frame
	   inside carries the TRUE dialled pixel width and is scaled to fit with a
	   transform when it would overflow (see the script). `height` is set in JS to
	   the frame's scaled height so the scaled-down frame doesn't leave a gap. */
	.vps-stage {
		position: relative;
		width: 100%;
		padding: 14px 0;
		background:
			repeating-linear-gradient(
				-45deg,
				var(--sl-color-gray-6, #eef2f6),
				var(--sl-color-gray-6, #eef2f6) 8px,
				transparent 8px,
				transparent 16px
			);
		border-radius: 10px;
		overflow: hidden;
		box-sizing: border-box;
	}

	.vps-frame {
		position: absolute;
		top: 14px;
		left: 12px;
		transform-origin: top left;
		/* width set inline + by JS to the true dialled width; transform: scale()
		   set by JS to fit the stage. No width transition — drag is 1:1.
		   The edge uses `outline`, not `border`: a border would sit *inside* the
		   frame and shrink the iframe's content box by 2px, so the iframe's real
		   viewport (what Tailwind measures) would fall 2px short of the dialled
		   width and breakpoints would snap a hair late. An outline draws outside
		   the box and costs zero layout width, so the iframe gets the exact
		   dialled width and the snaps land precisely on 640 / 768 / 1024. */
		outline: 1px solid var(--sl-color-gray-4, #cbd5e1);
		border-radius: 8px;
		background: #ffffff;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.12);
	}

	.vps-iframe {
		display: block;
		width: 100%;
		height: 340px;
		border: 0;
		border-radius: 8px 0 0 8px;
		background: #ffffff;
	}

	/* "shown to scale" hint — appears only when the frame is scaled below 1. */
	.vps-scale-note {
		position: absolute;
		right: 10px;
		bottom: 8px;
		z-index: 3;
		font-size: 0.66rem;
		font-weight: 600;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #f1f5f9);
		border: 1px solid var(--sl-color-gray-5, #e2e8f0);
		border-radius: 999px;
		padding: 2px 8px;
		pointer-events: none;
	}
	.vps-scale-note[hidden] {
		display: none;
	}

	/* Drag handle straddling the frame's right edge. */
	.vps-handle {
		position: absolute;
		top: 0;
		right: -11px;
		width: 22px;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: 0;
		background: transparent;
		cursor: ew-resize;
		touch-action: none; /* let JS own the horizontal drag on touch */
		z-index: 2;
	}

	.vps-handle-grip {
		width: 8px;
		height: 46px;
		max-height: 70%;
		border-radius: 5px;
		background: var(--sl-color-accent, #3b82f6);
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.3);
		transition:
			background-color 0.12s ease,
			transform 0.12s ease;
	}
	.vps-handle:hover .vps-handle-grip,
	.vps-handle:focus-visible .vps-handle-grip {
		transform: scaleY(1.12);
		background: var(--sl-color-accent-high, #2563eb);
	}
	.vps-handle:focus-visible {
		outline: 2px solid var(--sl-color-accent, #3b82f6);
		outline-offset: 2px;
		border-radius: 4px;
	}

	/* Whole-component cursor + selection lock while dragging (toggled in JS). */
	.vps[data-dragging='true'] {
		cursor: ew-resize;
		user-select: none;
	}
	.vps[data-dragging='true'] .vps-iframe {
		pointer-events: none; /* don't let the iframe swallow the drag */
	}

	/* ── slider row ────────────────────────────────────────────────────────── */
	.vps-slider-row {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 12px 0 0;
	}

	.vps-slider-label {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.7rem;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
		white-space: nowrap;
	}

	.vps-slider {
		flex: 1;
		accent-color: var(--sl-color-accent, #3b82f6);
		margin: 0;
		cursor: pointer;
	}

	@media (max-width: 600px) {
		.vps-iframe {
			height: 380px;
		}
		.vps-classline {
			font-size: 0.72rem;
		}
		.vps-readout {
			gap: 6px 10px;
		}
	}
</style>

<script>
	type Bp = { name: string; min: number; color: string };

	function initSimulator(root: HTMLElement) {
		const frame = root.querySelector<HTMLElement>('[data-frame]');
		const stage = root.querySelector<HTMLElement>('[data-stage]');
		const handle = root.querySelector<HTMLElement>('[data-handle]');
		const slider = root.querySelector<HTMLInputElement>('[data-slider]');
		const widthOut = root.querySelector<HTMLElement>('[data-width-readout]');
		const activeOut = root.querySelector<HTMLElement>('[data-active-readout]');
		const scaleNote = root.querySelector<HTMLElement>('[data-scale-note]');
		const iframe = root.querySelector<HTMLIFrameElement>('[data-iframe]');
		const segs = Array.from(root.querySelectorAll<HTMLElement>('.vps-seg'));
		if (!frame || !stage || !handle || !slider || !widthOut || !activeOut || !iframe) return;

		const MIN = Number(root.dataset.min) || 320;
		const MAX = Number(root.dataset.max) || 1440;
		const breakpoints: Bp[] = JSON.parse(root.dataset.breakpoints || '[]');
		const PAD = 24; // left+right breathing room inside the stage (12px each)

		const clamp = (n: number) => Math.max(MIN, Math.min(MAX, Math.round(n)));

		// The active breakpoint is the widest whose min-width the current width
		// meets — the same "widest matching min-width wins" rule the cascade uses.
		const activeFor = (w: number): Bp =>
			breakpoints.reduce((acc, bp) => (w >= bp.min ? bp : acc), breakpoints[0]);

		let current = clamp(Number(root.dataset.start) || 500);
		// The visual scale applied to the frame (1 when it fits, <1 when the true
		// width is wider than the column). Drag math reads this back so the handle
		// keeps tracking the pointer even when the frame is shrunk to fit.
		let scale = 1;

		// Fit the frame to the stage with a CSS transform. CRUCIAL: this scales
		// only the *rendered pixels*; the frame's layout width — and therefore the
		// iframe's own `innerWidth` — stays the true dialled value, so Tailwind's
		// media queries still evaluate against the real width. The readout never
		// disagrees with what the layout does.
		function applyScale() {
			const avail = Math.max(MIN, stage!.clientWidth - PAD);
			scale = Math.min(1, avail / current);
			frame!.style.transform = scale < 1 ? `scale(${scale})` : 'none';
			// Reserve the scaled height so the absolutely-positioned frame doesn't
			// leave a gap (or overflow) below it.
			const fh = frame!.offsetHeight;
			stage!.style.height = Math.round(fh * scale + 28) + 'px';
			if (scaleNote) scaleNote.hidden = scale >= 0.999;
		}

		function render(w: number) {
			current = w;
			// Give the frame its TRUE pixel width. The iframe is a genuine nested
			// viewport at exactly this width, so real Tailwind `md:`/`lg:` queries
			// fire against it — no class-swapping, no faking. When the width is
			// wider than the column, applyScale() shrinks the *picture* to fit
			// without changing the width Tailwind sees.
			frame!.style.width = w + 'px';

			widthOut!.textContent = w + 'px';

			const bp = activeFor(w);
			activeOut!.textContent = bp.name;
			activeOut!.style.background = bp.color;

			// Light the class-line segment for the active breakpoint and any
			// narrower ones (md lights at md and lg; lg lights only at lg) — the
			// layering the prose describes, made literal.
			for (const seg of segs) {
				const segMin = seg.dataset.seg === 'lg' ? 1024 : 768;
				const segColor = seg.dataset.seg === 'lg' ? '#7c3aed' : '#2563eb';
				const on = w >= segMin;
				seg.dataset.on = String(on);
				seg.style.background = on ? segColor : 'transparent';
			}

			if (slider!.value !== String(w)) slider!.value = String(w);

			applyScale();
		}

		// ── drag ───────────────────────────────────────────────────────────────
		// The handle sits on the frame's right edge; dragging it grows or shrinks
		// the width. When the frame is scaled to fit (scale < 1), a screen-pixel of
		// pointer travel maps to 1/scale layout-pixels of width, so the handle
		// stays glued under the cursor at any zoom — the devtools "grab the edge
		// and pull" feel the lesson wants the student to register.
		let dragging = false;
		let startX = 0;
		let startW = 0;
		let dragScale = 1;

		function onPointerDown(e: PointerEvent) {
			dragging = true;
			startX = e.clientX;
			startW = current;
			dragScale = scale || 1;
			root.dataset.dragging = 'true';
			handle!.setPointerCapture(e.pointerId);
			e.preventDefault();
		}
		function onPointerMove(e: PointerEvent) {
			if (!dragging) return;
			const dx = e.clientX - startX;
			render(clamp(startW + dx / dragScale));
		}
		function onPointerUp(e: PointerEvent) {
			if (!dragging) return;
			dragging = false;
			delete root.dataset.dragging;
			try {
				handle!.releasePointerCapture(e.pointerId);
			} catch {
				/* capture may already be gone */
			}
		}

		handle.addEventListener('pointerdown', onPointerDown);
		handle.addEventListener('pointermove', onPointerMove);
		handle.addEventListener('pointerup', onPointerUp);
		handle.addEventListener('pointercancel', onPointerUp);

		// Keyboard: arrows nudge, with a bigger step for Page/Shift.
		handle.addEventListener('keydown', (e: KeyboardEvent) => {
			const big = e.shiftKey || e.key === 'PageUp' || e.key === 'PageDown';
			const step = big ? 64 : 16;
			if (e.key === 'ArrowLeft' || e.key === 'PageDown') {
				render(clamp(current - step));
				e.preventDefault();
			} else if (e.key === 'ArrowRight' || e.key === 'PageUp') {
				render(clamp(current + step));
				e.preventDefault();
			}
		});

		// ── slider (accessible / fallback control) ──────────────────────────────
		slider.addEventListener('input', () => render(clamp(Number(slider.value))));

		// Re-fit when the column width changes (window resize, sidebar toggle).
		const ro = new ResizeObserver(() => applyScale());
		ro.observe(stage);

		// The iframe's height settles only after its content paints; re-fit then
		// so the reserved stage height matches the scaled frame exactly.
		iframe.addEventListener('load', () => applyScale());

		render(current);
	}

	function boot() {
		document
			.querySelectorAll<HTMLElement>('.vps')
			.forEach((el) => {
				if (el.dataset.vpsReady) return;
				el.dataset.vpsReady = 'true';
				initSimulator(el);
			});
	}

	boot();
	// Starlight uses view transitions / client-side nav — re-run after swaps.
	document.addEventListener('astro:page-load', boot);
</script>
