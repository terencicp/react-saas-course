---
// The "one viewport, two contexts" problem, made visceral in a single still
// (Chapter 021 L6 — the container-query teaser).
//
// One outer frame stands for the browser viewport, carrying ONE width label at
// the top. Inside it, a two-region page: a wide main feed and a narrow sidebar.
// The SAME <ProductCard> sits in both. In the feed it has room and reads as a
// clean horizontal row. In the sidebar there's no room, so the identical
// horizontal card overflows its slot and gets clipped — a "?" badge marks that
// the card has no idea it should have stacked here.
//
// The punch: both cards live under the one viewport-width label, yet one fits
// and one doesn't — so a `md:` query, which only ever sees that single top
// width, physically can't give them different answers. The information the
// sidebar card needs is its OWN width, not the screen's. That gap is exactly
// what lesson 7 (container queries) fills.
//
// Course-chrome illustration, not project code: theme-aware `--sl-color-*`
// variables for the viewport/region chrome, hard-coded accent colours for the
// signal (a blue card thumbnail; amber for the "this is broken" cues) that read
// in both light and dark themes. Real flexbox throughout (devtools-inspectable):
// the sidebar card genuinely is wider than its slot and is clipped by
// `overflow: hidden`, so the overflow is real, not faked. `margin: 0` everywhere
// defeats Starlight's injected prose margins.
---

<div class="ctxc not-content">
	{/* The viewport frame: one width for everything inside it. */}
	<div class="ctxc-viewport">
		<div class="ctxc-chrome">
			<span class="ctxc-dots" aria-hidden="true">
				<span></span><span></span><span></span>
			</span>
			<span class="ctxc-vw-label">
				viewport: <strong>1280px</strong> — one width for everything inside
			</span>
		</div>

		{/* Two-region page: wide feed + narrow sidebar, under that one width. */}
		<div class="ctxc-page">
			{/* Main feed — the card has room, so the row reads correctly. */}
			<section class="ctxc-region ctxc-feed">
				<span class="ctxc-region-tag">main feed</span>
				<article class="ctxc-card">
					<div class="ctxc-thumb" aria-hidden="true"></div>
					<div class="ctxc-body">
						<div class="ctxc-title"></div>
						<div class="ctxc-line"></div>
						<div class="ctxc-line ctxc-line-short"></div>
					</div>
				</article>
				<span class="ctxc-verdict ctxc-verdict-ok">row — fits</span>
			</section>

			{/* Sidebar — same card, no room. It still tries to be a row, so it
			    overflows the slot and is clipped at the right edge. */}
			<section class="ctxc-region ctxc-sidebar">
				<span class="ctxc-region-tag">sidebar</span>
				<div class="ctxc-clip">
					<article class="ctxc-card ctxc-card-broken">
						<div class="ctxc-thumb" aria-hidden="true"></div>
						<div class="ctxc-body">
							<div class="ctxc-title"></div>
							<div class="ctxc-line"></div>
							<div class="ctxc-line ctxc-line-short"></div>
						</div>
					</article>
					<span class="ctxc-badge" title="This card doesn't know it should stack here" aria-hidden="true">?</span>
				</div>
				<span class="ctxc-verdict ctxc-verdict-bad">row — overflows</span>
			</section>
		</div>
	</div>

	{/* The annotation that names the gap. */}
	<div class="ctxc-note">
		<span class="ctxc-note-arrow" aria-hidden="true">↑</span>
		<span class="ctxc-note-text">
			Same viewport — but no room. The card only knows the <strong>screen's</strong> width, not its <strong>own</strong>.
		</span>
	</div>
</div>

<style>
	.ctxc {
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		max-width: 660px;
		margin: 0 auto;
		padding: 4px 4px 0;
	}

	/* ---- the viewport frame ---- */
	.ctxc-viewport {
		border: 2px solid var(--sl-color-gray-4, #94a3b8);
		border-radius: 10px;
		overflow: hidden;
		background: var(--sl-color-bg, #fff);
		margin: 0;
	}

	.ctxc-chrome {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 7px 12px;
		background: var(--sl-color-gray-6, #1e293b);
		border-bottom: 1px solid var(--sl-color-gray-5, #334155);
		margin: 0;
	}

	.ctxc-dots {
		display: inline-flex;
		gap: 5px;
		flex: none;
		margin: 0;
	}
	.ctxc-dots span {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--sl-color-gray-4, #94a3b8);
		margin: 0;
	}

	.ctxc-vw-label {
		font-size: 0.74rem;
		font-weight: 600;
		color: var(--sl-color-gray-2, #cbd5e1);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		margin: 0;
	}
	.ctxc-vw-label strong {
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-weight: 700;
		color: var(--sl-color-white, #fff);
		margin: 0;
	}

	/* ---- the two-region page ---- */
	.ctxc-page {
		display: flex;
		gap: 12px;
		padding: 14px;
		align-items: stretch;
		background: var(--sl-color-bg-sidebar, #f8fafc);
		margin: 0;
	}

	.ctxc-region {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 20px 10px 10px;
		border: 1px dashed var(--sl-color-gray-4, #94a3b8);
		border-radius: 8px;
		background: var(--sl-color-bg, #fff);
		margin: 0;
	}
	/* Wide feed vs. narrow sidebar — the whole point is the slot widths differ
	   while the viewport above is a single width. */
	.ctxc-feed {
		flex: 0 0 64%;
	}
	.ctxc-sidebar {
		flex: 1 1 0;
		min-width: 0;
	}

	.ctxc-region-tag {
		position: absolute;
		top: -9px;
		left: 10px;
		padding: 1px 7px;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-bg-sidebar, #f8fafc);
		border-radius: 4px;
		margin: 0;
	}

	/* ---- the card (identical markup in both slots) ---- */
	.ctxc-card {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 10px;
		padding: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		border-radius: 8px;
		background: var(--sl-color-bg, #fff);
		box-sizing: border-box;
		margin: 0;
	}

	.ctxc-thumb {
		width: 52px;
		height: 52px;
		flex: none;
		border-radius: 6px;
		background: linear-gradient(135deg, #3b82f6, #2563eb);
		margin: 0;
	}

	.ctxc-body {
		display: flex;
		flex-direction: column;
		gap: 6px;
		min-width: 0;
		flex: 1 1 auto;
		margin: 0;
	}

	.ctxc-title {
		height: 9px;
		width: 78%;
		border-radius: 3px;
		background: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}
	.ctxc-line {
		height: 7px;
		width: 100%;
		border-radius: 3px;
		background: var(--sl-color-gray-5, #cbd5e1);
		margin: 0;
	}
	.ctxc-line-short {
		width: 62%;
	}

	/* The feed card fits; the sidebar card is the same row that no longer fits. */
	.ctxc-clip {
		position: relative;
		overflow: hidden;
		border-radius: 8px;
		margin: 0;
	}

	/* Broken card: forced to a width wider than the narrow sidebar slot, so its
	   right edge runs off and is clipped — a real overflow, not a drawing. The
	   amber outline marks it as the thing going wrong. */
	.ctxc-card-broken {
		width: 240px;
		max-width: none;
		border-color: #d97706;
		box-shadow: 0 0 0 1px #d97706;
	}
	.ctxc-card-broken .ctxc-body {
		flex: none;
		width: 160px;
	}

	.ctxc-badge {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		display: flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		border-radius: 50%;
		background: #d97706;
		color: #fff;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1;
		box-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
		margin: 0;
	}

	/* per-slot verdict pills */
	.ctxc-verdict {
		align-self: flex-start;
		font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
		font-size: 0.66rem;
		font-weight: 700;
		padding: 2px 7px;
		border-radius: 4px;
		margin: 0;
	}
	.ctxc-verdict-ok {
		color: #047857;
		background: rgba(16, 185, 129, 0.16);
	}
	.ctxc-verdict-bad {
		color: #b45309;
		background: rgba(217, 119, 6, 0.18);
	}

	/* ---- the annotation ---- */
	.ctxc-note {
		display: flex;
		align-items: flex-start;
		gap: 7px;
		/* nudge the pointer roughly under the sidebar column on the right */
		margin: 8px 8px 0 auto;
		max-width: 320px;
	}
	.ctxc-note-arrow {
		font-size: 0.95rem;
		font-weight: 800;
		line-height: 1.2;
		color: #d97706;
		margin: 0;
	}
	.ctxc-note-text {
		font-size: 0.74rem;
		line-height: 1.35;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.ctxc-note-text strong {
		color: var(--sl-color-white, #1e293b);
		font-weight: 700;
		margin: 0;
	}

	/* On a narrow figure card the two regions stop reading as feed-vs-sidebar
	   when squeezed; keep the proportions but tighten everything. */
	@media (max-width: 560px) {
		.ctxc-page {
			gap: 8px;
			padding: 12px 10px;
		}
		.ctxc-feed {
			flex-basis: 60%;
		}
		.ctxc-card-broken {
			width: 200px;
		}
		.ctxc-card-broken .ctxc-body {
			width: 130px;
		}
		.ctxc-vw-label {
			font-size: 0.68rem;
		}
		.ctxc-note {
			margin-left: 0;
			max-width: none;
		}
	}
</style>
