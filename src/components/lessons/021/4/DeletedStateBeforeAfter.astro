---
// "Deleted state" before/after — one frame of the DiagramSequence in ch021 L4
// (:has(), the parent selector that retired a generation of JS). Each
// <DeletedStateBeforeAfter step={n} /> is the body of one DiagramStep; the
// surrounding prose + caption narrate, this draws the contrast.
//
// The whole point of the figure is to make "deleted state" VISCERAL: the left
// panel is the 2022 React (a useState, a handler, a cn() conditional class) and
// the right panel is the 2026 one-liner that replaces all of it. The left card
// is deliberately MUTED — faded, dashed, struck-feeling — so it reads as "the
// thing being deleted"; the right card is solid, with the has-[…]: selector
// tinted green as the survivor. A center "replaces" arrow points left -> right.
//
// Deliberate static-illustration (per the lesson outline, mirroring ch021 L3's
// FocusRingShift note): :has() cannot fire in a non-live panel, so the "after"
// side shows the LITERAL className string and the prose/caption explains what
// fires. The "before" side deliberately shows the OLD cn()-conditional pattern
// being RETIRED — it is labelled as the anti-pattern, not a recommended shape.
//
// Pure HTML + CSS, devtools-inspectable, matching the sibling figures in this
// chapter (DesugarPanel, CnPipeline): a `not-content` class plus a `margin: 0`
// reset on every inner element defeat Starlight's prose-margin injection;
// Starlight gray/white CSS variables flip the chrome with light/dark; the
// theme-aware --mark-* palette (custom.css) gives accents that flip too. Code
// lines are rendered as ordered token segments so literal spacing survives and
// individual tokens (the has-[…]: selector, deleted state) can be tinted.

interface Props {
  /** Which case of the sequence to draw, 1-3. */
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const reset = "margin: 0";

const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// A code token. `kw` = language keyword (const/return), `state` = the React
// state machinery being deleted (useState, the handler, the boolean), `str` =
// a string literal, `has` = the surviving has-[…]: selector (green), `plain` =
// everything else. Tones are applied per-side (the whole left card is muted).
type Tok = { t: "kw" | "state" | "str" | "has" | "plain"; v: string };
// A line is a list of tokens plus an indent depth (in 2-space units).
type Line = { indent: number; toks: Tok[] };

type Frame = {
  /** Short title for what this case does. */
  title: string;
  /** The 2022 React being deleted (left, muted). */
  before: Line[];
  /** The 2026 one-liner (right). */
  after: Line[];
  /** How many lines of React the one-liner replaces (for the badge). */
  deleted: number;
};

const k = (v: string): Tok => ({ t: "kw", v });
const s = (v: string): Tok => ({ t: "state", v });
const str = (v: string): Tok => ({ t: "str", v });
const h = (v: string): Tok => ({ t: "has", v });
const p = (v: string): Tok => ({ t: "plain", v });

const frames: Record<1 | 2 | 3, Frame> = {
  1: {
    title: "A form row that turns red when its field is invalid",
    before: [
      { indent: 0, toks: [k("const "), p("["), s("isInvalid"), p(", "), s("setIsInvalid"), p("] = "), s("useState"), p("(false)")] },
      { indent: 0, toks: [] },
      { indent: 0, toks: [k("return "), p("(")] },
      { indent: 1, toks: [p("<div className={"), s("cn"), p("("), str("'border'"), p(",")] },
      { indent: 2, toks: [s("isInvalid"), p(" && "), str("'border-destructive'"), p(")}>")] },
      { indent: 2, toks: [p("<input onBlur={e =>")] },
      { indent: 3, toks: [s("setIsInvalid"), p("(!e.target.validity.valid))} />")] },
      { indent: 1, toks: [p("</div>")] },
      { indent: 0, toks: [p(")")] },
    ],
    after: [
      { indent: 0, toks: [p("<div className="), str('"border '), h("has-[input:invalid]:border-destructive"), str('"'), p(">")] },
      { indent: 1, toks: [p("<input />")] },
      { indent: 0, toks: [p("</div>")] },
    ],
    deleted: 6,
  },
  2: {
    title: "An option card that highlights when its radio is checked",
    before: [
      { indent: 0, toks: [k("const "), p("["), s("checked"), p(", "), s("setChecked"), p("] = "), s("useState"), p("(false)")] },
      { indent: 0, toks: [] },
      { indent: 0, toks: [k("return "), p("(")] },
      { indent: 1, toks: [p("<label className={"), s("cn"), p("("), str("'border'"), p(",")] },
      { indent: 2, toks: [s("checked"), p(" && "), str("'bg-accent'"), p(")}>")] },
      { indent: 2, toks: [p("<input type="), str('"radio"')] },
      { indent: 3, toks: [p("onChange={e => "), s("setChecked"), p("(e.target.checked))} />")] },
      { indent: 1, toks: [p("</label>")] },
      { indent: 0, toks: [p(")")] },
    ],
    after: [
      { indent: 0, toks: [p("<label className="), str('"border '), h("has-[:checked]:bg-accent"), str('"'), p(">")] },
      { indent: 1, toks: [p('<input type='), str('"radio"'), p(" />")] },
      { indent: 0, toks: [p("</label>")] },
    ],
    deleted: 6,
  },
  3: {
    title: "A card that goes flush when it contains an image",
    before: [
      { indent: 0, toks: [p("// often a whole second component, or:")] },
      { indent: 0, toks: [k("function "), p("Card({ "), s("hasImage"), p(", children }) {")] },
      { indent: 1, toks: [k("return "), p("(")] },
      { indent: 2, toks: [p("<div className={"), s("cn"), p("("), str("'p-6'"), p(",")] },
      { indent: 3, toks: [s("hasImage"), p(" && "), str("'p-0'"), p(")}>")] },
      { indent: 3, toks: [p("{children}")] },
      { indent: 2, toks: [p("</div>")] },
      { indent: 1, toks: [p(")")] },
      { indent: 0, toks: [p("}")] },
    ],
    after: [
      { indent: 0, toks: [p("<div className="), str('"p-6 '), h("has-[img]:p-0"), str('"'), p(">")] },
      { indent: 1, toks: [p("{children}")] },
      { indent: 0, toks: [p("</div>")] },
    ],
    deleted: 7,
  },
};

const frame = frames[step];

// ---- layout styles ---------------------------------------------------------

// Outer wrapper: a centered column. A fixed min-height keeps the three frames
// close in height so the DiagramSequence stage (which sizes to the tallest)
// doesn't leave gaps under the shorter ones.
const wrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 10px",
  "min-height: 248px",
  "box-sizing: border-box",
].join("; ");

// The case title above the two panels.
const title = [
  reset,
  sans,
  "font-size: 13px",
  "font-weight: 600",
  "line-height: 1.35",
  "color: var(--sl-color-white)",
  "padding-left: 2px",
].join("; ");

// The two-panel row. A grid with an arrow column between; it collapses to a
// single stacked column on a narrow figure card (handled in <style> below).
const grid = [
  reset,
  "display: grid",
  "grid-template-columns: 1fr auto 1fr",
  "align-items: center",
  "gap: 10px",
  "box-sizing: border-box",
].join("; ");

// One panel (a labelled code card).
const panel = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 5px",
  "min-width: 0",
  "box-sizing: border-box",
].join("; ");

// Header row above each card: an uppercase tag + a small chip.
const head = [
  reset,
  "display: flex",
  "align-items: baseline",
  "gap: 7px",
  "flex-wrap: wrap",
  "padding-left: 2px",
].join("; ");

const tag = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1.2",
].join("; ");

const tagMuted = [tag, "color: var(--sl-color-gray-3)"].join("; ");
const tagSurvivor = [tag, "color: var(--mark-green-brd)"].join("; ");

// A small chip after the header tag — "anti-pattern" on the left, "—N lines"
// on the right.
const chipBase = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "text-transform: uppercase",
  "line-height: 1",
  "padding: 2px 5px",
  "border-radius: 4px",
  "white-space: nowrap",
].join("; ");

const chipMuted = [
  chipBase,
  "color: var(--sl-color-gray-3)",
  "background: var(--sl-color-gray-6, rgba(120,120,120,0.12))",
  "border: 1px solid var(--sl-color-hairline)",
].join("; ");

const chipGreen = [
  chipBase,
  "color: var(--mark-green-brd)",
  "background: var(--mark-green-bg)",
  "border: 1px solid var(--mark-green-brd)",
].join("; ");

// The code cards. The "before" card is faded (lower opacity, dashed border,
// muted text) so it reads as the thing being deleted; the "after" card is
// solid with the dark editor background.
const cardBase = [
  reset,
  mono,
  "font-size: 12.5px",
  "line-height: 1.55",
  "padding: 11px 13px",
  "border-radius: 9px",
  "white-space: pre",
  "overflow-x: auto",
  "box-sizing: border-box",
  "flex: 1",
].join("; ");

const cardBefore = [
  cardBase,
  "background: var(--sl-color-gray-6, rgba(120,120,120,0.06))",
  "border: 1px dashed var(--sl-color-gray-4)",
  "color: var(--sl-color-gray-3)",
  "opacity: 0.75",
].join("; ");

const cardAfter = [
  cardBase,
  "background: var(--sl-color-black)",
  "border: 1px solid var(--sl-color-hairline)",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The center "replaces" connector: an arrow + label, pointing left -> right.
const connector = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 3px",
  "color: var(--sl-color-gray-3)",
  "padding: 0 2px",
].join("; ");

const connectorLabel = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1",
  "white-space: nowrap",
].join("; ");

// ---- token tints -----------------------------------------------------------

// On the BEFORE (muted) side every token is dimmed; the state machinery being
// deleted gets a faint red wash so the eye lands on "this is what goes away".
const beforeTint: Record<Tok["t"], string> = {
  kw: "color: var(--sl-color-gray-3)",
  state: `color: color-mix(in srgb, var(--mark-red-brd) 78%, var(--sl-color-gray-3)); font-weight: 600`,
  str: "color: var(--sl-color-gray-3)",
  has: "color: var(--sl-color-gray-3)",
  plain: "color: var(--sl-color-gray-3)",
};

// On the AFTER side the line reads as live code; the has-[…]: selector is the
// green survivor, tinted like a highlighted token.
const afterHasSpan = [
  "padding: 1px 4px",
  "margin: 0 -1px",
  "border-radius: 5px",
  "background: var(--mark-green-bg)",
  "box-shadow: inset 0 0 0 1px var(--mark-green-brd)",
  "color: var(--sl-color-white)",
  "font-weight: 700",
].join("; ");

const afterTint: Record<Tok["t"], string> = {
  kw: "color: var(--mark-violet-brd)",
  state: "color: var(--sl-color-gray-2)",
  str: "color: color-mix(in srgb, var(--mark-green-brd) 70%, var(--sl-color-gray-2))",
  has: afterHasSpan,
  plain: "color: var(--sl-color-gray-2)",
};

const esc = (v: string) =>
  v.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

const renderLine = (line: Line, side: "before" | "after") => {
  const pad = "  ".repeat(line.indent);
  const tint = side === "before" ? beforeTint : afterTint;
  const body = line.toks
    .map((tok) => `<span style="${tint[tok.t]}">${esc(tok.v)}</span>`)
    .join("");
  // A blank line still needs height.
  return pad + (body || "&#8203;");
};

const renderCode = (lines: Line[], side: "before" | "after") =>
  lines.map((l) => renderLine(l, side)).join("\n");
---

<div class="dsba-root not-content" style={wrap} data-step={step}>
  <div style={title}>{frame.title}</div>

  <div class="dsba-grid" style={grid}>
    {/* LEFT — the 2022 React, muted, being deleted. */}
    <div style={panel}>
      <div style={head}>
        <span style={tagMuted}>2022 — mirrored in state</span>
        <span style={chipMuted}>anti-pattern</span>
      </div>
      <pre
        style={cardBefore}
        set:html={renderCode(frame.before, "before")}
      />
    </div>

    {/* CENTER — the "replaces" arrow, left -> right. */}
    <div class="dsba-arrow" style={connector} aria-hidden="true">
      <svg
        width="30"
        height="14"
        viewBox="0 0 30 14"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="2" y1="7" x2="26" y2="7"></line>
        <polyline points="20 2 27 7 20 12"></polyline>
      </svg>
      <span style={connectorLabel}>replaced by</span>
    </div>

    {/* RIGHT — the 2026 one-liner. */}
    <div style={panel}>
      <div style={head}>
        <span style={tagSurvivor}>2026 — read by :has()</span>
        <span style={chipGreen}>−{frame.deleted} lines</span>
      </div>
      <pre style={cardAfter} set:html={renderCode(frame.after, "after")} />
    </div>
  </div>
</div>

<style>
  /* Collapse the three-column grid (panel | arrow | panel) into a single stack
     on a narrow figure card; rotate the arrow to point downward so the
     left -> right "replaces" reading becomes top -> bottom. */
  @media (max-width: 560px) {
    .dsba-grid {
      grid-template-columns: 1fr !important;
    }
    .dsba-arrow svg {
      transform: rotate(90deg);
    }
  }
</style>
