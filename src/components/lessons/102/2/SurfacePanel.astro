---
// Surface panel — one tab of the "three surfaces" boundary map (inline // why
// vs TSDoc vs ADR). Each panel has the same top-to-bottom structure so flipping
// tabs isolates the variable (who reads it, from where, at what scope):
//
//   1. a header line naming the surface
//   2. a row of three labeled facts — Who reads it / From where / Scope
//   3. two tagged rows — "Belongs here" (green ✓) and "Not here" (red ✕),
//      each with a one-line code example
//
// The `variant="tsdoc"` panel echoes L1's IDE-hover idiom: the example code is
// shown as a faint editor-hover popover (dark mono signature + summary) instead
// of a plain inline-comment line, so the TSDoc surface reads as "the contract a
// caller hovers" for continuity with the previous lesson.
//
// Pure HTML + CSS in the house style: a `not-content` wrapper, style arrays
// joined with "; ", theme variables for chrome, and `margin: 0` resets to defeat
// Starlight's prose-margin selector. Sits inside a built-in <TabbedItem>, which
// already provides the figure-card chrome.

interface Props {
  /** Surface name shown in the header, e.g. "Inline // why". */
  surface: string;
  /** Who reads this surface. */
  who: string;
  /** From where the reader reads it. */
  from: string;
  /** The scope the surface covers. */
  scope: string;
  /** The one-line example that belongs on this surface (code/text). */
  belongs: string;
  /** A short aside on the belongs example, e.g. "a local ordering rule". */
  belongsNote?: string;
  /** A one-line example that does NOT belong here. */
  notHere: string;
  /** Where the not-here example actually belongs, e.g. "that's an ADR". */
  notHereNote?: string;
  /** "tsdoc" renders the belongs example as a faint IDE-hover popover. */
  variant?: "default" | "tsdoc";
}

const {
  surface,
  who,
  from,
  scope,
  belongs,
  belongsNote,
  notHere,
  notHereNote,
  variant = "default",
} = Astro.props;

const GREEN = "#16a34a"; // green-600 — belongs here
const RED = "#dc2626"; // red-600 — not here
const ACCENT = "#0284c7"; // sky-600 — the IDE "hovered" highlight

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// ---- layout -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 11px",
  "width: 100%",
  "box-sizing: border-box",
  sans,
].join("; ");

// 1 — the surface header line.
const header = [
  reset,
  mono,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "font-size: 14px",
  "font-weight: 700",
  "color: var(--sl-color-white)",
  "padding-bottom: 8px",
  "border-bottom: 1px solid var(--sl-color-gray-5)",
].join("; ");

// 2 — the three labeled facts, side by side.
const factsRow = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "gap: 10px",
].join("; ");

const fact = [
  reset,
  "flex: 1 1 150px",
  "min-width: 0",
  "padding: 8px 11px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
  "box-sizing: border-box",
].join("; ");

const factLabel = [
  reset,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "margin-bottom: 4px",
].join("; ");

const factValue = [
  reset,
  "font-size: 13px",
  "line-height: 1.35",
  "color: var(--sl-color-white)",
].join("; ");

// 3 — the belongs / not-here verdict rows.
const verdictRow = [
  reset,
  "display: flex",
  "align-items: flex-start",
  "gap: 10px",
  "padding: 8px 11px",
  "border-radius: 8px",
  "box-sizing: border-box",
].join("; ");

const verdictRowGreen = [
  verdictRow,
  "border: 1px solid " + `color-mix(in srgb, ${GREEN} 45%, transparent)`,
  "background: " + `color-mix(in srgb, ${GREEN} 9%, transparent)`,
].join("; ");

const verdictRowRed = [
  verdictRow,
  "border: 1px solid " + `color-mix(in srgb, ${RED} 45%, transparent)`,
  "background: " + `color-mix(in srgb, ${RED} 8%, transparent)`,
].join("; ");

const badge = [
  reset,
  "flex: 0 0 auto",
  "display: inline-flex",
  "align-items: center",
  "justify-content: center",
  "width: 18px",
  "height: 18px",
  "border-radius: 999px",
  "font-size: 11px",
  "font-weight: 800",
  "line-height: 1",
  "color: #fff",
  "margin-top: 1px",
].join("; ");

const badgeGreen = [badge, "background: " + GREEN].join("; ");
const badgeRed = [badge, "background: " + RED].join("; ");

const verdictBody = [reset, "flex: 1 1 auto", "min-width: 0"].join("; ");

const verdictTag = [
  reset,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "margin-bottom: 5px",
].join("; ");

const verdictTagGreen = [verdictTag, "color: " + GREEN].join("; ");
const verdictTagRed = [verdictTag, "color: " + RED].join("; ");

// The inline-code example rendered for non-tsdoc panels.
const codeChip = [
  reset,
  mono,
  "display: inline-block",
  "font-size: 12.5px",
  "line-height: 1.4",
  "color: var(--sl-color-white)",
  "background: var(--sl-color-gray-6)",
  "border: 1px solid var(--sl-color-gray-5)",
  "border-radius: 5px",
  "padding: 2px 7px",
  "word-break: break-word",
].join("; ");

const verdictNote = [
  reset,
  sans,
  "display: block",
  "margin-top: 5px",
  "font-size: 11.5px",
  "line-height: 1.4",
  "color: var(--sl-color-gray-3)",
].join("; ");

// ---- the tsdoc "IDE hover" popover (belongs example only) ----------------

// A dark tooltip surface, like the IDE's hover card — reused idiom from L1.
const popover = [
  reset,
  "display: inline-block",
  "max-width: 100%",
  "border-radius: 8px",
  "border: 1px solid #3a3f4b",
  "background: #1e2230",
  "box-shadow: 0 8px 20px -12px rgba(0, 0, 0, 0.55)",
  "overflow: hidden",
  "box-sizing: border-box",
].join("; ");

const sigRow = [
  reset,
  mono,
  "padding: 8px 12px 7px",
  "font-size: 12px",
  "line-height: 1.5",
  "color: #c8cddb",
  "white-space: pre-wrap",
  "word-break: break-word",
].join("; ");

const sigKeyword = [reset, "color: #c792ea"].join("; ");
const sigName = [reset, "color: #82aaff", "font-weight: 700"].join("; ");
const sigType = [reset, "color: #ffcb6b"].join("; ");

const summaryRow = [
  reset,
  sans,
  "padding: 9px 12px",
  "border-top: 1px solid #2c313f",
  "font-size: 13px",
  "font-weight: 600",
  "line-height: 1.4",
  "color: #eef1f6",
  "background: " + `color-mix(in srgb, ${GREEN} 14%, #1e2230)`,
].join("; ");

const hoverTag = [
  reset,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "margin-bottom: 8px",
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "color: " + `color-mix(in srgb, ${ACCENT} 78%, var(--sl-color-white))`,
].join("; ");
---

<div class="not-content" style={root}>
  {/* 1 — the surface header */}
  <div style={header}>{surface}</div>

  {/* 2 — three labeled facts */}
  <div style={factsRow}>
    <div style={fact}>
      <div style={factLabel}>Who reads it</div>
      <div style={factValue}>{who}</div>
    </div>
    <div style={fact}>
      <div style={factLabel}>From where</div>
      <div style={factValue}>{from}</div>
    </div>
    <div style={fact}>
      <div style={factLabel}>Scope</div>
      <div style={factValue}>{scope}</div>
    </div>
  </div>

  {/* 3a — belongs here */}
  <div style={verdictRowGreen}>
    <span style={badgeGreen}>&#10003;</span>
    <div style={verdictBody}>
      <div style={verdictTagGreen}>Belongs here</div>
      {
        variant === "tsdoc" ? (
          <div style={popover}>
            <div style={sigRow}>
              <span style={sigKeyword}>function</span>{" "}
              <span style={sigName}>finalizeInvoice</span>(input):{" "}
              <span style={sigType}>Promise&lt;Result&gt;</span>
            </div>
            <div style={summaryRow}>
              <span style={hoverTag}>hover &mdash; the contract</span>
              <span style={reset + "; display: block"}>{belongs}</span>
            </div>
          </div>
        ) : (
          <code style={codeChip}>{belongs}</code>
        )
      }
      {belongsNote && <span style={verdictNote}>{belongsNote}</span>}
    </div>
  </div>

  {/* 3b — not here */}
  <div style={verdictRowRed}>
    <span style={badgeRed}>&#10007;</span>
    <div style={verdictBody}>
      <div style={verdictTagRed}>Not here</div>
      <code style={codeChip}>{notHere}</code>
      {notHereNote && <span style={verdictNote}>{notHereNote}</span>}
    </div>
  </div>
</div>
