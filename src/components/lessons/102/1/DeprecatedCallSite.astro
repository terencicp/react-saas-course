---
// Deprecated call site — a hand-coded mock of what an editor renders when you
// hover a *deprecated* identifier. The pedagogical point is the payoff of
// `@deprecated`: the IDE strikes the name through right at the call site, and
// the hover surfaces the replacement path — so the caller is redirected to
// `createInvoiceDraft` before they ever open the file the dead function lives in.
//
// It deliberately reuses the chrome of the sibling `IdeHoverCard` figure (same
// dark popover surface, call-site row, mono signature, faint divider) so the two
// figures read as the same editor. The one new element is the warning-tinted
// `@deprecated` strip, styled to stand out the way an IDE flags a deprecation.
//
// Top to bottom:
//   1. call-site line — `const id = await createInvoice(orgId, input);`, with the
//      function name struck through (line-through) the way an IDE marks a
//      deprecated identifier.
//   2. the popover — bold mono signature, then a prominent warning strip with the
//      `@deprecated` notice and the replacement path, then the dimmer summary that
//      survives "below the fold".
//
// Pure HTML + CSS in the house style: a `not-content` wrapper, style arrays
// joined with "; ", theme variables for chrome, and a `margin: 0` reset on every
// inner element to defeat Starlight's prose-margin selector.

const ACCENT = "#0284c7"; // sky-600 — the "hovered" highlight
const WARN = "#f59e0b"; // amber-500 — the deprecation warning tint

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// ---- layout -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 14px",
  "width: 100%",
  "max-width: 640px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// The editor "call site" line above the card.
const callSite = [
  reset,
  mono,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: baseline",
  "gap: 0",
  "padding: 9px 14px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
  "font-size: 13.5px",
  "line-height: 1.4",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

const gutter = [
  reset,
  "color: var(--sl-color-gray-4)",
  "user-select: none",
  "padding-right: 14px",
].join("; ");

// The function name, hovered AND struck through — the IDE's deprecation mark.
const deprecatedName = [
  reset,
  "padding: 1px 3px",
  "border-radius: 3px",
  "background: " + `color-mix(in srgb, ${ACCENT} 16%, transparent)`,
  "box-shadow: inset 0 -2px 0 0 " +
    `color-mix(in srgb, ${ACCENT} 60%, transparent)`,
  "color: " + `color-mix(in srgb, ${ACCENT} 82%, var(--sl-color-white))`,
  "font-weight: 600",
  "text-decoration: line-through",
  "text-decoration-thickness: 2px",
  "text-decoration-color: " +
    `color-mix(in srgb, ${ACCENT} 70%, var(--sl-color-gray-2))`,
].join("; ");

const punct = [reset, "color: var(--sl-color-gray-3)"].join("; ");

// A little "cursor is here" caret tail off the hovered name.
const caretNote = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "margin-left: 12px",
  "padding: 2px 8px",
  "border-radius: 999px",
  "border: 1px solid " + `color-mix(in srgb, ${ACCENT} 35%, transparent)`,
  "background: " + `color-mix(in srgb, ${ACCENT} 10%, transparent)`,
  "color: " + `color-mix(in srgb, ${ACCENT} 72%, var(--sl-color-white))`,
  "font-size: 10.5px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "white-space: nowrap",
].join("; ");

// ---- the popover --------------------------------------------------------

// A dark tooltip surface, like the IDE's hover card. Fixed dark chrome reads as
// an editor popover in both light and dark page themes.
const popover = [
  reset,
  "position: relative",
  "align-self: flex-start",
  "max-width: 100%",
  "margin-left: 26px",
  "padding: 0",
  "border-radius: 10px",
  "border: 1px solid #3a3f4b",
  "background: #1e2230",
  "box-shadow: 0 10px 28px -12px rgba(0, 0, 0, 0.55)",
  "overflow: hidden",
  "box-sizing: border-box",
].join("; ");

// The bold signature line at the top of the popover, with the name struck
// through here too so the popover echoes the call-site mark.
const sigRow = [
  reset,
  mono,
  "padding: 11px 15px 10px",
  "font-size: 12.5px",
  "line-height: 1.55",
  "color: #c8cddb",
  "white-space: pre-wrap",
  "word-break: break-word",
].join("; ");

const sigKeyword = [reset, "color: #c792ea"].join("; "); // function
const sigName = [
  reset,
  "color: #82aaff",
  "font-weight: 700",
  "text-decoration: line-through",
  "text-decoration-thickness: 2px",
  "text-decoration-color: " + `color-mix(in srgb, ${WARN} 75%, transparent)`,
].join("; ");
const sigType = [reset, "color: #ffcb6b"].join("; "); // types

// The prominent deprecation strip — the line the eye is meant to land on.
const warnRow = [
  reset,
  sans,
  "padding: 12px 15px 13px",
  "border-top: 1px solid #2c313f",
  "background: " + `color-mix(in srgb, ${WARN} 18%, #1e2230)`,
  "border-left: 3px solid " + WARN,
].join("; ");

const warnTag = [
  reset,
  mono,
  "display: inline-flex",
  "align-items: center",
  "gap: 6px",
  "margin-bottom: 7px",
  "padding: 2px 9px",
  "border-radius: 999px",
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.03em",
  "line-height: 1.3",
  "border: 1px solid " + `color-mix(in srgb, ${WARN} 60%, transparent)`,
  "background: " + `color-mix(in srgb, ${WARN} 26%, transparent)`,
  "color: #fde68a",
].join("; ");

const warnBody = [
  reset,
  sans,
  "display: block",
  "font-size: 14px",
  "font-weight: 600",
  "line-height: 1.45",
  "color: #fef3c7",
].join("; ");

const warnReplacement = [reset, mono, "font-weight: 700", "color: #fde68a"].join(
  "; ",
);

// The faint divider between the warning and the "below the fold" summary.
const fold = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "padding: 0 15px",
  "margin-top: 2px",
].join("; ");

const foldRule = [
  reset,
  "flex: 1 1 auto",
  "height: 1px",
  "background: #353b49",
].join("; ");

const foldLabel = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.08em",
  "text-transform: uppercase",
  "color: #5b6275",
].join("; ");

// The dimmer summary line that survives below the deprecation notice.
const summaryRow = [
  reset,
  sans,
  "padding: 9px 15px 13px",
  "font-size: 12.5px",
  "line-height: 1.55",
  "color: #6f7689",
].join("; ");
---

<div class="not-content" style={root}>
  {/* 1 — the call site, with the deprecated name struck through */}
  <div style={callSite}>
    <span style={gutter}>42</span><span style={punct}>const id = await </span><span
      style={deprecatedName}>createInvoice</span><span style={punct}
      >(orgId, input);</span
    >
    <span style={caretNote}>cursor here</span>
  </div>

  {/* 2 — the hover popover the IDE renders */}
  <div style={popover}>
    {/* signature line, name struck through */}
    <div style={sigRow}>
      <span style={sigKeyword}>function</span> <span style={sigName}
        >createInvoice</span
      >(input: <span style={sigType}>CreateInvoiceInput</span>): <span
        style={sigType}>Promise&lt;Result&lt;{"{ id: string }"}&gt;&gt;</span
      >
    </div>

    {/* the deprecation strip — the line the eye lands on */}
    <div style={warnRow}>
      <span style={warnTag}>&#9888; @deprecated</span>
      <span style={warnBody}
        >Use <span style={warnReplacement}>createInvoiceDraft</span> instead. Removed
        in the next major.</span
      >
    </div>

    {/* the fold */}
    <div style={fold}>
      <div style={foldRule}></div>
      <span style={foldLabel}>below the fold</span>
      <div style={foldRule}></div>
    </div>

    {/* the summary that still renders, dimmer, beneath the notice */}
    <div style={summaryRow}>
      Creates a draft invoice for the active organization and returns its id.
    </div>
  </div>
</div>
