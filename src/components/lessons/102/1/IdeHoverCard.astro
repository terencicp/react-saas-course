---
// IDE hover card — a hand-coded mock of what an editor renders when you hover a
// call. The pedagogical point is purely spatial: the IDE shows the signature,
// then the *first sentence* prominently, then the tags below a faint divider —
// most readers never scroll past the summary. So the summary line is the most
// valuable real estate, and a weak first sentence wastes it.
//
// This component is reused across both tabs of the `ide-hover-card` figure: the
// chrome is identical and ONLY the summary sentence changes, so flipping tabs
// isolates the variable. `tone` tints the summary so a verb-first line reads as
// confident signal and a preamble line reads as wasted space.
//
// Top to bottom:
//   1. call-site line — `createInvoiceDraft(orgId, input)`, with the name shown
//      "hovered" (subtle underline + highlight).
//   2. the popover — bold mono signature, then the summary (the part that
//      differs), a faint divider, then dimmer @param / @throws "below the fold".
//
// Pure HTML + CSS in the house style: a `not-content` wrapper, style arrays
// joined with "; ", theme variables for chrome, and a `margin: 0` reset on every
// inner element to defeat Starlight's prose-margin selector.

interface Props {
  /** The first-sentence summary the popover renders prominently. */
  summary: string;
  /** `good` tints the summary as confident signal; `weak` reads as filler. */
  tone?: "good" | "weak";
}

const { summary, tone = "good" } = Astro.props;

const ACCENT = "#0284c7"; // sky-600 — the "hovered" highlight
const GOOD = "#16a34a"; // green-600 — a strong first sentence
const WEAK = "#9ca3af"; // gray-400 — a wasted first sentence

const reset = "margin: 0";
const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";
const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// ---- layout -------------------------------------------------------------

const root = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 14px",
  "width: 100%",
  "max-width: 640px",
  "margin-inline: auto",
  "box-sizing: border-box",
  sans,
].join("; ");

// The editor "call site" line above the card.
const callSite = [
  reset,
  mono,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: baseline",
  "gap: 0",
  "padding: 9px 14px",
  "border-radius: 8px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-gray-6)",
  "font-size: 13.5px",
  "line-height: 1.4",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

const gutter = [
  reset,
  "color: var(--sl-color-gray-4)",
  "user-select: none",
  "padding-right: 14px",
].join("; ");

// The function name, shown as if the cursor is hovering it.
const hovered = [
  reset,
  "padding: 1px 3px",
  "border-radius: 3px",
  "background: " + `color-mix(in srgb, ${ACCENT} 16%, transparent)`,
  "box-shadow: inset 0 -2px 0 0 " +
    `color-mix(in srgb, ${ACCENT} 60%, transparent)`,
  "color: " + `color-mix(in srgb, ${ACCENT} 82%, var(--sl-color-white))`,
  "font-weight: 600",
].join("; ");

const punct = [reset, "color: var(--sl-color-gray-3)"].join("; ");

// A little "cursor is here" caret tail off the hovered name.
const caretNote = [
  reset,
  sans,
  "display: inline-flex",
  "align-items: center",
  "gap: 5px",
  "margin-left: 12px",
  "padding: 2px 8px",
  "border-radius: 999px",
  "border: 1px solid " + `color-mix(in srgb, ${ACCENT} 35%, transparent)`,
  "background: " + `color-mix(in srgb, ${ACCENT} 10%, transparent)`,
  "color: " + `color-mix(in srgb, ${ACCENT} 72%, var(--sl-color-white))`,
  "font-size: 10.5px",
  "font-weight: 600",
  "letter-spacing: 0.03em",
  "white-space: nowrap",
].join("; ");

// ---- the popover --------------------------------------------------------

// A dark tooltip surface, like the IDE's hover card. Fixed dark chrome reads as
// an editor popover in both light and dark page themes.
const popover = [
  reset,
  "position: relative",
  "align-self: flex-start",
  "max-width: 100%",
  "margin-left: 26px",
  "padding: 0",
  "border-radius: 10px",
  "border: 1px solid #3a3f4b",
  "background: #1e2230",
  "box-shadow: 0 10px 28px -12px rgba(0, 0, 0, 0.55)",
  "overflow: hidden",
  "box-sizing: border-box",
].join("; ");

// The bold signature line at the top of the popover.
const sigRow = [
  reset,
  mono,
  "padding: 11px 15px 10px",
  "font-size: 12.5px",
  "line-height: 1.55",
  "color: #c8cddb",
  "white-space: pre-wrap",
  "word-break: break-word",
].join("; ");

const sigKeyword = [reset, "color: #c792ea"].join("; "); // function
const sigName = [reset, "color: #82aaff", "font-weight: 700"].join("; ");
const sigType = [reset, "color: #ffcb6b"].join("; "); // types

// The prominent summary sentence — the part that differs between tabs.
const summaryRow = [
  reset,
  sans,
  "padding: 12px 15px",
  "border-top: 1px solid #2c313f",
  "font-size: 14.5px",
  "font-weight: 600",
  "line-height: 1.45",
  "color: " + (tone === "good" ? "#eef1f6" : "#9aa1b0"),
  "background: " +
    (tone === "good"
      ? `color-mix(in srgb, ${GOOD} 14%, #1e2230)`
      : "#1e2230"),
].join("; ");

// A small marker on the summary row that names what this line is.
const summaryTag = [
  reset,
  sans,
  "display: inline-block",
  "margin-bottom: 6px",
  "padding: 2px 8px",
  "border-radius: 999px",
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "border: 1px solid " +
    (tone === "good"
      ? `color-mix(in srgb, ${GOOD} 55%, transparent)`
      : `color-mix(in srgb, ${WEAK} 50%, transparent)`),
  "background: " +
    (tone === "good"
      ? `color-mix(in srgb, ${GOOD} 22%, transparent)`
      : `color-mix(in srgb, ${WEAK} 16%, transparent)`),
  "color: " +
    (tone === "good"
      ? "#a7f3c0"
      : "#c2c7d2"),
].join("; ");

// The faint divider between the summary and the "below the fold" tags.
const fold = [
  reset,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "padding: 0 15px",
  "margin-top: 2px",
].join("; ");

const foldRule = [
  reset,
  "flex: 1 1 auto",
  "height: 1px",
  "background: #353b49",
].join("; ");

const foldLabel = [
  reset,
  sans,
  "font-size: 9.5px",
  "font-weight: 700",
  "letter-spacing: 0.08em",
  "text-transform: uppercase",
  "color: #5b6275",
].join("; ");

// The dimmer tag lines that sit below the fold.
const tagsRow = [
  reset,
  mono,
  "padding: 9px 15px 13px",
  "font-size: 12px",
  "line-height: 1.7",
  "color: #6f7689",
].join("; ");

const tagName = [reset, "color: #8b93a7", "font-weight: 600"].join("; ");
---

<div class="not-content" style={root}>
  {/* 1 — the call site, with the function name "hovered" */}
  <div style={callSite}>
    <span style={gutter}>42</span><span style={punct}>const id = await </span><span
      style={hovered}>createInvoiceDraft</span><span style={punct}
      >(orgId, input);</span
    >
    <span style={caretNote}>cursor here</span>
  </div>

  {/* 2 — the hover popover the IDE renders */}
  <div style={popover}>
    {/* signature line */}
    <div style={sigRow}>
      <span style={sigKeyword}>function</span> <span style={sigName}
        >createInvoiceDraft</span
      >(input: <span style={sigType}>CreateInvoiceInput</span>): <span
        style={sigType}>Promise&lt;Result&lt;{"{ id: string }"}&gt;&gt;</span
      >
    </div>

    {/* the prominent first sentence — the line the eye lands on */}
    <div style={summaryRow}>
      <span style={summaryTag}>first sentence &mdash; what you see</span>
      <span style={reset + "; display: block"}>{summary}</span>
    </div>

    {/* the fold */}
    <div style={fold}>
      <div style={foldRule}></div>
      <span style={foldLabel}>below the fold</span>
      <div style={foldRule}></div>
    </div>

    {/* dimmer tags most readers never scroll to */}
    <div style={tagsRow}>
      <div style={reset}>
        <span style={tagName}>@param</span> input &mdash; the draft fields
      </div>
      <div style={reset}>
        <span style={tagName}>@throws</span> ValidationError
      </div>
    </div>
  </div>
</div>
