---
// SpeedBudgetBars — Chapter 097 Lesson 2 ("The four-job merge gate").
//
// Makes two senior reflexes visible at a glance:
//   1. "Wall-clock is the slowest job, not the sum." Four bars all start at
//      t=0 (they run in parallel), each ending at its own duration. The whole
//      gate finishes when the LONGEST bar (build) finishes — so build alone
//      sets the wall-clock, drawn in the most prominent fill.
//   2. "Under five minutes on a warm cache." A vertical "budget" line at the
//      5-minute mark; all four parallel bars finish to its LEFT (in budget).
//
// A muted contrast bar below — "one fat job = the sum" — stretches end-to-end
// across the four durations and blows past the budget line, re-justifying the
// parallel-over-fat-job decision from earlier in the lesson.
//
// Built as a custom HTML+CSS figure per the diagrams guide (a Gantt-style bar
// grid on a shared time axis). Widths are percentages of AXIS_MAX, so the bars,
// ticks, and budget line share one coordinate system. `not-content` plus margin
// resets keep Starlight's prose margins from leaking into the grid. Wrapped in
// <Figure> with a one-line caption.

import Figure from "../../../figures/Figure.astro";

// The time axis runs 0..AXIS_MAX minutes. Generous enough that the fat-job
// contrast bar (~8.5 min) still fits past the right edge of the budget.
const AXIS_MAX = 9;

// Tick marks (minutes). 5 is the budget; it gets its own treatment below.
const TICKS = [0, 2, 4, 6, 8];

// The five-minute speed budget.
const BUDGET = 5;

// The four parallel jobs. Durations are illustrative warm-cache figures, not
// measurements — build is the longest, so it sets the wall-clock.
const jobs = [
	{ name: "typecheck", min: 1, fill: "#2563eb" },
	{ name: "lint", min: 1.5, fill: "#d97706" },
	{ name: "test", min: 2.5, fill: "#0d9488" },
	{ name: "build", min: 3.5, fill: "#7c3aed", lead: true },
];

// The fat job runs the four commands in sequence, so its length is the sum.
const FAT_MIN = jobs.reduce((sum, j) => sum + j.min, 0);

const pct = (min: number) => `${(min / AXIS_MAX) * 100}%`;
---

<Figure caption="Four jobs in parallel finish with the slowest, not the sum — which is what keeps the gate inside the five-minute budget.">
	<div class="sbb not-content">
		{/* Plot area: a left label gutter + the time track the bars live on. */}
		<div class="sbb-rows">
			{
				jobs.map((j) => (
					<div class="sbb-row">
						<div class="sbb-label">{j.name}</div>
						<div class="sbb-track">
							<div
								class:list={["sbb-bar", { lead: j.lead }]}
								style={`width:${pct(j.min)};--bar-fill:${j.fill};`}
							>
								<span class="sbb-bar-time">{j.min}m</span>
							</div>
						</div>
					</div>
				))
			}

			{/* Contrast: one fat job = the sum of all four, blowing the budget. */}
			<div class="sbb-row sbb-row-fat">
				<div class="sbb-label sbb-label-fat">one fat job</div>
				<div class="sbb-track">
					<div class="sbb-bar fat" style={`width:${pct(FAT_MIN)};`}>
						<span class="sbb-bar-time">= the sum, {FAT_MIN}m</span>
					</div>
				</div>
			</div>

			{/* The budget line spans the whole plot, anchored over the track. */}
			<div class="sbb-budget" style={`--budget-frac:${BUDGET / AXIS_MAX};`}>
				<span class="sbb-budget-flag">5m budget</span>
			</div>
		</div>

		{/* Time axis under the bars, aligned to the same track. */}
		<div class="sbb-axis">
			<div class="sbb-label sbb-axis-pad" aria-hidden="true"></div>
			<div class="sbb-axis-track">
				{
					TICKS.map((t) => (
						<span class="sbb-tick" style={`left:${pct(t)};`}>
							<span class="sbb-tick-mark" />
							<span class="sbb-tick-num">{t}</span>
						</span>
					))
				}
				<span class="sbb-tick sbb-tick-unit" style={`left:${pct(AXIS_MAX)};`}>
					<span class="sbb-tick-num">min</span>
				</span>
			</div>
		</div>
	</div>
</Figure>

<style>
	.sbb {
		margin: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	.sbb-rows {
		margin: 0;
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.sbb-row {
		margin: 0;
		display: grid;
		grid-template-columns: 84px 1fr;
		align-items: center;
		gap: 10px;
	}

	/* Extra breathing room above the fat-job contrast row separates it from the
	   four parallel jobs it's being compared against. */
	.sbb-row-fat {
		margin: 6px 0 0;
		padding: 8px 0 0;
		border-top: 1px dashed
			color-mix(in srgb, var(--sl-color-gray-4) 70%, transparent);
	}

	.sbb-label {
		margin: 0;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.2;
		text-align: right;
		color: var(--sl-color-white, #1e293b);
	}

	.sbb-label-fat {
		font-weight: 700;
		color: var(--sl-color-gray-2, #64748b);
	}

	/* The track is the shared coordinate space: every bar, tick, and the budget
	   line measures its width / position as a percentage of this box. */
	.sbb-track {
		margin: 0;
		position: relative;
		height: 26px;
		border-radius: 5px;
		background: color-mix(in srgb, var(--sl-color-gray-5) 28%, transparent);
		overflow: hidden;
	}

	.sbb-bar {
		margin: 0;
		position: absolute;
		left: 0;
		top: 0;
		height: 100%;
		min-width: 34px;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		padding: 0 8px;
		box-sizing: border-box;
		border-radius: 5px;
		background: var(--bar-fill);
	}

	/* build sets the wall-clock, so it reads loudest: a touch taller-feeling via
	   a brighter ring and a stronger shadow. */
	.sbb-bar.lead {
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--bar-fill) 45%, transparent);
	}

	.sbb-bar-time {
		margin: 0;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 11px;
		font-weight: 700;
		line-height: 1;
		color: #fff;
		white-space: nowrap;
	}

	/* The fat-job bar is muted — it's the foil, not the recommendation. */
	.sbb-bar.fat {
		background: repeating-linear-gradient(
			45deg,
			color-mix(in srgb, var(--sl-color-gray-3) 38%, transparent),
			color-mix(in srgb, var(--sl-color-gray-3) 38%, transparent) 7px,
			color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent) 7px,
			color-mix(in srgb, var(--sl-color-gray-3) 22%, transparent) 14px
		);
		justify-content: flex-end;
		overflow: hidden;
	}

	/* The fat bar's stripes are mid-grey, so the time label gets a chip backdrop
	   to stay legible whichever stripe band it lands on, in both themes. */
	.sbb-bar.fat .sbb-bar-time {
		color: var(--sl-color-white, #1e293b);
		padding: 2px 6px;
		border-radius: 4px;
		background: color-mix(in srgb, var(--sl-color-bg) 78%, transparent);
	}

	/* The budget line spans the rows region. It's offset by the label gutter
	   (84px) + the grid gap (10px) so it lines up with the start of the track. */
	.sbb-budget {
		margin: 0;
		position: absolute;
		top: -2px;
		bottom: -2px;
		left: calc(94px + (100% - 94px) * var(--budget-frac));
		width: 0;
		border-left: 2px dashed #dc2626;
		pointer-events: none;
	}

	.sbb-budget-flag {
		position: absolute;
		top: -2px;
		left: 4px;
		padding: 1px 6px;
		border-radius: 4px;
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0.02em;
		line-height: 1.4;
		white-space: nowrap;
		color: #fff;
		background: #dc2626;
	}

	/* Axis row mirrors the bar rows' grid so its track aligns to the bars'. */
	.sbb-axis {
		margin: 6px 0 0;
		display: grid;
		grid-template-columns: 84px 1fr;
		gap: 10px;
	}

	.sbb-axis-pad {
		margin: 0;
	}

	.sbb-axis-track {
		margin: 0;
		position: relative;
		height: 20px;
	}

	.sbb-tick {
		margin: 0;
		position: absolute;
		top: 0;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
	}

	.sbb-tick-mark {
		width: 1px;
		height: 5px;
		background: var(--sl-color-gray-4, #9ca3af);
	}

	.sbb-tick-num {
		margin: 0;
		font-size: 10.5px;
		font-weight: 600;
		line-height: 1;
		color: var(--sl-color-gray-2, #64748b);
	}

	/* The trailing "min" unit label sits at the axis end; nudge it left so it
	   doesn't overflow the figure edge. */
	.sbb-tick-unit {
		transform: translateX(-100%);
	}

	@media (max-width: 520px) {
		.sbb-row,
		.sbb-axis {
			grid-template-columns: 64px 1fr;
		}

		.sbb-budget {
			left: calc(74px + (100% - 74px) * var(--budget-frac));
		}
	}
</style>
