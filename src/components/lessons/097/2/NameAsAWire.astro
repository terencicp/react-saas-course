---
// NameAsAWire — Chapter 097 Lesson 2 ("The four-job merge gate").
//
// Makes the string-equality seam between ci.yml and the branch-protection
// ruleset literal, and shows how a single rename silently breaks it. Two states
// live in two tabs (cramming both into one panel gets cluttered):
//
//   Tab "Matched"      — every job id has a solid green wire to the required
//                        check of the same name; the gate is whole.
//   Tab "After rename" — the `test` job is renamed to `tests`; its wire to the
//                        ruleset's still-required `test` dangles, red and
//                        unconnected, while the other three stay green.
//
// Each tab is the same shape: a left panel (ci.yml job ids) and a right panel
// (ruleset required strings) with an SVG connector column between them. The
// connector column mirrors the panels' layout — an invisible header spacer over
// a flex:1 SVG — so the SVG fills exactly the rows region. Inside, the four
// rows are `flex:1`, so their centres sit at 12.5 / 37.5 / 62.5 / 87.5% of that
// region; the wires use those same fractions and therefore land on the row
// text. TabbedContent supplies its own card, so this is NOT wrapped in <Figure>.
// `not-content` + margin resets keep Starlight's prose margins out of the grid.

import TabbedContent from "../../../figures/tabbed-content/TabbedContent.astro";
import TabbedItem from "../../../figures/tabbed-content/TabbedItem.astro";

const jobs = ["typecheck", "lint", "test", "build"];
const required = ["typecheck", "lint", "test", "build"];

// Centres of four equal flex rows, as a percentage of the rows region. The SVG
// uses a 0..100 viewBox, so these double as the wire y-coordinates.
const ROW_YS = [12.5, 37.5, 62.5, 87.5];
---

<TabbedContent>
	<TabbedItem
		label="Matched"
		caption="The job name is the only thing wiring the workflow to the ruleset — rename it on one side and the wire breaks silently."
	>
		<div class="naw not-content">
			<div class="naw-panel">
				<div class="naw-cap">
					<div class="naw-title">ci.yml</div>
					<div class="naw-sub">jobs</div>
				</div>
				<ul class="naw-rows">
					{jobs.map((j) => <li class="naw-row">{j}</li>)}
				</ul>
			</div>

			<div class="naw-conn">
				<div class="naw-cap naw-cap-ghost" aria-hidden="true">
					<div class="naw-title">·</div>
					<div class="naw-sub">·</div>
				</div>
				<svg
					class="naw-wires"
					viewBox="0 0 100 100"
					preserveAspectRatio="none"
					aria-hidden="true"
				>
					{
						ROW_YS.map((y) => (
							<line class="naw-wire ok" x1="0" y1={y} x2="100" y2={y} />
						))
					}
				</svg>
			</div>

			<div class="naw-panel">
				<div class="naw-cap">
					<div class="naw-title">ruleset</div>
					<div class="naw-sub">required checks</div>
				</div>
				<ul class="naw-rows">
					{required.map((r) => <li class="naw-row">{r}</li>)}
				</ul>
			</div>
		</div>
	</TabbedItem>

	<TabbedItem
		label="After rename"
		caption="One renamed job, one dead wire — the ruleset still requires test, and now nothing reports it."
	>
		<div class="naw not-content">
			<div class="naw-panel">
				<div class="naw-cap">
					<div class="naw-title">ci.yml</div>
					<div class="naw-sub">jobs</div>
				</div>
				<ul class="naw-rows">
					<li class="naw-row">typecheck</li>
					<li class="naw-row">lint</li>
					<li class="naw-row changed">tests</li>
					<li class="naw-row">build</li>
				</ul>
			</div>

			<div class="naw-conn">
				<div class="naw-cap naw-cap-ghost" aria-hidden="true">
					<div class="naw-title">·</div>
					<div class="naw-sub">·</div>
				</div>
				<svg
					class="naw-wires"
					viewBox="0 0 100 100"
					preserveAspectRatio="none"
					aria-hidden="true"
				>
					{/* typecheck, lint, build still match — solid green */}
					<line class="naw-wire ok" x1="0" y1={ROW_YS[0]} x2="100" y2={ROW_YS[0]} />
					<line class="naw-wire ok" x1="0" y1={ROW_YS[1]} x2="100" y2={ROW_YS[1]} />
					<line class="naw-wire ok" x1="0" y1={ROW_YS[3]} x2="100" y2={ROW_YS[3]} />
					{/* tests has no required check; the wire dangles, never reaching the right */}
					<line
						class="naw-wire broken"
						x1="0"
						y1={ROW_YS[2]}
						x2="60"
						y2={ROW_YS[2]}
					/>
					<circle class="naw-dangle" cx="60" cy={ROW_YS[2]} r="3" />
				</svg>
			</div>

			<div class="naw-panel">
				<div class="naw-cap">
					<div class="naw-title">ruleset</div>
					<div class="naw-sub">required checks</div>
				</div>
				<ul class="naw-rows">
					<li class="naw-row">typecheck</li>
					<li class="naw-row">lint</li>
					<li class="naw-row orphan">test</li>
					<li class="naw-row">build</li>
				</ul>
			</div>
		</div>

		<div class="naw-flag">
			<span class="naw-flag-dot"></span>
			ruleset still requires <code>test</code> — no check reports it
		</div>
	</TabbedItem>
</TabbedContent>

<style>
	.naw {
		margin: 0;
		display: grid;
		grid-template-columns: 1fr minmax(56px, 0.85fr) 1fr;
		align-items: stretch;
		gap: 0;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	.naw-panel {
		box-sizing: border-box;
		margin: 0;
		display: flex;
		flex-direction: column;
		border: 1px solid var(--sl-color-gray-5, #d1d5db);
		border-radius: 10px;
		background: var(--sl-color-bg-sidebar, var(--sl-color-bg, #fff));
		overflow: hidden;
		z-index: 1;
	}

	/* The caption block (title + sub) is shared by both panels and the connector
	   column's ghost spacer, so all three reserve the same vertical space and the
	   rows line up across columns. */
	.naw-cap {
		margin: 0;
		border-bottom: 1px solid var(--sl-color-gray-5, #d1d5db);
	}

	.naw-title {
		margin: 0;
		padding: 8px 12px 2px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 13px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white, #1e293b);
	}

	.naw-sub {
		margin: 0;
		padding: 0 12px 8px;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.07em;
		line-height: 1.2;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9ca3af);
	}

	.naw-rows {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	/* Four equal-height rows; their centres sit at 12.5/37.5/62.5/87.5% of the
	   rows region, matching ROW_YS. */
	.naw-row {
		margin: 0;
		flex: 1;
		display: flex;
		align-items: center;
		padding: 0 12px;
		min-height: 40px;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 13.5px;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		border-top: 1px solid
			color-mix(in srgb, var(--sl-color-gray-5) 55%, transparent);
	}

	.naw-row:first-child {
		border-top: none;
	}

	/* The renamed job — visibly the thing that changed. */
	.naw-row.changed {
		color: #b91c1c;
		background: color-mix(in srgb, #dc2626 10%, transparent);
		font-weight: 800;
	}

	/* The now-orphaned required check on the ruleset side. */
	.naw-row.orphan {
		color: #b91c1c;
		background: color-mix(in srgb, #dc2626 7%, transparent);
	}

	/* The connector column mirrors a panel's layout: a ghost caption spacer over
	   a flex:1 SVG, so the SVG occupies exactly the rows region. */
	.naw-conn {
		margin: 0;
		display: flex;
		flex-direction: column;
	}

	.naw-cap-ghost {
		border-bottom-color: transparent;
		visibility: hidden;
	}

	.naw-wires {
		flex: 1;
		width: calc(100% + 2px);
		margin: 0 -1px;
		overflow: visible;
	}

	.naw-wire {
		fill: none;
		vector-effect: non-scaling-stroke;
		stroke-width: 2;
	}

	.naw-wire.ok {
		stroke: #16a34a;
	}

	.naw-wire.broken {
		stroke: #dc2626;
		stroke-dasharray: 4 3;
	}

	.naw-dangle {
		fill: var(--sl-color-bg, #fff);
		stroke: #dc2626;
		stroke-width: 2;
		vector-effect: non-scaling-stroke;
	}

	/* The red flag under the "After rename" tab, pointing at the dead wire. */
	.naw-flag {
		margin: 12px 0 0;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 11px;
		border-radius: 8px;
		font-size: 12.5px;
		font-weight: 600;
		line-height: 1.4;
		color: #b91c1c;
		background: color-mix(in srgb, #dc2626 9%, transparent);
		border: 1px solid color-mix(in srgb, #dc2626 28%, transparent);
	}

	.naw-flag code {
		margin: 0;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 12px;
		padding: 1px 5px;
		border-radius: 4px;
		background: color-mix(in srgb, #dc2626 14%, transparent);
		color: #b91c1c;
	}

	.naw-flag-dot {
		flex: none;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: #dc2626;
	}

	:global([data-theme="dark"]) .naw-row.changed,
	:global([data-theme="dark"]) .naw-row.orphan,
	:global([data-theme="dark"]) .naw-flag,
	:global([data-theme="dark"]) .naw-flag code {
		color: #fca5a5;
	}

	:global([data-theme="dark"]) .naw-wire.ok {
		stroke: #4ade80;
	}

	:global([data-theme="dark"]) .naw-wire.broken,
	:global([data-theme="dark"]) .naw-dangle {
		stroke: #f87171;
	}

	:global([data-theme="dark"]) .naw-flag-dot {
		background: #f87171;
	}

	:global([data-theme="dark"]) .naw-dangle {
		fill: var(--sl-color-bg, #0b0b0b);
	}
</style>
