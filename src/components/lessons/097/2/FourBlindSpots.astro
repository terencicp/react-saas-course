---
// FourBlindSpots — Chapter 097 Lesson 2 ("The four-job merge gate").
//
// Makes "each of the four checks catches a class of mistake none of the others
// can" visible in one glance, so the set reads as minimal-and-complete rather
// than an arbitrary round number. Four cards in a row — cheapest/most-
// foundational on the left (typecheck) to most-expensive on the right (build).
//
// Each card has three stacked parts:
//   1. A header band — the check name in monospace white text, on a distinct
//      saturated mid-tone fill so each column visually owns its concern in both
//      light and dark themes (the four fills read against white and near-black).
//   2. A one-line "catches:" summary of the column's class of mistake.
//   3. A muted "only this catches:" box holding a tiny representative bug that
//      slips past the other three.
//
// Built as a custom HTML+CSS figure per the diagrams guide (the shape is colour-
// coded segments with callouts). `not-content` plus margin resets keep
// Starlight's prose margins from leaking into the grid. Wrapped in <Figure> by
// the lesson, no caption — the surrounding prose walks the four in detail.

import Figure from "../../../figures/Figure.astro";

const checks = [
	{
		name: "typecheck",
		fill: "#2563eb", // blue — the floor the codebase stands on
		catches: "what the type system can prove wrong",
		example: "a renamed field still read elsewhere",
	},
	{
		name: "lint",
		fill: "#d97706", // amber — correctness band types don't model
		catches: "the correctness band types don't model",
		example: "a forgotten await",
	},
	{
		name: "test",
		fill: "#0d9488", // teal — behavioural regressions
		catches: "behavioural regressions",
		example: "a refund total off by one",
	},
	{
		name: "build",
		fill: "#7c3aed", // purple — whole-graph integration
		catches: "whole-graph integration problems",
		example: "a server-only import in a Client Component",
	},
];
---

<Figure>
	<div class="fbs not-content">
		{
			checks.map((c) => (
				<div class="fbs-card" style={`--fbs-fill:${c.fill};`}>
					<div class="fbs-head">{c.name}</div>
					<div class="fbs-body">
						<div class="fbs-catches">
							<span class="fbs-catches-label">catches</span>
							<span class="fbs-catches-text">{c.catches}</span>
						</div>
						<div class="fbs-example">
							<span class="fbs-example-label">only this catches</span>
							<span class="fbs-example-text">{c.example}</span>
						</div>
					</div>
				</div>
			))
		}
	</div>
</Figure>

<style>
	.fbs {
		margin: 0;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 12px;
		font-family: var(
			--sl-font-system,
			ui-sans-serif,
			system-ui,
			-apple-system,
			sans-serif
		);
	}

	/* One column per check. The header carries the colour; the body holds the
	   summary and the representative bug. */
	.fbs-card {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		margin: 0;
		border: 1px solid var(--sl-color-gray-5, #d1d5db);
		border-top: 3px solid var(--fbs-fill);
		border-radius: 10px;
		background: var(--sl-color-bg, #fff);
		overflow: hidden;
	}

	/* Header band — the check name in monospace white on the saturated fill. */
	.fbs-head {
		margin: 0;
		padding: 9px 12px;
		background: var(--fbs-fill);
		color: #fff;
		font-family: var(--sl-font-mono, ui-monospace, monospace);
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1.2;
	}

	.fbs-body {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
		padding: 11px 12px 12px;
	}

	/* "catches:" — the one-line class of mistake this column owns. */
	.fbs-catches {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 3px;
	}

	.fbs-catches-label {
		margin: 0;
		font-size: 9.5px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--fbs-fill) 72%, var(--sl-color-text));
	}

	.fbs-catches-text {
		margin: 0;
		font-size: 13px;
		font-weight: 600;
		line-height: 1.4;
		color: var(--sl-color-white, #1e293b);
	}

	/* The muted example box — a tiny bug only this column catches. */
	.fbs-example {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 8px 9px;
		border-radius: 7px;
		background: color-mix(in srgb, var(--fbs-fill) 8%, transparent);
		border: 1px solid color-mix(in srgb, var(--fbs-fill) 22%, transparent);
	}

	.fbs-example-label {
		margin: 0;
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #9ca3af);
	}

	.fbs-example-text {
		margin: 0;
		font-size: 12px;
		line-height: 1.4;
		font-weight: 600;
		color: color-mix(in srgb, var(--fbs-fill) 70%, var(--sl-color-text));
		font-family: var(--sl-font-mono, ui-monospace, monospace);
	}

	/* Short viewports / narrow cards: drop to two columns so nothing clips. */
	@media (max-width: 640px) {
		.fbs {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
