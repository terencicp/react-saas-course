---
// gha-hierarchy — the four GitHub Actions nouns in one glance (Lesson 97.1).
//
// Four facts must read at once:
//   1. Fresh runner per job   — each job box carries a "fresh Ubuntu runner" tag.
//   2. Steps run in sequence  — steps stack VERTICALLY, numbered 1-4 top-to-bottom.
//   3. Jobs run in parallel   — the two job boxes sit SIDE BY SIDE horizontally.
//   4. Job name = check name  — a pill on each box reads "→ status check: <id>".
//
// Layout: an outer "workflow file" box (with a ci.yml top tab) containing two
// saturated job boxes laid out with flex; each job stacks four step rows and
// carries a status-check pill on its bottom edge. Saturated mid-tone fills with
// white text so the job boxes read in both themes; `not-content` + margin resets
// defeat Starlight's prose-margin selector. Jobs stack on narrow viewports.

import Figure from "../../../../figures/Figure.astro";

const steps = ["checkout", "setup", "install", "run"];

// Two jobs, side by side, to make "parallel by default" spatial. Distinct
// saturated hues so each job + its status-check pill read as one unit.
const jobs = [
  { id: "typecheck", hue: "var(--ghah-blue)", hueHi: "var(--ghah-blue-hi)" },
  { id: "lint", hue: "var(--ghah-teal)", hueHi: "var(--ghah-teal-hi)" },
];
---

<Figure>
  <div class="ghah not-content">
    {/* ---- The workflow file ---- */}
    <div class="ghah-file">
      <span class="ghah-tab">ci.yml</span>
      <span class="ghah-file-note">workflow</span>

      {/* ---- Two jobs, side by side = parallel ---- */}
      <div class="ghah-jobs">
        {
          jobs.map((job) => (
            <div
              class="ghah-job"
              style={`--ghah-fill: ${job.hue}; --ghah-fill-hi: ${job.hueHi};`}
            >
              <div class="ghah-job-head">
                <span class="ghah-job-id">{job.id}</span>
                <span class="ghah-job-runner">fresh Ubuntu runner</span>
              </div>

              {/* ---- Steps stack vertically = sequential, numbered 1-4 ---- */}
              <ol class="ghah-steps">
                {steps.map((step, i) => (
                  <li class="ghah-step">
                    <span class="ghah-step-num">{i + 1}</span>
                    <span class="ghah-step-label">{step}</span>
                  </li>
                ))}
              </ol>

              {/* ---- The job id becomes the status-check name ---- */}
              <span class="ghah-pill">
                <span class="ghah-pill-arrow" aria-hidden="true">&rarr;</span>
                status check: {job.id}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Figure>

<style>
  .ghah {
    margin: 0;
    display: flex;
    justify-content: center;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --ghah-blue: #2563eb;
    --ghah-blue-hi: #1d4ed8;
    --ghah-teal: #0d9488;
    --ghah-teal-hi: #0f766e;
  }

  /* ---- The workflow file box, with a filename tab ---- */
  .ghah-file {
    margin: 0;
    position: relative;
    width: 100%;
    max-width: 560px;
    padding: 30px 18px 18px;
    border: 1.5px solid var(--sl-color-gray-4);
    border-radius: 12px;
    background: var(--sl-color-bg-sidebar);
    box-sizing: border-box;
  }

  .ghah-tab {
    margin: 0;
    position: absolute;
    top: -13px;
    left: 16px;
    padding: 3px 12px;
    border: 1.5px solid var(--sl-color-gray-4);
    border-radius: 8px;
    background: var(--sl-color-bg-sidebar);
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 13px;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .ghah-file-note {
    margin: 0;
    display: block;
    margin-bottom: 14px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
  }

  /* ---- Two jobs side by side = parallel ---- */
  .ghah-jobs {
    margin: 0;
    display: flex;
    gap: 16px;
  }

  .ghah-job {
    margin: 0;
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding: 12px 12px 14px;
    border-radius: 10px;
    background: var(--ghah-fill);
    box-sizing: border-box;
  }

  .ghah-job-head {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-bottom: 10px;
  }

  .ghah-job-id {
    margin: 0;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.1;
    color: #fff;
  }

  .ghah-job-runner {
    margin: 0;
    font-size: 9.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.78);
  }

  /* ---- Steps stack vertically = sequential ---- */
  .ghah-steps {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ghah-step {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 9px;
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.16);
  }

  .ghah-step-num {
    margin: 0;
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background: var(--ghah-fill-hi);
    font-size: 10px;
    font-weight: 800;
    line-height: 1;
    color: #fff;
  }

  .ghah-step-label {
    margin: 0;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 12.5px;
    font-weight: 600;
    color: #fff;
  }

  /* ---- The status-check pill on the job's edge ---- */
  .ghah-pill {
    margin: 0;
    margin-top: 12px;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 999px;
    background: #fff;
    font-size: 11.5px;
    font-weight: 700;
    color: var(--ghah-fill-hi);
  }

  .ghah-pill-arrow {
    margin: 0;
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
  }

  /* Narrow viewports: jobs stack; that's fine, the read order is preserved. */
  @media (max-width: 460px) {
    .ghah-jobs {
      flex-direction: column;
    }
  }
</style>
