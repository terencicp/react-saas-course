---
// permissions-floor — "floor at the workflow, raise per job" made spatial (Lesson 97.1).
//
// The story in one glance:
//   1. A wide floor band at the top = the workflow-level default, contents: read.
//   2. A row of job tiles sitting below it, every tile inheriting that floor.
//   3. Most tiles add nothing — they stay at the muted read-only floor.
//   4. One tile (comment-bot) is RAISED above the floor: a saturated accent fill,
//      offset upward, and it adds `+ pull-requests: write` on top of the inherited
//      read. The contrast says "this one job is elevated, and only this one."
//
// HTML+CSS because this is a custom containment illustration, not a graph. The
// raised/highlighted tile uses a saturated fill with white text so the elevation
// reads in both themes; `not-content` + margin: 0 on every inner element defeats
// Starlight's prose-margin selector.

import Figure from "../../../../figures/Figure.astro";

// Four CI jobs. Three sit at the read-only floor; comment-bot is raised because
// it needs to write back to the pull request, so it grants up one scope.
const jobs = [
  { id: "typecheck", grant: "contents: read", elevated: false },
  { id: "lint", grant: "contents: read", elevated: false },
  { id: "test", grant: "contents: read", elevated: false },
  {
    id: "comment-bot",
    grant: "contents: read",
    add: "pull-requests: write",
    elevated: true,
  },
];
---

<Figure>
  <div class="pf not-content">
    {/* ---- The workflow-level floor, spanning full width ---- */}
    <div class="pf-floor">
      <span class="pf-floor-label">workflow default</span>
      <code class="pf-floor-grant">permissions: contents: read</code>
    </div>

    {/* ---- Job tiles inheriting the floor; one is raised above it ---- */}
    <div class="pf-jobs">
      {
        jobs.map((job) => (
          <div class={`pf-job${job.elevated ? " pf-job--up" : ""}`}>
            <span class="pf-job-id">{job.id}</span>
            <span class="pf-grant pf-grant--read">{job.grant}</span>
            {job.add && <span class="pf-grant pf-grant--add">+ {job.add}</span>}
          </div>
        ))
      }
    </div>
  </div>
</Figure>

<style>
  .pf {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: 620px;
    margin-inline: auto;
    box-sizing: border-box;
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
    --pf-accent: #7c3aed;
    --pf-accent-hi: #6d28d9;
  }

  /* ---- The wide floor band ---- */
  .pf-floor {
    margin: 0;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 4px 12px;
    padding: 10px 14px;
    border: 1.5px dashed var(--sl-color-gray-4);
    border-radius: 10px;
    background: var(--sl-color-gray-6, var(--sl-color-bg-sidebar));
    box-sizing: border-box;
  }

  .pf-floor-label {
    margin: 0;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
  }

  .pf-floor-grant {
    margin: 0;
    padding: 0;
    background: transparent;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 13.5px;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  /* ---- The row of job tiles ---- */
  .pf-jobs {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: flex-end;
  }

  .pf-job {
    margin: 0;
    flex: 1 1 0;
    min-width: 120px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 11px;
    border: 1.5px solid var(--sl-color-gray-4);
    border-radius: 9px;
    background: var(--sl-color-bg-sidebar);
    box-sizing: border-box;
  }

  /* The one elevated job: raised above the floor, saturated, white text. */
  .pf-job--up {
    transform: translateY(-10px);
    border-color: var(--pf-accent-hi);
    background: var(--pf-accent);
    box-shadow: 0 6px 14px -6px var(--pf-accent);
  }

  .pf-job-id {
    margin: 0;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 14px;
    font-weight: 800;
    line-height: 1.1;
    color: var(--sl-color-white);
  }

  .pf-job--up .pf-job-id {
    color: #fff;
  }

  .pf-grant {
    margin: 0;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 11.5px;
    font-weight: 600;
    line-height: 1.25;
  }

  /* Inherited read-only grant: muted on the floor tiles, dimmed on the raised one. */
  .pf-grant--read {
    color: var(--sl-color-gray-2);
  }

  .pf-job--up .pf-grant--read {
    color: rgba(255, 255, 255, 0.75);
  }

  /* The scope the elevated job adds on top of the inherited read. */
  .pf-grant--add {
    margin-top: 1px;
    padding: 2px 7px;
    align-self: flex-start;
    border-radius: 999px;
    background: #fff;
    font-weight: 800;
    color: var(--pf-accent-hi);
  }

  /* Narrow viewports: tiles wrap; keep the raised one from clipping. */
  @media (max-width: 460px) {
    .pf-job {
      min-width: 45%;
    }
  }
</style>
