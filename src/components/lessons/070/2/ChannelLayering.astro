---
// ChannelLayering — Chapter 070 Lesson 2, "Email and inbox, independent channels".
//
// The load-bearing figure of the lesson: the three-layer call stack a single
// dispatch descends through. Scrubbed inside a <DiagramSequence> at the call site,
// so the SAME stack renders in all four frames and only the emphasized layer moves.
// Its job is to kill the #1 beginner mistake — re-checking suppression, re-resolving
// `from`, or re-rendering content inside a channel — by making the sink sit visibly
// BELOW the channel. "The wrapper already does that" becomes obvious once you see it.
//
// Three layers, top to bottom:
//   dispatcher        — one full-width box, owns the loop + try/catch.
//   channel functions — two columns: sendEmailChannel | writeInboxChannel.
//   sinks             — two columns aligned under each channel:
//                       sendEmail wrapper → Resend | db.insert(notifications).
// Two parallel paths (email left, inbox right) run end to end, joined by vertical
// connectors. The email column is one box wider at the sink layer (wrapper → Resend),
// so the stack reads as "channel is the thin seam, the sink owns the hard part".
//
// `highlight` selects the emphasized layer for this frame; "none" shows the whole
// stack at equal weight (the consolidation step). Engine: plain HTML + CSS — the
// diagrams index's pick for a labeled, color-coded box hierarchy, devtools-inspectable.
// `.not-content` + a `margin: 0` reset on every descendant defeat Starlight's
// prose-margin injection. <DiagramSequence> + per-step captions come from the MDX.

interface Props {
	highlight: "dispatcher" | "channels" | "sinks" | "none";
}

const { highlight } = Astro.props;

// A layer is "lit" when it is the highlighted one, or when nothing is highlighted
// (the equal-weight consolidation frame). Otherwise it is dimmed.
const lit = (layer: "dispatcher" | "channels" | "sinks") =>
	highlight === "none" || highlight === layer;

const stateOf = (layer: "dispatcher" | "channels" | "sinks") =>
	lit(layer) ? "lit" : "dim";

const ALT =
	"A three-layer call stack a notification dispatch descends through, top to bottom. " +
	"Top layer: the dispatcher, a single box owning the channel loop and per-channel try/catch. " +
	"Middle layer: two channel-function boxes side by side, sendEmailChannel on the left and writeInboxChannel on the right. " +
	"Bottom layer: the sinks each channel calls — the sendEmail wrapper feeding Resend under the email channel, and a db.insert into the notifications table under the inbox channel. " +
	(highlight === "dispatcher"
		? "This frame emphasizes the dispatcher layer."
		: highlight === "channels"
			? "This frame emphasizes the channel-function layer."
			: highlight === "sinks"
				? "This frame emphasizes the sink layer."
				: "This frame shows all three layers at equal weight, the two parallel email and inbox paths visible end to end.");
---

<div class="cl not-content" role="img" aria-label={ALT}>
	{/* ── Layer 1 — the dispatcher ─────────────────────────────────────────── */}
	<div class="cl-layer">
		<span class="cl-layer-tag">caller</span>
		<div class="cl-row cl-row-single">
			<div class="cl-box cl-box-dispatcher" data-state={stateOf("dispatcher")}>
				<span class="cl-box-title">dispatcher</span>
				<span class="cl-box-sub">loop + try/catch</span>
			</div>
		</div>
	</div>

	{/* Connector: the dispatcher fans out to each channel. */}
	<div class="cl-connect cl-connect-fan" data-state={stateOf("channels")} aria-hidden="true">
		<span class="cl-stem"></span>
		<span class="cl-bar"></span>
		<span class="cl-leg cl-leg-left"></span>
		<span class="cl-leg cl-leg-right"></span>
	</div>

	{/* ── Layer 2 — the channel functions ──────────────────────────────────── */}
	<div class="cl-layer">
		<span class="cl-layer-tag">channel functions</span>
		<div class="cl-row cl-row-pair">
			<div class="cl-col">
				<div class="cl-box cl-box-channel" data-state={stateOf("channels")}>
					<span class="cl-box-title">sendEmailChannel</span>
					<span class="cl-box-sub">thin adapter</span>
				</div>
			</div>
			<div class="cl-col">
				<div class="cl-box cl-box-channel" data-state={stateOf("channels")}>
					<span class="cl-box-title">writeInboxChannel</span>
					<span class="cl-box-sub">thin adapter</span>
				</div>
			</div>
		</div>
	</div>

	{/* Connector: each channel drops straight into its own sink. */}
	<div class="cl-connect cl-connect-pair" data-state={stateOf("sinks")} aria-hidden="true">
		<span class="cl-drop"></span>
		<span class="cl-drop"></span>
	</div>

	{/* ── Layer 3 — the sinks ──────────────────────────────────────────────── */}
	<div class="cl-layer">
		<span class="cl-layer-tag">sinks</span>
		<div class="cl-row cl-row-pair">
			<div class="cl-col">
				<div class="cl-box cl-box-sink" data-state={stateOf("sinks")}>
					<span class="cl-box-title">sendEmail wrapper</span>
					<span class="cl-box-sub">suppression · from · idempotency</span>
					<span class="cl-sink-arrow" aria-hidden="true">→ Resend</span>
				</div>
			</div>
			<div class="cl-col">
				<div class="cl-box cl-box-sink" data-state={stateOf("sinks")}>
					<span class="cl-box-title">db.insert(notifications)</span>
					<span class="cl-box-sub">one indexed row</span>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	.cl {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		width: 100%;
		max-width: 540px;
		margin-left: auto;
		margin-right: auto;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}
	.cl * {
		box-sizing: border-box;
		margin: 0;
	}

	/* ── A layer band, with its faint role label hanging on the left ───────── */
	.cl-layer {
		position: relative;
		display: flex;
		flex-direction: column;
	}
	.cl-layer-tag {
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #94a3b8);
		margin: 0 0 5px 2px;
	}

	.cl-row {
		display: flex;
		gap: 14px;
	}
	.cl-row-single {
		justify-content: center;
	}
	.cl-row-pair > .cl-col {
		flex: 1 1 0;
		min-width: 0;
	}

	/* ── A box at any layer ────────────────────────────────────────────────── */
	.cl-box {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 10px 14px;
		border-radius: 11px;
		border: 1.5px solid var(--sl-color-gray-5, #d0d5dd);
		background: var(--sl-color-bg, #fff);
		transition: opacity 0.15s ease;
	}
	.cl-box-title {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.25;
		color: var(--sl-color-white, #1e293b);
		word-break: break-word;
	}
	.cl-box-sub {
		font-size: 9.5px;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.3;
		color: var(--sl-color-gray-3, #64748b);
	}
	.cl-box-dispatcher {
		min-width: 0;
		max-width: 280px;
		align-items: center;
		text-align: center;
	}
	.cl-sink-arrow {
		margin: 3px 0 0;
		align-self: flex-start;
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0.03em;
		padding: 1.5px 7px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--cl-accent) 86%, var(--sl-color-white));
		background: color-mix(in srgb, var(--cl-accent) 14%, transparent);
	}

	/* ── Lit vs dimmed, keyed per layer colour ─────────────────────────────── */
	.cl-box-dispatcher {
		--cl-accent: #7c3aed;
	}
	.cl-box-channel {
		--cl-accent: #0d9488;
	}
	.cl-box-sink {
		--cl-accent: #2563eb;
	}
	.cl-box[data-state="lit"] {
		border-color: color-mix(in srgb, var(--cl-accent) 70%, var(--sl-color-hairline));
		background: color-mix(in srgb, var(--cl-accent) 11%, var(--sl-color-bg));
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--cl-accent) 26%, transparent);
	}
	.cl-box[data-state="lit"] .cl-box-title {
		color: color-mix(in srgb, var(--cl-accent) 30%, var(--sl-color-white));
	}
	.cl-box[data-state="dim"] {
		opacity: 0.42;
	}

	/* ── Vertical connectors between layers ────────────────────────────────── */
	.cl-connect {
		position: relative;
		color: var(--sl-color-gray-4, #b0b7c3);
		transition: opacity 0.15s ease;
	}
	.cl-connect[data-state="dim"] {
		opacity: 0.4;
	}

	/* Dispatcher → two channels: a stem, a horizontal bar, two legs down. */
	.cl-connect-fan {
		height: 22px;
	}
	.cl-stem {
		position: absolute;
		top: 0;
		left: 50%;
		width: 0;
		height: 7px;
		border-left: 2px solid currentColor;
	}
	.cl-bar {
		position: absolute;
		top: 7px;
		left: 25%;
		width: 50%;
		height: 0;
		border-top: 2px solid currentColor;
	}
	.cl-leg {
		position: absolute;
		top: 7px;
		width: 0;
		height: 15px;
		border-left: 2px solid currentColor;
	}
	.cl-leg-left {
		left: 25%;
	}
	.cl-leg-right {
		left: 75%;
	}

	/* Each channel → its sink: two straight drops under the two columns. */
	.cl-connect-pair {
		display: flex;
		gap: 14px;
		height: 16px;
	}
	.cl-drop {
		flex: 1 1 0;
		position: relative;
	}
	.cl-drop::before {
		content: "";
		position: absolute;
		top: 0;
		left: 50%;
		width: 0;
		height: 100%;
		border-left: 2px solid currentColor;
	}

	/* ── Narrow viewports: stack the two columns ───────────────────────────── */
	@media (max-width: 460px) {
		.cl-row-pair {
			flex-direction: column;
		}
		.cl-connect-pair {
			justify-content: center;
		}
		.cl-drop {
			flex: 0 0 24px;
		}
		.cl-drop:last-child {
			display: none;
		}
	}
</style>
