---
// burst-walkthrough — Chapter 070 Lesson 4, "Dedup the rapid duplicates".
//
// The marquee figure of the lesson: one frame of a five-step DiagramSequence
// that walks a five-click "Resend invitation" burst through the dispatcher,
// one click per step. The point the picture must make viscerally legible is
// "first one wins, the next four are deduped, and the deduped counter climbs."
//
// Each frame composes three horizontal elements, left to right:
//   1. channel chips (Email | Inbox) — lit when this click actually fired and
//      fanned out, dim when it was skipped by the dedup check.
//   2. a `notification_dedup` table strip — empty until the first send, then
//      holding exactly one row (the key the next four clicks match against),
//      unchanged for the rest of the burst.
//   3. a result tally `{ sent, deduped, suppressedByPrefs }`, with the counter
//      that changed this step emphasized so the increment is impossible to miss.
//
// The visual language is shared with sibling lesson 3's ChipRow: React-cyan
// (#0891b2) fill for "lit", a dashed/greyed treatment for "dim/skipped". Engine
// is plain HTML + CSS — the diagrams index's pick for a labeled, color-coded,
// devtools-inspectable strip. `.not-content` + a margin reset on descendants
// defeat Starlight's prose-margin injection. <DiagramSequence> + per-step
// captions come from the MDX call site.
//
// `step` (1–5) selects the frame:
//   1 — Click 1 fires: chips lit, the dedup row is written, sent=1.
//   2 — Click 2 (0.3s later) hits the row: chips dim, deduped=1.
//   3 — Clicks 3 & 4 absorbed: chips dim, deduped=3.
//   4 — Click 5 skipped: chips dim, deduped=4.
//   5 — Summary: the delivered Email chip and Inbox row that actually shipped,
//       the single dedup row, and the final tally emphasized as a whole.

import { Icon } from 'astro-icon/components';

interface Props {
	step: 1 | 2 | 3 | 4 | 5;
}

const { step } = Astro.props;

// The fan-out only happened on click 1. Every later click in the window is a
// dedup hit, so its chips stay dim — nothing was sent.
const fired = step === 1;

// The dedup row exists from the first send onward (steps 1–5).
const hasRow = true;

// Per-step result tally and which counter just changed (for the emphasis ring).
const TALLY = {
	1: { sent: 1, deduped: 0, suppressedByPrefs: 0, changed: 'sent' },
	2: { sent: 1, deduped: 1, suppressedByPrefs: 0, changed: 'deduped' },
	3: { sent: 1, deduped: 3, suppressedByPrefs: 0, changed: 'deduped' },
	4: { sent: 1, deduped: 4, suppressedByPrefs: 0, changed: 'deduped' },
	5: { sent: 1, deduped: 4, suppressedByPrefs: 0, changed: 'all' },
} as const;

const tally = TALLY[step];

const STEP_LABEL = {
	1: 'Click 1 — fires',
	2: 'Click 2 — 0.3s later',
	3: 'Clicks 3 & 4',
	4: 'Click 5',
	5: 'Result',
} as const;

// The summary frame (step 5) reframes the chips as "what actually shipped":
// one Email delivery, one Inbox row. Earlier frames show the live Email|Inbox
// pair lighting up or staying dim.
const isSummary = step === 5;

const counters = [
	{ key: 'sent', label: 'sent', value: tally.sent },
	{ key: 'deduped', label: 'deduped', value: tally.deduped },
	{ key: 'suppressedByPrefs', label: 'suppressedByPrefs', value: tally.suppressedByPrefs },
] as const;

const ALT =
	`Step ${step} of a five-click "Resend invitation" burst moving through the dispatcher. ` +
	(isSummary
		? 'Summary: one Email delivery and one Inbox row actually shipped, the notification_dedup table holds a single row for the invitation, and the final tally reads sent 1, deduped 4, suppressedByPrefs 0.'
		: fired
			? 'The Email and Inbox channels both light up — this click found no matching row, so it fired and wrote a dedup row. The tally reads sent 1.'
			: `Both the Email and Inbox channels are dimmed — this click matched the existing dedup row inside the 60-second window and was skipped. The tally reads deduped ${tally.deduped}.`);
---

<div class="bw not-content" role="img" aria-label={ALT}>
	{/* ── Column 1 — the channels for this click ─────────────────────────── */}
	<section class="bw-col bw-col-channels">
		<span class="bw-eyebrow">{isSummary ? 'delivered' : 'channels'}</span>
		<div class="bw-chips">
			{
				isSummary ? (
					<>
						<div class="bw-chip is-lit">
							<Icon name="lucide:mail" class="bw-chip-icon" />
							<span>1 email</span>
						</div>
						<div class="bw-chip is-lit">
							<Icon name="lucide:inbox" class="bw-chip-icon" />
							<span>1 inbox row</span>
						</div>
					</>
				) : (
					<>
						<div class:list={['bw-chip', fired ? 'is-lit' : 'is-dim']}>
							<Icon name="lucide:mail" class="bw-chip-icon" />
							<span>email</span>
						</div>
						<div class:list={['bw-chip', fired ? 'is-lit' : 'is-dim']}>
							<Icon name="lucide:inbox" class="bw-chip-icon" />
							<span>inbox</span>
						</div>
					</>
				)
			}
		</div>
		<span class:list={['bw-verdict', fired ? 'is-send' : 'is-skip']}>
			{isSummary ? 'shipped once' : fired ? 'fan out' : 'skipped'}
		</span>
	</section>

	{/* ── Column 2 — the notification_dedup table strip ──────────────────── */}
	<section class="bw-col bw-col-table">
		<span class="bw-eyebrow">notification_dedup</span>
		<div class="bw-table">
			<div class="bw-table-head">
				<span>eventType</span>
				<span>dedupKey</span>
				<span>recipient</span>
				<span>firedAt</span>
			</div>
			{
				hasRow ? (
					<div class:list={['bw-table-row', step === 1 && 'is-fresh']}>
						<span>org.invitation.sent</span>
						<span>inv_123</span>
						<span>user_a</span>
						<span>T0</span>
					</div>
				) : (
					<div class="bw-table-empty">— no rows —</div>
				)
			}
		</div>
		<span class="bw-table-note">
			{isSummary ? 'one row, four hits' : step === 1 ? 'row written' : 'matched within 60s'}
		</span>
	</section>

	{/* ── Column 3 — the DispatchResult tally ────────────────────────────── */}
	<section class="bw-col bw-col-tally">
		<span class="bw-eyebrow">DispatchResult</span>
		<div class:list={['bw-tally', isSummary && 'is-final']}>
			<span class="bw-brace">{'{'}</span>
			{
				counters.map((c) => (
					<span
						class:list={[
							'bw-counter',
							(tally.changed === c.key || tally.changed === 'all') && 'is-changed',
						]}
					>
						<span class="bw-counter-label">{c.label}:</span>
						<span class="bw-counter-value">{c.value}</span>
					</span>
				))
			}
			<span class="bw-brace">{'}'}</span>
		</div>
	</section>
</div>

<style>
	.bw {
		display: grid;
		grid-template-columns: minmax(150px, 0.9fr) minmax(280px, 1.4fr) minmax(170px, 1fr);
		align-items: stretch;
		gap: 14px;
		padding: 14px 6px 6px;
		margin: 0;
		min-height: 168px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.bw :global(*) {
		margin: 0;
	}

	.bw-col {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		gap: 10px;
		padding: 12px 10px;
		border-radius: 12px;
		border: 1px solid var(--sl-color-gray-5, #e2e8f0);
		background: var(--sl-color-bg);
	}

	.bw-eyebrow {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-2, #475569);
		text-align: center;
	}

	/* ── Channel chips ──────────────────────────────────────────────────── */
	.bw-chips {
		display: flex;
		flex-direction: column;
		gap: 8px;
		width: 100%;
		max-width: 150px;
	}

	.bw-chip {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px;
		border-radius: 9px;
		font-size: 0.86rem;
		font-weight: 600;
		line-height: 1;
		transition:
			opacity 120ms ease,
			background 120ms ease;
	}

	.bw-chip.is-lit {
		background: color-mix(in srgb, #0891b2 16%, var(--sl-color-bg));
		border: 1.5px solid color-mix(in srgb, #0891b2 60%, transparent);
		color: var(--sl-color-white, #0e7490);
		box-shadow: 0 1px 4px rgba(8, 145, 178, 0.16);
	}

	.bw-chip.is-dim {
		background: var(--sl-color-bg);
		border: 1.5px dashed var(--sl-color-gray-4, #94a3b8);
		color: var(--sl-color-gray-3, #94a3b8);
		opacity: 0.65;
	}

	.bw-chip-icon {
		width: 1.05em;
		height: 1.05em;
		flex: none;
	}

	.bw-verdict {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding: 2px 8px;
		border-radius: 999px;
	}

	.bw-verdict.is-send {
		color: #0e7490;
		background: color-mix(in srgb, #0891b2 14%, var(--sl-color-bg));
	}

	.bw-verdict.is-skip {
		color: var(--sl-color-gray-2, #475569);
		background: var(--sl-color-gray-6, #f1f5f9);
	}

	/* ── notification_dedup table strip ─────────────────────────────────── */
	.bw-col-table {
		justify-content: center;
	}

	.bw-table {
		width: 100%;
		border-radius: 8px;
		border: 1px solid var(--sl-color-gray-5, #e2e8f0);
		overflow: hidden;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.7rem;
	}

	.bw-table-head,
	.bw-table-row {
		display: grid;
		grid-template-columns: 1.5fr 0.9fr 0.8fr 0.5fr;
		gap: 6px;
		padding: 6px 10px;
		align-items: center;
	}

	.bw-table-head {
		background: var(--sl-color-gray-6, #f1f5f9);
		color: var(--sl-color-gray-2, #475569);
		font-weight: 600;
		border-bottom: 1px solid var(--sl-color-gray-5, #e2e8f0);
	}

	.bw-table-row {
		color: var(--sl-color-white);
		background: color-mix(in srgb, #0891b2 9%, var(--sl-color-bg));
	}

	.bw-table-row.is-fresh {
		background: color-mix(in srgb, #0891b2 18%, var(--sl-color-bg));
		box-shadow: inset 3px 0 0 #0891b2;
	}

	.bw-table-row span {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.bw-table-empty {
		padding: 10px;
		text-align: center;
		color: var(--sl-color-gray-3, #94a3b8);
	}

	.bw-table-note {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.66rem;
		color: var(--sl-color-gray-2, #475569);
	}

	/* ── DispatchResult tally ───────────────────────────────────────────── */
	.bw-col-tally {
		justify-content: center;
	}

	.bw-tally {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 4px;
		padding: 12px 14px;
		border-radius: 10px;
		border: 1.5px solid var(--sl-color-gray-5, #e2e8f0);
		background: var(--sl-color-gray-7, #f8fafc);
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.8rem;
		line-height: 1.3;
	}

	.bw-tally.is-final {
		border-color: color-mix(in srgb, #0891b2 55%, transparent);
		box-shadow: 0 1px 6px rgba(8, 145, 178, 0.18);
	}

	.bw-brace {
		color: var(--sl-color-gray-3, #94a3b8);
	}

	.bw-counter {
		display: inline-flex;
		gap: 6px;
		padding: 1px 6px 1px 14px;
		border-radius: 6px;
		transition: background 120ms ease;
	}

	.bw-counter-label {
		color: var(--sl-color-gray-2, #475569);
	}

	.bw-counter-value {
		color: var(--sl-color-white);
		font-weight: 700;
	}

	.bw-counter.is-changed {
		background: color-mix(in srgb, #0891b2 16%, transparent);
	}

	.bw-counter.is-changed .bw-counter-value {
		color: #0e7490;
	}

	/* Keep the strip horizontal but allow a graceful stack on narrow screens. */
	@media (max-width: 640px) {
		.bw {
			grid-template-columns: 1fr;
			min-height: 0;
		}
	}
</style>
