---
// two-layers-contrast — Chapter 070 Lesson 4, "Dedup the rapid duplicates".
//
// A compact, static comparison strip that pins the lesson's second hard idea:
// webhook idempotency and dispatcher dedup are DIFFERENT layers guarding
// DIFFERENT duplicates at DIFFERENT boundaries — they compose, neither
// replaces the other.
//
// Shape: a three-column grid (Boundary | Stops | Keyed on) with a header row
// and one data row per layer. Each layer gets its own accent color so the
// "two layers" point is legible at a glance — the color itself is the signal:
//   • amber  — the webhook handler at the edge, guarding STATE churn.
//   • violet — the dispatcher at the seam, guarding NOTIFICATION churn.
// (Violet matches the lesson's "deduped" counter color from the flowchart and
// DiagramSequence, anchoring this layer to the mechanic the lesson just built.)
//
// Engine is plain HTML + CSS — the diagrams index's pick for a labeled,
// color-coded, devtools-inspectable strip. `.not-content` + a margin reset on
// descendants defeat Starlight's prose-margin injection. The <Figure> wrapper
// and caption come from the MDX call site.

import { Icon } from 'astro-icon/components';

interface Layer {
	accent: string;
	icon: string;
	boundary: string;
	role: string;
	stops: string;
	keyedOn: string;
}

const LAYERS: Layer[] = [
	{
		accent: '#b45309',
		icon: 'lucide:webhook',
		boundary: 'Webhook handler',
		role: 'at the edge',
		stops: 'state churn',
		keyedOn: 'processed_events (provider, event_id)',
	},
	{
		accent: '#7e22ce',
		icon: 'lucide:bell-ring',
		boundary: 'Dispatcher',
		role: 'at the seam',
		stops: 'notification churn',
		keyedOn: '(eventType, dedupKey, recipientUserId)',
	},
];

const ALT =
	'Two stacked layers, each guarding a different duplicate. The webhook handler at the edge stops state churn, keyed on processed_events (provider, event_id). The dispatcher at the seam stops notification churn, keyed on (eventType, dedupKey, recipientUserId).';
---

<div class="tlc not-content" role="img" aria-label={ALT}>
	<div class="tlc-grid">
		{/* ── Header row ───────────────────────────────────────────────────── */}
		<div class="tlc-head">Boundary</div>
		<div class="tlc-head">Stops</div>
		<div class="tlc-head">Keyed on</div>

		{/* ── One row per layer ────────────────────────────────────────────── */}
		{
			LAYERS.map((layer) => (
				<>
					<div class="tlc-cell tlc-boundary" style={`--accent: ${layer.accent}`}>
						<span class="tlc-rail" />
						<Icon name={layer.icon} class="tlc-icon" />
						<span class="tlc-boundary-text">
							<span class="tlc-boundary-name">{layer.boundary}</span>
							<span class="tlc-boundary-role">{layer.role}</span>
						</span>
					</div>
					<div class="tlc-cell tlc-stops" style={`--accent: ${layer.accent}`}>
						<span class="tlc-pill">{layer.stops}</span>
					</div>
					<div class="tlc-cell tlc-keyed" style={`--accent: ${layer.accent}`}>
						<code class="tlc-key">{layer.keyedOn}</code>
					</div>
				</>
			))
		}
	</div>
</div>

<style>
	.tlc {
		padding: 4px 2px;
		margin: 0;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.tlc :global(*) {
		margin: 0;
	}

	.tlc-grid {
		display: grid;
		grid-template-columns: minmax(170px, 1fr) minmax(140px, 0.9fr) minmax(240px, 1.5fr);
		column-gap: 12px;
		row-gap: 10px;
		align-items: stretch;
	}

	/* ── Header row ─────────────────────────────────────────────────────── */
	.tlc-head {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3, #94a3b8);
		padding: 0 4px 2px;
		align-self: end;
	}

	/* ── Data cells ─────────────────────────────────────────────────────── */
	.tlc-cell {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 11px 14px;
		border-radius: 10px;
		border: 1px solid color-mix(in srgb, var(--accent) 38%, transparent);
		background: color-mix(in srgb, var(--accent) 8%, var(--sl-color-bg));
	}

	/* ── Boundary cell: accent rail + icon + two-line label ─────────────── */
	.tlc-boundary {
		position: relative;
		padding-left: 18px;
	}

	.tlc-rail {
		position: absolute;
		left: 0;
		top: 8px;
		bottom: 8px;
		width: 4px;
		border-radius: 999px;
		background: var(--accent);
	}

	.tlc-icon {
		width: 1.25em;
		height: 1.25em;
		flex: none;
		color: var(--accent);
	}

	.tlc-boundary-text {
		display: flex;
		flex-direction: column;
		gap: 1px;
		min-width: 0;
	}

	.tlc-boundary-name {
		font-size: 0.92rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
		line-height: 1.2;
	}

	.tlc-boundary-role {
		font-size: 0.74rem;
		font-weight: 500;
		color: var(--sl-color-gray-2, #475569);
		line-height: 1.2;
	}

	/* ── Stops cell: a saturated pill, the verdict of the layer ─────────── */
	.tlc-pill {
		display: inline-flex;
		align-items: center;
		padding: 4px 11px;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 700;
		color: #fff;
		background: var(--accent);
		white-space: nowrap;
	}

	/* ── Keyed-on cell: the composite key, as code ──────────────────────── */
	.tlc-key {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.76rem;
		font-weight: 600;
		color: var(--sl-color-white, #1e293b);
		background: transparent;
		padding: 0;
		line-height: 1.35;
	}

	/* Stack each row's three cells on narrow screens, keeping color grouping. */
	@media (max-width: 560px) {
		.tlc-grid {
			grid-template-columns: 1fr;
			row-gap: 6px;
		}

		.tlc-head {
			display: none;
		}

		.tlc-cell {
			border-radius: 8px;
		}

		.tlc-boundary {
			margin-top: 8px;
		}
	}
</style>
