---
// subtraction-model — Chapter 070 Lesson 3, "Preferences, read once, default-on".
//
// One frame of the four-step subtraction-model DiagramSequence. The lesson's
// keystone picture: an event declares a default set of channels, and a user's
// preference row can only ever SUBTRACT from that set — never add. A missing
// row subtracts nothing, so it looks identical to the full default.
//
// Each frame is a centered horizontal row of channel "chips". A chip is in one
// of three visual states:
//   - lit:    the channel is in the resolved set (solid, React-cyan fill)
//   - muted:  the channel was opted out of — greyed and struck through (still
//             shown so the eye sees it switch off in place across steps)
//   - absent: the chip simply isn't passed in (step 3, where email has been
//             subtracted out of the set entirely)
//
// `label` is the small eyebrow above the row; it carries the per-step framing
// that the DiagramStep caption then expands on.

import { Icon } from 'astro-icon/components';

interface Chip {
	name: string;
	state: 'lit' | 'muted';
	icon: string;
}

interface Props {
	label: string;
	chips: Chip[];
}

const { label, chips } = Astro.props;
---

<div class="sm-stage not-content">
	<span class="sm-label">{label}</span>
	<div class="sm-row">
		{
			chips.map((chip) => (
				<div class:list={['sm-chip', `is-${chip.state}`]}>
					<Icon name={chip.icon} class="sm-chip-icon" />
					<span class="sm-chip-name">{chip.name}</span>
				</div>
			))
		}
	</div>
</div>

<style>
	.sm-stage {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
		padding: 22px 8px 10px;
		margin: 0;
		min-height: 116px;
		justify-content: center;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.sm-label {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.74rem;
		font-weight: 600;
		line-height: 1.2;
		text-align: center;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}

	.sm-row {
		display: flex;
		justify-content: center;
		align-items: stretch;
		gap: 16px;
		margin: 0;
	}

	.sm-chip {
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 18px;
		border-radius: 10px;
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1;
		margin: 0;
		transition:
			opacity 120ms ease,
			background 120ms ease;
	}

	/* lit — the channel is in the resolved set */
	.sm-chip.is-lit {
		background: color-mix(in srgb, #0891b2 16%, var(--sl-color-bg));
		border: 1.5px solid color-mix(in srgb, #0891b2 60%, transparent);
		color: var(--sl-color-white, #0e7490);
		box-shadow: 0 1px 4px rgba(8, 145, 178, 0.16);
	}

	/* muted — opted out: greyed and struck through, but still shown in place */
	.sm-chip.is-muted {
		background: var(--sl-color-bg);
		border: 1.5px dashed var(--sl-color-gray-4, #94a3b8);
		color: var(--sl-color-gray-3, #94a3b8);
		text-decoration: line-through;
		text-decoration-thickness: 1.5px;
		opacity: 0.7;
	}

	.sm-chip-icon {
		width: 1.05em;
		height: 1.05em;
		flex: none;
	}

	.sm-chip.is-muted .sm-chip-icon {
		opacity: 0.85;
	}

	.sm-chip-name {
		margin: 0;
	}
</style>
