---
// root-layout-escapes (diagram id: sequence-root-layout-escapes, Chapter 031 L4).
// Why a throw in the ROOT layout escapes app/error.tsx and runs clear off the
// top of the tree — the "trigger before tool" beat rendered as a picture, the
// felt need for a boundary ABOVE the root layout before global-error.tsx is
// named. Walks ErrorCatchesWhat's containment argument up one level to the root.
//
// Reading left -> right, three scrubbable steps:
//   LEFT  — the app tree as physical containment:
//             OUTER  `app/layout.tsx (root layout)`, neutral/grey "outside the
//                    boundary" — the error.tsx ring is its CHILD.
//             INNER  `app/error.tsx boundary`, a red/orange dashed ring.
//             CORE   `page.tsx`, green-checked "caught" in step 1.
//   RIGHT — the escape: an arrow leaving the TOP of the tree to a stark grey
//           `browser default error screen` box (no branding, no ring).
//
// step 1 — the tree you have: page.tsx caught inside the boundary; the escape
//          path on the right is a faint ghost (not yet taken).
// step 2 — the root layout throws: outer box gets a red ✕ + "throws here", a
//          note spells out the throw is OUTSIDE the ring (the boundary is its
//          child); the page core dims (it never renders). Escape still ghosted.
// step 3 — nothing catches it: the escape arrow + browser-default box light up;
//          the throw runs off the top of the tree to the bare fallback.
//
// Every step renders ALL elements (escape ghosted before step 3) so the
// grid-stacked DiagramSequence stage sizes to the tallest step (step 3) and
// never reflows as the reader scrubs.
//
// Pure HTML + CSS, no JS of its own (DiagramSequence owns the scrubber).
// color-scheme pinned light so the semantic tints (grey = outside / bare
// fallback, red = the boundary + the throw, green = caught) survive dark mode;
// margin:0 on inner elements defeats Starlight's injected prose margins. Palette
// and the fieldset-legend-pill technique deliberately match ErrorCatchesWhat
// and ThreeBoundariesCompose, the sibling figures in this chapter.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff';

// Neutral — the layout "outside the boundary"
const SLATE_BG = '#f1f5f9'; // slate-100 wash
const SLATE_EDGE = '#cbd5e1'; // slate-300 edge
const SLATE_INK = '#475569'; // slate-600

// The boundary + the throw — red / orange
const RED = '#dc2626'; // red-600
const RED_BG = '#fef2f2'; // red-50 wash
const RED_EDGE = '#fca5a5'; // red-300
const RED_INK = '#b91c1c'; // red-700

// Caught — green
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_EDGE = '#bbf7d0'; // green-200 edge
const GREEN_INK = '#15803d'; // green-700

// Bare fallback — plain grey, no branding
const BARE_BG = '#e2e8f0'; // slate-200 — a touch darker / starker than SLATE_BG
const BARE_EDGE = '#94a3b8'; // slate-400
const BARE_INK = '#475569'; // slate-600

// Ghost (the escape path before it is taken)
const GHOST_EDGE = '#e2e8f0'; // slate-200
const GHOST_INK = '#cbd5e1'; // slate-300

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage. The diagram is a left (tree) / right (escape) pair that wraps to
// a stack on narrow widths.
const stage = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 14px; margin: 0 auto; max-width: 660px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// LEFT — the app tree -------------------------------------------------------
// The outer root-layout box — the boundary's PARENT. Relative so its legend
// pill + the corner ✕ badge position against it. `crashed` swaps the neutral
// edge for a red one and tints the wash faintly red.
function outerBox(crashed: boolean) {
	const edge = crashed ? RED_EDGE : SLATE_EDGE;
	const bg = crashed ? RED_BG : SLATE_BG;
	return `position: relative; flex: 1 1 280px; min-width: 250px; max-width: 360px; margin: 0; padding: 34px 16px 16px; border: 1.5px solid ${edge}; border-radius: 14px; background: ${bg}; box-sizing: border-box;`;
}

// The note sitting just under the outer box's legend, before the boundary —
// either the quiet "the boundary below is its child" framing (steps 1) or the
// loud "throws here, outside the ring" escape note (steps 2-3).
const outerNote = `display: flex; align-items: flex-start; gap: 7px; margin: 0 0 12px; font-family: ${sans}; font-size: 11.5px; line-height: 1.35;`;

// The red ✕ badge marking the root layout as the throw site.
const crossBadge = `display: inline-flex; align-items: center; justify-content: center; flex: none; width: 18px; height: 18px; margin: 0; border-radius: 50%; background: ${RED}; color: ${SURFACE}; font-family: ${sans}; font-size: 12px; font-weight: 900; line-height: 1;`;

// A small neutral dot bullet for the quiet step-1 note.
const dotBadge = `display: inline-flex; align-items: center; justify-content: center; flex: none; width: 18px; height: 18px; margin: 0; border-radius: 50%; background: ${SLATE_EDGE}; color: ${SLATE_INK}; font-family: ${sans}; font-size: 12px; font-weight: 900; line-height: 1;`;

// The inner error.tsx boundary box — a dashed red ring. Relative for its legend
// pill. `bypassed` fades it: in steps 2-3 the throw is born outside it, so the
// boundary is impotent and reads as greyed-out.
function boundaryBox(bypassed: boolean) {
	const opacity = bypassed ? 0.4 : 1;
	return `position: relative; margin: 0; padding: 30px 14px 14px; border: 2px dashed ${RED_EDGE}; border-radius: 12px; background: ${RED_BG}; box-sizing: border-box; opacity: ${opacity};`;
}

// The page.tsx core inside the boundary. `caught` shows the green check; once
// the layout has thrown, the page never renders, so it dims to a placeholder.
function coreBox(caught: boolean) {
	const opacity = caught ? 1 : 0.55;
	return `display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 0; padding: 11px 12px; background: ${GREEN_BG}; border: 1.5px solid ${GREEN_EDGE}; border-radius: 10px; box-sizing: border-box; opacity: ${opacity};`;
}
const coreName = `margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 700; line-height: 1.1; color: ${INK};`;
const caughtRow = `display: flex; align-items: center; gap: 6px; margin: 0;`;
const checkBadge = `display: inline-flex; align-items: center; justify-content: center; flex: none; width: 16px; height: 16px; margin: 0; border-radius: 50%; background: ${GREEN}; color: ${SURFACE}; font-family: ${sans}; font-size: 10px; font-weight: 900; line-height: 1;`;
const caughtLabel = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: ${GREEN_INK};`;
const notRenderedLabel = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; letter-spacing: 0.02em; color: ${INK_SOFT};`;

// RIGHT — the escape --------------------------------------------------------
// The escape arrow leaving the top of the tree. `live` lights it red; before
// the throw escapes it is a faint ghost so the stage reserves its space.
function escapeArrow(live: boolean) {
	const color = live ? RED : GHOST_EDGE;
	return `flex: none; margin: 0; font-family: ${sans}; font-size: 30px; font-weight: 900; line-height: 1; color: ${color};`;
}
function escapeLabel(live: boolean) {
	const color = live ? RED_INK : GHOST_INK;
	return `margin: 4px 0 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.25; text-align: center; max-width: 96px; color: ${color};`;
}
const escapeCol = `display: flex; flex-direction: column; align-items: center; justify-content: center; flex: none; margin: 0;`;

// The bare browser-default box. `live` gives it the stark grey treatment; before
// the throw reaches it the box is a faint ghost reserving the stage height.
function bareBox(live: boolean) {
	const edge = live ? BARE_EDGE : GHOST_EDGE;
	const bg = live ? BARE_BG : 'transparent';
	const opacity = live ? 1 : 0.55;
	return `flex: 1 1 180px; min-width: 170px; max-width: 220px; display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 16px 14px; border: 1.5px solid ${edge}; border-radius: 10px; background: ${bg}; box-sizing: border-box; opacity: ${opacity};`;
}
function bareTitle(live: boolean) {
	return `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2; color: ${live ? BARE_INK : GHOST_INK};`;
}
function bareSub(live: boolean) {
	return `margin: 0; font-family: ${sans}; font-size: 10.5px; line-height: 1.3; color: ${live ? INK_SOFT : GHOST_INK};`;
}

// One step per beat: 1 = caught, 2 = layout throws (escape ghosted),
// 3 = the throw escapes to the bare fallback.
const steps = [1, 2, 3];
---

<DiagramSequence>
	{
		steps.map((step) => {
			const crashed = step >= 2; // root layout has thrown
			const live = step >= 3; // the throw has escaped to the bare fallback
			return (
				<DiagramStep>
					<div class="rle-stage not-content" style={stage}>
						{/* LEFT — the app tree */}
						<div style={outerBox(crashed)}>
							<span
								class="rle-legend"
								style={`background: ${crashed ? RED_BG : SLATE_BG};`}
							>
								<code class="rle-legend-code" style={`color: ${crashed ? RED_INK : SLATE_INK};`}>
									app/layout.tsx
								</code>
								<span style={`color: ${crashed ? RED_INK : INK_SOFT};`}>root layout</span>
							</span>

							{crashed ? (
								<p style={`${outerNote} color: ${RED_INK};`}>
									<span style={crossBadge} aria-hidden="true">
										&times;
									</span>
									<span>
										<strong>Throws here</strong> &mdash; outside the <code style={`background: transparent; padding: 0; font-family: ${mono}; color: ${RED_INK}; font-weight: 700;`}>error.tsx</code> ring. The boundary is its <strong>child</strong>, so it does not exist yet.
									</span>
								</p>
							) : (
								<p style={`${outerNote} color: ${SLATE_INK};`}>
									<span style={dotBadge} aria-hidden="true">
										&middot;
									</span>
									<span>
										The <code style={`background: transparent; padding: 0; font-family: ${mono}; color: ${SLATE_INK}; font-weight: 700;`}>error.tsx</code> boundary lives <strong>inside</strong> the root layout &mdash; it is the layout's child.
									</span>
								</p>
							)}

							{/* INNER — the error.tsx boundary */}
							<div style={boundaryBox(crashed)}>
								<span class="rle-legend" style={`background: ${RED_BG};`}>
									<code class="rle-legend-code" style={`color: ${RED_INK};`}>error.tsx</code>
									<span style={`color: ${RED_INK};`}>boundary</span>
								</span>

								{/* CORE — page.tsx */}
								<div style={coreBox(!crashed)}>
									<span style={coreName}>page.tsx</span>
									{crashed ? (
										<span style={notRenderedLabel}>never renders</span>
									) : (
										<span style={caughtRow}>
											<span style={checkBadge} aria-hidden="true">
												&checkmark;
											</span>
											<span style={caughtLabel}>caught</span>
										</span>
									)}
								</div>
							</div>
						</div>

						{/* RIGHT — the escape off the top of the tree */}
						<div style={escapeCol}>
							<span style={escapeArrow(live)} aria-hidden="true">
								&rarr;
							</span>
							<span style={escapeLabel(live)}>escapes the top of the tree</span>
						</div>

						<div style={bareBox(live)}>
							<span style={bareTitle(live)}>browser default error screen</span>
							<span style={bareSub(live)}>no branding &middot; no &ldquo;Try again&rdquo; &middot; no message you wrote</span>
						</div>
					</div>

					{step === 1 && (
						<Fragment slot="caption">
							Errors <strong>under</strong> the root layout are caught by <code>app/error.tsx</code>, exactly as the last lesson taught.
						</Fragment>
					)}
					{step === 2 && (
						<Fragment slot="caption">
							The boundary lives <strong>inside</strong> the layout, so a layout render error happens <strong>before</strong> the boundary exists.
						</Fragment>
					)}
					{step === 3 && (
						<Fragment slot="caption">
							There is no <code>error.tsx</code> above the root layout &mdash; the throw escapes the whole app and the user gets the framework's bare fallback.
						</Fragment>
					)}
				</DiagramStep>
			);
		})
	}
</DiagramSequence>

<style>
	/* "Fieldset legend" pills straddling each box's top border — same technique
	   as ErrorCatchesWhat / ThreeBoundariesCompose. Block + fit-content with a
	   negative margin-top lands the pill centred on the border line; the pill's
	   inline background (matching the box fill) breaks the border where it sits. */
	.rle-legend {
		display: block;
		width: fit-content;
		/* straddle the box's ~1.5-2px border + ~30-34px top padding minus the
		   pill's own half-height (~11px) */
		margin: -45px 0 0 4px;
		padding: 2px 9px;
		border-radius: 999px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 12px;
		font-weight: 700;
		white-space: nowrap;
		line-height: 1.4;
	}

	/* The inner boundary pill straddles a 30px-top-padding box, slightly tighter
	   than the outer 34px box. */
	.rle-stage :global(div[style*='30px 14px 14px'] > .rle-legend) {
		margin-top: -41px;
	}

	.rle-legend-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		font-weight: 800;
		background: transparent;
		padding: 0;
		margin-right: 5px;
	}

	/* Narrow viewports: the tree and the bare fallback stack, and the escape
	   arrow rotates to point downward into the box below it. */
	@media (max-width: 520px) {
		.rle-stage :global(span[style*='font-size: 30px']) {
			transform: rotate(90deg);
		}
	}
</style>
