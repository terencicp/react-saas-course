---
// A good fallback mirrors the resolved layout (diagram id:
// spinner-vs-skeleton-fallback, Chapter 031 L1). A two-tab TabbedContent letting
// the reader SEE the difference between a collapsing spinner fallback and a
// layout-matching skeleton, and — crucially — the layout shift that follows.
// It sits in "A good fallback mirrors the resolved layout", right after the rule
// that a skeleton should occupy the content's eventual footprint.
//
// Both tabs render the SAME tiny "page": a "Recent activity" heading, a loading
// region, then a pinned "rest of the page" footer bar — the next section, the
// thing that gets shoved. The ONLY honest difference between the tabs is how much
// vertical space the loading region claims, and therefore where the footer sits:
//   • Spinner tab — a short box with a small spinning CSS circle, then the footer
//     bar pinned right under it (HIGH), tagged "jumps". Below the footer, a faint
//     dashed amber "displacement" zone with a down-arrow shows the room the real
//     list will demand — room that appears between spinner and footer and shoves
//     the footer down to the dashed final line at the foot of the band.
//   • Skeleton tab — three/four grey skeleton rows the height of real invoice
//     rows, so the loading region already occupies the list's real footprint and
//     the footer bar is ALREADY at that final dashed line, tagged "no shift" —
//     the content swaps in place, nothing moves.
// The footer's vertical position is the load-bearing variable: flipping tabs
// moves it (spinner: high, about to drop) vs (skeleton: already at rest).
//
// House style is pinned to this lesson family (SuspenseContractStates,
// BoundaryCountGranularity, NestedRevealCascade — all 031 L1): the same indigo
// (boundary/accent), green (resolved/ready), amber (the defect/shift) and slate
// palette; color-scheme pinned light so the hand-picked tints survive dark mode;
// `margin: 0` on every inner element to defeat Starlight's injected prose
// margins; inline style strings. Per the outline this is its OWN card — a
// TabbedContent of two UI-state variants — so it is NOT wrapped in <Figure>.
//
// The spinner rotation is the one piece that needs a keyframe, so this component
// carries a single scoped <style> for the @keyframes (inline styles can't hold
// keyframes); everything else stays inline to read the same as its siblings.

import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

// Palette — shared with the rest of the 031 L1 figure family.
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary card edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)
const DIM_INK = '#94a3b8'; // greyed ink (slate-400)

const INDIGO = '#4f46e5'; // indigo-600 — the spinner accent / generic loading
const INDIGO_INK = '#3730a3'; // indigo-800

const GREEN = '#16a34a'; // green-600 — resolved / "no shift" good outcome
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const AMBER = '#d97706'; // amber-600 — the layout-shift defect
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by both tabs: pinned light, slate ink, a centered column so
// both panels are the same shape and the footer's vertical position is the only
// thing the eye tracks across the tabs.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The mock "page" frame — a phone-ish device card, identical chrome in both tabs.
const page = `box-sizing: border-box; display: flex; flex-direction: column; gap: 9px; width: 100%; max-width: 320px; margin: 0; padding: 13px 13px 14px; border: 1px solid ${BORDER}; border-radius: 13px; background: ${SURFACE}; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);`;

// The "Recent activity" section heading — same in both tabs.
const heading = `display: flex; align-items: center; gap: 7px; margin: 0;`;
const headingDot = `flex: 0 0 auto; width: 7px; height: 7px; margin: 0; border-radius: 50%; background: ${INDIGO};`;
const headingText = `margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 800; letter-spacing: -0.01em; line-height: 1.2; color: ${INK};`;

// The loading region's eyebrow: a tiny label + a state pill on the right.
const regionHead = `display: flex; align-items: center; justify-content: space-between; gap: 8px; margin: 0;`;
const regionTag = `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;
const pill = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 2px 8px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.3; white-space: nowrap;`;
const dot = (c: string) => `display: inline-block; flex: 0 0 auto; width: 6px; height: 6px; margin: 0; border-radius: 50%; background: ${c};`;

// ── SPINNER TAB ──
// The short spinner box: a small centered spinning circle in a low-height frame.
// Its height is deliberately a fraction of the skeleton's, so it under-reserves.
const spinnerBox = `box-sizing: border-box; display: flex; align-items: center; justify-content: center; gap: 8px; height: 40px; margin: 0; padding: 0; border-radius: 8px; border: 1px dashed ${INDIGO}; background: ${PANEL_BG};`;
// The spinner itself: a CSS ring with one coloured arc, rotated via @keyframes.
const spinner = `box-sizing: border-box; flex: 0 0 auto; width: 18px; height: 18px; margin: 0; border-radius: 50%; border: 2.5px solid ${BORDER}; border-top-color: ${INDIGO}; animation: spv-spin 0.8s linear infinite;`;
const spinnerLabel = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${INK_SOFT};`;

// The displacement zone — drawn BELOW the high footer to show the cause/effect:
// when the real list arrives it needs this much room, and that room appears
// between the spinner and the footer, shoving the footer down to the dashed line
// at the foot of this band. A dashed amber band with a down-arrow + note.
const ghostZone = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; height: 78px; margin: 0; padding: 0 8px; border: 1px dashed ${AMBER}; border-radius: 8px; background: repeating-linear-gradient(135deg, ${AMBER_BG} 0 7px, ${SURFACE} 7px 14px);`;
const ghostArrow = `margin: 0; font-size: 17px; font-weight: 900; line-height: 1; color: ${AMBER};`;
const ghostText = `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; line-height: 1.3; text-align: center; color: ${AMBER_INK};`;

// ── SKELETON TAB ──
// The skeleton list: rows the height of real invoice rows, so the region's total
// height matches the spinner box + ghost zone combined — i.e. the content's real
// footprint. This is what lets the footer sit at rest from the start.
const skelList = `display: flex; flex-direction: column; gap: 7px; margin: 0;`;
const skelRow = `box-sizing: border-box; display: flex; align-items: center; gap: 9px; margin: 0; padding: 7px 9px; border-radius: 7px; background: ${PANEL_BG}; border: 1px solid ${BORDER};`;
const skelAvatar = `flex: 0 0 auto; width: 18px; height: 18px; margin: 0; border-radius: 50%; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;
const skelBars = `display: flex; flex-direction: column; gap: 5px; flex: 1 1 auto; min-width: 0; margin: 0;`;
const skelBar = (w: string) =>
	`height: 7px; width: ${w}; margin: 0; border-radius: 999px; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;
const skelAmount = `flex: 0 0 auto; height: 7px; width: 26px; margin: 0; border-radius: 999px; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;

// ── The footer / "rest of the page" bar — the thing that gets shoved. Same look
// in both tabs; only its vertical position differs (driven by region height). A
// state badge on the right reads "jumps" (spinner) or "no shift" (skeleton).
const footer = (edge: string, bg: string) =>
	`box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; gap: 8px; margin: 0; padding: 8px 10px; border-radius: 8px; border: 1px solid ${edge}; background: ${bg};`;
const footerLabel = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.2; color: ${INK};`;

// The final-resting guide: a faint dashed line marking where the footer ENDS UP
// once content is in. In the spinner tab it floats below the high footer (the
// target it will drop to); in the skeleton tab the footer already sits on it, so
// it is omitted there.
const guideRow = `display: flex; align-items: center; gap: 7px; margin: 0;`;
const guideLine = `flex: 1 1 auto; height: 0; margin: 0; border-top: 1.5px dashed ${DIM_INK};`;
const guideLabel = `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.2; color: ${DIM_INK}; white-space: nowrap;`;
---

<TabbedContent>
	<TabbedItem
		label="Spinner"
		caption="The spinner is tiny; when the list arrives it grows into the dashed zone and shoves the footer down to the line below — a visible jump."
	>
		<div style={stage}>
			<div style={page}>
				<div style={heading}>
					<span style={headingDot} aria-hidden="true"></span>
					<h3 style={headingText}>Recent activity</h3>
				</div>

				{/* loading region — a short spinner that under-reserves space */}
				<div style={regionHead}>
					<span style={regionTag}>loading &mdash; spinner</span>
					<span style={pill(INDIGO, '#ffffff', INDIGO_INK)}>fallback</span>
				</div>
				<div style={spinnerBox}>
					<span style={spinner} aria-hidden="true"></span>
					<span style={spinnerLabel}>Loading&hellip;</span>
				</div>

				{/* footer sits HIGH, right under the short box — about to be shoved */}
				<div style={footer(AMBER, AMBER_BG)}>
					<span style={footerLabel}>&larr; rest of the page</span>
					<span style={pill(AMBER, '#ffffff', AMBER_INK)}>jumps</span>
				</div>

				{/* the room the real list needs appears here, shoving the footer down */}
				<div style={ghostZone}>
					<span style={ghostArrow} aria-hidden="true">&darr;</span>
					<p style={ghostText}>list needs this room &mdash; footer is shoved down to here</p>
				</div>

				{/* the line the footer ends up on once the list is in */}
				<div style={guideRow}>
					<span style={guideLine} aria-hidden="true"></span>
					<span style={guideLabel}>footer ends up here</span>
					<span style={guideLine} aria-hidden="true"></span>
				</div>
			</div>
		</div>
	</TabbedItem>

	<TabbedItem
		label="Skeleton"
		caption="The skeleton already occupies the list's real footprint, so the footer starts at its final position; the content swaps in place and nothing moves."
	>
		<div style={stage}>
			<div style={page}>
				<div style={heading}>
					<span style={headingDot} aria-hidden="true"></span>
					<h3 style={headingText}>Recent activity</h3>
				</div>

				{/* loading region — a skeleton matching the resolved list's footprint */}
				<div style={regionHead}>
					<span style={regionTag}>loading &mdash; skeleton</span>
					<span style={pill(INDIGO, '#ffffff', INDIGO_INK)}>fallback</span>
				</div>
				<div style={skelList}>
					<div style={skelRow}>
						<span style={skelAvatar} aria-hidden="true"></span>
						<span style={skelBars}>
							<span style={skelBar('70%')}></span>
							<span style={skelBar('40%')}></span>
						</span>
						<span style={skelAmount} aria-hidden="true"></span>
					</div>
					<div style={skelRow}>
						<span style={skelAvatar} aria-hidden="true"></span>
						<span style={skelBars}>
							<span style={skelBar('62%')}></span>
							<span style={skelBar('46%')}></span>
						</span>
						<span style={skelAmount} aria-hidden="true"></span>
					</div>
					<div style={skelRow}>
						<span style={skelAvatar} aria-hidden="true"></span>
						<span style={skelBars}>
							<span style={skelBar('74%')}></span>
							<span style={skelBar('38%')}></span>
						</span>
						<span style={skelAmount} aria-hidden="true"></span>
					</div>
				</div>

				{/* footer already at its final position — nothing to shove */}
				<div style={footer(GREEN, GREEN_BG)}>
					<span style={footerLabel}>&larr; rest of the page</span>
					<span style={pill(GREEN, '#ffffff', GREEN_INK)}>
						<span style={dot(GREEN)} aria-hidden="true"></span>no shift
					</span>
				</div>
			</div>
		</div>
	</TabbedItem>
</TabbedContent>

<style>
	@keyframes spv-spin {
		to {
			transform: rotate(360deg);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		[style*='spv-spin'] {
			animation: none !important;
		}
	}
</style>
