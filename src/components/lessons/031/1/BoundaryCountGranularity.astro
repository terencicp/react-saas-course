---
// Boundary count maps to reveal granularity (diagram id:
// boundary-count-maps-to-granularity, Chapter 031 L1). A compact, horizontal
// two-column HTML/CSS figure making the lesson's central placement claim
// literal: ONE <Suspense> reveals its contents as a single unit; TWO boundaries
// reveal two units independently. It sits right after the one-boundary-vs-two
// CodeVariants and visualizes the same two arrangements (a 10ms profile read +
// an 800ms activity-feed read).
//
// Encoding of the idea:
//   Left  "1 boundary"  — a single indigo-dashed <Suspense> box wrapping BOTH
//      content blocks (Profile, Activity feed), with ONE fallback chip drawn to
//      span the full width beneath it: "1 fallback covers both". A unit badge
//      reads "1 unit"; the note pins the cost — both appear together, at 800ms.
//   Right "2 boundaries" — two separate indigo-dashed <Suspense> boxes, one per
//      read, each with its OWN fallback chip directly beneath it. Unit badge
//      reads "2 units"; the note: Profile at 10ms, Activity feed at 800ms,
//      independent.
// The fallback chips are the load-bearing visual — chip count and chip width
// map one-to-one to boundary count and what each boundary covers.
//
// House style is pinned to this lesson family's SuspenseContractStates: the same
// indigo (boundary), green (fast / ready) and slate palette, color-scheme pinned
// light so the hand-picked tints survive dark mode, `margin: 0` on every inner
// element to defeat Starlight's injected prose margins, and inline style strings
// (no <style> block) so the figure reads the same as its sibling. Wrapped in
// <Figure> per the diagram index and the lesson outline (caption below).

import Figure from '../../../figures/Figure.astro';

// Palette — shared with SuspenseContractStates (031 L1) for visual continuity.
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary card edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)

const INDIGO = '#4f46e5'; // indigo-600 — the Suspense boundary accent
const INDIGO_SOFT = '#eef2ff'; // indigo-50 — boundary wash
const INDIGO_INK = '#3730a3'; // indigo-800 — boundary text

const GREEN = '#16a34a'; // green-600 — the fast read
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const AMBER = '#d97706'; // amber-600 — the slow read
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage: pinned light, slate ink. A responsive 2-col grid that drops to a
// single column on narrow figure cards so neither column is ever crushed.
const stage = `display: grid; grid-template-columns: repeat(auto-fit, minmax(248px, 1fr)); gap: 16px; align-items: start; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// One column = heading + arrangement + note, as a vertical stack.
const column = `display: flex; flex-direction: column; gap: 10px; margin: 0; min-width: 0;`;

// Column heading row: an h-count label + a "N unit(s)" badge on the right.
const colHead = `display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin: 0;`;
const colTitle = `margin: 0; font-family: ${sans}; font-size: 14px; font-weight: 800; letter-spacing: -0.01em; color: ${INK};`;
const unitBadge = (count: string) =>
	`display: inline-flex; align-items: center; margin: 0; padding: 2px 9px; border: 1px solid ${INDIGO}; border-radius: 999px; background: ${INDIGO_SOFT}; color: ${INDIGO_INK}; font-family: ${sans}; font-size: 9.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.3; white-space: nowrap;`;

// A <Suspense> boundary box — indigo dashed edge, faint indigo wash, with a
// "fieldset legend" eyebrow on its top-left.
const boundaryBox = `position: relative; box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 16px 12px 12px; border: 1.5px dashed ${INDIGO}; border-radius: 11px; background: ${INDIGO_SOFT};`;
const boundaryTag = `position: absolute; top: -9px; left: 12px; margin: 0; padding: 1px 7px; border-radius: 6px; background: ${INDIGO}; color: #ffffff; font-family: ${mono}; font-size: 10px; font-weight: 700; line-height: 1.4; white-space: nowrap;`;

// A content block inside a boundary (a read / widget). A small latency tag on
// the right colours by speed: green = fast read, amber = slow read.
const contentBlock = (edge: string) =>
	`box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; gap: 8px; margin: 0; padding: 8px 10px; border-radius: 8px; background: ${SURFACE}; border: 1px solid ${edge}; min-width: 0;`;
const blockName = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 700; line-height: 1.2; color: ${INK}; white-space: nowrap;`;
const latencyTag = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; flex: 0 0 auto; margin: 0; padding: 1px 7px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${mono}; font-size: 10px; font-weight: 700; line-height: 1.35; white-space: nowrap;`;
const dot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 5px; height: 5px; margin: 0; border-radius: 50%; background: ${c};`;

// A fallback chip: the UI a boundary shows while suspended. Width is meaningful
// — a chip that spans both blocks means one fallback covers both reads.
const fallbackChip = `box-sizing: border-box; display: flex; align-items: center; gap: 7px; margin: 0; padding: 6px 10px; border: 1px dashed ${INDIGO}; border-radius: 8px; background: ${SURFACE};`;
const chipBars = `display: inline-flex; flex-direction: column; gap: 3px; flex: 0 0 auto; margin: 0;`;
const chipBar = (w: string) =>
	`display: block; height: 4px; width: ${w}; margin: 0; border-radius: 999px; background: ${BORDER};`;
const chipLabel = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.25; color: ${INDIGO_INK};`;

// The small "↑ covers" connector between a boundary and its fallback chip.
const coversRow = `display: flex; align-items: center; gap: 6px; margin: 0; padding: 0 2px;`;
const coversArrow = `flex: 0 0 auto; margin: 0; font-size: 12px; font-weight: 800; line-height: 1; color: ${INK_SOFT};`;
const coversText = `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; color: ${INK_SOFT};`;

// Per-read group on the right column: a boundary box immediately followed by its
// own fallback chip, so the 1-boundary-to-1-fallback pairing is unmistakable.
const readGroup = `display: flex; flex-direction: column; gap: 6px; margin: 0;`;

// The reveal note pinned to the foot of each column.
const note = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 600; line-height: 1.45; color: ${INK_SOFT};`;
const noteStrong = (c: string) => `color: ${c}; font-weight: 700;`;
---

<Figure caption="Boundary count is reveal granularity. One boundary reveals its contents as one unit; two boundaries reveal two units independently.">
	<div style={stage}>
		{/* ---- Left: one shared boundary wrapping both reads ---- */}
		<div style={column}>
			<div style={colHead}>
				<h3 style={colTitle}>1 boundary</h3>
				<span style={unitBadge('1 unit')}>1 unit</span>
			</div>

			{/* one <Suspense> around both reads */}
			<div style={boundaryBox}>
				<span style={boundaryTag}>&lt;Suspense&gt;</span>
				<div style={contentBlock(BORDER)}>
					<span style={blockName}>Profile</span>
					<span style={latencyTag(GREEN, GREEN_BG, GREEN_INK)}>
						<span style={dot(GREEN)} aria-hidden="true"></span>~10ms
					</span>
				</div>
				<div style={contentBlock(BORDER)}>
					<span style={blockName}>Activity feed</span>
					<span style={latencyTag(AMBER, AMBER_BG, AMBER_INK)}>
						<span style={dot(AMBER)} aria-hidden="true"></span>~800ms
					</span>
				</div>
			</div>

			{/* one fallback covering everything below the single boundary */}
			<div style={coversRow}>
				<span style={coversArrow} aria-hidden="true">&uarr;</span>
				<span style={coversText}>1 fallback covers both</span>
			</div>
			<div style={fallbackChip}>
				<span style={chipBars} aria-hidden="true">
					<span style={chipBar('30px')}></span>
					<span style={chipBar('22px')}></span>
				</span>
				<span style={chipLabel}>shared fallback</span>
			</div>

			<p style={note}>
				All-or-nothing: the fast profile is held back until the feed resolves &mdash; <span
					style={noteStrong(INK)}>both appear together, at ~800ms</span
				>.
			</p>
		</div>

		{/* ---- Right: one boundary per read ---- */}
		<div style={column}>
			<div style={colHead}>
				<h3 style={colTitle}>2 boundaries</h3>
				<span style={unitBadge('2 units')}>2 units</span>
			</div>

			{/* profile gets its own boundary + its own fallback */}
			<div style={readGroup}>
				<div style={boundaryBox}>
					<span style={boundaryTag}>&lt;Suspense&gt;</span>
					<div style={contentBlock(BORDER)}>
						<span style={blockName}>Profile</span>
						<span style={latencyTag(GREEN, GREEN_BG, GREEN_INK)}>
							<span style={dot(GREEN)} aria-hidden="true"></span>~10ms
						</span>
					</div>
				</div>
				<div style={fallbackChip}>
					<span style={chipBars} aria-hidden="true">
						<span style={chipBar('26px')}></span>
					</span>
					<span style={chipLabel}>own fallback</span>
				</div>
			</div>

			{/* activity feed gets its own boundary + its own fallback */}
			<div style={readGroup}>
				<div style={boundaryBox}>
					<span style={boundaryTag}>&lt;Suspense&gt;</span>
					<div style={contentBlock(BORDER)}>
						<span style={blockName}>Activity feed</span>
						<span style={latencyTag(AMBER, AMBER_BG, AMBER_INK)}>
							<span style={dot(AMBER)} aria-hidden="true"></span>~800ms
						</span>
					</div>
				</div>
				<div style={fallbackChip}>
					<span style={chipBars} aria-hidden="true">
						<span style={chipBar('26px')}></span>
					</span>
					<span style={chipLabel}>own fallback</span>
				</div>
			</div>

			<p style={note}>
				Two independent units: <span style={noteStrong(GREEN_INK)}>Profile paints at ~10ms</span>,
				the feed fills in at ~800ms.
			</p>
		</div>
	</div>
</Figure>
