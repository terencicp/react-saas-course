---
// The fallback contract, as two states (diagram id: suspense-contract-states,
// Chapter 031 L1). A two-step scrubbable DiagramSequence cementing the lesson's
// core claim: ONE <Suspense> boundary has exactly TWO visual states, and the
// CHILD finishing — not any code the student writes — is what flips it.
//
// Fixed motif so the grid stack never reflows between the two steps: a single
// indigo-dashed <Suspense> card whose chrome is IDENTICAL across both steps —
// the same eyebrow, the same fallback={<InvoiceSkeleton />} signature line, the
// same fixed-height content frame. Only three things change between the steps:
//   (a) the status pill in the header  (fallback -> resolved)
//   (b) what the content frame shows    (skeleton bars -> real invoice rows)
//   (c) the CHILD chip below the card    (<InvoiceList /> loading… -> resolved)
// The child chip is the driver: the verdict pins the swap to it, and explicitly
// says nothing the student wrote changed between the frames.
//
// House style matches this lesson family's UseSuspendLifecycle (ch.025 L7) and
// KeyChangeRemountSequence (ch.023 L5): fixed slate ink, color-scheme pinned
// light so the hand-picked indigo/amber/green tints survive dark mode, and
// `margin: 0` on every inner element to defeat Starlight's injected prose
// margins. Per the diagram index this is a temporal swap the reader scrubs — a
// DiagramSequence — authored as plain HTML+CSS, its own card (not in <Figure>).

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary card edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)
const DIM_INK = '#94a3b8'; // greyed ink (slate-400)

const INDIGO = '#4f46e5'; // indigo-600 — the Suspense boundary accent
const INDIGO_SOFT = '#eef2ff'; // indigo-50 — boundary wash
const INDIGO_INK = '#3730a3'; // indigo-800 — boundary text

const GREEN = '#16a34a'; // green-600 — resolved / live
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const AMBER = '#d97706'; // amber-600 — the child still loading
const AMBER_BG = '#fef3c7'; // amber-100
const AMBER_INK = '#92400e'; // amber-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by both steps: pinned light, slate ink, centered column so
// the two steps are the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The single Suspense boundary card — indigo dashed edge so it reads as "a
// wrapper", faint indigo wash. Identical chrome across both steps.
const boundaryCard = `box-sizing: border-box; display: flex; flex-direction: column; gap: 10px; width: 100%; max-width: 380px; margin: 0; padding: 12px 13px 13px; border: 1.5px dashed ${INDIGO}; border-radius: 12px; background: ${INDIGO_SOFT};`;

// The eyebrow header line: a tiny label + a status pill on the right.
const cardHead = `display: flex; align-items: center; justify-content: space-between; gap: 8px; margin: 0;`;
const cardEyebrow = `margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${INDIGO_INK};`;
const pill = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 2px 8px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.3; white-space: nowrap;`;
const dot = (c: string) => `display: inline-block; flex: 0 0 auto; width: 6px; height: 6px; margin: 0; border-radius: 50%; background: ${c};`;

// The fallback signature line — constant across both steps, so the reader sees
// the SAME source code produced both frames.
const sigWrap = `display: flex; align-items: center; gap: 6px; margin: 0; padding: 7px 9px; border-radius: 8px; background: ${SURFACE}; border: 1px solid ${BORDER}; overflow: hidden;`;
const sigCode = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 600; line-height: 1.3; color: ${INK}; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;`;
const sigKeyword = `color: ${INDIGO}; font-weight: 700;`;

// A fixed-height content frame so the slot is the same footprint whether it
// holds the skeleton fallback or the live invoice rows.
const contentFrame = `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 7px; min-height: 104px; margin: 0; padding: 10px 11px; border-radius: 8px; border: 1px dashed ${INDIGO}; background: ${SURFACE};`;
const contentTag = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${ink};`;

// The skeleton fallback (step 1): three grey shimmer bars of unequal width.
const skeletonStack = `display: flex; flex-direction: column; gap: 8px; margin: 0;`;
const skelRow = `display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 0;`;
const skelBar = (w: string) =>
	`height: 9px; width: ${w}; margin: 0; border-radius: 999px; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;

// The live invoice list (step 2): a small <ul> of real rows with amounts.
const list = `list-style: none; display: flex; flex-direction: column; gap: 5px; margin: 0; padding: 0;`;
const listItem = `display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 0; padding: 5px 9px; border-radius: 6px; background: ${PANEL_BG}; border: 1px solid ${BORDER};`;
const itemNo = `display: flex; align-items: center; gap: 7px; margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${INK};`;
const itemAmount = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${INK}; font-variant-numeric: tabular-nums;`;
const itemDot = `display: inline-block; flex: 0 0 auto; width: 5px; height: 5px; margin: 0; border-radius: 50%; background: ${GREEN};`;

// The CHILD chip below the card — the driver of the swap. An arrow points up
// into the boundary; its state pill is what changes between the two steps.
const childWrap = `display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 10px; border-radius: 10px; background: ${SURFACE}; border: 1px solid ${BORDER}; width: 100%; max-width: 380px; box-sizing: border-box;`;
const childArrow = `flex: 0 0 auto; margin: 0; font-size: 14px; font-weight: 800; line-height: 1; color: ${INK_SOFT};`;
const childName = `margin: 0; font-family: ${mono}; font-size: 11.5px; font-weight: 700; line-height: 1.2; color: ${INK}; white-space: nowrap;`;
const childState = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; margin: 0 0 0 auto; padding: 2px 8px; border: 1px solid ${edge}; border-radius: 6px; background: ${bg}; color: ${ink}; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.25; white-space: nowrap;`;

// The one-line verdict under the stack. `tone` picks the ink; fixed min-height
// keeps the footprint stable across the two steps.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.4; color: ${tone}; max-width: 380px; text-align: center; min-height: 16px;`;
---

<DiagramSequence>
	{/* ---- Step 1: child suspends -> the boundary shows its fallback ---- */}
	<DiagramStep caption="Suspended → the boundary renders its fallback. InvoiceList is still awaiting its data, so the real list is not on screen — the InvoiceSkeleton is.">
		<div style={stage}>
			<div style={boundaryCard}>
				<div style={cardHead}>
					<span style={cardEyebrow}>&lt;Suspense&gt; boundary</span>
					<span style={pill(INDIGO, '#ffffff', INDIGO_INK)}>fallback</span>
				</div>
				<div style={sigWrap}>
					<code style={sigCode}
						><span style={sigKeyword}>&lt;Suspense</span> fallback={'{'}&lt;InvoiceSkeleton /&gt;{'}'}&gt;</code
					>
				</div>
				<div style={contentFrame}>
					<p style={contentTag(INDIGO_INK)}>showing &mdash; &lt;InvoiceSkeleton /&gt;</p>
					<div style={skeletonStack}>
						<div style={skelRow}>
							<span style={skelBar('38%')}></span>
							<span style={skelBar('20%')}></span>
						</div>
						<div style={skelRow}>
							<span style={skelBar('44%')}></span>
							<span style={skelBar('18%')}></span>
						</div>
						<div style={skelRow}>
							<span style={skelBar('34%')}></span>
							<span style={skelBar('22%')}></span>
						</div>
					</div>
				</div>
			</div>

			{/* the child — the driver: still loading */}
			<div style={childWrap}>
				<span style={childArrow} aria-hidden="true">&uarr;</span>
				<span style={childName}>&lt;InvoiceList /&gt;</span>
				<span style={childState(AMBER, AMBER_BG, AMBER_INK)}>still loading&hellip;</span>
			</div>

			<p style={verdict(INDIGO_INK)}>
				A child below the boundary said &ldquo;not yet,&rdquo; so the fallback is on screen in its place.
			</p>
		</div>
	</DiagramStep>

	{/* ---- Step 2: child resolves -> the boundary shows its children ---- */}
	<DiagramStep caption="Resolved → the boundary renders its children. InvoiceList finished awaiting, so React swapped the skeleton for the real list. Nothing you wrote changed between these two frames — the child settling flipped the state.">
		<div style={stage}>
			<div style={boundaryCard}>
				<div style={cardHead}>
					<span style={cardEyebrow}>&lt;Suspense&gt; boundary</span>
					<span style={pill(GREEN, GREEN_BG, GREEN_INK)}>
						<span style={dot(GREEN)} aria-hidden="true"></span>
						resolved
					</span>
				</div>
				<div style={sigWrap}>
					<code style={sigCode}
						><span style={sigKeyword}>&lt;Suspense</span> fallback={'{'}&lt;InvoiceSkeleton /&gt;{'}'}&gt;</code
					>
				</div>
				<div style={contentFrame}>
					<p style={contentTag(GREEN_INK)}>showing &mdash; &lt;InvoiceList /&gt;</p>
					<ul style={list}>
						<li style={listItem}>
							<span style={itemNo}><span style={itemDot} aria-hidden="true"></span>INV-1042</span>
							<span style={itemAmount}>$1,200</span>
						</li>
						<li style={listItem}>
							<span style={itemNo}><span style={itemDot} aria-hidden="true"></span>INV-1043</span>
							<span style={itemAmount}>$840</span>
						</li>
						<li style={listItem}>
							<span style={itemNo}><span style={itemDot} aria-hidden="true"></span>INV-1044</span>
							<span style={itemAmount}>$2,310</span>
						</li>
					</ul>
				</div>
			</div>

			{/* the child — the driver: now resolved */}
			<div style={childWrap}>
				<span style={childArrow} aria-hidden="true">&uarr;</span>
				<span style={childName}>&lt;InvoiceList /&gt;</span>
				<span style={childState(GREEN, GREEN_BG, GREEN_INK)}>
					<span style={dot(GREEN)} aria-hidden="true"></span>
					resolved
				</span>
			</div>

			<p style={verdict(GREEN_INK)}>
				The <strong>child</strong> finished &mdash; that, not any code you wrote, is what flipped the boundary to its children.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
