---
// Nested boundaries compose into a reveal cascade (diagram id:
// nested-reveal-cascade, Chapter 031 L1). A three-step scrubbable
// DiagramSequence showing the shell -> partial -> full reveal produced by ONE
// <Suspense> nested inside another — with no orchestration code. It sits right
// before the nested-JSX Code fence (outer <Suspense fallback={PageSkeleton}>
// wrapping a <DashboardHeader /> plus an inner <Suspense fallback={FeedSkeleton}>
// around the slow <ActivityFeed />), and is the visual of exactly that shape.
//
// Encoding of the idea — a single fixed page frame whose GEOMETRY never changes
// across the three steps; only contents and boundary status flip:
//   • An OUTER indigo-dashed boundary (legend: <Suspense> · PageSkeleton) wraps
//     the whole page: a header region + a content region.
//   • An INNER indigo-dashed boundary (legend: <Suspense> · FeedSkeleton) wraps
//     ONLY the content region, sitting nested inside the outer one.
//   • Each boundary carries a status pill that is the driver of the cascade:
//        Step 1  outer = fallback,   inner = (covered) — whole page is shell.
//        Step 2  outer = resolved,   inner = fallback   — header real, feed shell.
//        Step 3  outer = resolved,   inner = resolved   — full content.
// The header region greys -> real between steps 1 and 2; the content region
// greys -> real between steps 2 and 3. Because the inner boundary is drawn
// nested in the outer, the reader sees "skeleton -> partial -> full" IS the
// nesting, with no coordinating state.
//
// House style is pinned to this lesson family (SuspenseContractStates,
// BoundaryCountGranularity, both 031 L1): the same indigo (boundary), green
// (resolved) and slate palette; color-scheme pinned light so the hand-picked
// tints survive dark mode; `margin: 0` on every inner element to defeat
// Starlight's injected prose margins; inline style strings (no <style> block).
// Per the diagram index + outline this is a temporal swap the reader scrubs — a
// DiagramSequence — authored as plain HTML+CSS, its own card (not in <Figure>).

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette — shared with SuspenseContractStates / BoundaryCountGranularity.
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff'; // ordinary card surface
const BORDER = '#cbd5e1'; // ordinary card edge (slate-300)
const PANEL_BG = '#f1f5f9'; // inner wash (slate-100)
const DIM_INK = '#94a3b8'; // greyed ink (slate-400)

const INDIGO = '#4f46e5'; // indigo-600 — the Suspense boundary accent
const INDIGO_SOFT = '#eef2ff'; // indigo-50 — boundary wash
const INDIGO_INK = '#3730a3'; // indigo-800 — boundary text

const GREEN = '#16a34a'; // green-600 — resolved / live
const GREEN_BG = '#dcfce7'; // green-100
const GREEN_INK = '#166534'; // green-800

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage shared by all three steps: pinned light, slate ink, a centered
// column so every step is the same shape and the grid stack never reflows.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 12px; margin: 0; padding: 2px 0; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// ── The OUTER <Suspense> boundary — a dashed indigo frame around the whole page
// frame. A "fieldset legend" eyebrow on its top-left names the boundary and its
// fallback; a status pill on the top-right is the driver of the cascade.
const outerBoundary = `position: relative; box-sizing: border-box; display: flex; flex-direction: column; gap: 10px; width: 100%; max-width: 392px; margin: 0; padding: 18px 13px 14px; border: 1.5px dashed ${INDIGO}; border-radius: 13px; background: ${INDIGO_SOFT};`;

// The INNER <Suspense> boundary — a nested dashed indigo frame around only the
// content region, sitting inside the outer one. Same legend + status-pill motif
// so the reader reads "a boundary inside a boundary".
const innerBoundary = `position: relative; box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 17px 11px 11px; border: 1.5px dashed ${INDIGO}; border-radius: 11px; background: ${SURFACE};`;

// The legend tag pinned to a boundary's top-left: "<Suspense> · Fallback".
const legend = `position: absolute; top: -10px; left: 12px; display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 1px 8px; border-radius: 6px; background: ${INDIGO}; color: #ffffff; font-family: ${mono}; font-size: 10px; font-weight: 700; line-height: 1.45; white-space: nowrap;`;
const legendSub = `color: #c7d2fe; font-family: ${mono}; font-size: 10px; font-weight: 600;`;

// The status pill pinned to a boundary's top-right. `state` picks the look:
// indigo "fallback", green "resolved", or a muted "covered" for the inner
// boundary while the outer fallback hides it entirely.
type PillKind = 'fallback' | 'resolved' | 'covered';
const pill = (kind: PillKind) => {
	const map = {
		fallback: { edge: INDIGO, bg: '#ffffff', ink: INDIGO_INK },
		resolved: { edge: GREEN, bg: GREEN_BG, ink: GREEN_INK },
		covered: { edge: BORDER, bg: PANEL_BG, ink: DIM_INK },
	} as const;
	const c = map[kind];
	return `position: absolute; top: -9px; right: 12px; display: inline-flex; align-items: center; gap: 5px; margin: 0; padding: 2px 8px; border: 1px solid ${c.edge}; border-radius: 999px; background: ${c.bg}; color: ${c.ink}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.3; white-space: nowrap;`;
};
const dot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 6px; height: 6px; margin: 0; border-radius: 50%; background: ${c};`;

// ── The HEADER region inside the outer boundary. Fixed geometry across all
// steps; only its contents grey-out (shell) or become real. `tone` switches the
// palette between the skeleton state and the real state.
const headerRegion = (real: boolean) =>
	`box-sizing: border-box; display: flex; align-items: center; gap: 9px; margin: 0; padding: 9px 11px; border-radius: 9px; background: ${real ? SURFACE : PANEL_BG}; border: 1px ${real ? 'solid' : 'dashed'} ${real ? BORDER : DIM_INK};`;
// Real header: a small mark + a "Dashboard" title + two nav chips.
const brandMark = `flex: 0 0 auto; width: 18px; height: 18px; margin: 0; border-radius: 6px; background: ${INDIGO}; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.25);`;
const brandTitle = `margin: 0; font-family: ${sans}; font-size: 13px; font-weight: 800; letter-spacing: -0.01em; line-height: 1.2; color: ${INK};`;
const navRow = `display: flex; align-items: center; gap: 6px; margin: 0 0 0 auto;`;
const navChip = `margin: 0; padding: 2px 8px; border-radius: 999px; background: ${PANEL_BG}; border: 1px solid ${BORDER}; font-family: ${sans}; font-size: 10px; font-weight: 600; line-height: 1.3; color: ${INK_SOFT};`;
// Skeleton header: a grey square + two shimmer bars.
const skelSquare = `flex: 0 0 auto; width: 18px; height: 18px; margin: 0; border-radius: 6px; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;
const skelBar = (w: string) =>
	`height: 9px; width: ${w}; margin: 0; border-radius: 999px; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;

// A tiny eyebrow naming what the region is currently showing.
const showingTag = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${ink};`;

// ── The CONTENT region inside the inner boundary. Fixed min-height so the
// content area is the same footprint whether it holds the feed skeleton or the
// real activity feed.
const contentRegion = `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 7px; min-height: 92px; margin: 0;`;
// Skeleton feed rows.
const skelFeed = `display: flex; flex-direction: column; gap: 8px; margin: 0;`;
const skelFeedRow = `display: flex; align-items: center; gap: 9px; margin: 0;`;
const skelAvatar = `flex: 0 0 auto; width: 22px; height: 22px; margin: 0; border-radius: 50%; background: linear-gradient(90deg, ${BORDER} 0%, ${PANEL_BG} 50%, ${BORDER} 100%);`;
// Real feed rows: an avatar dot + a line of text + a timestamp.
const feedList = `list-style: none; display: flex; flex-direction: column; gap: 6px; margin: 0; padding: 0;`;
const feedItem = `display: flex; align-items: center; gap: 9px; margin: 0; padding: 5px 8px; border-radius: 7px; background: ${PANEL_BG}; border: 1px solid ${BORDER};`;
const feedAvatar = `flex: 0 0 auto; width: 22px; height: 22px; margin: 0; border-radius: 50%; background: ${GREEN_BG}; border: 1px solid ${GREEN};`;
const feedText = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 600; line-height: 1.2; color: ${INK}; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;`;
const feedTime = `margin: 0 0 0 auto; font-family: ${mono}; font-size: 9.5px; font-weight: 600; line-height: 1.2; color: ${INK_SOFT}; white-space: nowrap;`;

// The one-line verdict under each step. `tone` picks the ink; a fixed min-height
// keeps the footprint stable across the three steps.
const verdict = (tone: string) =>
	`margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.4; color: ${tone}; max-width: 392px; text-align: center; min-height: 16px;`;
---

<DiagramSequence>
	{/* ── Step 1: outer fallback covers everything — the whole page is a shell ── */}
	<DiagramStep
		caption="Outer fallback covers everything. Its directly-awaited content (the header) isn't ready, so the whole page is the outer PageSkeleton — the inner boundary is hidden behind it."
	>
		<div style={stage}>
			<div style={outerBoundary}>
				<span style={legend}>
					&lt;Suspense&gt; <span style={legendSub}>· PageSkeleton</span>
				</span>
				<span style={pill('fallback')}>fallback</span>

				{/* header region — shell */}
				<div style={headerRegion(false)}>
					<span style={skelSquare} aria-hidden="true"></span>
					<span style={skelBar('34%')}></span>
					<span style={{ marginLeft: 'auto' }}></span>
					<span style={skelBar('22%')}></span>
				</div>

				{/* inner boundary — covered by the outer fallback */}
				<div style={innerBoundary}>
					<span style={legend}>
						&lt;Suspense&gt; <span style={legendSub}>· FeedSkeleton</span>
					</span>
					<span style={pill('covered')}>covered</span>
					<div style={contentRegion}>
						<div style={skelFeed}>
							<div style={skelFeedRow}>
								<span style={skelAvatar} aria-hidden="true"></span>
								<span style={skelBar('52%')}></span>
							</div>
							<div style={skelFeedRow}>
								<span style={skelAvatar} aria-hidden="true"></span>
								<span style={skelBar('44%')}></span>
							</div>
							<div style={skelFeedRow}>
								<span style={skelAvatar} aria-hidden="true"></span>
								<span style={skelBar('60%')}></span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<p style={verdict(INDIGO_INK)}>
				Step 1 of 3 &mdash; the entire page is the <strong>outer</strong> skeleton.
			</p>
		</div>
	</DiagramStep>

	{/* ── Step 2: outer resolves — header is real, inner region still a shell ── */}
	<DiagramStep
		caption="Outer resolves. The header paints with real content, and the inner boundary takes over — showing its own FeedSkeleton while the slow ActivityFeed is still awaiting, with everything around it already on screen."
	>
		<div style={stage}>
			<div style={outerBoundary}>
				<span style={legend}>
					&lt;Suspense&gt; <span style={legendSub}>· PageSkeleton</span>
				</span>
				<span style={pill('resolved')}>
					<span style={dot(GREEN)} aria-hidden="true"></span>resolved
				</span>

				{/* header region — real */}
				<div style={headerRegion(true)}>
					<span style={brandMark} aria-hidden="true"></span>
					<span style={brandTitle}>Dashboard</span>
					<span style={navRow}>
						<span style={navChip}>Invoices</span>
						<span style={navChip}>Settings</span>
					</span>
				</div>

				{/* inner boundary — now showing ITS fallback */}
				<div style={innerBoundary}>
					<span style={legend}>
						&lt;Suspense&gt; <span style={legendSub}>· FeedSkeleton</span>
					</span>
					<span style={pill('fallback')}>fallback</span>
					<div style={contentRegion}>
						<p style={showingTag(INDIGO_INK)}>showing &mdash; &lt;FeedSkeleton /&gt;</p>
						<div style={skelFeed}>
							<div style={skelFeedRow}>
								<span style={skelAvatar} aria-hidden="true"></span>
								<span style={skelBar('52%')}></span>
							</div>
							<div style={skelFeedRow}>
								<span style={skelAvatar} aria-hidden="true"></span>
								<span style={skelBar('44%')}></span>
							</div>
							<div style={skelFeedRow}>
								<span style={skelAvatar} aria-hidden="true"></span>
								<span style={skelBar('60%')}></span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<p style={verdict(INDIGO_INK)}>
				Step 2 of 3 &mdash; <strong>shell + header real</strong>, the inner region is still its own skeleton.
			</p>
		</div>
	</DiagramStep>

	{/* ── Step 3: inner resolves — full content on screen ── */}
	<DiagramStep
		caption="Inner resolves. The ActivityFeed finished its slow read, so React swaps the FeedSkeleton for the real feed. Full content on screen — three visual states, and you wrote zero coordinating state."
	>
		<div style={stage}>
			<div style={outerBoundary}>
				<span style={legend}>
					&lt;Suspense&gt; <span style={legendSub}>· PageSkeleton</span>
				</span>
				<span style={pill('resolved')}>
					<span style={dot(GREEN)} aria-hidden="true"></span>resolved
				</span>

				{/* header region — real */}
				<div style={headerRegion(true)}>
					<span style={brandMark} aria-hidden="true"></span>
					<span style={brandTitle}>Dashboard</span>
					<span style={navRow}>
						<span style={navChip}>Invoices</span>
						<span style={navChip}>Settings</span>
					</span>
				</div>

				{/* inner boundary — resolved, real feed */}
				<div style={innerBoundary}>
					<span style={legend}>
						&lt;Suspense&gt; <span style={legendSub}>· FeedSkeleton</span>
					</span>
					<span style={pill('resolved')}>
						<span style={dot(GREEN)} aria-hidden="true"></span>resolved
					</span>
					<div style={contentRegion}>
						<p style={showingTag(GREEN_INK)}>showing &mdash; &lt;ActivityFeed /&gt;</p>
						<ul style={feedList}>
							<li style={feedItem}>
								<span style={feedAvatar} aria-hidden="true"></span>
								<span style={feedText}>Maya paid INV-1042</span>
								<span style={feedTime}>2m</span>
							</li>
							<li style={feedItem}>
								<span style={feedAvatar} aria-hidden="true"></span>
								<span style={feedText}>Leo opened INV-1043</span>
								<span style={feedTime}>9m</span>
							</li>
							<li style={feedItem}>
								<span style={feedAvatar} aria-hidden="true"></span>
								<span style={feedText}>Ada refunded INV-1041</span>
								<span style={feedTime}>14m</span>
							</li>
						</ul>
					</div>
				</div>
			</div>

			<p style={verdict(GREEN_INK)}>
				Step 3 of 3 &mdash; <strong>full content</strong>, produced by nesting alone &mdash; no orchestration code.
			</p>
		</div>
	</DiagramStep>
</DiagramSequence>
