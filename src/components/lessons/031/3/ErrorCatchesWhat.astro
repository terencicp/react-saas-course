---
// error-catches-what (diagram id: figure-error-catches-what, Chapter 031 L3).
// The asymmetry of what an `error.tsx` boundary catches, rendered as physical
// containment: things INSIDE the boundary box are caught; the layout the file
// sits BESIDE is the boundary's PARENT and wraps the box from the outside, so a
// throw there happens before the boundary exists.
//
//   OUTER  — `layout.tsx (this segment)`, neutral/grey "outside the boundary".
//            Carries a red ✕ and the note "not caught — boundary's parent",
//            because a render error here escapes upward past the box.
//   INNER  — `error.tsx boundary`, a red/orange dashed ring. Anything inside it
//            bubbles up to error.tsx ("throws here bubble up to error.tsx").
//   LEAVES — three boxes inside the boundary, each green-checked "caught":
//            `page.tsx`, `nested layout.tsx`, `child components`.
//
// The containment IS the argument: the boundary lives inside the layout's
// subtree, not around it. Nesting is real DOM nesting so devtools shows the
// true hierarchy.
//
// Pure HTML + CSS, no JS. color-scheme pinned light so the semantic tints
// (grey = outside, red = the boundary, green = caught) survive dark mode;
// margin:0 on every inner element defeats Starlight's injected prose margins.
// The <style> block carries only the legend-pill straddle and the narrow-
// viewport stack.

import Figure from '../../../figures/Figure.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)
const SURFACE = '#ffffff';

// Neutral — the layout "outside the boundary"
const SLATE_BG = '#f1f5f9'; // slate-100 wash
const SLATE_EDGE = '#cbd5e1'; // slate-300 edge
const SLATE_INK = '#475569'; // slate-600

// The boundary — red / orange ring
const RED = '#dc2626'; // red-600
const RED_BG = '#fef2f2'; // red-50 wash
const RED_EDGE = '#fca5a5'; // red-300
const RED_INK = '#b91c1c'; // red-700

// Caught — green
const GREEN = '#16a34a'; // green-600
const GREEN_BG = '#f0fdf4'; // green-50 wash
const GREEN_EDGE = '#bbf7d0'; // green-200 edge
const GREEN_INK = '#15803d'; // green-700

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage. Fixed-ish max width centred; the diagram is a single nested
// stack so width can stay fluid up to a cap.
const stage = `margin: 0 auto; max-width: 640px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The outer layout box — the boundary's PARENT. Relative so its legend pill and
// the corner ✕ badge position against it.
const outerBox = `position: relative; margin: 0; padding: 34px 16px 16px; border: 1.5px solid ${SLATE_EDGE}; border-radius: 14px; background: ${SLATE_BG}; box-sizing: border-box;`;

// The "not caught" note sitting just under the outer box's legend, before the
// boundary — the escape route a layout throw takes.
const escapeNote = `display: flex; align-items: center; gap: 7px; margin: 0 0 12px; font-family: ${sans}; font-size: 12px; line-height: 1.35; color: ${SLATE_INK};`;

// The red ✕ badge that marks the outer layout as "not caught".
const crossBadge = `display: inline-flex; align-items: center; justify-content: center; flex: none; width: 18px; height: 18px; margin: 0; border-radius: 50%; background: ${RED}; color: ${SURFACE}; font-family: ${sans}; font-size: 12px; font-weight: 900; line-height: 1;`;

// The inner error boundary box — a dashed red ring. Relative for its legend
// pill + the "bubble up" edge note.
const boundaryBox = `position: relative; margin: 0; padding: 30px 14px 14px; border: 2px dashed ${RED_EDGE}; border-radius: 12px; background: ${RED_BG}; box-sizing: border-box;`;

// The "throws here bubble up to error.tsx" edge note inside the boundary, above
// the children.
const bubbleNote = `display: flex; align-items: center; gap: 6px; margin: 0 0 11px; font-family: ${sans}; font-size: 11.5px; line-height: 1.3; color: ${RED_INK};`;

// Up-arrow glyph echoing the bubbling direction.
const upArrow = `flex: none; margin: 0; font-family: ${sans}; font-size: 13px; font-weight: 900; line-height: 1; color: ${RED};`;

// The row of three caught child boxes. Wraps on narrow widths.
const childRow = `display: flex; flex-wrap: wrap; gap: 10px; margin: 0;`;

// A caught child box — green-checked.
const childBox = `flex: 1 1 0; min-width: 130px; display: flex; flex-direction: column; gap: 7px; margin: 0; padding: 11px 12px; background: ${GREEN_BG}; border: 1.5px solid ${GREEN_EDGE}; border-radius: 10px; box-sizing: border-box;`;

// The file name inside a caught box.
const childName = `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.1; color: ${INK};`;

// "caught" row: a green check + the word.
const caughtRow = `display: flex; align-items: center; gap: 6px; margin: 0;`;
const checkBadge = `display: inline-flex; align-items: center; justify-content: center; flex: none; width: 16px; height: 16px; margin: 0; border-radius: 50%; background: ${GREEN}; color: ${SURFACE}; font-family: ${sans}; font-size: 10px; font-weight: 900; line-height: 1;`;
const caughtLabel = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; color: ${GREEN_INK};`;

const children = [
	{ name: 'page.tsx' },
	{ name: 'nested layout.tsx' },
	{ name: 'child components' },
];
---

<Figure
	caption="`error.tsx` wraps the page, nested layouts, and children — but not the layout it sits beside. That layout is the boundary's parent, so its render errors happen before the boundary exists to catch them."
>
	<div class="ecw-stage not-content" style={stage}>
		{/* OUTER — the layout this segment, the boundary's parent. Not caught. */}
		<div class="ecw-outer" style={outerBox}>
			<span class="ecw-legend ecw-legend--slate" style={`background: ${SLATE_BG};`}>
				<code class="ecw-legend-code" style={`color: ${SLATE_INK};`}>layout.tsx</code>
				<span style={`color: ${INK_SOFT};`}>(this segment)</span>
			</span>

			<p style={escapeNote}>
				<span style={crossBadge} aria-hidden="true">&times;</span>
				<span>A throw <strong>here</strong> escapes &mdash; it happens before the boundary exists.</span>
			</p>

			{/* INNER — the error.tsx boundary. Everything inside bubbles up to it. */}
			<div class="ecw-boundary" style={boundaryBox}>
				<span class="ecw-legend ecw-legend--red" style={`background: ${RED_BG};`}>
					<code class="ecw-legend-code" style={`color: ${RED_INK};`}>error.tsx</code>
					<span style={`color: ${RED_INK};`}>boundary</span>
				</span>

				<p style={bubbleNote}>
					<span style={upArrow} aria-hidden="true">&uarr;</span>
					<span>throws here bubble up to <code style={`background: transparent; padding: 0; font-family: ${mono}; color: ${RED_INK}; font-weight: 700;`}>error.tsx</code></span>
				</p>

				<div style={childRow}>
					{
						children.map((c) => (
							<div style={childBox}>
								<span style={childName}>{c.name}</span>
								<span style={caughtRow}>
									<span style={checkBadge} aria-hidden="true">&checkmark;</span>
									<span style={caughtLabel}>caught</span>
								</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</Figure>

<style>
	/* "Fieldset legend" pills straddling each box's top border. Block + fit-content
	   with a negative margin-top lands the pill centred on the border line; the
	   pill's background (set inline to match the box fill) breaks the border
	   where it sits. */
	.ecw-legend {
		display: block;
		width: fit-content;
		margin: 0 0 0 4px;
		padding: 2px 9px;
		border-radius: 999px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 12px;
		font-weight: 700;
		white-space: nowrap;
		line-height: 1.4;
	}

	.ecw-legend-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		font-weight: 800;
		background: transparent;
		padding: 0;
	}

	.ecw-legend--slate {
		/* straddle the outer box's 1.5px border + 34px top padding minus the
		   pill's own half-height (~11px) */
		margin-top: -45px;
	}

	.ecw-legend--red {
		/* straddle the inner boundary's 2px dashed border + 30px top padding */
		margin-top: -41px;
	}

	/* Narrow viewports: let the three caught boxes stack one per row so the
	   monospace file names never get crushed. */
	@media (max-width: 460px) {
		.ecw-stage :global(div[style*='min-width: 130px']) {
			flex-basis: 100% !important;
		}
	}
</style>
