---
// three-boundaries-compose (diagram id: sequence-three-boundaries-compose, Chapter 031 L3).
// How the framework composes loading.tsx / not-found.tsx / error.tsx into three
// NESTED boundaries around one segment, revealed one ring at a time.
//
// The figure is three concentric rings wrapping a neutral `layout -> page.tsx`
// core. Reading from the inside out, the wrap order is FIXED:
//   core      — `layout -> page.tsx`            (neutral white surface)
//   ring 1    — not-found boundary (not-found.tsx)   innermost, blue
//   ring 2    — Suspense (loading.tsx)               middle, grey/neutral
//   ring 3    — error boundary (error.tsx)           outermost, red/orange
// Concentric containment IS the argument: error is outside Suspense, so a throw
// while the skeleton shows replaces the skeleton; not-found is inside Suspense,
// caught after the loading phase, close to the page.
//
// Driven by a DiagramSequence: every step renders ALL three rings so the stage
// never reflows (grid-stack sizes to the tallest step). A ring is `active` once
// it has been added at that step and `pending` (faint dotted ghost) before then.
// level 1 = bare core; 2 = + not-found; 3 = + Suspense; 4 = + error.
//
// Pure HTML + CSS, no JS of its own (DiagramSequence owns the scrubber).
// color-scheme pinned light so the semantic tints survive dark mode; margin:0
// on inner elements defeats Starlight's injected prose margins. Palette and the
// fieldset-legend-pill technique deliberately match ErrorCatchesWhat.astro, the
// sibling figure earlier in this lesson about the same error boundary.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

// Palette --------------------------------------------------------------------
const INK = '#1e293b'; // primary ink (slate-800)
const INK_SOFT = '#64748b'; // secondary text (slate-500)

// Core — the thing being wrapped. Neutral white surface, slate edge.
const CORE_BG = '#ffffff';
const CORE_EDGE = '#cbd5e1'; // slate-300
const CORE_ARROW = '#94a3b8'; // slate-400

// not-found ring — blue
const BLUE_BG = '#eff6ff'; // blue-50
const BLUE_EDGE = '#93c5fd'; // blue-300
const BLUE_INK = '#1d4ed8'; // blue-700

// Suspense ring — neutral / grey
const GREY_BG = '#f1f5f9'; // slate-100
const GREY_EDGE = '#94a3b8'; // slate-400
const GREY_INK = '#475569'; // slate-600

// error ring — red / orange (matches ErrorCatchesWhat)
const RED_BG = '#fef2f2'; // red-50
const RED_EDGE = '#fca5a5'; // red-300
const RED_INK = '#b91c1c'; // red-700

// Ghost (a ring not yet added at this step)
const GHOST_EDGE = '#e2e8f0'; // slate-200
const GHOST_INK = '#cbd5e1'; // slate-300

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// The three rings, from OUTERMOST to innermost — the order they nest in source.
// `addedAt` is the step level at which the ring becomes active.
const RINGS = [
	{
		key: 'error',
		addedAt: 4,
		legendCode: 'error.tsx',
		legendWord: 'error boundary',
		bg: RED_BG,
		edge: RED_EDGE,
		ink: RED_INK,
	},
	{
		key: 'suspense',
		addedAt: 3,
		legendCode: 'loading.tsx',
		legendWord: 'Suspense',
		bg: GREY_BG,
		edge: GREY_EDGE,
		ink: GREY_INK,
	},
	{
		key: 'notfound',
		addedAt: 2,
		legendCode: 'not-found.tsx',
		legendWord: 'not-found boundary',
		bg: BLUE_BG,
		edge: BLUE_EDGE,
		ink: BLUE_INK,
	},
];

const stage = `margin: 0 auto; max-width: 540px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A ring box. Active rings carry their tint + solid edge; pending rings are a
// faint dotted ghost that still occupies its space so the core never shifts.
function ringStyle(active: boolean, edge: string, bg: string) {
	const border = active ? `2px solid ${edge}` : `1.5px dotted ${GHOST_EDGE}`;
	const fill = active ? bg : 'transparent';
	return `position: relative; margin: 0; padding: 32px 16px 16px; border-radius: 14px; border: ${border}; background: ${fill}; box-sizing: border-box; transition: none;`;
}

// The neutral core, always present, always identical.
const coreBox = `display: flex; align-items: center; justify-content: center; gap: 10px; margin: 0; padding: 18px 18px; border: 1.5px solid ${CORE_EDGE}; border-radius: 10px; background: ${CORE_BG}; box-sizing: border-box;`;
const coreLabel = `margin: 0; font-family: ${mono}; font-size: 14px; font-weight: 700; line-height: 1.1; color: ${INK}; white-space: nowrap;`;
const coreArrow = `flex: none; margin: 0; font-family: ${sans}; font-size: 15px; line-height: 1; color: ${CORE_ARROW};`;

// One step per activation level: 1 = bare core, 2 = + not-found, 3 = + Suspense,
// 4 = + error (the full nested wrapper).
const levels = [1, 2, 3, 4];
---

<DiagramSequence>
	{
		levels.map((level) => (
			<DiagramStep>
				<div class="tbc-stage not-content" style={stage}>
					{/* error ring (outermost) */}
					<div style={ringStyle(level >= RINGS[0].addedAt, RINGS[0].edge, RINGS[0].bg)}>
						<span
							class="tbc-legend"
							style={`background: ${level >= RINGS[0].addedAt ? RINGS[0].bg : '#ffffff'};`}
						>
							<code
								class="tbc-legend-code"
								style={`color: ${level >= RINGS[0].addedAt ? RINGS[0].ink : GHOST_INK};`}
							>
								{RINGS[0].legendCode}
							</code>
							<span style={`color: ${level >= RINGS[0].addedAt ? RINGS[0].ink : GHOST_INK};`}>
								{RINGS[0].legendWord}
							</span>
						</span>

						{/* Suspense ring (middle) */}
						<div style={ringStyle(level >= RINGS[1].addedAt, RINGS[1].edge, RINGS[1].bg)}>
							<span
								class="tbc-legend"
								style={`background: ${level >= RINGS[1].addedAt ? RINGS[1].bg : '#ffffff'};`}
							>
								<code
									class="tbc-legend-code"
									style={`color: ${level >= RINGS[1].addedAt ? RINGS[1].ink : GHOST_INK};`}
								>
									{RINGS[1].legendCode}
								</code>
								<span style={`color: ${level >= RINGS[1].addedAt ? RINGS[1].ink : GHOST_INK};`}>
									{RINGS[1].legendWord}
								</span>
							</span>

							{/* not-found ring (innermost) */}
							<div style={ringStyle(level >= RINGS[2].addedAt, RINGS[2].edge, RINGS[2].bg)}>
								<span
									class="tbc-legend"
									style={`background: ${level >= RINGS[2].addedAt ? RINGS[2].bg : '#ffffff'};`}
								>
									<code
										class="tbc-legend-code"
										style={`color: ${level >= RINGS[2].addedAt ? RINGS[2].ink : GHOST_INK};`}
									>
										{RINGS[2].legendCode}
									</code>
									<span style={`color: ${level >= RINGS[2].addedAt ? RINGS[2].ink : GHOST_INK};`}>
										{RINGS[2].legendWord}
									</span>
								</span>

								{/* core — always present */}
								<div style={coreBox}>
									<span style={coreLabel}>layout</span>
									<span style={coreArrow} aria-hidden="true">
										&rarr;
									</span>
									<span style={coreLabel}>page.tsx</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				{level === 1 && (
					<Fragment slot="caption">
						<strong>The bare segment.</strong> With no extra files, the page just renders &mdash; and any
						pending data, missing row, or throw is unhandled.
					</Fragment>
				)}
				{level === 2 && (
					<Fragment slot="caption">
						<code>not-found.tsx</code> &rarr; the <strong>innermost</strong> boundary. It catches a{' '}
						<code>notFound()</code> call from inside the segment.
					</Fragment>
				)}
				{level === 3 && (
					<Fragment slot="caption">
						<code>loading.tsx</code> &rarr; a <strong>Suspense</strong> boundary around that. It shows the
						skeleton while the segment suspends.
					</Fragment>
				)}
				{level === 4 && (
					<Fragment slot="caption">
						<code>error.tsx</code> &rarr; the <strong>outermost</strong> boundary. It catches any throw from
						everything inside &mdash; which is why an error while the skeleton is showing replaces the
						skeleton, not the other way round.
					</Fragment>
				)}
			</DiagramStep>
		))
	}
</DiagramSequence>

<style>
	/* "Fieldset legend" pills straddling each ring's top border — same technique
	   as ErrorCatchesWhat. Block + fit-content with a negative margin-top lands
	   the pill centred on the border line; the pill's inline background (matching
	   the ring fill, or white for a pending ring) breaks the border where it sits. */
	.tbc-legend {
		display: block;
		width: fit-content;
		/* straddle the ring's 2px border + 32px top padding, minus the pill's own
		   half-height (~11px) */
		margin: -43px 0 0 6px;
		padding: 2px 9px;
		border-radius: 999px;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: 12px;
		font-weight: 700;
		white-space: nowrap;
		line-height: 1.4;
	}

	.tbc-legend-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		font-weight: 800;
		background: transparent;
		padding: 0;
		margin-right: 5px;
	}

	/* Narrow viewports: shrink the ring padding so three nested rings + the core
	   still fit without the monospace core label wrapping. */
	@media (max-width: 460px) {
		.tbc-stage :global(div[style*='padding: 32px']) {
			padding-left: 11px !important;
			padding-right: 11px !important;
		}
	}
</style>
