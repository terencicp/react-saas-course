---
// Sequential vs parallel reads on a shared time axis (diagram id:
// gantt-sequential-vs-parallel, Chapter 031 L2). Makes the lesson's central
// latency claim a PICTURE rather than arithmetic the reader does in their head:
//
//   - Sequential awaits SUM:    chart (0–300) then activity (300–1100),
//                               first byte not until the LAST await, at 1100ms.
//   - Parallel boundaries MAX:  chart (0–300) and activity (0–800) both start
//                               at 0 and OVERLAP; the shell + skeletons flush at
//                               ~0, and each widget streams in at its bar's end.
//
// Authored as plain HTML+CSS (the documented fallback for the Gantt shape in
// documentation/diagrams/INDEX.md). A real millisecond axis with labeled
// gridlines and two milestone markers is the whole teaching beat, and HTML+CSS
// gives a clean ms axis where Mermaid's date-based gantt would fight us.
//
// House style follows this chapter's SuspenseContractStates (L1): pinned
// color-scheme light so the hand-picked tints survive dark mode, slate ink, and
// `margin: 0` on every inner element to defeat Starlight's injected prose
// margins. Palette is the chapter family's: AMBER = the slow serial cost (the
// defect being shown), GREEN = the streaming win, INDIGO = the shell flush /
// Suspense accent.

// Shared axis runs 0 -> MAX ms. Bars and ticks position as a % of MAX so both
// sections share one coordinate system (the point of the figure).
const MAX = 1100;
const pct = (ms: number) => `${(ms / MAX) * 100}%`;

// Axis tick stops (ms). 0 / 300 / 800 / 1100 — the four numbers the prose names.
const ticks = [0, 300, 800, 1100];

// Palette ---------------------------------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — secondary text
const GRID = '#e2e8f0'; // slate-200 — gridlines
const AXIS = '#cbd5e1'; // slate-300 — axis baseline / edges

const AMBER = '#d97706'; // amber-600 — slow serial read (the defect)
const AMBER_BG = '#fdba74'; // amber-300 — bar fill
const AMBER_INK = '#7c2d12'; // amber-900 — text on amber

const GREEN = '#16a34a'; // green-600 — streaming read (the win)
const GREEN_BG = '#86efac'; // green-300 — bar fill
const GREEN_INK = '#14532d'; // green-900 — text on green

const INDIGO = '#4f46e5'; // indigo-600 — shell flush / Suspense accent
const INDIGO_INK = '#3730a3'; // indigo-800
const RED = '#dc2626'; // red-600 — "first byte" (the cost the user pays)

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Chrome ----------------------------------------------------------------------
const stage = `display: flex; flex-direction: column; gap: 18px; margin: 0; padding: 4px 2px 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A section: a titled block (header row + plot). The plot is full width so bars
// get the whole coordinate system — no label gutter stealing space.
const section = `display: flex; flex-direction: column; gap: 9px; margin: 0;`;
const sectionHead = `display: flex; align-items: baseline; gap: 8px; margin: 0;`;
const sectionTitle = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 800; line-height: 1.2; color: ${ink};`;
const sectionRule = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 700; line-height: 1.2; color: ${ink};`;

// The plot: a relative box that holds the gridline backdrop, the bars, and the
// milestone markers. Bottom padding leaves room for milestone labels under the
// last bar; the gridlines run the full height including that padding.
const plot = `position: relative; margin: 0; padding: 0;`;

// Gridline backdrop — faint verticals at each tick, behind the bars.
const gridLayer = `position: absolute; inset: 0; margin: 0; pointer-events: none;`;
const gridLine = (ms: number) =>
	`position: absolute; top: 0; bottom: 0; left: ${pct(ms)}; width: 1px; margin: 0; background: ${GRID};`;

// One bar track (a row). Relative so the bar positions inside it by % of width.
const track = `position: relative; height: 28px; margin: 0;`;
const trackGap = `height: 8px; margin: 0;`; // vertical breathing room between bars

// A bar: absolutely placed by left/width %. Label sits inside, ellipsized.
const bar = (startMs: number, endMs: number, fill: string, edge: string, ink: string) =>
	`position: absolute; top: 0; height: 100%; left: ${pct(startMs)}; width: ${pct(endMs - startMs)};` +
	` box-sizing: border-box; display: flex; align-items: center; gap: 6px; margin: 0; padding: 0 9px;` +
	` border: 1px solid ${edge}; border-radius: 6px; background: ${fill}; color: ${ink}; overflow: hidden;`;
const barLabel = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;`;
const barMs = `margin: 0; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.2; font-variant-numeric: tabular-nums; opacity: 0.85; white-space: nowrap;`;

// "streams in" tag pinned to a bar's right edge (parallel section), pointing at
// the moment that boundary's chunk is written.
const streamsTag = (ms: number, ink: string) =>
	`position: absolute; top: 50%; left: ${pct(ms)}; transform: translate(6px, -50%); margin: 0;` +
	` font-family: ${sans}; font-size: 9.5px; font-weight: 700; line-height: 1.15; color: ${ink}; white-space: nowrap;`;

// Milestone marker: a small diamond on the axis at `ms`, with a stacked label.
// `side` flips the label left/right so it never runs off the plot edge. The
// wrapper is a ZERO-WIDTH anchor at the tick: the diamond centres on the point
// and the label offsets from it (left:11px → right of point; right:11px → left
// of point, since `right` resolves against the anchor's own zero width).
const milestone = (ms: number) =>
	`position: absolute; top: 50%; left: ${pct(ms)}; width: 0; height: 0; margin: 0; pointer-events: none;`;
const milestoneDiamond = (color: string) =>
	`position: absolute; top: 0; left: 0; width: 11px; height: 11px; margin: 0; transform: translate(-50%, -50%) rotate(45deg); background: ${color}; border: 1.5px solid ${color}; border-radius: 2px;`;
const milestoneLabel = (color: string, side: 'left' | 'right') =>
	`position: absolute; top: 0; ${side === 'right' ? 'left: 11px;' : 'right: 11px;'} transform: translateY(-50%);` +
	` margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 800; line-height: 1.15; color: ${color}; white-space: nowrap;` +
	` text-align: ${side === 'right' ? 'left' : 'right'};`;

// The axis baseline + tick labels under each section's plot.
const axisRow = `position: relative; height: 16px; margin: 4px 0 0; border-top: 1.5px solid ${AXIS};`;
const tickLabel = (ms: number) => {
	// First tick anchors at the left edge, last at the right edge, rest centered.
	const x = ms === 0 ? 'left: 0; transform: none;' : ms === MAX ? 'right: 0; left: auto; transform: none;' : `left: ${pct(ms)}; transform: translateX(-50%);`;
	return `position: absolute; top: 4px; ${x} margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 600; line-height: 1; color: ${INK_SOFT}; font-variant-numeric: tabular-nums; white-space: nowrap;`;
};
const tickMark = (ms: number) =>
	`position: absolute; top: 0; left: ${pct(ms)}; width: 1px; height: 4px; margin: 0; transform: translateX(-50%); background: ${AXIS};`;
---

<div style={stage}>
	{/* ============ Section 1 — sequential awaits SUM to 1100ms ============ */}
	<div style={section}>
		<div style={sectionHead}>
			<p style={sectionTitle(AMBER_INK)}>Sequential awaits <span style={`color: ${INK_SOFT}; font-weight: 600;`}>(one component)</span></p>
			<p style={sectionRule(AMBER)}>latency = sum</p>
		</div>

		{/* plot: two bars laid end to end, "first byte" milestone at the far end */}
		<div style={plot}>
			<div style={gridLayer} aria-hidden="true">
				{ticks.map((ms) => <div style={gridLine(ms)}></div>)}
			</div>

			{/* chart read: 0 -> 300 */}
			<div style={track}>
				<div style={bar(0, 300, AMBER_BG, AMBER, AMBER_INK)}>
					<span style={barLabel}>chart read</span>
					<span style={barMs}>300ms</span>
				</div>
			</div>
			<div style={trackGap}></div>

			{/* activity read: starts only AFTER chart, 300 -> 1100 */}
			<div style={track}>
				<div style={bar(300, 1100, AMBER_BG, AMBER, AMBER_INK)}>
					<span style={barLabel}>activity read</span>
					<span style={barMs}>800ms</span>
				</div>
			</div>
			<div style={trackGap}></div>

			{/* first-byte milestone: nothing reaches the user until 1100ms */}
			<div style={track}>
				<div style={milestone(MAX)}>
					<span style={milestoneDiamond(RED)} aria-hidden="true"></span>
					<span style={milestoneLabel(RED, 'left')}>first byte &mdash; 1100ms</span>
				</div>
			</div>

			{/* shared axis */}
			<div style={axisRow}>
				{ticks.map((ms) => <span style={tickMark(ms)}></span>)}
				{ticks.map((ms) => <span style={tickLabel(ms)}>{ms}</span>)}
			</div>
		</div>
		<p style={`margin: 2px 0 0; font-family: ${sans}; font-size: 11px; line-height: 1.4; color: ${INK_SOFT};`}>
			The second <code style={`font-family: ${mono}; font-size: 10.5px; background: transparent; padding: 0;`}>await</code> can&rsquo;t start until the first returns, so the reads stack &mdash; and the single render ships only at the very end.
		</p>
	</div>

	{/* ============ Section 2 — parallel boundaries MAX at 800ms ============ */}
	<div style={section}>
		<div style={sectionHead}>
			<p style={sectionTitle(GREEN_INK)}>Parallel boundaries <span style={`color: ${INK_SOFT}; font-weight: 600;`}>(two components)</span></p>
			<p style={sectionRule(GREEN)}>latency = max</p>
		</div>

		{/* plot: shell flush at ~0, two overlapping bars each streaming at its end */}
		<div style={plot}>
			<div style={gridLayer} aria-hidden="true">
				{ticks.map((ms) => <div style={gridLine(ms)}></div>)}
			</div>

			{/* shell + skeletons flush at ~0 — first paint */}
			<div style={track}>
				<div style={milestone(0)}>
					<span style={milestoneDiamond(INDIGO)} aria-hidden="true"></span>
					<span style={milestoneLabel(INDIGO_INK, 'right')}>shell + skeletons flush &mdash; ~0ms</span>
				</div>
			</div>
			<div style={trackGap}></div>

			{/* chart read: 0 -> 300, streams in at 300 */}
			<div style={track}>
				<div style={bar(0, 300, GREEN_BG, GREEN, GREEN_INK)}>
					<span style={barLabel}>chart read</span>
					<span style={barMs}>300ms</span>
				</div>
				<span style={streamsTag(300, GREEN_INK)}>chart streams in</span>
			</div>
			<div style={trackGap}></div>

			{/* activity read: 0 -> 800 (overlaps chart), streams in at 800 */}
			<div style={track}>
				<div style={bar(0, 800, GREEN_BG, GREEN, GREEN_INK)}>
					<span style={barLabel}>activity read</span>
					<span style={barMs}>800ms</span>
				</div>
				<span style={streamsTag(800, GREEN_INK)}>activity streams in</span>
			</div>
			<div style={trackGap}></div>

			{/* shared axis (identical scale to section 1) */}
			<div style={axisRow}>
				{ticks.map((ms) => <span style={tickMark(ms)}></span>)}
				{ticks.map((ms) => <span style={tickLabel(ms)}>{ms}</span>)}
			</div>
		</div>
		<p style={`margin: 2px 0 0; font-family: ${sans}; font-size: 11px; line-height: 1.4; color: ${INK_SOFT};`}>
			Both reads start together, so they overlap; first paint moves to the shell flush near zero, and each widget appears the moment its own bar ends.
		</p>
	</div>
</div>
