---
// Target-match ReactCoding exercise for "Reading a class string: the
// prefix-and-colon grammar". The student starts from a styled-but-static
// primary button and layers the plain variants taught in the section: a hover
// background darken, a keyboard-focus ring, a disabled treatment, and a
// responsive padding bump. They type the prefix-and-colon grammar and watch it
// fire by hovering and tab-focusing their own output.
//
// Why this is a wrapper and not a bare <ReactCoding> in the MDX (same reason as
// the sibling CardUtilities.astro): the target leans on *semantic* tokens —
// `bg-primary`, `text-primary-foreground`, `ring-ring` — which is the senior
// default the lesson models on purpose. But ReactCoding's iframe boots a bare
// Tailwind v4 Play CDN with no project `globals.css`, so those utilities
// resolve to nothing and the button renders unstyled. This wrapper makes the
// sandbox self-contained the same way the real project does: a
// `<style type="text/tailwindcss">` block with an `@theme` defining exactly the
// tokens this button consumes (canonical shadcn light-theme OKLCH values), plus
// a muted page background so the dark primary button reads against the surface.
// The block is shared verbatim by starter and target so "Your output" and
// "Target" resolve identically — the student types `hover:bg-primary/90` and
// actually sees it land. The setup `<style>` is the one line they leave alone;
// the button is what they edit.
import ReactCoding from "../../../live-coding/ReactCoding/ReactCoding.astro";

// Theme block injected into the sandbox. Mirrors the scaffold's `globals.css`
// for just the tokens this button consumes, and paints the page a muted surface
// so the dark primary button and its focus ring are visible. Shared by starter
// and target. `--color-ring` is the mid-grey shadcn ring token, chosen so the
// `focus-visible:ring-ring` is clearly visible against the near-black button.
const theme = `      {/* Project theme tokens — leave this as-is, it stands in for globals.css */}
      <style type="text/tailwindcss">{\`
        @theme {
          --color-primary: oklch(0.205 0 0);
          --color-primary-foreground: oklch(0.985 0 0);
          --color-ring: oklch(0.708 0 0);
        }
        body { background: oklch(0.97 0.001 286.4); }
      \`}</style>`;

const starter = `export function App() {
  return (
    <>
${theme}
      <button className="rounded-md bg-primary px-3 py-2 text-primary-foreground">
        Save changes
      </button>
    </>
  );
}`;

const target = `export function App() {
  return (
    <>
${theme}
      <button className="rounded-md bg-primary px-3 py-2 text-primary-foreground hover:bg-primary/90 focus-visible:ring-2 focus-visible:ring-ring disabled:opacity-50 disabled:pointer-events-none md:px-6">
        Save changes
      </button>
    </>
  );
}`;
---

<ReactCoding
  live
  instructions="Style the button to match the target. It needs: a primary background that darkens on hover, a visible ring on keyboard focus, a disabled state that dims it and ignores the pointer, and horizontal padding that grows from the md breakpoint up. Hover and keyboard-focus your output to check the states — both buttons stay enabled, so the disabled: utilities go in the string but won't fire visually here. Leave the theme <style> block alone."
  starter={starter}
  target={target}
  maxHeight={360}
/>
