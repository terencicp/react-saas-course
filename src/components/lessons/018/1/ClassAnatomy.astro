---
// The lesson's keystone visual: decompose the densest class in the lesson —
// `md:hover:bg-primary/80` — into the four parts of the Tailwind grammar, laid
// left-to-right so the class reads as one sentence. Each segment gets a label
// above and a one-line gloss below; a full plain-English reading runs underneath
// the row. The shape the student should carry away is
// [breakpoint][state][utility][modifier]: gates on the left, the declaration in
// the middle, a value modifier on the right.
//
// Pure HTML + CSS, devtools-inspectable. A flex row of four segment cards over a
// single reading line. Each chip carries its own punctuation (`md:`, `hover:`,
// `/80`), so reading the chips left-to-right with no gap reconstructs the literal
// class string exactly — no separator glyphs needed. `flex-wrap: wrap` keeps
// every segment visible on a narrow figure card rather than scrolling off edge.
// `margin: 0` reset on every inner element (belt-and-braces with `not-content`)
// defeats Starlight's prose-margin injection. Colors come from the theme-aware
// `--mark-*` palette in custom.css so every segment flips correctly between
// light and dark: the two gates share the cool family (violet, then blue), the
// utility is green (the real declaration), the modifier is orange (a value
// transform).

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The four segments of `md:hover:bg-primary/80`, in the order they read. `text`
// is the literal slice of the class *including* its own punctuation (the
// trailing colon on the two gates, the leading slash on the modifier), so the
// chips concatenate back into the exact class string. `color` names a `--mark-*`
// family from custom.css.
const segments = [
  {
    text: "md:",
    label: "breakpoint variant",
    gloss: "at the md screen size and up",
    color: "violet",
  },
  {
    text: "hover:",
    label: "state variant",
    gloss: "when the element is hovered",
    color: "blue",
  },
  {
    text: "bg-primary",
    label: "utility (the declaration)",
    gloss: "set background to the primary color",
    color: "green",
  },
  {
    text: "/80",
    label: "opacity modifier",
    gloss: "at 80% opacity",
    color: "orange",
  },
];

const wrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 18px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// The row of segment cards. Wraps rather than scrolls on a narrow card; a
// generous row-gap keeps the per-segment glosses from touching a wrapped row's
// labels.
const row = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: flex-start",
  "justify-content: center",
  "column-gap: 10px",
  "row-gap: 22px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// One segment column: label on top, the colored literal-text box in the middle,
// gloss underneath. Capped width so a long gloss wraps to two short lines
// instead of stretching the segment wider than its neighbours.
const segCol = [
  reset,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 6px",
  "max-width: 168px",
  "box-sizing: border-box",
].join("; ");

// The small label pill above each segment.
const labelStyle = (color: string) =>
  [
    reset,
    sans,
    "font-size: 11px",
    "font-weight: 700",
    "letter-spacing: 0.02em",
    "line-height: 1.2",
    "text-align: center",
    `color: var(--mark-${color}-brd)`,
  ].join("; ");

// The colored box holding the literal class slice. Saturated tint + matching
// border from the theme-aware mark palette so the segment colors flip with the
// theme; the monospace text reads as code without the inline-code pill chrome.
const chip = (color: string) =>
  [
    reset,
    mono,
    "font-size: 18px",
    "font-weight: 600",
    "line-height: 1.2",
    "padding: 8px 12px",
    "border-radius: 8px",
    `background: var(--mark-${color}-bg)`,
    `border: 1.5px solid var(--mark-${color}-brd)`,
    "color: var(--sl-color-white)",
    "white-space: nowrap",
    "box-sizing: border-box",
  ].join("; ");

// The one-line gloss under each segment.
const glossStyle = [
  reset,
  sans,
  "font-size: 12px",
  "font-weight: 400",
  "line-height: 1.3",
  "text-align: center",
  "color: var(--sl-color-gray-2)",
].join("; ");

// The full plain-English reading under the whole row.
const reading = [
  reset,
  sans,
  "font-size: 14px",
  "line-height: 1.45",
  "text-align: center",
  "max-width: 46ch",
  "color: var(--sl-color-gray-1)",
].join("; ");

const readingEm = [reset, "font-weight: 600", "color: var(--sl-color-white)"].join(
  "; ",
);
---

<div class="not-content" style={wrap}>
  <div style={row}>
    {
      segments.map((seg) => (
        <div style={segCol}>
          <div style={labelStyle(seg.color)}>{seg.label}</div>
          <div style={chip(seg.color)}>{seg.text}</div>
          <div style={glossStyle}>{seg.gloss}</div>
        </div>
      ))
    }
  </div>

  <p style={reading}>
    At <span style={readingEm}>md and up</span>, <span style={readingEm}>when
    hovered</span>, set the <span style={readingEm}>background to the primary
    color</span> <span style={readingEm}>at 80% opacity</span>.
  </p>
</div>
