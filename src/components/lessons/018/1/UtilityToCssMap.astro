---
// Maps three utility class names to the single CSS declaration each one emits,
// driving home the lesson's spine: a utility name *is* its declaration — no
// lookup, no indirection. Read left-to-right: the monospace utility on the
// left, a centered arrow, the literal CSS Tailwind generates on the right.
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the layout:
// three columns (utility | arrow | declaration), fixed so the rows align
// column-by-column and never wrap. `margin: 0` reset on every inner element
// (belt-and-braces with the `not-content` class) defeats Starlight's
// prose-margin injection. Chrome uses Starlight gray/theme CSS variables so it
// flips with light/dark; the `var(--token)` fragments in the right column get a
// faint accent so the "these resolve through theme tokens" point reads visually.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// Each row: the utility class on the left, and the CSS declaration it compiles
// to on the right, expressed as ordered segments. A `token` segment is the part
// that resolves through a theme token (faintly accented to make the point); a
// `plain` segment is literal CSS text. Splitting into segments — rather than a
// pre/token/post triple interpolated with JSX whitespace — keeps the literal
// spacing exact (no stray space sneaking in before the semicolon).
const rows = [
  {
    utility: "p-4",
    decl: [{ t: "plain", v: "padding: 1rem;" }],
  },
  {
    utility: "bg-primary",
    decl: [
      { t: "plain", v: "background-color: " },
      { t: "token", v: "var(--color-primary)" },
      { t: "plain", v: ";" },
    ],
  },
  {
    utility: "rounded-lg",
    decl: [
      { t: "plain", v: "border-radius: " },
      { t: "token", v: "var(--radius-lg)" },
      { t: "plain", v: ";" },
    ],
  },
];

const grid = [
  reset,
  "display: grid",
  // utility column | arrow column (intrinsic) | declaration column
  "grid-template-columns: minmax(96px, max-content) auto 1fr",
  "align-items: stretch",
  "column-gap: 0",
  "row-gap: 8px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Column header cells (the small "Utility class" / "CSS it emits" labels).
const headStyle = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "padding: 0 0 2px 2px",
].join("; ");

// Left tile: the utility class. Faint accent tint so the "name" side is
// distinct from the "declaration" side.
const utilityCell = [
  reset,
  mono,
  "font-size: 15px",
  "font-weight: 600",
  "line-height: 1.2",
  "display: flex",
  "align-items: center",
  "padding: 10px 14px",
  "border-radius: 8px 0 0 8px",
  "background: rgba(56, 189, 248, 0.12)",
  "color: var(--sl-color-white)",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

// Center arrow column.
const arrowCell = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "padding: 0 14px",
  "color: var(--sl-color-gray-3)",
  "font-size: 18px",
  "line-height: 1",
  "user-select: none",
].join("; ");

// Right tile: the literal CSS declaration. A normal block (not flex) so the
// inline spans flow as text and the literal space after the colon survives —
// flex items drop the whitespace between them, which would collapse
// `padding: 1rem;` into `padding:1rem;`.
const declCell = [
  reset,
  mono,
  "font-size: 15px",
  "font-weight: 400",
  "line-height: 1.2",
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "padding: 10px 14px",
  "border-radius: 0 8px 8px 0",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.04))",
  "color: var(--sl-color-gray-1)",
  "box-sizing: border-box",
].join("; ");

// The token fragment inside a declaration — faintly accented to signal "this
// resolves through the design system".
const tokenSpan = [
  reset,
  "color: #38bdf8",
].join("; ");
---

<div class="not-content" style={grid}>
  {/* Header row: blank corner over the arrow column keeps the two labels above their tiles */}
  <div style={headStyle}>Utility class</div>
  <div style={reset}></div>
  <div style={headStyle}>CSS it emits</div>

  {/* One grid row per mapping */}
  {
    rows.map((r) => (
      <Fragment>
        <div style={utilityCell}>{r.utility}</div>
        <div style={arrowCell} aria-hidden="true">
          &rarr;
        </div>
        <div style={declCell}>
          <span style={reset}>
            {r.decl.map((seg) =>
              seg.t === "token" ? (
                <span style={tokenSpan}>{seg.v}</span>
              ) : (
                seg.v
              ),
            )}
          </span>
        </div>
      </Fragment>
    ))
  }
</div>
