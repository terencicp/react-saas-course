---
// A scan-at-a-glance reference of the ~8 Tailwind utility families the student
// reaches for daily. The pedagogical message is "learn the families, not the
// list" — so the layout groups representative class names *under their family*,
// label on the left, the member pills on the right. Recognize the family; let
// autocomplete fill in the exact name.
//
// Pure HTML + CSS, devtools-inspectable. A two-column CSS grid (family label |
// member pills) keeps the labels aligned in one column while the pills wrap
// freely in the other. `margin: 0` reset on every inner element (with the
// `not-content` class) defeats Starlight's prose-margin injection. Chrome uses
// Starlight gray/theme variables so it flips with light/dark; the member pills
// carry the same faint sky tint as the sibling UtilityToCssMap so the two
// figures read as one chapter.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// One entry per family: the family name and its representative utilities. Order
// runs from the structural families (layout, spacing, sizing) through the
// surface families (color, typography, border) to the finishing one (effects),
// roughly the order you reach for them building an element.
const families = [
  { name: "Layout", items: ["flex", "grid", "block", "hidden", "items-center", "justify-between"] },
  { name: "Spacing", items: ["p-4", "px-6", "m-2", "gap-4"] },
  { name: "Sizing", items: ["w-full", "h-screen", "size-10"] },
  { name: "Color", items: ["bg-card", "text-foreground", "border-border"] },
  { name: "Typography", items: ["text-sm", "font-medium", "leading-tight", "tracking-tight"] },
  { name: "Border & radius", items: ["border", "border-2", "rounded-md", "divide-y"] },
  { name: "Effects", items: ["shadow-sm", "opacity-90", "transition", "ring-2"] },
];

const grid = [
  reset,
  "display: grid",
  // family-label column (sized to the longest label) | member-pills column
  "grid-template-columns: max-content 1fr",
  "align-items: stretch",
  "column-gap: 16px",
  "row-gap: 8px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Left cell: the family name. Sans-serif so it reads as a heading against the
// monospace pills, right-aligned so the labels hug the gutter before the pills.
const familyCell = [
  reset,
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)",
  "font-size: 13px",
  "font-weight: 600",
  "line-height: 1.2",
  "display: flex",
  "align-items: center",
  "justify-content: flex-end",
  "text-align: right",
  "color: var(--sl-color-white)",
  "white-space: nowrap",
  "padding: 4px 0",
  "box-sizing: border-box",
].join("; ");

// Right cell: a wrapping row of member pills.
const itemsCell = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "column-gap: 6px",
  "row-gap: 6px",
  "padding: 2px 0",
  "box-sizing: border-box",
].join("; ");

// Each representative utility, as a monospace pill. The faint sky tint matches
// the utility side of UtilityToCssMap — "this is a class name".
const pill = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 500",
  "line-height: 1.2",
  "padding: 3px 8px",
  "border-radius: 6px",
  "background: rgba(56, 189, 248, 0.12)",
  "color: var(--sl-color-gray-1)",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

// A thin divider between family rows, drawn as a full-width grid row so the line
// runs under both columns. Spanning both columns keeps the rule visually tying
// the label to its pills.
const dividerStyle = [
  reset,
  "grid-column: 1 / -1",
  "height: 1px",
  "background: var(--sl-color-gray-5, rgba(0,0,0,0.08))",
].join("; ");
---

<div class="not-content" style={grid}>
  {
    families.map((family, i) => (
      <Fragment>
        {i > 0 && <div style={dividerStyle} aria-hidden="true" />}
        <div style={familyCell}>{family.name}</div>
        <div style={itemsCell}>
          {family.items.map((item) => (
            <span style={pill}>{item}</span>
          ))}
        </div>
      </Fragment>
    ))
  }
</div>
