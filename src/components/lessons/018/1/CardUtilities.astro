---
// Target-match ReactCoding exercise for "The utility families you write daily".
// The student composes a utility class string on a plain card to match a
// reference card: padding, the card background, rounded corners, a subtle
// border, a small shadow, and larger medium-weight title text.
//
// Why this is a wrapper and not a bare <ReactCoding> in the MDX:
// the lesson teaches *semantic* tokens (`bg-card`, `border-border`,
// `text-card-foreground`) on purpose — raw `blue-500` is framed as a smell.
// But ReactCoding's iframe boots a bare Tailwind v4 Play CDN with no project
// `globals.css`, so those semantic utilities resolve to nothing and the card
// renders invisible. This wrapper makes the sandbox self-contained the same
// way the real project does it: a `<style type="text/tailwindcss">` block with
// an `@theme` defining exactly those tokens (canonical shadcn light-theme
// OKLCH values), plus a muted page background so the white `bg-card` reads as a
// card against it. The block is shared verbatim by the starter and the target
// so the "Your output" and "Target" panels resolve identically — the student
// types `bg-card` and actually sees it land. The setup `<style>` is the one
// line the student is told to leave alone; the card is what they edit.
import ReactCoding from "../../../live-coding/ReactCoding/ReactCoding.astro";

// Theme block injected into the sandbox. Mirrors the scaffold's `app/globals.css`
// for just the three tokens this card consumes, and paints the page a muted
// surface so the white card is visible. Shared by starter and target.
const theme = `      {/* Project theme tokens — leave this as-is, it stands in for globals.css */}
      <style type="text/tailwindcss">{\`
        @theme {
          --color-card: oklch(1 0 0);
          --color-card-foreground: oklch(0.21 0.006 285.9);
          --color-border: oklch(0.92 0.004 286.3);
        }
        body { background: oklch(0.97 0.001 286.4); }
      \`}</style>`;

const starter = `export function App() {
  return (
    <>
${theme}
      <div className="max-w-xs">
        <p>Monthly plan</p>
      </div>
    </>
  );
}`;

const target = `export function App() {
  return (
    <>
${theme}
      <div className="max-w-xs p-6 bg-card rounded-lg border border-border shadow-sm">
        <p className="text-lg font-medium text-card-foreground">Monthly plan</p>
      </div>
    </>
  );
}`;
---

<ReactCoding
  live
  instructions="Match the target card using utility classes on the inner div and its paragraph. It needs padding all around, the card background color, rounded corners, a subtle border, a small shadow, and slightly larger medium-weight text for the title. Leave the theme <style> block alone."
  starter={starter}
  target={target}
  maxHeight={360}
/>
