---
// The "whose state?" map — the spatial spine of the DOM-state-variants lesson.
//
// A variant is a CSS selector wrapped around a utility, so the families differ by
// exactly one question: WHOSE state does the selector read? There are five
// answers, and this figure lays them out as the spatial relationships they
// literally are, so every prefix in the rest of the lesson hangs off one arrow:
//
//   • this element's own state ......... pseudo-classes, data-*, aria-*   (self)
//   • a parent's state ................. group-*                          (UP / contains me)
//   • an earlier sibling's state ....... peer-*                           (BEFORE me, reads forward)
//   • a descendant's state ............. has-*                            (DOWN / I contain it)
//   • my position among siblings ...... first: last: odd:                (a badge on me)
//
// The relationships are encoded in REAL DOM nesting wherever it reads cleanly:
// the "parent" box genuinely contains "this element", and "this element"
// genuinely contains the "descendant" box — so "up" and "down" are actual
// containment a reader can confirm in devtools, the HTML/CSS USP. The peer sits
// as a real earlier sibling to the left, with a forward arrow into "this element"
// that encodes peer's one hard rule (it only reaches forward). Each family gets
// one accent from the theme-aware --mark-* palette (custom.css) so the colours
// flip with light/dark and match the sibling DesugarPanel figure in this lesson.
//
// Pure HTML + CSS: a `not-content` class plus a `margin: 0` reset on every inner
// element defeat Starlight's prose-margin injection (which otherwise reaches into
// nested flex/grid children); Starlight gray/hairline CSS variables flip the
// chrome. No props — the figure is static.

const reset = "margin: 0";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

// One family's accent (background + border tints from the --mark-* palette).
const accent = (name: "blue" | "green" | "orange" | "violet" | "slate") =>
  name === "slate"
    ? { bg: "var(--sl-color-gray-6, rgba(0,0,0,0.04))", brd: "var(--sl-color-gray-4)" }
    : { bg: `var(--mark-${name}-bg)`, brd: `var(--mark-${name}-brd)` };

// A "fieldset legend" pill that straddles a box's top border, naming the
// relationship and its variant family. display:block + width:fit-content + a
// negative margin-top lands its centre on the border line (see html-css.md);
// background matches the Figure card so it visually breaks the border.
const legend = (a: { bg: string; brd: string }) =>
  [
    reset,
    sans,
    "display: block",
    "width: fit-content",
    "margin-top: -10px",
    "margin-bottom: 4px",
    "padding: 2px 8px",
    "border-radius: 999px",
    "font-size: 10.5px",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "line-height: 1.2",
    "color: var(--sl-color-white)",
    `background: ${a.bg}`,
    `box-shadow: inset 0 0 0 1px ${a.brd}`,
    "white-space: nowrap",
  ].join("; ");

// The small monospace variant token shown under each box's role label.
const code = (a: { bg: string; brd: string }) =>
  [
    reset,
    mono,
    "display: inline-block",
    "font-size: 12px",
    "font-weight: 600",
    "line-height: 1.2",
    "padding: 2px 6px",
    "border-radius: 5px",
    "color: var(--sl-color-white)",
    `background: ${a.bg}`,
    `box-shadow: inset 0 0 0 1px ${a.brd}`,
    "white-space: nowrap",
  ].join("; ");

// A relationship box: rounded, tinted border, the legend pill on its top edge.
const box = (a: { bg: string; brd: string }, extra = "") =>
  [
    reset,
    "position: relative",
    "box-sizing: border-box",
    "border-radius: 11px",
    `border: 1.5px solid ${a.brd}`,
    "background: var(--sl-color-bg-sidebar, transparent)",
    extra,
  ].join("; ");

const roleLabel = [
  reset,
  sans,
  "font-size: 12.5px",
  "font-weight: 700",
  "color: var(--sl-color-white)",
  "line-height: 1.2",
].join("; ");

const hint = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 500",
  "color: var(--sl-color-gray-3)",
  "line-height: 1.2",
].join("; ");

const blue = accent("blue");
const green = accent("green");
const orange = accent("orange");
const violet = accent("violet");
const self = accent("slate");

// Directional cue text (UP / DOWN) shown beside a containment relationship.
const dirCue = (a: { bg: string; brd: string }) =>
  [
    reset,
    sans,
    "font-size: 10px",
    "font-weight: 700",
    "letter-spacing: 0.08em",
    "color: var(--sl-color-white)",
    "padding: 1px 6px",
    "border-radius: 999px",
    `background: ${a.bg}`,
    `box-shadow: inset 0 0 0 1px ${a.brd}`,
    "white-space: nowrap",
  ].join("; ");
---

<div
  class="not-content"
  style={[
    reset,
    "box-sizing: border-box",
    "max-width: 640px",
    "margin-left: auto",
    "margin-right: auto",
  ].join("; ")}
>
  {/* PARENT — the outer box literally contains everything below it (the "up" arrow). */}
  <div style={box(blue, "padding: 12px 14px 14px")}>
    <span style={legend(blue)}>parent</span>
    <div
      style={[
        reset,
        "display: flex",
        "align-items: center",
        "justify-content: space-between",
        "gap: 8px",
        "margin-bottom: 10px",
      ].join("; ")}
    >
      <span style={hint}>this element reads its parent&rsquo;s state</span>
      <span
        style={[reset, "display: inline-flex", "align-items: center", "gap: 7px"].join("; ")}
      >
        <span style={code(blue)}>group-*</span>
        <span style={dirCue(blue)}>↑ UP</span>
      </span>
    </div>

    {/* Row: earlier sibling (peer)  →  this element. Real source order: peer first. */}
    <div
      style={[
        reset,
        "display: flex",
        "align-items: stretch",
        "gap: 0",
      ].join("; ")}
    >
      {/* EARLIER SIBLING — sits before "this element"; arrow points forward only. */}
      <div
        style={box(
          green,
          "flex: 0 0 auto; width: 150px; padding: 14px 12px 12px; display: flex; flex-direction: column; gap: 7px;",
        )}
      >
        <span style={legend(green)}>earlier sibling</span>
        <span style={roleLabel}>peer</span>
        <span style={code(green)}>peer-*</span>
        <span style={hint}>marked first in the markup</span>
      </div>

      {/* Forward arrow — peer only reaches forward (the ~ combinator). */}
      <div
        style={[
          reset,
          "flex: 0 0 auto",
          "align-self: center",
          "display: flex",
          "flex-direction: column",
          "align-items: center",
          "gap: 2px",
          "padding: 0 6px",
        ].join("; ")}
        aria-hidden="true"
      >
        <span
          style={[
            reset,
            sans,
            "font-size: 9.5px",
            "font-weight: 700",
            "letter-spacing: 0.04em",
            "color: var(--mark-green-brd)",
            "white-space: nowrap",
          ].join("; ")}
        >reads forward</span>
        <svg width="46" height="14" viewBox="0 0 46 14" fill="none" aria-hidden="true">
          <line
            x1="2"
            y1="7"
            x2="38"
            y2="7"
            stroke="var(--mark-green-brd)"
            stroke-width="2"
            stroke-linecap="round"></line>
          <polyline
            points="32 2 42 7 32 12"
            fill="none"
            stroke="var(--mark-green-brd)"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></polyline>
        </svg>
      </div>

      {/* THIS ELEMENT — the prominent centre, carrying its self families + a position badge. */}
      <div
        style={box(
          self,
          "flex: 1 1 auto; min-width: 0; padding: 16px 14px 14px; border-width: 2px; box-shadow: 0 1px 0 rgba(0,0,0,0.04);",
        )}
      >
        <span
          style={[legend(self), "color: var(--sl-color-white); font-size: 11px;"].join("; ")}
          >this element</span
        >

        {/* position-among-siblings badge — the fifth answer, a tag ON this element. */}
        <span
          style={[
            reset,
            sans,
            "position: absolute",
            "top: 8px",
            "right: 8px",
            "display: inline-flex",
            "align-items: center",
            "gap: 5px",
            "padding: 2px 7px",
            "border-radius: 999px",
            "font-size: 9.5px",
            "font-weight: 700",
            "color: var(--sl-color-white)",
            `background: ${violet.bg}`,
            `box-shadow: inset 0 0 0 1px ${violet.brd}`,
            "white-space: nowrap",
          ].join("; ")}
        >
          position
          <span style={[mono, reset, "font-size: 10px; font-weight: 700;"].join("; ")}
            >first: last: odd:</span
          >
        </span>

        <div
          style={[
            reset,
            "display: flex",
            "align-items: baseline",
            "gap: 8px",
            "margin-top: 2px",
            "margin-bottom: 8px",
          ].join("; ")}
        >
          <span style={[roleLabel, "font-size: 13.5px;"].join("; ")}>reads its own state</span>
        </div>

        <div
          style={[
            reset,
            "display: flex",
            "flex-wrap: wrap",
            "gap: 5px",
          ].join("; ")}
        >
          <span style={code(self)}>hover:</span>
          <span style={code(self)}>data-*</span>
          <span style={code(self)}>aria-*</span>
        </div>

        {/* DESCENDANT — nested INSIDE this element (the "down" arrow). */}
        <div
          style={[
            reset,
            "display: flex",
            "align-items: center",
            "justify-content: space-between",
            "gap: 8px",
            "margin-top: 12px",
            "margin-bottom: 6px",
          ].join("; ")}
        >
          <span style={hint}>this element reads a descendant it contains</span>
          <span style={dirCue(orange)}>↓ DOWN</span>
        </div>
        <div
          style={box(
            orange,
            "padding: 12px 12px 11px; display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap;",
          )}
        >
          <span style={legend(orange)}>descendant</span>
          <span style={roleLabel}>a child inside</span>
          <span style={code(orange)}>has-*</span>
        </div>
      </div>
    </div>
  </div>
</div>
