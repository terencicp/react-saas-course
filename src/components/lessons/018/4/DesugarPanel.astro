---
// One frame of the "a variant desugars to a selector" sequence. Each
// <DesugarPanel step={n} /> is the body of one DiagramStep in the lesson's
// DiagramSequence. The whole point of the figure is to make "variant = a CSS
// selector wrapped around a utility" *literal*, and to show that the only thing
// changing from one variant family to the next is the SHAPE of the selector —
// the utility (rotate-180 / opacity-100 / border) and its declaration stay put.
//
// Each step is a two-row stacked panel:
//   top    — the class string you write on a JSX tag ("You write")
//   bottom — the CSS rule Tailwind emits for it ("Tailwind emits")
// In every step the *variant prefix* in the class and the matching *selector
// fragment* in the CSS carry the same blue accent, so the eye draws the line
// "this prefix -> this selector". The utility slice and its declaration are left
// neutral on purpose: they're the constant across all four families.
//
// The four frames widen the selector one step at a time:
//   1 hover:rotate-180            -> &:hover { rotate: 180deg }         (the anchor: a pseudo-class)
//   2 data-[state=open]:rotate-180-> &[data-state="open"] { … }        (new: an attribute selector)
//   3 group-hover:opacity-100     -> .group:hover & { opacity: 1 }     (the selector reaches UP)
//   4 has-[:invalid]:border-…     -> &:has(:invalid) { border-color }  (and DOWN)
//
// Pure HTML + CSS, devtools-inspectable, matching the sibling figures in this
// chapter (CnPipeline, UtilityToCssMap, ClassAnatomy): a `not-content` class plus
// a `margin: 0` reset on every inner element defeat Starlight's prose-margin
// injection; Starlight gray/white CSS variables flip the chrome with light/dark;
// the theme-aware --mark-blue-* palette (custom.css) gives the accent that flips
// too. Both rows are rendered as ordered segments rather than interpolated JSX so
// the literal spacing (the space after a colon, the quotes in the attribute
// value) survives exactly.

interface Props {
  /** Which frame of the sequence to draw, 1-4. */
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// A code segment: `prefix` is the variant prefix / its emitted selector fragment
// (blue, the linked pair); `plain` is literal code that stays neutral.
type Seg = { t: "prefix" | "plain"; v: string };

type Frame = {
  /** The class string as authored, segmented so the prefix can be tinted. */
  cls: Seg[];
  /** The CSS rule Tailwind emits, segmented so the selector can be tinted. */
  css: Seg[];
};

const frames: Record<1 | 2 | 3 | 4, Frame> = {
  1: {
    cls: [
      { t: "prefix", v: "hover:" },
      { t: "plain", v: "rotate-180" },
    ],
    css: [
      { t: "prefix", v: "&:hover" },
      { t: "plain", v: " { rotate: 180deg }" },
    ],
  },
  2: {
    cls: [
      { t: "prefix", v: "data-[state=open]:" },
      { t: "plain", v: "rotate-180" },
    ],
    css: [
      { t: "prefix", v: '&[data-state="open"]' },
      { t: "plain", v: " { rotate: 180deg }" },
    ],
  },
  3: {
    cls: [
      { t: "prefix", v: "group-hover:" },
      { t: "plain", v: "opacity-100" },
    ],
    css: [
      { t: "prefix", v: ".group:hover &" },
      { t: "plain", v: " { opacity: 1 }" },
    ],
  },
  4: {
    cls: [
      { t: "prefix", v: "has-[:invalid]:" },
      { t: "plain", v: "border-destructive" },
    ],
    css: [
      { t: "prefix", v: "&:has(:invalid)" },
      { t: "plain", v: " { border-color: … }" },
    ],
  },
};

const frame = frames[step];

// Outer wrapper. A fixed min-height keeps the four frames close in height so the
// DiagramSequence stage (which sizes to the tallest) doesn't leave gaps under the
// shorter ones, and centers the stacked pair vertically.
const wrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 10px",
  "min-height: 132px",
  "box-sizing: border-box",
].join("; ");

// One labelled code row (a "panel"): a small uppercase tag on the left edge and
// the code line itself, in a tinted card.
const panel = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 5px",
  "box-sizing: border-box",
].join("; ");

// The small uppercase tag above each code line.
const tag = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "padding-left: 2px",
].join("; ");

// The code card. A normal block (not flex) so the inline segment spans flow as
// text and literal spaces survive. `overflow-x: auto` rescues the longest lines
// on a narrow figure card instead of clipping them.
const codeCard = (kind: "cls" | "css") =>
  [
    reset,
    mono,
    "font-size: 15px",
    "font-weight: 500",
    "line-height: 1.5",
    "padding: 11px 14px",
    "border-radius: 9px",
    "white-space: nowrap",
    "overflow-x: auto",
    "box-sizing: border-box",
    kind === "cls"
      ? "background: var(--sl-color-gray-6, rgba(0,0,0,0.035))"
      : "background: var(--sl-color-black)",
    "border: 1px solid var(--sl-color-hairline)",
    kind === "cls"
      ? "color: var(--sl-color-white)"
      : "color: var(--sl-color-gray-2)",
  ].join("; ");

// A blue-tinted slice — the variant prefix on top, its emitted selector below.
// The shared accent is what links the two rows; rounded + padded so it reads as
// one highlighted token without breaking the monospace baseline.
const prefixSpan = [
  reset,
  "padding: 1px 4px",
  "margin: 0 -1px",
  "border-radius: 5px",
  "background: var(--mark-blue-bg)",
  "box-shadow: inset 0 0 0 1px var(--mark-blue-brd)",
  "color: var(--sl-color-white)",
  "font-weight: 700",
].join("; ");

// The little "compiles to" connector between the two rows: a down-chevron and a
// hairline, centered, so the top->bottom direction reads at a glance.
const connector = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "padding: 1px 2px",
  "font-size: 10.5px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
].join("; ");

const connectorRule = [
  reset,
  "flex: 1",
  "height: 1px",
  "background: var(--sl-color-hairline)",
].join("; ");

const renderSegs = (segs: Seg[]) =>
  segs.map((s) =>
    s.t === "prefix" ? `<span style="${prefixSpan}">${s.v}</span>` : s.v,
  );
---

<div class="not-content" style={wrap} data-step={step}>
  <div style={panel}>
    <div style={tag}>You write</div>
    <div style={codeCard("cls")}>
      <span style={reset} set:html={renderSegs(frame.cls).join("")} />
    </div>
  </div>

  <div style={connector} aria-hidden="true">
    <span style={connectorRule}></span>
    <svg
      width="13"
      height="13"
      viewBox="0 0 14 14"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="3 5 7 10 11 5"></polyline>
    </svg>
    <span style="margin: 0; white-space: nowrap;">compiles to</span>
    <svg
      width="13"
      height="13"
      viewBox="0 0 14 14"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="3 5 7 10 11 5"></polyline>
    </svg>
    <span style={connectorRule}></span>
  </div>

  <div style={panel}>
    <div style={tag}>Tailwind emits</div>
    <div style={codeCard("css")}>
      <span style={reset} set:html={renderSegs(frame.css).join("")} />
    </div>
  </div>
</div>
