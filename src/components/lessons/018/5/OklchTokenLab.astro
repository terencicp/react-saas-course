---
// "OKLCH token lab" — the lesson's hands-on playground for the semantic-token
// model. It is a thin wrapper over <ParamPlayground> that hides the preview
// markup, the scoped card styles, and the four contrast readouts so the MDX
// stays a single self-describing tag.
//
// What the student feels here:
//   - A surface token and its foreground token are *values you tune per theme*.
//     Sliding the lightness of each re-paints a mock card live (pure CSS-var
//     preview — no Tailwind compile, so it works under the lesson's CDN limit).
//   - The Theme toggle swaps the page the card sits on between a light and a
//     dark backdrop, exactly like `.dark` deciding which value set wins. It is a
//     framing cue: the student rebuilds the surface/foreground pair for the new
//     backdrop and watches the contrast chip.
//   - The "WCAG AA" chip makes the point the prose lands afterwards: a token pair
//     must pass contrast in *both* themes, which is why every surface ships with
//     its own `-foreground`. Drop the surface lightness toward the foreground's
//     and the chip flips to `false`.
//
// The backdrop swap is a CSS style query against `--dark`, which <Param
// kind="toggle"> writes onto the preview wrapper as the literal string
// `dark` / `light`. Every element is a style-query container by default, so the
// descendant `.page` resolves `--dark` from that ancestor with no extra plumbing.
//
// All preview colors are literal OKLCH (the thing the lesson is about); they must
// NOT follow the reader's own site theme. The <ParamPlayground> chrome around
// them already flips with the site theme on its own.

import ParamPlayground from '../../../figures/param-playground/ParamPlayground.astro';
import Param from '../../../figures/param-playground/Param.astro';
import Preview from '../../../figures/param-playground/Preview.astro';
import Readout from '../../../figures/param-playground/Readout.astro';

// The surface and foreground color strings, shared between the preview CSS and
// the readout expressions so the chip always describes what's on screen. Chroma
// is a constant faint tint so the swatch reads as a real token, not flat grey.
const surface = "'oklch(' + surfaceL + ' 0.01 ' + hue + ')'";
const foreground = "'oklch(' + fgL + ' 0.01 ' + hue + ')'";
---

<ParamPlayground caption="Slide the lightness of a surface and its foreground; toggle light/dark to swap the value set. The chip is the live contrast ratio.">
  <Param id="surfaceL" kind="slider" label="Surface lightness" min={0} max={1} step={0.005} default={1} />
  <Param id="fgL" kind="slider" label="Foreground lightness" min={0} max={1} step={0.005} default={0.145} />
  <Param id="hue" kind="slider" label="Hue" min={0} max={360} step={1} default={260} />
  <Param id="dark" kind="toggle" label="Theme" on="dark" off="light" default={false} />

  <Preview>
    <div class="otl-page">
      <div class="otl-card">
        <p class="otl-title">Monthly revenue</p>
        <p class="otl-value">$48,250</p>
        <p class="otl-muted">Updated 3 hours ago</p>
      </div>
    </div>
  </Preview>

  <Readout label="Surface" expr={surface} />
  <Readout label="Foreground" expr={foreground} />
  <Readout label="Contrast" expr={`wcagContrast(${surface}, ${foreground})`} />
  <Readout label="WCAG AA" expr={`wcagPasses(${surface}, ${foreground})`} />
</ParamPlayground>

<style is:global>
  /* Register --dark as an inherited custom property so the style query below
     re-evaluates every time the toggle rewrites it. Without registration,
     Chromium leaves the style-container query stale when an *unregistered*
     inherited property changes on an already-rendered subtree, so toggling back
     to light would not revert the backdrop. `syntax: "*"` forbids an
     initial-value; the ParamPlayground script seeds `--dark` to `light` on mount. */
  @property --dark {
    syntax: "*";
    inherits: true;
  }

  /* The mock "page" the card sits on. Its backdrop is the visual stand-in for
     "which theme is active" — the toggle's only job. Light by default; the
     style query flips it dark when --dark resolves to the string `dark`. */
  .param-playground .otl-page {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 22px 16px;
    border-radius: 8px;
    background: oklch(0.97 0 0);
    transition: background-color 0.16s ease;
  }

  @container style(--dark: dark) {
    .param-playground .otl-page {
      background: oklch(0.18 0 0);
    }
  }

  /* The token card. Surface + foreground are driven entirely by the sliders. */
  .param-playground .otl-card {
    width: min(15rem, 100%);
    box-sizing: border-box;
    padding: 14px 16px;
    border-radius: 10px;
    background: oklch(var(--surfaceL) 0.01 var(--hue));
    color: oklch(var(--fgL) 0.01 var(--hue));
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.18);
    font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
  }
  .param-playground .otl-card > * {
    margin: 0;
  }
  .param-playground .otl-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .param-playground .otl-value {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
    margin-top: 2px;
  }
  /* The muted line shares the foreground token, dimmed — the same trick a real
     `muted-foreground` plays, and a second thing the contrast must carry. */
  .param-playground .otl-muted {
    font-size: 0.7rem;
    opacity: 0.7;
    margin-top: 6px;
  }
</style>
