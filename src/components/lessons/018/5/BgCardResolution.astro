---
// One frame of the "how bg-card resolves" sequence. Each
// <BgCardResolution step={n} /> is the body of one DiagramStep in the lesson's
// DiagramSequence. The figure makes the load-bearing insight of the lesson
// *literal*: the utility `bg-card` is not a color, it is a reference to the
// variable `--card`, so re-pointing that variable under `.dark` re-themes the
// node without the class string ever moving.
//
// The four frames walk one indirection at a time:
//   1  the class string the component writes          (bg-card, tinted)
//   2  -> the CSS rule it compiles to                 (background-color: var(--card))
//   3  light: :root sets --card -> a WHITE surface renders
//   4  dark:  .dark wins, --card -> a DARK surface renders (same node, swapped value)
//
// The single variable `--card` / `var(--card)` carries the same blue accent in
// every frame it appears (steps 2-4) so the eye follows one thread: the utility
// reads it, and each theme decides what it equals. The class slice `bg-card`
// shares that blue in step 1, because it *is* the thing that reads the variable.
//
// Pure HTML + CSS, devtools-inspectable, matching the sibling figures in this
// chapter (DesugarPanel, CnPipeline): a `not-content` class plus a `margin: 0`
// reset on every inner element defeat Starlight's prose-margin injection;
// Starlight gray/white/black/hairline variables flip the figure chrome with the
// site theme; the theme-aware --mark-blue-* palette (custom.css) gives the
// accent that flips too. The rendered surface swatches in steps 3-4 use literal
// near-white / near-black colors on purpose — those are the *resolved values of
// --card*, the thing the diagram is about, so they must NOT follow the reader's
// own theme.

interface Props {
  /** Which frame of the sequence to draw, 1-4. */
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The resolved values of --card the diagram is about. Fixed, theme-independent:
// these ARE oklch(1 0 0) and oklch(0.205 0 0) from the lesson's globals.css.
const LIGHT_SURFACE = "oklch(1 0 0)"; // pure white
const LIGHT_FG = "oklch(0.205 0 0)"; // near-black text on the light card
const LIGHT_MUTED = "oklch(0.556 0 0)";
const DARK_SURFACE = "oklch(0.205 0 0)"; // dark grey
const DARK_FG = "oklch(0.985 0 0)"; // near-white text on the dark card
const DARK_MUTED = "oklch(0.708 0 0)";

// ── shared inline-style strings ───────────────────────────────────────────

// Outer wrapper. A fixed min-height keeps the four frames close in height so the
// DiagramSequence stage (which sizes to the tallest) doesn't leave large gaps
// under the shorter ones, and centers the content vertically.
const wrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "align-items: center",
  "gap: 9px",
  "min-height: 196px",
  "box-sizing: border-box",
  "padding: 4px 0",
].join("; ");

// A labelled block: a small uppercase tag above its body.
const block = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 5px",
  "box-sizing: border-box",
  "min-width: 0",
].join("; ");

// The small uppercase tag above a code line or a swatch.
const tag = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "padding-left: 2px",
].join("; ");

// A code card. `cls` = the authored class string (light chrome); `css` = the
// compiled rule (dark editor chrome). A normal block so inline segments flow as
// text and literal spaces survive; overflow-x rescues long lines on a narrow card.
const codeCard = (kind: "cls" | "css") =>
  [
    reset,
    mono,
    "font-size: 14.5px",
    "font-weight: 500",
    "line-height: 1.5",
    "padding: 10px 13px",
    "border-radius: 9px",
    "white-space: nowrap",
    "overflow-x: auto",
    "box-sizing: border-box",
    kind === "cls"
      ? "background: var(--sl-color-gray-6, rgba(0,0,0,0.035))"
      : "background: var(--sl-color-black)",
    "border: 1px solid var(--sl-color-hairline)",
    kind === "cls"
      ? "color: var(--sl-color-white)"
      : "color: var(--sl-color-gray-2)",
  ].join("; ");

// The blue accent slice — the one variable (--card / var(--card)) or the class
// (bg-card) the whole figure tracks. Same treatment everywhere it appears so the
// thread reads as one token across frames.
const accent = [
  reset,
  "padding: 1px 4px",
  "margin: 0 -1px",
  "border-radius: 5px",
  "background: var(--mark-blue-bg)",
  "box-shadow: inset 0 0 0 1px var(--mark-blue-brd)",
  "color: var(--sl-color-white)",
  "font-weight: 700",
].join("; ");

// A vertical "compiles to" connector: a hairline with a centred down-chevron and
// a label. Used between two stacked rows (steps 1-2).
const connectorV = [
  reset,
  sans,
  "display: flex",
  "align-items: center",
  "gap: 8px",
  "align-self: stretch",
  "padding: 0 2px",
  "font-size: 10px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
].join("; ");

const ruleH = [
  reset,
  "flex: 1",
  "height: 1px",
  "background: var(--sl-color-hairline)",
].join("; ");

// A horizontal "resolves to" arrow between the source rule and the swatch
// (steps 3-4), so the row reads source -> rendered result and stays short.
const arrowRow = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "gap: 12px",
  "flex-wrap: wrap",
].join("; ");

const arrowLabel = [
  reset,
  sans,
  "display: flex",
  "flex-direction: column",
  "align-items: center",
  "gap: 2px",
  "font-size: 10px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
].join("; ");

// The rendered surface swatch — a mock card painted with the *resolved* --card
// value. Steps 3 and 4 render the identical mock; only the surface + foreground
// values differ, which is the whole point ("same node, swapped value").
const swatch = (surface: string, fg: string, muted: string) =>
  [
    reset,
    "width: 168px",
    "box-sizing: border-box",
    "padding: 12px 14px",
    "border-radius: 11px",
    "border: 1px solid color-mix(in oklch, " + fg + " 16%, transparent)",
    "background: " + surface,
    "color: " + fg,
    "box-shadow: 0 1px 2px rgba(0,0,0,0.18)",
    "display: flex",
    "flex-direction: column",
    "gap: 8px",
    mono,
  ].join("; ");

const swatchTitle = (fg: string) =>
  [
    reset,
    sans,
    "font-size: 12.5px",
    "font-weight: 700",
    "line-height: 1",
    "color: " + fg,
  ].join("; ");

const swatchLine = (muted: string, w: string) =>
  [
    reset,
    "height: 6px",
    "width: " + w,
    "border-radius: 999px",
    "background: " + muted,
    "opacity: 0.85",
  ].join("; ");

// The tiny `bg-card` badge pinned on the rendered card, proving the node wearing
// the class is the same one in both themes.
const cardBadge = (fg: string) =>
  [
    reset,
    mono,
    "align-self: flex-start",
    "margin-top: 2px",
    "font-size: 10.5px",
    "font-weight: 600",
    "line-height: 1",
    "padding: 3px 6px",
    "border-radius: 6px",
    "background: color-mix(in oklch, " + fg + " 12%, transparent)",
    "color: " + fg,
  ].join("; ");

// A theme-tag pill (<html class="dark">) sitting above the dark rule in step 4.
const htmlPill = [
  reset,
  mono,
  "font-size: 12px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 5px 9px",
  "border-radius: 7px",
  "background: var(--mark-violet-bg)",
  "box-shadow: inset 0 0 0 1px var(--mark-violet-brd)",
  "color: var(--sl-color-white)",
  "align-self: center",
].join("; ");

// ── down-chevron svg (shared) ─────────────────────────────────────────────
const chevron = `<svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 5 7 10 11 5"></polyline></svg>`;
// right-chevron for the horizontal "resolves to" arrow
const chevronR = `<svg width="20" height="20" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 3 10 7 5 11"></polyline></svg>`;
---

<div class="not-content" style={wrap} data-step={step}>
  {/* ── Step 1: the class the component writes ─────────────────────────── */}
  {
    step === 1 && (
      <div style={block}>
        <div style={tag}>The component writes</div>
        <div style={codeCard("cls")}>
          <span style={reset}>{`<div className="`}</span>
          <span style={accent}>bg-card</span>
          <span style={reset}>{`">`}</span>
        </div>
      </div>
    )
  }

  {/* ── Step 2: the rule it compiles to (the hinge) ────────────────────── */}
  {
    step === 2 && (
      <>
        <div style={block}>
          <div style={tag}>The component writes</div>
          <div style={codeCard("cls")}>
            <span style={reset}>{`<div className="`}</span>
            <span style={accent}>bg-card</span>
            <span style={reset}>{`">`}</span>
          </div>
        </div>

        <div style={connectorV} aria-hidden="true">
          <span style={ruleH} />
          <Fragment set:html={chevron} />
          <span style="margin: 0; white-space: nowrap;">compiles to</span>
          <Fragment set:html={chevron} />
          <span style={ruleH} />
        </div>

        <div style={block}>
          <div style={tag}>Tailwind emits</div>
          <div style={codeCard("css")}>
            <span style={reset}>{`.bg-card { background-color: `}</span>
            <span style={accent}>var(--card)</span>
            <span style={reset}>{` }`}</span>
          </div>
        </div>
      </>
    )
  }

  {/* ── Step 3: light theme resolves --card to a white surface ─────────── */}
  {
    step === 3 && (
      <div style={arrowRow}>
        <div style={block}>
          <div style={tag}>Light theme</div>
          <div style={codeCard("css")}>
            <span style={reset}>{`:root { `}</span>
            <span style={accent}>--card</span>
            <span style={reset}>{`: ${LIGHT_SURFACE} }`}</span>
          </div>
        </div>

        <div style={arrowLabel} aria-hidden="true">
          <Fragment set:html={chevronR} />
          <span style="margin: 0; white-space: nowrap;">resolves to</span>
        </div>

        <div style={block}>
          <div style={tag}>Rendered node</div>
          <div style={swatch(LIGHT_SURFACE, LIGHT_FG, LIGHT_MUTED)}>
            <div style={swatchTitle(LIGHT_FG)}>Quarterly report</div>
            <div style={swatchLine(LIGHT_MUTED, "70%")} />
            <div style={cardBadge(LIGHT_FG)}>bg-card</div>
          </div>
        </div>
      </div>
    )
  }

  {/* ── Step 4: dark theme wins, --card resolves to a dark surface ─────── */}
  {
    step === 4 && (
      <div style={arrowRow}>
        <div style={block}>
          <div style={tag}>Dark theme</div>
          <div
            style={[
              reset,
              "display: flex",
              "flex-direction: column",
              "gap: 6px",
              "align-items: center",
            ].join("; ")}
          >
            <span style={htmlPill}>{`<html class="dark">`}</span>
            <div style={codeCard("css")}>
              <span style={reset}>{`.dark { `}</span>
              <span style={accent}>--card</span>
              <span style={reset}>{`: ${DARK_SURFACE} }`}</span>
            </div>
          </div>
        </div>

        <div style={arrowLabel} aria-hidden="true">
          <Fragment set:html={chevronR} />
          <span style="margin: 0; white-space: nowrap;">resolves to</span>
        </div>

        <div style={block}>
          <div style={tag}>Rendered node</div>
          <div style={swatch(DARK_SURFACE, DARK_FG, DARK_MUTED)}>
            <div style={swatchTitle(DARK_FG)}>Quarterly report</div>
            <div style={swatchLine(DARK_MUTED, "70%")} />
            <div style={cardBadge(DARK_FG)}>bg-card</div>
          </div>
        </div>
      </div>
    )
  }
</div>
