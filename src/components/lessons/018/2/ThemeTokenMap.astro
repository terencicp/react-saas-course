---
// The lesson's keystone visual — the definer-direction analog of Lesson 1's
// `UtilityToCssMap`. It makes v4's determinism *visible*: the `{name}` you choose
// in a `@theme` token reappears, unchanged, in every utility that token mints.
// Read each row left-to-right: the `@theme` line on the LEFT, a centered arrow,
// and on the RIGHT the family of utilities that one token brings into existence,
// each as its own chip.
//
// The load-bearing behavior: in BOTH the left token and every right-hand chip the
// namespace/family *prefix* stays dim (`--color-`, `bg-`), and only the shared
// `{name}` segment is tinted — `brand` lights up inside `--color-`brand and again
// inside `bg-`brand, `text-`brand, … — so the eye can trace the name from the
// definition into the utilities. Each row carries its own `--mark-*` family so the
// three namespaces don't blur into each other (blue / orange / violet — green and
// red are skipped to avoid a correct/wrong reading).
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the layout: three
// columns (token | arrow | utilities). The token column is sized to the longest
// `@theme` line so the arrows align; the utilities column flexes and its chips
// wrap. `margin: 0` reset on every inner element (belt-and-braces with the
// `not-content` class) defeats Starlight's prose-margin injection. Chrome uses
// Starlight gray/white CSS variables so it flips with light/dark; the accent tints
// come from the theme-aware `--mark-*` palette in custom.css so they flip too.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// One row per namespace. Both the token line and every utility chip are expressed
// as ordered `segments`, each segment a `{ t, v }` pair where `t` is `dim` (the
// namespace/family prefix and the literal value — muted) or `name` (the shared
// `{name}` the eye traces — tinted in the row's family color). Rendering segments
// via `.map()` keeps them as *adjacent* nodes with no source whitespace between
// them, so the chip reads `bg-brand`, not `bg- brand`. `color` names a `--mark-*`
// family from custom.css.
//
// `seg(prefix, name)` builds a `[dim prefix, tinted name]` pair; the token also
// appends the dim literal value after a colon.
const seg = (prefix: string, name: string) => [
  { t: "dim", v: prefix },
  { t: "name", v: name },
];

const rows = [
  {
    color: "blue",
    token: [...seg("--color-", "brand"), { t: "dim", v: ": oklch(0.62 0.19 256)" }],
    utilities: [
      seg("bg-", "brand"),
      seg("text-", "brand"),
      seg("border-", "brand"),
      seg("ring-", "brand"),
    ],
  },
  {
    color: "orange",
    token: [...seg("--spacing-", "gutter"), { t: "dim", v: ": 1.75rem" }],
    utilities: [
      seg("p-", "gutter"),
      seg("m-", "gutter"),
      seg("gap-", "gutter"),
      seg("size-", "gutter"),
    ],
  },
  {
    color: "violet",
    token: [...seg("--radius-", "card"), { t: "dim", v: ": 0.75rem" }],
    utilities: [seg("rounded-", "card")],
  },
];

const grid = [
  reset,
  "display: grid",
  // token column (sized to the longest @theme line) | arrow | utilities column
  "grid-template-columns: max-content auto 1fr",
  "align-items: center",
  "column-gap: 0",
  "row-gap: 14px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Column header cells (the small "@theme token" / "utilities it mints" labels).
const headStyle = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "padding: 0 0 2px 2px",
].join("; ");

// Left tile: the `@theme` line. Faint tint of the row's family + a matching left
// border so the whole row reads as one color group; the dim prefix/value let the
// tinted name pop.
const tokenCell = (color: string) =>
  [
    reset,
    mono,
    "font-size: 15px",
    "font-weight: 600",
    "line-height: 1.3",
    "display: flex",
    "align-items: center",
    "padding: 9px 14px",
    "border-radius: 8px 0 0 8px",
    `background: var(--mark-${color}-bg)`,
    `border-left: 3px solid var(--mark-${color}-brd)`,
    "white-space: nowrap",
    "box-sizing: border-box",
  ].join("; ");

// Center arrow column.
const arrowCell = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "padding: 0 16px",
  "color: var(--sl-color-gray-3)",
  "font-size: 18px",
  "line-height: 1",
  "user-select: none",
].join("; ");

// Right cell: a wrapping row of the utility chips this token mints.
const utilitiesCell = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "column-gap: 8px",
  "row-gap: 8px",
  "box-sizing: border-box",
].join("; ");

// Each minted utility, as a monospace chip. Outlined in the row's family color so
// the chip belongs to its row; the dim prefix lets the tinted name carry the eye.
const chip = (color: string) =>
  [
    reset,
    mono,
    "font-size: 14px",
    "font-weight: 600",
    "line-height: 1.2",
    "padding: 5px 10px",
    "border-radius: 7px",
    `background: var(--mark-${color}-bg)`,
    `border: 1px solid var(--mark-${color}-brd)`,
    "white-space: nowrap",
    "box-sizing: border-box",
  ].join("; ");

// The shared `{name}` segment — tinted in the row's family color, on both sides.
// This is the one thing the eye is meant to trace from token to utilities.
const nameSpan = (color: string) =>
  [reset, `color: var(--mark-${color}-brd)`].join("; ");

// The dim parts: the namespace/family prefix and the literal value. Muted so the
// tinted name is what stands out.
const dimSpan = [reset, "color: var(--sl-color-gray-2)"].join("; ");

// Render one segment array (`dim` text or the `name` accent) into adjacent spans
// with no whitespace between them, so the slices concatenate into the exact
// literal string (`bg-brand`, `--color-brand: …`).
const renderSegs = (segs: { t: string; v: string }[], color: string) =>
  segs.map((s) =>
    s.t === "name" ? { style: nameSpan(color), v: s.v } : { style: dimSpan, v: s.v },
  );
---

<div class="not-content" style={grid}>
  {/* Header row: a blank cell over the arrow column keeps the two labels above their tiles */}
  <div style={headStyle}>@theme token</div>
  <div style={reset}></div>
  <div style={headStyle}>Utilities it mints</div>

  {/* One grid row per namespace */}
  {
    rows.map((r) => (
      <Fragment>
        <div style={tokenCell(r.color)}>
          {renderSegs(r.token, r.color).map((s) => (
            <span style={s.style}>{s.v}</span>
          ))}
        </div>
        <div style={arrowCell} aria-hidden="true">
          &rarr;
        </div>
        <div style={utilitiesCell}>
          {r.utilities.map((u) => (
            <span style={chip(r.color)}>
              {renderSegs(u, r.color).map((s) => (
                <span style={s.style}>{s.v}</span>
              ))}
            </span>
          ))}
        </div>
      </Fragment>
    ))
  }
</div>
