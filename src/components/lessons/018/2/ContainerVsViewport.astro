---
// The `@container` section's one-glance contrast: the SAME card component placed in
// two different-width slots, at the SAME implied viewport, laying itself out
// differently *because of its own box*. Left scene = a wide content column, the card
// goes two-up (thumbnail beside text). Right scene = a narrow sidebar, the identical
// card stacks (thumbnail above text). The teaching beat the figure has to make
// visible: a *viewport* breakpoint sees one screen width and would render both
// scenes alike — only a *container* query lets the sidebar card collapse on its own.
//
// The behavior is REAL, not faked: each card wrapper is a CSS containment context
// (`container-type: inline-size`), and a genuine `@container (min-width: …)` rule
// flips the card body between one and two columns based on the wrapper's measured
// width. So a reader can open devtools, see two live container queries, and watch the
// same rule resolve differently in the wide vs narrow slot — the pedagogical USP of
// the HTML+CSS medium. `@container` rules can't be written as inline `style=`, so
// this component uses a scoped `<style>` block (the inline-style sibling components
// don't need one; this diagram genuinely does).
//
// Theme-aware throughout: Starlight gray/white CSS variables for chrome so it flips
// with light/dark, and the `--mark-blue-*` accent (from custom.css) to tint the card
// and the governing-class code labels so they read as one group and flip too. Every
// element carries `margin: 0` (belt-and-braces with `not-content`) to defeat
// Starlight's prose-margin injection.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The two scenes. `wide` drives which slot gets the extra flex weight, and the label
// strip + sub-annotation under each. `cls` is the governing-class code label shown as
// a caption strip under the scene.
const scenes = [
  {
    key: "wide",
    label: "Wide column",
    annotation: "The card has room, so it lays its contents out in two columns.",
    cls: ["@container", "@lg:grid-cols-2"],
    flex: 1.85,
  },
  {
    key: "narrow",
    label: "Narrow sidebar",
    annotation: "The same card is squeezed, so it stacks to one column on its own.",
    cls: ["@container", "@lg:grid-cols-2"],
    flex: 1,
  },
];

// Outer rail: the two scenes side by side, sharing one implied viewport. A faint
// "screen" frame around both makes the shared-viewport point literal — both cards
// live behind the same browser width.
const screenFrame = [
  reset,
  "display: flex",
  "gap: 18px",
  "align-items: stretch",
  "padding: 16px",
  "border-radius: 12px",
  "border: 1px dashed var(--sl-color-gray-4)",
  "background: var(--sl-color-gray-6, rgba(0,0,0,0.02))",
  "box-sizing: border-box",
].join("; ");

// A single scene column (label + slot frame + sub-annotation), stacked vertically.
const sceneCol = (flex: number) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    `flex: ${flex} 1 0`,
    "min-width: 0",
    "box-sizing: border-box",
  ].join("; ");

// The little "Wide column" / "Narrow sidebar" heading above each slot.
const sceneLabel = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 700",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "padding: 0 2px 7px",
].join("; ");

// The slot frame — the wide content area / narrow sidebar the card drops into. The
// frame itself is just chrome; the card inside is what adapts.
const slotFrame = [
  reset,
  "flex: 1",
  "display: flex",
  "padding: 12px",
  "border-radius: 10px",
  "border: 1px solid var(--sl-color-gray-5)",
  "background: var(--sl-color-bg)",
  "box-sizing: border-box",
].join("; ");

// The card body — a real grid whose column count the scoped `@container` rule flips.
// `display: grid`, the default single column, and the gap live in the `<style>`
// block below (NOT inline): an inline `grid-template-columns` would have higher
// specificity than the `@container` rule and would stop the query from ever winning,
// so the grid layout has to come from the stylesheet for the override to take.
const cardBody = [
  reset,
  "width: 100%",
  "padding: 12px",
  "border-radius: 9px",
  "background: var(--mark-blue-bg)",
  "border: 1px solid var(--mark-blue-brd)",
  "box-sizing: border-box",
].join("; ");

// The card's thumbnail block — a flat tinted rectangle standing in for an image.
const thumb = [
  reset,
  "border-radius: 6px",
  "min-height: 52px",
  "background: var(--mark-blue-brd)",
  "opacity: 0.85",
  "box-sizing: border-box",
].join("; ");

// The card's text column — a heading bar plus two body lines, all faked as bars so
// the layout (not the words) is what reads.
const textCol = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 7px",
  "min-width: 0",
  "box-sizing: border-box",
].join("; ");

const bar = (w: string, strong = false) =>
  [
    reset,
    "height: 8px",
    `width: ${w}`,
    "border-radius: 4px",
    strong
      ? "background: var(--sl-color-gray-2)"
      : "background: var(--sl-color-gray-4)",
    "box-sizing: border-box",
  ].join("; ");

// The governing-class code strip under each scene: `@container` on the wrapper,
// `@lg:grid-cols-2` on the child. The active state differs by scene — in the wide
// scene the `@lg:grid-cols-2` is what fired (so it's lit); in the narrow scene the
// container never reached `@lg`, so the same class sits dim/inert. That contrast is
// the lesson: identical classes, different outcome, decided by the box.
const codeStrip = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "column-gap: 6px",
  "row-gap: 4px",
  "padding: 8px 2px 0",
].join("; ");

const codeChip = (active: boolean) =>
  [
    reset,
    mono,
    "font-size: 12px",
    "font-weight: 600",
    "line-height: 1.2",
    "padding: 3px 7px",
    "border-radius: 6px",
    "white-space: nowrap",
    active
      ? "background: var(--mark-blue-bg)"
      : "background: var(--sl-color-gray-6, rgba(0,0,0,0.04))",
    active
      ? "color: var(--sl-color-white)"
      : "color: var(--sl-color-gray-3)",
    active
      ? "border: 1px solid var(--mark-blue-brd)"
      : "border: 1px solid var(--sl-color-gray-5)",
    "box-sizing: border-box",
  ].join("; ");

// The "fired" / "inert" tag after the class strip, naming whether `@lg` matched in
// this scene.
const fireTag = (active: boolean) =>
  [
    reset,
    sans,
    "font-size: 10.5px",
    "font-weight: 700",
    "letter-spacing: 0.03em",
    "text-transform: uppercase",
    "line-height: 1",
    "padding: 3px 6px",
    "border-radius: 5px",
    active
      ? "background: var(--mark-blue-bg)"
      : "background: transparent",
    active
      ? "color: var(--mark-blue-brd)"
      : "color: var(--sl-color-gray-3)",
    "box-sizing: border-box",
  ].join("; ");

// The per-scene sub-annotation under the code strip.
const annotation = [
  reset,
  sans,
  "font-size: 12px",
  "line-height: 1.4",
  "color: var(--sl-color-gray-2)",
  "padding: 8px 2px 0",
].join("; ");

// The teaching banner under both scenes — the beat the whole figure exists to make:
// a viewport breakpoint can't tell these two apart; a container query can.
const banner = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.45",
  "color: var(--sl-color-gray-2)",
  "margin: 14px 0 0",
  "padding: 10px 14px",
  "border-radius: 9px",
  "border-left: 3px solid var(--mark-blue-brd)",
  "background: var(--mark-blue-bg)",
  "box-sizing: border-box",
].join("; ");
---

<div class="not-content cvv-root" style={reset}>
  <div style={screenFrame}>
    {
      scenes.map((s) => (
        <div style={sceneCol(s.flex)}>
          <div style={sceneLabel}>{s.label}</div>

          <div style={slotFrame}>
            {/* The card wrapper IS the containment context — a real `@container`. */}
            <div class="cvv-card" style="margin: 0; flex: 1; min-width: 0; container-type: inline-size;">
              <div class="cvv-body" style={cardBody}>
                <div style={thumb} aria-hidden="true" />
                <div style={textCol}>
                  <div style={bar("75%", true)} aria-hidden="true" />
                  <div style={bar("100%")} aria-hidden="true" />
                  <div style={bar("85%")} aria-hidden="true" />
                </div>
              </div>
            </div>
          </div>

          <div style={codeStrip}>
            <span style={codeChip(true)}>{s.cls[0]}</span>
            <span style={codeChip(s.key === "wide")}>{s.cls[1]}</span>
            <span style={fireTag(s.key === "wide")}>
              {s.key === "wide" ? "fired" : "inert"}
            </span>
          </div>

          <div style={annotation}>{s.annotation}</div>
        </div>
      ))
    }
  </div>

  <p style={banner}>
    Same component, same screen width — only the available box differs. A{" "}
    <strong style="margin: 0; color: var(--sl-color-gray-1);">viewport</strong>{" "}
    breakpoint reads the screen, so it would style both cards identically; a{" "}
    <strong style="margin: 0; color: var(--sl-color-gray-1);">container</strong>{" "}
    query reads each card&rsquo;s own width, so the sidebar one collapses by itself.
  </p>
</div>

<style>
  /* The real container query, the thing a reader can inspect. Each `.cvv-card` is a
     `container-type: inline-size` context (set inline on the element); when its
     measured width reaches the threshold, its body switches to two columns. The wide
     slot clears this width; the narrow slot never does — so the identical rule
     resolves differently per scene, which is the whole point. The threshold is well
     below Tailwind's real `@lg` (32rem) on purpose, sized to this figure's slot
     widths so the contrast shows inside the card.

     The grid lives here (not inline) on purpose: an inline `grid-template-columns`
     outranks any selector, so the `@container` override could never win. With both
     the default and the override in the stylesheet, source order decides. */
  .cvv-root .cvv-card {
    container-name: cvvcard;
  }

  .cvv-root .cvv-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  @container cvvcard (min-width: 240px) {
    .cvv-root .cvv-body {
      grid-template-columns: 96px 1fr;
      align-items: center;
    }
  }
</style>
