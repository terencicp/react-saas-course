---
// The lesson's closing figure: the v4 build as one left-to-right flow, so the
// student sees input -> engine -> output as a single picture. It exists to make
// two facts from the text concrete — the output is *scan-derived*, not
// config-derived, and there is no separate build step. Read it left to right:
// two stacked INPUTS (your `globals.css` directives + the source files scanned
// as text) feed one ENGINE (Lightning CSS), which emits one OUTPUT (a single
// stylesheet holding only the utilities the source actually used).
//
// The load-bearing beat lives in the banner under the flow: unused tokens and
// unused utilities cost nothing because they were never written out, and a class
// name assembled from a string (last lesson's trap) never appears because the
// scanner never read it as literal text. That's *why* the output is derived from
// source, not config.
//
// Pure HTML + CSS, devtools-inspectable, matching its three sibling components in
// this lesson. A flex row drives the layout (inputs | arrow | engine | arrow |
// output); on narrow viewports it wraps and the connectors rotate to vertical so
// the flow still reads top-to-bottom. Each stage owns a distinct `--mark-*`
// family (blue inputs / violet engine / orange output — green and red are skipped
// to avoid a correct/wrong reading, same as the sibling figures). `margin: 0`
// reset on every inner element (belt-and-braces with the `not-content` class)
// defeats Starlight's prose-margin injection; Starlight gray/white CSS variables
// keep the chrome flipping with light/dark, and the `--mark-*` accents (from
// custom.css) flip too.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// The two inputs stacked into the left node. `mono` flags the title as a code
// string (a real path / file kind) vs. plain sans. `note` is the sub-annotation.
const inputs = [
  { title: "app/globals.css", mono: true, note: "your directives" },
  { title: "source files", mono: false, note: "scanned as text — .tsx, .mdx" },
];

// Outer rail: the whole flow on one horizontal axis, wrapping on narrow widths.
const rail = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: stretch",
  "justify-content: center",
  "gap: 10px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// The left node is itself a small vertical stack of the two input cards, plus a
// header strip naming them as the build's inputs.
const inputsCol = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 8px",
  "flex: 1 1 200px",
  "min-width: 0",
  "box-sizing: border-box",
].join("; ");

// The small uppercase "inputs" / "engine" / "output" stage label above each node.
const stageLabel = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "padding: 0 2px 6px",
].join("; ");

// A node card. `color` names the stage's `--mark-*` family; `emphatic` thickens
// the border for the engine/output so they read as the transform and its result.
const card = (color: string, emphatic = false) =>
  [
    reset,
    "display: flex",
    "flex-direction: column",
    "justify-content: center",
    "gap: 5px",
    "padding: 11px 13px",
    "border-radius: 10px",
    `background: var(--mark-${color}-bg)`,
    emphatic
      ? `border: 2px solid var(--mark-${color}-brd)`
      : `border: 1px solid var(--mark-${color}-brd)`,
    "box-sizing: border-box",
  ].join("; ");

// The card's title line. Mono for a real path/file kind, sans otherwise.
const cardTitle = (isMono: boolean) =>
  [
    reset,
    isMono ? mono : sans,
    "font-size: 13.5px",
    "font-weight: 700",
    "line-height: 1.25",
    "color: var(--sl-color-white)",
    "box-sizing: border-box",
  ].join("; ");

// The card's sub-annotation, muted and sans so it reads as a gloss on the title.
const cardNote = [
  reset,
  sans,
  "font-size: 11.5px",
  "line-height: 1.35",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

// A middle node (engine / output), centered on the rail as its own column so its
// stage label sits above it like the inputs column's does.
const node = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "flex: 1 1 180px",
  "min-width: 0",
  "box-sizing: border-box",
].join("; ");

// The connector between nodes — an arrow that points right on wide viewports and
// rotates to point down once the rail wraps, so the flow direction always reads.
const connector = [
  reset,
  "display: flex",
  "align-items: center",
  "justify-content: center",
  "flex: 0 0 auto",
  "color: var(--sl-color-gray-3)",
  "font-size: 22px",
  "line-height: 1",
  "user-select: none",
].join("; ");

// The closing banner — the beat the figure exists to drive home: the output is
// scan-derived, so unused tokens cost nothing and a string-built class never ships.
const banner = [
  reset,
  sans,
  "font-size: 12.5px",
  "line-height: 1.45",
  "color: var(--sl-color-gray-2)",
  "margin: 14px 0 0",
  "padding: 10px 14px",
  "border-radius: 9px",
  "border-left: 3px solid var(--mark-orange-brd)",
  "background: var(--mark-orange-bg)",
  "box-sizing: border-box",
].join("; ");

const strong = "margin: 0; color: var(--sl-color-gray-1); font-weight: 700";
---

<div class="not-content cpl-root" style={reset}>
  <div style={rail}>
    {/* INPUTS — two stacked cards feeding the engine */}
    <div style={inputsCol}>
      <div style={stageLabel}>Inputs</div>
      {
        inputs.map((i) => (
          <div style={card("blue")}>
            <div style={cardTitle(i.mono)}>{i.title}</div>
            <div style={cardNote}>{i.note}</div>
          </div>
        ))
      }
    </div>

    <div class="cpl-arrow" style={connector} aria-hidden="true">&rarr;</div>

    {/* ENGINE — Lightning CSS, the transform */}
    <div style={node}>
      <div style={stageLabel}>Engine</div>
      <div style={card("violet", true)}>
        <div style={cardTitle(false)}>Lightning CSS</div>
        <div style={cardNote}>transforms + minifies — no PostCSS step</div>
      </div>
    </div>

    <div class="cpl-arrow" style={connector} aria-hidden="true">&rarr;</div>

    {/* OUTPUT — one stylesheet, used utilities only */}
    <div style={node}>
      <div style={stageLabel}>Output</div>
      <div style={card("orange", true)}>
        <div style={cardTitle(false)}>One CSS file</div>
        <div style={cardNote}>only the utilities your source actually used</div>
      </div>
    </div>
  </div>

  <p style={banner}>
    The output is built from your <strong style={strong}>source</strong>, not your{" "}
    <strong style={strong}>config</strong>. Unused tokens and utilities cost nothing —
    they were never written out — and a class name assembled from a string{" "}
    (<code style="margin: 0; font-family: ui-monospace, monospace;">{"`bg-${color}-500`"}</code>)
    never appears, because the scanner never read it as text.
  </p>
</div>

<style>
  /* On wide viewports the rail is one horizontal line, so the connectors point
     right. Once the rail wraps (narrow viewports), the arrows rotate to point
     down so the flow still reads top-to-bottom. The breakpoint is keyed to the
     rail's own flex-basis sum, not the page, so it tracks the figure not the
     viewport. */
  @media (max-width: 34rem) {
    .cpl-root .cpl-arrow {
      transform: rotate(90deg);
      padding: 2px 0;
    }
  }
</style>
