---
// The lesson's load-bearing reference table: which `@theme` namespace mints which
// utility family. It's the lookup the student runs in *both* directions — forward
// (I defined `--color-brand`, so `bg-brand`/`text-brand`/… now exist) and, more
// importantly, backward (my `bg-brand` doesn't exist → which namespace did I get
// wrong?). So it's a scan-at-a-glance map, not a diagram: namespace on the LEFT,
// the family/families it mints in the MIDDLE as chips, a one-line plain-language
// note on the RIGHT where the row earns it.
//
// Styled as the sibling of Lesson 1's `UtilityFamilies` (label | pills, pure HTML
// + CSS, theme-aware, compact rows) so the two read as one chapter. The two bridge
// rows — `--breakpoint-*` (back to Lesson 1's responsive prefixes) and
// `--container-*` (forward to this lesson's `@container` section) — are tinted and
// carry a left rule so they stand out as the prose calls them out.
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the layout: three
// columns (namespace | minted-family chips | note). The namespace column is sized
// to the longest token so the chips align; the chips column flexes and wraps; the
// note column takes the remainder and wraps freely. `margin: 0` reset on every
// inner element (belt-and-braces with the `not-content` class) defeats Starlight's
// prose-margin injection. Chrome uses Starlight gray/white CSS variables so it
// flips with light/dark; the bridge-row tint comes from the theme-aware `--mark-*`
// palette in custom.css so it flips too.

const reset = "margin: 0";

const mono =
  "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// One entry per namespace. `ns` is the namespace token (left), `mints` the utility
// families it brings into existence (middle chips), `note` the optional plain note
// (right). `bridge` flags the two rows the prose singles out as bridges — they get
// the accent tint + left rule. A `null` note renders an empty (but still present)
// note cell so the grid columns stay aligned.
const rows: {
  ns: string;
  mints: string[];
  note: string | null;
  bridge?: boolean;
}[] = [
  {
    ns: "--color-*",
    mints: ["bg-*", "text-*", "border-*", "ring-*", "fill-*", "stroke-*"],
    note: "every color utility, for any color token",
  },
  {
    ns: "--spacing-*",
    mints: ["p-*", "m-*", "gap-*", "size-*", "w-*", "h-*"],
    note: "the one scale behind all spacing and sizing",
  },
  {
    ns: "--radius-*",
    mints: ["rounded-*"],
    note: null,
  },
  {
    ns: "--text-*",
    mints: ["text-*"],
    note: "font size — pair a line-height via a --{name}--line-height suffix",
  },
  {
    ns: "--font-*",
    mints: ["font-*"],
    note: "font family only — weight, tracking, leading are separate namespaces",
  },
  {
    ns: "--shadow-*",
    mints: ["shadow-*"],
    note: null,
  },
  {
    ns: "--breakpoint-*",
    mints: ["sm:", "md:", "lg:"],
    note: "the responsive prefixes from last lesson — where md is defined",
    bridge: true,
  },
  {
    ns: "--container-*",
    mints: ["@sm:", "@md:", "max-w-*"],
    note: "container-query variants (next section) plus container sizes",
    bridge: true,
  },
  {
    ns: "--animate-*",
    mints: ["animate-*"],
    note: "named for completeness — animation is a later chapter",
  },
];

const grid = [
  reset,
  "display: grid",
  // namespace column (sized to the longest token) | minted-family chips (flexes,
  // chips wrap inside) | note (gets a real share so it wraps to ~2 lines, not 6)
  "grid-template-columns: max-content minmax(0, 1.35fr) minmax(0, 1fr)",
  "align-items: stretch",
  "column-gap: 0",
  "row-gap: 6px",
  "width: 100%",
  "box-sizing: border-box",
].join("; ");

// Column header cells (the small "namespace" / "mints" / "" labels).
const headStyle = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "letter-spacing: 0.04em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
  "padding: 0 0 4px 12px",
].join("; ");

// Left tile: the namespace token. On a bridge row it carries a faint blue tint and
// a matching left rule so it stands out; otherwise it sits on the plain surface.
// Monospace + the namespace is the recognized part the student matches against.
const nsCell = (bridge: boolean) =>
  [
    reset,
    mono,
    "font-size: 14px",
    "font-weight: 600",
    "line-height: 1.2",
    "display: flex",
    "align-items: center",
    "padding: 7px 14px 7px 12px",
    "border-radius: 7px 0 0 7px",
    "color: var(--sl-color-white)",
    "white-space: nowrap",
    bridge
      ? "background: var(--mark-blue-bg)"
      : "background: var(--sl-color-gray-6, rgba(0,0,0,0.03))",
    bridge
      ? "border-left: 3px solid var(--mark-blue-brd)"
      : "border-left: 3px solid transparent",
    "box-sizing: border-box",
  ].join("; ");

// Middle cell: a wrapping row of the family chips this namespace mints.
const mintsCell = (bridge: boolean) =>
  [
    reset,
    "display: flex",
    "flex-wrap: wrap",
    "align-items: center",
    "column-gap: 6px",
    "row-gap: 6px",
    "padding: 6px 14px",
    bridge
      ? "background: var(--mark-blue-bg)"
      : "background: var(--sl-color-gray-6, rgba(0,0,0,0.03))",
    "box-sizing: border-box",
  ].join("; ");

// Each minted family, as a monospace chip. The faint sky tint matches Lesson 1's
// `UtilityFamilies` pills — "this is a class-name surface".
const chip = [
  reset,
  mono,
  "font-size: 13px",
  "font-weight: 500",
  "line-height: 1.2",
  "padding: 3px 8px",
  "border-radius: 6px",
  "background: rgba(56, 189, 248, 0.12)",
  "color: var(--sl-color-gray-1)",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

// Right cell: the plain-language note. Sans-serif and muted so it reads as a gloss,
// not part of the code. Vertically centered; wraps freely in the remaining width.
const noteCell = (bridge: boolean) =>
  [
    reset,
    sans,
    "font-size: 12.5px",
    "line-height: 1.35",
    "display: flex",
    "align-items: center",
    "padding: 6px 12px",
    "border-radius: 0 7px 7px 0",
    "color: var(--sl-color-gray-2)",
    bridge
      ? "background: var(--mark-blue-bg)"
      : "background: var(--sl-color-gray-6, rgba(0,0,0,0.03))",
    "box-sizing: border-box",
  ].join("; ");
---

<div class="not-content" style={grid}>
  {/* Header row: labels over the namespace and mints columns; the note column is unlabeled */}
  <div style={headStyle}>namespace</div>
  <div style={headStyle}>utility families it mints</div>
  <div style={reset}></div>

  {/* One grid row per namespace — three sibling cells so the row tint runs edge to edge */}
  {
    rows.map((r) => {
      const bridge = r.bridge ?? false;
      return (
        <Fragment>
          <div style={nsCell(bridge)}>{r.ns}</div>
          <div style={mintsCell(bridge)}>
            {r.mints.map((m) => (
              <span style={chip}>{m}</span>
            ))}
          </div>
          <div style={noteCell(bridge)}>{r.note}</div>
        </Fragment>
      );
    })
  }
</div>
