---
// One frame of the cn() pipeline, rendered as rows of utility "pills" so the
// student can watch a concrete class string transform across the four steps of
// the DiagramSequence in the lesson. Each <CnPipeline step={n} /> is the body of
// one DiagramStep; the surrounding captions narrate, this draws the state.
//
// The whole point is to make the two jobs of cn() visible:
//   1 Inputs        — the three raw arguments as authored (base string, a
//                     conditional object with isPending=false, the consumer's px-8).
//   2 After clsx    — everything flattened into one row; the falsy opacity-50 is
//                     dropped, but BOTH px-4 and px-8 still ride along.
//   3 Conflict      — tailwind-merge groups px-4 + px-8 as one conflict (amber),
//                     joined by a bracket, because they set the same property.
//   4 After merge   — px-4 struck out and faded (deleted), the consumer's px-8
//                     left standing as the survivor (green).
//
// To let the eye track the two padding utilities across steps, px-8 carries a
// faint "consumer" blue tint from step 2 on, and the px-4/px-8 pills keep their
// position (px-4 is struck in place in step 4 rather than reordered) so the
// deletion reads as "this one got removed", not "the row got shuffled".
//
// Pure HTML + CSS, devtools-inspectable, matching the sibling figures in this
// chapter (CompilePipeline et al.): `not-content` + a `margin: 0` reset defeat
// Starlight's prose-margin injection, Starlight gray/white variables flip the
// chrome with light/dark, and the --mark-* accents (custom.css) flip too. Orange
// is the amber "conflict" family; green is the survivor; red is deliberately
// avoided so nothing reads as an error.

interface Props {
  /** Which frame of the pipeline to draw, 1-4. */
  step: 1 | 2 | 3 | 4;
}

const { step } = Astro.props;

const reset = "margin: 0";

const mono =
  "font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";

const sans =
  "font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Pill "tones". `plain` is a neutral utility; `consumer` keeps the override
// faintly blue so it's followable across rows; `conflict` is the amber pair;
// `survivor` is the green winner; `dropped` is a falsy/removed pill — struck and
// faded. Each maps to a small style fragment so the markup below stays readable.
type Tone = "plain" | "consumer" | "conflict" | "survivor" | "dropped";

const pillBase = [
  reset,
  mono,
  "display: inline-flex",
  "align-items: center",
  "font-size: 12.5px",
  "font-weight: 600",
  "line-height: 1",
  "padding: 6px 9px",
  "border-radius: 7px",
  "white-space: nowrap",
  "box-sizing: border-box",
].join("; ");

const toneStyle: Record<Tone, string> = {
  plain: [
    "color: var(--sl-color-white)",
    "background: var(--sl-color-gray-6, var(--sl-color-gray-5))",
    "border: 1px solid var(--sl-color-gray-5)",
  ].join("; "),
  consumer: [
    "color: var(--sl-color-white)",
    "background: var(--mark-blue-bg)",
    "border: 1px solid var(--mark-blue-brd)",
  ].join("; "),
  conflict: [
    "color: var(--sl-color-white)",
    "background: var(--mark-orange-bg)",
    "border: 1.5px solid var(--mark-orange-brd)",
  ].join("; "),
  survivor: [
    "color: var(--sl-color-white)",
    "background: var(--mark-green-bg)",
    "border: 1.5px solid var(--mark-green-brd)",
  ].join("; "),
  dropped: [
    "color: var(--sl-color-gray-3)",
    "background: transparent",
    "border: 1px dashed var(--sl-color-gray-4)",
    "text-decoration: line-through",
    "opacity: 0.6",
  ].join("; "),
};

const pill = (tone: Tone) => `${pillBase}; ${toneStyle[tone]}`;

// A horizontal, wrapping row of pills — the shared shape of every step's body.
const row = [
  reset,
  "display: flex",
  "flex-wrap: wrap",
  "align-items: center",
  "gap: 7px",
  "box-sizing: border-box",
].join("; ");

// The small uppercase stage tag above each row (e.g. "INPUTS", "AFTER clsx").
// Names the transform happening so the rows have a stable top edge; the caption
// carries the full sentence, this is just the label.
const stageTag = [
  reset,
  sans,
  "font-size: 10.5px",
  "font-weight: 700",
  "letter-spacing: 0.06em",
  "text-transform: uppercase",
  "line-height: 1",
  "color: var(--sl-color-gray-3)",
].join("; ");

const stageTagCode = [
  mono,
  "text-transform: none",
  "letter-spacing: 0",
  "color: var(--sl-color-white)",
  "font-size: 12px",
].join("; ");

// In step 1, each argument is its own labelled group so the student sees the
// three *separate* inputs before they get flattened. `groupLabel` is the literal
// source the group renders, in muted mono.
const inputGroup = [
  reset,
  "display: flex",
  "flex-direction: column",
  "gap: 7px",
  "box-sizing: border-box",
].join("; ");

const groupLabel = [
  reset,
  mono,
  "font-size: 11px",
  "line-height: 1.4",
  "color: var(--sl-color-gray-2)",
  "box-sizing: border-box",
].join("; ");

const groupKind = [
  reset,
  sans,
  "font-size: 10px",
  "font-weight: 700",
  "letter-spacing: 0.05em",
  "text-transform: uppercase",
  "color: var(--sl-color-gray-3)",
  "margin-bottom: 1px",
].join("; ");

// The thin divider between the three input groups in step 1.
const divider =
  "margin: 2px 0; border: 0; border-top: 1px solid var(--sl-color-hairline)";

// Outer wrapper. A fixed min-height keeps the four frames close in height so the
// DiagramSequence stage (which sizes to the tallest) doesn't leave big gaps under
// the shorter single-row steps.
const wrap = [
  reset,
  "display: flex",
  "flex-direction: column",
  "justify-content: center",
  "gap: 12px",
  "min-height: 150px",
  "box-sizing: border-box",
].join("; ");

// The base-string utilities, shared by steps 1 and 2 (px-4 still present there).
const base = ["inline-flex", "rounded-md", "bg-primary", "px-4", "py-2"];

// Helper for the conflict bracket under the px-4 / px-8 pair in step 3.
const bracketWrap = [
  reset,
  "display: inline-flex",
  "flex-direction: column",
  "align-items: stretch",
  "gap: 4px",
  "box-sizing: border-box",
].join("; ");

const bracketRow = [
  reset,
  "display: inline-flex",
  "gap: 7px",
  "box-sizing: border-box",
].join("; ");

const bracketLine = [
  reset,
  "height: 7px",
  "border: 1.5px solid var(--mark-orange-brd)",
  "border-top: 0",
  "border-radius: 0 0 5px 5px",
  "box-sizing: border-box",
].join("; ");

const bracketLabel = [
  reset,
  sans,
  "font-size: 11px",
  "font-weight: 600",
  "line-height: 1.2",
  "text-align: center",
  "color: var(--mark-orange-brd)",
].join("; ");
---

<div class="not-content cnp-root" style={wrap} data-step={step}>
  {
    step === 1 && (
      <div style={inputGroup}>
        <div>
          <div style={groupKind}>Base string</div>
          <div style={groupLabel}>
            'inline-flex rounded-md bg-primary px-4 py-2'
          </div>
        </div>
        <div style={row}>
          {base.map((c) => (
            <span style={pill("plain")}>{c}</span>
          ))}
        </div>

        <hr style={divider} />

        <div>
          <div style={groupKind}>Conditional object · isPending = false</div>
          <div style={groupLabel}>{"{ 'opacity-50': isPending }"}</div>
        </div>
        <div style={row}>
          <span style={pill("dropped")}>opacity-50</span>
        </div>

        <hr style={divider} />

        <div>
          <div style={groupKind}>Consumer override</div>
          <div style={groupLabel}>'px-8'</div>
        </div>
        <div style={row}>
          <span style={pill("consumer")}>px-8</span>
        </div>
      </div>
    )
  }

  {
    step === 2 && (
      <Fragment>
        <div style={stageTag}>
          After <span style={stageTagCode}>clsx</span> — one flat string
        </div>
        <div style={row}>
          {base.map((c) => (
            <span style={pill("plain")}>{c}</span>
          ))}
          <span style={pill("consumer")}>px-8</span>
        </div>
      </Fragment>
    )
  }

  {
    step === 3 && (
      <Fragment>
        <div style={stageTag}>
          <span style={stageTagCode}>tailwind-merge</span> scans for conflicts
        </div>
        <div style={row}>
          <span style={pill("plain")}>inline-flex</span>
          <span style={pill("plain")}>rounded-md</span>
          <span style={pill("plain")}>bg-primary</span>
          <div style={bracketWrap}>
            <div style={bracketRow}>
              <span style={pill("conflict")}>px-4</span>
              <span style={pill("conflict")}>px-8</span>
            </div>
            <div style={bracketLine} aria-hidden="true" />
            <div style={bracketLabel}>same property: horizontal padding</div>
          </div>
          <span style={pill("plain")}>py-2</span>
        </div>
      </Fragment>
    )
  }

  {
    step === 4 && (
      <Fragment>
        <div style={stageTag}>
          After <span style={stageTagCode}>tailwind-merge</span> — last one wins
        </div>
        <div style={row}>
          <span style={pill("plain")}>inline-flex</span>
          <span style={pill("plain")}>rounded-md</span>
          <span style={pill("plain")}>bg-primary</span>
          <span style={pill("dropped")}>px-4</span>
          <span style={pill("plain")}>py-2</span>
          <span style={pill("survivor")}>px-8</span>
        </div>
      </Fragment>
    )
  }
</div>
