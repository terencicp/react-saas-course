---
// Target-match ReactCoding exercise for "Composing classes with cn()" — the
// "feel the bug" beat. The student is handed a <Badge> whose class string is
// built by naive template-literal concatenation, with `bg-muted` baked in. The
// instructions tell them to pass `className="bg-primary text-primary-foreground"`
// and make the badge primary-colored to match the target. The whole point is the
// friction: concatenation only appends, so the consumer's `bg-primary` lands on
// the element *next to* the built-in `bg-muted` — both survive, and which one
// paints is decided by Tailwind's emit order, not the student's string. The
// override is meant to feel unreliable. The next section hands them `cn()`.
//
// Why this is a wrapper and not a bare <ReactCoding> in the MDX (same reason as
// the sibling 018/1 wrappers CardUtilities.astro and ButtonVariants.astro): the
// badge leans on *semantic* tokens — `bg-muted`, `bg-primary`,
// `text-primary-foreground` — which is the senior default the chapter models on
// purpose. But ReactCoding's iframe boots a bare Tailwind v4 Play CDN with no
// project `globals.css`, so those utilities resolve to nothing and the badge
// renders unstyled. This wrapper makes the sandbox self-contained the same way
// the real project does: a `<style type="text/tailwindcss">` block with an
// `@theme` defining exactly the tokens this badge consumes (canonical shadcn
// neutral light-theme OKLCH values), on a white page so both the muted (faint
// gray) and primary (near-black) badges are clearly visible against the surface.
// The block is shared verbatim by starter and target so "Your output" and
// "Target" resolve identically. The setup `<style>` is the one line the student
// leaves alone; the `className` prop on <Badge> is what they edit.
import ReactCoding from "../../../live-coding/ReactCoding/ReactCoding.astro";

// Theme block injected into the sandbox. Mirrors the scaffold's `globals.css`
// for just the tokens this badge consumes, on a plain white page so the faint
// `bg-muted` badge and the near-black `bg-primary` badge both read against the
// surface. Shared by starter and target.
const theme = `      {/* Project theme tokens — leave this as-is, it stands in for globals.css */}
      <style type="text/tailwindcss">{\`
        @theme {
          --color-primary: oklch(0.205 0 0);
          --color-primary-foreground: oklch(0.985 0 0);
          --color-muted: oklch(0.97 0 0);
        }
        body { background: oklch(1 0 0); }
      \`}</style>`;

const starter = `const Badge = ({ className = '' }: { className?: string }) => {
  return (
    <span className={\`inline-flex rounded-md bg-muted px-2 py-1 text-sm \${className}\`}>
      Beta
    </span>
  );
};

export function App() {
  return (
    <>
${theme}
      <Badge className="" />
    </>
  );
}`;

const target = `export function App() {
  return (
    <>
${theme}
      <span className="inline-flex rounded-md bg-primary px-2 py-1 text-sm text-primary-foreground">
        Beta
      </span>
    </>
  );
}`;
---

<ReactCoding
  live
  instructions={`This <Badge> builds its class string by concatenation, with bg-muted baked in. Pass className="bg-primary text-primary-foreground" and try to make the badge primary-colored to match the target. Notice how unreliable overriding the built-in bg-muted is — concatenation only appends, so it can't remove the conflicting class. Leave the theme <style> block alone.`}
  starter={starter}
  target={target}
  maxHeight={360}
/>
