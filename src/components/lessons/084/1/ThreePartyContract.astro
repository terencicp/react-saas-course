---
// ThreePartyContract — Chapter 084 Lesson 1, "Keys, catalogs, and the
// no-concatenation rule".
//
// The load-bearing mental model of the whole lesson: a user-visible string is a
// contract between THREE parties, each with one job. Make "who owns what"
// spatial so every later rule has a home on this picture.
//
//   ┌─────────────────┐  looks up by key  ┌──────────────────┐  returns       ┌──────────────┐
//   │ Component code  │ ────────────────▶ │ Catalog          │  localized     │ Rendered UI  │
//   │ t('inbox.greet')│   (the engineer)  │ en-US/fr-FR.json  │ ─── string ──▶ │ "You have 3…"│
//   └─────────────────┘                   └──────────────────┘                └──────────────┘
//                                               ▲
//                                  edits text + │ reorders slots
//                                          ┌────┴──────┐
//                                          │ Translator │
//                                          └───────────┘
//
// Built with <ArrowDiagram> (LeaderLine): the boxes are mixed custom HTML —
// a label strip plus a monospace payload line, and one quoted token highlighted
// to read as the named slot the translator is free to move. D2/Mermaid plain
// labels couldn't carry that. The arrows are positioned from document.body, so
// the wrapping <Figure> MUST be expandable={false}.
//
// Three distinct arrow colors mark the three relationships:
//   blue   — code → catalog ("looks up by key"), the engineer's edge.
//   green  — catalog → UI ("returns localized string"), what the user sees.
//   violet — translator → catalog ("edits text + reorders slots").
// The catalog is the hub: code lands on its LEFT, UI leaves from its RIGHT, the
// translator lands on its BOTTOM — three separate contact zones so no two
// arrowheads stack. Mid-tone hexes used as-is in both themes; chrome is
// theme-aware via Starlight gray/white vars. margin:0 resets defeat Starlight's
// injected prose margins.

import Figure from '../../../figures/Figure.astro';
import ArrowDiagram from '../../../figures/ArrowDiagram.astro';

const KEY_BLUE = '#2563eb'; // blue-600  — engineer's lookup
const UI_GREEN = '#16a34a'; // green-600 — localized output to the user
const TR_VIOLET = '#7c3aed'; // violet-600 — translator edits

// Pin label badges to a light card so they survive dark mode (the body-appended
// badge defaults derive from the page bg).
const labelBase =
	'background: #ffffff; border: 1px solid #cbd5e1; color: #334155; font-weight: 600;';
const labelBlue = `${labelBase} border-color: #93c5fd; color: #1d4ed8;`;
const labelGreen = `${labelBase} border-color: #86efac; color: #15803d;`;
const labelViolet = `${labelBase} border-color: #c4b5fd; color: #6d28d9;`;

const arrows = [
	// Engineer's edge: component code → catalog, in the gap between box 1 and 2.
	{
		from: 'tpc-code',
		to: 'tpc-catalog',
		label: 'looks up by key',
		color: KEY_BLUE,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -22],
		labelStyle: labelBlue,
	},
	// Output edge: catalog → rendered UI, in the gap between box 2 and 3.
	{
		from: 'tpc-catalog',
		to: 'tpc-ui',
		label: 'returns localized string',
		color: UI_GREEN,
		startSocket: 'right',
		endSocket: 'left',
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
		labelOffset: [0, -22],
		labelStyle: labelGreen,
	},
	// Translator's edge: translator pill (below) → catalog's bottom.
	{
		from: 'tpc-translator',
		to: 'tpc-catalog',
		label: 'edits text + reorders slots',
		color: TR_VIOLET,
		startSocket: 'top',
		endSocket: 'bottom',
		startSocketGravity: [0, -50],
		endSocketGravity: [0, 50],
		labelOffset: [0, 0],
		labelStyle: labelViolet,
	},
];
---

<Figure expandable={false}>
	<ArrowDiagram arrows={arrows}>
		<div class="tpc not-content">
			<div class="tpc-row">
				{/* Box 1 — what the engineer writes. */}
				<div class="tpc-node" id="tpc-code">
					<span class="tpc-cap tpc-cap-blue">Component code</span>
					<code class="tpc-line"
						>t(<span class="tpc-key">'inbox.greeting'</span>, {'{'} count {'}'})</code
					>
					<span class="tpc-who">the engineer</span>
				</div>

				{/* Box 2 — the wire format, the hub of the picture. */}
				<div class="tpc-node tpc-node-hub" id="tpc-catalog">
					<span class="tpc-cap">Catalog</span>
					<span class="tpc-files">en-US.json / fr-FR.json</span>
					<code class="tpc-line"
						>"You have <span class="tpc-slot">{'{'}count{'}'}</span> unread messages"</code
					>
				</div>

				{/* Box 3 — what the user sees. */}
				<div class="tpc-node" id="tpc-ui">
					<span class="tpc-cap tpc-cap-green">Rendered UI</span>
					<span class="tpc-screen">You have 3 unread messages</span>
				</div>
			</div>

			{/* The translator — a person, working below, who only ever touches the
			    catalog. Centered under the hub so the violet arrow rises straight up. */}
			<div class="tpc-translator-row">
				<div class="tpc-pill" id="tpc-translator">
					<span class="tpc-pill-icon" aria-hidden="true">👤</span>
					Translator
				</div>
			</div>
		</div>
	</ArrowDiagram>
	<Fragment slot="caption">
		One string, three owners. The <strong style="color:#2563eb;">engineer</strong>
		holds the key and passes named values; the <strong>catalog</strong> is the
		wire format that holds the text; the <strong style="color:#7c3aed;"
			>translator</strong
		> edits inside it and moves the slots. The user sees only the
		<strong style="color:#15803d;">rendered string</strong>. Every rule in the
		lesson is a property of one of these boxes or the arrows between them.
	</Fragment>
</Figure>

<style>
	.tpc {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 74px;
		margin: 0;
		padding: 26px 8px 18px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	/* The three boxes, generously spaced so the labeled curves have room. */
	.tpc-row {
		display: flex;
		flex-wrap: nowrap;
		align-items: stretch;
		justify-content: center;
		gap: 134px;
		margin: 0;
	}

	.tpc-node {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 6px;
		min-width: 11rem;
		max-width: 16rem;
		padding: 12px 16px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-5, #cbd5e1);
		background: var(--sl-color-bg, #fff);
		margin: 0;
	}

	/* The catalog is the hub every arrow touches — a heavier border reads it as
	   the center of the contract. */
	.tpc-node-hub {
		border-color: var(--sl-color-gray-4, #94a3b8);
		border-width: 2px;
	}

	/* Caption strip at the top of each box: the party's role. */
	.tpc-cap {
		font-size: 0.62rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1.2;
		color: var(--sl-color-gray-2, #475569);
		margin: 0;
	}
	.tpc-cap-blue {
		color: #1d4ed8;
	}
	.tpc-cap-green {
		color: #15803d;
	}

	.tpc-files {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.7rem;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* Monospace payload line inside code / catalog boxes. */
	.tpc-line {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 0.76rem;
		line-height: 1.4;
		color: var(--sl-color-white, #1e293b);
		background: var(--sl-color-gray-6, #f1f5f9);
		border-radius: 6px;
		padding: 5px 8px;
		margin: 0;
	}

	/* The key is the thread that ties code to catalog — tint it blue in both. */
	.tpc-key {
		color: #1d4ed8;
		font-weight: 600;
	}

	/* The named slot is what the translator is free to move — tint it violet. */
	.tpc-slot {
		color: #6d28d9;
		font-weight: 700;
		background: color-mix(in srgb, #7c3aed 16%, transparent);
		border-radius: 3px;
		padding: 0 2px;
	}

	.tpc-who {
		font-size: 0.66rem;
		font-style: italic;
		line-height: 1.2;
		color: var(--sl-color-gray-3, #64748b);
		margin: 0;
	}

	/* The rendered output, shown as on-screen prose rather than code. */
	.tpc-screen {
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.35;
		color: var(--sl-color-white, #1e293b);
		margin: 0;
	}

	.tpc-translator-row {
		display: flex;
		justify-content: center;
		margin: 0;
	}

	/* The translator is a PERSON, not a system box — a pill marks the difference. */
	.tpc-pill {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		padding: 7px 16px;
		border-radius: 999px;
		border: 1.5px solid #c4b5fd;
		background: color-mix(in srgb, #7c3aed 10%, var(--sl-color-bg, #fff));
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
		color: #6d28d9;
		margin: 0;
	}

	.tpc-pill-icon {
		font-size: 0.95rem;
		line-height: 1;
	}

	/* Narrow viewports: stack the three boxes. The side sockets degrade to
	   vertical arcs between stacked boxes — readable, labels still float in the
	   gaps. The translator stays at the bottom, still pointing at the catalog. */
	@media (max-width: 800px) {
		.tpc {
			gap: 56px;
		}
		.tpc-row {
			flex-direction: column;
			align-items: center;
			gap: 64px;
		}
		.tpc-node {
			width: min(18rem, 100%);
			max-width: none;
		}
	}
</style>
