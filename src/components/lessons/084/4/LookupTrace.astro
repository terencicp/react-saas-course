---
// lookup-trace — Ch084 L4 "The locale resolution chain", the worked trace in
// the "Best-matching Accept-Language" section.
//
// Traces RFC 4647 `Lookup` one step at a time for the chapter's running case:
//
//   header  Accept-Language: pt-BR,pt;q=0.9
//   set     ['pt-PT', 'en-US']
//   result  pt-PT  (pt-BR strips its region → base 'pt' → shares pt-PT's base)
//
// Built on <DiagramSequence>: the four states are a temporal scrub, and the
// component swaps one panel for the next without reflow (all steps share a grid
// cell, sized to the tallest). The teaching beat is the subtag-stripping move in
// step 3 — pt-BR loses its region and finds pt-PT waiting on the shared base.
//
// LAYOUT IS STABLE BY DESIGN: every step renders the SAME three rows — the raw
// header → ranked tag list, the supported set, and a status line. Only per-box
// state classes (idle / cursor / miss / match) and the status text change
// between steps, so the stage never jumps as the reader scrubs. The "stripped"
// base tag `pt` sits in the tag list from the start (faint) and lights up in
// step 3, rather than appearing late and shifting layout.
//
// Self-carded — do NOT wrap in <Figure>.

import DiagramSequence from "../../../../components/figures/diagram-sequence/DiagramSequence.astro";
import DiagramStep from "../../../../components/figures/diagram-sequence/DiagramStep.astro";

const RAW_HEADER = "pt-BR,pt;q=0.9";

// The ranked tag list the header parses into. `pt` is shown as the base that
// `pt-BR` strips down to (an em-dash arc in the markup hints at the relation).
type TagState = "idle" | "cursor-pending" | "miss" | "match";
type SetState = "idle" | "match";

// Each step is the full board state: how every tag box and every supported box
// reads. Keeping the whole board per step makes the "only state changes" intent
// explicit and keeps the four panels structurally identical.
const steps = [
	{
		// 1 — parse only. Nothing tried yet.
		showList: false, // header still collapsed into raw string emphasis
		tags: { "pt-BR": "idle", pt: "idle" } as Record<string, TagState>,
		set: { "pt-PT": "idle", "en-US": "idle" } as Record<string, SetState>,
		statusKind: "neutral",
		statusLabel: "Parsed",
		statusText: "Header → ranked tag list. Nothing tried yet.",
	},
	{
		// 2 — try pt-BR exactly. Miss.
		showList: true,
		tags: { "pt-BR": "miss", pt: "idle" } as Record<string, TagState>,
		set: { "pt-PT": "idle", "en-US": "idle" } as Record<string, SetState>,
		statusKind: "miss",
		statusLabel: "Miss",
		statusText: "No 'pt-BR' in the supported set.",
	},
	{
		// 3 — strip region → pt → matches pt-PT's base.
		showList: true,
		tags: { "pt-BR": "miss", pt: "match" } as Record<string, TagState>,
		set: { "pt-PT": "match", "en-US": "idle" } as Record<string, SetState>,
		statusKind: "match",
		statusLabel: "Match",
		statusText: "Stripped to base 'pt' — pt-PT shares it.",
	},
	{
		// 4 — resolved.
		showList: true,
		tags: { "pt-BR": "miss", pt: "match" } as Record<string, TagState>,
		set: { "pt-PT": "match", "en-US": "idle" } as Record<string, SetState>,
		statusKind: "match",
		statusLabel: "Resolved",
		statusText: "→ pt-PT",
	},
];

const captions = [
	"Parse the header into a ranked tag list, most-preferred first.",
	"Try the first tag exactly. No 'pt-BR' in the supported set — miss.",
	"Strip the region subtag: pt-BR becomes pt. Now pt-PT shares the 'pt' base — match.",
	"Resolved: pt-PT. The Portuguese speaker reads Portuguese, not the English fallback.",
];

// Order matters: pt-BR first (most preferred), then its stripped base pt.
const tagOrder = ["pt-BR", "pt"];
const setOrder = ["pt-PT", "en-US"];
---

<DiagramSequence>
	{
		steps.map((step, i) => (
			<DiagramStep caption={captions[i]}>
				<div class="lt not-content">
					{/* ROW 1 — raw header → ranked tag list. */}
					<div class="lt-row">
						<span class="lt-rowlabel">Accept-Language</span>
						<div class="lt-headerline">
							<code class="lt-raw">{RAW_HEADER}</code>
							<span class="lt-arrow" aria-hidden="true">
								→
							</span>
							<div class:list={["lt-tags", { "lt-tags--ready": step.showList }]}>
								{tagOrder.map((tag, t) => {
									const state = step.tags[tag];
									const isBase = tag === "pt";
									return (
										<>
											{isBase && (
												<span class="lt-strip" aria-hidden="true">
													strip region
												</span>
											)}
											<code
												class:list={[
													"lt-tag",
													`lt-tag--${state}`,
													{ "lt-tag--base": isBase },
												]}
											>
												{state === "cursor-pending" || state === "miss" || state === "match" ? (
													<span class="lt-cursor" aria-hidden="true" />
												) : null}
												{tag}
											</code>
										</>
									);
								})}
							</div>
						</div>
					</div>

					{/* ROW 2 — the supported set. */}
					<div class="lt-row">
						<span class="lt-rowlabel">Supported set</span>
						<div class="lt-set">
							{setOrder.map((tag) => {
								const state = step.set[tag];
								return (
									<code class:list={["lt-supp", `lt-supp--${state}`]}>
										{state === "match" && (
											<span class="lt-tick" aria-hidden="true">
												✓
											</span>
										)}
										{tag}
									</code>
								);
							})}
						</div>
					</div>

					{/* ROW 3 — status line. */}
					<div class="lt-row lt-row--status">
						<span class="lt-rowlabel">Status</span>
						<div class:list={["lt-status", `lt-status--${step.statusKind}`]}>
							<span class="lt-badge">{step.statusLabel}</span>
							<span class="lt-statustext">{step.statusText}</span>
						</div>
					</div>
				</div>
			</DiagramStep>
		))
	}
</DiagramSequence>

<style>
	.lt {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 14px;
		width: 100%;
		max-width: 640px;
		margin-inline: auto;
		box-sizing: border-box;
		font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif);
	}

	.lt-row {
		display: grid;
		grid-template-columns: 116px 1fr;
		align-items: center;
		gap: 12px;
	}

	.lt-rowlabel {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
		text-align: right;
		line-height: 1.2;
	}

	.lt-headerline {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px 10px;
	}

	.lt-raw {
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
		font-size: 13px;
		font-weight: 600;
		padding: 5px 9px;
		border-radius: 8px;
		border: 1.5px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
		white-space: nowrap;
	}

	.lt-arrow {
		color: var(--sl-color-gray-3);
		font-size: 15px;
		font-weight: 700;
	}

	.lt-tags {
		display: flex;
		align-items: center;
		gap: 8px;
		opacity: 0.35;
		transition: opacity 0.18s ease;
	}
	.lt-tags--ready {
		opacity: 1;
	}

	/* "strip region" connector that sits between pt-BR and its base pt. */
	.lt-strip {
		font-size: 10px;
		font-weight: 700;
		font-style: italic;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
		position: relative;
		padding: 0 4px;
	}
	.lt-strip::before {
		content: "⤷";
		margin-right: 3px;
		font-style: normal;
	}

	.lt-tag,
	.lt-supp {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
		font-size: 13px;
		font-weight: 700;
		padding: 5px 10px;
		border-radius: 8px;
		border: 1.5px solid var(--sl-color-gray-5);
		background: var(--sl-color-bg);
		color: var(--sl-color-white);
		line-height: 1.2;
		white-space: nowrap;
		transition:
			border-color 0.18s ease,
			background 0.18s ease,
			color 0.18s ease,
			opacity 0.18s ease;
	}

	/* ---- tag (requested) states ---- */
	.lt-tag--idle {
		opacity: 0.6;
	}
	.lt-tag--base.lt-tag--idle {
		border-style: dashed;
	}
	.lt-tag--miss {
		border-color: #ef4444;
		background: color-mix(in srgb, #ef4444 12%, var(--sl-color-bg));
		color: color-mix(in srgb, #ef4444 35%, var(--sl-color-white));
		text-decoration: line-through;
		text-decoration-color: color-mix(in srgb, #ef4444 70%, transparent);
	}
	.lt-tag--match {
		border-color: #22c55e;
		border-style: solid;
		background: color-mix(in srgb, #22c55e 16%, var(--sl-color-bg));
		color: var(--sl-color-white);
	}

	/* the little cursor dot that marks the tag currently being tried */
	.lt-cursor {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		flex: none;
		background: currentColor;
	}

	/* ---- supported-set states ---- */
	.lt-supp--idle {
		border-color: var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
	}
	.lt-supp--match {
		border-color: #22c55e;
		background: color-mix(in srgb, #22c55e 16%, var(--sl-color-bg));
	}
	.lt-tick {
		color: #22c55e;
		font-weight: 900;
		font-size: 12px;
	}

	.lt-set {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
	}

	/* ---- status line ---- */
	.lt-row--status {
		align-items: stretch;
	}
	.lt-status {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 7px 12px;
		border-radius: 9px;
		border: 1.5px solid var(--sl-color-gray-5);
		background: var(--sl-color-gray-6);
		min-height: 22px;
	}
	.lt-badge {
		font-size: 10px;
		font-weight: 800;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		padding: 2px 8px;
		border-radius: 999px;
		flex: none;
		color: var(--sl-color-white);
		background: var(--sl-color-gray-4);
	}
	.lt-statustext {
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-gray-1);
		line-height: 1.3;
	}
	.lt-statustext :global(code),
	.lt-status code {
		font-family: var(--__sl-font-mono, ui-monospace, monospace);
	}

	.lt-status--miss {
		border-color: color-mix(in srgb, #ef4444 45%, var(--sl-color-gray-5));
		background: color-mix(in srgb, #ef4444 10%, var(--sl-color-bg));
	}
	.lt-status--miss .lt-badge {
		background: #ef4444;
	}
	.lt-status--match {
		border-color: color-mix(in srgb, #22c55e 45%, var(--sl-color-gray-5));
		background: color-mix(in srgb, #22c55e 12%, var(--sl-color-bg));
	}
	.lt-status--match .lt-badge {
		background: #22c55e;
	}

	@media (max-width: 540px) {
		.lt-row {
			grid-template-columns: 1fr;
			gap: 5px;
		}
		.lt-rowlabel {
			text-align: left;
		}
	}
</style>
