---
// signals-funnel — Ch084 L4 "The locale resolution chain", the figure that
// closes the "five signals a request carries" section.
//
// The shape the section establishes, made literal: MANY signals enter, ONE
// validated locale leaves. Five labelled signal boxes stack in a left column
// and each feeds a single central resolve() box; resolve() emits one locale on
// the right.
//
//   URL prefix      ─┐
//   Profile         ─┤
//   Cookie          ─┼─▶ resolve() ─▶ locale
//   Accept-Language ─┤
//   Geo-IP (dim)    ─┘
//
// The teaching beat is cardinality, not order yet: the student should SEE the
// funnel (five in, one out) before the next section ranks the inputs. Geo-IP is
// dimmed (lower opacity) + its arrow is muted/dashed to foreshadow that it is
// never a primary signal — that argument lands a section later.
//
// Built with <ArrowDiagram> (leader-line) because the placeholder asks for real
// directional arrows in a single converging gap that crosses no body text — the
// clean case for it. Boxes are custom HTML (title + mono subtext), which the
// engine renders verbatim. Wrapped in <Figure expandable={false}> at the call
// site: ArrowDiagram's leader lines are body-positioned and break if relocated
// into the expand lightbox.
//
// Static figure — no interactivity. Wraps to a vertical stack on narrow cards.

import ArrowDiagram from "../../../../components/figures/ArrowDiagram.astro";

const mono =
	"font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Theme-aware mid-tones reused verbatim in light + dark. Blue is the funnel's
// neutral accent for the four primary signals + resolve→locale flow; the muted
// grey marks geo-IP as the weak, last-resort signal.
const ACCENT = "#3b82f6"; // primary signal arrows + the resolve → locale arrow
const MUTED = "#94a3b8"; // geo-IP arrow — visibly weaker than the rest

const signals = [
	{ id: "sig-url", title: "URL prefix", sub: "/fr-FR/dashboard", dim: false },
	{ id: "sig-profile", title: "Profile", sub: "users.locale", dim: false },
	{ id: "sig-cookie", title: "Cookie", sub: "NEXT_LOCALE", dim: false },
	{
		id: "sig-header",
		title: "Accept-Language",
		sub: "browser hint",
		dim: false,
	},
	{ id: "sig-geo", title: "Geo-IP", sub: "weak / last resort", dim: true },
];

// Each signal arcs into the resolve() box. We fan the five curves apart with a
// vertical gravity component so their bodies occupy distinct lanes in the gap
// and the arrowheads land spaced down the box's left edge rather than stacking.
const arrows = [
	{
		from: "sig-url",
		to: "resolve",
		color: ACCENT,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, -90],
	},
	{
		from: "sig-profile",
		to: "resolve",
		color: ACCENT,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, -45],
	},
	{
		from: "sig-cookie",
		to: "resolve",
		color: ACCENT,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 0],
	},
	{
		from: "sig-header",
		to: "resolve",
		color: ACCENT,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 45],
	},
	{
		from: "sig-geo",
		to: "resolve",
		color: MUTED,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [70, 0],
		endSocketGravity: [-70, 90],
	},
	{
		from: "resolve",
		to: "out",
		color: ACCENT,
		startSocket: "right",
		endSocket: "left",
		startSocketGravity: [60, 0],
		endSocketGravity: [-60, 0],
	},
];
---

<ArrowDiagram arrows={arrows}>
	<div class="sf not-content">
		{/* LEFT column — the five signals, stacked top to bottom. */}
		<div class="sf-signals">
			{
				signals.map((s) => (
					<div class:list={["sf-sig", { "sf-sig--dim": s.dim }]} id={s.id}>
						<span class="sf-sig-title">{s.title}</span>
						<span class="sf-sig-sub">{s.sub}</span>
					</div>
				))
			}
		</div>

		{/* CENTER — the resolver. Runs once per request. */}
		<div class="sf-resolve" id="resolve">
			<span class="sf-resolve-title">resolve()</span>
			<span class="sf-resolve-sub">runs once per request</span>
		</div>

		{/* RIGHT — the single validated output. */}
		<div class="sf-out" id="out">
			<span class="sf-out-title">locale</span>
			<span class="sf-out-sub">e.g. 'fr-FR'</span>
		</div>
	</div>
</ArrowDiagram>

<style define:vars={{ accent: ACCENT, monoFont: mono, sansFont: sans }}>
	.sf {
		margin: 0;
		display: grid;
		grid-template-columns: minmax(170px, 220px) 150px minmax(140px, 180px);
		align-items: center;
		justify-items: center;
		column-gap: 0;
		width: 100%;
		max-width: 720px;
		margin-inline: auto;
		box-sizing: border-box;
		font-family: var(--sansFont);
	}

	/* ---- LEFT: stacked signal boxes ---- */
	.sf-signals {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 9px;
		width: 100%;
	}

	.sf-sig {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 8px 12px;
		border-radius: 10px;
		border: 1.5px solid
			color-mix(in srgb, var(--accent) 45%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--accent) 9%, var(--sl-color-bg));
	}
	.sf-sig--dim {
		opacity: 0.55;
		border-color: var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
	}

	.sf-sig-title {
		margin: 0;
		font-size: 14px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.sf-sig-sub {
		margin: 0;
		font-family: var(--monoFont);
		font-size: 11px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
	}

	/* ---- CENTER: the resolver ---- */
	.sf-resolve {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		padding: 16px 14px;
		width: 100%;
		border-radius: 12px;
		border: 2px solid color-mix(in srgb, var(--accent) 60%, transparent);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		text-align: center;
	}
	.sf-resolve-title {
		margin: 0;
		font-family: var(--monoFont);
		font-size: 16px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.sf-resolve-sub {
		margin: 0;
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
	}

	/* ---- RIGHT: the single output ---- */
	.sf-out {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
		padding: 14px 12px;
		width: 100%;
		border-radius: 12px;
		border: 1.5px solid var(--sl-color-gray-3);
		background: var(--sl-color-gray-7, var(--sl-color-gray-6));
		text-align: center;
	}
	.sf-out-title {
		margin: 0;
		font-family: var(--monoFont);
		font-size: 15px;
		font-weight: 700;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.sf-out-sub {
		margin: 0;
		font-family: var(--monoFont);
		font-size: 11px;
		font-weight: 600;
		line-height: 1.3;
		color: var(--sl-color-gray-2);
	}

	/* On narrow cards the three columns stack. The cross-region arrows degrade
	   gracefully (they arc between stacked boxes) — readable, and the static
	   funnel reading is carried by the layout order even before the curves. */
	@media (max-width: 560px) {
		.sf {
			grid-template-columns: 1fr;
			row-gap: 40px;
			max-width: 320px;
		}
		.sf-signals {
			gap: 8px;
		}
	}
</style>
