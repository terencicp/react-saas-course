---
// locale-vs-timezone — Ch084 L4 "The locale resolution chain", the figure that
// closes the "Locale and timezone are independent" subsection.
//
// The teaching beat: locale and timezone are TWO SEPARATE AXES on `users`, and
// neither implies the other. The beginner instinct is to derive one from the
// other (de-DE ⇒ Europe/Berlin); this figure makes them read as two distinct
// things so that instinct dies.
//
// Two side-by-side cards, one axis each:
//
//   ┌─ How it reads ───────┐   ✕   ┌─ When it happens ────┐
//   │ (locale)             │  no   │ (timezone)           │
//   │ Column  users.locale │ infer │ Column  users.timeZone│
//   │ Picker  language …   │ ───── │ Picker  timezone …    │
//   │ Drives  Intl.* / t() │       │ Drives  date/time …   │
//   │ Value   en-GB        │       │ Value   Europe/Berlin │
//   └──────────────────────┘       └───────────────────────┘
//
// A small "no inference" divider sits between the cards — a crossed arrow — to
// say explicitly: you do not read across from one axis to the other. The two
// example values (en-GB / Europe/Berlin) are deliberately the SAME Berlin
// operator from the prose: reads English, operates in Berlin time.
//
// Built with plain HTML + CSS (the placeholder's request, and the right tool for
// a static two-card comparison — no arrows between custom boxes, no temporal
// scrub, no interactivity). Distinct accents per card: blue tint for locale,
// warm amber tint for timezone, so they read as two separate things at a glance.
// Wrapped in <Figure> at the call site (plain HTML survives the expand lightbox,
// so the default expandable=true is fine).
//
// Static figure — no interactivity. Stacks to a single column on narrow cards.

const mono =
	"font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace)";
const sans =
	"font-family: var(--sl-font-system, ui-sans-serif, system-ui, sans-serif)";

// Per-axis accents. Blue = locale (how text reads); amber = timezone (when
// things happen). Both are theme-aware mid-tones that hold in light + dark.
const LOCALE = "#3b82f6"; // blue
const TZ = "#f59e0b"; // amber

type Row = { label: string; value: string; mono?: boolean };

const localeRows: Row[] = [
	{ label: "Column", value: "users.locale", mono: true },
	{ label: "Picker", value: "a language <select> on the profile page" },
	{ label: "Drives", value: "Intl.* formatters, t() lookups, <html lang>" },
	{ label: "Example", value: "en-GB", mono: true },
];

const tzRows: Row[] = [
	{ label: "Column", value: "users.timeZone", mono: true },
	{ label: "Picker", value: "a timezone <select> on the profile page" },
	{ label: "Drives", value: "date/time rendering (timeZone option), scheduling" },
	{ label: "Example", value: "Europe/Berlin", mono: true },
];
---

<div class="lvt not-content">
	{/* LEFT card — the locale axis (how it reads). */}
	<div class="lvt-card lvt-card--locale">
		<div class="lvt-head">
			<span class="lvt-title">How it reads</span>
			<span class="lvt-tag">locale</span>
		</div>
		<dl class="lvt-rows">
			{
				localeRows.map((r) => (
					<div class="lvt-row">
						<dt class="lvt-key">{r.label}</dt>
						<dd class:list={["lvt-val", { "lvt-val--mono": r.mono }]}>
							{r.value}
						</dd>
					</div>
				))
			}
		</dl>
	</div>

	{/* CENTER — the "no inference" divider. The whole point of the figure. */}
	<div class="lvt-sep" aria-hidden="true">
		<span class="lvt-sep-mark">✕</span>
		<span class="lvt-sep-text">no inference</span>
	</div>

	{/* RIGHT card — the timezone axis (when it happens). */}
	<div class="lvt-card lvt-card--tz">
		<div class="lvt-head">
			<span class="lvt-title">When it happens</span>
			<span class="lvt-tag">timezone</span>
		</div>
		<dl class="lvt-rows">
			{
				tzRows.map((r) => (
					<div class="lvt-row">
						<dt class="lvt-key">{r.label}</dt>
						<dd class:list={["lvt-val", { "lvt-val--mono": r.mono }]}>
							{r.value}
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</div>

<style
	define:vars={{
		locale: LOCALE,
		tz: TZ,
		monoFont: mono,
		sansFont: sans,
	}}
>
	.lvt {
		margin: 0;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: stretch;
		gap: 12px;
		width: 100%;
		max-width: 760px;
		margin-inline: auto;
		box-sizing: border-box;
		font-family: var(--sansFont);
	}

	/* ---- the two axis cards ---- */
	.lvt-card {
		margin: 0;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 16px;
		border-radius: 14px;
		border: 1.5px solid var(--axis-border);
		background: var(--axis-bg);
	}
	.lvt-card--locale {
		--axis: var(--locale);
		--axis-border: color-mix(in srgb, var(--locale) 45%, var(--sl-color-gray-4));
		--axis-bg: color-mix(in srgb, var(--locale) 9%, var(--sl-color-bg));
	}
	.lvt-card--tz {
		--axis: var(--tz);
		--axis-border: color-mix(in srgb, var(--tz) 50%, var(--sl-color-gray-4));
		--axis-bg: color-mix(in srgb, var(--tz) 10%, var(--sl-color-bg));
	}

	.lvt-head {
		margin: 0;
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 8px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--axis-border);
	}
	.lvt-title {
		margin: 0;
		font-size: 16px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--sl-color-white);
	}
	.lvt-tag {
		margin: 0;
		font-family: var(--monoFont);
		font-size: 11px;
		font-weight: 700;
		line-height: 1;
		padding: 3px 8px;
		border-radius: 999px;
		color: color-mix(in srgb, var(--axis) 65%, var(--sl-color-white));
		background: color-mix(in srgb, var(--axis) 18%, transparent);
		border: 1px solid color-mix(in srgb, var(--axis) 40%, transparent);
	}

	/* ---- the key/value rows ---- */
	.lvt-rows {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 9px;
	}
	.lvt-row {
		margin: 0;
		display: grid;
		grid-template-columns: 64px 1fr;
		align-items: baseline;
		gap: 10px;
	}
	.lvt-key {
		margin: 0;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		line-height: 1.3;
		color: var(--sl-color-gray-3);
	}
	.lvt-val {
		margin: 0;
		font-size: 13px;
		font-weight: 500;
		line-height: 1.35;
		color: var(--sl-color-gray-1);
	}
	.lvt-val--mono {
		font-family: var(--monoFont);
		font-weight: 600;
		color: var(--sl-color-white);
	}

	/* ---- CENTER: the "no inference" divider ---- */
	.lvt-sep {
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 6px;
		padding: 0 2px;
	}
	.lvt-sep-mark {
		margin: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		border-radius: 999px;
		font-size: 14px;
		font-weight: 700;
		line-height: 1;
		color: var(--sl-color-gray-2);
		border: 1.5px dashed var(--sl-color-gray-4);
		background: var(--sl-color-bg);
	}
	.lvt-sep-text {
		margin: 0;
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		line-height: 1.2;
		text-align: center;
		color: var(--sl-color-gray-3);
		max-width: 64px;
	}

	/* On narrow cards the two axes stack; the divider becomes a horizontal rule
	   with the "no inference" marker centred between the two stacked cards. */
	@media (max-width: 560px) {
		.lvt {
			grid-template-columns: 1fr;
			max-width: 360px;
			gap: 10px;
		}
		.lvt-sep {
			flex-direction: row;
			gap: 8px;
			padding: 2px 0;
		}
		.lvt-row {
			grid-template-columns: 60px 1fr;
		}
	}
</style>
