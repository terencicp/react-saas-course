---
// One frame of the "request-flow-six-files" DiagramSequence (Ch084 L5, "Wiring
// next-intl into Next.js 16"). It reuses the chapter-family horizontal strip
// grammar (Ch080's webhook-seam, Ch057's authed-action-gates, Ch049's
// render-pipeline): a row of file nodes with one lit (`is-on`, the accent) and
// the already-walked nodes dimmed (`is-done`). So one `GET /dashboard` reads as
// a single request walking the six wiring files in order, in the same visual
// language as the rest of the course.
//
// The six files, in request order:
//
//   proxy.ts → i18n/routing.ts → i18n/request.ts
//     → app/[locale]/layout.tsx → Server Component → Client Component
//
// The strip is fixed across the six steps; only the lit node and the already-
// walked dimmed nodes change. The per-step caption lives in the MDX on each
// <DiagramStep>, so it swaps with the frame. The row wraps (never scrolls) on
// short/narrow laptop viewports, keeping the stage height well under the ~500px
// cap.
//
// Pure HTML + CSS, matching the sibling figures: `.not-content` to drop
// Starlight's prose chrome, `margin: 0` resets, theme-aware `color-mix` accents
// that read on light and dark.

interface Props {
	// Index (0-5) of the file lit this frame. Nodes before it read as `is-done`
	// (the request has already passed through them).
	active: number;
}

const { active } = Astro.props;

// The six wiring files, in the order one request walks them. `file` is the
// monospace headline, `role` the one-line job beneath it.
const nodes: { file: string; role: string }[] = [
	{ file: "proxy.ts", role: "runs the resolution chain" },
	{ file: "i18n/routing.ts", role: "shared locale config" },
	{ file: "i18n/request.ts", role: "loads catalog + timezone" },
	{ file: "app/[locale]/layout.tsx", role: "sets locale + <html lang>" },
	{ file: "Server Component", role: "useTranslations / useFormatter" },
	{ file: "Client Component", role: "reads the same t / format" },
];

const ACCENT = "#2563eb"; // blue-600 — the chapter family's pipeline accent
---

<div class="rf-stage not-content">
	<div
		class="rf-pipe"
		role="img"
		aria-label="One GET /dashboard request walks six next-intl wiring files in order: proxy.ts, i18n/routing.ts, i18n/request.ts, app/[locale]/layout.tsx, a Server Component, then a Client Component. The active file is highlighted."
	>
		{
			nodes.map((node, i) => {
				const isOn = i === active;
				const isDone = i < active;
				return (
					<>
						<div class:list={["rf-node", { "is-on": isOn, "is-done": isDone }]}>
							<span class="rf-node-step">{i + 1}</span>
							<span class="rf-node-file">{node.file}</span>
							<span class="rf-node-role">{node.role}</span>
						</div>
						{i < nodes.length - 1 && (
							<span
								class:list={["rf-arrow", { "is-on": i < active }]}
								aria-hidden="true"
							>
								<svg
									viewBox="0 0 34 14"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<line x1="1" y1="7" x2="26" y2="7" />
									<polyline points="21 2.5 27.5 7 21 11.5" />
								</svg>
							</span>
						)}
					</>
				);
			})
		}
	</div>
</div>

<style define:vars={{ accent: ACCENT }}>
	.rf-stage {
		margin: 0;
	}

	/* The pipeline strip. Wraps (never scrolls) on narrow/short viewports so the
	   six file nodes always fit; centered so the wrapped rows read together. */
	.rf-pipe {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
	}

	.rf-node {
		margin: 0;
		flex: 1 1 150px;
		max-width: 220px;
		box-sizing: border-box;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		padding: 13px 12px 12px;
		border-radius: 10px;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-3);
		text-align: center;
		transition:
			border-color 0.14s,
			background-color 0.14s,
			color 0.14s,
			box-shadow 0.14s,
			opacity 0.14s;
	}
	/* Files the request has already passed through: tinted but receded, so the
	   strip reads as a path being walked left to right. */
	.rf-node.is-done {
		border-color: color-mix(in srgb, var(--accent) 32%, var(--sl-color-gray-4));
		background: color-mix(in srgb, var(--accent) 7%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 45%, var(--sl-color-gray-3));
		opacity: 0.78;
	}
	.rf-node.is-on {
		border: 1.5px solid var(--accent);
		background: color-mix(in srgb, var(--accent) 13%, transparent);
		color: color-mix(in srgb, var(--accent) 80%, var(--sl-color-text));
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
		opacity: 1;
	}

	/* Tiny step-number badge so the order is legible even when the row wraps. */
	.rf-node-step {
		margin: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 17px;
		height: 17px;
		border-radius: 50%;
		font-size: 10px;
		font-weight: 700;
		line-height: 1;
		background: var(--sl-color-gray-5);
		color: var(--sl-color-gray-2);
	}
	.rf-node.is-done .rf-node-step {
		background: color-mix(in srgb, var(--accent) 22%, var(--sl-color-bg));
		color: color-mix(in srgb, var(--accent) 60%, var(--sl-color-gray-2));
	}
	.rf-node.is-on .rf-node-step {
		background: var(--accent);
		color: #fff;
	}

	.rf-node-file {
		margin: 0;
		font-family: var(
			--__sl-font-mono,
			ui-monospace,
			SFMono-Regular,
			Menlo,
			Monaco,
			Consolas,
			monospace
		);
		font-size: 12.5px;
		font-weight: 700;
		line-height: 1.25;
		word-break: break-word;
	}
	.rf-node-role {
		margin: 0;
		font-size: 11px;
		font-weight: 500;
		line-height: 1.25;
		opacity: 0.92;
	}

	/* Connectors between files. Edges already crossed light up so the strip reads
	   as a request moving through, not a static row. */
	.rf-arrow {
		margin: 0;
		flex: 0 0 auto;
		align-self: center;
		display: inline-flex;
		color: var(--sl-color-gray-4);
		transition: color 0.14s;
	}
	.rf-arrow.is-on {
		color: var(--accent);
	}
	.rf-arrow svg {
		width: 26px;
		height: 13px;
	}

	/* On the narrowest viewports the files stack; rotate the connectors so the
	   flow still reads top-to-bottom. */
	@media (max-width: 600px) {
		.rf-pipe {
			flex-direction: column;
			align-items: stretch;
		}
		.rf-node {
			max-width: none;
		}
		.rf-arrow {
			align-self: center;
			transform: rotate(90deg);
		}
	}
</style>
