---
// HreflangSymmetryMatrix — Chapter 084 Lesson 6, "hreflang, per-locale canonicals, and SEO".
//
// The lesson's second key visual: it makes "every variant declares every
// sibling, both ways, including itself" obvious at a glance. A 3x3 grid where
// rows are the three locale variants of one logical page and columns are the
// locale each page declares an alternate for. Every cell is a green check —
// the grid is completely filled — so two structural facts read off the shape:
//
//   - the DIAGONAL (a page checking its own locale) = self-reference (rule 1)
//   - the SYMMETRY across that diagonal = bidirectionality (rule 2)
//
//        declares alternate for →     en-US   fr-FR   de-DE
//   /billing            (en-US)        [✓*]    ✓       ✓
//   /fr-FR/billing      (fr-FR)         ✓     [✓*]     ✓
//   /de-DE/billing      (de-DE)         ✓      ✓      [✓*]   ([✓*] = diagonal, ringed)
//
// Chosen over the ArrowDiagram triangle fallback because a grid shows both
// self-reference and bidirectionality at once with zero arrow-routing clutter.
// Flat HTML/CSS table inside <Figure expandable={false}> (no LeaderLines, but
// the diagram is small and the matrix layout is naturally horizontal/compact).
//
// Mid-tone green (600-range) carries the "present" signal in both themes; the
// diagonal cells get a stronger tint + ring so the eye catches the self-
// reference axis. Chrome is theme-aware via Starlight gray/bg vars. `not-content`
// + margin:0 resets defeat Starlight's injected prose margins inside the figure.

import Figure from '../../../figures/Figure.astro';

// One logical page (billing) in three locales. Rows = the page; the row's own
// locale is what makes its diagonal cell the self-reference entry.
const pages = [
	{ url: '/billing', locale: 'en-US' },
	{ url: '/fr-FR/billing', locale: 'fr-FR' },
	{ url: '/de-DE/billing', locale: 'de-DE' },
];
const declaredLocales = ['en-US', 'fr-FR', 'de-DE'];
---

<Figure expandable={false}>
	<div class="hsm not-content">
		<table class="hsm-grid">
			<thead>
				<tr>
					{/* Corner cell carries the axis legend for the columns. */}
					<th class="hsm-corner" scope="col">
						<span class="hsm-corner-row">Page</span>
						<span class="hsm-corner-col">declares alternate for →</span>
					</th>
					{
						declaredLocales.map((loc) => (
							<th class="hsm-col-head" scope="col">
								{loc}
							</th>
						))
					}
				</tr>
			</thead>
			<tbody>
				{
					pages.map((page) => (
						<tr>
							<th class="hsm-row-head" scope="row">
								<code class="hsm-url">{page.url}</code>
								<span class="hsm-row-locale">{page.locale}</span>
							</th>
							{declaredLocales.map((loc) => {
								const isSelf = loc === page.locale;
								return (
									<td class:list={['hsm-cell', { 'hsm-cell-self': isSelf }]}>
										<span class="hsm-check" aria-hidden="true">
											✓
										</span>
										<span class="hsm-sr">
											{page.url} declares {loc}
											{isSelf ? ' (self-reference)' : ''}
										</span>
									</td>
								);
							})}
						</tr>
					))
				}
			</tbody>
		</table>

		<div class="hsm-legend">
			<span class="hsm-legend-item">
				<span class="hsm-swatch hsm-swatch-self" aria-hidden="true">✓</span>
				<span><strong>Diagonal</strong> = self-reference</span>
			</span>
			<span class="hsm-legend-item">
				<span class="hsm-swatch hsm-swatch-mirror" aria-hidden="true"></span>
				<span><strong>Symmetry across the diagonal</strong> = bidirectionality</span>
			</span>
		</div>
	</div>

	<Fragment slot="caption">
		Every variant declares every sibling, both directions, plus itself. The
		diagonal is self-reference; the symmetry is bidirectionality. A single page
		emits one tag per locale, including its own.
	</Fragment>
</Figure>

<style>
	.hsm {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 18px;
		margin: 0;
		padding: 8px 4px;
		font-family:
			ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
	}

	.hsm-grid {
		border-collapse: separate;
		border-spacing: 6px;
		margin: 0;
		table-layout: auto;
	}
	/* Defeat Starlight's prose table chrome (zebra rows, full-width, borders). */
	.hsm-grid :global(th),
	.hsm-grid :global(td) {
		border: 0;
		background: none;
		padding: 0;
	}
	.hsm-grid :global(tbody tr:nth-child(2n)) {
		background: none;
	}

	/* Corner cell: labels both axes so the grid is self-explaining. */
	.hsm-corner {
		text-align: right;
		vertical-align: bottom;
		padding: 0 10px 6px 0 !important;
		line-height: 1.3;
	}
	.hsm-corner-row {
		display: block;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--sl-color-white, #1e293b);
	}
	.hsm-corner-col {
		display: block;
		font-size: 0.66rem;
		font-weight: 500;
		color: var(--sl-color-gray-3, #64748b);
	}

	/* Column headers — the locale each column declares. */
	.hsm-col-head {
		text-align: center !important;
		vertical-align: bottom;
		padding: 0 0 6px !important;
		min-width: 74px;
		font-size: 0.74rem;
		font-weight: 700;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		color: #1d4ed8;
	}

	/* Row headers — the page URL plus its own locale tag. */
	.hsm-row-head {
		text-align: right !important;
		vertical-align: middle;
		padding: 0 12px 0 0 !important;
		white-space: nowrap;
	}
	.hsm-url {
		display: block;
		font-size: 0.78rem;
		font-weight: 600;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		color: var(--sl-color-white, #1e293b);
		background: none;
		padding: 0;
		border: 0;
	}
	.hsm-row-locale {
		display: block;
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #1d4ed8;
		margin-top: 1px;
	}

	/* Default cell — a present alternate. */
	.hsm-cell {
		width: 74px;
		height: 52px;
		text-align: center;
		vertical-align: middle;
		border-radius: 9px !important;
		border: 1px solid color-mix(in srgb, #16a34a 32%, transparent) !important;
		background: color-mix(in srgb, #16a34a 9%, transparent) !important;
	}
	/* Diagonal (self-reference) — stronger tint + ring so the axis pops. */
	.hsm-cell-self {
		border: 2px solid #16a34a !important;
		background: color-mix(in srgb, #16a34a 20%, transparent) !important;
		box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 18%, transparent);
	}

	.hsm-check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		border-radius: 999px;
		background: #16a34a;
		color: #fff;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1;
	}
	.hsm-cell-self .hsm-check {
		width: 28px;
		height: 28px;
		font-size: 0.92rem;
	}

	/* Visually-hidden per-cell description for assistive tech. */
	.hsm-sr {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	/* Legend — reads off the two axes the shape encodes. */
	.hsm-legend {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px 22px;
		margin: 0;
		font-size: 0.78rem;
		color: var(--sl-color-gray-2, #475569);
	}
	.hsm-legend-item {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}
	.hsm-legend-item strong {
		color: var(--sl-color-white, #1e293b);
		font-weight: 600;
	}
	.hsm-swatch {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		border-radius: 7px;
	}
	.hsm-swatch-self {
		border: 2px solid #16a34a;
		background: color-mix(in srgb, #16a34a 20%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 18%, transparent);
		color: #15803d;
		font-size: 0.72rem;
		font-weight: 700;
	}
	/* Mirror swatch: two triangles split by the diagonal, echoing the symmetry. */
	.hsm-swatch-mirror {
		border: 1px solid color-mix(in srgb, #16a34a 40%, transparent);
		background: linear-gradient(
			135deg,
			color-mix(in srgb, #16a34a 26%, transparent) 0 48%,
			#16a34a 48% 52%,
			color-mix(in srgb, #16a34a 9%, transparent) 52% 100%
		);
	}

	/* Narrow viewports: shrink cells and the URL type so the grid stays inline. */
	@media (max-width: 560px) {
		.hsm-grid {
			border-spacing: 4px;
		}
		.hsm-cell {
			width: 56px;
			height: 46px;
		}
		.hsm-col-head {
			min-width: 56px;
			font-size: 0.66rem;
		}
		.hsm-url {
			font-size: 0.68rem;
		}
		.hsm-row-head {
			padding-right: 8px !important;
		}
	}
</style>
