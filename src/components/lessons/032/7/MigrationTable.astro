---
// MigrationTable — the legacy-to-Cache-Components lookup (Chapter 032 L7, "How a
// route declares itself dynamic"). The official Next.js 16 migration mapping:
// each legacy route segment config export on the left, what to do with it under
// `cacheComponents: true` on the right. This is a *reference* the student comes
// back to, not a sequence — so it's a plain two-column table, no flow.
//
// Encoding:
//   - Left column: the legacy `export const` line, in monospace — the artifact
//     the student is learning to recognise in inherited code.
//   - Right column: prose replacement, with the new directives/APIs (`'use cache'`,
//     `cacheLife(...)`, `<Suspense>`, `proxy.ts`) rendered monospace inline.
//   - A per-row ACTION chip splits the rows the way the prose does: most legacy
//     exports simply *Remove* (Cache Components decides structurally — dynamic is
//     the default, caching follows the boundary), shown in neutral SLATE. The two
//     that carry a real transform into a cached scope are *Replace*, shown in the
//     chapter's cached TEAL — the same colour 'use cache' wears across the chapter.
//     This lets the student see at a glance that the panel mostly evaporates and
//     only `revalidate` / `force-static` translate.
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the two tracks
// (`display: contents` rows), collapsing to a stacked card per row on narrow
// viewports. `not-content` + a `margin: 0` reset on inner elements defeats
// Starlight's injected prose margins. Chrome leans on Starlight CSS variables so
// it flips with the theme; the teal accent is mixed with `color-mix` so it stays
// legible in both light and dark.

// 'remove' — the export evaporates; Cache Components handles it structurally.
// 'replace' — the export carries a value/intent that moves into a 'use cache' scope.
type Action = 'remove' | 'replace';

type Row = {
	// The legacy export line, shown monospace in the left cell.
	legacy: string;
	// The replacement cell, an array of segments: plain prose or inline `code`.
	replacement: (string | { code: string })[];
	action: Action;
};

const ACTION_LABEL: Record<Action, string> = {
	remove: 'Remove',
	replace: 'Replace',
};

const rows: Row[] = [
	{
		legacy: "dynamic = 'force-dynamic'",
		replacement: ['Dynamic is already the default — just delete the line.'],
		action: 'remove',
	},
	{
		legacy: "dynamic = 'force-static'",
		replacement: [
			'Mark the data read ',
			{ code: "'use cache'" },
			' with ',
			{ code: "cacheLife('max')" },
			'; drop any request-time reads — those now need a ',
			{ code: '<Suspense>' },
			' boundary, which contradicts "fully static".',
		],
		action: 'replace',
	},
	{
		legacy: 'revalidate = 3600',
		replacement: [
			{ code: "'use cache'" },
			' + ',
			{ code: "cacheLife('hours')" },
			' — pick the preset closest to the interval, not a raw second count.',
		],
		action: 'replace',
	},
	{
		legacy: "fetchCache = 'force-cache'",
		replacement: [
			'Inside a ',
			{ code: "'use cache'" },
			' scope every fetch is cached; outside one, nothing is. The directive subsumes it.',
		],
		action: 'remove',
	},
	{
		legacy: "runtime = 'edge'",
		replacement: [
			'Not supported — Node is the default. For genuine edge behaviour, reach for ',
			{ code: 'proxy.ts' },
			'.',
		],
		action: 'remove',
	},
];
---

<div class="mt-root not-content">
	<div class="mt-row mt-header">
		<div class="mt-cell mt-head-cell">Legacy export</div>
		<div class="mt-cell mt-head-cell">Replacement under Cache Components</div>
	</div>

	{
		rows.map((r) => (
			<div class={`mt-row mt-action-${r.action}`}>
				<div class="mt-cell mt-legacy" data-label="Legacy export">
					<span class="mt-mono">{r.legacy}</span>
					<span class={`mt-chip mt-chip-${r.action}`}>
						{ACTION_LABEL[r.action]}
					</span>
				</div>
				<div
					class="mt-cell mt-replacement"
					data-label="Replacement under Cache Components"
				>
					<span>
						{r.replacement.map((seg) =>
							typeof seg === 'string' ? (
								seg
							) : (
								<code class="mt-inline-code">{seg.code}</code>
							),
						)}
					</span>
				</div>
			</div>
		))
	}
</div>

<style>
	.mt-root {
		display: grid;
		grid-template-columns: max-content minmax(0, 1fr);
		row-gap: 1px;
		column-gap: 0;
		padding: 0;
		margin: 0;
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 10px;
		overflow: hidden;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		/* chapter cached colour (teal-600) — what 'use cache' wears */
		--mt-teal: #0d9488;
		--mt-slate: #64748b;
	}

	.mt-row {
		display: contents;
	}

	.mt-cell {
		padding: 11px 16px;
		font-size: 13.5px;
		line-height: 1.5;
		color: var(--sl-color-text);
		margin: 0;
		background: var(--sl-color-bg);
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 6px;
	}

	/* Hairline between rows: a faint line under every cell except the last row. */
	.mt-row:not(:last-child) .mt-cell {
		border-bottom: 1px solid
			color-mix(in srgb, var(--sl-color-gray-5) 70%, transparent);
	}

	/* Faint divider between the two columns. */
	.mt-cell.mt-replacement {
		border-left: 1px solid
			color-mix(in srgb, var(--sl-color-gray-5) 70%, transparent);
	}

	.mt-head-cell {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		background: color-mix(in srgb, var(--sl-color-gray-6) 55%, transparent);
		padding-top: 9px;
		padding-bottom: 9px;
	}

	.mt-legacy {
		flex-direction: row;
		align-items: center;
		gap: 10px;
		white-space: nowrap;
	}

	.mt-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 13px;
		font-weight: 600;
		color: var(--sl-color-text);
		white-space: nowrap;
		margin: 0;
	}

	/* Inline code in the replacement column — monospace, no prose pill. */
	.mt-inline-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 12.5px;
		font-weight: 600;
		color: color-mix(in srgb, var(--mt-teal) 70%, var(--sl-color-text));
		background: transparent;
		padding: 0;
		margin: 0;
		white-space: nowrap;
	}

	/* Action chip — Remove (slate) vs Replace (cached teal). */
	.mt-chip {
		flex-shrink: 0;
		font-size: 9.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1;
		margin: 0;
		padding: 3px 7px;
		border-radius: 999px;
		white-space: nowrap;
		border: 1px solid transparent;
	}

	.mt-chip-remove {
		color: var(--mt-slate);
		background: color-mix(in srgb, var(--mt-slate) 12%, transparent);
		border-color: color-mix(in srgb, var(--mt-slate) 30%, transparent);
	}

	.mt-chip-replace {
		color: var(--mt-teal);
		background: color-mix(in srgb, var(--mt-teal) 12%, transparent);
		border-color: color-mix(in srgb, var(--mt-teal) 35%, transparent);
	}

	/* The two 'use cache' rows carry a faint teal wash so the spectrum reads. */
	.mt-action-replace .mt-cell {
		background: color-mix(in srgb, var(--mt-teal) 5%, var(--sl-color-bg));
	}

	/* Narrow viewport: collapse each row to a stacked card. */
	@media (max-width: 640px) {
		.mt-root {
			grid-template-columns: 1fr;
			row-gap: 0;
		}

		.mt-row.mt-header {
			display: none;
		}

		.mt-row {
			display: block;
			padding: 12px 14px;
			margin: 0;
		}

		.mt-row:not(:last-child) {
			border-bottom: 1px solid
				color-mix(in srgb, var(--sl-color-gray-5) 70%, transparent);
		}

		.mt-action-replace {
			background: color-mix(in srgb, var(--mt-teal) 5%, var(--sl-color-bg));
		}

		.mt-cell {
			background: transparent !important;
			border: none !important;
			padding: 0;
			flex-direction: row;
			align-items: baseline;
			gap: 8px;
		}

		.mt-legacy {
			white-space: normal;
			flex-wrap: wrap;
			margin-bottom: 6px;
		}

		.mt-replacement::before {
			content: attr(data-label);
			font-size: 10px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--sl-color-gray-3);
			flex-shrink: 0;
			align-self: flex-start;
			padding-top: 2px;
		}
	}
</style>
