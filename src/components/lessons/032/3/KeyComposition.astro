---
// The cache key as a composition (diagram id: key-composition, Chapter 032 L3).
//
// Pedagogical goal (two ideas in one picture):
//   1. The cache key is a *composition* of inputs — four ingredients
//      (build id, function id, arguments, captured vars) are folded into one
//      hash. The left column makes "the key is built FROM these" literal.
//   2. Different inputs -> different entries. The same key box fans out to TWO
//      distinct stored entries because two calls pass different arguments
//      (getPost('pricing') vs getPost('about')). The two blue entry boxes are
//      drawn visibly separate to show they are two different stored values.
//
// Placed after the closure section, so all four ingredients are already taught.
// Layout is left -> right and vertically compact (well under 800px): a column of
// grey ingredient chips, an arrow into one neutral "cache key (hash)" box, then a
// split into two blue (cached colour) entry boxes, each tagged with the argument
// value that produced it so the cause of the split is explicit.
//
// House style follows this chapter family's HTML/CSS figures
// (e.g. 031 BoundaryCountGranularity): pinned `color-scheme: light` so the
// hand-picked tints survive dark mode, `margin: 0` on every inner element to
// defeat Starlight's injected prose margins, inline style strings (no <style>
// block), and box-sizing: border-box. Wrapped in <Figure> per the diagram index.

import Figure from '../../../figures/Figure.astro';

// Palette — neutral slate for the ingredients + key (they are not "the colour"),
// blue for the stored entries (the chapter-wide cached colour).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — secondary text
const SURFACE = '#ffffff'; // ordinary surface
const BORDER = '#cbd5e1'; // slate-300 — ordinary edge
const PANEL_BG = '#f1f5f9'; // slate-100 — neutral wash

const BLUE = '#2563eb'; // blue-600 — cached accent (chapter-wide)
const BLUE_BG = '#eff6ff'; // blue-50 — cached wash
const BLUE_INK = '#1e40af'; // blue-800 — cached text

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, monospace';

// Outer stage: pinned light, slate ink. A 3-zone row (ingredients -> key ->
// entries) that wraps to a column on narrow figure cards so nothing is crushed.
const stage = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; column-gap: 14px; row-gap: 18px; margin: 0; padding: 4px 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// Zone 1 — the ingredient stack, with a small eyebrow above the chips.
const ingredients = `display: flex; flex-direction: column; gap: 7px; margin: 0; min-width: 0;`;
const eyebrow = `margin: 0 0 1px; font-family: ${sans}; font-size: 9.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${INK_SOFT};`;

// A single ingredient chip. The `arguments` chip is the one that varies between
// the two calls below, so it gets the blue accent to tie cause -> effect; the
// other three stay neutral grey (constant across both entries here).
const chip = (accent: boolean) =>
	`box-sizing: border-box; display: flex; align-items: center; gap: 8px; margin: 0; padding: 7px 11px; border-radius: 9px; border: 1px solid ${accent ? BLUE : BORDER}; background: ${accent ? BLUE_BG : PANEL_BG}; min-width: 168px;`;
const chipDot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 7px; height: 7px; margin: 0; border-radius: 2px; background: ${c};`;
const chipLabel = (accent: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.25; white-space: nowrap; color: ${accent ? BLUE_INK : INK};`;

// Connector arrows + the "fold into" / "look up" micro-labels.
const connector = `display: flex; flex-direction: column; align-items: center; gap: 3px; margin: 0;`;
const arrowGlyph = `margin: 0; font-size: 22px; font-weight: 800; line-height: 1; color: ${INK_SOFT};`;
const connectorText = `margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT}; white-space: nowrap;`;

// Zone 2 — the single cache-key (hash) box: the funnel point.
const keyBox = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 4px; margin: 0; padding: 14px 16px; border-radius: 12px; border: 1.5px solid ${INK_SOFT}; background: ${SURFACE};`;
const keyTitle = `margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 800; line-height: 1.2; color: ${INK};`;
const keyHash = `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.2; color: ${INK_SOFT}; letter-spacing: 0.02em;`;

// Zone 3 — the fan-out: two distinct stored entries, each its own blue box.
const entriesCol = `display: flex; flex-direction: column; gap: 12px; margin: 0; min-width: 0;`;

// One stored entry: a call tag at the top (which argument produced it) and a
// mini "stored render" block inside, all on the cached-blue tint.
const entryBox = `box-sizing: border-box; display: flex; flex-direction: column; gap: 8px; margin: 0; padding: 11px 12px; border-radius: 11px; border: 1.5px solid ${BLUE}; background: ${BLUE_BG}; min-width: 206px;`;
const entryHead = `display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 0;`;
const callLabel = `margin: 0; font-family: ${mono}; font-size: 12px; font-weight: 700; line-height: 1.2; color: ${BLUE_INK}; white-space: nowrap;`;
const entryTag = `display: inline-flex; align-items: center; flex: 0 0 auto; margin: 0; padding: 1px 8px; border-radius: 999px; border: 1px solid ${BLUE}; background: ${SURFACE}; color: ${BLUE_INK}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.35; white-space: nowrap;`;

// The "stored render" mini-block — a tiny mock of a cached result.
const storedRender = `box-sizing: border-box; display: flex; align-items: center; gap: 9px; margin: 0; padding: 8px 9px; border-radius: 8px; border: 1px solid ${BLUE}; background: ${SURFACE};`;
const renderBars = `display: inline-flex; flex-direction: column; gap: 4px; flex: 1 1 auto; margin: 0; min-width: 0;`;
const renderBar = (w: string, c: string) =>
	`display: block; height: 5px; width: ${w}; margin: 0; border-radius: 999px; background: ${c};`;
const storedTag = `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 700; line-height: 1.2; color: ${BLUE_INK}; white-space: nowrap;`;

// The small split bracket label between the key box and the two entries.
const splitNote = `margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT}; white-space: nowrap; text-align: center;`;
---

<Figure
	caption="The key is a composition: build id, function id, arguments, and captured vars fold into one hash. Two calls with different arguments produce different keys, so each is stored as its own entry."
>
	<div style={stage}>
		{/* ---- Zone 1: the ingredients that compose the key ---- */}
		<div style={ingredients}>
			<p style={eyebrow}>key ingredients</p>
			<div style={chip(false)}>
				<span style={chipDot(INK_SOFT)} aria-hidden="true"></span>
				<span style={chipLabel(false)}>build id</span>
			</div>
			<div style={chip(false)}>
				<span style={chipDot(INK_SOFT)} aria-hidden="true"></span>
				<span style={chipLabel(false)}>function id</span>
			</div>
			<div style={chip(true)}>
				<span style={chipDot(BLUE)} aria-hidden="true"></span>
				<span style={chipLabel(true)}>arguments</span>
			</div>
			<div style={chip(false)}>
				<span style={chipDot(INK_SOFT)} aria-hidden="true"></span>
				<span style={chipLabel(false)}>captured vars</span>
			</div>
		</div>

		{/* ---- fold into ---- */}
		<div style={connector}>
			<span style={connectorText}>fold into</span>
			<span style={arrowGlyph} aria-hidden="true">&rarr;</span>
		</div>

		{/* ---- Zone 2: one composed key ---- */}
		<div style={keyBox}>
			<p style={keyTitle}>cache key</p>
			<p style={keyHash}>hash(&hellip;)</p>
		</div>

		{/* ---- look up -> splits into distinct entries ---- */}
		<div style={connector}>
			<span style={connectorText}>looks up</span>
			<span style={arrowGlyph} aria-hidden="true">&rarr;</span>
			<span style={splitNote}>different args<br />different entries</span>
		</div>

		{/* ---- Zone 3: two distinct stored entries ---- */}
		<div style={entriesCol}>
			<div style={entryBox}>
				<div style={entryHead}>
					<span style={callLabel}>{"getPost('pricing')"}</span>
					<span style={entryTag}>entry A</span>
				</div>
				<div style={storedRender}>
					<span style={renderBars} aria-hidden="true">
						<span style={renderBar('70%', BLUE)}></span>
						<span style={renderBar('92%', BORDER)}></span>
						<span style={renderBar('60%', BORDER)}></span>
					</span>
					<span style={storedTag}>stored render</span>
				</div>
			</div>

			<div style={entryBox}>
				<div style={entryHead}>
					<span style={callLabel}>{"getPost('about')"}</span>
					<span style={entryTag}>entry B</span>
				</div>
				<div style={storedRender}>
					<span style={renderBars} aria-hidden="true">
						<span style={renderBar('58%', BLUE)}></span>
						<span style={renderBar('86%', BORDER)}></span>
						<span style={renderBar('74%', BORDER)}></span>
					</span>
					<span style={storedTag}>stored render</span>
				</div>
			</div>
		</div>
	</div>
</Figure>
