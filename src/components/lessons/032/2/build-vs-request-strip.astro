---
// build-vs-request-strip (diagram id: build-vs-request-strip, Chapter 032 L2).
// The "shell comes from build" novelty made concrete: one route drawn in TWO
// time frames, stacked as two horizontal lanes with column-aligned segments so
// the eye reads the same three pieces (Header / OrgInvoices / FooterAd) twice.
//
//   Lane 1 "At `next build` (once)" — the route row. <Header/> and <FooterAd/>
//     are SOLID teal (cached → shell) segments; the <OrgInvoices/> region is a
//     DASHED striped placeholder (the skeleton the build drops in, because the
//     data does not exist yet). A "stored on the CDN" tag points out of the lane.
//   Lane 2 "At each request" — the SAME row. The cached segments are tagged
//     "from edge · ~30ms" (already HTML near the user, no work); the placeholder
//     column is now filled by a SOLID amber "from origin · ~400ms" segment that
//     streams in — a down-arrow from lane 1's skeleton into lane 2's filled hole
//     carries the "streams in over the same response" beat.
//
// Encoding: horizontal position = the route's layout left-to-right; the three
// segments share identical flex ratios in both lanes so columns align exactly
// (the whole point — "same route, two time frames"). Teal = cached/shell, amber
// = dynamic/hole — the chapter-wide tints, lifted verbatim from L1's
// route-tree-dispositions so the color reads continuously across the chapter.
// The skeleton hole is dashed teal-neutral (it is the shell's placeholder), then
// becomes a solid amber fill once the origin resolves it.
//
// Hand-authored markup → wrapped in <Figure> (correct here; the self-carding
// RequestTrace above carries the animated timeline, this is the simpler static
// companion the section's prose asked for). Pure HTML + CSS, inline style
// strings only. color-scheme pinned light so the semantic tints survive dark
// mode; margin:0 on every inner node to defeat Starlight's injected prose
// margin-top.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette — fixed, color-scheme pinned light (lifted verbatim from L1's
// route-tree-dispositions so cached/dynamic read continuously across the chapter).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// Neutral lane chrome.
const SLATE_EDGE = '#cbd5e1'; // slate-300
const SLATE_BG = '#f8fafc'; // slate-50

// CACHED / SHELL — teal.
const TEAL = '#0d9488'; // teal-600
const TEAL_BG = '#f0fdfa'; // teal-50 wash
const TEAL_EDGE = '#5eead4'; // teal-300
const TEAL_INK = '#0f766e'; // teal-700

// DYNAMIC / HOLE — amber.
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 wash
const AMBER_EDGE = '#fcd34d'; // amber-300
const AMBER_INK = '#b45309'; // amber-700

// ---- shared atoms ----------------------------------------------------------

// Outer stage: pinned light, slate ink, vertical stack of the two lanes.
const stage = `display: flex; flex-direction: column; align-items: stretch; gap: 0; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK}; max-width: 640px; margin-left: auto; margin-right: auto;`;

// A lane block: its time-frame heading on top, the segmented bar below.
const lane = `display: flex; flex-direction: column; align-items: stretch; gap: 8px; margin: 0;`;

// The time-frame heading row (e.g. "At `next build`  (once)").
const laneHead = `display: flex; align-items: baseline; flex-wrap: wrap; column-gap: 8px; row-gap: 2px; margin: 0;`;
const laneTitle = `margin: 0; font-family: ${sans}; font-size: 13.5px; font-weight: 800; line-height: 1.25; color: ${INK};`;
const laneTitleCode = `font-family: ${mono}; font-size: 12.5px; font-weight: 800; background: transparent; padding: 0; color: ${INK};`;
const laneQual = `margin: 0; font-family: ${sans}; font-size: 11px; font-weight: 700; line-height: 1.3; color: ${INK_SOFT}; text-transform: uppercase; letter-spacing: 0.04em;`;

// The segmented bar — three columns, fixed flex ratios shared across both lanes.
// Header : OrgInvoices : FooterAd  =  3 : 6 : 2  (OrgInvoices is the wide,
// slow middle). min-width:0 lets each segment shrink before its label forces it.
const barRow = `display: flex; align-items: stretch; gap: 6px; margin: 0; width: 100%;`;
const RATIO = { header: 3, invoices: 6, footer: 2 };

// A solid cached/shell segment.
const cachedSeg = (flex: number) =>
	`box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 3px; flex: ${flex} 1 0; min-width: 0; margin: 0; padding: 9px 10px; border: 1.5px solid ${TEAL}; border-radius: 9px; background: ${TEAL_BG};`;

// A solid dynamic/hole segment (the filled hole on the request lane).
const dynSeg = (flex: number) =>
	`box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 3px; flex: ${flex} 1 0; min-width: 0; margin: 0; padding: 9px 10px; border: 1.5px solid ${AMBER}; border-radius: 9px; background: ${AMBER_BG};`;

// The build-time placeholder: a dashed, striped skeleton holding the hole's slot.
const holeStripe = `repeating-linear-gradient(135deg, ${SLATE_BG} 0 7px, #eef2f6 7px 14px)`;
const skeletonSeg = (flex: number) =>
	`box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 4px; flex: ${flex} 1 0; min-width: 0; margin: 0; padding: 9px 10px; border: 1.5px dashed ${SLATE_EDGE}; border-radius: 9px; background: ${holeStripe};`;

// Segment label (component name) + sublabel (disposition / timing).
const segName = `margin: 0; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;`;
const segSub = `display: inline-flex; align-items: center; gap: 5px; margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.3; white-space: nowrap;`;
const segTime = `font-family: ${mono}; font-weight: 700;`;
const dot = (c: string) => `display: inline-block; flex: 0 0 auto; width: 6px; height: 6px; margin: 0; border-radius: 50%; background: ${c};`;

// Skeleton bars inside the placeholder segment (mirror the resolved footprint).
const skelBars = `display: flex; flex-direction: column; align-items: stretch; gap: 4px; width: 100%; margin: 0;`;
const skelBar = (w: string) =>
	`height: 5px; width: ${w}; margin: 0; border-radius: 3px; background: ${SLATE_EDGE}; align-self: center;`;
const skelTag = `margin: 0; font-family: ${sans}; font-size: 9.5px; font-weight: 800; line-height: 1.3; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT}; white-space: nowrap;`;

// "stored on the CDN" tag trailing the build lane.
const cdnNote = `display: inline-flex; align-items: center; gap: 6px; align-self: flex-end; margin: 0; padding: 2px 9px; border: 1px solid ${TEAL_EDGE}; border-radius: 999px; background: ${SURFACE}; color: ${TEAL_INK}; font-family: ${sans}; font-size: 10.5px; font-weight: 800; line-height: 1.35; white-space: nowrap;`;

// ---- the connector between the lanes (skeleton → filled hole) --------------
// A thin band sitting between the two bars; an arrow drops down the OrgInvoices
// column, carrying "streams in over the same response". It is laid out with the
// same flex ratios so the arrow lands under the middle (hole) column.
const connectorRow = `display: flex; align-items: stretch; gap: 6px; margin: 8px 0; width: 100%;`;
const connectorSpacer = (flex: number) => `flex: ${flex} 1 0; min-width: 0; margin: 0;`;
const connectorMid = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; flex: ${RATIO.invoices} 1 0; min-width: 0; margin: 0;`;
const arrowGlyph = `margin: 0; font-family: ${sans}; font-size: 18px; font-weight: 900; line-height: 0.7; color: ${AMBER};`;
const arrowLabel = `margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.25; text-align: center; color: ${AMBER_INK}; white-space: nowrap;`;
---

<Figure caption="The same route in two time frames. The shell is rendered once at build and served from the edge; only the dynamic hole runs again on each request.">
	<div style={stage}>
		{/* ============ LANE 1 — AT BUILD ============ */}
		<div style={lane}>
			<div style={laneHead}>
				<span style={laneTitle}>
					At <code style={laneTitleCode}>next build</code>
				</span>
				<span style={laneQual}>once</span>
			</div>

			<div style={barRow}>
				{/* Header — cached → shell */}
				<div style={cachedSeg(RATIO.header)}>
					<span style={`${segName} color: ${TEAL_INK};`}>&lt;Header /&gt;</span>
					<span style={`${segSub} color: ${TEAL_INK};`}>
						<span style={dot(TEAL)} aria-hidden="true"></span>prerendered
					</span>
				</div>

				{/* OrgInvoices — the hole, held by a skeleton placeholder at build */}
				<div style={skeletonSeg(RATIO.invoices)}>
					<span style={skelTag}>&lt;OrgInvoices /&gt; &mdash; skeleton</span>
					<div style={skelBars} aria-hidden="true">
						<span style={skelBar('86%')}></span>
						<span style={skelBar('72%')}></span>
						<span style={skelBar('80%')}></span>
					</div>
				</div>

				{/* FooterAd — cached → shell */}
				<div style={cachedSeg(RATIO.footer)}>
					<span style={`${segName} color: ${TEAL_INK};`}>&lt;FooterAd /&gt;</span>
					<span style={`${segSub} color: ${TEAL_INK};`}>
						<span style={dot(TEAL)} aria-hidden="true"></span>prerendered
					</span>
				</div>
			</div>

			<span style={cdnNote}>
				<span aria-hidden="true">&#9729;</span>stored on the CDN
			</span>
		</div>

		{/* ============ CONNECTOR — skeleton resolves into the hole ============ */}
		<div style={connectorRow} aria-hidden="true">
			<span style={connectorSpacer(RATIO.header)}></span>
			<div style={connectorMid}>
				<span style={arrowLabel}>streams in</span>
				<span style={arrowGlyph}>&darr;</span>
			</div>
			<span style={connectorSpacer(RATIO.footer)}></span>
		</div>

		{/* ============ LANE 2 — AT EACH REQUEST ============ */}
		<div style={lane}>
			<div style={laneHead}>
				<span style={laneTitle}>At each request</span>
				<span style={laneQual}>every visitor</span>
			</div>

			<div style={barRow}>
				{/* Header — served straight from the edge cache */}
				<div style={cachedSeg(RATIO.header)}>
					<span style={`${segName} color: ${TEAL_INK};`}>&lt;Header /&gt;</span>
					<span style={`${segSub} color: ${TEAL_INK};`}>
						<span style={dot(TEAL)} aria-hidden="true"></span>from edge&nbsp;&middot;&nbsp;<span
							style={segTime}>~30ms</span
						>
					</span>
				</div>

				{/* OrgInvoices — the filled hole, streamed from the origin */}
				<div style={dynSeg(RATIO.invoices)}>
					<span style={`${segName} color: ${AMBER_INK};`}>&lt;OrgInvoices /&gt;</span>
					<span style={`${segSub} color: ${AMBER_INK};`}>
						<span style={dot(AMBER)} aria-hidden="true"></span>from origin&nbsp;&middot;&nbsp;<span
							style={segTime}>~400ms</span
						>
					</span>
				</div>

				{/* FooterAd — served straight from the edge cache */}
				<div style={cachedSeg(RATIO.footer)}>
					<span style={`${segName} color: ${TEAL_INK};`}>&lt;FooterAd /&gt;</span>
					<span style={`${segSub} color: ${TEAL_INK};`}>
						<span style={dot(TEAL)} aria-hidden="true"></span>from edge&nbsp;&middot;&nbsp;<span
							style={segTime}>~30ms</span
						>
					</span>
				</div>
			</div>
		</div>
	</div>
</Figure>
