---
// dynamic-signals-inventory (diagram id: dynamic-signals-inventory, Chapter 032 L1).
// The closed set of request-time APIs that mark a code path dynamic under Cache
// Components, drawn as a compact two-group inventory — NOT a syntax tutorial.
// Each row maps one API to the request data it reads. The whole point is the
// student seeing (a) it is a SMALL, CLOSED list and (b) the two SOURCES the
// signals come from:
//
//   Group 1 "Page props" — params, searchParams. The props the framework hands
//     a page/layout. Tinted violet.
//   Group 2 "from next/headers" — cookies(), headers(), draftMode(). The
//     next/headers surface. Tinted cyan.
//
// API names are monospace; the "reads" column is prose. A single footer line
// carries the only how-to detail allowed here: all of these are read with
// `await` (the actual await/Promise mechanics are deferred to lesson 7), so the
// diagram does NOT show await syntax, Promise-unwrapping, or worked usage.
//
// Wrapped in <Figure> (a plain static visual). Pure HTML + CSS, inline style
// strings only. color-scheme pinned light so the hand-picked source tints
// survive dark mode; margin:0 on every inner node to defeat Starlight's
// injected prose margin-top. Palette + atom conventions match the lesson's
// other figure (route-tree-dispositions, 032/1) for page-wide consistency,
// using its slate chrome and the same monospace/sans pairing.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette (fixed — color-scheme pinned light so these survive dark mode).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// Neutral chrome — the canvas the groups sit on (matches route-tree figure).
const SLATE_EDGE = '#cbd5e1'; // slate-300
const SLATE_BG = '#f8fafc'; // slate-50
const SLATE_LINE = '#e2e8f0'; // slate-200 — row hairlines

// SOURCE 1 — page props (params, searchParams). Violet.
const VIOLET = '#7c3aed'; // violet-600
const VIOLET_BG = '#f5f3ff'; // violet-50 wash
const VIOLET_EDGE = '#c4b5fd'; // violet-300
const VIOLET_INK = '#6d28d9'; // violet-700

// SOURCE 2 — next/headers (cookies, headers, draftMode). Cyan.
const CYAN = '#0891b2'; // cyan-600
const CYAN_BG = '#ecfeff'; // cyan-50 wash
const CYAN_EDGE = '#67e8f9'; // cyan-300
const CYAN_INK = '#0e7490'; // cyan-700

// ---- atoms -----------------------------------------------------------------

// Outer stage: pinned light, slate ink, centered column.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A short header line above the two groups, framing the closed-set idea.
const intro = `display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 4px 12px; border: 1px solid ${SLATE_EDGE}; border-radius: 999px; background: ${SLATE_BG}; font-family: ${sans}; font-size: 12px; font-weight: 700; line-height: 1.3; color: ${INK};`;
const introCount = `display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; min-width: 18px; height: 18px; margin: 0; padding: 0 5px; border-radius: 6px; background: ${INK}; color: #ffffff; font-family: ${mono}; font-size: 11px; font-weight: 800; line-height: 1;`;

// The two groups sit side by side and wrap on narrow cards.
const groupsRow = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 14px; margin: 0; width: 100%; max-width: 640px;`;

// A source group box — a fieldset-legend pill straddles its top edge.
const group = (edge: string, bg: string) =>
	`position: relative; box-sizing: border-box; display: flex; flex-direction: column; flex: 1 1 270px; min-width: 250px; margin: 0; padding: 24px 12px 12px; border: 1.5px solid ${edge}; border-radius: 13px; background: ${bg};`;
const groupPill = (ink: string, edge: string, bg: string) =>
	`display: block; width: fit-content; box-sizing: border-box; margin: -36px 0 0 12px; padding: 3px 10px; font-family: ${sans}; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.3; white-space: nowrap; border-radius: 7px; color: ${ink}; background: ${SURFACE}; border: 1.5px solid ${edge}; box-shadow: 0 0 0 3px ${bg};`;
const groupPillSrc = (ink: string) =>
	`font-family: ${mono}; font-weight: 800; text-transform: none; letter-spacing: 0; color: ${ink};`;

// The rows inside a group, hairline-separated.
const rowList = `display: flex; flex-direction: column; margin: 0; padding: 0;`;
const rowSep = (i: number) =>
	`display: flex; align-items: baseline; gap: 9px; margin: 0; padding: 8px 4px; ${i > 0 ? `border-top: 1px solid ${SLATE_LINE};` : ''}`;

// The API name pill (monospace), tinted to its source.
const apiPill = (ink: string, edge: string, bg: string) =>
	`display: inline-flex; align-items: center; flex: 0 0 auto; margin: 0; padding: 2px 8px; border: 1px solid ${edge}; border-radius: 7px; background: ${bg}; color: ${ink}; font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.4; white-space: nowrap;`;
// The "what it reads" prose.
const readsText = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 500; line-height: 1.4; color: ${INK};`;
const codeFrag = `font-family: ${mono}; font-size: 0.92em; color: ${INK_SOFT};`;

// Footer note — the one allowed how-to detail: all read with await.
const footer = `display: inline-flex; align-items: center; gap: 8px; margin: 0; padding: 7px 13px; border: 1px solid ${SLATE_EDGE}; border-radius: 10px; background: ${SLATE_BG}; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.45; text-align: center; color: ${INK_SOFT}; max-width: 560px;`;
const awaitKw = `font-family: ${mono}; font-weight: 800; color: ${INK};`;
---

<Figure caption="The complete, closed set of request-time APIs. Reading any one of them is what marks a code path dynamic — two come in as page props, three from next/headers, and there is no hidden sixth channel.">
	<div style={stage}>
		<span style={intro}>
			<span style={introCount} aria-hidden="true">5</span>
			the entire set of request-time APIs
		</span>

		<div style={groupsRow}>
			{/* ===== SOURCE 1 — page props ===== */}
			<div style={group(VIOLET_EDGE, VIOLET_BG)}>
				<span style={groupPill(VIOLET_INK, VIOLET_EDGE, VIOLET_BG)}>Page props</span>

				<div style={rowList}>
					<div style={rowSep(0)}>
						<span style={apiPill(VIOLET_INK, VIOLET_EDGE, SURFACE)}>params</span>
						<span style={readsText}>
							the dynamic route segments &mdash; e.g. the <code style={codeFrag}>id</code> in <code
								style={codeFrag}>/invoices/[id]</code
							>
						</span>
					</div>
					<div style={rowSep(1)}>
						<span style={apiPill(VIOLET_INK, VIOLET_EDGE, SURFACE)}>searchParams</span>
						<span style={readsText}>the URL's query string</span>
					</div>
				</div>
			</div>

			{/* ===== SOURCE 2 — next/headers ===== */}
			<div style={group(CYAN_EDGE, CYAN_BG)}>
				<span style={groupPill(CYAN_INK, CYAN_EDGE, CYAN_BG)}>
					from <span style={groupPillSrc(CYAN_INK)}>next/headers</span>
				</span>

				<div style={rowList}>
					<div style={rowSep(0)}>
						<span style={apiPill(CYAN_INK, CYAN_EDGE, SURFACE)}>cookies()</span>
						<span style={readsText}>the request's cookies</span>
					</div>
					<div style={rowSep(1)}>
						<span style={apiPill(CYAN_INK, CYAN_EDGE, SURFACE)}>headers()</span>
						<span style={readsText}>the request's headers</span>
					</div>
					<div style={rowSep(2)}>
						<span style={apiPill(CYAN_INK, CYAN_EDGE, SURFACE)}>draftMode()</span>
						<span style={readsText}>whether draft mode is on for this request</span>
					</div>
				</div>
			</div>
		</div>

		<p style={footer}>
			Every one is read with <code style={awaitKw}>await</code> &mdash; the exact syntax is a later
			lesson; here, just know the set.
		</p>
	</div>
</Figure>
