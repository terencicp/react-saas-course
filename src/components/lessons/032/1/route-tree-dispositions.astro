---
// route-tree-dispositions (diagram id: route-tree-dispositions, Chapter 032 L1).
// The central artifact of the "Dynamic by default" lesson: a route's component
// tree drawn as a compact nested hierarchy, every node color-coded by its
// render-time DISPOSITION (the same tree the student colored by environment in
// ch 030, recolored cached-vs-dynamic). Two tabs flip between the legal shape
// and the build-rejected shape so the one hard rule lands as a picture.
//
//   Tab 1 "Legal: dynamic lifted to a sibling" — a Route node with three
//     SIBLING children: a cached <Header/>, a dynamic <InvoiceTable/> (the node
//     that awaits request data), and a cached <FooterAd/>. The <Suspense>
//     boundary is drawn as an indigo dashed ring wrapping ONLY the dynamic
//     sibling — the literal seam where the cached region ends and the dynamic
//     region begins. This is the shape to memorize.
//   Tab 2 "Rejected: dynamic nested under cache" — a cached <Header/> PARENT
//     with a dynamic child (await cookies()) nested INSIDE it. The offending
//     child carries a red error border + a "build fails" badge, so "dynamic
//     content inside a cached subtree breaks the build" is visual.
//
// Encoding: containment = parent/child (boxes literally nest); two disposition
// tints carried in a legend at the top of each tab — TEAL = cached (rendered
// once, served from cache), AMBER = dynamic (rendered every request). Indigo is
// reused verbatim from the ch 031 Suspense figures (BoundaryCountGranularity)
// so "the seam is the same <Suspense> you already know" reads at a glance; red
// is the build-error signal.
//
// TabbedContent provides its own figure card — NOT wrapped in <Figure>. Pure
// HTML + CSS, inline style strings only. color-scheme pinned light so the
// hand-picked semantic tints survive dark mode; margin:0 on every inner node to
// defeat Starlight's injected prose margin-top. The fieldset-legend pill
// technique (block + fit-content + negative margin-top) matches nesting-dolls
// (029/2) and the 031 boundary figures.

import TabbedContent from '../../../figures/tabbed-content/TabbedContent.astro';
import TabbedItem from '../../../figures/tabbed-content/TabbedItem.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette (fixed — color-scheme pinned light so these survive dark mode).
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';

// The route container chrome — neutral slate, just the canvas the nodes live on.
const SLATE_EDGE = '#cbd5e1'; // slate-300
const SLATE_BG = '#f8fafc'; // slate-50

// CACHED disposition — teal (rendered once, frozen, served from cache).
const TEAL = '#0d9488'; // teal-600
const TEAL_BG = '#f0fdfa'; // teal-50 wash
const TEAL_EDGE = '#5eead4'; // teal-300
const TEAL_INK = '#0f766e'; // teal-700

// DYNAMIC disposition — amber (rendered fresh on every request).
const AMBER = '#d97706'; // amber-600
const AMBER_BG = '#fffbeb'; // amber-50 wash
const AMBER_EDGE = '#fcd34d'; // amber-300
const AMBER_INK = '#b45309'; // amber-700

// The <Suspense> seam — indigo, verbatim from the ch 031 Suspense figures.
const INDIGO = '#4f46e5'; // indigo-600
const INDIGO_BG = '#eef2ff'; // indigo-50
const INDIGO_INK = '#3730a3'; // indigo-800

// The build error — red.
const RED = '#dc2626'; // red-600
const RED_BG = '#fef2f2'; // red-50 wash
const RED_INK = '#b91c1c'; // red-700

// ---- shared atoms ----------------------------------------------------------

// Outer stage per tab: pinned light, slate ink, centered.
const stage = `display: flex; flex-direction: column; align-items: center; gap: 14px; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// Legend row — maps each tint to its meaning, carried at the top of both tabs.
const legend = `display: flex; flex-wrap: wrap; justify-content: center; align-items: center; column-gap: 18px; row-gap: 8px; margin: 0; padding: 8px 12px; border: 1px solid ${SLATE_EDGE}; border-radius: 10px; background: ${SLATE_BG};`;
const legendItem = `display: inline-flex; align-items: center; gap: 7px; margin: 0;`;
const swatch = (bg: string, edge: string) =>
	`display: inline-block; flex: 0 0 auto; width: 16px; height: 16px; margin: 0; border-radius: 5px; background: ${bg}; border: 1.5px solid ${edge};`;
const swatchDashed = `display: inline-block; flex: 0 0 auto; width: 16px; height: 16px; margin: 0; border-radius: 5px; background: ${INDIGO_BG}; border: 1.5px dashed ${INDIGO};`;
const legendText = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 600; line-height: 1.3; color: ${INK};`;
const legendStrong = (c: string) => `color: ${c}; font-weight: 800;`;

// The Route container box — the canvas; a fieldset-legend pill straddles its top.
const routeBox = `position: relative; box-sizing: border-box; margin: 0; padding: 22px 16px 16px; border: 1.5px solid ${SLATE_EDGE}; border-radius: 13px; background: ${SLATE_BG}; width: 100%; max-width: 560px;`;
const routePill = `display: block; width: fit-content; box-sizing: border-box; margin: -33px 0 0 14px; padding: 2px 9px; font-family: ${mono}; font-size: 11.5px; font-weight: 700; line-height: 1.3; white-space: nowrap; border-radius: 6px; color: #ffffff; background: ${INK}; box-shadow: 0 0 0 3px ${SLATE_BG};`;

// A disposition node box (cached or dynamic). `straddle` controls the pill
// margin so a node sitting directly under the route pill clears it.
function node(bg: string, edge: string, extra = '') {
	return `position: relative; box-sizing: border-box; display: flex; flex-direction: column; gap: 6px; margin: 0; padding: 9px 11px 11px; border: 1.5px solid ${edge}; border-radius: 10px; background: ${bg}; min-width: 0; ${extra}`;
}
const nodeName = `margin: 0; font-family: ${mono}; font-size: 13px; font-weight: 700; line-height: 1.2; color: ${INK}; white-space: nowrap;`;

// A small disposition chip pinned under a node name ("cached" / "dynamic").
const chip = (edge: string, bg: string, ink: string) =>
	`display: inline-flex; align-items: center; gap: 5px; align-self: flex-start; margin: 0; padding: 1px 8px; border: 1px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${ink}; font-family: ${sans}; font-size: 9.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.35; white-space: nowrap;`;
const dot = (c: string) => `display: inline-block; flex: 0 0 auto; width: 6px; height: 6px; margin: 0; border-radius: 50%; background: ${c};`;

// A faint "reads request data" line under the dynamic node.
const readsLine = `display: inline-flex; align-items: center; gap: 5px; margin: 0; font-family: ${mono}; font-size: 10.5px; font-weight: 600; line-height: 1.3; color: ${AMBER_INK};`;

// ---- Tab 1 (Legal) atoms ---------------------------------------------------

// The sibling row — three children side by side, wraps on narrow cards.
const siblingRow = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 12px; margin: 0;`;
// Each sibling column gets equal flex; min-width:0 lets them shrink before wrap.
const sibling = `display: flex; flex: 1 1 150px; min-width: 150px; margin: 0;`;

// The <Suspense> seam — an indigo dashed ring wrapping ONLY the dynamic sibling.
const suspenseRing = `position: relative; box-sizing: border-box; display: flex; flex: 1; margin: 0; padding: 20px 9px 9px; border: 1.5px dashed ${INDIGO}; border-radius: 12px; background: ${INDIGO_BG}; min-width: 0;`;
const suspensePill = `position: absolute; top: -9px; left: 11px; margin: 0; padding: 1px 7px; border-radius: 6px; background: ${INDIGO}; color: #ffffff; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.4; white-space: nowrap;`;

// The "seam" caption under the row, pointing at where cached ends / dynamic begins.
const seamNote = `margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.45; text-align: center; color: ${INK_SOFT}; max-width: 520px;`;

// ---- Tab 2 (Rejected) atoms ------------------------------------------------

// The nesting label between the cached parent and its illegal child.
const nestLabel = `display: inline-flex; align-items: center; gap: 6px; margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: ${TEAL_INK};`;

// The build-fails badge that brands the offending nested node.
const errorBadge = `display: inline-flex; align-items: center; gap: 6px; align-self: flex-start; margin: 0; padding: 2px 9px; border: 1px solid ${RED}; border-radius: 999px; background: ${RED_BG}; color: ${RED_INK}; font-family: ${sans}; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.35; white-space: nowrap;`;
const errorGlyph = `display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 14px; height: 14px; margin: 0; border-radius: 50%; background: ${RED}; color: #ffffff; font-family: ${sans}; font-size: 10px; font-weight: 900; line-height: 1;`;
const rejectNote = `margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.45; text-align: center; color: ${INK_SOFT}; max-width: 520px;`;
const rejectStrong = (c: string) => `color: ${c}; font-weight: 800;`;
---

<TabbedContent>
	{/* ====================== TAB 1 — LEGAL ====================== */}
	<TabbedItem
		label="Legal: dynamic lifted to a sibling"
		caption="The shape to memorize: pure cached siblings around a dynamic sibling, the <Suspense> boundary drawn as the seam where the cached region ends and the dynamic one begins."
	>
		<div style={stage}>
			{/* legend */}
			<div style={legend}>
				<span style={legendItem}>
					<span style={swatch(TEAL_BG, TEAL)} aria-hidden="true"></span>
					<span style={legendText}>
						<span style={legendStrong(TEAL_INK)}>Cached</span> &mdash; rendered once, served from cache
					</span>
				</span>
				<span style={legendItem}>
					<span style={swatch(AMBER_BG, AMBER)} aria-hidden="true"></span>
					<span style={legendText}>
						<span style={legendStrong(AMBER_INK)}>Dynamic</span> &mdash; rendered on every request
					</span>
				</span>
				<span style={legendItem}>
					<span style={swatchDashed} aria-hidden="true"></span>
					<span style={legendText}>
						<span style={legendStrong(INDIGO_INK)}>&lt;Suspense&gt;</span> &mdash; the seam
					</span>
				</span>
			</div>

			{/* the route tree */}
			<div style={routeBox}>
				<span style={routePill}>app/invoices/page.tsx</span>

				<div style={siblingRow}>
					{/* cached sibling — Header */}
					<div style={sibling}>
						<div style={node(TEAL_BG, TEAL)}>
							<span style={nodeName}>&lt;Header /&gt;</span>
							<span style={chip(TEAL_EDGE, SURFACE, TEAL_INK)}>
								<span style={dot(TEAL)} aria-hidden="true"></span>cached
							</span>
						</div>
					</div>

					{/* dynamic sibling — InvoiceTable, wrapped in its own <Suspense> seam */}
					<div style={sibling}>
						<div style={suspenseRing}>
							<span style={suspensePill}>&lt;Suspense&gt;</span>
							<div style={node(AMBER_BG, AMBER)}>
								<span style={nodeName}>&lt;InvoiceTable /&gt;</span>
								<span style={chip(AMBER_EDGE, SURFACE, AMBER_INK)}>
									<span style={dot(AMBER)} aria-hidden="true"></span>dynamic
								</span>
								<span style={readsLine}>
									<span style={dot(AMBER)} aria-hidden="true"></span>awaits request data
								</span>
							</div>
						</div>
					</div>

					{/* cached sibling — FooterAd */}
					<div style={sibling}>
						<div style={node(TEAL_BG, TEAL)}>
							<span style={nodeName}>&lt;FooterAd /&gt;</span>
							<span style={chip(TEAL_EDGE, SURFACE, TEAL_INK)}>
								<span style={dot(TEAL)} aria-hidden="true"></span>cached
							</span>
						</div>
					</div>
				</div>
			</div>

			<p style={seamNote}>
				Three children, three dispositions, one URL. The dynamic work sits <strong>beside</strong> the
				cached siblings, never inside them &mdash; and its <code
					style={`font-family: ${mono}; background: transparent; padding: 0; color: ${INDIGO_INK};`}
					>&lt;Suspense&gt;</code
				> boundary is the seam.
			</p>
		</div>
	</TabbedItem>

	{/* ====================== TAB 2 — REJECTED ====================== */}
	<TabbedItem
		label="Rejected: dynamic nested under cache"
		caption="The mistake the build stops you from shipping: dynamic content nested inside a cached subtree. Caught loudly at build time, not silently mis-served in production."
	>
		<div style={stage}>
			{/* legend (identical mapping, carried per tab) */}
			<div style={legend}>
				<span style={legendItem}>
					<span style={swatch(TEAL_BG, TEAL)} aria-hidden="true"></span>
					<span style={legendText}>
						<span style={legendStrong(TEAL_INK)}>Cached</span> &mdash; rendered once, served from cache
					</span>
				</span>
				<span style={legendItem}>
					<span style={swatch(AMBER_BG, AMBER)} aria-hidden="true"></span>
					<span style={legendText}>
						<span style={legendStrong(AMBER_INK)}>Dynamic</span> &mdash; rendered on every request
					</span>
				</span>
				<span style={legendItem}>
					<span
						style={`display: inline-block; flex: 0 0 auto; width: 16px; height: 16px; margin: 0; border-radius: 5px; background: ${RED_BG}; border: 1.5px solid ${RED};`}
						aria-hidden="true"></span>
					<span style={legendText}>
						<span style={legendStrong(RED_INK)}>Build fails</span> &mdash; the rejected node
					</span>
				</span>
			</div>

			{/* the route tree — a cached parent illegally wrapping a dynamic child */}
			<div style={routeBox}>
				<span style={routePill}>app/invoices/page.tsx</span>

				{/* cached <Header/> PARENT */}
				<div
					style={node(
						TEAL_BG,
						TEAL,
						'gap: 9px; box-shadow: 0 0 0 1px rgba(13, 148, 136, 0.12);',
					)}
				>
					<span style={nodeName}>&lt;Header /&gt;</span>
					<span style={chip(TEAL_EDGE, SURFACE, TEAL_INK)}>
						<span style={dot(TEAL)} aria-hidden="true"></span>'use cache'
					</span>

					<span style={nestLabel}>
						<span aria-hidden="true">&darr;</span>nested child
					</span>

					{/* illegal dynamic child nested INSIDE the cached parent */}
					<div
						style={node(
							AMBER_BG,
							RED,
							'gap: 8px; border-width: 2px; box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.12);',
						)}
					>
						<span style={nodeName}>&lt;UserGreeting /&gt;</span>
						<span style={readsLine}>
							<span style={dot(AMBER)} aria-hidden="true"></span>await cookies()
						</span>
						<span style={errorBadge}>
							<span style={errorGlyph} aria-hidden="true">!</span>build fails
						</span>
					</div>
				</div>
			</div>

			<p style={rejectNote}>
				A cached subtree includes its children, so request data <strong>cannot</strong> live inside it.
				The framework <span style={rejectStrong(RED_INK)}>fails the build</span> &mdash; the fix is the
				left tab: lift <code
					style={`font-family: ${mono}; background: transparent; padding: 0; color: ${AMBER_INK};`}
					>await cookies()</code
				> out to a sibling with its own boundary.
			</p>
		</div>
	</TabbedItem>
</TabbedContent>
