---
// stale-after-write-timeline (diagram id: stale-after-write-timeline, Ch 032 L6).
//
// The keystone motivator for the lesson: the student must SEE the stale cached
// entry sitting there, watch it serve the pre-edit snapshot (the bug), and then
// watch the moment it gets struck by `updateTag` and the user reads their own
// write (the fix). Built as a DiagramSequence (self-carding — NOT wrapped in
// <Figure>) of five scrubbable steps with per-step captions.
//
// Composition: one persistent left-to-right rail of the SAME five stages drawn
// every step, so the slider scrubs a single machine and the eye keeps its place
// (the chapter's column-aligned house style, cf. L2 build-vs-request-strip):
//
//   [ Save form ] -> [ save handler ] -> [ database ] -> [ cached list ] -> [ rendered list ]
//
// Per step we light the active stage(s) and dim the rest; the focal node walks
// rightward 1..5. Step 5 (the fix) inserts a green `updateTag(...)` badge on the
// handler->cache arrow, strikes the previously-blue cached box (drawn dissolving
// in green), and flips the rendered list from `#42 draft` to `#42 sent`.
//
// Colour convention carried from this chapter (L1-L4): BLUE = cached / stale
// entry; plus the lesson's own additions — GREEN = the strike + fresh read,
// RED = the "did the save even work?" alarm. Neutral slate for inert chrome.
//
// House style (cf. KeyComposition, build-vs-request-strip): pinned
// `color-scheme: light` so the hand-picked tints survive dark mode; inline style
// strings (no <style> block); `box-sizing: border-box`; `margin: 0` on every
// inner node to defeat Starlight's injected prose margins. Every step reserves
// the same callout row height so the grid-stacked panels never change height.

import DiagramSequence from '../../../figures/diagram-sequence/DiagramSequence.astro';
import DiagramStep from '../../../figures/diagram-sequence/DiagramStep.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ------------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';
const BORDER = '#cbd5e1'; // slate-300 — inert edge
const PANEL_BG = '#f8fafc'; // slate-50 — inert wash

const BLUE = '#2563eb'; // blue-600 — cached / stale (chapter-wide)
const BLUE_BG = '#eff6ff'; // blue-50
const BLUE_INK = '#1e40af'; // blue-800

const GREEN = '#16a34a'; // green-600 — the strike + fresh read
const GREEN_BG = '#f0fdf4'; // green-50
const GREEN_INK = '#15803d'; // green-700

const RED = '#dc2626'; // red-600 — the alarm
const RED_BG = '#fef2f2'; // red-50
const RED_INK = '#b91c1c'; // red-700

// ---- shared atoms ----------------------------------------------------------
// Stage: pinned light, slate ink. Vertical: the rail, then a fixed-height
// callout row reserved on every step so panels stack without height jumps.
const stage = `display: flex; flex-direction: column; align-items: stretch; gap: 0; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The rail: five stage boxes with arrow connectors between them, wrapping to a
// column on a narrow card. align-items:stretch keeps boxes equal-height per row.
const rail = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 4px; margin: 0;`;

// A stage box. `state`: 'idle' | 'lit' | 'blue' | 'green' | 'red'. Idle boxes
// are dimmed so the active node(s) pop; lit is the neutral active fill.
type State = 'idle' | 'lit' | 'blue' | 'green' | 'red';
const stageBox = (state: State) => {
	const map: Record<State, { edge: string; bg: string; op: string; ring: string }> = {
		idle: { edge: BORDER, bg: PANEL_BG, op: '0.5', ring: 'none' },
		lit: { edge: INK_SOFT, bg: SURFACE, op: '1', ring: 'none' },
		blue: { edge: BLUE, bg: BLUE_BG, op: '1', ring: `0 0 0 3px ${BLUE_BG}` },
		green: { edge: GREEN, bg: GREEN_BG, op: '1', ring: `0 0 0 3px ${GREEN_BG}` },
		red: { edge: RED, bg: RED_BG, op: '1', ring: `0 0 0 3px ${RED_BG}` },
	};
	const s = map[state];
	return `box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; gap: 5px; width: 112px; min-height: 88px; margin: 0; padding: 9px 10px; border: 1.5px solid ${s.edge}; border-radius: 11px; background: ${s.bg}; opacity: ${s.op}; box-shadow: ${s.ring}; transition: none;`;
};

const boxEyebrow = (c: string) =>
	`margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; line-height: 1.2; color: ${c};`;
const boxTitle = (c: string) =>
	`margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 800; line-height: 1.25; color: ${c};`;
const boxCode = (c: string) =>
	`margin: 0; font-family: ${mono}; font-size: 11px; font-weight: 700; line-height: 1.3; color: ${c}; word-break: break-word;`;

// A mock invoice row inside the database / cached / rendered boxes. `tone`
// drives the status pill; `struck` draws the whole row dissolving (the strike).
const rowChip = (struck: boolean) =>
	`box-sizing: border-box; display: inline-flex; align-items: center; gap: 6px; margin: 0; padding: 3px 7px; border-radius: 7px; border: 1px solid ${struck ? GREEN : BORDER}; background: ${SURFACE};${
		struck ? ' opacity: 0.55;' : ''
	}`;
const rowId = (struck: boolean) =>
	`margin: 0; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.2; color: ${INK};${
		struck ? ` text-decoration: line-through; text-decoration-color: ${GREEN};` : ''
	}`;
const statusPill = (tone: 'draft' | 'sent', struck: boolean) => {
	const edge = tone === 'sent' ? GREEN : INK_SOFT;
	const fg = tone === 'sent' ? GREEN_INK : INK_SOFT;
	const bg = tone === 'sent' ? GREEN_BG : PANEL_BG;
	return `display: inline-flex; align-items: center; margin: 0; padding: 0 6px; border-radius: 999px; border: 1px solid ${edge}; background: ${bg}; color: ${fg}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.5;${
		struck ? ' text-decoration: line-through;' : ''
	}`;
};

// A connector cell between two stage boxes: an arrow glyph, optionally carrying
// a flip label (draft->sent) or the green updateTag badge (step 5).
const connector = `display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; align-self: center; margin: 0; min-width: 26px;`;
const arrowGlyph = (c: string) =>
	`margin: 0; font-size: 20px; font-weight: 900; line-height: 0.7; color: ${c};`;
const connLabel = (c: string) =>
	`margin: 0; font-family: ${mono}; font-size: 9px; font-weight: 700; line-height: 1.2; text-align: center; white-space: nowrap; color: ${c};`;

// The green `updateTag(...)` badge that slots onto the handler->cache arrow in
// step 5. Reserved (invisible) on steps 1-4 so the connector width is stable.
const tagBadge = (on: boolean) =>
	`box-sizing: border-box; display: inline-flex; align-items: center; margin: 0; padding: 2px 7px; border-radius: 999px; border: 1.5px solid ${GREEN}; background: ${GREEN_BG}; color: ${GREEN_INK}; font-family: ${mono}; font-size: 9.5px; font-weight: 800; line-height: 1.4; white-space: nowrap; visibility: ${
		on ? 'visible' : 'hidden'
	};`;

// The callout bubble row, reserved at a fixed min-height on every step so the
// grid-stacked panels never change height as the reader scrubs.
const calloutRow = `display: flex; align-items: flex-start; justify-content: center; min-height: 40px; margin: 14px 0 0;`;
const callout = (tone: 'red' | 'green') => {
	const edge = tone === 'red' ? RED : GREEN;
	const bg = tone === 'red' ? RED_BG : GREEN_BG;
	const fg = tone === 'red' ? RED_INK : GREEN_INK;
	return `box-sizing: border-box; display: inline-flex; align-items: center; gap: 8px; max-width: 100%; margin: 0; padding: 7px 13px; border: 1.5px solid ${edge}; border-radius: 999px; background: ${bg}; color: ${fg}; font-family: ${sans}; font-size: 12px; font-weight: 700; line-height: 1.35;`;
};
const calloutDot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 8px; height: 8px; margin: 0; border-radius: 50%; background: ${c};`;
---

<DiagramSequence>
	{/* ============ STEP 1 — the user submits the edit form ============ */}
	<DiagramStep caption="The user submits the edit form. The save handler runs on the server.">
		<div style={stage}>
			<div style={rail}>
				{/* Save form — focal */}
				<div style={stageBox('blue')}>
					<p style={boxEyebrow(BLUE_INK)}>user</p>
					<p style={boxTitle(BLUE_INK)}>Save invoice #42</p>
					<p style={boxCode(BLUE_INK)}>draft &rarr; sent</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BLUE)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(INK_SOFT)}>submit</span>
				</div>
				{/* save handler — lit */}
				<div style={stageBox('lit')}>
					<p style={boxEyebrow(INK_SOFT)}>server</p>
					<p style={boxTitle(INK)}>save handler</p>
					<p style={boxCode(INK_SOFT)}>running&hellip;</p>
				</div>
				<div style={connector}>
					<span style={tagBadge(false)}>updateTag</span>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* database — idle */}
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>database</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* cached list entry — idle */}
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>cached list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* rendered list — idle */}
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>rendered list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
				</div>
			</div>
			<div style={calloutRow}></div>
		</div>
	</DiagramStep>

	{/* ============ STEP 2 — the handler writes the row ============ */}
	<DiagramStep caption="The handler writes the row. In the database, invoice #42 flips from draft to sent.">
		<div style={stage}>
			<div style={rail}>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>user</p>
					<p style={boxTitle(INK)}>Save invoice #42</p>
					<p style={boxCode(INK_SOFT)}>draft &rarr; sent</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* save handler — lit */}
				<div style={stageBox('lit')}>
					<p style={boxEyebrow(INK_SOFT)}>server</p>
					<p style={boxTitle(INK)}>save handler</p>
					<p style={boxCode(INK_SOFT)}>writes row</p>
				</div>
				<div style={connector}>
					<span style={tagBadge(false)}>updateTag</span>
					<span style={arrowGlyph(GREEN)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(GREEN_INK)}>write</span>
				</div>
				{/* database — focal green flip */}
				<div style={stageBox('green')}>
					<p style={boxEyebrow(GREEN_INK)}>database</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('sent', false)}>sent</span>
					</div>
					<p style={connLabel(GREEN_INK)}>draft &rarr; sent</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* cached list entry — idle, still stale */}
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>cached list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>rendered list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
				</div>
			</div>
			<div style={calloutRow}></div>
		</div>
	</DiagramStep>

	{/* ============ STEP 3 — redirect hits the cached entry ============ */}
	<DiagramStep caption="The handler redirects to /invoices. That page is a cached read, so it serves the entry it stored before the edit.">
		<div style={stage}>
			<div style={rail}>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>user</p>
					<p style={boxTitle(INK)}>Save invoice #42</p>
					<p style={boxCode(INK_SOFT)}>draft &rarr; sent</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* save handler — lit, redirecting */}
				<div style={stageBox('lit')}>
					<p style={boxEyebrow(INK_SOFT)}>server</p>
					<p style={boxTitle(INK)}>save handler</p>
					<p style={boxCode(INK_SOFT)}>redirect('/invoices')</p>
				</div>
				<div style={connector}>
					<span style={tagBadge(false)}>updateTag</span>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* database — written, settled */}
				<div style={stageBox('lit')}>
					<p style={boxEyebrow(INK_SOFT)}>database</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('sent', false)}>sent</span>
					</div>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BLUE)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(BLUE_INK)}>serves</span>
				</div>
				{/* cached list entry — FOCAL blue, stored before the edit */}
				<div style={stageBox('blue')}>
					<p style={boxEyebrow(BLUE_INK)}>cached list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
					<p style={connLabel(BLUE_INK)}>stored before edit</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BLUE)} aria-hidden="true">&rarr;</span>
				</div>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>rendered list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
				</div>
			</div>
			<div style={calloutRow}></div>
		</div>
	</DiagramStep>

	{/* ============ STEP 4 — THE BUG: user sees the old row ============ */}
	<DiagramStep caption="The user lands on the list and sees #42 still as a draft. The save looks like it failed.">
		<div style={stage}>
			<div style={rail}>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>user</p>
					<p style={boxTitle(INK)}>Save invoice #42</p>
					<p style={boxCode(INK_SOFT)}>draft &rarr; sent</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>server</p>
					<p style={boxTitle(INK)}>save handler</p>
					<p style={boxCode(INK_SOFT)}>redirect('/invoices')</p>
				</div>
				<div style={connector}>
					<span style={tagBadge(false)}>updateTag</span>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>database</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('sent', false)}>sent</span>
					</div>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BLUE)} aria-hidden="true">&rarr;</span>
				</div>
				{/* cached list entry — still the stale blue source */}
				<div style={stageBox('blue')}>
					<p style={boxEyebrow(BLUE_INK)}>cached list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(RED)} aria-hidden="true">&rarr;</span>
				</div>
				{/* rendered list — FOCAL red: shows the stale draft */}
				<div style={stageBox('red')}>
					<p style={boxEyebrow(RED_INK)}>rendered list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('draft', false)}>draft</span>
					</div>
					<p style={connLabel(RED_INK)}>stale!</p>
				</div>
			</div>
			<div style={calloutRow}>
				<span style={callout('red')}>
					<span style={calloutDot(RED)} aria-hidden="true"></span>
					"did the save even work?"
				</span>
			</div>
		</div>
	</DiagramStep>

	{/* ============ STEP 5 — THE FIX: updateTag strikes the entry ============ */}
	<DiagramStep caption="Now the handler calls updateTag(invoiceTags.list(orgId)) before the redirect. The stale entry is struck, the list re-renders fresh, and the user sees #42 as sent — they read their own write.">
		<div style={stage}>
			<div style={rail}>
				<div style={stageBox('idle')}>
					<p style={boxEyebrow(INK_SOFT)}>user</p>
					<p style={boxTitle(INK)}>Save invoice #42</p>
					<p style={boxCode(INK_SOFT)}>draft &rarr; sent</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(BORDER)} aria-hidden="true">&rarr;</span>
				</div>
				{/* save handler — settled */}
				<div style={stageBox('lit')}>
					<p style={boxEyebrow(INK_SOFT)}>server</p>
					<p style={boxTitle(INK)}>save handler</p>
					<p style={boxCode(INK_SOFT)}>redirect('/invoices')</p>
				</div>
				{/* handler -> cache arrow now carries the green updateTag badge */}
				<div style={connector}>
					<span style={tagBadge(true)}>updateTag(&hellip;)</span>
					<span style={arrowGlyph(GREEN)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(GREEN_INK)}>strikes</span>
				</div>
				<div style={stageBox('lit')}>
					<p style={boxEyebrow(INK_SOFT)}>database</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('sent', false)}>sent</span>
					</div>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(GREEN)} aria-hidden="true">&rarr;</span>
					<span style={connLabel(GREEN_INK)}>refetch</span>
				</div>
				{/* cached list entry — struck: dissolving green, old row crossed out */}
				<div style={stageBox('green')}>
					<p style={boxEyebrow(GREEN_INK)}>cached list</p>
					<div style={rowChip(true)}>
						<span style={rowId(true)}>#42</span>
						<span style={statusPill('draft', true)}>draft</span>
					</div>
					<p style={connLabel(GREEN_INK)}>struck &mdash; stale</p>
				</div>
				<div style={connector}>
					<span style={arrowGlyph(GREEN)} aria-hidden="true">&rarr;</span>
				</div>
				{/* rendered list — FOCAL green: fresh, shows sent */}
				<div style={stageBox('green')}>
					<p style={boxEyebrow(GREEN_INK)}>rendered list</p>
					<div style={rowChip(false)}>
						<span style={rowId(false)}>#42</span>
						<span style={statusPill('sent', false)}>sent</span>
					</div>
					<p style={connLabel(GREEN_INK)}>fresh</p>
				</div>
			</div>
			<div style={calloutRow}>
				<span style={callout('green')}>
					<span style={calloutDot(GREEN)} aria-hidden="true"></span>
					read-your-writes
				</span>
			</div>
		</div>
	</DiagramStep>
</DiagramSequence>
