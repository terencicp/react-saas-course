---
// Two cache layers (diagram id: two-cache-layers, Chapter 032 L5). The keystone
// of the lesson: cache() and 'use cache' are different SCOPES, not rival
// strategies. The whole figure is built to be read as "one shared box" up top
// versus "two isolated, throwaway boxes" down below.
//
//   TOP LANE "Cross-request — 'use cache'" (BLUE, the chapter-wide cached
//     colour): two request chips on the left (Request A · user 1, Request B ·
//     user 2) BOTH arrow into ONE central store box ("cache entry, keyed by
//     args + source"). A writes it, the next request reads it — one box, shared.
//     Caption strip: survives across requests, shared across users.
//   BOTTOM LANE "Per-request — cache()" (VIOLET, distinct layer): two separate
//     swim-lanes side by side. Request A holds three call sites (layout, page,
//     nav) all pointing at ONE small dotted memo box that lives INSIDE A's lane
//     and is marked "discarded when render ends". Request B has its OWN separate
//     dotted memo box. A dashed divider between the lanes carries a "no sharing
//     between requests" note so the eye sees that no arrow ever crosses.
//
// Colour convention is load-bearing: BLUE = cross-request store (lifted verbatim
// from this chapter's L3 KeyComposition so cached reads continuously across the
// chapter), VIOLET = per-request memo (a deliberately different layer so the two
// don't read as the same thing). Orange is reserved chapter-wide for dynamic
// holes and is NOT used here.
//
// House style follows the chapter family (L3 KeyComposition / L2
// build-vs-request-strip): pinned `color-scheme: light` so the hand-picked tints
// survive dark mode, `margin: 0` on every inner element to defeat Starlight's
// injected prose margins, inline style strings only (no <style> block),
// box-sizing: border-box throughout. Wrapped in <Figure> per the diagram index.

import Figure from '../../../figures/Figure.astro';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// ---- palette (pinned light) ----------------------------------------------
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — secondary text
const SURFACE = '#ffffff';
const BORDER = '#cbd5e1'; // slate-300 — ordinary edge
const PANEL_BG = '#f8fafc'; // slate-50 — neutral lane wash
const CHIP_BG = '#f1f5f9'; // slate-100 — request chip fill

// CROSS-REQUEST — blue (chapter-wide cached colour).
const BLUE = '#2563eb'; // blue-600
const BLUE_BG = '#eff6ff'; // blue-50 wash
const BLUE_EDGE = '#93c5fd'; // blue-300
const BLUE_INK = '#1e40af'; // blue-800

// PER-REQUEST — violet (a distinct layer).
const VIO = '#7c3aed'; // violet-600
const VIO_BG = '#f5f3ff'; // violet-50 wash
const VIO_EDGE = '#c4b5fd'; // violet-300
const VIO_INK = '#5b21b6'; // violet-800

// ---- shared atoms ---------------------------------------------------------
const stage = `display: flex; flex-direction: column; gap: 16px; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// A lane is a bordered region with a "fieldset legend" pill straddling its top
// border. accent picks the layer colour for the legend + frame tint.
const lane = (edge: string) =>
	`box-sizing: border-box; position: relative; margin: 0; padding: 24px 16px 14px; border: 1.5px solid ${edge}; border-radius: 14px; background: ${PANEL_BG};`;
const legend = (accent: string, accentBg: string, ink: string) =>
	`display: block; width: fit-content; margin: -34px 0 0; padding: 4px 12px; border-radius: 999px; border: 1.5px solid ${accent}; background: ${accentBg}; color: ${ink}; font-family: ${sans}; font-size: 11.5px; font-weight: 800; letter-spacing: 0.01em; line-height: 1.3;`;
const legendCode = (ink: string) =>
	`font-family: ${mono}; font-weight: 800; color: ${ink};`;

// The body row of a lane (content + connectors).
const row = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; column-gap: 12px; row-gap: 14px; margin: 18px 0 0;`;

// A request chip (the actor on the left of each lane).
const reqChip = (accent: string, ink: string) =>
	`box-sizing: border-box; display: flex; flex-direction: column; align-items: flex-start; gap: 1px; margin: 0; padding: 8px 12px; border-radius: 10px; border: 1.5px solid ${accent}; background: ${SURFACE}; min-width: 132px;`;
const reqName = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 800; line-height: 1.2; color: ${ink};`;
const reqWho = `margin: 0; font-family: ${sans}; font-size: 10.5px; font-weight: 600; line-height: 1.25; color: ${INK_SOFT};`;

// Connector arrow with an optional micro-label above it.
const connector = `display: flex; flex-direction: column; align-items: center; gap: 2px; margin: 0;`;
const connectorText = `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: ${INK_SOFT}; white-space: nowrap;`;
const arrowGlyph = `margin: 0; font-size: 20px; font-weight: 800; line-height: 1; color: ${INK_SOFT};`;

// The caption strip under each lane.
const strip = (accent: string, accentBg: string, ink: string) =>
	`box-sizing: border-box; display: flex; align-items: center; gap: 8px; margin: 14px 0 0; padding: 7px 12px; border-radius: 9px; border: 1px solid ${accent}; background: ${accentBg}; color: ${ink}; font-family: ${sans}; font-size: 11.5px; font-weight: 600; line-height: 1.35;`;
const stripDot = (c: string) =>
	`display: inline-block; flex: 0 0 auto; width: 8px; height: 8px; margin: 0; border-radius: 999px; background: ${c};`;

// ---- top lane: the one shared store box -----------------------------------
const storeBox = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 5px; margin: 0; padding: 14px 18px; border-radius: 12px; border: 2px solid ${BLUE}; background: ${BLUE_BG}; min-width: 220px;`;
const storeTitle = `margin: 0; font-family: ${sans}; font-size: 12.5px; font-weight: 800; line-height: 1.2; color: ${BLUE_INK};`;
const storeKey = `margin: 0; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.25; color: ${BLUE}; text-align: center;`;
const storeTag = `margin: 4px 0 0; padding: 1px 9px; border-radius: 999px; border: 1px solid ${BLUE}; background: ${SURFACE}; color: ${BLUE_INK}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.4; white-space: nowrap;`;

// the two stacked request chips on the left of the top lane
const reqStack = `display: flex; flex-direction: column; gap: 9px; margin: 0;`;

// ---- bottom lane: two isolated swim-lanes ---------------------------------
const subLanes = `display: flex; flex-wrap: wrap; align-items: stretch; justify-content: center; gap: 0; margin: 18px 0 0; width: 100%;`;
const subLane = `box-sizing: border-box; flex: 1 1 280px; display: flex; flex-direction: column; align-items: center; gap: 9px; margin: 0; padding: 12px 14px; border: 1.5px dashed ${VIO_EDGE}; border-radius: 12px; background: ${VIO_BG}; min-width: 248px;`;
const subLaneHead = `margin: 0 0 2px; font-family: ${sans}; font-size: 11.5px; font-weight: 800; line-height: 1.2; color: ${VIO_INK};`;

// the three call-site chips, laid in a row inside each sub-lane
const callRow = `display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 6px; margin: 0;`;
const callChip = `box-sizing: border-box; margin: 0; padding: 4px 9px; border-radius: 7px; border: 1px solid ${VIO_EDGE}; background: ${SURFACE}; color: ${VIO_INK}; font-family: ${mono}; font-size: 10.5px; font-weight: 700; line-height: 1.25; white-space: nowrap;`;

// the in-render memo box (dotted, throwaway)
const memoBox = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; gap: 4px; margin: 0; padding: 9px 14px; border-radius: 10px; border: 2px dotted ${VIO}; background: ${SURFACE}; min-width: 188px;`;
const memoTitle = `margin: 0; font-family: ${sans}; font-size: 11.5px; font-weight: 800; line-height: 1.2; color: ${VIO_INK};`;
const memoSub = `margin: 0; font-family: ${mono}; font-size: 9.5px; font-weight: 700; line-height: 1.2; color: ${VIO};`;
const discardTag = `display: inline-flex; align-items: center; gap: 5px; margin: 3px 0 0; padding: 1px 9px; border-radius: 999px; border: 1px dashed ${VIO}; background: ${VIO_BG}; color: ${VIO_INK}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.45; white-space: nowrap;`;

// the divider between the two sub-lanes carrying the "no sharing" note
const divider = `box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; flex: 0 0 auto; margin: 0; padding: 0 8px; align-self: center;`;
const dividerRule = `display: block; width: 0; flex: 1 1 auto; min-height: 18px; margin: 0; border-left: 2px dashed ${BORDER};`;
const noCross = `box-sizing: border-box; margin: 0; padding: 4px 8px; border-radius: 999px; border: 1px solid ${BORDER}; background: ${SURFACE}; color: ${INK_SOFT}; font-family: ${sans}; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.3; text-align: center; white-space: nowrap;`;
---

<Figure
	caption="Two layers, two lifetimes. 'use cache' writes one entry that any later request can read — shared across users. cache() spins up a throwaway memo inside a single render; a second request gets its own, and nothing ever crosses between them."
	expandable={true}
>
	<div style={stage}>
		{/* ============ TOP LANE — cross-request, blue ============ */}
		<section style={lane(BLUE_EDGE)}>
			<span style={legend(BLUE, BLUE_BG, BLUE_INK)}>
				Cross-request &mdash; <span style={legendCode(BLUE_INK)}>'use cache'</span>
			</span>
			<div style={row}>
				{/* two requests on the left */}
				<div style={reqStack}>
					<div style={reqChip(BLUE, BLUE_INK)}>
						<p style={reqName(BLUE_INK)}>Request A</p>
						<p style={reqWho}>user 1</p>
					</div>
					<div style={reqChip(BLUE, BLUE_INK)}>
						<p style={reqName(BLUE_INK)}>Request B</p>
						<p style={reqWho}>user 2 &middot; seconds later</p>
					</div>
				</div>

				{/* both point at ONE box */}
				<div style={connector}>
					<span style={connectorText}>A writes &middot; B reads</span>
					<span style={arrowGlyph} aria-hidden="true">&rarr;</span>
				</div>

				{/* the single shared store */}
				<div style={storeBox}>
					<p style={storeTitle}>cache entry</p>
					<p style={storeKey}>keyed by args + source</p>
					<span style={storeTag}>one box, shared</span>
				</div>
			</div>
			<div style={strip(BLUE_EDGE, BLUE_BG, BLUE_INK)}>
				<span style={stripDot(BLUE)} aria-hidden="true"></span>
				<span>Survives across requests. Shared across users until it expires or is invalidated.</span>
			</div>
		</section>

		{/* ============ BOTTOM LANE — per-request, violet ============ */}
		<section style={lane(VIO_EDGE)}>
			<span style={legend(VIO, VIO_BG, VIO_INK)}>
				Per-request &mdash; <span style={legendCode(VIO_INK)}>cache()</span>
			</span>
			<div style={subLanes}>
				{/* ---- Request A's own render ---- */}
				<div style={subLane}>
					<p style={subLaneHead}>Request A &middot; one render</p>
					<div style={callRow}>
						<span style={callChip}>layout</span>
						<span style={callChip}>page</span>
						<span style={callChip}>nav</span>
					</div>
					<span style={arrowGlyph} aria-hidden="true">&darr;</span>
					<div style={memoBox}>
						<p style={memoTitle}>in-render memo</p>
						<p style={memoSub}>runs once, all three share it</p>
						<span style={discardTag}>discarded when render ends</span>
					</div>
				</div>

				{/* ---- the gap: nothing crosses ---- */}
				<div style={divider}>
					<span style={dividerRule} aria-hidden="true"></span>
					<span style={noCross}>no sharing<br />between requests</span>
					<span style={dividerRule} aria-hidden="true"></span>
				</div>

				{/* ---- Request B's own render ---- */}
				<div style={subLane}>
					<p style={subLaneHead}>Request B &middot; its own render</p>
					<div style={callRow}>
						<span style={callChip}>layout</span>
						<span style={callChip}>page</span>
						<span style={callChip}>nav</span>
					</div>
					<span style={arrowGlyph} aria-hidden="true">&darr;</span>
					<div style={memoBox}>
						<p style={memoTitle}>its own fresh memo</p>
						<p style={memoSub}>separate, runs again</p>
						<span style={discardTag}>discarded when render ends</span>
					</div>
				</div>
			</div>
			<div style={strip(VIO_EDGE, VIO_BG, VIO_INK)}>
				<span style={stripDot(VIO)} aria-hidden="true"></span>
				<span>Born and dies inside one render. Never shared between requests.</span>
			</div>
		</section>
	</div>
</Figure>
