---
// PresetTable — the cacheLife preset reference (Chapter 032 L4, "Lifetimes and
// tags"). A compact three-column table: the preset name, the user-facing
// freshness it buys, and the data-shape you reach for it with. Raw second-counts
// are deliberately kept OUT — the whole point of the section is matching a
// *shape of data* to a preset, not memorising arithmetic.
//
// Encoding:
//   - One row per preset, ordered shortest -> longest lifetime, so the column
//     reads as a freshness spectrum top-to-bottom: near-real-time at the top,
//     effectively-stable at the bottom.
//   - A per-row accent (preset token colour + left bar + faint row tint) ramps
//     from GREEN (refreshes constantly / freshest) up to the chapter's BLUE
//     (cached / stable) so the spectrum is visible at a glance.
//   - `'max'` is the row the prose tells the student to watch: it carries the
//     chapter's cached BLUE and an emphasis ring, because it's the production
//     default for business data (paired with tags).
//   - `default` is set apart in neutral GREY — it's "what a bare 'use cache'
//     gets", the fallback the student didn't choose, not a row on the spectrum.
//
// Pure HTML + CSS, devtools-inspectable. A real CSS grid drives the layout
// (`display: contents` rows over a 3-track grid), collapsing to stacked cards
// on narrow viewports. `margin: 0` reset on every inner element defeats
// Starlight's injected prose margins. Accent fills use color-mix over the
// accent var so they stay legible in both light and dark themes; chrome
// (header, dividers, body text) leans on Starlight CSS variables so it flips
// with the theme.

// Freshness ramp: green (freshest, refreshes constantly) -> teal -> blue
// (cached / stable). `max` reuses the chapter's cached blue; `default` is grey.
const ACCENT = {
	seconds: '#16a34a', // green-600  — near-real-time
	minutes: '#0d9488', // teal-600   — lags a little
	hours: '#0891b2', // cyan-600   — several updates a day
	days: '#2563eb', // blue-600   — one update a day
	weeks: '#4f46e5', // indigo-600 — weekly cadence
	max: '#2563eb', // blue-600   — chapter cached colour (the watch row)
	default: '#64748b', // slate-500  — the unchosen fallback
};

type Accent = keyof typeof ACCENT;

type Row = {
	preset: string;
	sees: string;
	reach: string;
	accent: Accent;
	// The production-default row the prose tells the student to watch.
	emphasis?: boolean;
	// The "what a bare directive gets" fallback — rendered set-apart in grey.
	muted?: boolean;
};

const rows: Row[] = [
	{
		preset: "'seconds'",
		sees: 'Near-real-time — refreshes constantly.',
		reach: 'a live metric or status that must track reality second by second.',
		accent: 'seconds',
	},
	{
		preset: "'minutes'",
		sees: 'Can lag a little.',
		reach: "a feed, a news list, a dashboard metric that's fine a few minutes behind.",
		accent: 'minutes',
	},
	{
		preset: "'hours'",
		sees: 'Several updates a day.',
		reach: 'inventory or stock levels that change through the day.',
		accent: 'hours',
	},
	{
		preset: "'days'",
		sees: 'One update a day.',
		reach: 'a blog post, a marketing or pricing page.',
		accent: 'days',
	},
	{
		preset: "'weeks'",
		sees: 'A weekly cadence.',
		reach: 'a newsletter archive, a weekly digest.',
		accent: 'weeks',
	},
	{
		preset: "'max'",
		sees: 'Effectively stable.',
		reach: 'a product catalog, CMS content, settings — anything you invalidate explicitly with a tag.',
		accent: 'max',
		emphasis: true,
	},
	{
		preset: 'default',
		sees: "What a bare 'use cache' gets.",
		reach: 'a background refresh on a roughly 15-minute clock; never hard-expires.',
		accent: 'default',
		muted: true,
	},
];

---

<div
	class="pt-root not-content"
	style={Object.entries(ACCENT)
		.map(([k, v]) => `--pt-${k}: ${v};`)
		.join(' ')}
>
	<div class="pt-row pt-header">
		<div class="pt-cell pt-head-cell">Preset</div>
		<div class="pt-cell pt-head-cell">The user sees…</div>
		<div class="pt-cell pt-head-cell">Reach for it when…</div>
	</div>

	{
		rows.map((r) => (
			<div
				class={`pt-row pt-accent-${r.accent}${r.emphasis ? ' pt-emphasis' : ''}${r.muted ? ' pt-muted' : ''}`}
			>
				<div class="pt-cell pt-preset" data-label="Preset">
					<span class="pt-mono">{r.preset}</span>
					{r.emphasis && <span class="pt-tag">production default</span>}
				</div>
				<div class="pt-cell pt-sees" data-label="The user sees">
					{r.sees}
				</div>
				<div class="pt-cell pt-reach" data-label="Reach for it when">
					{r.reach}
				</div>
			</div>
		))
	}
</div>

<style>
	.pt-root {
		display: grid;
		grid-template-columns: max-content minmax(0, 1fr) minmax(0, 1.5fr);
		row-gap: 1px;
		column-gap: 0;
		padding: 0;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
	}

	.pt-row {
		display: contents;
	}

	.pt-cell {
		padding: 9px 14px;
		font-size: 13px;
		line-height: 1.45;
		color: var(--sl-color-text);
		margin: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background: color-mix(in srgb, var(--pt-row-accent) 6%, transparent);
	}

	.pt-head-cell {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--sl-color-gray-2);
		padding-top: 8px;
		padding-bottom: 8px;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}

	.pt-preset {
		flex-direction: row;
		align-items: center;
		gap: 10px;
		white-space: nowrap;
		border-left: 3px solid
			color-mix(in srgb, var(--pt-row-accent) 70%, transparent);
	}

	.pt-mono {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 13px;
		font-weight: 600;
		color: color-mix(in srgb, var(--pt-row-accent) 78%, var(--sl-color-text));
		white-space: nowrap;
		margin: 0;
	}

	.pt-tag {
		font-size: 9.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		line-height: 1;
		margin: 0;
		padding: 3px 7px;
		border-radius: 999px;
		white-space: nowrap;
		color: #ffffff;
		background: var(--pt-row-accent);
	}

	/* Per-row accent var assignment — feeds the cell tint, left bar, token. */
	.pt-accent-seconds {
		--pt-row-accent: var(--pt-seconds);
	}
	.pt-accent-minutes {
		--pt-row-accent: var(--pt-minutes);
	}
	.pt-accent-hours {
		--pt-row-accent: var(--pt-hours);
	}
	.pt-accent-days {
		--pt-row-accent: var(--pt-days);
	}
	.pt-accent-weeks {
		--pt-row-accent: var(--pt-weeks);
	}
	.pt-accent-max {
		--pt-row-accent: var(--pt-max);
	}
	.pt-accent-default {
		--pt-row-accent: var(--pt-default);
	}

	/* The watch row: lift the tint and ring the whole row. */
	.pt-emphasis .pt-cell {
		background: color-mix(in srgb, var(--pt-row-accent) 13%, transparent);
	}
	.pt-emphasis .pt-preset {
		box-shadow: inset 3px 0 0 var(--pt-row-accent);
		border-left-color: var(--pt-row-accent);
	}
	.pt-emphasis .pt-cell:first-child {
		border-top-left-radius: 8px;
		border-bottom-left-radius: 8px;
	}
	.pt-emphasis .pt-cell:last-child {
		border-top-right-radius: 8px;
		border-bottom-right-radius: 8px;
	}

	/* The fallback row: visually demote it — muted token, dotted top divider. */
	.pt-muted {
		margin-top: 2px;
	}
	.pt-muted .pt-cell {
		background: color-mix(in srgb, var(--pt-row-accent) 4%, transparent);
		border-top: 1px dashed color-mix(in srgb, var(--pt-row-accent) 35%, transparent);
	}
	.pt-muted .pt-mono {
		font-style: italic;
		color: var(--sl-color-gray-2);
	}
	.pt-muted .pt-preset {
		border-left-style: dashed;
	}

	/* Narrow viewport: collapse to a stacked card per preset. */
	@media (max-width: 720px) {
		.pt-root {
			grid-template-columns: 1fr;
			row-gap: 12px;
		}

		.pt-row.pt-header {
			display: none;
		}

		.pt-row {
			display: block;
			padding: 10px 12px;
			border-radius: 8px;
			margin: 0;
			background: color-mix(in srgb, var(--pt-row-accent) 7%, transparent);
			border-left: 3px solid
				color-mix(in srgb, var(--pt-row-accent) 65%, transparent);
		}

		.pt-emphasis {
			background: color-mix(in srgb, var(--pt-row-accent) 14%, transparent);
			border-left-color: var(--pt-row-accent);
		}

		.pt-muted {
			border-left-style: dashed;
		}

		.pt-cell {
			background: transparent !important;
			border-left: none !important;
			box-shadow: none !important;
			border-top: none !important;
			border-radius: 0 !important;
			padding: 3px 0;
			flex-direction: row;
			align-items: baseline;
			gap: 6px;
		}

		.pt-sees::before,
		.pt-reach::before {
			content: attr(data-label) ' — ';
			font-size: 10.5px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--sl-color-gray-3);
			flex-shrink: 0;
		}

		.pt-preset {
			padding-top: 0;
			padding-bottom: 4px;
		}
	}
</style>
