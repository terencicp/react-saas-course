---
// TimeoutVsPush — the conceptual hinge of Chapter 032 L4 ("Lifetimes and
// tags"): a cached entry has exactly TWO independent ways to become fresh
// again, and students conflate them constantly. This figure separates them
// side by side, then unites them in a footer band that IS the lesson's
// destination shape (`cacheLife('max')` + tags).
//
// Encoding:
//   - Two columns, deliberately symmetric so the contrast reads as "two of the
//     same kind of thing" (orthogonal mechanisms), not "a choice between A and B".
//       LEFT  — Timeout / pull. A clock. AMBER, the chapter's clock-driven /
//               aging colour (verbatim from SwrStrip + L1/L2): the entry
//               refreshes on a schedule whether or not the data changed.
//       RIGHT — Push. A bolt. BLUE, the chapter's cached / on-change colour
//               (verbatim from L3 / SwrStrip): the entry refreshes exactly when
//               the source says so.
//   - Each column: an icon + title + a pull/push tag in the header, the API in
//     mono as the first body line, then three plain glosses (when it fires, what
//     triggers it, when to reach for it).
//   - A full-width FOOTER BAND in BLUE tint under both columns carries the
//     production pairing — "use both": the clock becomes a safety net, the tag
//     does the real work. This is the shape the lesson keeps promising.
//
// Pure HTML + CSS, inline style strings only (chapter house style). color-scheme
// pinned light so the hand-picked tints survive dark mode; margin:0 on every
// inner node to defeat Starlight's injected prose margins; box-sizing:border-box.

import { Icon } from 'astro-icon/components';

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette — slate ink + the chapter's AMBER (clock-driven / aging, verbatim
// from SwrStrip) for the timeout side, and the chapter's BLUE (cached /
// on-change, verbatim from L3 + SwrStrip) for the push side and the footer band.
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#475569'; // slate-600 — body gloss
const INK_FAINT = '#64748b'; // slate-500 — muted

const AMBER = '#d97706'; // amber-600 — clock / timeout accent
const AMBER_INK = '#b45309'; // amber-700 — timeout text
const AMBER_BG = '#fffbeb'; // amber-50  — timeout card wash
const AMBER_EDGE = '#fcd9a8'; // amber-200-ish — timeout border

const BLUE = '#2563eb'; // blue-600 — cached / push accent (chapter-wide)
const BLUE_INK = '#1e40af'; // blue-800 — push / footer text
const BLUE_BG = '#eff6ff'; // blue-50  — push card wash
const BLUE_BG2 = '#dbeafe'; // blue-100 — footer band wash (slightly deeper)
const BLUE_EDGE = '#bfdbfe'; // blue-200 — push / footer border

// ---- atoms -----------------------------------------------------------------

const root = `display: flex; flex-direction: column; gap: 12px; margin: 0; padding: 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// The two columns. A CSS grid so they share an identical coordinate system and
// collapse to a single column on narrow viewports (handled in <style>).
const columns = 'tvp-columns';

// One mechanism card.
const card = (accent: string, bg: string, edge: string) =>
	`box-sizing: border-box; display: flex; flex-direction: column; gap: 0; margin: 0; padding: 14px 16px 15px; border-radius: 12px; background: ${bg}; border: 1.5px solid ${edge}; border-top: 4px solid ${accent};`;

// Header row: icon chip + title stack.
const header = `display: flex; align-items: center; gap: 11px; margin: 0;`;
const iconChip = (accent: string) =>
	`box-sizing: border-box; display: flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 34px; height: 34px; margin: 0; border-radius: 9px; background: #ffffff; border: 1.5px solid ${accent}; color: ${accent};`;
const titleStack = `display: flex; flex-direction: column; gap: 1px; margin: 0; min-width: 0;`;
const title = (ink: string) =>
	`margin: 0; font-family: ${sans}; font-size: 15px; font-weight: 800; line-height: 1.15; color: ${ink};`;
const kind = (accent: string) =>
	`margin: 0; font-family: ${sans}; font-size: 10px; font-weight: 800; line-height: 1.1; letter-spacing: 0.07em; text-transform: uppercase; color: ${accent};`;

// The API line, set in mono inside a faint pill so it reads as code.
const apiLine = (accent: string, bg: string) =>
	`box-sizing: border-box; align-self: flex-start; margin: 12px 0 0; padding: 4px 10px; border-radius: 7px; background: ${bg}; border: 1px solid color-mix(in srgb, ${accent} 30%, transparent); font-family: ${mono}; font-size: 12.5px; font-weight: 700; line-height: 1.2; color: ${accent}; white-space: nowrap; max-width: 100%; overflow: hidden; text-overflow: ellipsis;`;

// Body glosses: a tight list, each with a small accent tick.
const list = `display: flex; flex-direction: column; gap: 7px; margin: 12px 0 0; padding: 0; list-style: none;`;
const item = `display: flex; align-items: flex-start; gap: 8px; margin: 0; font-family: ${sans}; font-size: 12.5px; line-height: 1.35; color: ${INK_SOFT};`;
const tick = (accent: string) =>
	`flex: 0 0 auto; width: 5px; height: 5px; margin: 6px 0 0; border-radius: 50%; background: ${accent};`;
// The "when to reach for it" line gets a touch more weight — it's the takeaway.
const itemLead = (ink: string) => `font-weight: 700; color: ${ink};`;

// ---- the footer band: the production "use both" shape -----------------------
const band = `box-sizing: border-box; display: flex; align-items: center; gap: 13px; margin: 0; padding: 13px 16px; border-radius: 12px; background: ${BLUE_BG2}; border: 1.5px solid ${BLUE_EDGE};`;
const bandIcon = `box-sizing: border-box; display: flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 30px; height: 30px; margin: 0; border-radius: 8px; background: ${BLUE}; color: #ffffff;`;
const bandBody = `display: flex; flex-direction: column; gap: 2px; margin: 0; min-width: 0;`;
const bandTitle = `margin: 0; font-family: ${sans}; font-size: 13px; font-weight: 800; line-height: 1.3; color: ${BLUE_INK};`;
const bandSub = `margin: 0; font-family: ${sans}; font-size: 12px; font-weight: 600; line-height: 1.35; color: ${INK_FAINT};`;
// Inline mono inside the band copy.
const bandCode = `font-family: ${mono}; font-size: 12px; font-weight: 800; color: ${BLUE_INK};`;
---

<div class="not-content" style={root}>
	{/* ----- the two orthogonal mechanisms, side by side ----- */}
	<div class={columns}>
		{/* LEFT — timeout / pull (the clock) */}
		<div style={card(AMBER, AMBER_BG, AMBER_EDGE)}>
			<div style={header}>
				<span style={iconChip(AMBER)}>
					<Icon name="lucide:clock" size={19} />
				</span>
				<span style={titleStack}>
					<span style={title(AMBER_INK)}>Timeout</span>
					<span style={kind(AMBER)}>pull</span>
				</span>
			</div>

			<code style={apiLine(AMBER_INK, '#fff7ed')}>cacheLife</code>

			<ul style={list}>
				<li style={item}>
					<span style={tick(AMBER)}></span>
					<span style="margin: 0;">Refreshes on a clock</span>
				</li>
				<li style={item}>
					<span style={tick(AMBER)}></span>
					<span style="margin: 0;">Whether or not the data changed</span>
				</li>
				<li style={item}>
					<span style={tick(AMBER)}></span>
					<span style={`margin: 0; ${itemLead(AMBER_INK)}`}>
						Good when nothing tells you about changes
					</span>
				</li>
			</ul>
		</div>

		{/* RIGHT — push (the bolt) */}
		<div style={card(BLUE, BLUE_BG, BLUE_EDGE)}>
			<div style={header}>
				<span style={iconChip(BLUE)}>
					<Icon name="lucide:zap" size={19} />
				</span>
				<span style={titleStack}>
					<span style={title(BLUE_INK)}>Push</span>
					<span style={kind(BLUE)}>on change</span>
				</span>
			</div>

			<code style={apiLine(BLUE_INK, '#eff6ff')}>cacheTag + invalidation</code>

			<ul style={list}>
				<li style={item}>
					<span style={tick(BLUE)}></span>
					<span style="margin: 0;">Refreshes exactly when data changed</span>
				</li>
				<li style={item}>
					<span style={tick(BLUE)}></span>
					<span style="margin: 0;">Triggered by the mutation itself</span>
				</li>
				<li style={item}>
					<span style={tick(BLUE)}></span>
					<span style={`margin: 0; ${itemLead(BLUE_INK)}`}>
						Good when you own the change event
					</span>
				</li>
			</ul>
		</div>
	</div>

	{/* ----- the footer band: combine both (the production shape) ----- */}
	<div style={band}>
		<span style={bandIcon}>
			<Icon name="lucide:layers" size={17} />
		</span>
		<span style={bandBody}>
			<span style={bandTitle}>
				Production: <code style={bandCode}>cacheLife('max')</code> + tags &mdash; use
				both.
			</span>
			<span style={bandSub}>
				The clock becomes a safety net; the tag does the real work.
			</span>
		</span>
	</div>
</div>

<style>
	.tvp-columns {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 12px;
		margin: 0;
	}

	/* Narrow viewport: stack the two mechanisms. */
	@media (max-width: 600px) {
		.tvp-columns {
			grid-template-columns: 1fr;
		}
	}
</style>
