---
// SwrStrip — the single timeline strip reused across all four steps of the
// `swr-timeline` DiagramSequence (Chapter 032 L4, "Lifetimes and tags"). It is
// the *same* horizontal strip every frame; only the `now` marker position, the
// strip's aging tint, and a small annotation above the strip change. Keeping the
// geometry identical (and reserving a fixed-height annotation row + label row on
// every render) is what lets the DiagramSequence stage size once and never
// reflow as the reader scrubs.
//
// Encoding (left -> right is time, one cache entry's life):
//   - Three labeled zones, fixed widths: `stale` | `revalidate` | `expire`,
//     then a short faded "too old" tail past expire.
//   - A "now" pointer sits ABOVE the strip and slides right each step (`nowPct`).
//   - The strip ages with `phase`: fresh/current frames are BLUE (the chapter's
//     stored-cache-entry colour, lifted from L3 KeyComposition); the post-expire
//     frame fades the strip toward grey/amber (the chapter's stale/dynamic tint).
//   - `mode` drives the annotation above the strip — what the user/server does at
//     `now`: an instant client read, a server hand-back, a parallel
//     serve-now + background-refetch pair, or a blocking wait with a spinner.
//
// Pure HTML + CSS, inline style strings only (chapter house style). color-scheme
// pinned light so the hand-picked tints survive dark mode; margin:0 on every
// inner node to defeat Starlight's injected prose margins; box-sizing:border-box.

interface Props {
	// 0..100 — where the "now" pointer sits along the full strip width.
	nowPct: number;
	// Which zone the `now` marker currently sits in (drives the zone highlight).
	active: 'stale' | 'revalidate' | 'expire' | 'past';
	// 'fresh' | 'current' keep the strip blue; 'aged' fades it toward grey/amber.
	tint: 'fresh' | 'aged';
	// The annotation drawn above the strip at `now`.
	mode: 'instant' | 'handback' | 'swr' | 'block';
}

const { nowPct, active, tint, mode } = Astro.props;

const sans = "system-ui, -apple-system, 'Segoe UI', sans-serif";
const mono = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace';

// Palette — slate ink + the chapter's BLUE cached-entry colour (verbatim from
// L3 KeyComposition) and the chapter's AMBER stale/dynamic colour (verbatim from
// L1/L2). Past-expire frames swap the strip to GREY/AMBER to read as "too old".
const INK = '#1e293b'; // slate-800 — primary ink
const INK_SOFT = '#64748b'; // slate-500 — muted text
const SURFACE = '#ffffff';
const GRID = '#e2e8f0'; // slate-200 — soft dividers

const BLUE = '#2563eb'; // blue-600 — cached accent (chapter-wide stored entry)
const BLUE_BG = '#eff6ff'; // blue-50 — cached wash
const BLUE_BG2 = '#dbeafe'; // blue-100 — slightly deeper wash for the live zone
const BLUE_INK = '#1e40af'; // blue-800 — cached text

const AMBER = '#d97706'; // amber-600 — stale / dynamic
const AMBER_INK = '#b45309'; // amber-700
const STALE_BG = '#f1f5f9'; // slate-100 — the faded "too old" fill
const STALE_EDGE = '#cbd5e1'; // slate-300

// Zone widths as flex ratios — stale is the longest reuse window, the expire
// tail the shortest. Identical every step so columns never move.
const W = { stale: 5, revalidate: 4, expire: 3, tail: 2 };

// ---- atoms -----------------------------------------------------------------

const stage = `display: flex; flex-direction: column; gap: 0; margin: 0; padding: 4px 2px 2px; color-scheme: light; font-family: ${sans}; color: ${INK};`;

// Fixed-height row ABOVE the strip that holds the "now" pointer + its annotation.
// Reserved on every step (even quiet ones) so the strip never shifts vertically.
const markerRow = `position: relative; height: 86px; margin: 0;`;

// The "now" pointer: a stacked label + caret, anchored at nowPct, centred on it.
const nowAnchor = `position: absolute; bottom: 0; left: ${nowPct}%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0; margin: 0; width: max-content; max-width: 220px;`;
const nowPill = `margin: 0; padding: 1px 8px; border-radius: 999px; border: 1px solid ${INK}; background: ${INK}; color: ${SURFACE}; font-family: ${sans}; font-size: 9.5px; font-weight: 800; line-height: 1.4; letter-spacing: 0.04em; text-transform: uppercase; white-space: nowrap;`;
// The annotation under the pill describing what the user/server does right now.
const nowNote = `margin: 2px 0 0; font-family: ${sans}; font-size: 10px; font-weight: 700; line-height: 1.25; text-align: center; white-space: nowrap;`;
const nowCaret = `margin: 1px 0 0; font-size: 13px; line-height: 0.7; color: ${INK};`;

// The strip itself: a flex row of zone cells, fixed total height.
const strip = `position: relative; display: flex; align-items: stretch; gap: 0; height: 34px; margin: 0; border-radius: 8px; overflow: hidden; border: 1.5px solid ${tint === 'aged' ? STALE_EDGE : BLUE};`;

// A zone cell. Live (blue) vs faded (grey) depending on `tint`; the cell holding
// `now` gets a slightly deeper fill so the eye lands on the current phase.
const zone = (key: 'stale' | 'revalidate' | 'expire', isActive: boolean) => {
	const live = tint !== 'aged';
	const bg = live ? (isActive ? BLUE_BG2 : BLUE_BG) : isActive ? '#e9eef5' : STALE_BG;
	return (
		`box-sizing: border-box; flex: ${W[key]} 1 0; min-width: 0; margin: 0; padding: 0 6px;` +
		` background: ${bg}; border-right: 1px solid ${live ? '#c7dbfa' : STALE_EDGE};`
	);
};
// The trailing "too old" tail past expire — always a faded hatched grey.
const tailFill = `repeating-linear-gradient(135deg, ${STALE_BG} 0 6px, #e7ecf2 6px 12px)`;
const tail = (isActive: boolean) =>
	`box-sizing: border-box; flex: ${W.tail} 1 0; min-width: 0; display: flex; align-items: center; justify-content: center; margin: 0; padding: 0 4px; background: ${tailFill};` +
	(isActive ? ` box-shadow: inset 0 0 0 1.5px ${AMBER};` : '');
const tailLabel = (isActive: boolean) => `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 800; line-height: 1.1; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.02em; color: ${isActive ? AMBER_INK : INK_SOFT};`;

// Zone cells carry a stacked label: the window name (mono) + a tiny gloss of
// what reuse it buys, so the strip is self-describing without an extra row.
const zoneCell = `display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1px; margin: 0;`;
const zoneLabel = (isActive: boolean) => {
	const live = tint !== 'aged';
	const color = live ? (isActive ? BLUE_INK : '#5b8def') : isActive ? AMBER_INK : INK_SOFT;
	return `margin: 0; font-family: ${mono}; font-size: 11px; font-weight: ${isActive ? 800 : 700}; line-height: 1.15; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: ${color};`;
};
const zoneGloss = (isActive: boolean) => {
	const live = tint !== 'aged';
	const color = live ? (isActive ? BLUE_INK : '#7aa6f0') : INK_SOFT;
	return `margin: 0; font-family: ${sans}; font-size: 8.5px; font-weight: 700; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; opacity: 0.95; color: ${color};`;
};

// ---- the "what happens now" annotation -------------------------------------
// A small fixed-size glyph block that swaps by `mode`. Always rendered inside the
// reserved markerRow so its presence/absence never changes the strip's height.

// serve-now + background-refetch: two short stacked arrows (out, then back).
const swrBox = `display: flex; flex-direction: column; align-items: center; gap: 2px; margin: 0;`;
const swrLine = (color: string) => `display: flex; align-items: center; gap: 4px; margin: 0; font-family: ${sans}; font-size: 9px; font-weight: 800; line-height: 1.1; color: ${color}; white-space: nowrap;`;
const swrArrow = (color: string) => `font-size: 12px; line-height: 0.8; color: ${color};`;

// blocking wait: a spinner ring glyph + "waiting" label.
const spinner = `display: inline-block; width: 13px; height: 13px; margin: 0; border-radius: 50%; border: 2px solid ${STALE_EDGE}; border-top-color: ${AMBER}; box-sizing: border-box;`;
---

<div style={stage}>
	{/* ----- ABOVE THE STRIP: the moving "now" pointer + its annotation ----- */}
	<div style={markerRow}>
		<div style={nowAnchor}>
			{mode === 'instant' && (
				<Fragment>
					<span style={`${nowNote} color: ${BLUE_INK};`}>Client serves it instantly</span>
					<span style={`${nowNote} color: ${INK_SOFT};`}>server not contacted</span>
				</Fragment>
			)}

			{mode === 'handback' && (
				<Fragment>
					<span style={`${nowNote} color: ${BLUE_INK};`}>Server hands the stored value back</span>
					<span style={`${nowNote} color: ${INK_SOFT};`}>no fetch &middot; still instant</span>
				</Fragment>
			)}

			{mode === 'swr' && (
				<div style={swrBox}>
					<span style={swrLine(BLUE_INK)}>
						<span style={swrArrow(BLUE_INK)} aria-hidden="true">&uarr;</span>stale value served now
					</span>
					<span style={swrLine(AMBER_INK)}>
						<span style={swrArrow(AMBER_INK)} aria-hidden="true">&darr;</span>refetch in background
					</span>
				</div>
			)}

			{mode === 'block' && (
				<div style={swrBox}>
					<span style={`${swrLine(AMBER_INK)}`}>
						<span style={spinner} aria-hidden="true"></span>request blocks &amp; waits
					</span>
					<span style={`${nowNote} color: ${INK_SOFT};`}>fetch fresh before it can render</span>
				</div>
			)}

			<span style={nowPill}>now</span>
			<span style={nowCaret} aria-hidden="true">&#9660;</span>
		</div>
	</div>

	{/* ----- THE STRIP: identical geometry every step ----- */}
	<div style={strip}>
		<div style={`${zone('stale', active === 'stale')} ${zoneCell}`}>
			<span style={zoneLabel(active === 'stale')}>stale</span>
			<span style={zoneGloss(active === 'stale')}>reuse, no check</span>
		</div>
		<div style={`${zone('revalidate', active === 'revalidate')} ${zoneCell}`}>
			<span style={zoneLabel(active === 'revalidate')}>revalidate</span>
			<span style={zoneGloss(active === 'revalidate')}>refresh in background</span>
		</div>
		<div style={`${zone('expire', active === 'expire')} ${zoneCell}`}>
			<span style={zoneLabel(active === 'expire')}>expire</span>
			<span style={zoneGloss(active === 'expire')}>hard ceiling</span>
		</div>
		<div style={tail(active === 'past')}>
			<span style={tailLabel(active === 'past')}>too old</span>
		</div>
	</div>
</div>
