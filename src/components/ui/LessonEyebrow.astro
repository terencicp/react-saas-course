---
// Small uppercase line rendered above the H1 on every lesson page.
// Wired in via the PageTitle override (src/components/overrides/PageTitle.astro),
// which reads chapter-id, chapter-title, and sidebar.order from frontmatter and
// passes them in as props. Authors never instantiate this in MDX directly.
interface Props {
  /** Padded chapter id from frontmatter, e.g. "091". */
  chapterId?: string;
  /** Chapter name from frontmatter. Backticks render as inline <code>. */
  chapterTitle?: string;
  /** Lesson order within the chapter (sidebar.order). */
  lessonNumber?: number;
}

const { chapterId, chapterTitle, lessonNumber } = Astro.props;

// HTML-escape then upgrade `…` runs into <code> so chapter titles like
// "Unit tests for `-lib`" render cleanly inside the uppercase eyebrow.
function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
function renderInlineCode(s: string): string {
  return escapeHtml(s).replace(/`([^`]+)`/g, '<code>$1</code>');
}

const hasAny =
  Boolean(chapterId) || Boolean(chapterTitle) || lessonNumber != null;
const chapterTitleHtml = chapterTitle ? renderInlineCode(chapterTitle) : '';
---

{
  hasAny && (
    <div class="lesson-eyebrow not-content">
      {chapterId && <span>Chapter {chapterId}</span>}
      {chapterTitle && (
        <>
          {chapterId && <span class="sep" aria-hidden="true">·</span>}
          <span set:html={chapterTitleHtml} />
        </>
      )}
      {lessonNumber != null && (
        <>
          {(chapterId || chapterTitle) && (
            <span class="sep" aria-hidden="true">·</span>
          )}
          <span>Lesson {lessonNumber}</span>
        </>
      )}
    </div>
  )
}

<style>
  .lesson-eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0;
    /* Absorb the H1's original `margin-top: 1rem` here so the eyebrow takes
       the top space and sits flush against the title below it. */
    margin: 1rem 0 0.125rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-accent);
    line-height: 1.4;
  }
  .lesson-eyebrow .sep {
    margin: 0 0.5em;
    color: color-mix(in srgb, var(--sl-color-accent) 55%, transparent);
  }
  /* Inline code inside chapter titles (e.g. `-lib`) should ride the eyebrow's
     size/casing instead of popping out as a styled chip. */
  .lesson-eyebrow :global(code) {
    font-size: inherit;
    color: inherit;
    background: transparent;
    border: 0;
    padding: 0;
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    text-transform: none;
    letter-spacing: 0;
  }
</style>
