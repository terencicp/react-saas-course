---
// Clickable card for an external resource — replacement for Starlight's
// `LinkCard` when linking out to docs, repos, design files, etc.
// Renders as a tile with an icon badge, title, hostname, top-right
// external-link affordance, and description below.
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  href: string;
  description?: string;
  /** astro-icon name, e.g. `lucide:book` or `simple-icons:github`. */
  icon?: string;
  /** Optional accent color for the icon (CSS color value). */
  iconColor?: string;
}

const {
  title,
  href,
  description,
  icon = 'lucide:external-link',
  iconColor,
} = Astro.props;

let hostname = '';
try {
  hostname = new URL(href).hostname.replace(/^www\./, '');
} catch {
  hostname = href;
}
---

<a
  class="external-resource not-content"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="icon-badge" aria-hidden="true">
    <Icon
      name={icon}
      size={22}
      style={iconColor ? `color: ${iconColor}` : undefined}
    />
  </span>
  <div class="meta">
    <div class="title">{title}</div>
    <div class="host">{hostname}</div>
  </div>
  <span class="arrow" aria-hidden="true">
    <Icon name="lucide:arrow-up-right" size={18} />
  </span>
  {description && <p class="description">{description}</p>}
</a>

<style>
  .external-resource {
    display: grid;
    grid-template-columns: auto 1fr auto;
    column-gap: 1rem;
    row-gap: 0.85rem;
    padding: 1.25rem 1.5rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.875rem;
    color: var(--sl-color-text);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
    /* Starlight's content-spacing rule excludes <a> from sibling margins, so
       a standalone ExternalResource collapses against its neighbours. Restore
       the vertical rhythm here; inside <CardGrid> the parent's `gap` takes
       over (margin-top is zeroed by Starlight, margin-bottom by the rule
       below). */
    margin-block: var(--sl-content-gap-y, 1rem);
  }
  :global(.card-grid) > .external-resource {
    margin-block: 0;
  }
  .external-resource:hover,
  .external-resource:focus-visible {
    background: var(--sl-color-gray-5);
    border-color: var(--sl-color-gray-4);
    outline: none;
  }

  .icon-badge {
    grid-row: 1;
    grid-column: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-accent-high, var(--sl-color-accent));
    flex-shrink: 0;
  }
  .external-resource:hover .icon-badge {
    border-color: var(--sl-color-gray-4);
  }

  .meta {
    grid-row: 1;
    grid-column: 2;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--sl-color-white);
    line-height: 1.3;
  }
  .host {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.125rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .arrow {
    grid-row: 1;
    grid-column: 3;
    align-self: flex-start;
    display: inline-flex;
    color: var(--sl-color-gray-3);
    transition: color 0.15s, transform 0.15s;
  }
  .external-resource:hover .arrow {
    color: var(--sl-color-white);
    transform: translate(2px, -2px);
  }

  .description {
    grid-row: 2;
    grid-column: 1 / -1;
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
  }
</style>
