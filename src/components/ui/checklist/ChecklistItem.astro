---
// One row of a <Checklist>. The slot is the requirement; `chip` optionally
// tags it with a styled tested/untested pill.
interface Props {
  chip?: 'tested' | 'untested';
}
const { chip } = Astro.props;
---

<div class="ck-item" data-ck-item>
  <input type="checkbox" class="ck-box" />
  <div class="ck-label"><slot /></div>
  {chip && <span class={`ck-chip ${chip}`}>{chip}</span>}
</div>
