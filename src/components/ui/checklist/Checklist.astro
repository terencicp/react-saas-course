---
// Tickable checklist. Wrap <ChecklistItem> children inside; each renders a
// checkbox the student ticks as they work through a build. Ticked state
// persists per page + `id` in localStorage so progress survives a reload.
// Items never reorder, so saved state maps to source order by index.
interface Props {
  id?: string;
}
const { id } = Astro.props;
---

<div class="ck-list not-content" data-checklist data-id={id ?? ''}>
  <slot />
</div>

<style is:global>
  .ck-list {
    --ck-surface: var(--sl-color-bg-nav);
    --ck-text: var(--sl-color-white);
    --ck-muted: var(--sl-color-gray-3);
    --ck-accent: var(--sl-color-accent);
    --ck-border: var(--sl-color-gray-5);

    --ck-tested: #4ade80;
    --ck-tested-bg: #14532d;
    --ck-untested: #fbbf24;
    --ck-untested-bg: #78350f;

    color: var(--ck-text);
    line-height: 1.6;
    border: 1px solid var(--ck-border);
    background: var(--ck-surface);
    border-radius: 12px;
    padding: 4px 18px;
    margin: 1rem 0;
  }
  :root[data-theme='light'] .ck-list {
    --ck-tested: #16a34a;
    --ck-tested-bg: #dcfce7;
    --ck-untested: #b45309;
    --ck-untested-bg: #fef3c7;
  }

  .ck-list * { box-sizing: border-box; }

  .ck-item {
    display: grid;
    grid-template-columns: 22px 1fr auto;
    align-items: start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--ck-border);
    cursor: pointer;
  }
  .ck-item:last-child { border-bottom: none; }

  .ck-box {
    appearance: none;
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    margin: 2px 0 0;
    border: 1.5px solid var(--ck-border);
    border-radius: 6px;
    background: var(--ck-surface);
    cursor: pointer;
    display: grid;
    place-content: center;
    transition: background-color 0.14s, border-color 0.14s;
  }
  .ck-box::after {
    content: "\2713";
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
    color: white;
    transform: scale(0);
    transition: transform 0.12s ease;
  }
  .ck-box:checked {
    background: var(--ck-accent);
    border-color: var(--ck-accent);
  }
  .ck-box:checked::after { transform: scale(1); }
  .ck-box:focus-visible {
    outline: 2px solid var(--ck-accent);
    outline-offset: 2px;
  }

  .ck-label {
    font-size: 15px;
    transition: color 0.14s;
  }
  .ck-label > :first-child { margin-top: 0; }
  .ck-label > :last-child { margin-bottom: 0; }
  .ck-item.checked .ck-label { color: var(--ck-muted); }

  .ck-label code {
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
  }

  .ck-chip {
    align-self: start;
    margin-top: 3px;
    font-size: 10.5px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .ck-chip.tested { background: var(--ck-tested-bg); color: var(--ck-tested); }
  .ck-chip.untested { background: var(--ck-untested-bg); color: var(--ck-untested); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-checklist]').forEach((root, rootIdx) => {
    const rows = Array.from(root.querySelectorAll<HTMLElement>('[data-ck-item]'));
    if (rows.length === 0) return;

    const id = root.dataset.id || `c${rootIdx}`;
    const STORAGE_KEY = `react-saas-course:checklist:${location.pathname}:${id}`;

    function load(): boolean[] | null {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        const data = JSON.parse(raw);
        if (data?.v !== 1 || !Array.isArray(data.done)) return null;
        return data.done;
      } catch { return null; }
    }

    function save(boxes: HTMLInputElement[]) {
      try {
        const done = boxes.map((b) => b.checked);
        if (done.every((d) => !d)) localStorage.removeItem(STORAGE_KEY);
        else localStorage.setItem(STORAGE_KEY, JSON.stringify({ v: 1, done }));
      } catch {}
    }

    const saved = load();
    const boxes = rows.map((r) => r.querySelector<HTMLInputElement>('.ck-box')!);

    rows.forEach((row, i) => {
      const box = boxes[i];
      const label = row.querySelector<HTMLElement>('.ck-label');
      if (label && !box.getAttribute('aria-label')) {
        box.setAttribute('aria-label', (label.textContent || '').trim());
      }
      if (saved && typeof saved[i] === 'boolean') box.checked = saved[i];
      row.classList.toggle('checked', box.checked);

      box.addEventListener('change', () => {
        row.classList.toggle('checked', box.checked);
        save(boxes);
      });
      row.addEventListener('click', (e) => {
        if (e.target === box) return;
        box.checked = !box.checked;
        box.dispatchEvent(new Event('change'));
      });
    });
  });
</script>
