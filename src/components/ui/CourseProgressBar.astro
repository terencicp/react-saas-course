---
// Thin progress strip pinned to the very top edge of the viewport, filled in
// the theme accent to show how far through the whole course this lesson sits.
//
// `value` is a 0–1 fraction (typically a lesson's `course-progress`
// frontmatter). When it's absent or not a finite number the component renders
// nothing, so pages without the field are completely unaffected.
interface Props {
  /** Fraction of the course completed, 0–1. Omit to hide the bar entirely. */
  value?: number | null;
}

const { value } = Astro.props;

const show = typeof value === "number" && Number.isFinite(value);
// Clamp into [0, 100] so a stray out-of-range value can't overflow the track.
const percent = show ? Math.min(100, Math.max(0, value * 100)) : 0;
---

{
  show && (
    <Fragment>
      <div
        class="course-progress not-content"
        role="progressbar"
        aria-label="Course progress"
        aria-valuemin={0}
        aria-valuemax={100}
        aria-valuenow={Math.round(percent)}
      >
        <div class="course-progress__fill" style={`width: ${percent}%`} />
      </div>
      <script is:inline>
        // Hoist out of Starlight's `.main-pane` (isolation: isolate), whose
        // stacking context traps this fixed strip behind the sticky header.
        // Appending to body puts it in the root context. Runs during parse.
        (function () {
          var bar = document.currentScript.previousElementSibling;
          if (bar && bar.classList.contains("course-progress")) {
            document.body.appendChild(bar);
          }
        })();
      </script>
    </Fragment>
  )
}

<style>
  /* Pinned to the very top edge of the viewport, above Starlight's sticky
     header (--sl-z-index-navbar: 10). Hoisted to <body> by the script above so
     this z-index actually competes with the header. A native <dialog> (search)
     renders in the top layer, so it still covers this strip when open. */
  .course-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 3px;
    z-index: 100;
    /* Faint accent track so the filled portion reads as progress. */
    background: color-mix(in srgb, var(--sl-color-accent) 18%, transparent);
  }
  .course-progress__fill {
    height: 100%;
    background: var(--sl-color-accent);
  }
</style>
