---
// Stepped walkthrough of a single code block. The block is written *once* as
// the `code` prop on this component; each child <AnnotatedStep> contributes
// only a `meta` string (EC highlight syntax — `{1-3}`, `"token"`, `/regex/`)
// and the prose that explains the highlight. Only one step is visible at a
// time; Prev/Next swap which.
//
// Each step's <Code> renders independently with EC's programmatic API, so
// the highlights are baked at build time exactly like fenced blocks. The
// children-as-metadata pattern uses an <ac-step> custom-element marker:
// AnnotatedStep emits <ac-step data-payload="base64({meta,color})">prose
// </ac-step> into the slot, and we extract those here. (HTML comments would
// be simpler but Astro strips them from rendered output.)
//
// When `maxLines` is set, code blocks are capped to that visible line count
// and overflow scrolls vertically. On step change, the script scrolls the
// active code block to bring its first highlight into view.
import { Code } from 'astro-expressive-code/components';

interface Props {
  code: string;
  lang: string;
  maxLines?: number;
}
const { code: rawCode, lang, maxLines } = Astro.props;
const capped = typeof maxLines === 'number';

// Dedent + trim leading/trailing blank lines so template-literal `code` can
// be authored with normal MDX indentation without the EC block inheriting it.
function dedent(s: string): string {
  const lines = s.replace(/^\n+|\s+$/g, '').split('\n');
  let min = Infinity;
  for (const line of lines) {
    if (!line.trim()) continue;
    const m = line.match(/^[ \t]*/);
    if (m) min = Math.min(min, m[0].length);
  }
  if (!isFinite(min) || min === 0) return lines.join('\n');
  return lines.map((l) => (l.length >= min ? l.slice(min) : l)).join('\n');
}
const code = dedent(rawCode);

// Render children and pull out each step's metadata + prose HTML. Steps are
// never nested, so the lazy [\s\S]*? capture stops at the next </ac-step>.
const slotHtml = await Astro.slots.render('default');
type Color = 'green' | 'red' | 'blue' | 'orange' | 'violet' | null;
type Step = { meta: string; color: Color; prose: string };
const steps: Step[] = [];
const re = /<ac-step\s+data-payload="([A-Za-z0-9+/=]+)"[^>]*>([\s\S]*?)<\/ac-step>/g;
let m: RegExpExecArray | null;
while ((m = re.exec(slotHtml)) !== null) {
  const { meta, color } = JSON.parse(Buffer.from(m[1], 'base64').toString('utf-8'));
  steps.push({ meta, color, prose: m[2] });
}
---

<div
  class="ac-host"
  data-max-lines={capped ? '' : undefined}
  style={capped ? `--ac-max-lines: ${maxLines}` : undefined}
>
  <div class="ac-steps">
    {steps.map((step) => (
      <div class="ac-step" data-color={step.color ?? undefined}>
        <Code code={code} lang={lang} meta={step.meta} />
        <Fragment set:html={step.prose} />
      </div>
    ))}
  </div>
  <div class="ac-controls">
    <button type="button" class="ac-prev" aria-label="Previous step">← Previous</button>
    <span class="ac-counter" aria-live="polite">1 / 1</span>
    <button type="button" class="ac-next" aria-label="Next step">Next →</button>
  </div>
</div>

<style is:global>
  .ac-host {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-gray-5);
    margin: 1rem 0;
    overflow: hidden;
  }

  /* Steps stack in a single grid cell — the grid auto-sizes to the tallest
     step, so the controls below don't jump when stepping through. Inactive
     steps use `visibility: hidden` so they still occupy space. */
  .ac-host .ac-steps { display: grid; }
  .ac-host .ac-step {
    grid-column: 1;
    grid-row: 1;
    margin-top: 0;        /* opt out of Starlight's .sl-markdown-content flow margin */
    visibility: hidden;
  }
  .ac-host .ac-step[data-active] { visibility: visible; }

  /* The expressive-code block is the first child — flush to the top edges. */
  .ac-step .expressive-code { margin: 0; }
  .ac-step .expressive-code .frame pre,
  .ac-step .expressive-code .frame .header {
    border-radius: 0;
    border-left: 0;
    border-right: 0;
    border-top: 0;
  }

  /* maxLines cap: vertical scroll when code exceeds the requested line count.
     1.5em ≈ EC's line-height; +1.5rem covers the <code> element's vertical
     padding (12px top + 12px bottom). */
  .ac-host[data-max-lines] .ac-step .expressive-code pre {
    max-height: calc(1.5em * var(--ac-max-lines) + 1.5rem);
    overflow-y: auto;
  }

  /* Explanation prose sits below the code. Vertical padding (0.75rem) matches
     EC's internal `<code>` padding so the prose feels weighted the same as
     the code block. Horizontal padding (1rem) frames the text. */
  .ac-step > :not(.expressive-code) {
    padding-left: 1rem;
    padding-right: 1rem;
  }
  .ac-step > .expressive-code + :not(.expressive-code) {
    margin-top: 0;        /* override Starlight's flow margin on the first prose element */
    padding-top: 0.75rem;
  }
  .ac-step > :last-child:not(.expressive-code) {
    padding-bottom: 0.75rem;
  }

  .ac-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0;        /* opt out of Starlight's .sl-markdown-content flow margin */
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-7, transparent);
  }
  .ac-controls button {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-white);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.14s, border-color 0.14s, opacity 0.14s;
  }
  .ac-controls button:hover:not(:disabled) {
    border-color: var(--sl-color-accent);
  }
  .ac-controls button:disabled {
    opacity: 0.45;
    cursor: default;
  }
  .ac-controls .ac-next {
    background: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: white;
  }
  .ac-controls .ac-next:hover:not(:disabled) {
    opacity: 0.9;
    border-color: var(--sl-color-accent);
  }
  .ac-controls .ac-next:disabled {
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-3);
    border-color: var(--sl-color-gray-5);
  }
  .ac-counter {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    font-variant-numeric: tabular-nums;
  }

  /* Per-step highlight color. Overrides EC's `mark` background + border
     (used for both .ec-line.mark and inline <mark>). Two opacity stops:
     bg ~12-20%, border ~60-66%. Dark theme uses brighter accents, light
     theme uses more saturated ones so they read against #faf9f8. */
  .ac-step[data-color='green'] .expressive-code {
    --ec-tm-markBg: #4ade8033;
    --ec-tm-markBrdCol: #4ade80aa;
  }
  .ac-step[data-color='red'] .expressive-code {
    --ec-tm-markBg: #f8717133;
    --ec-tm-markBrdCol: #f87171aa;
  }
  .ac-step[data-color='blue'] .expressive-code {
    --ec-tm-markBg: #358ef133;
    --ec-tm-markBrdCol: #358ef1aa;
  }
  .ac-step[data-color='orange'] .expressive-code {
    --ec-tm-markBg: #fbbf2433;
    --ec-tm-markBrdCol: #fbbf24aa;
  }
  .ac-step[data-color='violet'] .expressive-code {
    --ec-tm-markBg: #a78bfa33;
    --ec-tm-markBrdCol: #a78bfaaa;
  }

  :root[data-theme='light'] .ac-step[data-color='green'] .expressive-code {
    --ec-tm-markBg: #16a34a1f;
    --ec-tm-markBrdCol: #16a34a99;
  }
  :root[data-theme='light'] .ac-step[data-color='red'] .expressive-code {
    --ec-tm-markBg: #dc26261f;
    --ec-tm-markBrdCol: #dc262699;
  }
  :root[data-theme='light'] .ac-step[data-color='blue'] .expressive-code {
    --ec-tm-markBg: #3178c61f;
    --ec-tm-markBrdCol: #3178c699;
  }
  :root[data-theme='light'] .ac-step[data-color='orange'] .expressive-code {
    --ec-tm-markBg: #d977061f;
    --ec-tm-markBrdCol: #d9770699;
  }
  :root[data-theme='light'] .ac-step[data-color='violet'] .expressive-code {
    --ec-tm-markBg: #7c3aed1f;
    --ec-tm-markBrdCol: #7c3aed99;
  }
</style>

<script>
  // Scroll the active step's <pre> so the highlighted region is centered in view.
  // Multi-line highlights produce one .ec-line.mark per line — span the union.
  // Note: smooth scroll via scrollTo is a no-op on EC's <pre> — set scrollTop directly.
  function scrollToHighlight(activeStep: HTMLElement) {
    const pre = activeStep.querySelector<HTMLElement>('.expressive-code pre');
    const highlights = activeStep.querySelectorAll<HTMLElement>(
      '.expressive-code .ec-line.mark, .expressive-code mark',
    );
    if (!pre || !highlights.length) return;
    let hlTop = Infinity;
    let hlBottom = -Infinity;
    highlights.forEach((el) => {
      const r = el.getBoundingClientRect();
      if (r.top < hlTop) hlTop = r.top;
      if (r.bottom > hlBottom) hlBottom = r.bottom;
    });
    const preRect = pre.getBoundingClientRect();
    if (hlTop >= preRect.top && hlBottom <= preRect.bottom) return;
    const hlHeight = hlBottom - hlTop;
    const targetTop = pre.scrollTop + (hlTop - preRect.top) - (preRect.height - hlHeight) / 2;
    pre.scrollTop = Math.max(0, targetTop);
  }

  document.querySelectorAll<HTMLElement>('.ac-host').forEach((host) => {
    // HMR re-runs this script; skip already-wired hosts so we don't stack listeners.
    if (host.dataset.acWired !== undefined) return;
    host.dataset.acWired = '';
    const steps = Array.from(host.querySelectorAll<HTMLElement>('.ac-step'));
    if (!steps.length) return;
    const prev = host.querySelector<HTMLButtonElement>('.ac-prev')!;
    const next = host.querySelector<HTMLButtonElement>('.ac-next')!;
    const counter = host.querySelector<HTMLElement>('.ac-counter')!;
    let i = 0;

    function render() {
      steps.forEach((s, idx) => {
        if (idx === i) s.dataset.active = '';
        else delete s.dataset.active;
      });
      counter.textContent = `${i + 1} / ${steps.length}`;
      prev.disabled = i === 0;
      next.disabled = i === steps.length - 1;
      scrollToHighlight(steps[i]);
    }

    prev.addEventListener('click', () => {
      if (i > 0) { i--; render(); }
    });
    next.addEventListener('click', () => {
      if (i < steps.length - 1) { i++; render(); }
    });
    render();
  });
</script>
