---
// One step inside <AnnotatedCode>. Holds a fenced code block (with EC's native
// line/regex highlights) plus the prose explaining it. The parent toggles
// visibility via [data-active].
//
// `color` re-tints the EC `mark` highlight (line + inline) for this step.
// Implemented by overriding EC's --ec-tm-markBg / --ec-tm-markBrdCol vars in
// AnnotatedCode's global stylesheet, keyed off [data-color].
type Color = 'green' | 'red' | 'blue' | 'orange' | 'violet';
interface Props {
  color?: Color;
}
const { color } = Astro.props;
---

<div class="ac-step" data-color={color}>
  <slot />
</div>
