---
// One step inside <AnnotatedCode>. Carries the highlight `meta` + optional
// `color` for this step, plus the prose that explains the highlight.
//
// The component itself emits no visible chrome — it wraps its slot in an
// <ac-step> custom element that the parent <AnnotatedCode> finds in its
// slot output. The parent then renders the shared <Code> block with this
// step's `meta` and re-emits the prose. Authors never write the code twice.
//
// Custom element (vs HTML comments) because Astro strips comments from
// output. `data-payload` is base64(JSON({ meta, color })) so values can
// contain arbitrary characters (quotes, regex slashes, etc.) without HTML
// attribute escaping concerns.
type Color = 'green' | 'red' | 'blue' | 'orange' | 'violet';
interface Props {
  meta?: string;
  color?: Color;
}
const { meta = '', color = null } = Astro.props;
const payload = Buffer.from(JSON.stringify({ meta, color })).toString('base64');
---

<ac-step data-payload={payload}>
  <slot />
</ac-step>
