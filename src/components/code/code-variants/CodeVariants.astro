---
// Tabbed comparison of labeled code variants. Each child <CodeVariant> is one
// Starlight <TabItem> holding a fenced code block (with EC's native
// highlights) plus prose. The wrapper renders Starlight's <Tabs> primitive so
// the tab strip looks like every other tabbed block on the site — then drops
// a card border around the whole thing and removes the internal dividers
// (between the tab strip and the code, and between the code and the prose)
// so the panel reads as a single unit.
import { Tabs } from '@astrojs/starlight/components';

interface Props {
  // Forwarded to Starlight's <Tabs> so multiple variant blocks on a page can
  // switch in sync (e.g. "Before / After" repeated across a long lesson).
  syncKey?: string;
  // Caps every variant's visible code-block height to ~maxLines lines and
  // adds vertical scroll. Applies uniformly across all tabs so the card
  // doesn't resize when switching variants. Defaults to 18, which is also the
  // hard ceiling (>18 throws). Pass `0` (or any non-positive number) to
  // disable the cap.
  maxLines?: number;
}
const { syncKey, maxLines = 18 } = Astro.props;
// 18 is a hard ceiling so a comparison card can't grow tall enough to swamp the
// page; pass a smaller value to shrink it, or `0` to disable the cap.
if (maxLines > 18) {
  throw new Error(`CodeVariants: maxLines must be ≤ 18 (received ${maxLines}).`);
}
const capped = typeof maxLines === 'number' && maxLines > 0;
---

<div
  class="code-variants not-content"
  data-max-lines={capped ? '' : undefined}
  style={capped ? `--cv-max-lines: ${maxLines}` : undefined}
>
  <Tabs syncKey={syncKey}>
    <slot />
  </Tabs>
</div>

<style is:global>
  /* Card chrome, same vibe as AnnotatedCode — single border, no internal
     dividers. Internal padding lives on the prose, not the card, so the EC
     frame can sit flush with the card edges. */
  .code-variants {
    border-bottom: 1px solid var(--sl-color-gray-5);
    margin: 1rem 0;
    overflow: hidden;
  }

  /* Starlight's tablist normally sits above a divider line; remove it so the
     tab strip and the code below read as a single surface. */
  .code-variants .tablist-wrapper {
    border-bottom: 0;
  }

  /* Close the gap between the tab strip and the code. Starlight gives the
     tabpanel a 1rem top margin by default; the card chrome makes that read
     as a hole. The side borders live on the panel, not the wrapper, so the
     tab strip can sit flush with the page edges. */
  .code-variants [role='tabpanel'] {
    margin-top: 0;
    border-left: 1px solid var(--sl-color-gray-5);
    border-right: 1px solid var(--sl-color-gray-5);
  }

  /* Drop EC's own frame borders on all four sides — the card border already
     does the framing. The bottom divider between code and prose lives on the
     prose element below, so it spans the full card width (border to border)
     instead of just the EC frame's pre. */
  .code-variants .expressive-code {
    margin: 0;
  }
  .code-variants .expressive-code .frame pre,
  .code-variants .expressive-code .frame .header {
    border: 0;
    border-radius: 0;
  }

  /* A `<div data-mark-color="…">` wrapper around the fence (used to retint
     marks per pane) sits between the tabpanel and the EC block — treat it as
     transparent for layout so the EC frame still sits flush with the card
     edges. The CSS-variable retint kicks in via the global selector. */
  .code-variants [role='tabpanel'] > [data-mark-color] {
    margin: 0;
  }

  /* maxLines cap: vertical scroll when code exceeds the requested line count.
     Mirrors AnnotatedCode — 1.5em ≈ EC's line-height; +1.5rem covers the
     <code> element's vertical padding (12px top + 12px bottom). */
  .code-variants[data-max-lines] .expressive-code pre {
    max-height: calc(1.5em * var(--cv-max-lines) + 1.5rem);
    overflow-y: auto;
  }

  /* Prose explanation under each tab's code block. Padding matches
     AnnotatedCode's prose section so the two components feel related. The
     border-top draws the full-width divider where the code container ends.
     The `:has(> .expressive-code)` arm of each selector handles the wrapped
     case so the per-pane color wrapper doesn't break the layout. */
  .code-variants [role='tabpanel'] > :not(.expressive-code):not(:has(> .expressive-code)) {
    padding-left: 1rem;
    padding-right: 1rem;
  }
  .code-variants [role='tabpanel'] > :is(.expressive-code, :has(> .expressive-code)) + :not(.expressive-code):not(:has(> .expressive-code)) {
    margin-top: 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }
  .code-variants [role='tabpanel'] > :last-child:not(.expressive-code):not(:has(> .expressive-code)) {
    padding-bottom: 0.75rem;
  }
</style>
