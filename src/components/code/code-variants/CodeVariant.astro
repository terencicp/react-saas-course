---
// One variant inside <CodeVariants>. Thin wrapper around Starlight's
// <TabItem> — the `label` drives the tab strip, the slot holds the fenced
// code block followed by the prose explaining that variant. Any variant-
// specific framing (e.g. "3 round-trips, in series" as a bold lead-in) is
// written in prose; the component intentionally has no header decorations.
import { TabItem } from '@astrojs/starlight/components';

interface Props {
  label: string;
  icon?: string;
}
const { label, icon } = Astro.props;
---

<TabItem label={label} icon={icon as any}>
  <slot />
</TabItem>
