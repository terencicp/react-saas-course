---
// Two-column matching drill. Wrap <Pair> children inside; each Pair has two
// named slots (`left` and `right`). Click a left pill, then a right pill —
// they lock in with a coloured dot and a curved line. Re-click a locked pill
// to undo. Check turns each pair green/red. Both columns shuffle on render.
---

<div class="mt-drill not-content">
  <p class="mt-prompt">
    Click an item on the left, then its match on the right. Press <strong>Check</strong> when done.
  </p>

  <div class="mt-source" data-source><slot /></div>

  <div class="mt-board" data-board>
    <div class="mt-col" data-col="left"></div>
    <div class="mt-col" data-col="right"></div>
    <svg class="mt-lines" data-lines xmlns="http://www.w3.org/2000/svg"></svg>
  </div>

  <div class="mt-actions">
    <button type="button" class="mt-btn mt-btn-check" data-check>Check</button>
    <button type="button" class="mt-btn mt-btn-reset" data-reset>Reset</button>
  </div>
</div>

<style is:global>
  .mt-drill {
    --mt-surface: var(--sl-color-bg-nav);
    --mt-surface-2: var(--sl-color-bg-sidebar);
    --mt-text: var(--sl-color-white);
    --mt-muted: var(--sl-color-gray-3);
    --mt-accent: var(--sl-color-accent);
    --mt-border: var(--sl-color-gray-5);
    --mt-pill-bg: var(--sl-color-gray-6);

    --mt-correct: #4ade80;
    --mt-correct-bg: #14532d;
    --mt-wrong: #f87171;
    --mt-wrong-bg: #7f1d1d;

    /* Eight distinct hues so concurrent pair lines stay readable. */
    --mt-p1: #fb7185;
    --mt-p2: #fdba74;
    --mt-p3: #facc15;
    --mt-p4: #4ade80;
    --mt-p5: #22d3ee;
    --mt-p6: #60a5fa;
    --mt-p7: #c4b5fd;
    --mt-p8: #f472b6;

    color: var(--mt-text);
    line-height: 1.6;
    border: 1px solid var(--mt-border);
    background: var(--mt-surface);
    border-radius: 12px;
    padding: 18px 20px;
  }
  :root[data-theme='light'] .mt-drill {
    --mt-correct: #16a34a;
    --mt-correct-bg: #dcfce7;
    --mt-wrong: #dc2626;
    --mt-wrong-bg: #fee2e2;

    --mt-p1: #e11d48;
    --mt-p2: #f97316;
    --mt-p3: #ca8a04;
    --mt-p4: #16a34a;
    --mt-p5: #0891b2;
    --mt-p6: #2563eb;
    --mt-p7: #7c3aed;
    --mt-p8: #db2777;
  }

  .mt-drill * { box-sizing: border-box; }

  .mt-prompt {
    color: var(--mt-muted);
    font-size: 14px;
    margin: 0 0 14px;
  }

  .mt-source { display: none; }

  .mt-board {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 56px;
    background: var(--mt-surface-2);
    border: 1px solid var(--mt-border);
    border-radius: 10px;
    padding: 12px;
    margin-bottom: 14px;
  }
  .mt-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mt-lines {
    position: absolute;
    inset: 12px;
    width: calc(100% - 24px);
    height: calc(100% - 24px);
    pointer-events: none;
    z-index: 2;
    overflow: visible;
  }

  .mt-pill {
    position: relative;
    padding: 10px 12px;
    border: 1px solid var(--mt-border);
    background: var(--mt-pill-bg);
    color: var(--mt-text);
    border-radius: 8px;
    font-size: 13.5px;
    font-weight: 500;
    cursor: pointer;
    user-select: none;
    transition: border-color 0.12s, background-color 0.12s, transform 0.1s;
  }
  .mt-pill:hover { border-color: var(--mt-accent); }
  .mt-pill.selected {
    border-color: var(--mt-accent);
    box-shadow: 0 0 0 2px var(--mt-accent);
  }
  .mt-pill[data-side="left"].selected { transform: translateX(2px); }
  .mt-pill[data-side="right"].selected { transform: translateX(-2px); }
  .mt-pill.locked { background: var(--mt-surface); cursor: pointer; }

  .mt-pill code {
    font: inherit;
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    background: transparent;
    padding: 0;
    border: 0;
    color: inherit;
  }

  .mt-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 8px;
    vertical-align: middle;
  }

  .mt-pill.right,
  .mt-pill.wrong { padding-right: 36px; }
  .mt-pill.right {
    border-color: var(--mt-correct);
    background: var(--mt-correct-bg);
    color: var(--mt-correct);
  }
  .mt-pill.wrong {
    border-color: var(--mt-wrong);
    background: var(--mt-wrong-bg);
    color: var(--mt-wrong);
    border-style: dashed;
  }
  .mt-pill.right::after,
  .mt-pill.wrong::after {
    position: absolute;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }
  .mt-pill.right::after { content: "\2713"; background: var(--mt-correct-bg); }
  .mt-pill.wrong::after { content: "\2717"; background: var(--mt-wrong-bg); }

  .mt-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .mt-btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--mt-border);
    background: var(--mt-surface-2);
    color: var(--mt-text);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.14s, border-color 0.14s, opacity 0.14s;
  }
  .mt-btn:hover { border-color: var(--mt-accent); }
  .mt-btn-check {
    background: var(--mt-accent);
    color: white;
    border-color: var(--mt-accent);
  }
  .mt-btn-check:hover { opacity: 0.9; border-color: var(--mt-accent); }

  @media (max-width: 540px) {
    .mt-board { column-gap: 32px; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.mt-drill').forEach((root) => {
    const source = root.querySelector<HTMLElement>('[data-source]');
    const board = root.querySelector<HTMLElement>('[data-board]');
    const leftCol = root.querySelector<HTMLElement>('[data-col="left"]');
    const rightCol = root.querySelector<HTMLElement>('[data-col="right"]');
    const svg = root.querySelector<SVGSVGElement>('[data-lines]');
    const checkBtn = root.querySelector<HTMLButtonElement>('[data-check]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]');
    if (!source || !board || !leftCol || !rightCol || !svg || !checkBtn || !resetBtn) return;

    const palette = ['--mt-p1', '--mt-p2', '--mt-p3', '--mt-p4', '--mt-p5', '--mt-p6', '--mt-p7', '--mt-p8'];
    const colorVar = (i: number) => `var(${palette[i % palette.length]})`;

    function shuffle<T>(a: T[]): T[] {
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function makePill(side: 'left' | 'right', key: string, content: HTMLElement): HTMLElement {
      const pill = document.createElement('div');
      pill.className = 'mt-pill';
      pill.dataset.side = side;
      pill.dataset.key = key;
      while (content.firstChild) pill.appendChild(content.firstChild);
      return pill;
    }

    const pairsSrc = Array.from(source.querySelectorAll<HTMLElement>('[data-pair]'));
    const lefts: HTMLElement[] = [];
    const rights: HTMLElement[] = [];
    pairsSrc.forEach((pairEl, i) => {
      const key = String(i);
      const lSrc = pairEl.querySelector<HTMLElement>('[data-side="left"]');
      const rSrc = pairEl.querySelector<HTMLElement>('[data-side="right"]');
      if (!lSrc || !rSrc) return;
      lefts.push(makePill('left', key, lSrc));
      rights.push(makePill('right', key, rSrc));
    });
    source.remove();
    shuffle(lefts.slice()).forEach((p) => leftCol.appendChild(p));
    shuffle(rights.slice()).forEach((p) => rightCol.appendChild(p));

    type Made = { leftEl: HTMLElement; rightEl: HTMLElement; colorIndex: number };
    const made: Made[] = [];
    let selectedLeft: HTMLElement | null = null;
    let selectedRight: HTMLElement | null = null;

    function clearSel() {
      selectedLeft?.classList.remove('selected');
      selectedRight?.classList.remove('selected');
      selectedLeft = null;
      selectedRight = null;
    }

    function nextColorIndex() {
      const used = new Set(made.map((p) => p.colorIndex));
      for (let i = 0; i < palette.length; i++) if (!used.has(i)) return i;
      return made.length % palette.length;
    }

    function tryPair() {
      if (!selectedLeft || !selectedRight) return;
      const colorIndex = nextColorIndex();
      [selectedLeft, selectedRight].forEach((p) => {
        const dot = document.createElement('span');
        dot.className = 'mt-dot';
        dot.style.background = colorVar(colorIndex);
        p.prepend(dot);
        p.classList.add('locked');
      });
      made.push({ leftEl: selectedLeft, rightEl: selectedRight, colorIndex });
      clearSel();
      drawLines();
    }

    function undoPair(pillEl: HTMLElement) {
      const idx = made.findIndex((p) => p.leftEl === pillEl || p.rightEl === pillEl);
      if (idx === -1) return;
      const p = made.splice(idx, 1)[0];
      [p.leftEl, p.rightEl].forEach((el) => {
        el.classList.remove('locked', 'right', 'wrong');
        el.querySelector('.mt-dot')?.remove();
      });
      drawLines();
    }

    function drawLines() {
      const boardRect = board!.getBoundingClientRect();
      const padding = 12;
      svg!.innerHTML = '';
      made.forEach((p) => {
        const lr = p.leftEl.getBoundingClientRect();
        const rr = p.rightEl.getBoundingClientRect();
        const x1 = lr.right - boardRect.left - padding;
        const y1 = lr.top + lr.height / 2 - boardRect.top - padding;
        const x2 = rr.left - boardRect.left - padding;
        const y2 = rr.top + rr.height / 2 - boardRect.top - padding;
        const cx = (x1 + x2) / 2;
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', `M ${x1} ${y1} C ${cx} ${y1}, ${cx} ${y2}, ${x2} ${y2}`);
        path.setAttribute('stroke', colorVar(p.colorIndex));
        path.setAttribute('stroke-width', '2.5');
        path.setAttribute('fill', 'none');
        path.setAttribute('stroke-linecap', 'round');
        svg!.appendChild(path);
      });
    }
    window.addEventListener('resize', drawLines);

    function bindCol(col: HTMLElement, isLeft: boolean) {
      col.querySelectorAll<HTMLElement>('.mt-pill').forEach((pill) => {
        pill.addEventListener('click', () => {
          if (pill.classList.contains('locked')) {
            undoPair(pill);
            return;
          }
          const cur = isLeft ? selectedLeft : selectedRight;
          if (cur) cur.classList.remove('selected');
          if (isLeft) selectedLeft = pill;
          else selectedRight = pill;
          pill.classList.add('selected');
          if (selectedLeft && selectedRight) tryPair();
        });
      });
    }
    bindCol(leftCol, true);
    bindCol(rightCol, false);

    checkBtn.addEventListener('click', () => {
      made.forEach((p) => {
        const correct = p.leftEl.dataset.key === p.rightEl.dataset.key;
        p.leftEl.classList.toggle('right', correct);
        p.rightEl.classList.toggle('right', correct);
        p.leftEl.classList.toggle('wrong', !correct);
        p.rightEl.classList.toggle('wrong', !correct);
      });
    });

    resetBtn.addEventListener('click', () => {
      made.length = 0;
      svg.innerHTML = '';
      root.querySelectorAll<HTMLElement>('.mt-pill').forEach((p) => {
        p.classList.remove('selected', 'locked', 'right', 'wrong');
        p.querySelector('.mt-dot')?.remove();
      });
      clearSel();
    });
  });
</script>
