---
// Free-text answer drill. Wrap question prose (and an optional fenced code
// block) in the default slot, plus a mandatory <AnswerWhy>...</AnswerWhy> with the
// senior-quality explanation. The student writes a free-form answer into
// the textarea and presses Submit. A local Ollama model grades the answer
// in two halves:
//
//   1. First word of the streamed reply MUST be `Pass.` or `Fail.` — that
//      drives the verdict color and headline.
//   2. The rest of the stream is short feedback addressed to the student;
//      it streams live into the panel as tokens arrive. The grader is told
//      to weave the <AnswerWhy> explanation naturally into this paragraph, so the
//      student walks away understanding the principle — the <AnswerWhy> itself is
//      never rendered to the page.
//
// If Ollama is unreachable or the model never emits a verdict, the script
// falls back to keyword grading: at least one string in `keywords` must
// appear (case-insensitive substring) in the answer to pass. The bar is
// intentionally lax — the offline path is already degraded, so author the
// `keywords` list with synonyms ("stale", "doesn't update", "out of sync")
// so any plausible phrasing triggers a match. `keywords` is required so
// every card has a working offline path. The feedback panel labels which
// path was used ("Graded by AI" vs "Graded by keyword match").
//
//   <TextAnswer
//     rubric="Must mention that the mirror only captures the initial prop."
//     keywords={['stale', 'render']}
//     lines={4}
//   >
//     Why is mirroring a prop into `useState` an anti-pattern?
//     <AnswerWhy>The local state is initialized once and never re-syncs…</AnswerWhy>
//   </TextAnswer>
interface Props {
  rubric: string;
  keywords: string[];
  lines?: number;
  placeholder?: string;
}
const {
  rubric,
  keywords,
  lines = 4,
  placeholder = 'Write your answer…',
} = Astro.props;
if (!Array.isArray(keywords) || keywords.length === 0) {
  throw new Error(
    '<TextAnswer> requires a non-empty `keywords` array — it is the fallback ' +
      'rubric when the AI grader is unreachable.',
  );
}

// Validate the <AnswerWhy> slot at render time so authoring mistakes surface during
// build, not at runtime. <AnswerWhy> emits `.ta-why`; if the slot HTML doesn't carry
// that class, the card has no senior explanation to feed the grader.
const slotHtml = await Astro.slots.render('default');
if (!/class=["'][^"']*\bta-why\b/.test(slotHtml)) {
  throw new Error(
    '<TextAnswer> requires an <AnswerWhy>...</AnswerWhy> slot — its content is fed to the ' +
      'AI grader so feedback can weave in the canonical explanation.',
  );
}
---

<div
  class="ta-card not-content"
  data-rubric={rubric}
  data-keywords={JSON.stringify(keywords)}
>
  <div class="ta-body">
    <Fragment set:html={slotHtml} />
  </div>

  <div class="ta-input-wrap">
    <textarea
      class="ta-input"
      rows={lines}
      placeholder={placeholder}
      spellcheck="true"
      autocomplete="off"></textarea>
  </div>

  <div class="ta-actions">
    <button type="button" class="ta-submit">Submit answer</button>
  </div>

  <div class="ta-feedback" hidden>
    <div class="ta-feedback-head">
      <span class="ta-feedback-title"></span>
      <span class="ta-feedback-mode"></span>
    </div>
    <div class="ta-feedback-stream"></div>
  </div>
</div>

<style is:global>
  .ta-card {
    --ta-surface: var(--sl-color-bg-nav);
    --ta-text: var(--sl-color-white);
    --ta-muted: var(--sl-color-gray-3);
    --ta-accent: var(--sl-color-accent);
    --ta-border: var(--sl-color-gray-5);
    --ta-hover: var(--sl-color-gray-6);
    --ta-correct: #4ade80;
    --ta-wrong: #f87171;
    --ta-code-strong: rgba(255, 255, 255, 0.15);
    --ta-code-soft: rgba(255, 255, 255, 0.10);

    color: var(--ta-text);
    line-height: 1.6;
    background: var(--ta-surface);
    border: 1px solid var(--ta-border);
    border-radius: 12px;
    padding: 20px 22px;
    margin-bottom: 16px;
  }
  :root[data-theme='light'] .ta-card {
    --ta-correct: #16a34a;
    --ta-wrong: #dc2626;
    --ta-code-strong: rgba(0, 0, 0, 0.12);
    --ta-code-soft: rgba(0, 0, 0, 0.08);
  }
  .ta-card * { box-sizing: border-box; }

  .ta-body { font-size: 16px; }
  .ta-body > :first-child { margin-top: 0; }
  .ta-body > p { margin: 0 0 14px; }
  .ta-body code:not(pre code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9em;
    background: var(--ta-hover);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .ta-body .expressive-code { margin: 0 0 14px; }
  /* Hidden by default; the script harvests its text for the AI prompt and
     never renders it to the page. */
  .ta-body .ta-why { display: none; }

  /* Textarea — readable plain-prose input, sized via the `lines` prop. */
  .ta-input-wrap {
    border: 1px solid var(--ta-border);
    border-radius: 8px;
    background: var(--ta-surface);
    overflow: hidden;
    margin-bottom: 14px;
    transition: border-color 0.12s;
  }
  .ta-input-wrap:focus-within { border-color: var(--ta-accent); }
  .ta-input {
    display: block;
    width: 100%;
    padding: 12px 14px;
    background: transparent;
    color: var(--ta-text);
    border: 0;
    outline: none;
    font: inherit;
    font-size: 15px;
    line-height: 1.55;
    resize: vertical;
  }
  .ta-input::placeholder {
    color: var(--ta-muted);
    font-style: italic;
  }
  .ta-input:disabled { cursor: default; opacity: 0.85; }

  .ta-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .ta-submit {
    background: var(--ta-accent);
    color: white;
    border: 0;
    padding: 10px 18px;
    border-radius: 8px;
    font: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .ta-submit:hover:not(:disabled) { opacity: 0.9; }
  .ta-submit:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Feedback panel — soft neutral background + a colored left rail. We
     keep the background a true grey (not Starlight's slightly-tinted gray-6)
     so it doesn't clash with the green/red verdict accents. The rail is
     muted while pending and flips to green or red once the verdict lands.
     The 14px gap above comes from `.ta-input-wrap`'s margin — no extra
     margin here so the rhythm with the rest of the card stays consistent. */
  .ta-feedback {
    padding: 12px 14px;
    background: rgba(127, 127, 127, 0.08);
    border-left: 3px solid var(--ta-border);
    border-radius: 4px;
    font-size: 14px;
    color: var(--ta-text);
  }
  .ta-feedback[hidden] { display: none; }
  .ta-card[data-state='correct'] .ta-feedback { border-left-color: var(--ta-correct); }
  .ta-card[data-state='wrong'] .ta-feedback { border-left-color: var(--ta-wrong); }

  .ta-feedback-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }
  .ta-feedback-title {
    font-weight: 700;
    font-size: 14px;
  }
  .ta-card[data-state='pending'] .ta-feedback-title { color: var(--ta-muted); }
  .ta-card[data-state='correct'] .ta-feedback-title { color: var(--ta-correct); }
  .ta-card[data-state='wrong'] .ta-feedback-title { color: var(--ta-wrong); }
  .ta-card[data-state='pending'] .ta-feedback-title::after {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-left: 6px;
    border-radius: 50%;
    background: currentColor;
    animation: ta-pulse 1.2s infinite ease-in-out;
    vertical-align: middle;
  }
  @keyframes ta-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
  .ta-feedback-mode {
    margin-left: auto;
    font-size: 12px;
    font-weight: 500;
    color: var(--ta-muted);
    letter-spacing: 0.02em;
  }
  .ta-feedback-mode:empty { display: none; }

  .ta-feedback-stream {
    white-space: pre-wrap;
    word-wrap: break-word;
    min-height: 1.4em;
  }
  /* Subtle caret while we're still streaming tokens. */
  .ta-card[data-state='pending'] .ta-feedback-stream::after,
  .ta-card[data-streaming] .ta-feedback-stream::after {
    content: '\25AE';
    display: inline-block;
    margin-left: 2px;
    color: var(--ta-muted);
    animation: ta-pulse 1s infinite ease-in-out;
  }

  /* Once submitted, lock the input visually but keep the answer visible. */
  .ta-card[data-state]:not([data-state='']) .ta-input { color: var(--ta-muted); }
  .ta-card[data-state]:not([data-state='']) .ta-submit { display: none; }
</style>

<script>
  import { streamPrompt, OllamaError } from '../../../lib/ollama';

  const stripHtml = (el: HTMLElement): string => {
    return (el.textContent ?? '').replace(/\s+/g, ' ').trim();
  };

  function buildPrompt(
    question: string,
    rubric: string,
    why: string,
    answer: string,
  ): string {
    return (
      `You are grading a student's free-text answer to a programming question.\n\n` +
      `QUESTION:\n${question}\n\n` +
      `PASSING RUBRIC (what the answer must include to pass):\n${rubric}\n\n` +
      `SENIOR EXPLANATION (the canonical explanation — weave its insight ` +
      `naturally into your feedback so the student walks away understanding ` +
      `the principle, not just whether they passed; never quote or label it):\n` +
      `${why}\n\n` +
      `STUDENT ANSWER:\n${answer}\n\n` +
      `Reply with EXACTLY one verdict word — "Pass." or "Fail." — followed ` +
      `by a single short paragraph (2–4 sentences) addressed to the student ` +
      `in second person. The paragraph must teach: incorporate the key idea ` +
      `from the SENIOR EXPLANATION in your own words. No preamble, no ` +
      `headers, no markdown, no code fences.\n\n` +
      `Pass means the answer satisfies the rubric (wording can be informal ` +
      `and brief). Fail means the answer misses, contradicts, or only ` +
      `vaguely gestures at the rubric.\n\n` +
      `Examples:\n` +
      `Pass. You nailed it — the useState initializer only runs on mount, so ` +
      `the local copy never re-syncs when the parent updates the prop. ` +
      `Derived values like this should be recomputed from the current props ` +
      `on every render instead.\n` +
      `Fail. You're describing general hooks rules, but the question asks ` +
      `specifically about staleness. The initializer captures props.name once ` +
      `at mount; nothing re-runs it when the parent re-renders with a new ` +
      `name, so the child silently displays the old value.\n\n` +
      `Reply now:`
    );
  }

  function keywordGrade(answer: string, keywords: string[]): { pass: boolean } {
    // Any single keyword match passes. Authors curate the list with synonyms,
    // so the bar is forgiving — better than failing a correct answer just
    // because the student happened to use different wording than the rubric.
    const haystack = answer.toLowerCase();
    return { pass: keywords.some((k) => haystack.includes(k.toLowerCase())) };
  }

  document.querySelectorAll<HTMLElement>('.ta-card').forEach((card) => {
    if (card.dataset.taWired !== undefined) return;
    card.dataset.taWired = '';

    const body = card.querySelector<HTMLElement>('.ta-body')!;
    const input = card.querySelector<HTMLTextAreaElement>('.ta-input')!;
    const submitBtn = card.querySelector<HTMLButtonElement>('.ta-submit')!;
    const feedback = card.querySelector<HTMLElement>('.ta-feedback')!;
    const titleEl = card.querySelector<HTMLElement>('.ta-feedback-title')!;
    const modeEl = card.querySelector<HTMLElement>('.ta-feedback-mode')!;
    const streamEl = card.querySelector<HTMLElement>('.ta-feedback-stream')!;

    // Detach the <AnswerWhy> before flattening the question. Its text is forwarded
    // to the AI grader as a senior explanation; it is never rendered to the
    // student. Server-side validation in the Astro frontmatter guarantees one
    // is present, so the fallback empty string is only a type-safety guard.
    const whyEl = body.querySelector<HTMLElement>('.ta-why');
    const whyText = whyEl ? stripHtml(whyEl) : '';
    whyEl?.remove();

    const rubric = card.dataset.rubric ?? '';
    let keywords: string[] = [];
    try {
      keywords = JSON.parse(card.dataset.keywords ?? '[]') as string[];
    } catch { keywords = []; }
    const questionText = stripHtml(body);

    function showFeedback(): void {
      feedback.hidden = false;
      feedback.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function applyKeywordFallback(answer: string): void {
      const { pass } = keywordGrade(answer, keywords);
      card.dataset.state = pass ? 'correct' : 'wrong';
      titleEl.textContent = pass ? 'Correct.' : 'Not quite.';
      modeEl.textContent = 'Graded by keyword match';
      // Offline path can't weave the senior explanation the way the AI does,
      // so show the author's <AnswerWhy> verbatim — that's the canonical teaching
      // beat the student should still walk away with.
      streamEl.textContent = whyText;
    }

    async function grade(answer: string): Promise<void> {
      const prompt = buildPrompt(questionText, rubric, whyText, answer);

      card.dataset.state = 'pending';
      card.dataset.streaming = '';
      titleEl.textContent = 'Reviewing your answer';
      modeEl.textContent = '';
      streamEl.textContent = '';
      showFeedback();

      let buffer = '';
      let verdict: 'pass' | 'fail' | null = null;
      const VERDICT_RE = /^\s*(Pass|Fail)\.\s*/i;
      const GIVE_UP_AT = 80; // chars; bail to keyword fallback if no verdict yet.

      try {
        for await (const chunk of streamPrompt(prompt, { temperature: 0 })) {
          if (verdict == null) {
            buffer += chunk;
            const m = buffer.match(VERDICT_RE);
            if (m) {
              verdict = m[1].toLowerCase() === 'pass' ? 'pass' : 'fail';
              card.dataset.state = verdict === 'pass' ? 'correct' : 'wrong';
              titleEl.textContent = verdict === 'pass' ? 'Correct.' : 'Not quite.';
              modeEl.textContent = 'Graded by AI';
              // Trim any whitespace bridging the verdict and the explanation —
              // models often emit "Pass." then a separate " " token, leaving a
              // dangling space at the start of the visible answer.
              streamEl.textContent = buffer.slice(m[0].length).replace(/^\s+/, '');
            } else if (buffer.length > GIVE_UP_AT) {
              throw new Error('No verdict prefix in model response');
            }
          } else {
            const current = streamEl.textContent ?? '';
            const piece = current === '' ? chunk.replace(/^\s+/, '') : chunk;
            if (piece) streamEl.textContent = current + piece;
          }
        }
        if (verdict == null) {
          // Stream ended without ever producing Pass./Fail. — bail.
          throw new Error('Stream ended before verdict prefix arrived');
        }
      } catch (err) {
        // Ollama unreachable, malformed stream, or no verdict — fall back to
        // keyword grading. Reset any partial stream we may have shown.
        if (!(err instanceof OllamaError)) {
          // eslint-disable-next-line no-console
          console.warn('TextAnswer AI grading failed, falling back:', err);
        }
        applyKeywordFallback(answer);
      } finally {
        delete card.dataset.streaming;
      }
    }

    submitBtn.addEventListener('click', async () => {
      if (card.dataset.state && card.dataset.state !== 'pending') return;
      const answer = input.value.trim();
      if (!answer) {
        input.focus();
        return;
      }
      submitBtn.disabled = true;
      input.disabled = true;
      await grade(answer);
    });

    // Cmd/Ctrl-Enter submits, matching PredictOutput's keybind.
    input.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
        e.preventDefault();
        if (!submitBtn.disabled) submitBtn.click();
      }
    });
  });
</script>
