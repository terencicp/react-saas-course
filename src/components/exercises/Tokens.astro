---
// Token-identification drill. Drop a fenced code block in the slot, then list
// which token strings are clickable: `targets` are the correct picks,
// `decoys` are the clickable wrong picks. Each string is wrapped around the
// first un-wrapped occurrence found in source order — repeat the string in
// the array to wrap multiple occurrences.
interface Props {
  targets: string[];
  decoys?: string[];
  prompt?: string;
}
const {
  targets,
  decoys = [],
  prompt = 'Click each matching token, then press Check.',
} = Astro.props;
---

<div
  class="tk-drill not-content"
  data-targets={JSON.stringify(targets)}
  data-decoys={JSON.stringify(decoys)}
>
  <p class="tk-prompt">{prompt}</p>

  <div class="tk-body" data-body><slot /></div>

  <div class="tk-actions">
    <button type="button" class="tk-btn tk-btn-check" data-check>Check</button>
    <button type="button" class="tk-btn tk-btn-reset" data-reset>Reset</button>
    <span class="tk-status" data-status></span>
  </div>
</div>

<style is:global>
  .tk-drill {
    --tk-surface: var(--sl-color-bg-nav);
    --tk-surface-2: var(--sl-color-bg-sidebar);
    --tk-text: var(--sl-color-white);
    --tk-muted: var(--sl-color-gray-3);
    --tk-accent: var(--sl-color-accent);
    --tk-border: var(--sl-color-gray-5);

    --tk-correct: #4ade80;
    --tk-correct-bg: #14532d;
    --tk-wrong: #f87171;
    --tk-wrong-bg: #7f1d1d;

    color: var(--tk-text);
    line-height: 1.6;
    border: 1px solid var(--tk-border);
    background: var(--tk-surface);
    border-radius: 12px;
    padding: 18px 20px;
  }
  :root[data-theme='light'] .tk-drill {
    --tk-correct: #16a34a;
    --tk-correct-bg: #dcfce7;
    --tk-wrong: #dc2626;
    --tk-wrong-bg: #fee2e2;
  }

  .tk-drill * { box-sizing: border-box; }

  .tk-prompt {
    color: var(--tk-muted);
    font-size: 14px;
    margin: 0 0 14px;
  }

  .tk-body { margin-bottom: 14px; }
  .tk-body .expressive-code { margin: 0; }

  .tk-tok {
    cursor: pointer;
    border-radius: 3px;
    padding: 0 1px;
    margin: 0 -1px;
    border: 1px dashed var(--tk-muted);
    transition: background-color 0.12s, border-color 0.12s;
  }
  .tk-tok:not(.picked):not(.right):not(.wrong):hover {
    background: rgba(127, 127, 127, 0.25);
  }
  .tk-tok.picked {
    background: color-mix(in srgb, var(--tk-accent) 35%, transparent);
    border-color: var(--tk-accent);
    border-style: solid;
  }
  .tk-tok.right {
    background: var(--tk-correct-bg);
    color: var(--tk-correct) !important;
    border-color: var(--tk-correct);
    border-style: solid;
    cursor: default;
  }
  .tk-tok.wrong {
    background: var(--tk-wrong-bg);
    color: var(--tk-wrong) !important;
    border-color: var(--tk-wrong);
    border-style: solid;
    text-decoration: line-through;
    cursor: default;
  }

  .tk-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .tk-btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--tk-border);
    background: var(--tk-surface-2);
    color: var(--tk-text);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.14s, border-color 0.14s, opacity 0.14s;
  }
  .tk-btn:hover:not(:disabled) { border-color: var(--tk-accent); }
  .tk-btn:disabled { opacity: 0.45; cursor: default; }
  .tk-btn-check {
    background: var(--tk-accent);
    color: white;
    border-color: var(--tk-accent);
  }
  .tk-btn-check:hover:not(:disabled) { opacity: 0.9; border-color: var(--tk-accent); }
  .tk-btn-check:disabled {
    background: var(--tk-surface-2);
    color: var(--tk-muted);
    border-color: var(--tk-border);
  }

  .tk-status {
    margin-left: auto;
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 12px;
    color: var(--tk-muted);
  }
</style>

<script>
  // Wrap the first un-wrapped occurrence of `needle` inside `root` with a
  // <span class="tk-tok"> (plus `target` if appropriate). The match may span
  // multiple text nodes — Expressive Code splits e.g. `"admin"` into three
  // sibling spans (open-quote, inner, close-quote).
  function wrapMatch(root: HTMLElement, needle: string, isTarget: boolean): boolean {
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(n) {
        return (n as Text).parentElement?.closest('.tk-tok')
          ? NodeFilter.FILTER_REJECT
          : NodeFilter.FILTER_ACCEPT;
      },
    });
    const entries: { node: Text; start: number }[] = [];
    let flat = '';
    let n: Node | null;
    while ((n = walker.nextNode())) {
      entries.push({ node: n as Text, start: flat.length });
      flat += (n as Text).nodeValue || '';
    }
    const start = flat.indexOf(needle);
    if (start < 0) return false;
    const end = start + needle.length;
    const startEntry = entries.find((e) => e.start <= start && start < e.start + e.node.length)!;
    const endEntry = [...entries].reverse().find((e) => e.start < end && end <= e.start + e.node.length)!;

    const range = document.createRange();
    range.setStart(startEntry.node, start - startEntry.start);
    range.setEnd(endEntry.node, end - endEntry.start);

    const span = document.createElement('span');
    span.className = isTarget ? 'tk-tok target' : 'tk-tok';
    span.appendChild(range.extractContents());
    range.insertNode(span);
    return true;
  }

  document.querySelectorAll<HTMLElement>('.tk-drill').forEach((root) => {
    const body = root.querySelector<HTMLElement>('[data-body]')!;
    const checkBtn = root.querySelector<HTMLButtonElement>('[data-check]')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]')!;
    const status = root.querySelector<HTMLElement>('[data-status]')!;

    const targets: string[] = JSON.parse(root.dataset.targets || '[]');
    const decoys: string[] = JSON.parse(root.dataset.decoys || '[]');

    // Process longer needles first so a short string (`==`) doesn't claim the
    // prefix of a longer one (`===`). User-given order is preserved within the
    // same length.
    const needles = [
      ...targets.map((s, i) => ({ s, isTarget: true, i })),
      ...decoys.map((s, i) => ({ s, isTarget: false, i: targets.length + i })),
    ];
    needles.sort((a, b) => b.s.length - a.s.length || a.i - b.i);
    needles.forEach((n) => wrapMatch(body, n.s, n.isTarget));

    const tokens = Array.from(body.querySelectorAll<HTMLElement>('.tk-tok'));
    const totalTargets = tokens.filter((t) => t.classList.contains('target')).length;

    function refresh() {
      const found = tokens.filter((t) => t.classList.contains('right')).length;
      status.textContent = `${found} / ${totalTargets} found`;
      checkBtn.disabled = found === totalTargets;
    }

    tokens.forEach((tok) => {
      tok.addEventListener('click', () => {
        if (tok.classList.contains('right') || tok.classList.contains('wrong')) return;
        tok.classList.toggle('picked');
      });
    });

    checkBtn.addEventListener('click', () => {
      tokens.forEach((tok) => {
        if (!tok.classList.contains('picked')) return;
        tok.classList.remove('picked');
        tok.classList.add(tok.classList.contains('target') ? 'right' : 'wrong');
      });
      refresh();
    });

    resetBtn.addEventListener('click', () => {
      tokens.forEach((tok) => tok.classList.remove('picked', 'right', 'wrong'));
      refresh();
    });

    refresh();
  });
</script>
