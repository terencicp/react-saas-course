---
// Single multiple-choice question. Wrap question prose, <McqChoice> options
// (mark the right ones with `correct`), and an optional <McqWhy> inside.
//
// Standalone in a lesson: the card runs its own click → reveal flow and
// drops a "Try again" button after the answer is shown.
//
// Inside a <Quiz>: the Quiz script claims the card, fills in the header
// (`(0.X.Y.1)` chip + `Question N of M`), and rolls each card's
// `mcq:answered` event into the shared score bar.
//
// Multi-correct: marking two or more <McqChoice> elements as correct switches
// the card into select-many mode with a Check button. A single correct
// choice keeps the original click-and-reveal behavior.

interface Props {
  src?: string;
}
const { src } = Astro.props;
---

<div class="mcq-card not-content" data-src={src}>
  <div class="mcq-header">
    <span class="mcq-source"></span>
    <span class="mcq-num"></span>
  </div>
  <div class="mcq-body">
    <slot />
  </div>
</div>

<style is:global>
  .mcq-card {
    --mcq-surface: var(--sl-color-bg-nav);
    --mcq-text: var(--sl-color-white);
    --mcq-muted: var(--sl-color-gray-3);
    --mcq-accent: var(--sl-color-accent);
    --mcq-border: var(--sl-color-gray-5);
    --mcq-hover: var(--sl-color-gray-6);
    --mcq-correct-bg: #14532d;
    --mcq-correct-border: #4ade80;
    --mcq-correct-text: #bbf7d0;
    --mcq-wrong-bg: #7f1d1d;
    --mcq-wrong-border: #f87171;
    --mcq-wrong-text: #fecaca;
    --mcq-code-strong: rgba(255, 255, 255, 0.15);
    --mcq-code-soft: rgba(255, 255, 255, 0.10);

    color: var(--mcq-text);
    line-height: 1.6;
    background: var(--mcq-surface);
    border: 1px solid var(--mcq-border);
    border-radius: 12px;
    /* Bottom is lighter than top because the last choice already carries its
       own 12px of padding; otherwise the trailing whitespace looks heavy. */
    padding: 20px 22px 8px;
    margin-bottom: 16px;
    scroll-margin-top: calc(var(--sl-nav-height, 0px) + 138px);
  }
  :root[data-theme='light'] .mcq-card {
    --mcq-correct-bg: #dcfce7;
    --mcq-correct-border: #16a34a;
    --mcq-correct-text: #14532d;
    --mcq-wrong-bg: #fee2e2;
    --mcq-wrong-border: #dc2626;
    --mcq-wrong-text: #7f1d1d;
    --mcq-code-strong: rgba(0, 0, 0, 0.12);
    --mcq-code-soft: rgba(0, 0, 0, 0.08);
  }

  .mcq-card * {
    box-sizing: border-box;
  }

  /* Header is hidden by default — only rendered when the card sits inside a
     <Quiz>, which adds .mcq-in-quiz and populates the source / number. */
  .mcq-card .mcq-header {
    display: none;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .mcq-card.mcq-in-quiz .mcq-header {
    display: flex;
  }
  .mcq-card .mcq-source {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 100px;
    background: var(--mcq-hover);
    color: var(--mcq-accent);
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    order: 1;
  }
  .mcq-card .mcq-source:empty {
    display: none;
  }
  .mcq-card .mcq-num {
    font-size: 11px;
    font-weight: 600;
    color: var(--mcq-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: auto;
  }

  .mcq-card .mcq-body {
    font-size: 16px;
  }
  .mcq-card .mcq-body > :first-child {
    margin-top: 0;
  }
  .mcq-card .mcq-body > p {
    margin: 0 0 14px;
    font-weight: 500;
  }
  .mcq-card code:not(pre code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9em;
    background: var(--mcq-hover);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .mcq-card .mcq-body .expressive-code {
    margin: 0 0 14px;
  }

  .mcq-choices {
    display: flex;
    flex-direction: column;
    margin-top: 14px;
    counter-reset: mcq-choice;
  }
  .mcq-choice {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    text-align: left;
    padding: 12px 4px;
    cursor: pointer;
    color: inherit;
    transition: background 0.12s, color 0.12s;
    line-height: 1.5;
    counter-increment: mcq-choice;
    border-top: 1px solid var(--mcq-border);
    user-select: none;
  }
  /* When the question ends in a code block, the block already separates the
     prose from the choices — drop the redundant top divider on the first row. */
  .mcq-body .expressive-code + .mcq-choices > .mcq-choice:first-of-type {
    border-top: none;
  }
  .mcq-choice:focus-visible {
    outline: 2px solid var(--mcq-accent);
    outline-offset: -2px;
    border-radius: 4px;
  }

  /* Bullet — circle with letter (single) or square with check (multi). */
  .mcq-choice .mcq-choice-bullet {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border: 1.5px solid var(--mcq-border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--mcq-muted);
    line-height: 1;
    border-radius: 50%;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
  }
  .mcq-card[data-multi='true'] .mcq-choice .mcq-choice-bullet {
    border-radius: 6px;
  }
  .mcq-choice .mcq-choice-bullet::before {
    content: counter(mcq-choice, upper-alpha);
  }
  .mcq-card[data-multi='true'] .mcq-choice.selected .mcq-choice-bullet {
    background: var(--mcq-accent);
    border-color: var(--mcq-accent);
    color: white;
  }
  .mcq-card[data-multi='true'] .mcq-choice.selected .mcq-choice-bullet::before {
    content: '✓';
  }

  .mcq-choice .mcq-choice-text {
    flex: 1;
    min-width: 0;
  }
  .mcq-choice .mcq-choice-text > :first-child {
    margin-top: 0;
  }
  .mcq-choice .mcq-choice-text > :last-child {
    margin-bottom: 0;
  }
  .mcq-choice .mcq-choice-text > p {
    margin: 0 0 8px;
  }
  .mcq-choice .mcq-choice-text > p:last-child {
    margin-bottom: 0;
  }
  .mcq-choice .mcq-choice-text .expressive-code {
    margin: 6px 0 0;
  }
  .mcq-choice .mcq-choice-text > .expressive-code:first-child {
    margin-top: 0;
  }

  .mcq-choice:hover:not([aria-disabled='true']) {
    background: var(--sl-color-accent-low);
  }
  .mcq-choice[aria-disabled='true'] {
    cursor: default;
  }
  .mcq-choice.correct {
    color: var(--mcq-correct-border);
  }
  .mcq-choice.wrong {
    color: var(--mcq-wrong-border);
  }
  .mcq-choice.correct .mcq-choice-bullet {
    background: var(--mcq-correct-border);
    border-color: var(--mcq-correct-border);
    color: white;
  }
  .mcq-choice.correct .mcq-choice-bullet::before {
    content: '✓';
  }
  .mcq-choice.wrong .mcq-choice-bullet {
    background: var(--mcq-wrong-border);
    border-color: var(--mcq-wrong-border);
    color: white;
  }
  .mcq-choice.wrong .mcq-choice-bullet::before {
    content: '✕';
  }
  .mcq-choice.correct code,
  .mcq-choice.wrong code {
    background: var(--mcq-code-strong);
  }

  .mcq-check {
    margin-top: 14px;
    margin-bottom: 14px;
    background: var(--mcq-accent);
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 8px;
    font: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s, background 0.15s;
    align-self: flex-start;
  }
  .mcq-check:hover:not(:disabled) {
    opacity: 0.9;
  }
  .mcq-check:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .mcq-why {
    margin-top: 14px;
    margin-bottom: 14px;
    padding: 12px 14px;
    background: var(--mcq-hover);
    border-left: 3px solid var(--mcq-accent);
    border-radius: 4px;
    font-size: 14px;
    color: var(--mcq-text);
  }
  .mcq-why > :first-child {
    margin-top: 0;
  }
  .mcq-why > :last-child {
    margin-bottom: 0;
  }
  .mcq-why > p {
    margin: 0;
  }
  .mcq-why code {
    background: var(--mcq-code-soft);
  }
  .mcq-card[data-state='correct'] .mcq-why::before {
    content: 'Correct. ';
    font-weight: 700;
  }
  .mcq-card[data-state='wrong'] .mcq-why::before {
    content: 'Not quite. ';
    font-weight: 700;
  }
</style>

<script>
  import { autoClaimStandalone } from './setup';
  autoClaimStandalone();
</script>
