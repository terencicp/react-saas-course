---
// One option inside a <MultipleChoice>. Mark `correct` to flag it as a
// valid answer — multiple `correct` choices on the same question switch the
// component into multi-select / submit-to-check mode automatically.
interface Props {
  correct?: boolean;
}
const { correct = false } = Astro.props;
---

<div class="mcq-choice" data-correct={correct ? 'true' : 'false'}>
  <span class="mcq-choice-bullet" aria-hidden="true"></span>
  <div class="mcq-choice-text"><slot /></div>
</div>
