---
// Code review exercise — a PR-style multi-file diff the student annotates
// with inline review comments.
//
//   <CodeReview>
//     <ReviewFile name="src/foo.ts">
//       ```ts del={3} ins={4}
//       …
//       ```
//     </ReviewFile>
//     <ReviewIssue file="src/foo.ts" line={4}>Senior's note here.</ReviewIssue>
//     <Why>Optional overall debrief.</Why>
//   </CodeReview>
//
// Two-or-more files render inside Starlight's <Tabs>. ReviewFile already
// emits a <starlight-tab-item>, so processing happens inside <Tabs> for free.
// A plant is "caught" iff at least one comment lands on its exact file:line —
// the comment text is not inspected.
import { Tabs } from '@astrojs/starlight/components';

interface Props {
  instructions?: string;
}
const { instructions } = Astro.props;

const slotHtml = await Astro.slots.render('default');
const useTabs = (slotHtml.match(/<starlight-tab-item\b/g)?.length ?? 0) > 1;
---

<div class="cr-card not-content">
  <p class="cr-prompt">
    {instructions && <>{instructions}{' '}</>}
    Click any line to leave a review comment, then press <strong>Submit review</strong>.
  </p>

  <div class="cr-body" data-tabbed={useTabs ? '' : undefined}>
    {useTabs ? (
      <Tabs><Fragment set:html={slotHtml} /></Tabs>
    ) : (
      <Fragment set:html={slotHtml} />
    )}
  </div>

  <div class="cr-actions">
    <button type="button" class="cr-submit">Submit review</button>
    <span class="cr-status" hidden></span>
    <span class="cr-target"></span>
  </div>

  <div class="cr-feedback" hidden>
    <div class="cr-feedback-head">
      <span class="cr-feedback-title"></span>
      <span class="cr-feedback-mode"></span>
    </div>
    <div class="cr-feedback-body">
      <div class="cr-overall" hidden><div class="cr-why-slot"></div></div>
      <ul class="cr-issue-list"></ul>
    </div>
  </div>
</div>

<style is:global>
  .cr-card {
    --cr-surface: var(--sl-color-bg-nav);
    --cr-text: var(--sl-color-white);
    --cr-muted: var(--sl-color-gray-3);
    --cr-accent: var(--sl-color-accent);
    --cr-border: var(--sl-color-gray-5);
    --cr-hover: var(--sl-color-gray-6);
    --cr-thread-bg: var(--sl-color-gray-7, var(--sl-color-bg));
    --cr-correct: #4ade80;
    --cr-wrong: #f87171;
    --cr-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;

    color: var(--cr-text);
    line-height: 1.6;
    background: var(--cr-surface);
    border: 1px solid var(--cr-border);
    border-radius: 12px;
    padding: 20px 22px;
    margin-bottom: 16px;
  }
  :root[data-theme='light'] .cr-card { --cr-correct: #16a34a; --cr-wrong: #dc2626; }
  .cr-card * { box-sizing: border-box; }

  .cr-prompt { color: var(--cr-muted); font-size: 14px; margin: 0 0 14px; }
  .cr-body code:not(pre code) {
    font-family: var(--cr-mono);
    font-size: 0.9em;
    background: var(--cr-hover);
    padding: 1px 5px;
    border-radius: 4px;
  }

  /* Files */
  .cr-file {
    border: 1px solid var(--cr-border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 14px;
    background: var(--cr-surface);
  }
  .cr-file-header {
    padding: 8px 12px;
    background: var(--cr-hover);
    border-bottom: 1px solid var(--cr-border);
    font: 13px var(--cr-mono);
    color: var(--cr-text);
  }
  .cr-file-body .expressive-code { margin: 0; }
  .cr-file-body .expressive-code .frame pre,
  .cr-file-body .expressive-code .frame .header {
    border-radius: 0;
    border-left: 0;
    border-right: 0;
    border-bottom: 0;
  }
  .cr-file-body .expressive-code .frame .header { display: none; }

  /* Tabs mode — Starlight's tablist already shows the filename. */
  .cr-body[data-tabbed] .cr-file { border: 0; border-radius: 0; margin-bottom: 0; }
  .cr-body[data-tabbed] .cr-file-header { display: none; }
  .cr-body[data-tabbed] starlight-tabs .tablist-wrapper ~ [role='tabpanel'] { margin-top: 0; }

  /* Clickable EC lines */
  .cr-file .expressive-code .ec-line { cursor: pointer; transition: background-color 0.1s; }
  .cr-file .expressive-code .ec-line:hover { background: rgba(127, 127, 127, 0.12); }
  .cr-file .expressive-code .ec-line[data-cr-active='true'] { background: rgba(127, 127, 127, 0.18); }
  .cr-card[data-state] .cr-file .expressive-code .ec-line { cursor: default; }
  .cr-card[data-state] .cr-file .expressive-code .ec-line:hover { background: transparent; }

  /* Comment threads */
  .cr-thread {
    background: var(--cr-thread-bg);
    border-top: 1px solid var(--cr-border);
    border-bottom: 1px solid var(--cr-border);
    padding: 10px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 14px;
  }
  .cr-comment {
    border: 1px solid var(--cr-border);
    border-radius: 6px;
    background: var(--cr-surface);
    padding: 8px 10px;
  }
  .cr-comment-text {
    white-space: pre-wrap;
    word-wrap: break-word;
    color: var(--cr-text);
    margin-bottom: 6px;
  }
  .cr-comment > button {
    background: transparent;
    border: 0;
    color: var(--cr-muted);
    font: inherit;
    font-size: 12px;
    cursor: pointer;
    padding: 2px 4px;
    margin-right: 4px;
    border-radius: 4px;
  }
  .cr-comment > button:hover { color: var(--cr-accent); background: var(--cr-hover); }
  /* Hide edit/delete actions on every comment once the review is submitted. */
  .cr-card[data-state] .cr-comment > button { display: none; }

  /* Composer */
  .cr-composer {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border: 1px solid var(--cr-border);
    border-radius: 6px;
    background: var(--cr-surface);
    padding: 8px;
  }
  .cr-composer textarea {
    width: 100%;
    min-height: 60px;
    resize: vertical;
    background: transparent;
    color: var(--cr-text);
    border: 0;
    outline: none;
    font: inherit;
    line-height: 1.5;
  }
  .cr-composer-actions { display: flex; gap: 8px; justify-content: flex-end; }
  .cr-composer-actions button {
    padding: 6px 12px;
    border-radius: 6px;
    font: inherit;
    font-size: 13px;
    cursor: pointer;
    border: 1px solid var(--cr-border);
    background: var(--cr-hover);
    color: var(--cr-text);
  }
  .cr-composer-actions .cr-composer-save {
    background: var(--cr-accent);
    border-color: var(--cr-accent);
    color: white;
  }
  .cr-composer-actions .cr-composer-save:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Submit row */
  .cr-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .cr-submit {
    background: var(--cr-accent);
    color: white;
    border: 0;
    padding: 10px 18px;
    border-radius: 8px;
    font: inherit;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .cr-submit:hover:not(:disabled) { opacity: 0.9; }
  .cr-submit:disabled { opacity: 0.4; cursor: not-allowed; }
  .cr-status { font-size: 13px; color: var(--cr-muted); font-style: italic; }
  .cr-status[hidden] { display: none; }
  .cr-target { margin-left: auto; font-size: 13px; color: var(--cr-muted); }

  /* Reveal panel */
  .cr-feedback {
    margin-top: 14px;
    border-radius: 8px;
    border: 1px solid var(--cr-border);
    background: var(--cr-hover);
    overflow: hidden;
  }
  .cr-feedback[hidden] { display: none; }
  .cr-feedback-head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--cr-border);
    font-size: 14px;
    font-weight: 600;
  }
  .cr-feedback-mode {
    margin-left: auto;
    font-size: 13px;
    font-weight: 500;
    color: var(--cr-muted);
  }
  .cr-feedback-body { padding: 12px 14px; display: flex; flex-direction: column; gap: 12px; }
  .cr-overall { color: var(--cr-text); font-size: 14px; font-style: italic; }
  .cr-overall .cr-why-slot > :first-child { margin-top: 0; }
  .cr-overall .cr-why-slot > :last-child { margin-bottom: 0; }

  .cr-issue-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .cr-issue-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px 0;
    border-top: 1px solid var(--cr-border);
  }
  .cr-issue-row:first-child { border-top: 0; padding-top: 0; }
  .cr-issue-row:last-child { padding-bottom: 0; }
  /* When an overall <Why> sits above the list, restore the divider on the
     first row so the optional debrief is separated from the first issue. */
  .cr-overall:not([hidden]) + .cr-issue-list .cr-issue-row:first-child {
    border-top: 1px solid var(--cr-border);
    padding-top: 12px;
  }
  .cr-issue-head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .cr-issue-status {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    color: white;
    font: 800 11px / 1 -apple-system, BlinkMacSystemFont, sans-serif;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cr-issue-row[data-status='caught'] .cr-issue-status { background: var(--cr-correct); }
  .cr-issue-row[data-status='caught'] .cr-issue-status::before { content: '\2713'; }
  .cr-issue-row[data-status='missed'] .cr-issue-status { background: var(--cr-wrong); }
  .cr-issue-row[data-status='missed'] .cr-issue-status::before { content: '\2715'; }
  .cr-issue-loc { font: 13px var(--cr-mono); color: var(--cr-muted); }
  .cr-issue-note { margin: 0; color: var(--cr-text); }
  .cr-issue-note > :first-child { margin-top: 0; }
  .cr-issue-note > :last-child { margin-bottom: 0; }
  .cr-issue-note > p { margin: 0; }
  .cr-issue-note code:not(pre code) {
    font-family: var(--cr-mono);
    font-size: 0.9em;
    background: var(--cr-hover);
    padding: 1px 5px;
    border-radius: 4px;
  }
</style>

<script>
  import { runPrompt } from '../../../lib/ollama';

  type Issue = { file: string; line: number; noteHtml: string };
  type Comment = { id: number; text: string };

  const stripHtml = (html: string): string => {
    const tmp = document.createElement('div');
    tmp.innerHTML = html;
    return (tmp.textContent ?? '').trim().replace(/\s+/g, ' ');
  };

  async function gradeWithAI(
    items: { issue: Issue; text: string }[],
  ): Promise<boolean[]> {
    const itemsBlock = items
      .map(
        (it, i) =>
          `[${i}] ${it.issue.file}:${it.issue.line}\n` +
          `RUBRIC: ${stripHtml(it.issue.noteHtml)}\n` +
          `STUDENT: ${it.text}`,
      )
      .join('\n\n');

    const prompt =
      `Grade each item: does the STUDENT comment identify the same defect as the RUBRIC? ` +
      `Wording differences are fine; superficial or empty comments fail.\n\n` +
      `Reply with ONLY a JSON array, no prose, no code fences, in this exact shape:\n` +
      `[{"i":0,"pass":true},{"i":1,"pass":false}]\n\n` +
      `ITEMS:\n${itemsBlock}`;

    const raw = await runPrompt(prompt);
    const m = raw.match(/\[[\s\S]*\]/);
    if (!m) throw new Error('No JSON array in model response.');
    const parsed = JSON.parse(m[0]) as { i?: number; pass?: boolean }[];
    const out = items.map(() => false);
    for (const v of parsed) {
      if (typeof v?.i === 'number' && v.i >= 0 && v.i < items.length) {
        out[v.i] = !!v.pass;
      }
    }
    return out;
  }

  const el = <K extends keyof HTMLElementTagNameMap>(
    tag: K,
    cls?: string,
    text?: string,
  ): HTMLElementTagNameMap[K] => {
    const e = document.createElement(tag);
    if (cls) e.className = cls;
    if (text != null) e.textContent = text;
    return e;
  };
  const btn = (cls: string, text: string): HTMLButtonElement => {
    const b = el('button', cls, text);
    b.type = 'button';
    return b;
  };

  document.querySelectorAll<HTMLElement>('.cr-card').forEach((card) => {
    if (card.dataset.crWired !== undefined) return;
    card.dataset.crWired = '';

    const body = card.querySelector<HTMLElement>('.cr-body')!;
    const submitBtn = card.querySelector<HTMLButtonElement>('.cr-submit')!;
    const targetEl = card.querySelector<HTMLElement>('.cr-target')!;
    const feedback = card.querySelector<HTMLElement>('.cr-feedback')!;
    const issueList = card.querySelector<HTMLElement>('.cr-issue-list')!;
    const overall = card.querySelector<HTMLElement>('.cr-overall')!;

    // Harvest <ReviewIssue> declarations into JS state.
    const issues: Issue[] = [];
    body.querySelectorAll<HTMLElement>('.cr-issue').forEach((i) => {
      issues.push({
        file: i.dataset.file ?? '',
        line: Number(i.dataset.line ?? '0'),
        noteHtml: i.innerHTML,
      });
      i.remove();
    });
    targetEl.textContent = issues.length === 0
      ? ''
      : `${issues.length} line${issues.length === 1 ? '' : 's'} to flag`;

    // Move <Why> (overall debrief) into the reveal panel. Descendant query
    // works in tabs mode where the slot HTML lives inside <starlight-tabs>.
    const why = body.querySelector<HTMLElement>('.cr-why');
    if (why) {
      card.querySelector<HTMLElement>('.cr-why-slot')!.appendChild(why);
      why.hidden = false;
      overall.hidden = false;
    }

    // Per-line comment state. Key: `${file}:${line}`.
    const threads = new Map<string, Comment[]>();
    let nextId = 1;
    const key = (file: string, line: number) => `${file}:${line}`;

    body.querySelectorAll<HTMLElement>('.cr-file').forEach((fileEl) => {
      const file = fileEl.dataset.file ?? '';
      fileEl.querySelectorAll<HTMLElement>('.expressive-code .ec-line').forEach((lineEl, idx) => {
        const line = idx + 1;
        lineEl.addEventListener('click', (e) => {
          // Defensive: a click inside a thread shouldn't open a new composer.
          if ((e.target as HTMLElement).closest('.cr-thread')) return;
          openComposer(fileEl, file, line, lineEl);
        });
      });
    });

    const getThread = (fileEl: HTMLElement, line: number) =>
      fileEl.querySelector<HTMLElement>(`.cr-thread[data-line="${line}"]`);

    function ensureThread(fileEl: HTMLElement, line: number, lineEl: HTMLElement) {
      let t = getThread(fileEl, line);
      if (!t) {
        t = el('div', 'cr-thread');
        t.dataset.line = String(line);
        lineEl.insertAdjacentElement('afterend', t);
      }
      return t;
    }

    function renderThread(fileEl: HTMLElement, file: string, line: number, lineEl: HTMLElement) {
      const comments = threads.get(key(file, line)) ?? [];
      const existing = getThread(fileEl, line);
      // Preserve an open composer across re-renders (e.g. if the user edits
      // one comment and deletes another while the composer is open).
      const composer = existing?.querySelector<HTMLElement>('.cr-composer');
      if (comments.length === 0 && !composer) {
        existing?.remove();
        delete lineEl.dataset.crActive;
        return;
      }
      const thread = existing ?? ensureThread(fileEl, line, lineEl);
      thread.innerHTML = '';
      comments.forEach((c) => thread.appendChild(renderComment(fileEl, file, line, lineEl, c)));
      if (composer) thread.appendChild(composer);
      lineEl.dataset.crActive = 'true';
    }

    function renderComment(
      fileEl: HTMLElement,
      file: string,
      line: number,
      lineEl: HTMLElement,
      c: Comment,
    ) {
      const wrap = el('div', 'cr-comment');
      wrap.append(el('div', 'cr-comment-text', c.text));

      const editBtn = btn('', 'Edit');
      editBtn.onclick = () => openComposer(fileEl, file, line, lineEl, c);

      const delBtn = btn('', 'Delete');
      delBtn.onclick = () => {
        const k = key(file, line);
        threads.set(k, (threads.get(k) ?? []).filter((x) => x.id !== c.id));
        renderThread(fileEl, file, line, lineEl);
      };

      wrap.append(editBtn, delBtn);
      return wrap;
    }

    function openComposer(
      fileEl: HTMLElement,
      file: string,
      line: number,
      lineEl: HTMLElement,
      editing?: Comment,
    ) {
      if (card.dataset.state) return;
      const thread = ensureThread(fileEl, line, lineEl);
      const open = thread.querySelector<HTMLTextAreaElement>('.cr-composer textarea');
      if (open) { open.focus(); return; }

      const composer = el('div', 'cr-composer');
      const ta = el('textarea');
      ta.placeholder = editing ? 'Edit your comment…' : 'Leave a review comment…';
      ta.value = editing?.text ?? '';

      const cancelBtn = btn('', 'Cancel');
      const saveBtn = btn('cr-composer-save', editing ? 'Save' : 'Comment');
      saveBtn.disabled = ta.value.trim() === '';

      const actions = el('div', 'cr-composer-actions');
      actions.append(cancelBtn, saveBtn);
      composer.append(ta, actions);
      thread.appendChild(composer);
      lineEl.dataset.crActive = 'true';
      ta.focus();

      ta.oninput = () => { saveBtn.disabled = ta.value.trim() === ''; };
      ta.onkeydown = (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
          e.preventDefault();
          if (!saveBtn.disabled) saveBtn.click();
        } else if (e.key === 'Escape') {
          e.preventDefault();
          cancelBtn.click();
        }
      };
      cancelBtn.onclick = () => {
        composer.remove();
        renderThread(fileEl, file, line, lineEl);
      };
      saveBtn.onclick = () => {
        const text = ta.value.trim();
        if (!text) return;
        const k = key(file, line);
        const arr = threads.get(k) ?? [];
        if (editing) {
          const i = arr.findIndex((x) => x.id === editing.id);
          if (i >= 0) arr[i] = { ...editing, text };
        } else {
          arr.push({ id: nextId++, text });
        }
        threads.set(k, arr);
        composer.remove();
        renderThread(fileEl, file, line, lineEl);
      };
    }

    const statusEl = card.querySelector<HTMLElement>('.cr-status')!;
    const modeEl = card.querySelector<HTMLElement>('.cr-feedback-mode')!;

    submitBtn.addEventListener('click', async () => {
      if (card.dataset.state) return;
      // Discard any open composer drafts; saved comments are already in `threads`.
      card.querySelectorAll<HTMLElement>('.cr-composer').forEach((c) => c.remove());

      // Only grade plants that received an on-line comment. Everything else
      // stays false by default per spec.
      const candidates: { issue: Issue; text: string }[] = [];
      issues.forEach((issue) => {
        const cs = threads.get(key(issue.file, issue.line)) ?? [];
        if (cs.length > 0) {
          candidates.push({ issue, text: cs.map((c) => c.text).join('\n\n') });
        }
      });

      let verdicts: boolean[] = candidates.map(() => false);
      let mode: 'comments' | 'lines' = 'lines';

      if (candidates.length > 0) {
        // Lock interactions while the model thinks. `pending` triggers the
        // same CSS gates as a finalized state (no new composers, no edits).
        card.dataset.state = 'pending';
        submitBtn.disabled = true;
        statusEl.textContent = 'Reviewing answer…';
        statusEl.hidden = false;

        try {
          verdicts = await gradeWithAI(candidates);
          mode = 'comments';
        } catch {
          // Ollama unreachable / malformed JSON: fall back to line-only grading.
          verdicts = candidates.map(() => true);
          mode = 'lines';
        }

        statusEl.hidden = true;
        statusEl.textContent = '';
      }

      const passByIssueIdx = new Map<number, boolean>();
      candidates.forEach((c, i) => {
        passByIssueIdx.set(issues.indexOf(c.issue), verdicts[i]);
      });

      issueList.innerHTML = '';
      let caught = 0;
      issues.forEach((issue, idx) => {
        const pass = passByIssueIdx.get(idx) ?? false;
        if (pass) caught++;

        const row = el('li', 'cr-issue-row');
        row.dataset.status = pass ? 'caught' : 'missed';

        const status = el('span', 'cr-issue-status');
        status.setAttribute('aria-hidden', 'true');
        const head = el('div', 'cr-issue-head');
        head.append(status, el('span', 'cr-issue-loc', `${issue.file}:${issue.line}`));

        const note = el('div', 'cr-issue-note');
        note.innerHTML = issue.noteHtml;

        row.append(head, note);
        issueList.appendChild(row);
      });

      card.dataset.state = caught === issues.length && issues.length > 0 ? 'correct' : 'partial';
      card.querySelector<HTMLElement>('.cr-feedback-title')!.textContent =
        `${caught} of ${issues.length} caught`;
      modeEl.textContent = mode === 'comments' ? 'Comments graded' : 'Lines graded';
      feedback.hidden = false;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitted';
      feedback.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });
</script>
