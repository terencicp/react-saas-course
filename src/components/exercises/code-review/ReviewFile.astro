---
// One file in a <CodeReview>. Renders a header with the filename and a slot
// for an Expressive Code block (typically using `ins={...}` / `del={...}`
// for diff gutters). Issue declarations placed inside this file's slot are
// hidden — the parent CodeReview script harvests them.
//
// We wrap in Starlight's <TabItem> so that when CodeReview detects multiple
// files in its slot, it can hand the lot straight to Starlight's <Tabs> —
// same primitive the rest of the docs use for tabbed content. <TabItem>
// emits a <starlight-tab-item> custom element that's transparent outside of
// <Tabs>, so single-file usage is visually unaffected.
import { TabItem } from '@astrojs/starlight/components';

interface Props {
  name: string;
}
const { name } = Astro.props;
---

<TabItem label={name}>
  <div class="cr-file" data-file={name}>
    <div class="cr-file-header">{name}</div>
    <div class="cr-file-body">
      <slot />
    </div>
  </div>
</TabItem>
