---
// One seeded "plant" for a <CodeReview>. Declares that line `line` of file
// `file` is something a senior would flag. The slot holds the senior's note
// — shown in the reveal panel for every plant, alongside its caught/missed
// status. A plant is "caught" iff the student left at least one comment on
// that exact file:line; the comment text itself is not inspected.
//
// The element is rendered hidden inside the file body purely as data; the
// CodeReview script harvests it on mount and removes it from the flow.
interface Props {
  file: string;
  line: number;
}
const { file, line } = Astro.props;
---

<div class="cr-issue" data-file={file} data-line={line} hidden>
  <slot />
</div>
