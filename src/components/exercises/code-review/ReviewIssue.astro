---
// One seeded "plant" for a <CodeReview>. Declares that line `line` of file
// `file` is something a senior would flag.
//
// `kernel` is the grading floor — a short phrase naming the single defect
// the student must identify (e.g. "missing tenant-scope filter"). It is
// the only thing sent to the AI grader. The slot holds the long-form
// senior reveal, shown after submit. Authoring the rubric (one phrase)
// separately from the reveal (a paragraph) keeps the bar where the lesson
// author meant it.
//
// `kernel` is optional for back-compat: when omitted, the grader falls
// back to the flattened slot text.
//
// The element is rendered hidden inside the file body purely as data; the
// CodeReview script harvests it on mount and removes it from the flow.
interface Props {
  file: string;
  line: number;
  kernel?: string;
}
const { file, line, kernel } = Astro.props;
---

<div class="cr-issue" data-file={file} data-line={line} data-kernel={kernel} hidden>
  <slot />
</div>
