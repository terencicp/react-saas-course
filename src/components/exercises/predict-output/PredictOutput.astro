---
// Predict-the-output drill. Wrap a fenced code block (Expressive Code handles
// syntax highlighting) and pass the program's literal stdout via `expected`.
// The student types their prediction into a console-styled textarea and
// presses Check; the script normalizes trailing whitespace and blank lines
// before comparing. An optional <PredictWhy> slot is shown only on a wrong answer.
//
// In MDX, multi-line `expected` values are easiest as a template string:
//   <PredictOutput expected={`line one\nline two`}>...</PredictOutput>
interface Props {
  expected: string;
  placeholder?: string;
  instructions?: string;
}
const { expected, placeholder = 'Type the predicted output…', instructions } = Astro.props;

// Size the textarea to the expected answer so the input box visually mirrors
// the volume of output the student is being asked to predict.
const expectedRows = Math.max(1, expected.replace(/^\n+|\n+$/g, '').split('\n').length);
---

<div class="po-card not-content" data-expected={expected}>
  <div class="po-body">
    <p class="po-prompt">
      {instructions && <>{instructions}{' '}</>}
      Predict what this program prints, then press <strong>Check</strong>.
    </p>

    <slot />

    <div class="po-console">
      <textarea
        class="po-input"
        spellcheck="false"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        placeholder={placeholder}
        rows={expectedRows}></textarea>
    </div>

    <div class="po-feedback" hidden>
      <div class="po-feedback-head">
        <span class="po-feedback-icon" aria-hidden="true"></span>
        <span class="po-feedback-text"></span>
      </div>
      <div class="po-feedback-body">
        <div class="po-feedback-expected" hidden>
          <div class="po-expected-label">Expected output</div>
          <pre class="po-expected-code"></pre>
        </div>
      </div>
    </div>

    <div class="po-actions">
      <button type="button" class="po-check">Check</button>
    </div>
  </div>
</div>

<style is:global>
  .po-card {
    --po-surface: var(--sl-color-bg-nav);
    --po-text: var(--sl-color-white);
    --po-muted: var(--sl-color-gray-3);
    --po-accent: var(--sl-color-accent);
    --po-border: var(--sl-color-gray-5);
    --po-hover: var(--sl-color-gray-6);
    --po-correct: #4ade80;
    --po-correct-bg: #14532d;
    --po-correct-text: #bbf7d0;
    --po-wrong: #f87171;
    --po-wrong-bg: #7f1d1d;
    --po-wrong-text: #fecaca;

    color: var(--po-text);
    line-height: 1.6;
    background: var(--po-surface);
    border: 1px solid var(--po-border);
    border-radius: 12px;
    padding: 20px 22px;
    margin-bottom: 16px;
  }
  :root[data-theme='light'] .po-card {
    --po-correct: #16a34a;
    --po-correct-bg: #dcfce7;
    --po-correct-text: #14532d;
    --po-wrong: #dc2626;
    --po-wrong-bg: #fee2e2;
    --po-wrong-text: #7f1d1d;
  }
  .po-card * { box-sizing: border-box; }

  .po-prompt {
    color: var(--po-muted);
    font-size: 14px;
    margin: 0 0 14px;
  }
  .po-body > p { margin: 0 0 14px; }
  .po-body code:not(pre code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9em;
    background: var(--po-hover);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .po-body .expressive-code { margin: 0 0 14px; }

  /* Console-styled textarea — fixed dark theme to read as a terminal even
     when the page is in light mode. */
  .po-console {
    background: #0d1117;
    color: #e6edf3;
    border: 1px solid #30363d;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 14px;
  }
  .po-input {
    display: block;
    width: 100%;
    padding: 12px 14px;
    background: transparent;
    border: 0;
    color: inherit;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 13.5px;
    line-height: 1.55;
    resize: vertical;
    outline: none;
    white-space: pre;
    overflow: auto;
    tab-size: 4;
    -moz-tab-size: 4;
  }
  .po-input::placeholder {
    color: #6e7681;
    font-style: italic;
  }
  .po-input:disabled {
    cursor: default;
    opacity: 0.85;
  }

  /* Feedback panel — collapses to a green pill when correct,
     expands into a red panel with explanation + expected when wrong. */
  .po-feedback {
    margin-bottom: 14px;
    border-radius: 8px;
    border: 1px solid transparent;
    overflow: hidden;
  }
  .po-feedback[hidden] { display: none; }
  .po-feedback-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    font-size: 14px;
    font-weight: 600;
  }
  .po-feedback-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    color: white;
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    flex-shrink: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }

  /* Correct: just a green check + label, no container. */
  .po-card[data-state='correct'] .po-feedback {
    display: inline-flex;
    background: transparent;
    border-color: transparent;
    color: var(--po-correct);
    margin-bottom: 0;
  }
  .po-card[data-state='correct'] .po-feedback-head {
    padding: 0;
  }
  .po-card[data-state='correct'] .po-feedback-icon {
    background: var(--po-correct);
  }
  .po-card[data-state='correct'] .po-feedback-icon::before { content: '\2713'; }
  .po-card[data-state='correct'] .po-feedback-body { display: none; }
  .po-card[data-state='correct'] .po-actions { display: none; }

  /* Wrong: neutral panel — only icon and title carry the red. */
  .po-card[data-state='wrong'] .po-feedback {
    display: block;
    background: var(--po-hover);
    border-color: var(--po-border);
    color: var(--po-text);
  }
  .po-card[data-state='wrong'] .po-feedback-head {
    color: var(--po-wrong);
  }
  .po-card[data-state='wrong'] .po-feedback:has(.po-feedback-body:not([hidden])) .po-feedback-head {
    border-bottom: 1px solid var(--po-border);
  }
  .po-feedback-body[hidden] { display: none; }
  .po-card[data-state='wrong'] .po-feedback-icon {
    background: var(--po-wrong);
  }
  .po-card[data-state='wrong'] .po-feedback-icon::before { content: '\2715'; }
  .po-card[data-state='wrong'] .po-feedback-body {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Why content — rendered hidden by default; the script moves it into the
     feedback body, where it inherits the panel's coloring. */
  .po-feedback-body .po-why {
    margin: 0;
    font-size: 14px;
    color: inherit;
  }
  .po-feedback-body .po-why > :first-child { margin-top: 0; }
  .po-feedback-body .po-why > :last-child { margin-bottom: 0; }
  .po-feedback-body .po-why > p { margin: 0; }
  .po-feedback-body .po-why code:not(pre code) {
    background: var(--po-surface);
    color: inherit;
  }

  .po-feedback-expected {
    background: var(--po-surface);
    border: 1px solid var(--po-border);
    border-radius: 6px;
    padding: 10px 12px;
  }
  .po-expected-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
    opacity: 0.85;
  }
  .po-expected-code {
    margin: 0;
    padding: 0;
    background: transparent;
    border: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 13.5px;
    line-height: 1.55;
    color: inherit;
    white-space: pre-wrap;
    overflow-x: auto;
  }

  .po-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .po-check {
    background: var(--po-accent);
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 8px;
    font: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .po-check:hover:not(:disabled) { opacity: 0.9; }
  .po-check:disabled { opacity: 0.4; cursor: not-allowed; }
</style>

<script>
  function normalize(s: string): string {
    return s
      .split('\n')
      .map((l) => l.replace(/[ \t]+$/, ''))
      .join('\n')
      .replace(/^\n+|\n+$/g, '');
  }

  document.querySelectorAll<HTMLElement>('.po-card').forEach((card) => {
    const expectedRaw = card.dataset.expected ?? '';
    const expected = normalize(expectedRaw);
    const input = card.querySelector<HTMLTextAreaElement>('.po-input')!;
    const checkBtn = card.querySelector<HTMLButtonElement>('.po-check')!;
    const feedback = card.querySelector<HTMLElement>('.po-feedback')!;
    const feedbackBody = card.querySelector<HTMLElement>('.po-feedback-body')!;
    const feedbackText = card.querySelector<HTMLElement>('.po-feedback-text')!;
    const expectedBox = card.querySelector<HTMLElement>('.po-feedback-expected')!;
    const expectedCode = card.querySelector<HTMLElement>('.po-expected-code')!;

    // Move the <PredictWhy> slot content (rendered earlier in the body) into the
    // wrong-feedback panel so the wrong state shows explanation + expected
    // together. Unhide it; visibility is now driven by the feedback panel.
    const why = card.querySelector<HTMLElement>('.po-body > .po-why, .po-body .po-why');
    if (why && !feedbackBody.contains(why)) {
      feedbackBody.insertBefore(why, feedbackBody.firstChild);
      why.hidden = false;
    }
    const hasWhy = !!feedbackBody.querySelector('.po-why');

    let attempts = 0;

    function check() {
      attempts++;
      const got = normalize(input.value);
      const isCorrect = got === expected;
      card.dataset.state = isCorrect ? 'correct' : 'wrong';
      feedbackText.textContent = isCorrect ? 'Correct' : 'Not quite';
      expectedCode.textContent = expected;
      feedback.hidden = false;
      if (isCorrect) {
        input.disabled = true;
        checkBtn.hidden = true;
        return;
      }
      // Wrong: leave the input editable and the button visible. The first
      // wrong attempt withholds the expected output so the student has a
      // chance to fix it on their own; from the second attempt on, reveal it.
      checkBtn.textContent = 'Try again';
      expectedBox.hidden = attempts < 2;
      feedbackBody.hidden = !hasWhy && expectedBox.hidden;
    }

    checkBtn.addEventListener('click', check);

    // Cmd/Ctrl-Enter inside the textarea submits.
    input.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
        e.preventDefault();
        if (!checkBtn.hidden) check();
      }
    });
  });
</script>
