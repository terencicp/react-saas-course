---
interface Props {
  name: string;
  label: string;
  description?: string;
}
const { name, label, description } = Astro.props;
---

<div class="bk-bucket" data-key={name}>
  <div class="bk-bucket-head">
    <span class="bk-bucket-label">{label}</span>
    {description && <span class="bk-bucket-desc">{description}</span>}
  </div>
  <div class="bk-bucket-items" data-items></div>
</div>
