---
// Bucket-classification drill. Wrap <Bucket> definitions and <Item> children
// inside; each item has a `bucket` prop matching the target bucket's `name`.
// `twoCol` lays buckets out in two columns; default is one full-width column.
interface Props {
  twoCol?: boolean;
}
const { twoCol = false } = Astro.props;
---

<div class="bk-drill not-content" data-two-col={twoCol ? 'true' : 'false'}>
  <p class="bk-prompt">
    Drag each item into the bucket it belongs to, then press <strong>Check</strong>.
  </p>

  <div class="bk-source" data-source><slot /></div>

  <div class="bk-pool" data-pool></div>
  <div class="bk-buckets" data-buckets></div>

  <div class="bk-actions">
    <button type="button" class="bk-btn bk-btn-check" data-check>Check</button>
    <button type="button" class="bk-btn bk-btn-reset" data-reset>Reset</button>
  </div>
</div>

<style is:global>
  .bk-drill {
    --bk-surface: var(--sl-color-bg-nav);
    --bk-surface-2: var(--sl-color-bg-sidebar);
    --bk-text: var(--sl-color-white);
    --bk-muted: var(--sl-color-gray-3);
    --bk-accent: var(--sl-color-accent);
    --bk-border: var(--sl-color-gray-5);
    --bk-chip-bg: var(--sl-color-gray-6);

    --bk-correct: #4ade80;
    --bk-correct-bg: #14532d;
    --bk-wrong: #f87171;
    --bk-wrong-bg: #7f1d1d;

    color: var(--bk-text);
    line-height: 1.6;
    border: 1px solid var(--bk-border);
    background: var(--bk-surface);
    border-radius: 12px;
    padding: 18px 20px;
  }
  :root[data-theme='light'] .bk-drill {
    --bk-correct: #16a34a;
    --bk-correct-bg: #dcfce7;
    --bk-wrong: #dc2626;
    --bk-wrong-bg: #fee2e2;
  }

  .bk-drill * { box-sizing: border-box; }

  .bk-prompt {
    color: var(--bk-muted);
    font-size: 14px;
    margin: 0 0 14px;
  }

  /* Source slot — items start hidden here, then JS moves them into the pool. */
  .bk-source { display: none; }

  .bk-pool {
    background: var(--bk-surface-2);
    border: 1px solid var(--bk-border);
    border-radius: 10px;
    padding: 12px;
    min-height: 56px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
    transition: border-color 0.12s, background-color 0.12s;
  }
  .bk-pool.over {
    border-color: var(--bk-accent);
    background: var(--bk-surface);
  }

  .bk-buckets {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-bottom: 14px;
  }
  .bk-drill[data-two-col='true'] .bk-buckets {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  @media (max-width: 540px) {
    .bk-drill[data-two-col='true'] .bk-buckets {
      grid-template-columns: 1fr;
    }
  }

  .bk-bucket {
    background: var(--bk-surface-2);
    border: 2px dashed var(--bk-border);
    border-radius: 10px;
    padding: 12px;
    min-height: 110px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color 0.12s, background-color 0.12s;
  }
  .bk-bucket.over {
    border-color: var(--bk-accent);
    background: var(--bk-surface);
  }
  .bk-bucket-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 4px 2px;
  }
  .bk-bucket-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bk-text);
  }
  .bk-bucket-desc {
    font-size: 12.5px;
    color: var(--bk-muted);
    font-weight: 400;
    letter-spacing: normal;
    text-transform: none;
  }
  .bk-bucket-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-height: 36px;
    flex: 1;
  }

  .bk-item {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 16px;
    background: var(--bk-chip-bg);
    color: var(--bk-text);
    border: 1px solid var(--bk-border);
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 13px;
    cursor: grab;
    user-select: none;
    transition: transform 0.12s, box-shadow 0.12s, opacity 0.12s, border-color 0.12s, background-color 0.12s;
  }
  .bk-item:active { cursor: grabbing; }
  .bk-item.dragging { opacity: 0.4; transform: scale(0.95); }
  .bk-item.selected {
    border-color: var(--bk-accent);
    box-shadow: 0 0 0 2px var(--bk-accent);
  }
  .bk-item.right {
    border-color: var(--bk-correct);
    background: var(--bk-correct-bg);
    color: var(--bk-correct);
  }
  .bk-item.wrong {
    border-color: var(--bk-wrong);
    background: var(--bk-wrong-bg);
    color: var(--bk-wrong);
  }
  /* Wrong-only badge for colorblind accessibility */
  .bk-item.wrong::after {
    content: "\2717";
    position: absolute;
    top: -7px;
    right: -7px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    background: var(--bk-wrong);
    color: var(--bk-wrong-bg);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }
  /* Inline content inherits chip styling. */
  .bk-item code {
    font: inherit;
    background: transparent;
    padding: 0;
    border: 0;
    color: inherit;
  }
  /* Items containing a fenced code block (Expressive Code) get a roomier chip. */
  .bk-item:has(.expressive-code) {
    padding: 4px;
    border-radius: 8px;
    align-items: stretch;
  }
  .bk-item .expressive-code {
    margin: 0;
  }

  .bk-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .bk-btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--bk-border);
    background: var(--bk-surface-2);
    color: var(--bk-text);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.14s, border-color 0.14s, opacity 0.14s;
  }
  .bk-btn:hover { border-color: var(--bk-accent); }
  .bk-btn-check {
    background: var(--bk-accent);
    color: white;
    border-color: var(--bk-accent);
  }
  .bk-btn-check:hover { opacity: 0.9; border-color: var(--bk-accent); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.bk-drill').forEach((root) => {
    const source = root.querySelector<HTMLElement>('[data-source]');
    const pool = root.querySelector<HTMLElement>('[data-pool]');
    const bucketsContainer = root.querySelector<HTMLElement>('[data-buckets]');
    const checkBtn = root.querySelector<HTMLButtonElement>('[data-check]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]');
    if (!source || !pool || !bucketsContainer || !checkBtn || !resetBtn) return;

    const buckets = Array.from(source.querySelectorAll<HTMLElement>('.bk-bucket'));
    buckets.forEach((b) => bucketsContainer.appendChild(b));

    function shuffle<T>(a: T[]): T[] {
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    const items = Array.from(source.querySelectorAll<HTMLElement>('.bk-item'));
    shuffle(items.slice()).forEach((i) => pool.appendChild(i));
    source.remove();

    let dragged: HTMLElement | null = null;
    let selected: HTMLElement | null = null;

    function clearMark(el: HTMLElement) {
      el.classList.remove('right', 'wrong');
    }

    function moveTo(target: HTMLElement, item: HTMLElement) {
      target.appendChild(item);
      clearMark(item);
    }

    items.forEach((item) => {
      item.addEventListener('dragstart', (e) => {
        dragged = item;
        item.classList.add('dragging');
        if (e.dataTransfer) {
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('text/plain', '');
        }
      });
      item.addEventListener('dragend', () => {
        item.classList.remove('dragging');
        dragged = null;
      });
      // Tap-to-select fallback for touch devices.
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        if (selected === item) {
          item.classList.remove('selected');
          selected = null;
          return;
        }
        if (selected) selected.classList.remove('selected');
        selected = item;
        item.classList.add('selected');
      });
    });

    function setupZone(zone: HTMLElement, target: HTMLElement) {
      zone.addEventListener('dragover', (e) => {
        e.preventDefault();
        zone.classList.add('over');
      });
      zone.addEventListener('dragleave', (e) => {
        if (e.target === zone) zone.classList.remove('over');
      });
      zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.classList.remove('over');
        if (!dragged) return;
        moveTo(target, dragged);
      });
      zone.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.bk-item')) return;
        if (!selected) return;
        const cur = selected;
        cur.classList.remove('selected');
        selected = null;
        moveTo(target, cur);
      });
    }

    setupZone(pool, pool);
    buckets.forEach((b) => {
      const itemsZone = b.querySelector<HTMLElement>('[data-items]');
      if (itemsZone) setupZone(b, itemsZone);
    });

    checkBtn.addEventListener('click', () => {
      items.forEach((item) => {
        clearMark(item);
        const inBucket = item.parentElement?.closest('.bk-bucket') as HTMLElement | null;
        if (!inBucket) return;
        item.classList.add(inBucket.dataset.key === item.dataset.bucket ? 'right' : 'wrong');
      });
    });

    resetBtn.addEventListener('click', () => {
      items.forEach((i) => {
        clearMark(i);
        i.classList.remove('selected');
        pool.appendChild(i);
      });
      selected = null;
    });
  });
</script>
