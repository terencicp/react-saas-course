---
// Ordering drill. Wrap <Step> children inside; source order is the correct
// order, and the list is shuffled on render. Optionally include a fenced code
// block in the slot before the steps (Expressive Code handles highlights via
// the usual `{1,3-5}` line-highlight syntax).
interface Props {
  instructions?: string;
}
const { instructions } = Astro.props;
---

<div class="sq-drill not-content">
  <p class="sq-prompt">
    {instructions && <>{instructions}{' '}</>}
    Drag the items into the correct order, then press <strong>Check</strong>.
  </p>

  <div class="sq-source" data-source><slot /></div>

  <div class="sq-stage" data-stage></div>

  <div class="sq-actions">
    <button type="button" class="sq-btn sq-btn-check" data-check>Check</button>
    <button type="button" class="sq-btn sq-btn-reset" data-reset>Reset</button>
  </div>
</div>

<style is:global>
  .sq-drill {
    --sq-surface: var(--sl-color-bg-nav);
    --sq-surface-2: var(--sl-color-bg-sidebar);
    --sq-text: var(--sl-color-white);
    --sq-muted: var(--sl-color-gray-3);
    --sq-accent: var(--sl-color-accent);
    --sq-border: var(--sl-color-gray-5);
    --sq-pill-bg: var(--sl-color-gray-6);

    --sq-correct: #4ade80;
    --sq-correct-bg: #14532d;
    --sq-wrong: #f87171;
    --sq-wrong-bg: #7f1d1d;

    color: var(--sq-text);
    line-height: 1.6;
    border: 1px solid var(--sq-border);
    background: var(--sq-surface);
    border-radius: 12px;
    padding: 18px 20px;
  }
  :root[data-theme='light'] .sq-drill {
    --sq-correct: #16a34a;
    --sq-correct-bg: #dcfce7;
    --sq-wrong: #dc2626;
    --sq-wrong-bg: #fee2e2;
  }

  .sq-drill * { box-sizing: border-box; }

  .sq-prompt {
    color: var(--sq-muted);
    font-size: 14px;
    margin: 0 0 14px;
  }

  .sq-source { display: none; }

  .sq-stage { margin-bottom: 14px; }
  .sq-stage > :first-child { margin-top: 0; }
  .sq-stage > :last-child { margin-bottom: 0; }
  .sq-stage .expressive-code { margin: 0 0 12px; }

  .sq-list {
    counter-reset: step;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: 40px;
  }

  .sq-step {
    counter-increment: step;
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: var(--sq-pill-bg);
    color: var(--sq-text);
    border: 1px solid var(--sq-border);
    border-radius: 8px;
    font-size: 13.5px;
    font-weight: 500;
    cursor: grab;
    user-select: none;
    transition: background-color 0.12s, color 0.12s;
  }
  .sq-step:active { cursor: grabbing; }
  /* Live-move drop preview: while dragging, the item itself is the indicator —
     dashed outline at the would-be drop position, contents hidden so it reads
     as a placeholder slot. */
  .sq-step.dragging {
    background: transparent;
    border-style: dashed;
    border-color: var(--sq-accent);
    color: var(--sq-muted);
  }
  .sq-step.dragging > * { opacity: 0.5; }

  /* Position number circle, outside the step's right edge — same shape as
     Starlight's <Steps> bullets. The number reflects DOM order, so it always
     reads 1…n top-to-bottom. */
  .sq-step::before {
    content: counter(step);
    position: absolute;
    right: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    border: 1px solid var(--sq-border);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--sq-muted);
    background: var(--sq-surface);
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
  }

  .sq-handle {
    color: var(--sq-muted);
    line-height: 1;
    flex: 0 0 auto;
    font-size: 16px;
    letter-spacing: -2px;
  }
  .sq-label { flex: 1; }

  .sq-step code {
    font: inherit;
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    background: transparent;
    padding: 0;
    border: 0;
    color: inherit;
  }

  .sq-step.right,
  .sq-step.wrong { padding-right: 36px; }
  .sq-step.right {
    border-color: var(--sq-correct);
    background: var(--sq-correct-bg);
    color: var(--sq-correct);
  }
  .sq-step.wrong {
    border-color: var(--sq-wrong);
    background: var(--sq-wrong-bg);
    color: var(--sq-wrong);
    border-style: dashed;
  }
  .sq-step.right::after,
  .sq-step.wrong::after {
    position: absolute;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }
  .sq-step.right::after { content: "\2713"; background: var(--sq-correct-bg); }
  .sq-step.wrong::after { content: "\2717"; background: var(--sq-wrong-bg); }

  .sq-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .sq-btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--sq-border);
    background: var(--sq-surface-2);
    color: var(--sq-text);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.14s, border-color 0.14s, opacity 0.14s;
  }
  .sq-btn:hover:not(:disabled) { border-color: var(--sq-accent); }
  .sq-btn:disabled { opacity: 0.45; cursor: default; }
  .sq-btn-check {
    background: var(--sq-accent);
    color: white;
    border-color: var(--sq-accent);
  }
  .sq-btn-check:hover:not(:disabled) { opacity: 0.9; border-color: var(--sq-accent); }
  .sq-btn-check:disabled {
    background: var(--sq-surface-2);
    color: var(--sq-muted);
    border-color: var(--sq-border);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.sq-drill').forEach((root) => {
    const source = root.querySelector<HTMLElement>('[data-source]');
    const stage = root.querySelector<HTMLElement>('[data-stage]');
    const checkBtn = root.querySelector<HTMLButtonElement>('[data-check]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]');
    if (!source || !stage || !checkBtn || !resetBtn) return;

    // Capture steps in source order; everything else (e.g. an Expressive Code
    // block) keeps its place and renders above the list.
    const steps = Array.from(source.querySelectorAll<HTMLElement>('.sq-step'));
    steps.forEach((s, i) => { s.dataset.correct = String(i); });

    const list = document.createElement('div');
    list.className = 'sq-list';

    while (source.firstChild) {
      const node = source.firstChild;
      if (node instanceof HTMLElement && node.classList.contains('sq-step')) {
        source.removeChild(node);
      } else {
        stage.appendChild(node);
      }
    }
    stage.appendChild(list);
    source.remove();

    function shuffle<T>(a: T[]): T[] {
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function clearMarks() {
      steps.forEach((s) => s.classList.remove('right', 'wrong'));
      checkBtn.disabled = false;
    }

    function reshuffle() {
      const order = shuffle(steps.slice());
      // Avoid the rare case where a "shuffle" lands back on the correct order.
      if (steps.length > 1 && order.every((s, i) => s === steps[i])) {
        [order[0], order[1]] = [order[1], order[0]];
      }
      order.forEach((s) => list.appendChild(s));
      clearMarks();
    }

    // 1×1 transparent gif — used as a custom drag image so the browser doesn't
    // render its own opaque snapshot ghosting next to the cursor. The dashed
    // placeholder slot is the only drop indicator we want.
    const blankImg = new Image();
    blankImg.src =
      'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7';

    let dragged: HTMLElement | null = null;

    steps.forEach((step) => {
      step.addEventListener('dragstart', (e) => {
        dragged = step;
        step.classList.add('dragging');
        e.dataTransfer?.setData('text/plain', '');
        e.dataTransfer?.setDragImage(blankImg, 0, 0);
      });
      step.addEventListener('dragend', () => {
        step.classList.remove('dragging');
        dragged = null;
      });
    });

    // Live-move: as the cursor passes another step's midpoint, slide the
    // dragged item into that position immediately. The dashed placeholder
    // (.dragging) shows the landing slot, so the user always sees where it
    // will end up.
    list.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (!dragged) return;
      const target = (e.target as HTMLElement).closest<HTMLElement>('.sq-step');
      if (!target || target === dragged) return;
      const r = target.getBoundingClientRect();
      const above = e.clientY - r.top < r.height / 2;
      const ref = above ? target : target.nextSibling;
      if (dragged.nextSibling === ref || dragged === ref) return;
      list.insertBefore(dragged, ref);
      clearMarks();
    });

    list.addEventListener('drop', (e) => {
      e.preventDefault();
    });

    checkBtn.addEventListener('click', () => {
      let allRight = true;
      Array.from(list.children).forEach((node, i) => {
        const s = node as HTMLElement;
        const ok = s.dataset.correct === String(i);
        s.classList.toggle('right', ok);
        s.classList.toggle('wrong', !ok);
        if (!ok) allRight = false;
      });
      checkBtn.disabled = allRight;
    });

    resetBtn.addEventListener('click', reshuffle);

    reshuffle();
  });
</script>
