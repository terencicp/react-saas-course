---
// Basic live-coding widget with assertions. CodeMirror 6 editor + a runner
// that executes the student's code and a tiny jest-flavoured `test`/`expect`
// shim. The default runner is "vanilla" (own iframe sandbox, ~80 KB, instant
// boot, plain JS only). Opt into "sandpack" for code that needs Sandpack's
// in-browser bundler (JSX/TS/Tailwind/npm) — heavier and network-dependent.
//
// MDX usage:
//   <ScriptCoding
//     starter={`function add(a, b) { /* … */ }`}
//     tests={`test('adds positive numbers', () => { expect(add(2,3)).toBe(5); });`}
//   />
//   <ScriptCoding runner="sandpack" starter={...} tests={...} />
//
// Assertion API (both runners): `test(name, fn)`,
// `expect(x).toBe`/`.toEqual`/`.toBeTruthy`/`.toBeFalsy`/`.toBeCloseTo`
// /`.toThrow`/`.toContain`/`.not.*`.
import LiveCoding from '../_shared/LiveCoding.astro';

type Runner = 'vanilla' | 'sandpack';
interface Props {
    starter: string;
    tests: string;
    instructions?: string;
    maxHeight?: number;
    runner?: Runner;
}
const {
    starter,
    tests,
    instructions,
    maxHeight = 320,
    runner = 'vanilla',
} = Astro.props;
---

<LiveCoding
    variant="script"
    instructions={instructions}
    controls="toolbar"
    runLabel="Run tests"
    hasStatus={runner === 'sandpack'}
    style={`--lc-max-h: ${maxHeight}px`}
    data={{ starter, runner, tests }}
>
    <div slot="output">
        <ul class="lc-results"></ul>
        <div class="lc-script-console" hidden>
            <div class="lc-script-console-label">Output</div>
            <pre class="lc-script-console-body"></pre>
        </div>
        {runner === 'sandpack' && (
            // `credentialless` is required because the site sends
            // `COEP: credentialless` (see astro.config.mjs). Sandpack reuses
            // this iframe and navigates it to its cross-origin bundler URL —
            // without the attribute the load is blocked with
            // `net::ERR_BLOCKED_BY_RESPONSE` and the inner UI never boots.
            <iframe class="lc-script-runner-iframe" aria-hidden="true" tabindex="-1" credentialless></iframe>
        )}
    </div>
</LiveCoding>

<style is:global>
    /* Run button starts disabled in sandpack mode (until the bundler boots). */
    .lc-script[data-runner='sandpack'] .lc-run[disabled] {
        opacity: 0.5;
    }

    /* Console output pane — GitHub-dark style; specific to ScriptCoding. */
    .lc-script .lc-script-console {
        margin-top: 12px;
        border: 1px solid var(--lc-border);
        border-radius: 8px;
        overflow: hidden;
        background: #0d1117;
    }
    .lc-script .lc-script-console[hidden] { display: none; }
    .lc-script .lc-script-console-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6e7681;
        padding: 6px 12px;
        border-bottom: 1px solid #30363d;
    }
    .lc-script .lc-script-console-body {
        margin: 0;
        padding: 10px 12px;
        background: transparent;
        color: #e6edf3;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 13px;
        line-height: 1.5;
        white-space: pre-wrap;
        overflow-x: auto;
    }
    .lc-script .lc-console-line[data-method='error'] { color: #f87171; }
    .lc-script .lc-console-line[data-method='warn'] { color: #fbbf24; }

    /* Sandpack runner's bundler iframe — hidden but kept in flow so the
       SandpackClient has a valid target. */
    .lc-script[data-runner='sandpack'] iframe.lc-script-runner-iframe {
        width: 1px;
        height: 1px;
        position: absolute;
        left: -9999px;
        border: 0;
    }
</style>

<script>
    import './bootstrap';
</script>
