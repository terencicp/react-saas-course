---
// Type-only live-coding widget. CodeMirror 6 editor over an in-browser
// TypeScript LanguageService (via @typescript/vfs). The student never executes
// code — the exercise is "make tsc quiet" and (optionally) resolve Twoslash
// `^?` queries to the expected types.
//
// MDX usage:
//   <TypeCoding
//     starter={`const colors = { red: '#f00' } satisfies Record<string, string>;`}
//     instructions="Add `satisfies` so autocomplete on `colors` keeps the literal keys."
//   />
//
// To author a Twoslash-style query, add a comment line with `^?` under the
// expression whose type you want shown:
//
//   const c: ColorName = 'red';
//   //       ^?
//
// The widget renders the resolved type below the editor.
// Pass criteria. Without them the card is a pure sandbox: status only flips
// between "No type errors" and "N errors". When either array is non-empty the
// card becomes an exercise — a checklist renders below and the status turns
// green ✓ only when every criterion is met AND no unexpected errors exist.
type ExpectedQuery = {
  /** 1-indexed line of the `^?` marker. */
  line: number;
  /** Substring that must appear in the resolved type's display string. */
  contains: string;
};
type ExpectedError = {
  /** Substring that must appear in the diagnostic message. */
  contains: string;
  /** Optional 1-indexed line constraint. */
  line?: number;
};
type Props = {
  starter: string;
  instructions?: string;
  /**
   * Cap, in pixels, on the editor's height. The editor auto-sizes to its
   * starter; this only kicks in for code longer than the cap, after which
   * the editor scrolls.
   */
  maxHeight?: number;
  expectedQueries?: ExpectedQuery[];
  expectedErrors?: ExpectedError[];
};
const {
  starter,
  instructions,
  maxHeight = 320,
  expectedQueries = [],
  expectedErrors = [],
} = Astro.props as Props;

// "Fix all errors" only renders as a checklist row when it's the lesson's
// sole goal. Once a lesson pins explicit criteria (queries or expected errors),
// "no errors remain" is baseline behavior — the errors panel at the bottom
// of the card already makes any leftover errors loud — and shouldn't take up
// a row in the checklist too.
const showCleanCriterion =
  expectedQueries.length === 0 && expectedErrors.length === 0;
---

<div class="tc-card not-content">
  {instructions && <p class="tc-instructions">{instructions}</p>}
  <ul class="tc-criteria">
    {expectedQueries.map((q) => (
      <li class="tc-criterion" data-kind="query" data-contains={q.contains} data-met="false">
        <span class="tc-criterion-icon" aria-hidden="true"></span>
        <span class="tc-criterion-text">
          Type query at line {q.line} must resolve to a type containing <code>{q.contains}</code>
        </span>
      </li>
    ))}
    {expectedErrors.map((e) => (
      <li class="tc-criterion" data-kind="error" data-line={e.line ?? ''} data-contains={e.contains} data-met="false">
        <span class="tc-criterion-icon" aria-hidden="true"></span>
        <span class="tc-criterion-text">
          {e.line ? <>Error on line {e.line}</> : <>Some error</>} must mention <code>{e.contains}</code>
        </span>
      </li>
    ))}
    {showCleanCriterion && (
      <li class="tc-criterion" data-kind="clean" data-met="false">
        <span class="tc-criterion-icon" aria-hidden="true"></span>
        <span class="tc-criterion-text">Fix all errors</span>
      </li>
    )}
  </ul>
  <div class="tc-editor" style={`--tc-max-h:${maxHeight}px`} data-starter={starter}>
    <span class="tc-boot" aria-live="polite">Booting type-checker…</span>
    <button class="tc-feedback-btn" type="button">Feedback</button>
    <button class="tc-reset" type="button">Reset</button>
  </div>
  <div class="tc-queries" hidden>
    <ul class="tc-queries-list"></ul>
  </div>
  <div class="tc-feedback" hidden>
    <div class="tc-feedback-head">
      <span class="tc-feedback-title">AI feedback</span>
    </div>
    <div class="tc-feedback-stream"></div>
  </div>
  <ul class="tc-diagnostics" hidden></ul>
</div>

<style is:global>
  .tc-card {
    --tc-surface: var(--sl-color-bg-nav);
    --tc-text: var(--sl-color-white);
    --tc-muted: var(--sl-color-gray-3);
    --tc-accent: var(--sl-color-accent);
    --tc-border: var(--sl-color-gray-5);
    --tc-hover: var(--sl-color-gray-6);
    --tc-pass: #16a34a;
    --tc-pass-bg: rgba(22, 163, 74, 0.12);
    --tc-fail: #dc2626;
    --tc-fail-bg: rgba(220, 38, 38, 0.12);
    --tc-warn: #d97706;
    --tc-warn-bg: rgba(217, 119, 6, 0.12);

    color: var(--tc-text);
    background: var(--tc-surface);
    border: 1px solid var(--tc-border);
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 16px;
  }
  .tc-card * { box-sizing: border-box; }

  .tc-instructions {
    margin: 0 0 14px;
    color: var(--tc-text);
    font-size: 1rem;
    line-height: 1.55;
  }

  .tc-editor {
    position: relative;
    border: 1px solid var(--tc-border);
    border-radius: 8px;
    overflow: hidden;
  }
  .tc-editor .cm-editor {
    height: auto;
    min-height: 64px;
    max-height: var(--tc-max-h, 320px);
  }
  .tc-editor .cm-scroller {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 13.5px;
    overflow: auto;
  }

  /* Reset chip — bottom-right inside the editor. Muted by default so it doesn't
     compete with the code; opacity goes to full on hover. Sits on top of the
     scroller, so if the cursor is on the last visible line the chip overlays;
     that's tolerable for a small element that the student rarely needs. */
  .tc-reset {
    position: absolute;
    bottom: 8px;
    right: 8px;
    z-index: 2;
    font: inherit;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 6px;
    border: 1px solid var(--tc-border);
    cursor: pointer;
    background: var(--tc-surface);
    color: var(--tc-muted);
    opacity: 0.45;
    transition: opacity 0.15s, color 0.15s;
  }
  .tc-reset:hover,
  .tc-reset:focus-visible {
    opacity: 1;
    color: var(--tc-text);
  }

  /* Feedback chip — top-right twin of the Reset chip. Same muted styling so it
     doesn't compete with the code; sits in the top-right so the two action
     chips bracket the editor diagonally. Disabled state dims it further. */
  .tc-feedback-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 2;
    font: inherit;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 6px;
    border: 1px solid var(--tc-border);
    cursor: pointer;
    background: var(--tc-surface);
    color: var(--tc-muted);
    opacity: 0.45;
    transition: opacity 0.15s, color 0.15s;
  }
  .tc-feedback-btn:hover:not(:disabled),
  .tc-feedback-btn:focus-visible:not(:disabled) {
    opacity: 1;
    color: var(--tc-text);
  }
  .tc-feedback-btn:disabled {
    cursor: not-allowed;
    opacity: 0.25;
  }

  /* AI feedback panel — sits between the type queries and the diagnostics list.
     Grey left stripe (rather than accent) so it reads as ancillary commentary,
     not a status signal like the red error band below. */
  .tc-feedback {
    margin-top: 12px;
    padding: 10px 12px;
    background: rgba(127, 127, 127, 0.08);
    border-left: 3px solid var(--tc-border);
    border-radius: 4px;
    font-size: 13px;
    color: var(--tc-text);
    line-height: 1.55;
  }
  .tc-feedback[hidden] { display: none; }
  .tc-feedback-head { margin-bottom: 6px; }
  .tc-feedback-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tc-muted);
  }
  .tc-card[data-feedback-state='pending'] .tc-feedback-title::after {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-left: 6px;
    border-radius: 50%;
    background: currentColor;
    animation: tc-pulse 1.2s infinite ease-in-out;
    vertical-align: middle;
  }
  .tc-feedback-stream {
    white-space: pre-wrap;
    word-wrap: break-word;
    min-height: 1.4em;
  }

  /* Boot indicator — bottom-left inside the editor. Mirrors the Reset chip's
     muted style and hides after the first successful check. */
  .tc-boot {
    position: absolute;
    bottom: 8px;
    left: 8px;
    z-index: 2;
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 6px;
    background: var(--tc-surface);
    color: var(--tc-muted);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    opacity: 0.85;
  }
  .tc-boot::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--tc-accent);
    animation: tc-pulse 1.2s infinite ease-in-out;
  }
  .tc-boot[hidden] { display: none; }
  @keyframes tc-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  .tc-criteria {
    list-style: none;
    padding: 10px 12px;
    margin: 0 0 12px;
    border: 1px dashed var(--tc-border);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    background: rgba(127, 127, 127, 0.05);
  }
  .tc-criterion {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    align-items: center;
    color: var(--tc-muted);
    line-height: 1.5;
  }
  .tc-criterion[data-met='true'] { color: var(--tc-pass); }
  .tc-criterion-icon {
    display: inline-flex;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 800;
    color: white;
    border: 1.5px solid currentColor;
    flex-shrink: 0;
  }
  .tc-criterion[data-met='true'] .tc-criterion-icon {
    background: var(--tc-pass);
    border-color: var(--tc-pass);
  }
  .tc-criterion[data-met='true'] .tc-criterion-icon::before { content: '\2713'; }
  .tc-criterion-text code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    padding: 1px 5px;
    border-radius: 4px;
    background: rgba(127, 127, 127, 0.15);
  }

  /* Type queries sit directly under the editor, deliberately quiet — they're
     supporting info ("what's the inferred type?"), not status. The loc column
     mirrors CodeMirror's gutter geometry (20px wide, right-aligned digits,
     3px gutter-to-code gap, 1px offset for the editor's border) so the digits
     and the type text both align vertically with the editor's gutter and code. */
  .tc-queries {
    margin-top: 8px;
    padding-left: 1px;
  }
  .tc-queries[hidden] { display: none; }
  .tc-queries-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tc-query {
    display: grid;
    grid-template-columns: 25px 1fr;
    gap: 0;
    padding: 2px 0;
    align-items: baseline;
  }
  .tc-query-loc {
    font-size: 11.5px;
    color: var(--tc-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    white-space: nowrap;
    opacity: 0.7;
    text-align: right;
    padding-right: 8px;
    box-sizing: border-box;
  }
  .tc-query-type {
    background: transparent;
    color: var(--tc-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 13px;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Errors sit at the very bottom of the card — they're the loudest piece of
     UI, so they get the strongest visual treatment (red wash) and a label. */
  .tc-diagnostics {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .tc-diagnostics[hidden] { display: none; }
  .tc-diagnostics::before {
    content: 'Errors';
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tc-fail);
    padding: 0 2px 2px;
  }
  .tc-diagnostic {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 13px;
    line-height: 1.5;
    background: var(--tc-fail-bg);
    color: var(--tc-fail);
  }
  .tc-diagnostic[data-category='warning'] {
    background: var(--tc-warn-bg);
    color: var(--tc-warn);
  }
  .tc-diag-loc {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-weight: 700;
    font-size: 12.5px;
    opacity: 0.8;
    white-space: nowrap;
  }
  .tc-diag-msg {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12.5px;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>

<script>
  import './bootstrap';
</script>
