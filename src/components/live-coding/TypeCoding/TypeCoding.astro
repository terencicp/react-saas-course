---
// Type-only live-coding widget. CodeMirror 6 editor over an in-browser
// TypeScript LanguageService (via @typescript/vfs). The student never executes
// code — the exercise is "make tsc quiet" and (optionally) resolve Twoslash
// `^?` queries to the expected types.
//
// MDX usage:
//   <TypeCoding
//     starter={`const colors = { red: '#f00' } satisfies Record<string, string>;`}
//     instructions="Add `satisfies` so autocomplete on `colors` keeps the literal keys."
//   />
//
// Twoslash query syntax — add a `^?` comment under the expression whose type
// you want shown:
//
//   const c: ColorName = 'red';
//   //       ^?
//
// The widget renders the resolved type below the editor.
import LiveCoding from '../_shared/LiveCoding.astro';

type ExpectedQuery = {
    /** 1-indexed line of the `^?` marker. */
    line: number;
    /** Substring that must appear in the resolved type's display string. */
    contains: string;
};
type ExpectedError = {
    contains: string;
    line?: number;
};
type Props = {
    starter: string;
    instructions?: string;
    maxHeight?: number;
    expectedQueries?: ExpectedQuery[];
    expectedErrors?: ExpectedError[];
};

const {
    starter,
    instructions,
    maxHeight = 320,
    expectedQueries = [],
    expectedErrors = [],
} = Astro.props as Props;

// "Fix all errors" only renders when the lesson didn't pin explicit criteria.
// Once a lesson pins queries or expected errors, "no errors remain" is
// baseline — the errors panel at the bottom already makes any leftover errors
// loud — and shouldn't take a row in the checklist.
const showCleanCriterion =
    expectedQueries.length === 0 && expectedErrors.length === 0;
---

<LiveCoding
    variant="type"
    instructions={instructions}
    controls="chips"
    hasBoot={true}
    bootLabel="Booting type-checker…"
    criteriaPosition="above"
    style={`--lc-max-h: ${maxHeight}px`}
    data={{ starter }}
>
    <ul class="lc-criteria" slot="above-output">
        {expectedQueries.map((q) => (
            <li class="lc-criterion" data-kind="query" data-contains={q.contains} data-met="false">
                <span class="lc-criterion-icon" aria-hidden="true"></span>
                <span class="lc-criterion-text">
                    Type query at line {q.line} must resolve to a type containing <code>{q.contains}</code>
                </span>
            </li>
        ))}
        {expectedErrors.map((e) => (
            <li class="lc-criterion" data-kind="error" data-line={e.line ?? ''} data-contains={e.contains} data-met="false">
                <span class="lc-criterion-icon" aria-hidden="true"></span>
                <span class="lc-criterion-text">
                    {e.line ? <>Error on line {e.line}</> : <>Some error</>} must mention <code>{e.contains}</code>
                </span>
            </li>
        ))}
        {showCleanCriterion && (
            <li class="lc-criterion" data-kind="clean" data-met="false">
                <span class="lc-criterion-icon" aria-hidden="true"></span>
                <span class="lc-criterion-text">Fix all errors</span>
            </li>
        )}
    </ul>

    <div slot="output">
        <div class="lc-queries" hidden>
            <ul class="lc-queries-list"></ul>
        </div>
        <ul class="lc-diagnostics" hidden></ul>
    </div>
</LiveCoding>

<style>
    /* TypeCoding's criteria checklist is always rendered (never `hidden`) —
       the live type-check fires on mount, so flipping data-met is the only
       state change. */
    :global(.lc-type .lc-criteria[hidden]) {
        display: flex;
    }
</style>

<script>
    import './bootstrap';
</script>
