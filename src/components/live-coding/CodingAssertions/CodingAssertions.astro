---
// Basic live-coding widget with assertions. CodeMirror 6 editor + a runner
// that executes the student's code and a tiny jest-flavoured `test`/`expect`
// shim. The default runner is "vanilla" (own iframe sandbox, ~80 KB, instant
// boot, plain JS only). Opt into "sandpack" for code that needs Sandpack's
// in-browser bundler (JSX/TS/Tailwind/npm) — heavier and network-dependent.
//
// MDX usage:
//   <CodingAssertions
//     starter={`function add(a, b) {\n  // your code\n}`}
//     tests={`test('adds positive numbers', () => { expect(add(2,3)).toBe(5); });`}
//   />
//   <CodingAssertions runner="sandpack" starter={...} tests={...} />
//
// Assertion API (both runners): `test(name, fn)`,
// `expect(x).toBe`/`.toEqual`/`.toBeTruthy`/`.toBeFalsy`/`.toBeCloseTo`
// /`.toThrow`/`.toContain`/`.not.*`.
type Runner = 'vanilla' | 'sandpack';
interface Props {
  starter: string;
  tests: string;
  instructions?: string;
  /**
   * Cap, in pixels, on the editor's height. The editor auto-sizes to its
   * starter; this only kicks in for code longer than the cap, after which
   * the editor scrolls.
   */
  maxHeight?: number;
  runner?: Runner;
}
const {
  starter,
  tests,
  instructions,
  maxHeight = 320,
  runner = 'vanilla',
} = Astro.props;
---

<div class="lc-card not-content" data-runner={runner}>
  {instructions && <p class="lc-instructions">{instructions}</p>}
  <div class="lc-editor" style={`--lc-max-h:${maxHeight}px`} data-starter={starter}></div>
  <div class="lc-toolbar">
    <button class="lc-run" type="button" disabled={runner === 'sandpack'}>Run tests</button>
    <button class="lc-feedback-btn" type="button">Feedback</button>
    <button class="lc-reset" type="button">Reset</button>
    {runner === 'sandpack' && (
      <span class="lc-status" aria-live="polite" data-state="booting">Booting bundler…</span>
    )}
  </div>
  <ul class="lc-results" data-tests={tests}></ul>
  <div class="lc-console" hidden>
    <div class="lc-console-label">Output</div>
    <pre class="lc-console-body"></pre>
  </div>
  <div class="lc-feedback" hidden>
    <div class="lc-feedback-head">
      <span class="lc-feedback-title">AI feedback</span>
    </div>
    <div class="lc-feedback-stream"></div>
  </div>
  {runner === 'sandpack' && <iframe class="lc-runner-iframe" aria-hidden="true" tabindex="-1"></iframe>}
</div>

<style is:global>
  .lc-card {
    --lc-surface: var(--sl-color-bg-nav);
    --lc-text: var(--sl-color-white);
    --lc-muted: var(--sl-color-gray-3);
    --lc-accent: var(--sl-color-accent);
    --lc-border: var(--sl-color-gray-5);
    --lc-hover: var(--sl-color-gray-6);
    --lc-pass: #16a34a;
    --lc-pass-bg: rgba(22, 163, 74, 0.12);
    --lc-fail: #dc2626;
    --lc-fail-bg: rgba(220, 38, 38, 0.12);

    color: var(--lc-text);
    background: var(--lc-surface);
    border: 1px solid var(--lc-border);
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 16px;
  }
  .lc-card * { box-sizing: border-box; }

  .lc-instructions {
    margin: 0 0 14px;
    color: var(--lc-text);
    font-size: 1rem;
    line-height: 1.55;
  }

  .lc-editor {
    border: 1px solid var(--lc-border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  /* Auto-size to content up to the cap; longer code scrolls inside the
     editor. `min-height` keeps very short starters from looking cramped. */
  .lc-editor .cm-editor {
    height: auto;
    min-height: 64px;
    max-height: var(--lc-max-h, 320px);
  }
  .lc-editor .cm-scroller {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 13.5px;
    overflow: auto;
  }

  .lc-toolbar {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .lc-toolbar button {
    font: inherit;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--lc-border);
    cursor: pointer;
    background: var(--lc-hover);
    color: var(--lc-text);
    transition: opacity 0.15s;
  }
  .lc-toolbar button:hover:not(:disabled) { opacity: 0.85; }
  .lc-toolbar .lc-run {
    background: var(--lc-accent);
    color: white;
    border-color: transparent;
  }
  .lc-toolbar button:disabled { opacity: 0.5; cursor: not-allowed; }
  .lc-status {
    margin-left: auto;
    align-self: flex-start;
    font-size: 13px;
    color: var(--lc-muted);
  }
  .lc-status[data-state='running'] { color: var(--lc-accent); }
  .lc-status[data-state='error'] { color: var(--lc-fail); }

  .lc-results {
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .lc-results:empty { display: none; }
  .lc-result {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 14px;
    line-height: 1.5;
  }
  .lc-result-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    color: white;
    font-size: 11px;
    font-weight: 800;
    flex-shrink: 0;
    margin-top: 1px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  }
  .lc-result[data-status='pass'] { background: var(--lc-pass-bg); color: var(--lc-pass); }
  .lc-result[data-status='pass'] .lc-result-icon { background: var(--lc-pass); }
  .lc-result[data-status='pass'] .lc-result-icon::before { content: '\2713'; }
  .lc-result[data-status='fail'] { background: var(--lc-fail-bg); color: var(--lc-fail); }
  .lc-result[data-status='fail'] .lc-result-icon { background: var(--lc-fail); }
  .lc-result[data-status='fail'] .lc-result-icon::before { content: '\2715'; }
  .lc-result[data-status='error'] { background: var(--lc-fail-bg); color: var(--lc-fail); }
  .lc-result[data-status='error'] .lc-result-icon { background: var(--lc-fail); }
  .lc-result[data-status='error'] .lc-result-icon::before { content: '!'; }
  .lc-result-body { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .lc-result-name { font-weight: 500; }
  .lc-result-error {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12.5px;
    opacity: 0.9;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .lc-console {
    margin-top: 12px;
    border: 1px solid var(--lc-border);
    border-radius: 8px;
    overflow: hidden;
    background: #0d1117;
  }
  .lc-console[hidden] { display: none; }
  .lc-console-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6e7681;
    padding: 6px 12px;
    border-bottom: 1px solid #30363d;
  }
  .lc-console-body {
    margin: 0;
    padding: 10px 12px;
    background: transparent;
    color: #e6edf3;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 13px;
    line-height: 1.5;
    white-space: pre-wrap;
    overflow-x: auto;
  }
  .lc-console-line[data-method='error'] { color: #f87171; }
  .lc-console-line[data-method='warn'] { color: #fbbf24; }

  /* Sandpack runner's bundler iframe — hidden but kept in flow so the
     SandpackClient has a valid target. */
  .lc-card[data-runner='sandpack'] iframe.lc-runner-iframe {
    width: 1px;
    height: 1px;
    position: absolute;
    left: -9999px;
    border: 0;
  }

  .lc-feedback {
    margin-top: 12px;
    padding: 12px 14px;
    background: rgba(127, 127, 127, 0.08);
    border-left: 3px solid var(--lc-accent);
    border-radius: 4px;
    font-size: 14px;
    color: var(--lc-text);
    line-height: 1.55;
  }
  .lc-feedback[hidden] { display: none; }
  .lc-feedback-head { margin-bottom: 6px; }
  .lc-feedback-title { font-weight: 700; font-size: 14px; }
  .lc-card[data-feedback-state='pending'] .lc-feedback-title::after {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-left: 6px;
    border-radius: 50%;
    background: currentColor;
    animation: lc-pulse 1.2s infinite ease-in-out;
    vertical-align: middle;
  }
  @keyframes lc-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
  .lc-feedback-stream {
    white-space: pre-wrap;
    word-wrap: break-word;
    min-height: 1.4em;
  }
</style>

<script>
  import './bootstrap';
</script>
