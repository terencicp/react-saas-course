---
// HTML/CSS live-coding widget. Tabbed CodeMirror panes (HTML + CSS, plus an
// optional JS pane) drive a same-origin `srcdoc` iframe. Lighter than
// ReactCoding by design: no bundler, no import map, no worker — the student's
// HTML lands in `<body>`, their CSS in a `<style>` tag, their JS (if any) in a
// `<script>` tag.
//
// MDX usage:
//   <HtmlCssCoding
//     instructions="Make the .card element red."
//     html={`<div class="card">Hello</div>`}
//     css={`.card { /* your styles */ }`}
//   />
//
//   <HtmlCssCoding
//     instructions="Wire the button to toggle the panel."
//     html={`<button id="toggle">Toggle</button>\n<div id="panel">Hi</div>`}
//     css={`.hidden { display: none; }`}
//     js={`// your code`}
//     tests={`test('button hides panel', () => {
//       document.getElementById('toggle')?.click();
//       expect(document.getElementById('panel')?.classList.contains('hidden')).toBe(true);
//     });`}
//   />
//
// Assertion surface (in-iframe runner, see srcdoc-builder.ts):
//   `test(name, fn)`, `expect(x).{toBe, toEqual, toBeNull, toBeUndefined,
//   toBeTruthy, toBeFalsy, toContain, toMatch}`, plus `.not.*`.
//   Inside `fn` the rendered DOM is live — query it via `document.querySelector`.
//   For computed-style assertions use `getComputedStyle(el).propertyName`.

interface Props {
    /** Starter HTML for the iframe `<body>`. Required. */
    html: string;
    /** Starter CSS injected into a `<style>` tag in the iframe `<head>`. Required. */
    css: string;
    /** Optional starter JS. When provided, a third tab appears and the script
     *  runs after the DOM mounts. Opt in for DOM/event lessons (Chapter 3.5);
     *  leave undefined for pure cascade / layout lessons. */
    js?: string;
    /** Optional instructions rendered above the editor. */
    instructions?: string;
    /** Optional jest-style tests run against the rendered DOM. */
    tests?: string;
    /** Editor max-height cap in px. Auto-sizes shorter starters. */
    maxHeight?: number;
    /** Wire Tailwind v4 Play CDN into the iframe. Off by default — raw CSS is
     *  the primary use case. Flip on for 4.2 lessons that contrast Tailwind
     *  utilities with hand-rolled CSS. */
    tailwind?: boolean;
    /** Auto-rebuild on edit, with a short debounce. On by default — CSS
     *  lessons benefit from instant visual feedback. Flip off for fix-the-bug
     *  exercises where the click-Run-to-commit ritual is part of the
     *  pedagogy. */
    live?: boolean;
}

const {
    html,
    css,
    js,
    instructions,
    tests,
    maxHeight = 360,
    tailwind = false,
    live = true,
} = Astro.props as Props;

const hasTests = !!tests && tests.trim().length > 0;
const hasJs = typeof js === 'string';
---

<div
    class="hc-card not-content"
    data-tailwind={String(tailwind)}
    data-live={String(live)}
>
    {instructions && <p class="hc-instructions">{instructions}</p>}

    <div class="hc-editor-shell" style={`--hc-max-h:${maxHeight}px`}>
        <div class="hc-tabs" role="tablist">
            <button class="hc-tab" type="button" role="tab" data-lang="html" aria-selected="true">HTML</button>
            <button class="hc-tab" type="button" role="tab" data-lang="css" aria-selected="false">CSS</button>
            {hasJs && (
                <button class="hc-tab" type="button" role="tab" data-lang="js" aria-selected="false">JS</button>
            )}
        </div>
        <div class="hc-panes">
            <div class="hc-pane" data-lang="html" data-starter={html}></div>
            <div class="hc-pane" data-lang="css" data-starter={css} hidden></div>
            {hasJs && <div class="hc-pane" data-lang="js" data-starter={js} hidden></div>}
            <button class="hc-feedback-btn hc-chip" type="button">Feedback</button>
            <button class="hc-reset hc-chip" type="button">Reset</button>
        </div>
    </div>

    {!live && (
        <div class="hc-toolbar">
            <button class="hc-run" type="button">Run</button>
        </div>
    )}

    <div class="hc-feedback" hidden>
        <button class="hc-feedback-close" type="button" aria-label="Close feedback">×</button>
        <div class="hc-feedback-head">
            <span class="hc-feedback-title">AI feedback</span>
        </div>
        <div class="hc-feedback-stream" />
    </div>

    <div class="hc-preview-wrap">
        <div class="hc-preview-label">
            <span>Preview</span>
            {live && <span class="hc-live-chip" aria-label="Live updates enabled">LIVE</span>}
        </div>
        <iframe class="hc-preview" title="Live preview"></iframe>
    </div>

    {hasTests && <ul class="hc-results" data-tests={tests}></ul>}
    <pre class="hc-error" hidden></pre>
</div>

<style is:global>
    .hc-card {
        --hc-surface: var(--sl-color-bg-nav);
        --hc-text: var(--sl-color-white);
        --hc-muted: var(--sl-color-gray-3);
        --hc-accent: var(--sl-color-accent);
        --hc-border: var(--sl-color-gray-5);
        --hc-hover: var(--sl-color-gray-6);
        --hc-pass: #16a34a;
        --hc-pass-bg: rgba(22, 163, 74, 0.12);
        --hc-fail: #dc2626;
        --hc-fail-bg: rgba(220, 38, 38, 0.12);

        color: var(--hc-text);
        background: var(--hc-surface);
        border: 1px solid var(--hc-border);
        border-radius: 12px;
        padding: 18px 20px;
        margin-bottom: 16px;
    }
    .hc-card * { box-sizing: border-box; }

    .hc-instructions {
        margin: 0 0 14px;
        color: var(--hc-text);
        font-size: 1rem;
        line-height: 1.55;
    }

    .hc-editor-shell {
        border: 1px solid var(--hc-border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 12px;
    }
    .hc-tabs {
        display: flex;
        align-items: center;
        gap: 2px;
        background: var(--hc-surface);
        border-bottom: 1px solid var(--hc-border);
        padding: 4px 6px 0;
    }
    .hc-tab {
        font: inherit;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 6px 12px;
        border: 1px solid transparent;
        border-bottom: 0;
        border-top-left-radius: 6px;
        border-top-right-radius: 6px;
        background: transparent;
        color: var(--hc-muted);
        cursor: pointer;
        margin-bottom: -1px;
    }
    .hc-tab:hover { color: var(--hc-text); }
    /* Selected tab merges into the editor's hardcoded oneDark background, so
       the text needs a matching hardcoded light tone — `var(--hc-text)` is
       dark in Starlight's light theme and would be invisible here. */
    .hc-tab[aria-selected="true"] {
        background: #282c34;
        color: #e6edf3;
        border-color: var(--hc-border);
    }

    .hc-panes { position: relative; }
    .hc-pane[hidden] { display: none; }

    /* Reset + Feedback chips inside the editor — muted by default so they don't
       compete with the code; full opacity on hover. Mirrors TypeCoding's chip
       layout (Feedback top-right, Reset bottom-right) so the eye learns one
       place per action across all live-coding widgets. */
    .hc-chip {
        position: absolute;
        right: 8px;
        z-index: 2;
        font: inherit;
        font-size: 11px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 6px;
        border: 1px solid var(--hc-border);
        cursor: pointer;
        background: var(--hc-surface);
        color: var(--hc-muted);
        opacity: 0.45;
        transition: opacity 0.15s, color 0.15s;
    }
    .hc-chip:hover:not(:disabled),
    .hc-chip:focus-visible:not(:disabled) {
        opacity: 1;
        color: var(--hc-text);
    }
    .hc-chip:disabled { cursor: not-allowed; opacity: 0.25; }
    .hc-feedback-btn.hc-chip { top: 8px; }
    .hc-reset.hc-chip { bottom: 8px; }
    .hc-pane .cm-editor {
        height: auto;
        min-height: 96px;
        max-height: var(--hc-max-h, 360px);
    }
    .hc-pane .cm-scroller {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 13.5px;
        overflow: auto;
    }

    .hc-toolbar {
        display: flex;
        gap: 8px;
        align-items: center;
        margin-bottom: 12px;
    }
    .hc-toolbar button {
        font: inherit;
        font-weight: 500;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid var(--hc-border);
        cursor: pointer;
        background: var(--hc-hover);
        color: var(--hc-text);
        transition: opacity 0.15s;
    }
    .hc-toolbar button:hover:not(:disabled) { opacity: 0.85; }
    .hc-toolbar button:disabled { opacity: 0.5; cursor: not-allowed; }
    .hc-toolbar .hc-run {
        background: var(--hc-accent);
        color: white;
        border-color: transparent;
    }

    .hc-preview-wrap {
        border: 1px solid var(--hc-border);
        border-radius: 8px;
        overflow: hidden;
        background: #ffffff;
    }
    .hc-preview-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--hc-muted);
        background: var(--hc-surface);
        padding: 6px 12px;
        border-bottom: 1px solid var(--hc-border);
    }
    .hc-live-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--hc-pass);
    }
    .hc-live-chip::before {
        content: '';
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
        animation: hc-live-pulse 2s infinite ease-in-out;
    }
    @keyframes hc-live-pulse {
        0%, 100% { opacity: 0.35; }
        50% { opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
        .hc-live-chip::before { animation: none; opacity: 1; }
    }
    .hc-preview {
        display: block;
        width: 100%;
        height: 96px;
        min-height: 96px;
        border: 0;
        background: #ffffff;
    }

    .hc-results {
        list-style: none;
        padding: 0;
        margin: 12px 0 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .hc-results:empty { display: none; }
    .hc-result {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 14px;
        line-height: 1.5;
    }
    .hc-result-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        color: white;
        font-size: 11px;
        font-weight: 800;
        flex-shrink: 0;
        margin-top: 1px;
    }
    .hc-result[data-status="pass"] { background: var(--hc-pass-bg); color: var(--hc-pass); }
    .hc-result[data-status="pass"] .hc-result-icon { background: var(--hc-pass); }
    .hc-result[data-status="pass"] .hc-result-icon::before { content: "\2713"; }
    .hc-result[data-status="fail"],
    .hc-result[data-status="error"] { background: var(--hc-fail-bg); color: var(--hc-fail); }
    .hc-result[data-status="fail"] .hc-result-icon,
    .hc-result[data-status="error"] .hc-result-icon { background: var(--hc-fail); }
    .hc-result[data-status="fail"] .hc-result-icon::before { content: "\2715"; }
    .hc-result[data-status="error"] .hc-result-icon::before { content: "!"; }
    .hc-result-body { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .hc-result-name { font-weight: 500; }
    .hc-result-error {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12.5px;
        opacity: 0.9;
        white-space: pre-wrap;
        word-break: break-word;
    }
    /* Diagnostic text stays in the DOM (so the AI Feedback prompt can read it
       via collectResults) but is hidden from the student — noisy mid-typing,
       and the student is meant to reach for Feedback when stuck. */
    .hc-result[data-status="fail"] .hc-result-error,
    .hc-result[data-status="error"] .hc-result-error { display: none; }

    .hc-error {
        margin: 12px 0 0;
        padding: 10px 12px;
        background: var(--hc-fail-bg);
        color: var(--hc-fail);
        border-radius: 8px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12.5px;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .hc-error[hidden] { display: none; }

    .hc-feedback {
        position: relative;
        margin-bottom: 12px;
        padding: 12px 36px 12px 14px;
        background: rgba(127, 127, 127, 0.08);
        border-left: 3px solid var(--hc-accent);
        border-radius: 4px;
        font-size: 14px;
        color: var(--hc-text);
        line-height: 1.55;
    }
    .hc-feedback[hidden] { display: none; }
    .hc-feedback-head { margin-bottom: 6px; }
    .hc-feedback-title { font-weight: 700; font-size: 14px; }
    .hc-feedback-close {
        position: absolute;
        top: 4px;
        right: 6px;
        background: transparent;
        border: 0;
        color: var(--hc-muted);
        font-size: 18px;
        line-height: 1;
        padding: 2px 6px;
        cursor: pointer;
        border-radius: 4px;
    }
    .hc-feedback-close:hover { color: var(--hc-text); background: var(--hc-hover); }
    .hc-card[data-feedback-state="pending"] .hc-feedback-title::after {
        content: "";
        display: inline-block;
        width: 6px;
        height: 6px;
        margin-left: 6px;
        border-radius: 50%;
        background: currentColor;
        animation: hc-pulse 1.2s infinite ease-in-out;
        vertical-align: middle;
    }
    @keyframes hc-pulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 1; }
    }
    .hc-feedback-stream {
        white-space: pre-wrap;
        word-wrap: break-word;
        min-height: 1.4em;
    }
</style>

<script>
    import './bootstrap';
</script>
