---
// HTML/CSS live-coding widget. Tabbed CodeMirror panes (HTML + CSS, plus an
// optional JS pane) drive a same-origin `srcdoc` iframe. Lighter than
// ReactCoding by design: no bundler, no import map, no worker — the student's
// HTML lands in `<body>`, their CSS in a `<style>` tag, their JS (if any) in
// a `<script>` tag.
//
// MDX usage:
//   <HtmlCssCoding
//     instructions="Make the .card element red."
//     html={`<div class="card">Hello</div>`}
//     css={`.card { /* your styles */ }`}
//   />
//
// Assertion surface (in-iframe runner, see srcdoc-builder.ts):
//   `test(name, fn)`, `expect(x).{toBe, toEqual, toBeNull, toBeUndefined,
//   toBeTruthy, toBeFalsy, toContain, toMatch}`, plus `.not.*`.
import LiveCoding from '../_shared/LiveCoding.astro';

interface Props {
    html: string;
    css: string;
    /** When provided, a third tab appears and the script runs after DOM mount. */
    js?: string;
    instructions?: string;
    tests?: string;
    maxHeight?: number;
    /** Wire Tailwind v4 Play CDN into the iframe. Off by default. */
    tailwind?: boolean;
    /** Auto-rebuild on edit. On by default — CSS lessons benefit from
     * instant visual feedback. */
    live?: boolean;
}

const {
    html,
    css,
    js,
    instructions,
    tests,
    maxHeight = 360,
    tailwind = false,
    live = true,
} = Astro.props as Props;

const hasTests = !!tests && tests.trim().length > 0;
const hasJs = typeof js === 'string';
---

<LiveCoding
    variant="html-css"
    instructions={instructions}
    controls={live ? 'chips' : 'toolbar'}
    showRun={!live}
    style={`--lc-max-h: ${maxHeight}px`}
    data={{
        tailwind: String(tailwind),
        live: String(live),
        tests: tests ?? '',
    }}
>
    <Fragment slot="editor-overlay">
        <div class="lc-hc-tabs" role="tablist">
            <button class="lc-hc-tab" type="button" role="tab" data-lang="html" aria-selected="true">HTML</button>
            <button class="lc-hc-tab" type="button" role="tab" data-lang="css" aria-selected="false">CSS</button>
            {hasJs && (
                <button class="lc-hc-tab" type="button" role="tab" data-lang="js" aria-selected="false">JS</button>
            )}
        </div>
        <div class="lc-hc-panes">
            <div class="lc-hc-pane" data-lang="html" data-starter={html}></div>
            <div class="lc-hc-pane" data-lang="css" data-starter={css} hidden></div>
            {hasJs && <div class="lc-hc-pane" data-lang="js" data-starter={js} hidden></div>}
        </div>
    </Fragment>

    <div slot="output">
        <div class="lc-hc-preview-wrap">
            <div class="lc-hc-preview-label">
                <span>Preview</span>
                {live && <span class="lc-hc-live-chip" aria-label="Live updates enabled">LIVE</span>}
            </div>
            <iframe class="lc-hc-preview" title="Live preview"></iframe>
        </div>
        {hasTests && <ul class="lc-results"></ul>}
    </div>
</LiveCoding>

<style is:global>
    /* HtmlCss replaces the single-CodeMirror layout with a tabs+panes block;
       both go inside the shell's `.lc-editor` via the `editor-overlay` slot so
       the shared chips (Reset bottom-right, Feedback top-right) naturally
       overlay the panes the same way they overlay a single editor. */
    .lc-html-css .lc-hc-tabs {
        display: flex;
        align-items: center;
        gap: 2px;
        background: var(--lc-surface);
        border-bottom: 1px solid var(--lc-border);
        padding: 4px 6px 0;
    }
    .lc-html-css .lc-hc-tab {
        font: inherit;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 6px 12px;
        border: 1px solid transparent;
        border-bottom: 0;
        border-top-left-radius: 6px;
        border-top-right-radius: 6px;
        background: transparent;
        color: var(--lc-muted);
        cursor: pointer;
        margin-bottom: -1px;
    }
    .lc-html-css .lc-hc-tab:hover { color: var(--lc-text); }
    .lc-html-css .lc-hc-tab[aria-selected='true'] {
        background: #282c34;
        color: #e6edf3;
        border-color: var(--lc-border);
    }
    .lc-html-css .lc-hc-panes {
        position: relative;
    }
    .lc-html-css .lc-hc-pane[hidden] { display: none; }

    /* The shell positions chips relative to `.lc-editor`. Because HtmlCss
       puts a tabs strip ABOVE the panes inside that same `.lc-editor`, the
       default `top: 8px` lands the Feedback chip on the tabs row. Bump it
       down past the tabs (38px tall) so it sits inside the panes. Reset
       chip uses `bottom: 8px`, which lands inside the panes by default. */
    .lc-html-css .lc-chip-feedback { top: 46px; }
    .lc-html-css .lc-hc-pane .cm-editor {
        height: auto;
        min-height: 96px;
        max-height: var(--lc-max-h, 360px);
    }
    .lc-html-css .lc-hc-pane .cm-scroller {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 13.5px;
        overflow: auto;
    }

    /* Preview pane — white background, autoresizes via postMessage from the
       iframe. Sits in the `output` slot, which is wrapped in a slot <div>;
       that wrapper blocks margin collapse from the feedback panel above, so
       set the gap explicitly on the preview-wrap. */
    .lc-html-css .lc-hc-preview-wrap {
        margin-top: 12px;
        border: 1px solid var(--lc-border);
        border-radius: 8px;
        overflow: hidden;
        background: #ffffff;
    }
    .lc-html-css .lc-hc-preview-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--lc-muted);
        background: var(--lc-surface);
        padding: 6px 12px;
        border-bottom: 1px solid var(--lc-border);
    }
    .lc-html-css .lc-hc-live-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--lc-pass);
    }
    .lc-html-css .lc-hc-live-chip::before {
        content: '';
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
        animation: lc-pulse 2s infinite ease-in-out;
    }
    @media (prefers-reduced-motion: reduce) {
        .lc-html-css .lc-hc-live-chip::before { animation: none; opacity: 1; }
    }
    .lc-html-css .lc-hc-preview {
        display: block;
        width: 100%;
        height: 96px;
        min-height: 96px;
        border: 0;
        background: #ffffff;
    }

    /* Diagnostic text stays in the DOM (so the AI Feedback prompt can read
       it via collectTestResults) but is hidden from the student — noisy
       mid-typing. */
    .lc-html-css .lc-result-item[data-status='fail'] .lc-result-error,
    .lc-html-css .lc-result-item[data-status='error'] .lc-result-error {
        display: none;
    }
</style>

<script>
    import './bootstrap';
</script>
