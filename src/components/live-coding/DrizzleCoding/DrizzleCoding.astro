---
// PGlite-backed Drizzle live-coding widget. CodeMirror (TypeScript) editor +
// a sandboxed iframe that runs the student's Drizzle query against a real
// Postgres-in-WASM. The lesson author supplies three sources:
//
//   - `schema`  — TS table definitions (Drizzle pgTable(...)). The single
//                 source of truth — the worker walks it with drizzle-orm's
//                 introspection to emit CREATE TABLE DDL automatically, so
//                 the lesson author never writes the DDL twice. Visible to
//                 the student in the collapsible "Schema & seed rows" panel.
//   - `seed`    — Raw SQL INSERT statements (and any auxiliary DDL the
//                 schema can't express, e.g. extensions). Re-applied per
//                 click so state is deterministic.
//   - `starter` — TS code the student starts with. Expected to `return` an
//                 array of rows (or an awaited Drizzle query); the result is
//                 compared to `expectedRows`.
//
// MDX usage:
//   <DrizzleCoding
//     schema={`export const users = pgTable('users', { ... });`}
//     seed={`CREATE TABLE users (...); INSERT INTO users VALUES ...;`}
//     starter={`return await db.select().from(users);`}
//     expectedRows={[{ name: 'Alice' }]}
//     instructions="Return Alice's row."
//   />
//
// Drizzle operators (`eq`, `and`, `asc`, …) and pg-core builders (`pgTable`,
// `integer`, `text`, …) are auto-available as globals inside the runtime —
// see drizzle-runtime.ts for the exact set.
import LiveCoding from '../_shared/LiveCoding.astro';

type ExpectedRow = Record<string, unknown>;
interface Props {
    schema: string;
    seed: string;
    starter: string;
    instructions?: string;
    maxHeight?: number;
    expectedRows?: ExpectedRow[];
    ordered?: boolean;
    hideSchema?: boolean;
}
const {
    schema,
    seed,
    starter,
    instructions,
    maxHeight = 360,
    expectedRows,
    ordered = true,
    hideSchema = false,
} = Astro.props as Props;

const expectedRowsJSON = expectedRows ? JSON.stringify(expectedRows) : '';
const hasCriteria = !!expectedRows && expectedRows.length > 0;
---

<LiveCoding
    variant="drizzle"
    instructions={instructions}
    controls="toolbar"
    runLabel="Run query"
    hasFeedback={hasCriteria}
    style={`--lc-max-h: ${maxHeight}px`}
    data={{
        starter,
        schema,
        seed,
        'expected-rows': expectedRowsJSON,
        ordered: String(ordered),
    }}
>
    {!hideSchema && (
        <details class="lc-details" slot="above-editor">
            <summary>View schema &amp; seed rows</summary>
            <div class="lc-drizzle-schema-section">
                <div class="lc-drizzle-schema-label">Schema (Drizzle)</div>
                <pre class="lc-details-body">{schema}</pre>
            </div>
            {seed.trim().length > 0 && (
                <div class="lc-drizzle-schema-section">
                    <div class="lc-drizzle-schema-label">Seed rows (SQL)</div>
                    <pre class="lc-details-body">{seed}</pre>
                </div>
            )}
        </details>
    )}

    {hasCriteria && (
        <ul class="lc-criteria" slot="above-output" hidden>
            <li class="lc-criterion" data-kind="rows" data-met="false">
                <span class="lc-criterion-icon" aria-hidden="true"></span>
                <span class="lc-criterion-text">
                    {`Query returns the ${expectedRows!.length} expected row${expectedRows!.length === 1 ? '' : 's'} ${ordered ? 'in order' : '(any order)'}`}
                </span>
            </li>
        </ul>
    )}

    <div class="lc-result" slot="output" hidden></div>
</LiveCoding>

<style is:global>
    /* Drizzle uses a two-section details panel (schema + seed) instead of a
       single body, so the `.lc-details-body` border-top from the shared
       styles would create double dividers; we draw the section divider
       between the two sections instead. */
    .lc-drizzle .lc-details .lc-drizzle-schema-section {
        border-top: 1px solid var(--lc-border);
    }
    .lc-drizzle .lc-details .lc-drizzle-schema-section .lc-details-body {
        border-top: 0;
        padding: 4px 12px 10px;
    }
    .lc-drizzle .lc-details .lc-drizzle-schema-label {
        padding: 6px 12px 0;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--lc-muted);
    }
</style>

<script>
    import './bootstrap';
</script>
