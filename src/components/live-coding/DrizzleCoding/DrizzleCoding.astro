---
// PGlite-backed Drizzle live-coding widget. CodeMirror (TypeScript) editor +
// a sandboxed iframe that runs the student's Drizzle query against a real
// Postgres-in-WASM. The lesson author supplies three sources:
//
//   - `schema`  — TS table definitions (Drizzle pgTable(...)). The single
//                 source of truth — the worker walks it with drizzle-orm's
//                 introspection to emit CREATE TABLE DDL automatically, so
//                 the lesson author never writes the DDL twice. Visible to
//                 the student in the collapsible "Schema & seed rows" panel.
//   - `seed`    — Raw SQL INSERT statements (and any auxiliary DDL the
//                 schema can't express, e.g. extensions). The CREATE TABLEs
//                 are generated; this is rows-only in the common case.
//                 Re-applied per click so state is deterministic.
//   - `starter` — TS code the student starts with. Expected to `return` an
//                 array of rows (or an awaited Drizzle query); the result is
//                 compared to `expectedRows`.
//
// MDX usage:
//   <DrizzleCoding
//     schema={`export const users = pgTable('users', { ... });`}
//     seed={`CREATE TABLE users (...); INSERT INTO users VALUES ...;`}
//     starter={`return await db.select().from(users);`}
//     expectedRows={[{ name: 'Alice' }]}
//     instructions="Return Alice's row."
//   />
//
// Without `expectedRows` the card is a pure sandbox — run any query, see the
// rows come back. With `expectedRows`, the criteria checklist below the result
// table flips ✓ when the rows match (subset per column; ordered toggleable).
//
// Drizzle operators (`eq`, `and`, `asc`, `count`, `sql`, …) and pg-core
// builders (`pgTable`, `integer`, `text`, …) are auto-available as globals
// inside the runtime, so students don't have to write the imports — the
// `drizzle-runtime.ts` module lists the exact set.

type ExpectedRow = Record<string, unknown>;
interface Props {
    /** TS source of the Drizzle schema. Shown to the student and used at runtime. */
    schema: string;
    /** Raw SQL (DDL + INSERTs) applied to PGlite before every run. */
    seed: string;
    /** Starter TS the student edits. */
    starter: string;
    instructions?: string;
    /** Editor max-height cap in px. Auto-sizes shorter starters. */
    maxHeight?: number;
    /** Rows the student's query must return. Subset-match per column. Omit for sandbox. */
    expectedRows?: ExpectedRow[];
    /** Whether row order matters. Defaults to true. */
    ordered?: boolean;
    /** Hide the schema/seed panel above the editor. Defaults to false. */
    hideSchema?: boolean;
}
const {
    schema,
    seed,
    starter,
    instructions,
    maxHeight = 360,
    expectedRows,
    ordered = true,
    hideSchema = false,
} = Astro.props as Props;

const expectedRowsJSON = expectedRows ? JSON.stringify(expectedRows) : "";
const hasCriteria = !!expectedRows && expectedRows.length > 0;
---

<div
    class="dc-card not-content"
    data-schema={schema}
    data-seed={seed}
    data-expected-rows={expectedRowsJSON}
    data-ordered={String(ordered)}
>
    {instructions && <p class="dc-instructions">{instructions}</p>}

    {
        !hideSchema && (
            <details class="dc-schema">
                <summary>View schema &amp; seed rows</summary>
                <div class="dc-schema-section">
                    <div class="dc-schema-label">Schema (Drizzle)</div>
                    <pre class="dc-schema-body">{schema}</pre>
                </div>
                {seed.trim().length > 0 && (
                    <div class="dc-schema-section">
                        <div class="dc-schema-label">Seed rows (SQL)</div>
                        <pre class="dc-schema-body">{seed}</pre>
                    </div>
                )}
            </details>
        )
    }

    <div
        class="dc-editor"
        style={`--dc-max-h:${maxHeight}px`}
        data-starter={starter}
    >
    </div>

    <div class="dc-toolbar">
        <button class="dc-run" type="button">Run query</button>
        {
            hasCriteria && (
                <button class="dc-feedback-btn" type="button">
                    Feedback
                </button>
            )
        }
        <button class="dc-reset" type="button">Reset</button>
        <span class="dc-status" aria-live="polite"></span>
    </div>

    {
        hasCriteria && (
            <ul class="dc-criteria" hidden>
                <li class="dc-criterion" data-kind="rows" data-met="false">
                    <span class="dc-criterion-icon" aria-hidden="true" />
                    <span class="dc-criterion-text">
                        {`Query returns the ${expectedRows!.length} expected row${expectedRows!.length === 1 ? "" : "s"} ${ordered ? "in order" : "(any order)"}`}
                    </span>
                </li>
            </ul>
        )
    }

    <div class="dc-result" hidden></div>
    <pre class="dc-error" hidden></pre>

    {
        hasCriteria && (
            <div class="dc-feedback" hidden>
                <div class="dc-feedback-head">
                    <span class="dc-feedback-title">AI feedback</span>
                </div>
                <div class="dc-feedback-stream" />
            </div>
        )
    }
</div>

<style is:global>
    .dc-card {
        --dc-surface: var(--sl-color-bg-nav);
        --dc-text: var(--sl-color-white);
        --dc-muted: var(--sl-color-gray-3);
        --dc-accent: var(--sl-color-accent);
        --dc-border: var(--sl-color-gray-5);
        --dc-hover: var(--sl-color-gray-6);
        --dc-pass: #16a34a;
        --dc-pass-bg: rgba(22, 163, 74, 0.12);
        --dc-fail: #dc2626;
        --dc-fail-bg: rgba(220, 38, 38, 0.12);

        color: var(--dc-text);
        background: var(--dc-surface);
        border: 1px solid var(--dc-border);
        border-radius: 12px;
        padding: 18px 20px;
        margin-bottom: 16px;
    }
    .dc-card * {
        box-sizing: border-box;
    }

    .dc-instructions {
        margin: 0 0 14px;
        color: var(--dc-text);
        font-size: 1rem;
        line-height: 1.55;
    }

    .dc-schema {
        margin: 0 0 12px;
        border: 1px solid var(--dc-border);
        border-radius: 8px;
        background: rgba(127, 127, 127, 0.05);
    }
    .dc-schema > summary {
        cursor: pointer;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 600;
        color: var(--dc-muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        list-style: none;
    }
    .dc-schema > summary::-webkit-details-marker {
        display: none;
    }
    .dc-schema > summary::before {
        content: "▸";
        display: inline-block;
        margin-right: 6px;
        transition: transform 0.15s;
    }
    .dc-schema[open] > summary::before {
        transform: rotate(90deg);
    }
    .dc-schema-section {
        border-top: 1px solid var(--dc-border);
    }
    .dc-schema-label {
        padding: 6px 12px 0;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--dc-muted);
    }
    .dc-schema-body {
        margin: 0;
        padding: 4px 12px 10px;
        background: transparent;
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12.5px;
        color: var(--dc-text);
        white-space: pre-wrap;
        word-break: break-word;
        overflow-x: auto;
    }

    .dc-editor {
        border: 1px solid var(--dc-border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 12px;
    }
    .dc-editor .cm-editor {
        height: auto;
        min-height: 64px;
        max-height: var(--dc-max-h, 360px);
    }
    .dc-editor .cm-scroller {
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 13.5px;
        overflow: auto;
    }

    .dc-toolbar {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    .dc-toolbar button {
        font: inherit;
        font-weight: 500;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid var(--dc-border);
        cursor: pointer;
        background: var(--dc-hover);
        color: var(--dc-text);
        transition: opacity 0.15s;
    }
    .dc-toolbar button:hover:not(:disabled) {
        opacity: 0.85;
    }
    .dc-toolbar button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .dc-toolbar .dc-run {
        background: var(--dc-accent);
        color: white;
        border-color: transparent;
    }
    .dc-status {
        margin-left: auto;
        font-size: 13px;
        color: var(--dc-muted);
    }
    .dc-status[data-state="running"] {
        color: var(--dc-accent);
    }
    .dc-status[data-state="error"] {
        color: var(--dc-fail);
    }

    .dc-criteria {
        list-style: none;
        padding: 10px 12px;
        margin: 12px 0 0;
        border: 1px dashed var(--dc-border);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        font-size: 13px;
        background: rgba(127, 127, 127, 0.05);
    }
    /* Override [hidden] because `display: flex` clobbers the UA rule. */
    .dc-criteria[hidden] {
        display: none;
    }
    .dc-criterion {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 10px;
        align-items: center;
        color: var(--dc-muted);
        line-height: 1.5;
    }
    .dc-criterion[data-met="true"] {
        color: var(--dc-pass);
    }
    .dc-criterion[data-met="false"] {
        color: var(--dc-fail);
    }
    .dc-criterion-icon {
        display: inline-flex;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
        color: white;
        border: 1.5px solid currentColor;
        flex-shrink: 0;
    }
    .dc-criterion[data-met="true"] .dc-criterion-icon {
        background: var(--dc-pass);
        border-color: var(--dc-pass);
    }
    .dc-criterion[data-met="true"] .dc-criterion-icon::before {
        content: "\2713";
    }
    .dc-criterion[data-met="false"] .dc-criterion-icon {
        background: var(--dc-fail);
        border-color: var(--dc-fail);
    }
    .dc-criterion[data-met="false"] .dc-criterion-icon::before {
        content: "\2715";
    }

    .dc-result {
        margin-top: 12px;
    }
    .dc-result[hidden] {
        display: none;
    }
    .dc-result-tablewrap {
        border: 1px solid var(--dc-border);
        border-radius: 8px;
        overflow-x: auto;
        background: var(--sl-color-bg);
    }
    .dc-result-table {
        border-collapse: collapse;
        width: 100%;
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12.5px;
        color: var(--dc-text);
    }
    .dc-result-table th,
    .dc-result-table td {
        padding: 6px 12px;
        text-align: left;
        border-bottom: 1px solid var(--dc-border);
        white-space: nowrap;
    }
    .dc-result-table th {
        background: var(--dc-surface);
        color: var(--dc-muted);
        font-weight: 600;
        font-size: 11px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        position: sticky;
        top: 0;
    }
    .dc-result-table tr:last-child td {
        border-bottom: none;
    }
    .dc-result-table tr:hover td {
        background: rgba(127, 127, 127, 0.06);
    }
    .dc-cell-null {
        color: var(--dc-muted);
        font-style: italic;
    }
    .dc-result-summary {
        margin-top: 6px;
        font-size: 11.5px;
        color: var(--dc-muted);
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    .dc-error {
        margin: 12px 0 0;
        padding: 10px 12px;
        background: var(--dc-fail-bg);
        color: var(--dc-fail);
        border-radius: 8px;
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12.5px;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .dc-error[hidden] {
        display: none;
    }

    .dc-feedback {
        margin-top: 12px;
        padding: 12px 14px;
        background: rgba(127, 127, 127, 0.08);
        border-left: 3px solid var(--dc-accent);
        border-radius: 4px;
        font-size: 14px;
        color: var(--dc-text);
        line-height: 1.55;
    }
    .dc-feedback[hidden] {
        display: none;
    }
    .dc-feedback-head {
        margin-bottom: 6px;
    }
    .dc-feedback-title {
        font-weight: 700;
        font-size: 14px;
    }
    .dc-card[data-feedback-state="pending"] .dc-feedback-title::after {
        content: "";
        display: inline-block;
        width: 6px;
        height: 6px;
        margin-left: 6px;
        border-radius: 50%;
        background: currentColor;
        animation: dc-pulse 1.2s infinite ease-in-out;
        vertical-align: middle;
    }
    @keyframes dc-pulse {
        0%,
        100% {
            opacity: 0.3;
        }
        50% {
            opacity: 1;
        }
    }
    .dc-feedback-stream {
        white-space: pre-wrap;
        word-wrap: break-word;
        min-height: 1.4em;
    }
</style>

<script>
    import "./bootstrap";
</script>
