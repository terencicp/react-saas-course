---
// React live-coding widget. CodeMirror editor + a same-origin `srcdoc` iframe
// rendering the student's component. TSX → JS via esbuild-wasm; React 19 from
// esm.sh via an in-iframe import map; Tailwind v4 from the Play CDN.
//
// MDX usage:
//   <ReactCoding
//     instructions="Build a primary button."
//     starter={`export function App() { return <button>Save</button>; }`}
//     tests={`test('renders Save', () => { expect(document.querySelector('button')?.textContent).toBe('Save'); });`}
//   />
//
// Visual target-match usage (Tailwind / layout exercises):
//   <ReactCoding
//     live
//     instructions="Match the target."
//     target={`export function App() { return <button className="…">Save</button>; }`}
//     starter={`export function App() { return <button>Save</button>; }`}
//   />
//
// Assertion surface (in-iframe runner, see bootstrap.ts):
//   `test(name, fn)`, `expect(x).{toBe, toEqual, toBeNull, toBeUndefined,
//   toBeTruthy, toBeFalsy, toContain, toMatch}`, plus `.not.*`.
import LiveCoding from '../_shared/LiveCoding.astro';

interface Props {
    starter: string;
    instructions?: string;
    tests?: string;
    maxHeight?: number;
    tailwind?: boolean;
    hidePreview?: boolean;
    live?: boolean;
    /** TSX for the reference output the student should match. */
    target?: string;
}

const {
    starter,
    instructions,
    tests,
    maxHeight = 320,
    tailwind = true,
    hidePreview = false,
    live = false,
    target,
} = Astro.props as Props;

const hasTarget = !!target && target.trim().length > 0;
const hasTests = !!tests && tests.trim().length > 0;
// Feedback also earns its weight when the exercise is target-match: the AI
// tutor compares the student's current code to the reference TSX even without
// a tests block to grade against.
const hasFeedback = hasTests || hasTarget;
// Short starters (≤3 lines) don't have vertical room for the diagonal chip
// layout — the top and bottom chips would overlap. Fall back to a single
// side-by-side group in the top-right when the editor is short.
const compactChips = live && starter.trim().split('\n').length <= 3;
---

<LiveCoding
    variant="react"
    instructions={instructions}
    controls={live ? 'chips' : 'toolbar'}
    showRun={!live}
    hasFeedback={hasFeedback}
    style={`--lc-max-h: ${maxHeight}px`}
    data={{
        starter,
        tailwind: String(tailwind),
        'hide-preview': String(hidePreview && !hasTarget),
        live: String(live),
        'target-match': String(hasTarget),
        'compact-chips': String(compactChips),
        tests: tests ?? '',
        ...(hasTarget ? { 'target-src': target! } : {}),
    }}
>
    <div slot="output">
        {hasTarget ? (
            <div class="lc-rc-preview-grid">
                <div class="lc-rc-preview-wrap">
                    <div class="lc-rc-preview-label">
                        <span>Target</span>
                    </div>
                    <iframe
                        class="lc-rc-preview lc-rc-preview-target"
                        title="Target output"
                    ></iframe>
                </div>
                <div class="lc-rc-preview-wrap">
                    <div class="lc-rc-preview-label">
                        <span>Your output</span>
                        {live && <span class="lc-rc-live-chip" aria-label="Live updates enabled">LIVE</span>}
                    </div>
                    <iframe class="lc-rc-preview" title="Live preview"></iframe>
                </div>
            </div>
        ) : (
            <div class="lc-rc-preview-wrap">
                <div class="lc-rc-preview-label">
                    <span>Preview</span>
                    {live && <span class="lc-rc-live-chip" aria-label="Live updates enabled">LIVE</span>}
                </div>
                <iframe class="lc-rc-preview" title="Live preview"></iframe>
            </div>
        )}
        {hasTests && <ul class="lc-results"></ul>}
    </div>
</LiveCoding>

<style is:global>
    /* Preview pane — white background, autoresizes via postMessage. */
    .lc-react .lc-rc-preview-wrap {
        margin-top: 12px;
        border: 1px solid var(--lc-border);
        border-radius: 8px;
        overflow: hidden;
        background: #ffffff;
    }
    .lc-react .lc-rc-preview-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--lc-muted);
        background: var(--lc-surface);
        padding: 6px 12px;
        border-bottom: 1px solid var(--lc-border);
    }
    .lc-react .lc-rc-preview {
        display: block;
        width: 100%;
        height: 96px;
        min-height: 96px;
        border: 0;
        background: #ffffff;
    }
    /* Hidden preview (hidePreview prop) — collapse the iframe while keeping
       it in the DOM so the runtime still mounts. */
    .lc-react[data-hide-preview='true'] .lc-rc-preview-wrap { display: none; }

    /* Compact-chip layout — short starters (≤3 lines) don't have room for
       the diagonal Feedback/Reset placement, so fall back to side-by-side
       chips in the top-right. */
    .lc-react[data-compact-chips='true'] .lc-chip-reset {
        top: 8px;
        right: 8px;
        bottom: auto;
    }
    .lc-react[data-compact-chips='true'] .lc-chip-feedback {
        top: 8px;
        /* Sit to the left of the Reset chip — exact offset depends on chip
           width, but ~70px works for the two-word label. */
        right: 70px;
    }

    /* Target-match grid — two side-by-side iframes (Target | Your output). */
    .lc-react .lc-rc-preview-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 12px;
    }
    .lc-react .lc-rc-preview-grid > .lc-rc-preview-wrap { margin-top: 0; }

    /* LIVE chip — green pulse to signal auto-rebuild. */
    .lc-react .lc-rc-live-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--lc-pass);
    }
    .lc-react .lc-rc-live-chip::before {
        content: '';
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
        animation: lc-pulse 2s infinite ease-in-out;
    }
    @media (prefers-reduced-motion: reduce) {
        .lc-react .lc-rc-live-chip::before { animation: none; opacity: 1; }
    }

    /* Diagnostic text stays in DOM (for feedback prompt) but is hidden from
       the student. */
    .lc-react .lc-result-item[data-status='fail'] .lc-result-error,
    .lc-react .lc-result-item[data-status='error'] .lc-result-error {
        display: none;
    }
</style>

<script>
    import './bootstrap';
</script>
