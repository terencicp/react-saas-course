---
// Shared shell for every live-coding card. Wrappers compose this with named
// slots and pass their per-card data via `data` (forwarded as data-* on the
// root div for bootstrap pickup).
//
// Five named slots, each justified by structural variation that wouldn't fit
// a single prop:
//   above-editor    — schema/seed <details>, HtmlCss tab strip
//   editor-overlay  — Type/Zod boot pill, chip-style overlays inside .lc-editor
//   toolbar         — default = Run / Feedback / Reset / status; override for
//                     custom labels (e.g. Script's "Run tests")
//   above-output    — criteria checklist (Drizzle/SQL/Type)
//   output          — result table | iframe preview | diagnostics | fixtures
//
// Buttons, status pill, feedback panel, error pane: ALL inside this shell —
// the "one place to change a button" guarantee.
import type { Variant } from './types';
import './styles.css';

interface Props {
    variant: Variant;
    instructions?: string;
    /**
     * 'toolbar' = bottom Run / Feedback / Reset row.
     * 'chips'   = muted Reset/Feedback chips positioned inside the editor
     *             (Type/Zod, live-update React/HtmlCss).
     */
    controls: 'toolbar' | 'chips';
    /**
     * Toolbar-only. False for live-update widgets that have no Run button.
     * Ignored when controls='chips'.
     */
    showRun?: boolean;
    /** Run button label override. Defaults to "Run". */
    runLabel?: string;
    /** Render the AI feedback button + panel. Defaults to true. Sandbox cards
     * (no pass/fail criteria) pass false. */
    hasFeedback?: boolean;
    /** Render the status pill (toolbar variant only). Default: true. */
    hasStatus?: boolean;
    /** Render the Type/Zod boot pill in the editor overlay. */
    hasBoot?: boolean;
    /** Boot pill label. Defaults to "Booting…". */
    bootLabel?: string;
    /** Position of the criteria checklist relative to the editor. Type uses
     * 'above' so the goal reads first; SQL/Drizzle use 'below' so the result
     * table sits next to the criteria. */
    criteriaPosition?: 'above' | 'below';
    /** Forwarded to root <div> as data-* attributes for the wrapper's
     * bootstrap to pick up. Keys are written verbatim, e.g.
     * `data={{ 'seed': sql }}` becomes `data-seed="…"`. */
    data?: Record<string, string>;
    /** Optional CSS class to append to the root. */
    class?: string;
    /** Inline style on the root. Typically used to pass CSS custom
     * properties for per-card overrides (e.g. `--lc-max-h`). */
    style?: string;
}

const {
    variant,
    instructions,
    controls,
    showRun = true,
    runLabel = 'Run',
    hasFeedback = true,
    hasStatus = true,
    hasBoot = false,
    bootLabel = 'Booting…',
    criteriaPosition = 'below',
    data,
    class: extraClass,
    style,
} = Astro.props;

const rootDataAttrs: Record<string, string> = {
    'data-variant': variant,
    'data-controls': controls,
    'data-criteria-position': criteriaPosition,
};
if (data) {
    for (const [key, value] of Object.entries(data)) {
        rootDataAttrs[`data-${key}`] = value;
    }
}
---

<div
    class:list={['lc-card', `lc-${variant}`, 'not-content', extraClass]}
    style={style}
    {...rootDataAttrs}
>
    {instructions && <p class="lc-instructions">{instructions}</p>}

    <slot name="above-editor" />

    {criteriaPosition === 'above' && <slot name="above-output" />}

    <div class="lc-editor">
        <slot name="editor-overlay" />
        {hasBoot && (
            <span class="lc-boot" aria-live="polite">{bootLabel}</span>
        )}
        {controls === 'chips' && (
            <>
                {hasFeedback && (
                    /* Chip buttons start hidden (not disabled) — feedback-loop
                       toggles `hidden` only, so leaving `disabled` here would
                       persist after the gate opens. */
                    <button
                        class="lc-chip lc-chip-feedback lc-feedback-btn"
                        type="button"
                        hidden
                    >
                        Feedback
                    </button>
                )}
                <button class="lc-chip lc-chip-reset lc-reset" type="button">
                    Reset
                </button>
            </>
        )}
    </div>

    {controls === 'toolbar' && (
        <slot name="toolbar">
            <div class="lc-toolbar">
                {showRun && (
                    <button class="lc-btn lc-btn-primary lc-run" type="button">
                        {runLabel}
                    </button>
                )}
                {hasFeedback && (
                    <button
                        class="lc-btn lc-feedback-btn"
                        type="button"
                        disabled
                    >
                        Feedback
                    </button>
                )}
                <button class="lc-btn lc-reset" type="button">Reset</button>
                {hasStatus && (
                    <span class="lc-status" aria-live="polite"></span>
                )}
            </div>
        </slot>
    )}

    {/* Feedback panel sits right after the toolbar/editor — where the
        Feedback button lives. Hidden by default; appears when the student
        clicks the (now-nearby) button. */}
    {hasFeedback && (
        <div class="lc-feedback" hidden>
            <div class="lc-feedback-head">
                <span class="lc-feedback-title">AI feedback</span>
            </div>
            <button
                class="lc-feedback-close"
                type="button"
                aria-label="Close feedback"
            >&times;</button>
            <div class="lc-feedback-stream"></div>
        </div>
    )}

    {criteriaPosition === 'below' && <slot name="above-output" />}

    <slot name="output" />

    <pre class="lc-error" hidden></pre>
</div>
