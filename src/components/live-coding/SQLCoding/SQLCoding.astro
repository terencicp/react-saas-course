---
// PGlite-backed SQL live-coding widget. CodeMirror editor + a Postgres
// database running in WebAssembly. The seed (DDL + INSERTs) is re-applied
// before every run so state is deterministic per click.
//
// MDX usage:
//   <SQLCoding
//     seed={`CREATE TABLE users (id int, name text);
//            INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob');`}
//     starter={`SELECT name FROM users WHERE id = 1;`}
//     expectedRows={[{ name: 'Alice' }]}
//     instructions="Return Alice's name."
//   />
//
// Without `expectedRows` the card is a pure sandbox — run any query, see
// the rows come back. With `expectedRows`, the criteria checklist below the
// result table flips ✓ when the rows match (subset match per column).
import LiveCoding from '../_shared/LiveCoding.astro';

type ExpectedRow = Record<string, unknown>;
type Props = {
    /** SQL the student starts with. */
    starter: string;
    /** DDL + INSERTs run before every query. */
    seed: string;
    instructions?: string;
    maxHeight?: number;
    /** Rows the student's query must return. Subset-matched per column. */
    expectedRows?: ExpectedRow[];
    /** Whether row order matters in the comparison. Defaults to true. */
    ordered?: boolean;
    /** Hide the seed/schema panel above the editor. Defaults to false. */
    hideSeed?: boolean;
};

const {
    starter,
    seed,
    instructions,
    maxHeight = 320,
    expectedRows,
    ordered = true,
    hideSeed = false,
} = Astro.props as Props;

const hasCriteria = !!expectedRows && expectedRows.length > 0;
const expectedRowsJSON = expectedRows ? JSON.stringify(expectedRows) : '';
---

<LiveCoding
    variant="sql"
    instructions={instructions}
    controls="toolbar"
    runLabel="Run query"
    hasFeedback={hasCriteria}
    style={`--lc-max-h: ${maxHeight}px`}
    data={{
        starter,
        seed,
        'expected-rows': expectedRowsJSON,
        ordered: String(ordered),
    }}
>
    {!hideSeed && (
        <details class="lc-details" slot="above-editor">
            <summary>View schema &amp; data</summary>
            {/* `<pre>` preserves every byte of whitespace it contains, so the
                seed text is interpolated as a direct child with no surrounding
                indentation or newlines. */}
            <pre class="lc-details-body">{seed}</pre>
        </details>
    )}

    {hasCriteria && (
        <ul class="lc-criteria" slot="above-output" hidden>
            <li class="lc-criterion" data-kind="rows" data-met="false">
                <span class="lc-criterion-icon" aria-hidden="true"></span>
                <span class="lc-criterion-text">
                    {`Query returns the ${expectedRows!.length} expected row${expectedRows!.length === 1 ? '' : 's'} ${ordered ? 'in order' : '(any order)'}`}
                </span>
            </li>
        </ul>
    )}

    <div class="lc-result" slot="output" hidden></div>
</LiveCoding>

<script>
    import './bootstrap';
</script>
