---
// Hybrid live-coding widget for Zod 4. Combines TypeCoding's type-only checker
// (Twoslash `^?` queries + diagnostics) with a sandboxed runtime that imports
// real zod from esm.sh and runs the student's schema against a fixtures table.
//
// The senior pitch for Zod is "one declaration produces both the static type
// AND the runtime contract" — showing the inferred type update alongside the
// per-fixture pass/fail in the same card lands that lesson without splitting
// it across two widgets.
//
// No pass/fail checklist on top: in Zod the runtime and the type follow from
// one declaration, so a fixture passing implies the type took the right shape.
// The `^?` query panel renders the inferred type as informational context.
import LiveCoding from '../_shared/LiveCoding.astro';

type Fixture = {
    /** Short label rendered in the results table. */
    name: string;
    /** Value passed to `schema.safeParse(input)`. */
    input: unknown;
    /** Whether the schema should accept (`pass`) or reject (`fail`) this input. */
    expect: 'pass' | 'fail';
    /** When `expect === 'fail'`, optional substring the Zod error must contain. */
    errorContains?: string;
};
type Props = {
    starter: string;
    /** Name of the const the lesson is testing — the harness looks this up
     * after the student code runs. */
    schemaName: string;
    instructions?: string;
    fixtures?: Fixture[];
    maxHeight?: number;
};
const {
    starter,
    schemaName,
    instructions,
    fixtures = [],
    maxHeight = 360,
} = Astro.props as Props;

// Pretty-print fixture inputs for the static (no-JS) view. Keep it short —
// the runner will replace this with live pass/fail status once hydrated.
const fixturesJson = JSON.stringify(fixtures);
function previewInput(input: unknown): string {
    try {
        const s = JSON.stringify(input);
        if (s == null) return 'undefined';
        return s.length > 60 ? s.slice(0, 57) + '…' : s;
    } catch {
        return String(input);
    }
}
---

<LiveCoding
    variant="zod"
    instructions={instructions}
    controls="chips"
    hasBoot={true}
    bootLabel="Booting type-checker…"
    style={`--lc-max-h: ${maxHeight}px`}
    data={{
        starter,
        'schema-name': schemaName,
        fixtures: fixturesJson,
    }}
>
    <div slot="output">
        {fixtures.length > 0 && (
            <div class="lc-zc-fixtures">
                <table class="lc-zc-fixtures-table">
                    <thead>
                        <tr>
                            <th colspan="2" class="lc-zc-col-name">Test scenario</th>
                            <th class="lc-zc-col-input">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="lc-zc-harness-error-row" hidden>
                            <td colspan="3" class="lc-zc-harness-error-cell" aria-live="polite"></td>
                        </tr>
                        {fixtures.map((f) => (
                            <tr class="lc-zc-fixture-row" data-fixture-name={f.name} data-status="pending">
                                <td class="lc-zc-col-status">
                                    <span class="lc-zc-fixture-icon" aria-hidden="true"></span>
                                </td>
                                <td class="lc-zc-col-name">{f.name}</td>
                                <td class="lc-zc-col-input">
                                    <code>{previewInput(f.input)}</code>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        )}
    </div>
</LiveCoding>

<style is:global>
    /* Hover-tooltip styling for `^?` query reveals — same visual register as
       the CodeTooltips widget. */
    .lc-zod .cm-editor .cm-query-mark {
        border-bottom: 1px dashed var(--lc-muted);
        cursor: help;
        border-radius: 2px;
        transition: background-color 0.12s, border-color 0.12s;
    }
    .lc-zod .cm-editor .cm-query-mark:hover {
        background: color-mix(in srgb, var(--lc-accent) 22%, transparent);
        border-bottom-color: var(--lc-accent);
    }
    .lc-zod .cm-editor .cm-tooltip {
        background: transparent;
        border: 0;
        box-shadow: none;
        padding: 0;
    }
    .lc-zod .zc-cm-tip {
        background: #1f2937;
        color: #f3f4f6;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        border-radius: 6px;
        padding: 7px 10px;
        font: 12px / 1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        white-space: pre-wrap;
        word-break: break-word;
        max-width: min(420px, calc(100vw - 24px));
        width: max-content;
    }

    /* Fixtures table — the runtime half of the lesson. */
    .lc-zod .lc-zc-fixtures {
        margin-top: 14px;
        border: 1px solid var(--lc-border);
        border-radius: 8px;
        overflow: hidden;
    }
    .lc-zod .lc-zc-fixtures-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }
    .lc-zod .lc-zc-fixtures-table th,
    .lc-zod .lc-zc-fixtures-table td {
        padding: 8px 12px;
        text-align: left;
        border-bottom: 1px solid var(--lc-border);
        vertical-align: top;
    }
    .lc-zod .lc-zc-fixtures-table tr:last-child td { border-bottom: 0; }
    .lc-zod .lc-zc-fixtures-table th {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--lc-muted);
        background: rgba(127, 127, 127, 0.06);
        padding: 10px 12px;
    }
    .lc-zod .lc-zc-col-status { width: 28px; }
    .lc-zod .lc-zc-fixtures-table tbody .lc-zc-col-name { padding-left: 0; }
    .lc-zod .lc-zc-harness-error-row[hidden] { display: none; }
    .lc-zod .lc-zc-harness-error-cell {
        background: var(--lc-fail-bg);
        color: var(--lc-fail);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12.5px;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .lc-zod .lc-zc-fixtures-table code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12px;
        color: var(--lc-text);
        word-break: break-all;
    }
    .lc-zod .lc-zc-fixture-icon {
        display: inline-flex;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 800;
        color: white;
        border: 1.5px solid var(--lc-muted);
    }
    .lc-zod .lc-zc-fixture-row[data-status='ok'] .lc-zc-fixture-icon {
        background: var(--lc-pass);
        border-color: var(--lc-pass);
    }
    .lc-zod .lc-zc-fixture-row[data-status='ok'] .lc-zc-fixture-icon::before { content: '\2713'; }
    .lc-zod .lc-zc-fixture-row[data-status='bad'] .lc-zc-fixture-icon {
        background: var(--lc-fail);
        border-color: var(--lc-fail);
    }
    .lc-zod .lc-zc-fixture-row[data-status='bad'] .lc-zc-fixture-icon::before { content: '\2715'; }
    .lc-zod .lc-zc-fixture-row[data-status='ok'] { background: var(--lc-pass-bg); }
    .lc-zod .lc-zc-fixture-row[data-status='bad'] { background: var(--lc-fail-bg); }

    /* Runner iframe — kept off-screen but in the DOM. */
    .lc-zod iframe.lc-zc-runner-iframe {
        width: 1px;
        height: 1px;
        position: absolute;
        left: -9999px;
        border: 0;
    }
</style>

<script>
    import './bootstrap';
</script>
