---
// PGlite-backed Drizzle SCHEMA-DESIGN live-coding widget. The student writes
// a Drizzle pgTable schema; the grader walks every top-level pgTable with
// `getTableConfig` and compares against the lesson author's `requirements`
// (which tables, which columns, which constraints). Optional `probes` are
// SQL INSERTs the schema is expected to accept or reject — the constraint-
// firing tests that prove the schema means what it says.
//
// Sibling to DrizzleCoding (query-graded; this one is schema-graded). Shares
// the schema-emit logic so DDL emission stays consistent across widgets.
import LiveCoding from '../_shared/LiveCoding.astro';
import type { TableRequirement } from './requirement-check';
import type { ProbeSpec } from './schema-runtime';

interface Props {
    /** Starter TS the student edits — a partial Drizzle schema. */
    starter: string;
    instructions?: string;
    maxHeight?: number;
    /** What the student's schema must define. Omit for a pure sandbox. */
    requirements?: TableRequirement[];
    /** Optional SQL probes that test the schema's constraints. */
    probes?: ProbeSpec[];
    /** Optional auxiliary SQL applied after the student's DDL, before probes
     * (extensions, seed rows the probes assume). */
    seedSQL?: string;
}
const {
    starter,
    instructions,
    maxHeight = 360,
    requirements,
    probes,
    seedSQL = '',
} = Astro.props as Props;

const requirementsJSON = requirements ? JSON.stringify(requirements) : '';
const probesJSON = probes ? JSON.stringify(probes) : '';
const hasRequirements = !!requirements && requirements.length > 0;
const hasProbes = !!probes && probes.length > 0;
const hasCriteria = hasRequirements || hasProbes;
---

<LiveCoding
    variant="drizzle-schema"
    instructions={instructions}
    controls="toolbar"
    runLabel="Check schema"
    hasFeedback={hasCriteria}
    style={`--lc-max-h: ${maxHeight}px`}
    data={{
        starter,
        requirements: requirementsJSON,
        probes: probesJSON,
        seed: seedSQL,
    }}
>
    {hasCriteria && <ul class="lc-criteria" slot="above-output" hidden></ul>}

    <div slot="output">
        <details class="lc-details lc-dsc-introspection" hidden open={!hasCriteria}>
            <summary>What your schema produced</summary>
            <div class="lc-dsc-introspection-body lc-details-body"></div>
        </details>
    </div>
</LiveCoding>

<style is:global>
    /* Criterion's reason text — second line below the label, muted. */
    .lc-drizzle-schema .lc-criterion {
        align-items: start;
    }
    .lc-drizzle-schema .lc-criterion-icon {
        margin-top: 2px;
    }
    .lc-drizzle-schema .lc-criterion-reason {
        display: block;
        margin-top: 2px;
        color: var(--lc-muted);
        font-size: 12px;
    }
    .lc-drizzle-schema .lc-criterion-text code {
        font-size: 12.5px;
    }

    /* Introspection panel — collapsible, contains pre-formatted table blocks.
       Top padding gives breathing room between the "WHAT YOUR SCHEMA PRODUCED"
       summary and the first table block. */
    .lc-drizzle-schema .lc-dsc-introspection-body {
        padding: 10px 12px 10px;
    }
    .lc-drizzle-schema .lc-dsc-introspection-empty {
        color: var(--lc-muted);
        font-size: 12.5px;
        padding: 6px 10px;
        border: 1px dashed var(--lc-border);
        border-radius: 6px;
    }
    .lc-drizzle-schema .lc-dsc-introspection-body pre {
        margin: 0;
        padding: 10px 12px;
        background: var(--sl-color-bg);
        border: 1px solid var(--lc-border);
        border-radius: 6px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 12px;
        color: var(--lc-text);
        white-space: pre-wrap;
        overflow-x: auto;
    }
    .lc-drizzle-schema .lc-dsc-introspection-table {
        margin-bottom: 8px;
    }
    .lc-drizzle-schema .lc-dsc-introspection-table:last-child {
        margin-bottom: 0;
    }
</style>

<script>
    import './bootstrap';
</script>
