---
/**
 * TSPlaygroundCallout — collapsible iframe for TypeScript Playground.
 *
 * Two ways to use:
 *
 * 1. Pre-computed URL — pass `url` directly. The URL already contains the
 *    `#code/<lz-string>` payload; the wrapper does nothing clever.
 *
 * 2. Raw code + flags — pass `code` and `flags`. A small client script
 *    loads `lz-string` from a CDN, compresses the code in the browser,
 *    and writes the resulting URL into the iframe's `src` on first open.
 *    Useful when the LZ payload is too long to paste literally into MDX,
 *    or when the author hasn't pre-computed it.
 *
 * Either path renders through SandboxCallout for the collapsible chrome.
 */
import SandboxCallout from './SandboxCallout.astro';

type Flags = Record<string, string | number | boolean>;

interface Props {
  /** Pre-built TypeScript Playground URL (skip `code` + `flags`). */
  url?: string;
  /** Raw TS source. Encoded client-side via lz-string if `url` is missing. */
  code?: string;
  /** Compiler flags as query params (e.g. `{ strict: true, target: 99 }`). */
  flags?: Flags;
  /** TypeScript version override (e.g. `"5.7"` or `"next"`). */
  tsVersion?: string;
  /** Tooltip / iframe title. Defaults to "TypeScript Playground". */
  title?: string;
  /** Iframe height in pixels. */
  height?: number;
  /** Button label. */
  label?: string;
  /** Filetype tab — ts (default), js, or dts. */
  filetype?: 'ts' | 'js' | 'dts';
}

const {
  url,
  code,
  flags = {},
  tsVersion,
  title = 'TypeScript Playground',
  height = 600,
  label = 'Open in TypeScript Playground',
  filetype,
} = Astro.props;

const BASE = 'https://www.typescriptlang.org/play/';

// Build the query-string part (everything before the `#code/<lz>` hash).
// This part is identical in both modes — only the hash payload changes.
const params = new URLSearchParams();
for (const [k, v] of Object.entries(flags)) params.set(k, String(v));
if (tsVersion) params.set('ts', tsVersion);
if (filetype) params.set('filetype', filetype);
const queryPrefix = params.toString() ? `?${params.toString()}` : '';

// Mode 1: caller pre-built the URL. Pass it through verbatim.
// Mode 2: caller passed raw code. Render a placeholder URL (the playground
// homepage, so the iframe doesn't 404 if JS is disabled) and let the
// inline script swap in the compressed `#code/...` URL on demand.
const resolvedUrl = url ?? `${BASE}${queryPrefix}`;
const needsClientEncode = !url && typeof code === 'string';
---

<SandboxCallout url={resolvedUrl} title={title} height={height} label={label}>
  <slot />
</SandboxCallout>

{
  needsClientEncode && (
    <script
      type="application/json"
      data-ts-playground-payload
      data-base={`${BASE}${queryPrefix}`}
      set:html={JSON.stringify({ code })}
    />
  )
}

{
  needsClientEncode && (
    <script is:inline>
      {`
        (() => {
          const LZ_SRC = 'https://unpkg.com/lz-string@1.5.0/libs/lz-string.min.js';
          const loadLz = () => new Promise((resolve, reject) => {
            if (window.LZString) return resolve(window.LZString);
            const s = document.createElement('script');
            s.src = LZ_SRC;
            s.onload = () => resolve(window.LZString);
            s.onerror = reject;
            document.head.appendChild(s);
          });
          document.querySelectorAll('script[data-ts-playground-payload]').forEach((node) => {
            const payload = JSON.parse(node.textContent || '{}');
            const base = node.getAttribute('data-base') || '';
            // The associated iframe is the closest preceding sandbox callout's iframe.
            const callout = node.previousElementSibling;
            const iframe = callout && callout.querySelector('iframe');
            if (!iframe) return;
            let primed = false;
            const prime = async () => {
              if (primed) return;
              primed = true;
              try {
                const LZ = await loadLz();
                const lz = LZ.compressToEncodedURIComponent(payload.code || '');
                iframe.dataset.src = base + '#code/' + lz;
                // SandboxCallout sets iframe.src on first open; if the user
                // already opened it before encode finished, push it now.
                if (iframe.src && !iframe.src.includes('#code/')) {
                  iframe.src = iframe.dataset.src;
                }
              } catch (e) {
                console.warn('Failed to load lz-string for TS Playground embed', e);
              }
            };
            // Prime on first user interaction with the toggle, so we don't
            // pay the CDN round-trip until the learner actually opens the box.
            const toggle = callout && callout.querySelector('.toggle');
            if (toggle) toggle.addEventListener('click', prime, { once: true });
          });
        })();
      `}
    </script>
  )
}
