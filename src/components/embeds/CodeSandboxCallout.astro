---
/**
 * CodeSandboxCallout — URL builder around the legacy /embed/<id> family
 * and the /p/github/<owner>/<repo> repo-loader.
 *
 * Accepts a flat set of CodeSandbox embed query parameters and produces a
 * fully-built iframe URL. The actual iframe is rendered inside the existing
 * SandboxCallout so the player stays collapsible and lazy.
 *
 * `kind` selects the base URL family:
 *  - "embed"  → https://codesandbox.io/embed/<id>      (devbox / browser sandbox)
 *  - "p"      → https://codesandbox.io/p/sandbox/<id>  (newer Cloud sandbox)
 *  - "github" → https://codesandbox.io/p/github/<owner>/<repo>(/<branch>)?
 */
import SandboxCallout from './SandboxCallout.astro';

type Kind = 'embed' | 'p' | 'github';
type View = 'editor' | 'split' | 'preview';
type PreviewWindow = 'browser' | 'console' | 'tests';
type Theme = 'dark' | 'light';

interface Props {
  kind: Kind;
  // For `embed` / `p`: the sandbox id (e.g. "react-new" or "4tn8i").
  id?: string;
  // For `github`: "owner/repo" — optionally followed by tree-path via `path`.
  repo?: string;
  branch?: string;
  // Path inside the repo (e.g. "examples/with-react-hook-form").
  path?: string;
  // Embed cosmetics / behavior:
  view?: View;
  module?: string; // file path opened in the editor, e.g. "/src/App.tsx"
  file?: string; // alias used on /p/github URLs (?file=<path>)
  theme?: Theme;
  fontsize?: number;
  hidenavigation?: boolean;
  runonclick?: boolean;
  initialpath?: string;
  previewwindow?: PreviewWindow;
  forcerefresh?: boolean;
  editorsize?: number; // percentage 0-100
  expanddevtools?: boolean;
  eslint?: boolean;
  codemirror?: boolean;
  verticallayout?: boolean;
  highlights?: string; // comma-separated line numbers
  // Wrapper:
  title: string;
  label?: string;
  height?: number;
}

const {
  kind,
  id,
  repo,
  branch,
  path,
  view,
  module,
  file,
  theme,
  fontsize,
  hidenavigation,
  runonclick,
  initialpath,
  previewwindow,
  forcerefresh,
  editorsize,
  expanddevtools,
  eslint,
  codemirror,
  verticallayout,
  highlights,
  title,
  label = 'Open CodeSandbox',
  height,
} = Astro.props;

function base(): string {
  if (kind === 'embed') {
    if (!id) throw new Error("CodeSandboxCallout kind='embed' requires `id`");
    return `https://codesandbox.io/embed/${id}`;
  }
  if (kind === 'p') {
    if (!id) throw new Error("CodeSandboxCallout kind='p' requires `id`");
    return `https://codesandbox.io/p/sandbox/${id}`;
  }
  if (kind === 'github') {
    if (!repo) throw new Error("CodeSandboxCallout kind='github' requires `repo` ('owner/repo')");
    const br = branch ?? 'main';
    const tail = path ? `/tree/${br}/${path}` : '';
    return `https://codesandbox.io/p/github/${repo}${tail}`;
  }
  throw new Error(`Unknown CodeSandboxCallout kind: ${kind}`);
}

const params = new URLSearchParams();
if (view) params.set('view', view);
if (module) params.set('module', module);
if (file) params.set('file', file);
if (theme) params.set('theme', theme);
if (fontsize != null) params.set('fontsize', String(fontsize));
if (hidenavigation) params.set('hidenavigation', '1');
if (runonclick) params.set('runonclick', '1');
if (initialpath) params.set('initialpath', initialpath);
if (previewwindow) params.set('previewwindow', previewwindow);
if (forcerefresh) params.set('forcerefresh', '1');
if (editorsize != null) params.set('editorsize', String(editorsize));
if (expanddevtools) params.set('expanddevtools', '1');
if (eslint) params.set('eslint', '1');
if (codemirror) params.set('codemirror', '1');
if (verticallayout) params.set('verticallayout', '1');
if (highlights) params.set('highlights', highlights);

const qs = params.toString();
const url = qs ? `${base()}?${qs}` : base();
---

<SandboxCallout url={url} title={title} label={label} height={height}>
  <slot />
</SandboxCallout>
