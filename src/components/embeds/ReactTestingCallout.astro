---
/**
 * ReactTestingCallout — iframe `testing-playground.com` with a chunk of
 * HTML (and optionally a starter `screen.*` query) prefilled.
 *
 * Prefill mechanism (confirmed by reading the playground's source on
 * `testing-library/testing-playground` at `src/lib/state/url.js`):
 *
 *   import {
 *     compressToEncodedURIComponent,
 *     decompressFromEncodedURIComponent,
 *   } from 'lz-string';
 *
 *   export function compress({ markup, query }) {
 *     return {
 *       markup: compressToEncodedURIComponent(unindent(markup)),
 *       query:  compressToEncodedURIComponent(unindent(query)),
 *     };
 *   }
 *
 *   function load() {
 *     let params = queryString.parse(location.search);
 *     if (!params.markup && !params.query) {
 *       params = queryString.parse(location.hash);   // <-- hash fallback
 *     }
 *     // ...decompress and return
 *   }
 *
 * So the URL can use either `?markup=…&query=…` or `#markup=…&query=…`;
 * the matrix tags the hash form ([9] JSON-in-URL in the legend, sense
 * "opaque blob in URL"). We use the hash form so the URL stays out of
 * server logs.
 *
 * Astro renders this component's frontmatter at *build* time, so the
 * compressed URL is baked into the static HTML — no client JS needed,
 * no CDN load, no `lz-string` npm dependency. The lz-string compressor
 * below is the same inlined copy used by `ZodPlaygroundEmbed.astro`
 * (lz-string 1.5.0, MIT/WTFPL © 2013 Pieroxy). Only the compress path
 * is included; we never decompress.
 *
 * Usage:
 *
 *   <TestingPlaygroundEmbed
 *     title="Login form"
 *     html={`<form>
 *       <label>Email <input type="email" /></label>
 *       <button>Sign in</button>
 *     </form>`}
 *     query={`screen.getByRole('button', { name: /sign in/i })`}
 *   />
 */
import SandboxCallout from './SandboxCallout.astro';

interface Props {
  /** Tooltip / iframe title (a11y). Defaults to "Testing Playground". */
  title?: string;
  /** HTML markup the playground should render in the left pane. */
  html: string;
  /** Optional starter `screen.*` query to prefill the right pane. */
  query?: string;
  /**
   * Use the `/embed` route instead of the main page. The embedded view
   * drops the marketing chrome and is optimised for iframes — see the
   * `src/pages/Embedded.js` route in the upstream repo.
   */
  embed?: boolean;
  /**
   * Comma-separated list of panes to show (matches the embedded view's
   * `?panes=` param). Allowed values: `markup`, `query`, `preview`,
   * `suggestions`. Only honoured when `embed` is true.
   */
  panes?: string;
  /** Iframe height in px. Defaults to 600 so both panes have room. */
  height?: number;
  /** Override the "Open sandbox" label on the callout button. */
  label?: string;
}

const {
  title = 'Testing Playground',
  html,
  query,
  embed = false,
  panes,
  height = 600,
  label,
} = Astro.props;

// ---------------------------------------------------------------------------
// Inlined lz-string compressToEncodedURIComponent (1.5.0). Same algorithm
// the playground itself imports, so the URLs round-trip without escape
// hatches. Verbatim port from the upstream `compressToEncodedURIComponent`
// + private `_compress`.
// ---------------------------------------------------------------------------

const keyStrUriSafe =
  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+-$';

function compressToEncodedURIComponent(input: string): string {
  if (input == null) return '';
  return _compress(input, 6, (a: number) => keyStrUriSafe.charAt(a));
}

function _compress(
  uncompressed: string,
  bitsPerChar: number,
  getCharFromInt: (n: number) => string,
): string {
  if (uncompressed == null) return '';
  let i: number;
  let value: number;
  const context_dictionary: Record<string, number> = {};
  const context_dictionaryToCreate: Record<string, boolean> = {};
  let context_c = '';
  let context_wc = '';
  let context_w = '';
  let context_enlargeIn = 2;
  let context_dictSize = 3;
  let context_numBits = 2;
  const context_data: string[] = [];
  let context_data_val = 0;
  let context_data_position = 0;

  for (let ii = 0; ii < uncompressed.length; ii += 1) {
    context_c = uncompressed.charAt(ii);
    if (!Object.prototype.hasOwnProperty.call(context_dictionary, context_c)) {
      context_dictionary[context_c] = context_dictSize++;
      context_dictionaryToCreate[context_c] = true;
    }
    context_wc = context_w + context_c;
    if (Object.prototype.hasOwnProperty.call(context_dictionary, context_wc)) {
      context_w = context_wc;
    } else {
      if (Object.prototype.hasOwnProperty.call(context_dictionaryToCreate, context_w)) {
        if (context_w.charCodeAt(0) < 256) {
          for (i = 0; i < context_numBits; i++) {
            context_data_val = context_data_val << 1;
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
          }
          value = context_w.charCodeAt(0);
          for (i = 0; i < 8; i++) {
            context_data_val = (context_data_val << 1) | (value & 1);
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
            value = value >> 1;
          }
        } else {
          value = 1;
          for (i = 0; i < context_numBits; i++) {
            context_data_val = (context_data_val << 1) | value;
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
            value = 0;
          }
          value = context_w.charCodeAt(0);
          for (i = 0; i < 16; i++) {
            context_data_val = (context_data_val << 1) | (value & 1);
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
            value = value >> 1;
          }
        }
        context_enlargeIn--;
        if (context_enlargeIn == 0) {
          context_enlargeIn = Math.pow(2, context_numBits);
          context_numBits++;
        }
        delete context_dictionaryToCreate[context_w];
      } else {
        value = context_dictionary[context_w];
        for (i = 0; i < context_numBits; i++) {
          context_data_val = (context_data_val << 1) | (value & 1);
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = value >> 1;
        }
      }
      context_enlargeIn--;
      if (context_enlargeIn == 0) {
        context_enlargeIn = Math.pow(2, context_numBits);
        context_numBits++;
      }
      context_dictionary[context_wc] = context_dictSize++;
      context_w = String(context_c);
    }
  }

  if (context_w !== '') {
    if (Object.prototype.hasOwnProperty.call(context_dictionaryToCreate, context_w)) {
      if (context_w.charCodeAt(0) < 256) {
        for (i = 0; i < context_numBits; i++) {
          context_data_val = context_data_val << 1;
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
        }
        value = context_w.charCodeAt(0);
        for (i = 0; i < 8; i++) {
          context_data_val = (context_data_val << 1) | (value & 1);
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = value >> 1;
        }
      } else {
        value = 1;
        for (i = 0; i < context_numBits; i++) {
          context_data_val = (context_data_val << 1) | value;
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = 0;
        }
        value = context_w.charCodeAt(0);
        for (i = 0; i < 16; i++) {
          context_data_val = (context_data_val << 1) | (value & 1);
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = value >> 1;
        }
      }
      context_enlargeIn--;
      if (context_enlargeIn == 0) {
        context_enlargeIn = Math.pow(2, context_numBits);
        context_numBits++;
      }
      delete context_dictionaryToCreate[context_w];
    } else {
      value = context_dictionary[context_w];
      for (i = 0; i < context_numBits; i++) {
        context_data_val = (context_data_val << 1) | (value & 1);
        if (context_data_position == bitsPerChar - 1) {
          context_data_position = 0;
          context_data.push(getCharFromInt(context_data_val));
          context_data_val = 0;
        } else {
          context_data_position++;
        }
        value = value >> 1;
      }
    }
    context_enlargeIn--;
    if (context_enlargeIn == 0) {
      context_enlargeIn = Math.pow(2, context_numBits);
      context_numBits++;
    }
  }

  value = 2;
  for (i = 0; i < context_numBits; i++) {
    context_data_val = (context_data_val << 1) | (value & 1);
    if (context_data_position == bitsPerChar - 1) {
      context_data_position = 0;
      context_data.push(getCharFromInt(context_data_val));
      context_data_val = 0;
    } else {
      context_data_position++;
    }
    value = value >> 1;
  }

  while (true) {
    context_data_val = context_data_val << 1;
    if (context_data_position == bitsPerChar - 1) {
      context_data.push(getCharFromInt(context_data_val));
      break;
    }
    context_data_position++;
  }
  return context_data.join('');
}

// ---------------------------------------------------------------------------
// Build the prefill URL. The playground's `unindent` helper strips leading
// whitespace before compressing, so we do the same — otherwise round-trips
// through the live site re-indent on every save and the URL hash drifts.
// ---------------------------------------------------------------------------

function unindent(str: string): string {
  // Mirrors the upstream behaviour: drop a leading newline, then trim
  // the smallest common indentation across non-empty lines.
  const stripped = str.replace(/^\n/, '').replace(/\s+$/, '');
  const lines = stripped.split('\n');
  const indents = lines
    .filter((l) => l.trim().length > 0)
    .map((l) => l.match(/^ */)?.[0].length ?? 0);
  const min = indents.length ? Math.min(...indents) : 0;
  return lines.map((l) => l.slice(min)).join('\n');
}

const compressedMarkup = compressToEncodedURIComponent(unindent(html));
const compressedQuery = query
  ? compressToEncodedURIComponent(unindent(query))
  : '';

const base = embed
  ? 'https://testing-playground.com/embed'
  : 'https://testing-playground.com/';

const params: string[] = [`markup=${compressedMarkup}`];
if (compressedQuery) params.push(`query=${compressedQuery}`);
if (embed && panes) params.push(`panes=${encodeURIComponent(panes)}`);

// Hash form keeps the markup out of server logs and matches the
// matrix's [9] `#markup=<lz-string-compressed HTML>` tag.
const url = `${base}#${params.join('&')}`;
---

<SandboxCallout url={url} title={title} height={height} label={label ?? `Open: ${title}`}>
  <slot />
</SandboxCallout>
