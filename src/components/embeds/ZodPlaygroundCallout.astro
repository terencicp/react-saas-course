---
/**
 * ZodPlaygroundCallout — collapsible iframe for the marilari88 Zod Playground
 * with a schema (and optional sample values, zod version, zod-mini flag)
 * prefilled.
 *
 * Prefill mechanism (confirmed by reading the playground's source —
 * `src/utils/appData.ts` and `src/App.tsx` on the `marilari88/zod-playground`
 * repo): the page reads `?appdata=<lz-string.compressToEncodedURIComponent(
 * JSON.stringify({schema, values, version, isZodMini}))>` from
 * `window.location.search` on first render and seeds React state with it.
 * Local storage and the default schema are only checked if `appdata` is
 * absent. That gives the course a clean URL-injection [1] story:
 *
 *   https://zod-playground.vercel.app/?appdata=<lz-compressed JSON>
 *
 * The mechanism the [[Sandbox provider matrix]] flagged as "unconfirmed"
 * is confirmed here — see `documentation/content/overview/Sandbox provider matrix.md`.
 *
 * lz-string isn't a project dependency, and we don't want to add one, so
 * the compressor below is inlined verbatim from lz-string 1.5.0
 * (`compressToEncodedURIComponent`, MIT / WTFPL — © 2013 Pieroxy). Only the
 * compress path is included; we never need to decompress.
 *
 * Usage:
 *   <ZodPlaygroundCallout
 *     title="Email validator"
 *     schema={`const schema = z.string().email()\nreturn schema`}
 *     values={['"hi@example.com"', '"not-an-email"']}
 *     height={520}
 *   />
 */
import SandboxCallout from './SandboxCallout.astro';

interface Props {
  /** Heading for the SandboxCallout button. */
  title: string;
  /** The `schema` source code shown in the Monaco editor. Must end with
   *  `return schema` — that's how the playground evaluates it. */
  schema: string;
  /** Optional sample values, one per pane. Strings are inserted as-is, so
   *  use double quotes inside JSON values you want the playground to parse
   *  as JS literals (e.g. `'"hi@example.com"'`, not `'hi@example.com'`). */
  values?: string[];
  /** Zod version the playground should load. Defaults to a recent zod 4. */
  version?: string;
  /** Use the zod/mini export instead of the full zod surface. */
  isZodMini?: boolean;
  /** Iframe height in px. */
  height?: number;
  /** Override the "Open sandbox" label on the callout button. */
  label?: string;
}

const {
  title,
  schema,
  values = ['{}'],
  version = '4.1.16',
  isZodMini = false,
  height = 540,
  label,
} = Astro.props;

// ---------------------------------------------------------------------------
// Inlined lz-string compressToEncodedURIComponent. Same output as the npm
// package the playground itself imports, so the resulting URLs round-trip
// through the live site without modification.
// ---------------------------------------------------------------------------

const keyStrUriSafe =
  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+-$';

function compressToEncodedURIComponent(input: string): string {
  if (input == null) return '';
  return _compress(input, 6, (a: number) => keyStrUriSafe.charAt(a));
}

function _compress(
  uncompressed: string,
  bitsPerChar: number,
  getCharFromInt: (n: number) => string,
): string {
  if (uncompressed == null) return '';
  let i: number;
  let value: number;
  const context_dictionary: Record<string, number> = {};
  const context_dictionaryToCreate: Record<string, boolean> = {};
  let context_c = '';
  let context_wc = '';
  let context_w = '';
  let context_enlargeIn = 2;
  let context_dictSize = 3;
  let context_numBits = 2;
  const context_data: string[] = [];
  let context_data_val = 0;
  let context_data_position = 0;

  for (let ii = 0; ii < uncompressed.length; ii += 1) {
    context_c = uncompressed.charAt(ii);
    if (!Object.prototype.hasOwnProperty.call(context_dictionary, context_c)) {
      context_dictionary[context_c] = context_dictSize++;
      context_dictionaryToCreate[context_c] = true;
    }
    context_wc = context_w + context_c;
    if (Object.prototype.hasOwnProperty.call(context_dictionary, context_wc)) {
      context_w = context_wc;
    } else {
      if (Object.prototype.hasOwnProperty.call(context_dictionaryToCreate, context_w)) {
        if (context_w.charCodeAt(0) < 256) {
          for (i = 0; i < context_numBits; i++) {
            context_data_val = context_data_val << 1;
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
          }
          value = context_w.charCodeAt(0);
          for (i = 0; i < 8; i++) {
            context_data_val = (context_data_val << 1) | (value & 1);
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
            value = value >> 1;
          }
        } else {
          value = 1;
          for (i = 0; i < context_numBits; i++) {
            context_data_val = (context_data_val << 1) | value;
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
            value = 0;
          }
          value = context_w.charCodeAt(0);
          for (i = 0; i < 16; i++) {
            context_data_val = (context_data_val << 1) | (value & 1);
            if (context_data_position == bitsPerChar - 1) {
              context_data_position = 0;
              context_data.push(getCharFromInt(context_data_val));
              context_data_val = 0;
            } else {
              context_data_position++;
            }
            value = value >> 1;
          }
        }
        context_enlargeIn--;
        if (context_enlargeIn == 0) {
          context_enlargeIn = Math.pow(2, context_numBits);
          context_numBits++;
        }
        delete context_dictionaryToCreate[context_w];
      } else {
        value = context_dictionary[context_w];
        for (i = 0; i < context_numBits; i++) {
          context_data_val = (context_data_val << 1) | (value & 1);
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = value >> 1;
        }
      }
      context_enlargeIn--;
      if (context_enlargeIn == 0) {
        context_enlargeIn = Math.pow(2, context_numBits);
        context_numBits++;
      }
      context_dictionary[context_wc] = context_dictSize++;
      context_w = String(context_c);
    }
  }

  if (context_w !== '') {
    if (Object.prototype.hasOwnProperty.call(context_dictionaryToCreate, context_w)) {
      if (context_w.charCodeAt(0) < 256) {
        for (i = 0; i < context_numBits; i++) {
          context_data_val = context_data_val << 1;
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
        }
        value = context_w.charCodeAt(0);
        for (i = 0; i < 8; i++) {
          context_data_val = (context_data_val << 1) | (value & 1);
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = value >> 1;
        }
      } else {
        value = 1;
        for (i = 0; i < context_numBits; i++) {
          context_data_val = (context_data_val << 1) | value;
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = 0;
        }
        value = context_w.charCodeAt(0);
        for (i = 0; i < 16; i++) {
          context_data_val = (context_data_val << 1) | (value & 1);
          if (context_data_position == bitsPerChar - 1) {
            context_data_position = 0;
            context_data.push(getCharFromInt(context_data_val));
            context_data_val = 0;
          } else {
            context_data_position++;
          }
          value = value >> 1;
        }
      }
      context_enlargeIn--;
      if (context_enlargeIn == 0) {
        context_enlargeIn = Math.pow(2, context_numBits);
        context_numBits++;
      }
      delete context_dictionaryToCreate[context_w];
    } else {
      value = context_dictionary[context_w];
      for (i = 0; i < context_numBits; i++) {
        context_data_val = (context_data_val << 1) | (value & 1);
        if (context_data_position == bitsPerChar - 1) {
          context_data_position = 0;
          context_data.push(getCharFromInt(context_data_val));
          context_data_val = 0;
        } else {
          context_data_position++;
        }
        value = value >> 1;
      }
    }
    context_enlargeIn--;
    if (context_enlargeIn == 0) {
      context_enlargeIn = Math.pow(2, context_numBits);
      context_numBits++;
    }
  }

  value = 2;
  for (i = 0; i < context_numBits; i++) {
    context_data_val = (context_data_val << 1) | (value & 1);
    if (context_data_position == bitsPerChar - 1) {
      context_data_position = 0;
      context_data.push(getCharFromInt(context_data_val));
      context_data_val = 0;
    } else {
      context_data_position++;
    }
    value = value >> 1;
  }

  while (true) {
    context_data_val = context_data_val << 1;
    if (context_data_position == bitsPerChar - 1) {
      context_data.push(getCharFromInt(context_data_val));
      break;
    }
    context_data_position++;
  }
  return context_data.join('');
}

// Build the appdata payload, compress it, and assemble the prefill URL.
const appData = { schema, values, version, isZodMini };
const compressed = compressToEncodedURIComponent(JSON.stringify(appData));
const url = `https://zod-playground.vercel.app/?appdata=${compressed}`;
---

<SandboxCallout url={url} title={title} height={height} label={label ?? `Open: ${title}`}>
  <slot />
</SandboxCallout>
