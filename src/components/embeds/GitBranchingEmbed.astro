---
// Inline embed of `learngitbranching.js.org` — renders the iframe directly
// (no collapsible wrapper) because the LGB UI is the lesson, not a side note.
//
// Authors pass either a `level` id (e.g. "intro1", "rampup3", "remote1") to
// open the app at that level, or a `command` string to run an arbitrary
// semicolon-separated sequence on load (LGB's sandbox command surface — git
// commands, `level <id>`, `levels`, `reset`, `undo`, etc.). Both can be
// combined; `level` is prepended to `command` when both are passed.
//
// The iframe carries `credentialless` because the site is cross-origin
// isolated (COEP: credentialless) — see src/components/embeds/SandboxCallout.astro
// for the long version of the rationale.
//
// Scroll-jump fix: clicking an interactive element inside a cross-origin
// iframe normally makes Chromium scroll the parent page to align the iframe's
// top edge with the viewport top. We dodge this with two layers:
//
//  1. The iframe lives in a `position: fixed` figure whose left/top/width
//     are JS-mirrored to its in-flow placeholder slot on every scroll/resize
//     (and during a rAF loop while the slot is intersecting the viewport).
//     Because the figure is fixed, its document-relative offset stays at
//     viewport origin — the browser's scrollIntoView has no document offset
//     to target. Visually it still looks like an inline block that scrolls
//     with the surrounding prose.
//
//  2. Belt-and-suspenders: a snapshot+restore safety net catches any scroll
//     that still slips through. On pointerdown anywhere in the iframe we
//     snapshot `window.scrollY`; the first `scroll` event within 1s restores
//     it. The figure re-mirrors immediately so there's no flash.
interface Props {
  /** Open at a specific level id, e.g. "intro1", "rampup1", "remote1". */
  level?: string;
  /** Raw command(s) to run on load, semicolon-separated. */
  command?: string;
  /** `<iframe title>` — for accessibility, not shown. */
  title: string;
  /** Iframe height in pixels. */
  height?: number;
  /** Skip LGB's intro dialog. Defaults to true. */
  skipIntro?: boolean;
}

const { level, command, title, height = 720, skipIntro = true } = Astro.props;

const parts = [
  skipIntro ? 'NODEMO' : null,
  (level || command)
    ? `command=${encodeURIComponent(
        [level ? `level ${level}` : null, command].filter(Boolean).join('; '),
      )}`
    : null,
].filter(Boolean);

const url = `https://learngitbranching.js.org/${parts.length ? '?' + parts.join('&') : ''}`;
const id = `lgb-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="lgb-slot" data-lgb-embed={id} style={`--lgb-h: ${height}px`}>
  <figure class="lgb-embed not-content">
    <iframe
      src={url}
      title={title}
      loading="lazy"
      referrerpolicy="strict-origin-when-cross-origin"
      allow="cross-origin-isolated; clipboard-read; clipboard-write"
      credentialless></iframe>
    <figcaption>
      <span class="caption-text"><slot /></span>
      <a href={url} target="_blank" rel="noopener noreferrer">Open in a new tab ↗</a>
    </figcaption>
  </figure>
</div>

<script is:inline define:vars={{ id }}>
  (function () {
    const slot = document.querySelector(`[data-lgb-embed="${id}"]`);
    if (!slot) return;
    const fig = slot.querySelector('figure');

    // Mirror the slot's viewport bounds onto the fixed figure so it APPEARS
    // inline in the content column while technically remaining position:
    // fixed. Driven by scroll/resize events plus a rAF loop while the slot
    // is intersecting the viewport, so we cover programmatic scrolls, user
    // scrolls, and layout shifts uniformly across browsers.
    let last = { l: -1, t: -1, w: -1, v: '' };
    function update() {
      const r = slot.getBoundingClientRect();
      const offscreen = r.bottom < 0 || r.top > window.innerHeight;
      const v = offscreen ? 'hidden' : 'visible';
      if (r.left !== last.l) { fig.style.left = r.left + 'px'; last.l = r.left; }
      if (r.top !== last.t) { fig.style.top = r.top + 'px'; last.t = r.top; }
      if (r.width !== last.w) { fig.style.width = r.width + 'px'; last.w = r.width; }
      if (v !== last.v) { fig.style.visibility = v; last.v = v; }
    }
    let active = false;
    function tick() {
      update();
      if (active) requestAnimationFrame(tick);
    }
    const io = new IntersectionObserver((entries) => {
      const wasActive = active;
      active = entries.some(e => e.isIntersecting);
      if (active && !wasActive) requestAnimationFrame(tick);
      if (!active && wasActive) update();
    }, { rootMargin: '300px 0px' });
    io.observe(slot);
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    if ('ResizeObserver' in window) new ResizeObserver(update).observe(slot);
    update();

    // Snapshot+restore safety net.
    let savedY = null;
    function onScroll() {
      if (savedY === null) return;
      const target = savedY;
      savedY = null;
      window.scrollTo({ top: target, behavior: 'instant' });
      update();
    }
    fig.addEventListener('pointerdown', () => {
      savedY = Math.round(window.scrollY);
      window.addEventListener('scroll', onScroll, { once: true, passive: true });
      setTimeout(() => {
        savedY = null;
        window.removeEventListener('scroll', onScroll);
      }, 1000);
    }, true);
  })();
</script>

<style>
  /* The slot reserves layout space matching the iframe's intended size,
     so surrounding prose flows around it naturally. */
  .lgb-slot {
    height: calc(var(--lgb-h, 720px) + 2.5rem);
    margin: 1.5rem 0;
  }
  /* The figure is position: fixed — left/top/width set inline by JS to
     mirror the slot. Starts hidden so it doesn't flash at 0,0 before the
     first JS update runs. */
  .lgb-embed {
    position: fixed;
    margin: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    z-index: 1;
    visibility: hidden;
  }
  .lgb-embed iframe {
    display: block;
    width: 100%;
    height: var(--lgb-h, 720px);
    border: 0;
    background: black;
  }
  .lgb-embed figcaption {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--sl-color-gray-2);
    border-top: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-black);
  }
  .lgb-embed figcaption a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .lgb-embed figcaption a:hover { text-decoration: underline; }
  .lgb-embed figcaption :global(p) { margin: 0; display: inline; }
</style>
