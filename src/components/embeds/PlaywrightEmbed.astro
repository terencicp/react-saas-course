---
/**
 * PlaywrightEmbed — iframe wrapper for trace.playwright.dev.
 *
 * trace.playwright.dev is a statically-hosted, fully client-side build of
 * the Playwright trace inspector. It accepts a `?trace=<absolute zip URL>`
 * query parameter (multiple `trace=` params are allowed for layered/compare
 * mode) and fetches the zip in-browser — no upload, no auth. The zip must
 * be served with CORS open (`Access-Control-Allow-Origin: *`) because the
 * viewer fetches it from the trace.playwright.dev origin.
 *
 * Two render modes:
 *
 * - `expandable` (default `true`) — collapsible SandboxCallout chrome with
 *   a click-to-load button. Use when the iframe shouldn't auto-load on
 *   page hit.
 * - `expandable={false}` — plain inline iframe that loads with the page.
 *   Use when the embed *is* the lesson content (e.g. a prefilled trace
 *   the prose anchors back to).
 *
 * No SDK, no postMessage — the whole API is the URL.
 *
 * Course role: lesson 19.5.2 (Playwright trace as the debugging surface).
 * The matrix tags this row as `[1]` URL code injection — the cleanest
 * prefill on the testing unit.
 */
import SandboxCallout from './SandboxCallout.astro';

interface Props {
  /**
   * Absolute URL to a public `trace.zip`. Must respond with binary content
   * and a permissive `Access-Control-Allow-Origin` header. Required unless
   * `zipUrls` is set.
   */
  zipUrl?: string;
  /** Pass multiple trace URLs to render compare/layer mode. Overrides `zipUrl`. */
  zipUrls?: string[];
  /** Iframe title (accessibility). */
  title?: string;
  /** Iframe height in pixels. */
  height?: number;
  /** Button label (only used when `expandable` is true). */
  label?: string;
  /**
   * When `true` (default), wraps the iframe in the collapsible
   * SandboxCallout button. When `false`, renders a plain inline iframe
   * that loads immediately with the page.
   */
  expandable?: boolean;
}

const {
  zipUrl,
  zipUrls,
  title = 'Playwright Trace Viewer',
  height = 640,
  label = 'Open in Trace Viewer',
  expandable = true,
} = Astro.props;

const BASE = 'https://trace.playwright.dev/';

// Build the query string. The viewer reads `?trace=` (repeatable) — passing
// it multiple times opens compare mode. Single trace = standard inspector.
const urls = zipUrls && zipUrls.length > 0 ? zipUrls : zipUrl ? [zipUrl] : [];
if (urls.length === 0) {
  throw new Error('PlaywrightEmbed: pass `zipUrl` or `zipUrls`.');
}
const query = urls.map((u) => `trace=${encodeURIComponent(u)}`).join('&');
const resolvedUrl = `${BASE}?${query}`;
---

{expandable ? (
  <SandboxCallout url={resolvedUrl} title={title} height={height} label={label}>
    <slot />
  </SandboxCallout>
) : (
  <div class="playwright-embed not-content" style={`--playwright-embed-h: ${height}px`}>
    <div class="frame">
      <iframe
        src={resolvedUrl}
        title={title}
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
        allow="cross-origin-isolated; clipboard-read; clipboard-write"
        credentialless></iframe>
    </div>
  </div>
)}

<style>
  .playwright-embed {
    margin: 1.5rem 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    overflow: hidden;
  }
  .playwright-embed .frame {
    position: relative;
    width: 100%;
    height: var(--playwright-embed-h, 640px);
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }
  .playwright-embed .frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
