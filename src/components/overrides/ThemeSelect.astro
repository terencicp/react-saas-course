---
// Starlight `ThemeSelect` override. The course site has no theme picker —
// the theme always follows the OS (`prefers-color-scheme`) — so the slot the
// picker occupied (desktop header right-group AND the mobile menu footer:
// this component renders TWICE per page) hosts the "?" button that opens the
// AI assistant instead.
//
// Two responsibilities move here from the stock component
// (node_modules/@astrojs/starlight/components/ThemeSelect.astro):
//
//   1. Forcing the stored preference to auto. ThemeProvider (still stock,
//      runs pre-paint) reads `localStorage['starlight-theme']` and falls back
//      to the media query when it's '' — exactly what stock `storeTheme`
//      writes for "auto". Users who picked an explicit theme before this
//      override shipped get healed back to auto here.
//   2. The live `prefers-color-scheme` listener. It lived in the stock
//      ThemeSelect's script, so it must be re-added or an OS theme flip
//      would not repaint until reload. `ai-chat:theme-change` lets the chat
//      widget re-render its mermaid diagrams on flips.
import { Icon } from 'astro-icon/components';
---

<button
	type="button"
	class="ai-chat-toggle"
	data-ai-chat-toggle
	aria-label="Open the AI tutor"
	title="Ask the AI tutor"
>
	<Icon name="lucide:sparkles" />
</button>

<script is:inline>
	(function () {
		if (window.__aiChatThemeForced) return;
		window.__aiChatThemeForced = true;
		try {
			localStorage.setItem('starlight-theme', '');
		} catch (e) {}
		// ThemeProvider may have painted from a stale explicit preference in
		// the same pass; re-derive from the OS now that the store is auto.
		var apply = function (light) {
			document.documentElement.dataset.theme = light ? 'light' : 'dark';
			document.dispatchEvent(new CustomEvent('ai-chat:theme-change'));
		};
		var mq = matchMedia('(prefers-color-scheme: light)');
		if ((document.documentElement.dataset.theme === 'light') !== mq.matches) {
			document.documentElement.dataset.theme = mq.matches ? 'light' : 'dark';
		}
		mq.addEventListener('change', function (e) {
			apply(e.matches);
		});
	})();
</script>

<style>
	.ai-chat-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: var(--sl-color-gray-3);
		cursor: pointer;
		font-size: 1.25rem;
	}
	.ai-chat-toggle:hover {
		color: var(--sl-color-accent);
		background: var(--sl-color-gray-6);
	}
</style>
