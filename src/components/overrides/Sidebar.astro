---
// Starlight `Sidebar` override. Renders the default sidebar, then appends a
// render-blocking inline <script> that synchronously applies `data-finished`
// to every sidebar <a> whose pathname is in `localStorage.finishedLessons`.
//
// Because this script sits in body, *after* the sidebar HTML has been parsed
// but *before* anything below it, the attributes land in the very first paint
// — no flash of dot-less sidebar.
//
// The same script also wires up the IntersectionObserver that flips a lesson
// to "finished" once `.pagination-links` has been continuously visible for
// >= 2 s. That observer needs `.pagination-links` which is rendered later in
// the body, so its setup is deferred to DOMContentLoaded.
//
// Finally, it scrolls the sidebar so the current lesson sits in the vertical
// centre of the scroll pane. With ~20 chapters expanded the pane is many
// screens tall, so deep lessons would otherwise load scrolled to the top with
// the active link far below the fold. Running synchronously here — after the
// nav is parsed but before first paint — means the pane paints already at the
// centred position, with no visible jump.
import Default from '@astrojs/starlight/components/Sidebar.astro';
---

<Default><slot /></Default>

<script is:inline>
    (function () {
        var KEY = 'finishedLessons';
        function readSet() {
            try {
                var raw = localStorage.getItem(KEY);
                var arr = raw ? JSON.parse(raw) : [];
                return new Set(Array.isArray(arr) ? arr : []);
            } catch (e) {
                return new Set();
            }
        }
        var finished = readSet();
        function paint() {
            var links = document.querySelectorAll('nav.sidebar a[href]');
            for (var i = 0; i < links.length; i++) {
                if (finished.has(links[i].pathname)) {
                    links[i].setAttribute('data-finished', '');
                }
            }
        }
        // Sync paint — render-blocking, runs before first paint.
        paint();

        // Centre the active lesson in the scroll pane. getBoundingClientRect
        // forces a synchronous reflow, so the values are accurate even mid-parse;
        // the pane's height is viewport-derived and the sidebar is fully parsed
        // above this script, so the only thing not yet final is web-font metrics.
        function centerCurrentLesson() {
            var pane = document.querySelector('nav.sidebar .sidebar-pane');
            var current = document.querySelector('nav.sidebar a[aria-current="page"]');
            if (!pane || !current) return;
            // Nothing to do when the pane isn't taller than its viewport.
            if (pane.scrollHeight <= pane.clientHeight) return;
            var paneRect = pane.getBoundingClientRect();
            var linkRect = current.getBoundingClientRect();
            var linkCenter = linkRect.top - paneRect.top + linkRect.height / 2;
            // Browser clamps the assignment to [0, scrollHeight - clientHeight].
            pane.scrollTop += linkCenter - pane.clientHeight / 2;
        }
        centerCurrentLesson();

        document.addEventListener('DOMContentLoaded', function () {
            if (/^404\b/.test(document.title)) return;
            var path = location.pathname;
            if (finished.has(path)) return;
            var pagination = document.querySelector('.pagination-links');
            if (!pagination) return;
            var timer = null;
            var observer = new IntersectionObserver(function (entries) {
                for (var i = 0; i < entries.length; i++) {
                    if (entries[i].isIntersecting) {
                        if (timer === null) {
                            timer = setTimeout(function () {
                                finished.add(path);
                                try {
                                    localStorage.setItem(KEY, JSON.stringify(Array.from(finished)));
                                } catch (e) {}
                                paint();
                                observer.disconnect();
                            }, 2000);
                        }
                    } else if (timer !== null) {
                        clearTimeout(timer);
                        timer = null;
                    }
                }
            });
            observer.observe(pagination);
        });
    })();
</script>
