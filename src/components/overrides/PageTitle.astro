---
// Starlight `PageTitle` override. Renders LessonEyebrow above the default H1
// for every page in the docs collection — chapter id, chapter title, and lesson
// number come straight from the page's frontmatter via Starlight's route locals.
//
// Mirrors the default at node_modules/@astrojs/starlight/components/PageTitle.astro
// (h1 id="_top", same Starlight CSS layer for the title styling) so the rest of
// Starlight (skip-to-top, ToC, etc.) keeps working unchanged.
import LessonEyebrow from '../ui/LessonEyebrow.astro';

const { entry } = Astro.locals.starlightRoute;
const data = entry.data;
---

<div class="page-title-block">
  <LessonEyebrow
    chapterId={data['chapter-id']}
    lessonNumber={data.sidebar?.order}
  />
  <h1 id="_top">{data.title}</h1>
</div>

<style>
  @layer starlight.core {
    /* Wrap eyebrow + H1 in a single block so Starlight's
       `.sl-container > * + *` sibling-margin rule doesn't push the H1 down. */
    .page-title-block {
      display: flex;
      flex-direction: column;
    }
    .page-title-block h1 {
      margin-top: 0;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }
</style>
