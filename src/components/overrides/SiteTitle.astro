---
// Starlight `SiteTitle` override. Replaces the default plain-text title with a
// React-inspired orbit mark + three-tone wordmark. Reads siteTitle/siteTitleHref
// from starlightRoute exactly like the default at
// node_modules/@astrojs/starlight/components/SiteTitle.astro so click/keyboard
// behavior and the `.site-title` layout rules are preserved.
const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
const words = siteTitle.split(/\s+/);
// Append `?home=1` so the root-redirect script in astro.config.mjs skips its
// "bounce to lastLesson" branch and the index page actually renders.
const homeHref = siteTitleHref === '/' ? '/?home=1' : siteTitleHref;
---

<a href={homeHref} class="site-title sl-flex" translate="no">
  <svg
    class="orbit-mark"
    viewBox="0 0 32 32"
    width="28"
    height="28"
    aria-hidden="true"
    focusable="false"
  >
    <g fill="none" stroke="currentColor" stroke-width="2">
      <ellipse cx="16" cy="16" rx="13" ry="5" />
      <ellipse cx="16" cy="16" rx="13" ry="5" transform="rotate(60 16 16)" />
      <ellipse cx="16" cy="16" rx="13" ry="5" transform="rotate(120 16 16)" />
    </g>
    <circle cx="16" cy="16" r="2.2" fill="var(--sl-color-accent)" />
  </svg>
  <span class="wordmark">
    {words.map((w, i) => <span class={`word word-${i}`}>{w}</span>)}
  </span>
</a>

<style>
  @layer starlight.core {
    .site-title {
      align-items: center;
      gap: 0.4rem;
      margin-left: -0.35rem;
      font-size: var(--sl-text-h4);
      font-weight: 700;
      letter-spacing: -0.03em;
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
    }
    .orbit-mark {
      color: var(--sl-color-accent);
      flex-shrink: 0;
    }
    .wordmark {
      display: inline-flex;
      gap: 0.3em;
      overflow: hidden;
    }
    .word-0 {
      color: var(--sl-color-gray-3);
    }
    .word-1 {
      color: var(--sl-color-accent);
    }
    .word-2 {
      color: var(--sl-color-gray-3);
    }
    /* Collapse to icon-only on narrow viewports so the title doesn't
       crowd the hamburger/search controls in Starlight's mobile header. */
    @media (max-width: 30rem) {
      .wordmark {
        display: none;
      }
    }
  }
</style>
