---
import SandboxCallout from '../ui/SandboxCallout.astro';

/**
 * Builds a stackblitz.com URL and renders it via SandboxCallout. The site
 * is cross-origin isolated (COOP same-origin + COEP credentialless, set in
 * astro.config.mjs and public/_headers), so the iframe boots WebContainer
 * directly — no wrapper page needed.
 *
 * Pick a mode:
 *   - mode="github"  → stackblitz.com/github/<repo>?embed=1&...
 *   - mode="id"      → stackblitz.com/edit/<projectId>?embed=1&...
 */
interface Props {
  mode: 'github' | 'id';
  /** "<owner>/<repo>" or "<owner>/<repo>/tree/<ref>/<path>" — required for mode="github". */
  repo?: string;
  /** Existing StackBlitz project id — required for mode="id". */
  projectId?: string;

  /** Default file open in the editor. */
  file?: string;
  /** "editor" | "preview" | "both". */
  view?: 'editor' | 'preview' | 'both';
  /** Terminal pane to show; typical value for Node templates is "dev". */
  terminal?: string;
  /** npm script to auto-run (e.g. "dev"). */
  startScript?: string;
  /** "dark" | "light". Defaults to "dark". */
  theme?: 'dark' | 'light';
  /** Gate the WebContainer boot behind a click. */
  ctl?: boolean;
  hideNavigation?: boolean;
  hideExplorer?: boolean;
  hideDevTools?: boolean;
  /** Initial preview pathname (e.g. "/about"). */
  initialPath?: string;
  /** Editor devtools pane height in percent (0–100). */
  devToolsHeight?: number;
  terminalHeight?: number;

  // Forwarded to SandboxCallout.
  title: string;
  height?: number;
  label?: string;
}

const {
  mode,
  repo,
  projectId,
  file,
  view,
  terminal,
  startScript,
  theme = 'dark',
  ctl,
  hideNavigation,
  hideExplorer,
  hideDevTools,
  initialPath,
  devToolsHeight,
  terminalHeight,
  title,
  height,
  label,
} = Astro.props;

const params = new URLSearchParams();
// Slim embed layout is the only sensible default inside a callout.
params.set('embed', '1');
if (file) params.set('file', file);
if (view) params.set('view', view);
if (terminal) params.set('terminal', terminal);
if (startScript) params.set('startScript', startScript);
if (theme) params.set('theme', theme);
if (ctl) params.set('ctl', '1');
if (hideNavigation) params.set('hideNavigation', '1');
if (hideExplorer) params.set('hideExplorer', '1');
if (hideDevTools) params.set('hidedevtools', '1');
if (initialPath) params.set('initialpath', initialPath);
if (devToolsHeight != null) params.set('devtoolsheight', String(devToolsHeight));
if (terminalHeight != null) params.set('terminalHeight', String(terminalHeight));

const base =
  mode === 'github' && repo
    ? `https://stackblitz.com/github/${repo}`
    : mode === 'id' && projectId
      ? `https://stackblitz.com/edit/${projectId}`
      : null;

if (!base) {
  throw new Error(
    `StackBlitzCallout: mode="${mode}" requires ${mode === 'github' ? '"repo"' : '"projectId"'}`,
  );
}

const url = `${base}?${params.toString()}`;
---

<SandboxCallout url={url} title={title} height={height} label={label}>
  <slot />
</SandboxCallout>
