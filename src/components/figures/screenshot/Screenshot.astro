---
interface Props {
	viewport: 'desktop' | 'tablet' | 'mobile';
}

const { viewport } = Astro.props;
const ariaLabel = `${viewport} screenshot`;
---

<div class="screenshot" data-viewport={viewport} role="img" aria-label={ariaLabel}>
	<div class="screenshot-scroll">
		<slot />
	</div>
</div>

<style>
	.screenshot {
		margin: 0 auto;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 8px;
		background: var(--sl-color-bg);
		overflow: hidden;
	}
	.screenshot[data-viewport='desktop'],
	.screenshot[data-viewport='tablet'] {
		width: 100%;
	}
	.screenshot[data-viewport='mobile'] {
		width: 100%;
		max-width: 320px;
	}
	.screenshot-scroll {
		max-height: min(70vh, 520px);
		overflow-y: auto;
		overflow-x: hidden;
	}
	.screenshot-scroll :global(img),
	.screenshot-scroll :global(picture),
	.screenshot-scroll :global(svg) {
		display: block;
		width: 100%;
		height: auto;
	}
</style>
