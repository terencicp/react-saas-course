---
// One implementation variant on a <RenderTracking>. Wraps a set of
// <Trigger> children; when multiple Implementations are present, the parent
// script renders a tab strip and swaps the active trigger set on switch.
// All implementations share the same TrackedNode tree.

interface Props {
	id: string;
	label: string;
	/** Mark this implementation as the initially selected tab. */
	default?: boolean;
}

const { id, label, default: isDefault = false } = Astro.props;
---

<div
	hidden
	data-rtp-implementation
	data-rtp-id={id}
	data-rtp-label={label}
	data-rtp-default={isDefault ? 'true' : 'false'}>
	<slot />
</div>
