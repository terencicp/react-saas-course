---
// A tree of "components" (labeled boxes) with per-node render-count badges.
// Author declares the tree via nested <TrackedNode> children and a set of
// <Trigger> buttons; clicking a trigger ticks the badges on the listed nodes
// and briefly flashes those boxes. An optional <Implementation> wrapper turns
// the trigger row into a segmented selector — switching strategies swaps the
// trigger→renders mapping (and resets badge counts), so the same external
// surface can be compared across two implementations (e.g. "without memo" vs
// "with memo", "slice selector" vs "atomic selector").
//
// Children are read declaratively — <TrackedNode>, <Trigger>, and
// <Implementation> drop hidden placeholders into the default slot; the script
// crawls them on mount to build the live UI.
//
// This component simulates React renders deterministically from the author's
// trigger→renders mapping; it does not observe a real React tree. The visual
// vocabulary (badges, flash, strategy toggle) matches the proposal so chapter
// pedagogy lands the same.

interface Props {
	title?: string;
}

const { title } = Astro.props;
---

<div class="render-tracking not-content" data-rtp-root>
	<div class="rtp-header">
		{title && <div class="rtp-title">{title}</div>}
		<button
			type="button"
			class="rtp-reset"
			data-rtp-reset
			aria-label="Reset render counts">
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
				focusable="false">
				<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
				<path d="M3 3v5h5" />
			</svg>
			<span>reset</span>
		</button>
	</div>

	<div class="rtp-tabs" data-rtp-tabs role="tablist" aria-label="Strategy"></div>

	<div class="rtp-triggers" data-rtp-triggers role="group" aria-label="Triggers"></div>

	<div class="rtp-tree" data-rtp-tree></div>

	{/* Hidden payload area: <TrackedNode>, <Trigger>, <Implementation> children
	    drop placeholder elements here; the script reads them on mount. */}
	<div class="rtp-payloads" data-rtp-payloads hidden>
		<slot />
	</div>
</div>

<style is:global>
	.render-tracking {
		position: relative;
		margin: 1.5rem 0;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 14px;
		padding: 18px 20px 20px;
	}

	/* === Header (title + reset) === */
	.render-tracking .rtp-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 14px;
		min-height: 24px;
	}
	.render-tracking .rtp-title {
		font: 600 14px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		letter-spacing: -0.005em;
	}
	.render-tracking .rtp-header:not(:has(.rtp-title)) {
		justify-content: flex-end;
	}
	.render-tracking .rtp-reset {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font: 500 11.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		background: transparent;
		border: 1px solid transparent;
		border-radius: 6px;
		padding: 4px 9px 4px 7px;
		cursor: pointer;
		transition: color 0.14s, background-color 0.14s, border-color 0.14s;
	}
	.render-tracking .rtp-reset svg {
		width: 14px;
		height: 14px;
	}
	.render-tracking .rtp-reset:hover {
		color: var(--sl-color-text);
		background: var(--sl-color-bg);
		border-color: var(--sl-color-hairline);
	}
	.render-tracking .rtp-reset:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}

	/* === Strategy selector (filled accent tabs sitting on a thick accent rule) === */
	.render-tracking .rtp-tabs {
		display: flex;
		align-items: flex-end;
		gap: 2px;
		background: transparent;
		border-bottom: 3px solid var(--sl-color-accent);
		padding: 0;
		margin: 0 0 14px;
		overflow-x: auto;
		scrollbar-width: none;
	}
	.render-tracking .rtp-tabs::-webkit-scrollbar {
		display: none;
	}
	.render-tracking .rtp-tabs:empty {
		display: none;
	}
	.render-tracking .rtp-tab {
		flex: 0 0 auto;
		font: 600 13px ui-monospace, SFMono-Regular, Menlo, monospace;
		padding: 8px 14px;
		border: 1px solid transparent;
		border-bottom: 0;
		border-top-left-radius: 8px;
		border-top-right-radius: 8px;
		background: transparent;
		color: var(--sl-color-gray-3);
		cursor: pointer;
		margin-bottom: -3px;
		white-space: nowrap;
		transition: color 0.14s, background-color 0.14s, border-color 0.14s;
	}
	.render-tracking .rtp-tab:hover {
		color: var(--sl-color-text);
		background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
	}
	.render-tracking .rtp-tab:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	.render-tracking .rtp-tab[aria-pressed='true'] {
		background: var(--sl-color-accent);
		color: #fff;
		border-color: var(--sl-color-accent);
	}

	/* === Trigger action buttons (solid blue) === */
	.render-tracking .rtp-triggers {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-bottom: 14px;
	}
	.render-tracking .rtp-triggers:empty {
		display: none;
	}
	.render-tracking .rtp-trigger {
		display: inline-flex;
		align-items: center;
		font: 600 13px ui-sans-serif, system-ui, sans-serif;
		color: #fff;
		background: var(--sl-color-accent);
		border: 1px solid var(--sl-color-accent);
		border-radius: 8px;
		padding: 8px 14px;
		cursor: pointer;
		box-shadow: 0 1px 2px color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
		transition: filter 0.14s, transform 0.06s, box-shadow 0.14s;
	}
	.render-tracking .rtp-trigger:hover {
		filter: brightness(1.08);
		box-shadow: 0 2px 6px color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}
	.render-tracking .rtp-trigger:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	.render-tracking .rtp-trigger:active {
		transform: translateY(1px);
		box-shadow: 0 1px 1px color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
	}

	/* === Tree container === */
	.render-tracking .rtp-tree {
		display: flex;
		flex-direction: column;
		gap: 8px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 10px;
		padding: 12px 14px;
		min-height: 60px;
	}
	.render-tracking .rtp-tree:empty::before {
		content: 'No nodes declared.';
		font: 500 12.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-4);
		font-style: italic;
	}

	/* === Tracked node === */
	.render-tracking .rtp-node {
		position: relative;
		display: block;
		background: transparent;
		border: 1px solid var(--sl-color-hairline-light, var(--sl-color-hairline));
		border-radius: 8px;
		padding: 9px 12px;
		transition: background-color 0.4s ease-out, border-color 0.4s ease-out, box-shadow 0.4s ease-out;
	}
	.render-tracking .rtp-node.is-flashing {
		background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
		border-color: var(--sl-color-accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--sl-color-accent) 18%, transparent);
		transition: background-color 0.05s ease-in, border-color 0.05s ease-in, box-shadow 0.05s ease-in;
	}
	.render-tracking .rtp-node-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}
	.render-tracking .rtp-node-label {
		font: 600 13px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-text);
		letter-spacing: -0.005em;
		min-width: 0;
		overflow-wrap: anywhere;
	}

	/* === Render-count badge === */
	.render-tracking .rtp-badge {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font: 600 11px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		background: transparent;
		border: 1px dashed var(--sl-color-hairline);
		border-radius: 999px;
		padding: 2px 8px 2px 6px;
		flex: 0 0 auto;
		transition: color 0.14s, background-color 0.14s, border-color 0.14s;
	}
	.render-tracking .rtp-badge::before {
		content: '';
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--sl-color-gray-5);
		transition: background-color 0.14s;
	}
	.render-tracking .rtp-badge[data-count='0']::after {
		content: 'renders';
		color: var(--sl-color-gray-3);
	}
	.render-tracking .rtp-badge[data-count='0'] .rtp-badge-count {
		display: none;
	}
	.render-tracking .rtp-badge:not([data-count='0']) {
		color: #fff;
		background: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
		border-style: solid;
	}
	.render-tracking .rtp-badge:not([data-count='0'])::before {
		background: #fff;
	}
	.render-tracking .rtp-badge.is-flashing {
		animation: rtp-fade 0.4s ease-out;
	}
	@keyframes rtp-fade {
		0% {
			opacity: 0.3;
		}
		100% {
			opacity: 1;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.render-tracking .rtp-badge.is-flashing {
			animation: none;
		}
	}

	/* === Nested children === */
	.render-tracking .rtp-children {
		display: flex;
		flex-direction: column;
		gap: 6px;
		margin: 8px 0 0 6px;
		padding-left: 14px;
		border-left: 2px solid var(--sl-color-hairline);
	}
	.render-tracking .rtp-children:empty {
		display: none;
	}
	.render-tracking .rtp-children[data-layout='row'] {
		flex-direction: row;
		flex-wrap: wrap;
		gap: 8px;
	}
	.render-tracking .rtp-children[data-layout='row'] > .rtp-node {
		flex: 1 1 180px;
		min-width: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.render-tracking .rtp-node,
		.render-tracking .rtp-badge,
		.render-tracking .rtp-trigger {
			transition: background-color 0.2s linear, color 0.2s linear, border-color 0.2s linear !important;
			transform: none !important;
		}
		.render-tracking .rtp-node.is-flashing {
			box-shadow: none;
		}
		.render-tracking .rtp-trigger::before {
			transition: opacity 0.2s linear !important;
		}
	}
</style>

<script>
	type NodeDef = {
		id: string;
		label: string;
		children: NodeDef[];
		layout?: 'row' | 'col';
	};
	type TriggerDef = { id: string; label: string; renders: string[] };
	type ImplDef = { id: string; label: string; isDefault: boolean; triggers: TriggerDef[] };

	function parseRenders(s: string | undefined): string[] {
		if (!s) return [];
		return s
			.split(',')
			.map((p) => p.trim())
			.filter(Boolean);
	}

	function parseNode(el: HTMLElement): NodeDef {
		const id = el.dataset.rtpId ?? '';
		const label = el.dataset.rtpLabel ?? id;
		const layout = (el.dataset.rtpLayout as 'row' | 'col' | undefined) ?? undefined;
		const children = Array.from(
			el.querySelectorAll<HTMLElement>(':scope > [data-rtp-node]'),
		).map(parseNode);
		return { id, label, children, layout };
	}

	function parseTriggers(scope: HTMLElement): TriggerDef[] {
		return Array.from(
			scope.querySelectorAll<HTMLElement>(':scope > [data-rtp-trigger]'),
		).map((el) => ({
			id: el.dataset.rtpId ?? '',
			label: el.dataset.rtpLabel ?? el.dataset.rtpId ?? '',
			renders: parseRenders(el.dataset.rtpRenders),
		}));
	}

	function renderTree(treeEl: HTMLElement, nodes: NodeDef[]) {
		for (const n of nodes) {
			const nodeEl = document.createElement('div');
			nodeEl.className = 'rtp-node';
			nodeEl.dataset.id = n.id;

			const row = document.createElement('div');
			row.className = 'rtp-node-row';

			const labelEl = document.createElement('span');
			labelEl.className = 'rtp-node-label';
			labelEl.textContent = `<${n.label} />`;

			const badge = document.createElement('span');
			badge.className = 'rtp-badge';
			badge.dataset.idBadge = n.id;
			badge.dataset.count = '0';
			badge.setAttribute('aria-live', 'polite');
			badge.setAttribute('aria-label', `${n.label} render count: 0`);
			const badgeCount = document.createElement('span');
			badgeCount.className = 'rtp-badge-count';
			badgeCount.textContent = '0 renders';
			badge.appendChild(badgeCount);

			row.appendChild(labelEl);
			row.appendChild(badge);
			nodeEl.appendChild(row);

			if (n.children.length > 0) {
				const childrenEl = document.createElement('div');
				childrenEl.className = 'rtp-children';
				if (n.layout === 'row') childrenEl.dataset.layout = 'row';
				renderTree(childrenEl, n.children);
				nodeEl.appendChild(childrenEl);
			}

			treeEl.appendChild(nodeEl);
		}
	}

	document.querySelectorAll<HTMLElement>('[data-rtp-root]').forEach((root) => {
		const tabsEl = root.querySelector<HTMLElement>('[data-rtp-tabs]');
		const triggersEl = root.querySelector<HTMLElement>('[data-rtp-triggers]');
		const treeEl = root.querySelector<HTMLElement>('[data-rtp-tree]');
		const resetBtn = root.querySelector<HTMLButtonElement>('[data-rtp-reset]');
		const payloads = root.querySelector<HTMLElement>('[data-rtp-payloads]');

		if (!tabsEl || !triggersEl || !treeEl || !resetBtn || !payloads) return;

		const nodes: NodeDef[] = Array.from(
			payloads.querySelectorAll<HTMLElement>(':scope > [data-rtp-node]'),
		).map(parseNode);

		const implEls = Array.from(
			payloads.querySelectorAll<HTMLElement>(':scope > [data-rtp-implementation]'),
		);

		const implementations: ImplDef[] = implEls.map((el) => ({
			id: el.dataset.rtpId ?? '',
			label: el.dataset.rtpLabel ?? el.dataset.rtpId ?? '',
			isDefault: (el.dataset.rtpDefault ?? 'false') === 'true',
			triggers: parseTriggers(el),
		}));

		const rootTriggers: TriggerDef[] = parseTriggers(payloads);

		renderTree(treeEl, nodes);

		let activeImplId: string | null = null;
		if (implementations.length > 0) {
			activeImplId =
				implementations.find((i) => i.isDefault)?.id ?? implementations[0].id;
		}

		const tabButtons = new Map<string, HTMLButtonElement>();

		function currentTriggers(): TriggerDef[] {
			if (implementations.length === 0) return rootTriggers;
			const impl = implementations.find((i) => i.id === activeImplId);
			return impl ? impl.triggers : [];
		}

		function setBadge(badge: HTMLElement, count: number) {
			badge.dataset.count = String(count);
			const countEl = badge.querySelector<HTMLElement>('.rtp-badge-count');
			if (countEl) {
				countEl.textContent = count === 1 ? '1 render' : `${count} renders`;
			}
			const id = badge.dataset.idBadge ?? '';
			badge.setAttribute('aria-label', `${id} render count: ${count}`);
		}

		function resetCounts() {
			const badges = root.querySelectorAll<HTMLElement>('[data-id-badge]');
			badges.forEach((b) => setBadge(b, 0));
		}

		function fireTrigger(t: TriggerDef) {
			for (const nodeId of t.renders) {
				const nodeEl = treeEl!.querySelector<HTMLElement>(
					`.rtp-node[data-id="${CSS.escape(nodeId)}"]`,
				);
				const badge = treeEl!.querySelector<HTMLElement>(
					`[data-id-badge="${CSS.escape(nodeId)}"]`,
				);
				if (!nodeEl || !badge) continue;
				const next = (parseInt(badge.dataset.count ?? '0', 10) || 0) + 1;
				setBadge(badge, next);
				nodeEl.classList.add('is-flashing');
				// Restart the ping animation: removing then re-adding the class on
				// the next frame retriggers the @keyframes from 0%.
				badge.classList.remove('is-flashing');
				void badge.offsetWidth;
				badge.classList.add('is-flashing');
				window.setTimeout(() => {
					nodeEl.classList.remove('is-flashing');
				}, 380);
			}
		}

		function renderTriggers() {
			triggersEl!.innerHTML = '';
			for (const t of currentTriggers()) {
				const btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'rtp-trigger';
				btn.textContent = t.label;
				btn.dataset.triggerId = t.id;
				btn.addEventListener('click', () => fireTrigger(t));
				triggersEl!.appendChild(btn);
			}
		}

		function renderTabs() {
			tabsEl!.innerHTML = '';
			tabButtons.clear();
			if (implementations.length === 0) return;
			for (const impl of implementations) {
				const btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'rtp-tab';
				btn.textContent = impl.label;
				btn.setAttribute('role', 'tab');
				btn.setAttribute('aria-pressed', impl.id === activeImplId ? 'true' : 'false');
				btn.dataset.implId = impl.id;
				btn.addEventListener('click', () => {
					if (impl.id === activeImplId) return;
					activeImplId = impl.id;
					tabButtons.forEach((b, id) => {
						b.setAttribute('aria-pressed', id === activeImplId ? 'true' : 'false');
					});
					resetCounts();
					renderTriggers();
				});
				tabsEl!.appendChild(btn);
				tabButtons.set(impl.id, btn);
			}
		}

		resetBtn.addEventListener('click', () => {
			resetCounts();
		});

		renderTabs();
		renderTriggers();
	});
</script>
