---
// One trigger button on a <RenderTracking>. Declared as a child;
// the parent script reads id/label/renders off the dataset and renders the
// actual button in the trigger row. `renders` is a comma-separated list of
// TrackedNode ids that re-render when this trigger fires.

interface Props {
	id: string;
	label: string;
	/** Comma-separated TrackedNode ids that re-render when this trigger fires. */
	renders: string;
}

const { id, label, renders } = Astro.props;
---

<span
	hidden
	data-rtp-trigger
	data-rtp-id={id}
	data-rtp-label={label}
	data-rtp-renders={renders}></span>
