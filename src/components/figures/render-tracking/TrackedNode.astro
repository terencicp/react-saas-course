---
// One node in a <RenderTracking> tree. Recursive — its default slot
// holds nested <TrackedNode> children. The parent script crawls the placeholder
// tree on mount and renders the live tree with per-node render-count badges.

interface Props {
	id: string;
	label: string;
}

const { id, label } = Astro.props;
---

<div hidden data-rtp-node data-rtp-id={id} data-rtp-label={label}>
	<slot />
</div>
