---
// Steps through a temporal sequence with a slider + back/forward buttons.
// Wrap <DiagramStep> children inside; each step's content takes the same
// grid cell so the stage sizes to the tallest step and never jumps height
// as the user moves through the sequence.
---

<div class="diagram-sequence not-content" data-ds-root>
	<div class="ds-stage" data-ds-stage>
		<slot />
	</div>

	<div class="ds-controls" data-ds-controls>
		<button type="button" class="ds-btn ds-btn-prev" data-ds-prev aria-label="Previous step">
			<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<polyline points="9 3 4 7 9 11"></polyline>
			</svg>
		</button>

		<div class="ds-slider-wrap">
			<input type="range" class="ds-slider" data-ds-slider min="0" max="0" value="0" step="1" aria-label="Sequence step" />
			<div class="ds-ticks" data-ds-ticks aria-hidden="true"></div>
		</div>

		<button type="button" class="ds-btn ds-btn-next" data-ds-next aria-label="Next step">
			<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<polyline points="5 3 10 7 5 11"></polyline>
			</svg>
		</button>
	</div>
</div>

<style is:global>
	.diagram-sequence {
		--ds-accent: hsl(217, 91%, 60%);
		--ds-thumb-size: 18px;

		margin: 1.5rem 0;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 12px;
		padding: 18px;
	}

	/* Grid stack: every step occupies the same cell so the stage sizes to the
	   tallest step. Inactive steps are kept in layout (visibility: hidden) so
	   the height stays constant as the user moves through the sequence. */
	.diagram-sequence .ds-stage {
		display: grid;
		margin-bottom: 16px;
	}
	.diagram-sequence .ds-step {
		grid-column: 1;
		grid-row: 1;
		visibility: hidden;
		min-width: 0;
	}
	.diagram-sequence .ds-step.is-active {
		visibility: visible;
	}
	.diagram-sequence .ds-step-body > :first-child {
		margin-top: 0;
	}
	.diagram-sequence .ds-step-body > :last-child {
		margin-bottom: 0;
	}
	.diagram-sequence .ds-step-caption {
		margin: 14px 4px 0;
		font-size: 14px;
		line-height: 1.6;
		color: var(--sl-color-gray-3);
	}
	.diagram-sequence .ds-step-caption :global(p) {
		margin: 0 0 8px;
	}
	.diagram-sequence .ds-step-caption :global(p:last-child) {
		margin-bottom: 0;
	}

	.diagram-sequence .ds-controls {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.diagram-sequence .ds-btn {
		flex: 0 0 auto;
		width: 34px;
		height: 34px;
		display: grid;
		place-items: center;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 8px;
		color: var(--sl-color-text);
		cursor: pointer;
		padding: 0;
		transition: border-color 0.14s, background-color 0.14s, color 0.14s;
	}
	.diagram-sequence .ds-btn:hover:not(:disabled) {
		border-color: var(--ds-accent);
		color: var(--ds-accent);
	}
	.diagram-sequence .ds-btn:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}

	.diagram-sequence .ds-slider-wrap {
		flex: 1;
		position: relative;
		min-width: 0;
		padding-bottom: 14px; /* room for the tick row */
	}

	.diagram-sequence .ds-slider {
		appearance: none;
		-webkit-appearance: none;
		width: 100%;
		height: var(--ds-thumb-size);
		background: transparent;
		outline: none;
		margin: 0;
		display: block;
		cursor: pointer;
	}
	.diagram-sequence .ds-slider:disabled {
		cursor: not-allowed;
		opacity: 0.5;
	}
	/* Track */
	.diagram-sequence .ds-slider::-webkit-slider-runnable-track {
		height: 4px;
		background: var(--sl-color-hairline);
		border-radius: 2px;
	}
	.diagram-sequence .ds-slider::-moz-range-track {
		height: 4px;
		background: var(--sl-color-hairline);
		border-radius: 2px;
	}
	/* Thumb */
	.diagram-sequence .ds-slider::-webkit-slider-thumb {
		appearance: none;
		-webkit-appearance: none;
		width: var(--ds-thumb-size);
		height: var(--ds-thumb-size);
		background: var(--ds-accent);
		border: 2px solid var(--sl-color-bg);
		border-radius: 50%;
		margin-top: calc((4px - var(--ds-thumb-size)) / 2);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
	}
	.diagram-sequence .ds-slider::-moz-range-thumb {
		width: var(--ds-thumb-size);
		height: var(--ds-thumb-size);
		background: var(--ds-accent);
		border: 2px solid var(--sl-color-bg);
		border-radius: 50%;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
	}
	.diagram-sequence .ds-slider:focus-visible::-webkit-slider-thumb {
		outline: 2px solid var(--ds-accent);
		outline-offset: 2px;
	}
	.diagram-sequence .ds-slider:focus-visible::-moz-range-thumb {
		outline: 2px solid var(--ds-accent);
		outline-offset: 2px;
	}

	/* Ticks live in the same coordinate space as the thumb's *center* travel:
	   the thumb center moves from thumb-radius to (width - thumb-radius), so
	   we inset the tick row by half the thumb width on each side and place
	   ticks at percentages within that inner range. */
	.diagram-sequence .ds-ticks {
		position: absolute;
		left: calc(var(--ds-thumb-size) / 2);
		right: calc(var(--ds-thumb-size) / 2);
		bottom: 0;
		height: 12px;
		pointer-events: none;
	}
	.diagram-sequence .ds-tick {
		position: absolute;
		top: 0;
		width: 1.5px;
		height: 6px;
		background: var(--sl-color-gray-4);
		border-radius: 1px;
		transform: translateX(-50%);
		transition: height 0.14s, background-color 0.14s;
	}
	.diagram-sequence .ds-tick.is-active {
		height: 10px;
		background: var(--ds-accent);
	}
</style>

<script>
	document.querySelectorAll<HTMLElement>('[data-ds-root]').forEach((root) => {
		const stage = root.querySelector<HTMLElement>('[data-ds-stage]');
		const slider = root.querySelector<HTMLInputElement>('[data-ds-slider]');
		const ticksEl = root.querySelector<HTMLElement>('[data-ds-ticks]');
		const prevBtn = root.querySelector<HTMLButtonElement>('[data-ds-prev]');
		const nextBtn = root.querySelector<HTMLButtonElement>('[data-ds-next]');
		if (!stage || !slider || !ticksEl || !prevBtn || !nextBtn) return;

		const steps = Array.from(stage.querySelectorAll<HTMLElement>('[data-ds-step]'));
		const count = steps.length;
		if (count === 0) return;

		// Configure slider for the actual step count.
		slider.min = '0';
		slider.max = String(Math.max(0, count - 1));
		slider.value = '0';
		if (count <= 1) slider.disabled = true;

		// Generate tick marks aligned with each slider position.
		const tickEls: HTMLElement[] = [];
		for (let i = 0; i < count; i++) {
			const t = document.createElement('span');
			t.className = 'ds-tick';
			// With 1 step the tick sits dead center; otherwise spread 0..100%.
			t.style.left = count === 1 ? '50%' : (i / (count - 1)) * 100 + '%';
			ticksEl.appendChild(t);
			tickEls.push(t);
		}

		function setActive(index: number) {
			const i = Math.max(0, Math.min(count - 1, index));
			steps.forEach((s, k) => s.classList.toggle('is-active', k === i));
			tickEls.forEach((t, k) => t.classList.toggle('is-active', k === i));
			slider!.value = String(i);
			prevBtn!.disabled = i === 0;
			nextBtn!.disabled = i === count - 1;
		}

		slider.addEventListener('input', () => setActive(Number(slider.value)));
		prevBtn.addEventListener('click', () => setActive(Number(slider.value) - 1));
		nextBtn.addEventListener('click', () => setActive(Number(slider.value) + 1));

		setActive(0);
	});
</script>
