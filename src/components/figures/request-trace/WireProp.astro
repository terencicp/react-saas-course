---
// One prop crossing a server→client boundary. Declared as a direct child of
// the receiving <TraceNode kind="client">. The parent script reads the
// dataset on mount and renders a row in the wire panel during the `wire`
// phase. `status` drives the visual treatment ("ok" / "rejected" / "leak").

interface Props {
	name: string;
	/** Display value, e.g. `"() => archive(id)"` or `"{ id, total }"`. */
	value?: string;
	status: 'ok' | 'rejected' | 'leak';
	/** One-line explanation shown beneath the row. */
	note?: string;
}

const { name, value, status, note } = Astro.props;
---

<span
	hidden
	data-rt-wireprop
	data-rt-name={name}
	data-rt-value={value}
	data-rt-status={status}
	data-rt-note={note}></span>
