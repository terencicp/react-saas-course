---
// Optional per-phase caption override on a <RequestTrace>. Without one, the
// phase shows a built-in default caption. Plain text via `caption=`; rich
// MDX (inline code, links) via the default slot — the slot wins when both
// are present.

interface Props {
	id: 'request' | 'server-render' | 'wire' | 'shell' | 'stream' | 'hydrate';
	caption?: string;
}

const { id, caption } = Astro.props;
const hasRichCaption = Astro.slots.has('default');
---

<div
	hidden
	data-rt-phase
	data-rt-id={id}
	data-rt-caption={caption ?? ''}
	data-rt-has-rich={hasRichCaption ? 'true' : 'false'}>
	{hasRichCaption && <div data-rt-phase-rich><slot /></div>}
</div>
