---
// A scrubbable figure that animates one request through the Next.js App
// Router: server render → RSC payload across the wire → static shell →
// streamed Suspense holes → client hydration. The author declares a
// marked-up component tree with <TraceNode>, an optional <WireProp> set on
// client boundaries, and optional <Phase> caption overrides; a fixed
// six-phase engine derives each node's transient state at every phase.
//
// Children are read declaratively — <TraceNode>, <WireProp>, and <Phase>
// drop hidden placeholders into the default slot; the script crawls them on
// mount and builds the live UI.
//
// This component simulates the App Router execution model deterministically
// from the author's markup. It does not run Next.js, RSC, or a bundler — the
// simulation encodes the correct model so lesson markup is correct by
// construction. See `documentation/components/figures/request-trace.spec.md`.

interface Props {
	title?: string;
	/** Comma-separated subset of phase ids. Renders in canonical order. */
	phases?: string;
	/** Optional request URL shown next to the lane strip. Cosmetic. */
	url?: string;
}

const { title, phases, url } = Astro.props;
---

<div class="request-trace not-content" data-rt-root data-rt-phases={phases}>
	<div class="rt-header">
		{title && <div class="rt-title">{title}</div>}
		<button
			type="button"
			class="rt-reset"
			data-rt-reset
			aria-label="Reset to first phase">
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
				focusable="false">
				<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
				<path d="M3 3v5h5"></path>
			</svg>
			<span>reset</span>
		</button>
	</div>

	<div class="rt-lanes" role="presentation" aria-hidden="true">
		<span class="rt-lane" data-rt-lane="server">
			<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="2" y="3" width="20" height="8" rx="2"></rect>
				<rect x="2" y="13" width="20" height="8" rx="2"></rect>
				<line x1="6" y1="7" x2="6.01" y2="7"></line>
				<line x1="6" y1="17" x2="6.01" y2="17"></line>
			</svg>
			Server
		</span>
		<span class="rt-lane-sep" aria-hidden="true">
			<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="9 18 15 12 9 6"></polyline>
			</svg>
		</span>
		<span class="rt-lane" data-rt-lane="network">
			<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="10"></circle>
				<line x1="2" y1="12" x2="22" y2="12"></line>
				<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
			</svg>
			Network
		</span>
		<span class="rt-lane-sep" aria-hidden="true">
			<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="9 18 15 12 9 6"></polyline>
			</svg>
		</span>
		<span class="rt-lane" data-rt-lane="browser">
			<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="2" y="3" width="20" height="18" rx="2"></rect>
				<line x1="2" y1="8" x2="22" y2="8"></line>
				<circle cx="5" cy="5.5" r="0.7"></circle>
				<circle cx="7.5" cy="5.5" r="0.7"></circle>
			</svg>
			Browser
		</span>
		{url && (
			<span class="rt-url" data-rt-url>
				<span class="rt-url-method">GET</span>
				<span class="rt-url-path">{url}</span>
			</span>
		)}
	</div>

	<div class="rt-stage" data-rt-stage></div>

	<div class="rt-scrubber" data-rt-scrubber>
		<button
			type="button"
			class="rt-btn rt-btn-prev"
			data-rt-prev
			aria-label="Previous phase">
			<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<polyline points="9 3 4 7 9 11"></polyline>
			</svg>
			<span class="rt-btn-label">Prev</span>
		</button>

		<div class="rt-slider-wrap">
			<input
				type="range"
				class="rt-slider"
				data-rt-slider
				min="0"
				max="0"
				value="0"
				step="1"
				aria-label="Request phase"
			/>
			<div class="rt-ticks" data-rt-ticks aria-hidden="true"></div>
			<div class="rt-tick-labels" data-rt-tick-labels aria-hidden="true"></div>
		</div>

		<button
			type="button"
			class="rt-btn rt-btn-next"
			data-rt-next
			aria-label="Next phase">
			<span class="rt-btn-label">Next</span>
			<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<polyline points="5 3 10 7 5 11"></polyline>
			</svg>
		</button>
	</div>

	<div class="rt-caption" data-rt-caption aria-live="polite" aria-atomic="true"></div>

	{/* The wire panel is the LAST element in the card so it can fully collapse
	    when the learner is off the `wire` phase without pushing the scrubber
	    or caption — only the figure's own bottom edge moves. */}
	<div class="rt-wire-panel" data-rt-wire-panel hidden>
		<div class="rt-wire-title">Props crossing the wire</div>
		<div class="rt-wire-rows" data-rt-wire-rows></div>
	</div>

	{/* Hidden payload area: <TraceNode>, <WireProp>, <Phase> children drop
	    placeholder elements here; the script reads them on mount. */}
	<div class="rt-payloads" data-rt-payloads hidden>
		<slot />
	</div>
</div>

<style is:global>
	.request-trace {
		--rt-pad: 18px;
		position: relative;
		margin: 1.5rem 0;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 14px;
		padding: var(--rt-pad) 20px 20px;
	}

	/* === Header (title + reset) === */
	.request-trace .rt-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 12px;
		min-height: 24px;
	}
	.request-trace .rt-title {
		font: 600 14px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		letter-spacing: -0.005em;
	}
	.request-trace .rt-header:not(:has(.rt-title)) {
		justify-content: flex-end;
	}
	.request-trace .rt-reset {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font: 500 11.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		background: transparent;
		border: 1px solid transparent;
		border-radius: 6px;
		padding: 4px 9px 4px 7px;
		cursor: pointer;
		transition: color 0.14s, background-color 0.14s, border-color 0.14s;
	}
	.request-trace .rt-reset svg {
		width: 14px;
		height: 14px;
	}
	.request-trace .rt-reset:hover {
		color: var(--sl-color-text);
		background: var(--sl-color-bg);
		border-color: var(--sl-color-hairline);
	}
	.request-trace .rt-reset:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}

	/* === Lane strip === */
	.request-trace .rt-lanes {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
		margin-bottom: 12px;
		padding: 8px 10px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 10px;
	}
	.request-trace .rt-lane {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font: 600 12px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-4);
		padding: 4px 10px;
		border-radius: 999px;
		border: 1px solid transparent;
		transition: color 0.18s, background-color 0.18s, border-color 0.18s;
	}
	.request-trace .rt-lane.is-active {
		color: #fff;
		background: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
	}
	.request-trace .rt-lane-sep {
		color: var(--sl-color-gray-5);
		display: inline-flex;
	}
	.request-trace .rt-url {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font: 500 11.5px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-gray-2);
		padding: 3px 9px;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 6px;
	}
	.request-trace .rt-url-method {
		font-weight: 700;
		color: var(--sl-color-accent);
		font-size: 10.5px;
		letter-spacing: 0.04em;
	}

	/* === Stage (the tree) === */
	.request-trace .rt-stage {
		display: flex;
		flex-direction: column;
		gap: 8px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 10px;
		padding: 12px 14px;
		min-height: 80px;
	}
	.request-trace .rt-stage:empty::before {
		content: 'No nodes declared.';
		font: 500 12.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-4);
		font-style: italic;
	}

	.request-trace .rt-node {
		position: relative;
		display: block;
		background: transparent;
		border: 1px solid var(--sl-color-hairline-light, var(--sl-color-hairline));
		border-radius: 8px;
		padding: 9px 12px;
		min-height: 38px;
		transition:
			background-color 0.25s ease,
			border-color 0.25s ease,
			box-shadow 0.25s ease,
			opacity 0.25s ease;
	}
	.request-trace .rt-node.is-hidden-fallback {
		opacity: 0.32;
	}
	.request-trace .rt-node.is-dimmed {
		opacity: 0.7;
	}
	.request-trace .rt-node-row {
		display: flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
		min-height: 22px;
	}
	/* Cache-miss server nodes pick up a `STORED` chip on `server-render` and
	   `wire`. With a cache marker + role tag + label + state badge already on
	   the row, adding the chip can push the row to wrap a second line on the
	   chip-bearing phases — moving the slider up/down. Reserve the wrapped
	   height up front on these nodes so the row keeps a constant height. */
	.request-trace .rt-node[data-rt-reserve-chip] > .rt-node-row {
		min-height: 46px;
	}
	.request-trace .rt-node-label {
		font: 600 13px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-text);
		letter-spacing: -0.005em;
		min-width: 0;
		overflow-wrap: anywhere;
	}

	/* Role tag — persistent, always visible */
	.request-trace .rt-tag {
		display: inline-flex;
		align-items: center;
		font: 700 9.5px ui-sans-serif, system-ui, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 2px 6px;
		border-radius: 4px;
		border: 1px solid currentColor;
		background: color-mix(in srgb, currentColor 8%, transparent);
		flex: 0 0 auto;
	}
	.request-trace .rt-tag[data-rt-kind='server'] {
		color: var(--sl-color-blue, var(--sl-color-accent));
	}
	.request-trace .rt-tag[data-rt-kind='client'] {
		color: var(--sl-color-purple, var(--sl-color-accent-high));
	}
	.request-trace .rt-tag[data-rt-kind='suspense'] {
		color: var(--sl-color-orange, var(--sl-color-accent));
	}

	/* State badge — transient, recomputed per phase */
	.request-trace .rt-state {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font: 600 11px ui-sans-serif, system-ui, sans-serif;
		padding: 2px 8px 2px 7px;
		border-radius: 999px;
		border: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg-sidebar);
		color: var(--sl-color-gray-3);
		margin-left: auto;
		flex: 0 0 auto;
		transition: color 0.2s, background-color 0.2s, border-color 0.2s;
	}
	.request-trace .rt-state::before {
		content: '';
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: currentColor;
		opacity: 0.75;
		flex: 0 0 auto;
	}
	.request-trace .rt-state-detail {
		font: 500 11px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-gray-3);
		flex: 0 0 auto;
	}

	/* State palette — text/border/background swap per state. */
	.request-trace .rt-state[data-state='idle'] {
		color: var(--sl-color-gray-3);
		background: var(--sl-color-bg-sidebar);
		border-color: var(--sl-color-hairline);
	}
	.request-trace .rt-state[data-state='rendering'] {
		color: #fff;
		background: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
	}
	.request-trace .rt-state[data-state='awaiting'] {
		color: var(--sl-color-orange, var(--sl-color-accent));
		background: color-mix(in srgb, var(--sl-color-orange, var(--sl-color-accent)) 14%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-orange, var(--sl-color-accent)) 55%, transparent);
	}
	.request-trace .rt-state[data-state='prerendered'] {
		color: var(--sl-color-purple, var(--sl-color-accent-high));
		background: color-mix(in srgb, var(--sl-color-purple, var(--sl-color-accent-high)) 12%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-purple, var(--sl-color-accent-high)) 55%, transparent);
	}
	.request-trace .rt-state[data-state='cached'] {
		color: var(--sl-color-green, var(--sl-color-accent));
		background: color-mix(in srgb, var(--sl-color-green, var(--sl-color-accent)) 14%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-green, var(--sl-color-accent)) 55%, transparent);
	}
	.request-trace .rt-state[data-state='shell'] {
		color: var(--sl-color-text);
		background: color-mix(in srgb, var(--sl-color-accent) 16%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-accent) 55%, transparent);
	}
	.request-trace .rt-state[data-state='fallback'] {
		color: var(--sl-color-orange, var(--sl-color-accent));
		background: color-mix(in srgb, var(--sl-color-orange, var(--sl-color-accent)) 16%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-orange, var(--sl-color-accent)) 55%, transparent);
		border-style: dashed;
	}
	.request-trace .rt-state[data-state='streamed'] {
		color: #fff;
		background: var(--sl-color-green, var(--sl-color-accent));
		border-color: var(--sl-color-green, var(--sl-color-accent));
	}
	.request-trace .rt-state[data-state='hydrated'] {
		color: #fff;
		background: var(--sl-color-purple, var(--sl-color-accent-high));
		border-color: var(--sl-color-purple, var(--sl-color-accent-high));
	}
	.request-trace .rt-state[data-state='painted'] {
		color: var(--sl-color-gray-2);
		background: var(--sl-color-bg-sidebar);
		border-color: var(--sl-color-gray-5);
	}
	.request-trace .rt-state[data-state='pending'] {
		color: var(--sl-color-gray-3);
		background: var(--sl-color-bg-sidebar);
		border-color: var(--sl-color-hairline);
		border-style: dashed;
	}
	.request-trace .rt-state[data-state='needs-suspense'] {
		color: var(--sl-color-red, var(--sl-color-accent));
		background: color-mix(in srgb, var(--sl-color-red, var(--sl-color-accent)) 14%, transparent);
		border-color: var(--sl-color-red, var(--sl-color-accent));
		border-style: dashed;
	}

	/* "stored" chip for cache-miss server-render */
	.request-trace .rt-chip {
		display: inline-flex;
		align-items: center;
		font: 700 9.5px ui-sans-serif, system-ui, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 2px 6px;
		border-radius: 4px;
		color: var(--sl-color-green, var(--sl-color-accent));
		border: 1px dashed color-mix(in srgb, var(--sl-color-green, var(--sl-color-accent)) 55%, transparent);
		background: color-mix(in srgb, var(--sl-color-green, var(--sl-color-accent)) 10%, transparent);
		flex: 0 0 auto;
	}

	/* Cache marker on the role row */
	.request-trace .rt-cache {
		display: inline-flex;
		align-items: center;
		font: 600 10px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-gray-3);
		padding: 1px 6px;
		border-radius: 4px;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		flex: 0 0 auto;
	}

	/* Nested children */
	.request-trace .rt-children {
		display: flex;
		flex-direction: column;
		gap: 6px;
		margin: 8px 0 0 6px;
		padding-left: 14px;
		border-left: 2px solid var(--sl-color-hairline);
	}
	.request-trace .rt-children:empty {
		display: none;
	}

	/* === Wire panel ===
	   Rendered only on the `wire` phase, and only when the trace has at least
	   one <WireProp>. Sits at the bottom of the card so its collapse is free
	   — nothing above it reflows. */
	.request-trace .rt-wire-panel {
		margin-top: 14px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 10px;
		padding: 12px 14px;
	}
	.request-trace .rt-wire-panel[hidden] {
		display: none;
	}
	.request-trace .rt-wire-title {
		font: 600 12px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		letter-spacing: -0.005em;
		margin-bottom: 8px;
	}
	.request-trace .rt-wire-rows {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.request-trace .rt-wire-boundary {
		border: 1px solid var(--sl-color-hairline);
		border-radius: 8px;
		padding: 8px 10px;
		background: var(--sl-color-bg-sidebar);
	}
	.request-trace .rt-wire-boundary-head {
		font: 600 11.5px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-gray-2);
		margin-bottom: 6px;
	}
	.request-trace .rt-wire-row {
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: 8px 10px;
		align-items: baseline;
		padding: 5px 0;
	}
	.request-trace .rt-wire-row + .rt-wire-row {
		border-top: 1px dashed var(--sl-color-hairline);
	}
	.request-trace .rt-wire-name {
		font: 600 12.5px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-text);
	}
	.request-trace .rt-wire-value {
		font: 500 12px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-gray-3);
		overflow-wrap: anywhere;
	}
	.request-trace .rt-wire-status {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font: 700 10.5px ui-sans-serif, system-ui, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 2px 8px;
		border-radius: 999px;
	}
	.request-trace .rt-wire-status[data-status='ok'] {
		color: #fff;
		background: var(--sl-color-green, var(--sl-color-accent));
	}
	.request-trace .rt-wire-status[data-status='rejected'] {
		color: #fff;
		background: var(--sl-color-red, var(--sl-color-accent));
	}
	.request-trace .rt-wire-status[data-status='leak'] {
		color: var(--sl-color-orange, var(--sl-color-accent));
		background: color-mix(in srgb, var(--sl-color-orange, var(--sl-color-accent)) 18%, transparent);
		border: 1px solid var(--sl-color-orange, var(--sl-color-accent));
	}
	.request-trace .rt-wire-note {
		grid-column: 1 / -1;
		font: 400 11.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		line-height: 1.45;
	}

	/* === Scrubber === */
	.request-trace .rt-scrubber {
		--rt-thumb-size: 18px;
		display: flex;
		align-items: center;
		gap: 12px;
		margin-top: 14px;
		/* Reserve space for ticks + tick labels that overflow below the slider-wrap.
		   The slider-wrap itself is only as tall as the slider, so buttons align
		   with the slider track instead of being centered against a taller column
		   that includes the labels. */
		padding-bottom: 36px;
	}

	.request-trace .rt-btn {
		flex: 0 0 auto;
		height: 34px;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		background: var(--sl-color-accent);
		border: 1px solid var(--sl-color-accent);
		border-radius: 8px;
		color: #fff;
		cursor: pointer;
		padding: 0 12px;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.02em;
		box-shadow: 0 1px 2px color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
		transition:
			filter 0.14s,
			box-shadow 0.14s,
			transform 0.06s,
			background-color 0.14s,
			border-color 0.14s,
			color 0.14s;
	}
	.request-trace .rt-btn:hover:not(:disabled) {
		filter: brightness(1.08);
		box-shadow: 0 2px 6px color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
	}
	.request-trace .rt-btn:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	.request-trace .rt-btn:active:not(:disabled) {
		transform: translateY(1px);
	}
	.request-trace .rt-btn:disabled {
		background: var(--sl-color-bg);
		border-color: var(--sl-color-hairline);
		color: var(--sl-color-text);
		box-shadow: none;
		opacity: 0.4;
		cursor: not-allowed;
	}
	.request-trace .rt-btn-label {
		line-height: 1;
	}

	.request-trace .rt-slider-wrap {
		flex: 1;
		position: relative;
		min-width: 0;
		height: var(--rt-thumb-size);
	}
	.request-trace .rt-slider {
		appearance: none;
		-webkit-appearance: none;
		width: 100%;
		height: var(--rt-thumb-size);
		background: transparent;
		outline: none;
		margin: 0;
		display: block;
