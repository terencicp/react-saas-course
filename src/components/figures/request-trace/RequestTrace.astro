		left: calc(var(--rt-thumb-size) / 2);
		right: calc(var(--rt-thumb-size) / 2);
		top: calc(100% + 22px);
		height: 12px;
		pointer-events: none;
	}
	.request-trace .rt-tick-label {
		position: absolute;
		top: 0;
		transform: translateX(-50%);
		font: 500 10.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
		transition: color 0.14s, font-weight 0.14s;
	}
	.request-trace .rt-tick-label.is-active {
		color: var(--sl-color-accent);
		font-weight: 700;
	}

	/* === Caption ===
	   The min-height absorbs typical 1–3 line variation between built-in and
	   author-overridden captions so the figure does not reflow as the learner
	   scrubs. Authors should keep captions to ≤3 short lines. */
	.request-trace .rt-caption {
		margin-top: 14px;
		padding: 10px 12px;
		font: 400 13.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		line-height: 1.55;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 8px;
		min-height: calc(3 * 1.55em + 20px);
	}
	.request-trace .rt-caption :global(p) {
		margin: 0 0 6px;
	}
	.request-trace .rt-caption :global(p:last-child) {
		margin-bottom: 0;
	}
	.request-trace .rt-caption :global(code) {
		font-size: 0.92em;
		padding: 1px 4px;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 4px;
	}

	/* Visually hidden but reachable by screen readers. */
	.request-trace .rt-sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.request-trace .rt-node,
		.request-trace .rt-state,
		.request-trace .rt-lane,
		.request-trace .rt-tick,
		.request-trace .rt-tick-label,
		.request-trace .rt-btn {
			transition: none !important;
			transform: none !important;
		}
	}
</style>

<script>
	type PhaseId =
		| 'request'
		| 'server-render'
		| 'wire'
		| 'shell'
		| 'stream'
		| 'hydrate';

	type Kind = 'server' | 'client' | 'suspense';
	type CacheKind = 'dynamic' | 'static' | 'cached';
	type CacheState = 'hit' | 'miss' | undefined;
	type WireStatus = 'ok' | 'rejected' | 'leak';

	type WirePropDef = {
		name: string;
		value?: string;
		status: WireStatus;
		note?: string;
	};

	type NodeDef = {
		id: string;
		label: string;
		kind: Kind;
		cache: CacheKind;
		cacheState: CacheState;
		awaitLabel?: string;
		fallback?: string;
		children: NodeDef[];
		wireProps: WirePropDef[];
	};

	type NodeState =
		| 'idle'
		| 'rendering'
		| 'awaiting'
		| 'pending'
		| 'prerendered'
		| 'cached'
		| 'shell'
		| 'fallback'
		| 'streamed'
		| 'hydrated'
		| 'painted'
		| 'needs-suspense';

	type NodeView = {
		state: NodeState;
		detail?: string;
		chip?: string;
		dimmed?: boolean;
		hiddenInFallback?: boolean;
	};

	const CANONICAL_PHASES: PhaseId[] = [
		'request',
		'server-render',
		'wire',
		'shell',
		'stream',
		'hydrate',
	];

	const PHASE_META: Record<
		PhaseId,
		{
			label: string;
			lane: 'server' | 'network' | 'browser';
			defaultCaption: string;
		}
	> = {
		request: {
			label: 'Request',
			lane: 'server',
			defaultCaption: 'A request arrives at the server. Nothing has rendered yet.',
		},
		'server-render': {
			label: 'Server render',
			lane: 'server',
			defaultCaption:
				'Server Components execute. Async reads await; client components pre-render to HTML. Cached segments resolve or are stored.',
		},
		wire: {
			label: 'The wire',
			lane: 'network',
			defaultCaption:
				'The RSC payload and HTML serialize and cross the network. Only serializable values cross.',
		},
		shell: {
			label: 'Shell flush',
			lane: 'browser',
			defaultCaption:
				'The static shell paints in the browser. Dynamic regions show their Suspense fallbacks.',
		},
		stream: {
			label: 'Stream',
			lane: 'browser',
			defaultCaption:
				'Suspense boundaries resolve and stream in, in document order. Holes fill with content.',
		},
		hydrate: {
			label: 'Hydrate',
			lane: 'browser',
			defaultCaption:
				'Client Components hydrate and become interactive. Server-only content stays as painted HTML.',
		},
	};

	const STATE_LABELS: Record<NodeState, string> = {
		idle: 'idle',
		rendering: 'rendering',
		awaiting: 'awaiting',
		pending: 'pending',
		prerendered: 'prerendered',
		cached: 'cached',
		shell: 'in shell',
		fallback: 'fallback',
		streamed: 'streamed',
		hydrated: 'hydrated',
		painted: 'painted',
		'needs-suspense': 'needs <Suspense>',
	};

	function parsePhases(s: string | null | undefined): PhaseId[] {
		if (!s) return CANONICAL_PHASES.slice();
		const want = new Set(
			s
				.split(',')
				.map((p) => p.trim())
				.filter(Boolean) as PhaseId[],
		);
		return CANONICAL_PHASES.filter((p) => want.has(p));
	}

	function parseNode(el: HTMLElement): NodeDef {
		const id = el.dataset.rtId ?? '';
		const label = el.dataset.rtLabel ?? id;
		const kind = (el.dataset.rtKind ?? 'server') as Kind;
		const cache = (el.dataset.rtCache ?? 'dynamic') as CacheKind;
		const cacheState = (el.dataset.rtCacheState || undefined) as CacheState;
		const awaitLabel = el.dataset.rtAwait || undefined;
		const fallback = el.dataset.rtFallback || undefined;

		const children = Array.from(
			el.querySelectorAll<HTMLElement>(':scope > [data-rt-node]'),
		).map(parseNode);

		const wireProps: WirePropDef[] = Array.from(
			el.querySelectorAll<HTMLElement>(':scope > [data-rt-wireprop]'),
		).map((w) => ({
			name: w.dataset.rtName ?? '',
			value: w.dataset.rtValue || undefined,
			status: (w.dataset.rtStatus ?? 'ok') as WireStatus,
			note: w.dataset.rtNote || undefined,
		}));

		return {
			id,
			label,
			kind,
			cache,
			cacheState,
			awaitLabel,
			fallback,
			children,
			wireProps,
		};
	}

	function parsePhaseOverrides(scope: HTMLElement): Map<PhaseId, HTMLElement> {
		const out = new Map<PhaseId, HTMLElement>();
		for (const el of Array.from(
			scope.querySelectorAll<HTMLElement>(':scope > [data-rt-phase]'),
		)) {
			const id = el.dataset.rtId as PhaseId | undefined;
			if (id && CANONICAL_PHASES.includes(id)) out.set(id, el);
		}
		return out;
	}

	// === Phase engine ===
	//
	// For each (node, phase), compute the transient NodeView. The engine walks
	// the tree once per phase, tracking ancestry flags (inSuspense,
	// inCacheHitSubtree) so descendants behave as their nearest "containing"
	// boundary dictates.

	type Ancestry = {
		inSuspense: boolean;
		inCacheHit: boolean;
	};

	function computeStates(nodes: NodeDef[], visiblePhases: PhaseId[]) {
		const out = new Map<string, Map<PhaseId, NodeView>>();

		// Helper: ensure entry, then set view for a (node, phase).
		function setView(id: string, phase: PhaseId, view: NodeView) {
			let m = out.get(id);
			if (!m) {
				m = new Map();
				out.set(id, m);
			}
			m.set(phase, view);
		}

		// Pass 1: per-phase walk, in canonical order.
		for (const phase of CANONICAL_PHASES) {
			walkAndApply(nodes, phase, { inSuspense: false, inCacheHit: false }, setView);
		}

		// Pass 2: suspense bubble-up. If a suspense node has any descendant in
		// `awaiting` during server-render, it becomes `awaiting` too.
		function bubbleSuspense(nodes: NodeDef[]) {
			for (const n of nodes) {
				bubbleSuspense(n.children);
				if (n.kind === 'suspense') {
					const hasAwaiting = anyDescendant(n, (d) => {
						const v = out.get(d.id)?.get('server-render');
						return v?.state === 'awaiting';
					});
					if (hasAwaiting) {
						const cur = out.get(n.id)?.get('server-render');
						if (cur) {
							setView(n.id, 'server-render', { ...cur, state: 'awaiting' });
						}
					}
				}
			}
		}
		bubbleSuspense(nodes);

		// Pass 3: the `wire` phase carries the server-render state forward,
		// dimmed. (We do this after the suspense bubble so suspense nodes show
		// the same "awaiting" treatment they had at server-render.)
		function carryWire(nodes: NodeDef[]) {
			for (const n of nodes) {
				const srv = out.get(n.id)?.get('server-render');
				if (srv) {
					setView(n.id, 'wire', { ...srv, dimmed: true });
				}
				carryWire(n.children);
			}
		}
		carryWire(nodes);

		// Pass 4: surface authoring errors — an awaiting server node that is
		// neither wrapped in <Suspense> nor placed in the static shell (`cache=
		// "static"`) cannot exist in the App Router. The shell needs to either
		// fall back through Suspense or know the value statically, otherwise
		// the whole shell stalls on that data read. Force the node's `shell`
		// and `stream` views to a distinct `needs-suspense` error state and
		// log a console warning so the lesson author sees the problem.
		//
		// Only runs when the visible phase set includes `shell` or `stream` —
		// if the author has intentionally omitted those phases (e.g. a trace
		// scoped to boundary + hydration), the await-without-Suspense is not
		// reachable and not a teaching error in that lesson.
		const shellOrStreamVisible =
			visiblePhases.includes('shell') ||
			visiblePhases.includes('stream');
		function flagNeedsSuspense(nodes: NodeDef[], anc: Ancestry) {
			for (const n of nodes) {
				const isStatic = n.cache === 'static';
				const isCached = n.cache === 'cached';
				const isErrant =
					n.kind === 'server' &&
					!!n.awaitLabel &&
					!anc.inSuspense &&
					!isStatic &&
					!isCached;
				if (isErrant) {
					console.warn(
						`[RequestTrace] <TraceNode id="${n.id}"> performs an async read (await="${n.awaitLabel}") but is not wrapped in a kind="suspense" ancestor or marked cache="static" — the App Router shell cannot ship until this resolves. Wrap it in <Suspense>.`,
					);
					setView(n.id, 'shell', {
						state: 'needs-suspense',
						detail: 'wrap in <Suspense>',
					});
					setView(n.id, 'stream', {
						state: 'needs-suspense',
						detail: 'wrap in <Suspense>',
					});
				}
				flagNeedsSuspense(n.children, {
					inSuspense: anc.inSuspense || n.kind === 'suspense',
					inCacheHit:
						anc.inCacheHit ||
						(n.cache === 'cached' && n.cacheState === 'hit'),
				});
			}
		}
		if (shellOrStreamVisible) {
			flagNeedsSuspense(nodes, { inSuspense: false, inCacheHit: false });
		}

		return out;
	}

	function anyDescendant(node: NodeDef, pred: (n: NodeDef) => boolean): boolean {
		for (const c of node.children) {
			if (pred(c)) return true;
			if (anyDescendant(c, pred)) return true;
		}
		return false;
	}

	function countWireProps(nodes: NodeDef[], clientOnly = false): number {
		let n = 0;
		for (const node of nodes) {
			if (clientOnly) {
				if (node.kind === 'client') n += node.wireProps.length;
				else if (node.wireProps.length > 0) {
					console.warn(
						`[RequestTrace] <WireProp> declared on a non-client <TraceNode id="${node.id}"> — ignored. Move the WireProp into a kind="client" node.`,
					);
				}
			} else {
				n += node.wireProps.length;
			}
			n += countWireProps(node.children, clientOnly);
		}
		return n;
	}

	function walkAndApply(
		nodes: NodeDef[],
		phase: PhaseId,
		anc: Ancestry,
		setView: (id: string, phase: PhaseId, view: NodeView) => void,
	) {
		for (const n of nodes) {
			const view = nodeViewFor(n, phase, anc);
			setView(n.id, phase, view);

			// Propagate ancestry to children.
			const childAnc: Ancestry = {
				inSuspense: anc.inSuspense || n.kind === 'suspense',
				inCacheHit:
					anc.inCacheHit ||
					(n.cache === 'cached' && n.cacheState === 'hit'),
			};
			walkAndApply(n.children, phase, childAnc, setView);
		}
	}

	function nodeViewFor(node: NodeDef, phase: PhaseId, anc: Ancestry): NodeView {
		switch (phase) {
			case 'request':
				return { state: 'idle' };

			case 'server-render': {
				if (node.cache === 'cached') {
					if (node.cacheState === 'hit') return { state: 'cached', detail: 'hit' };
					if (node.cacheState === 'miss') {
						// A miss runs fresh, so an await label still applies.
						return node.awaitLabel
							? { state: 'awaiting', detail: node.awaitLabel, chip: 'stored' }
							: { state: 'rendering', chip: 'stored' };
					}
					return { state: 'cached' };
				}
				if (anc.inCacheHit) return { state: 'cached' };
				if (node.kind === 'client') return { state: 'prerendered' };
				if (node.kind === 'suspense') return { state: 'rendering' };
				// server
				if (node.awaitLabel)
					return { state: 'awaiting', detail: node.awaitLabel };
				return { state: 'rendering' };
			}

			case 'wire':
				// Filled in by the carryWire pass.
				return { state: 'idle', dimmed: true };

			case 'shell': {
				if (node.kind === 'suspense')
					return {
						state: 'fallback',
						detail: node.fallback || 'Loading…',
					};
				if (anc.inSuspense)
					return { state: 'pending', hiddenInFallback: true };
				if (anc.inCacheHit) return { state: 'cached' };
				return { state: 'shell' };
			}

			case 'stream': {
				if (node.kind === 'suspense') return { state: 'streamed' };
				if (anc.inSuspense) return { state: 'streamed' };
				if (anc.inCacheHit) return { state: 'cached' };
				return { state: 'shell' };
			}

			case 'hydrate':
				if (node.kind === 'client') return { state: 'hydrated' };
				return { state: 'painted' };
		}
	}

	// === Rendering ===

	function renderTree(parent: HTMLElement, nodes: NodeDef[]) {
		for (const n of nodes) {
			const nodeEl = document.createElement('div');
			nodeEl.className = 'rt-node';
			nodeEl.dataset.id = n.id;
			// Cache-miss server nodes get a `STORED` chip on the chip-bearing
			// phases; reserve the wrapped row height to keep the figure stable.
			if (n.cache === 'cached' && n.cacheState === 'miss') {
				nodeEl.dataset.rtReserveChip = '';
			}

			const row = document.createElement('div');
			row.className = 'rt-node-row';

			const tag = document.createElement('span');
			tag.className = 'rt-tag';
			tag.dataset.rtKind = n.kind;
			tag.textContent = n.kind;
			row.appendChild(tag);

			if (n.cache && n.cache !== 'dynamic') {
				const cache = document.createElement('span');
				cache.className = 'rt-cache';
				cache.textContent =
					n.cache === 'cached' && n.cacheState
						? `cache: ${n.cacheState}`
						: `cache: ${n.cache}`;
				row.appendChild(cache);
			}

			const label = document.createElement('span');
			label.className = 'rt-node-label';
			label.textContent =
				n.kind === 'suspense' ? `<${n.label}>` : `<${n.label} />`;
			row.appendChild(label);

			const state = document.createElement('span');
			state.className = 'rt-state';
			state.dataset.idState = n.id;
			state.dataset.state = 'idle';
			const stateLabel = document.createElement('span');
			stateLabel.className = 'rt-state-text';
			stateLabel.textContent = STATE_LABELS.idle;
			state.appendChild(stateLabel);
			row.appendChild(state);

			nodeEl.appendChild(row);

			if (n.children.length > 0) {
				const childrenEl = document.createElement('div');
				childrenEl.className = 'rt-children';
				renderTree(childrenEl, n.children);
				nodeEl.appendChild(childrenEl);
			}

			parent.appendChild(nodeEl);
		}
	}

	function renderWirePanel(panelRows: HTMLElement, nodes: NodeDef[]) {
		panelRows.innerHTML = '';
		const boundaries: NodeDef[] = [];
		function walk(nodes: NodeDef[]) {
			for (const n of nodes) {
				if (n.kind === 'client' && n.wireProps.length > 0) boundaries.push(n);
				walk(n.children);
			}
		}
		walk(nodes);

		// The caller (mount script) only invokes this when at least one
		// <WireProp> exists in the trace, so we don't render an empty state.
		if (boundaries.length === 0) return;

		for (const b of boundaries) {
			const card = document.createElement('div');
			card.className = 'rt-wire-boundary';

			const head = document.createElement('div');
			head.className = 'rt-wire-boundary-head';
			head.textContent = `server → <${b.label} /> (client)`;
			card.appendChild(head);

			for (const wp of b.wireProps) {
				const row = document.createElement('div');
				row.className = 'rt-wire-row';

				const name = document.createElement('span');
				name.className = 'rt-wire-name';
				name.textContent = wp.name;
				row.appendChild(name);

				const value = document.createElement('span');
				value.className = 'rt-wire-value';
				value.textContent = wp.value ?? '';
				row.appendChild(value);

				const status = document.createElement('span');
				status.className = 'rt-wire-status';
				status.dataset.status = wp.status;
				status.textContent =
					wp.status === 'ok'
						? 'ok'
						: wp.status === 'rejected'
						? 'rejected'
						: 'leak';
				row.appendChild(status);

				if (wp.note) {
					const note = document.createElement('span');
					note.className = 'rt-wire-note';
					note.textContent = wp.note;
					row.appendChild(note);
				}

				card.appendChild(row);
			}

			panelRows.appendChild(card);
		}
	}

	function ariaForState(label: string, view: NodeView): string {
		const tail =
			view.state === 'awaiting' && view.detail
				? `, awaiting ${view.detail}`
				: view.state === 'fallback' && view.detail
				? `, showing fallback ${view.detail}`
				: '';
		return `${label} — ${STATE_LABELS[view.state]}${tail}`;
	}

	function applyPhase(
		stage: HTMLElement,
		nodes: NodeDef[],
		stateMap: Map<string, Map<PhaseId, NodeView>>,
		phase: PhaseId,
	) {
		function walk(nodes: NodeDef[]) {
			for (const n of nodes) {
				const view = stateMap.get(n.id)?.get(phase);
				if (!view) {
					walk(n.children);
					continue;
				}

				const nodeEl = stage.querySelector<HTMLElement>(
					`.rt-node[data-id="${CSS.escape(n.id)}"]`,
				);
				if (!nodeEl) {
					walk(n.children);
					continue;
				}

				nodeEl.classList.toggle('is-dimmed', !!view.dimmed);
				nodeEl.classList.toggle(
					'is-hidden-fallback',
					!!view.hiddenInFallback,
				);

				const stateEl = nodeEl.querySelector<HTMLElement>(
					':scope > .rt-node-row > .rt-state',
				);
				if (stateEl) {
					stateEl.dataset.state = view.state;
					const text = stateEl.querySelector<HTMLElement>('.rt-state-text');
					if (text) text.textContent = STATE_LABELS[view.state];

					// Detail lives inside the badge — clean only inside stateEl.
					stateEl
						.querySelectorAll('.rt-state-detail')
						.forEach((e) => e.remove());
					// Chip is a SIBLING of stateEl on the row — must be cleaned at
					// row scope, scoped with `:scope >` so a parent node's cleanup
					// does not strip a nested child node's chip.
					stateEl.parentElement
						?.querySelectorAll(':scope > .rt-state-chip')
						.forEach((e) => e.remove());

					if (view.detail) {
						const detail = document.createElement('span');
						detail.className = 'rt-state-detail';
						detail.textContent = `· ${view.detail}`;
						stateEl.appendChild(detail);
					}

					// "stored" chip on the row, placed BEFORE the state badge so it
					// sits next to the label instead of floating against the right
					// edge after the auto-margin badge.
					if (view.chip) {
						const chip = document.createElement('span');
						chip.className = 'rt-chip rt-state-chip';
						chip.textContent = view.chip;
						stateEl.parentElement?.insertBefore(chip, stateEl);
					}

					stateEl.setAttribute('aria-label', ariaForState(n.label, view));
				}

				walk(n.children);
			}
		}
		walk(nodes);
	}

	function updateLanes(root: HTMLElement, phase: PhaseId) {
		const lane = PHASE_META[phase].lane;
		root
			.querySelectorAll<HTMLElement>('.rt-lane')
			.forEach((el) =>
				el.classList.toggle('is-active', el.dataset.rtLane === lane),
			);
	}

	function setWirePanelPhase(
		root: HTMLElement,
		phase: PhaseId,
		hasWireProps: boolean,
	) {
		const panel = root.querySelector<HTMLElement>('[data-rt-wire-panel]');
		if (!panel) return;
		// Only show on the wire phase, and only when the trace has at least one
		// <WireProp>. Off-phase: fully collapsed (display:none) — no empty void.
		if (hasWireProps && phase === 'wire') panel.removeAttribute('hidden');
		else panel.setAttribute('hidden', '');
	}

	function setCaption(
		root: HTMLElement,
		phase: PhaseId,
		overrides: Map<PhaseId, HTMLElement>,
		announcement: string,
	) {
		const captionEl = root.querySelector<HTMLElement>('[data-rt-caption]');
		if (!captionEl) return;
		const override = overrides.get(phase);
		captionEl.innerHTML = '';

		// Visually-hidden phase announcement so screen-reader users hear the
		// phase change whether they tabbed the slider or clicked Prev/Next.
		const sr = document.createElement('span');
		sr.className = 'rt-sr-only';
		sr.textContent = announcement + ' ';
		captionEl.appendChild(sr);

		if (override) {
			const rich = override.querySelector<HTMLElement>(
				':scope > [data-rt-phase-rich]',
			);
			if (rich && rich.innerHTML.trim()) {
				const wrapper = document.createElement('span');
				wrapper.innerHTML = rich.innerHTML;
				captionEl.appendChild(wrapper);
				return;
			}
			const captionText = override.dataset.rtCaption?.trim();
			if (captionText) {
				captionEl.appendChild(document.createTextNode(captionText));
				return;
			}
		}
		captionEl.appendChild(
			document.createTextNode(PHASE_META[phase].defaultCaption),
		);
	}

	document.querySelectorAll<HTMLElement>('[data-rt-root]').forEach((root) => {
		const stage = root.querySelector<HTMLElement>('[data-rt-stage]');
		const slider = root.querySelector<HTMLInputElement>('[data-rt-slider]');
		const ticksEl = root.querySelector<HTMLElement>('[data-rt-ticks]');
		const tickLabelsEl =
			root.querySelector<HTMLElement>('[data-rt-tick-labels]');
		const prevBtn = root.querySelector<HTMLButtonElement>('[data-rt-prev]');
		const nextBtn = root.querySelector<HTMLButtonElement>('[data-rt-next]');
		const resetBtn = root.querySelector<HTMLButtonElement>('[data-rt-reset]');
		const payloads = root.querySelector<HTMLElement>('[data-rt-payloads]');
		const wirePanel = root.querySelector<HTMLElement>('[data-rt-wire-panel]');
		const wireRows = root.querySelector<HTMLElement>('[data-rt-wire-rows]');

		if (
			!stage ||
			!slider ||
			!ticksEl ||
			!tickLabelsEl ||
			!prevBtn ||
			!nextBtn ||
			!resetBtn ||
			!payloads ||
			!wirePanel ||
			!wireRows
		)
			return;

		const phases = parsePhases(root.dataset.rtPhases);
		if (phases.length === 0) return;

		const nodes: NodeDef[] = Array.from(
			payloads.querySelectorAll<HTMLElement>(':scope > [data-rt-node]'),
		).map(parseNode);

		const phaseOverrides = parsePhaseOverrides(payloads);

		// Build the tree once. Subsequent phase changes only mutate state badges.
		renderTree(stage, nodes);
		// The wire panel earns its place only when the trace declares at least
		// one <WireProp> AND the `wire` phase is in the visible set. Even then
		// we render the rows once up-front but keep the panel hidden by
		// default — setWirePanelPhase() shows it just on the `wire` phase.
		// (Hidden via `hidden` attribute → display:none. Because the panel is
		// the last element in the card, collapsing it does not move anything
		// above it.)
		const wirePropCount = countWireProps(nodes, true);
		const hasWireProps =
			wirePropCount > 0 && phases.includes('wire');
		if (hasWireProps) {
			renderWirePanel(wireRows, nodes);
		}
		wirePanel.setAttribute('hidden', '');

		// Compute the full (node, phase) state table once, up front. Cheap and
		// keeps every phase swap O(nodes).
		const stateMap = computeStates(nodes, phases);

		// Configure scrubber.
		const count = phases.length;
		slider.min = '0';
		slider.max = String(Math.max(0, count - 1));
		slider.value = '0';
		if (count <= 1) slider.disabled = true;

		const tickEls: HTMLElement[] = [];
		const tickLabelEls: HTMLElement[] = [];
		ticksEl.innerHTML = '';
		tickLabelsEl.innerHTML = '';
		for (let i = 0; i < count; i++) {
			const left = count === 1 ? '50%' : (i / (count - 1)) * 100 + '%';

			const t = document.createElement('span');
			t.className = 'rt-tick';
			t.style.left = left;
			ticksEl.appendChild(t);
			tickEls.push(t);

			const lbl = document.createElement('span');
			lbl.className = 'rt-tick-label';
			lbl.style.left = left;
			lbl.textContent = PHASE_META[phases[i]].label;
			tickLabelsEl.appendChild(lbl);
			tickLabelEls.push(lbl);
		}

		function setActive(index: number) {
			const i = Math.max(0, Math.min(count - 1, index));
			const phase = phases[i];
			slider!.value = String(i);
			prevBtn!.disabled = i === 0;
			nextBtn!.disabled = i === count - 1;
			tickEls.forEach((t, k) => t.classList.toggle('is-active', k === i));
			tickLabelEls.forEach((l, k) =>
				l.classList.toggle('is-active', k === i),
			);
			const announcement = `Phase ${i + 1} of ${count}: ${PHASE_META[phase].label}.`;
			applyPhase(stage!, nodes, stateMap, phase);
			updateLanes(root, phase);
			setWirePanelPhase(root, phase, hasWireProps);
			setCaption(root, phase, phaseOverrides, announcement);
			slider!.setAttribute('aria-valuetext', announcement);
		}

		slider.addEventListener('input', () => setActive(Number(slider.value)));
		prevBtn.addEventListener('click', () =>
			setActive(Number(slider.value) - 1),
		);
		nextBtn.addEventListener('click', () =>
			setActive(Number(slider.value) + 1),
		);
		resetBtn.addEventListener('click', () => setActive(0));

		setActive(0);
	});
</script>
