	}
	.request-trace .rt-slider::-webkit-slider-runnable-track {
		height: 4px;
		background: var(--sl-color-gray-5);
		border-radius: 2px;
	}
	.request-trace .rt-slider::-moz-range-track {
		height: 4px;
		background: var(--sl-color-gray-5);
		border-radius: 2px;
	}
	.request-trace .rt-slider::-webkit-slider-thumb {
		appearance: none;
		-webkit-appearance: none;
		width: var(--rt-thumb-size);
		height: var(--rt-thumb-size);
		background: var(--sl-color-accent);
		border: 2px solid var(--sl-color-bg);
		border-radius: 50%;
		margin-top: calc((4px - var(--rt-thumb-size)) / 2);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
	}
	.request-trace .rt-slider::-moz-range-thumb {
		width: var(--rt-thumb-size);
		height: var(--rt-thumb-size);
		background: var(--sl-color-accent);
		border: 2px solid var(--sl-color-bg);
		border-radius: 50%;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
	}
	.request-trace .rt-slider:focus-visible::-webkit-slider-thumb {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	.request-trace .rt-slider:focus-visible::-moz-range-thumb {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}

	.request-trace .rt-ticks {
		position: absolute;
		left: calc(var(--rt-thumb-size) / 2);
		right: calc(var(--rt-thumb-size) / 2);
		top: calc(100% + 12px);
		height: 6px;
		pointer-events: none;
	}
	.request-trace .rt-tick {
		position: absolute;
		top: 0;
		width: 1.5px;
		height: 6px;
		background: var(--sl-color-gray-4);
