---
// One node in a <RequestTrace> tree. Recursive — its default slot holds
// nested <TraceNode> children, plus (for kind="client") any <WireProp> rows
// listing props crossing the server→client boundary. The parent script
// crawls the placeholder tree on mount and builds the live stage.
//
// Markers (kind, cache, cacheState, await, fallback) feed the phase engine
// that derives this node's transient state at every phase.

interface Props {
	id: string;
	label: string;
	kind?: 'server' | 'client' | 'suspense';
	cache?: 'dynamic' | 'static' | 'cached';
	cacheState?: 'hit' | 'miss';
	/** Async data-read label, e.g. `"db: invoices"`. Only meaningful on server nodes. */
	await?: string;
	/** Fallback UI text. Only meaningful on `kind="suspense"` nodes. */
	fallback?: string;
}

const {
	id,
	label,
	kind = 'server',
	cache = 'dynamic',
	cacheState,
	await: awaitLabel,
	fallback,
} = Astro.props;
---

<div
	hidden
	data-rt-node
	data-rt-id={id}
	data-rt-label={label}
	data-rt-kind={kind}
	data-rt-cache={cache}
	data-rt-cache-state={cacheState}
	data-rt-await={awaitLabel}
	data-rt-fallback={fallback}>
	<slot />
</div>
