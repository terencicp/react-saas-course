---
interface Props {
	caption?: string;
}

const { caption } = Astro.props;
const hasSlotCaption = Astro.slots.has('caption');
---

<figure class="sl-figure">
	<slot />
	{
		(hasSlotCaption || caption) && (
			<figcaption class="sl-figure-caption">
				{hasSlotCaption ? <slot name="caption" /> : caption}
			</figcaption>
		)
	}
</figure>

<style>
	.sl-figure {
		margin: 1.5rem 0;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 12px;
		padding: 18px;
	}
	.sl-figure-caption {
		margin: 14px 4px 0;
		font-size: 14px;
		line-height: 1.6;
		color: var(--sl-color-gray-3);
	}
	.sl-figure-caption :global(p) {
		margin: 0 0 8px;
	}
	.sl-figure-caption :global(p:last-child) {
		margin-bottom: 0;
	}
</style>
