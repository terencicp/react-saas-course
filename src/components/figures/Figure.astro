---
interface Props {
	caption?: string;
	expandable?: boolean;
}

const { caption, expandable = true } = Astro.props;
const hasSlotCaption = Astro.slots.has('caption');
---

<figure class="sl-figure" data-expandable={expandable ? 'true' : undefined}>
	<div class="sl-figure-body">
		<slot />
	</div>
	{
		(hasSlotCaption || caption) && (
			<figcaption class="sl-figure-caption">
				{hasSlotCaption ? <slot name="caption" /> : caption}
			</figcaption>
		)
	}
	{
		expandable && (
			<>
				<button
					type="button"
					class="sl-figure-expand"
					aria-label="Open figure full screen"
					aria-expanded="false"
				>
					<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path
							d="M4 9V4h5M20 9V4h-5M4 15v5h5M20 15v5h-5"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</button>
				<dialog class="sl-figure-dialog" aria-label="Expanded figure">
					<button
						type="button"
						class="sl-figure-dialog-close"
						aria-label="Close"
					>
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
							<path
								d="M6 6l12 12M18 6L6 18"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</button>
					<div class="sl-figure-dialog-host" />
				</dialog>
			</>
		)
	}
</figure>

<style>
	.sl-figure {
		position: relative;
		margin: 1.5rem 0;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 12px;
		padding: 18px;
	}
	.sl-figure-caption {
		margin: 14px 4px 0;
		font-size: 14px;
		line-height: 1.6;
		color: var(--sl-color-gray-3);
	}
	.sl-figure-caption :global(p) {
		margin: 0 0 8px;
	}
	.sl-figure-caption :global(p:last-child) {
		margin-bottom: 0;
	}

	.sl-figure-expand {
		position: absolute;
		/* Negative offsets compensate for the figure's 18px padding so the chip
		   straddles the border-box corner — half outside, half inside. */
		top: -16px;
		right: -16px;
		margin: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		padding: 0;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 8px;
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-2);
		cursor: pointer;
		opacity: 0;
		transition: opacity 0.15s, background 0.15s, color 0.15s, border-color 0.15s;
		z-index: 1;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
	}
	.sl-figure:hover .sl-figure-expand,
	.sl-figure:focus-within .sl-figure-expand,
	.sl-figure-expand:focus-visible {
		opacity: 1;
	}
	.sl-figure-expand:hover {
		color: var(--sl-color-white);
		border-color: var(--sl-color-gray-3);
	}
	@media (hover: none) {
		.sl-figure-expand {
			opacity: 1;
		}
	}

	.sl-figure-dialog {
		position: fixed;
		inset: 0;
		margin: auto;
		padding: 0;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 12px;
		background: var(--sl-color-bg);
		color: var(--sl-color-text);
		width: min(96vw, 1800px);
		max-height: 92vh;
		height: fit-content;
		overflow: hidden;
	}
	.sl-figure-dialog::backdrop {
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(2px);
	}
	.sl-figure-dialog-host {
		padding: 28px 32px 24px;
		overflow: auto;
		max-height: 92vh;
	}
	.sl-figure-dialog-host :global(.sl-figure-body) {
		display: block;
	}
	.sl-figure-dialog-host :global(.sl-figure-caption) {
		margin: 14px 4px 0;
		font-size: 14px;
		line-height: 1.6;
		color: var(--sl-color-gray-3);
	}
	.sl-figure-dialog-close {
		position: absolute;
		top: 10px;
		right: 10px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		padding: 0;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 6px;
		background: var(--sl-color-bg);
		color: var(--sl-color-gray-2);
		cursor: pointer;
		z-index: 2;
		transition: color 0.15s, border-color 0.15s;
	}
	.sl-figure-dialog-close:hover {
		color: var(--sl-color-white);
		border-color: var(--sl-color-gray-3);
	}

	@media (prefers-reduced-motion: reduce) {
		.sl-figure-expand {
			transition: none;
		}
		.sl-figure-dialog-close {
			transition: none;
		}
	}
</style>

<script>
	document.querySelectorAll<HTMLElement>('.sl-figure[data-expandable="true"]').forEach((figure) => {
		const chip = figure.querySelector<HTMLButtonElement>(':scope > .sl-figure-expand');
		const dialog = figure.querySelector<HTMLDialogElement>(':scope > .sl-figure-dialog');
		const host = dialog?.querySelector<HTMLElement>(':scope > .sl-figure-dialog-host');
		const closeBtn = dialog?.querySelector<HTMLButtonElement>(':scope > .sl-figure-dialog-close');
		const body = figure.querySelector<HTMLElement>(':scope > .sl-figure-body');
		const caption = figure.querySelector<HTMLElement>(':scope > .sl-figure-caption');
		if (!chip || !dialog || !host || !closeBtn || !body) return;

		const open = () => {
			host.appendChild(body);
			if (caption) host.appendChild(caption);
			chip.setAttribute('aria-expanded', 'true');
			dialog.showModal();
		};

		const close = () => {
			figure.insertBefore(body, chip);
			if (caption) figure.insertBefore(caption, chip);
			chip.setAttribute('aria-expanded', 'false');
			dialog.close();
		};

		chip.addEventListener('click', open);
		closeBtn.addEventListener('click', close);

		// Close on backdrop click (clicks that land on the <dialog> element itself,
		// not on its descendants, fall on the backdrop area of the dialog box).
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) close();
		});

		// ESC closes natively via <dialog>; restore DOM and aria state on cancel/close.
		dialog.addEventListener('close', () => {
			if (body.parentElement === host) {
				figure.insertBefore(body, chip);
				if (caption) figure.insertBefore(caption, chip);
			}
			chip.setAttribute('aria-expanded', 'false');
		});
	});
</script>
