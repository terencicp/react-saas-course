---
// One edge in a <GraphExplorer>. Declared as a child; the parent script
// reads from/to/label off the dataset and emits the edge into Mermaid's
// source. The default slot becomes the edge's side-panel content (when
// absent, the panel just shows endpoints + label).

interface Props {
	from: string;
	to: string;
	label?: string;
}

const { from, to, label } = Astro.props;
---

<div
	hidden
	data-ge-edge
	data-ge-from={from}
	data-ge-to={to}
	data-ge-label={label}>
	<slot />
</div>
