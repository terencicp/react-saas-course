---
// One node in a <GraphExplorer>. Declared as a child; the parent script
// reads id/label/group off the dataset and feeds them to Mermaid's layout
// engine. The default slot becomes this node's side-panel content.

interface Props {
	id: string;
	label: string;
	/** Optional group key — adds `data-group="…"` for color-coded clusters. */
	group?: string;
}

const { id, label, group } = Astro.props;
---

<div
	hidden
	data-ge-node
	data-ge-id={id}
	data-ge-label={label}
	data-ge-group={group}>
	<slot />
</div>
