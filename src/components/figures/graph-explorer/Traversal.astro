---
// One traversal sequence in a <GraphExplorer>. Self-closing carrier; the
// parent script reads id/label/sequence off the dataset and renders the
// play/scrub toolbar (and tab strip when ≥2 traversals exist).

interface Props {
	id: string;
	label: string;
	/** Comma-separated GraphNode ids that the play/scrub control walks through in order. */
	sequence: string;
	/**
	 * When true, playback dwells on each node in the sequence but skips the
	 * intermediate edge step. Edges remain visible and clickable; this only
	 * affects the animation. Default: false (cursor pulses each edge between
	 * nodes during the walk).
	 */
	nodesOnly?: boolean;
}

const { id, label, sequence, nodesOnly = false } = Astro.props;
---

<span
	hidden
	data-ge-traversal
	data-ge-id={id}
	data-ge-label={label}
	data-ge-sequence={sequence}
	data-ge-nodes-only={nodesOnly ? 'true' : undefined}></span>
