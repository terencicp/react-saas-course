---
import leaderLineUrl from 'leader-line-new/leader-line.min.js?url';

type Socket = 'top' | 'bottom' | 'left' | 'right' | 'auto';
type Gravity = number | [number, number] | 'auto';

export interface Arrow {
	from: string;
	to: string;
	label?: string;
	color?: string;
	startSocket?: Socket;
	endSocket?: Socket;
	startSocketGravity?: Gravity;
	endSocketGravity?: Gravity;
	labelOffset?: [number, number];
}

interface Props {
	arrows: Arrow[];
}

const { arrows } = Astro.props;
---

<div class="arrow-stage" data-arrows={JSON.stringify(arrows)}>
	<slot />
</div>

<style>
	.arrow-stage {
		position: relative;
	}
</style>

<style is:global>
	.arrow-figure-label {
		position: absolute;
		font:
			700 10.5px ui-monospace,
			SFMono-Regular,
			Menlo,
			monospace;
		padding: 1px 6px;
		border-radius: 4px;
		pointer-events: none;
		z-index: 99999;
		white-space: nowrap;
		transform: translate(-50%, -50%);
		background: color-mix(in srgb, var(--sl-color-bg) 85%, transparent);
		border: 1px solid currentColor;
		line-height: 1.2;
		backdrop-filter: blur(2px);
	}
</style>

<script is:inline define:vars={{ leaderLineUrl }}>
	(function () {
		const ARROW = { light: '#0ea5e9', dark: '#38bdf8' };
		const LABEL = { light: '#0c4a6e', dark: '#bae6fd' };

		let llPromise = null;
		function loadLeaderLine() {
			if (window.LeaderLine) return Promise.resolve(window.LeaderLine);
			if (llPromise) return llPromise;
			llPromise = new Promise((resolve, reject) => {
				const s = document.createElement('script');
				s.src = leaderLineUrl;
				s.onload = () => resolve(window.LeaderLine);
				s.onerror = reject;
				document.head.appendChild(s);
			});
			return llPromise;
		}

		function isDark() {
			const t = document.documentElement.getAttribute('data-theme');
			if (t === 'dark') return true;
			if (t === 'light') return false;
			return matchMedia('(prefers-color-scheme: dark)').matches;
		}

		const built = new Map();

		function sidePoint(rect, side) {
			const x = (rect.left + rect.right) / 2;
			const y = (rect.top + rect.bottom) / 2;
			if (side === 'top') return { x, y: rect.top };
			if (side === 'bottom') return { x, y: rect.bottom };
			if (side === 'left') return { x: rect.left, y };
			if (side === 'right') return { x: rect.right, y };
			return { x, y };
		}

		async function build(stage) {
			if (stage.__arrowBuilding) return;
			stage.__arrowBuilding = true;
			try {
				if (built.has(stage)) tearDown(stage);

				const LeaderLine = await loadLeaderLine();
				if (!LeaderLine) return;

				let arrows = [];
				try {
					arrows = JSON.parse(stage.dataset.arrows || '[]');
				} catch (_) {
					return;
				}

				const dark = isDark();
				const ac = dark ? ARROW.dark : ARROW.light;
				const lc = dark ? LABEL.dark : LABEL.light;

				const lines = [];
				for (const a of arrows) {
					const start = stage.querySelector('#' + CSS.escape(a.from));
					const end = stage.querySelector('#' + CSS.escape(a.to));
					if (!start || !end) continue;

					const arrowColor = a.color || ac;
					const labelColor = a.color || lc;

					const opts = {
						color: arrowColor,
						size: 2.2,
						path: 'fluid',
						endPlug: 'arrow2',
						endPlugSize: 1.4,
					};
					if (a.startSocket) opts.startSocket = a.startSocket;
					if (a.endSocket) opts.endSocket = a.endSocket;
					if (a.startSocketGravity != null) opts.startSocketGravity = a.startSocketGravity;
					if (a.endSocketGravity != null) opts.endSocketGravity = a.endSocketGravity;

					const line = new LeaderLine(start, end, opts);

					let lbl = null;
					if (a.label) {
						lbl = document.createElement('div');
						lbl.className = 'arrow-figure-label';
						lbl.textContent = a.label;
						lbl.style.color = labelColor;
						document.body.appendChild(lbl);
					}

					const place = () => {
						if (!lbl) return;
						const sr = start.getBoundingClientRect();
						const er = end.getBoundingClientRect();
						const off = a.labelOffset || [0, 0];
						const sp = sidePoint(sr, a.startSocket);
						const ep = sidePoint(er, a.endSocket);
						lbl.style.left = (sp.x + ep.x) / 2 + window.scrollX + off[0] + 'px';
						lbl.style.top = (sp.y + ep.y) / 2 + window.scrollY + off[1] + 'px';
					};
					place();
					lines.push({ line, lbl, place });
				}
				built.set(stage, lines);
			} finally {
				stage.__arrowBuilding = false;
			}
		}

		function tearDown(stage) {
			const lines = built.get(stage);
			if (!lines) return;
			for (const l of lines) {
				try {
					l.line.remove();
				} catch (_) {}
				try {
					l.lbl && l.lbl.parentNode && l.lbl.parentNode.removeChild(l.lbl);
				} catch (_) {}
			}
			built.delete(stage);
		}

		function rebuildAll() {
			for (const s of document.querySelectorAll('.arrow-stage')) {
				tearDown(s);
				build(s);
			}
		}

		function repositionAll() {
			for (const lines of built.values()) {
				for (const l of lines) {
					try {
						l.line.position();
					} catch (_) {}
					try {
						l.place();
					} catch (_) {}
				}
			}
		}

		function init() {
			for (const s of document.querySelectorAll('.arrow-stage')) build(s);
		}

		if (document.readyState === 'complete') setTimeout(init, 0);
		else window.addEventListener('load', () => setTimeout(init, 0));

		window.addEventListener('resize', repositionAll);
		new MutationObserver(rebuildAll).observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['data-theme'],
		});
		if (window.ResizeObserver) new ResizeObserver(repositionAll).observe(document.body);
	})();
</script>
