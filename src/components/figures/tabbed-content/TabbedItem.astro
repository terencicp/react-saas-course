---
import { TabItem } from '@astrojs/starlight/components';

interface Props {
	label: string;
	icon?: string;
	caption?: string;
}

const { label, icon, caption } = Astro.props;
const hasSlotCaption = Astro.slots.has('caption');
---

<TabItem label={label} icon={icon as any}>
	<div class="tabbed-item-body">
		<slot />
	</div>
	{
		(hasSlotCaption || caption) && (
			<figcaption class="tabbed-item-caption">
				{hasSlotCaption ? <slot name="caption" /> : caption}
			</figcaption>
		)
	}
</TabItem>

<style>
	.tabbed-item-caption {
		margin: 14px 4px 0;
		font-size: 14px;
		line-height: 1.6;
		color: var(--sl-color-gray-3);
	}
	.tabbed-item-caption :global(p) {
		margin: 0 0 8px;
	}
	.tabbed-item-caption :global(p:last-child) {
		margin-bottom: 0;
	}
</style>
