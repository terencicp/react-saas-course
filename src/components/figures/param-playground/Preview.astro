---
// Wrapper for the preview content inside a <ParamPlayground>. The parent
// script reads each <Param>'s current value and writes `--{id}` CSS
// variables onto this wrapper's inline style, which the author's markup
// inside addresses via `var(--id)`.
//
// When <ParamPlayground> uses the default slot (no slot="preview"), the
// parent script moves this element into the preview column at runtime —
// data-pp-preview is the marker it looks for.
---

<div class="pp-preview" data-pp-preview>
	<slot />
</div>

<style is:global>
	.param-playground .pp-preview-wrap > .pp-preview {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
</style>
