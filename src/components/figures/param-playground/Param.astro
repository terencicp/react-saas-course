---
// One control inside a <ParamPlayground>. The control kind selects the
// underlying native input; the script in the parent reads its value on
// every change and writes `--{id}` on the preview wrapper.

type SelectOption = string | { value: string; label?: string };

interface Props {
	id: string;
	label: string;
	kind: 'slider' | 'select' | 'toggle' | 'color';
	default?: number | string | boolean;
	/** Slider-only. */
	min?: number;
	/** Slider-only. */
	max?: number;
	/** Slider-only. */
	step?: number;
	/** Slider-only — appended to the CSS variable so `var(--id)` carries its unit. */
	suffix?: string;
	/** Select-only. */
	options?: SelectOption[];
	/** Toggle-only — the string the CSS variable takes when checked. */
	on?: string;
	/** Toggle-only — the string the CSS variable takes when unchecked. */
	off?: string;
}

const {
	id,
	label,
	kind,
	default: defaultValue,
	min = 0,
	max = 100,
	step = 1,
	suffix = '',
	options = [],
	on = 'true',
	off = 'false',
} = Astro.props;

const inputId = `pp-${id}-${Math.random().toString(36).slice(2, 8)}`;

// Slider default clamped to range.
let initialNumber = typeof defaultValue === 'number' ? defaultValue : Number(defaultValue);
if (!Number.isFinite(initialNumber)) initialNumber = min;
initialNumber = Math.max(min, Math.min(max, initialNumber));

// Normalize select options to {value, label} pairs.
const normalizedOptions: { value: string; label: string }[] = options.map((o) =>
	typeof o === 'string' ? { value: o, label: o } : { value: o.value, label: o.label ?? o.value },
);

// Toggle initial state.
const toggleChecked =
	defaultValue === true || defaultValue === on || (typeof defaultValue === 'string' && defaultValue !== off && defaultValue !== '');

// Color initial value (hex).
const colorDefault = typeof defaultValue === 'string' && defaultValue.startsWith('#') ? defaultValue : '#3b82f6';

// Select initial value.
const selectDefault =
	typeof defaultValue === 'string' && normalizedOptions.some((o) => o.value === defaultValue)
		? defaultValue
		: normalizedOptions[0]?.value ?? '';
---

<div class="pp-param" data-pp-param={id} data-pp-kind={kind} data-pp-suffix={suffix}>
	<div class="pp-param-head">
		<label class="pp-param-label" for={inputId}>{label}</label>
		{
			kind === 'slider' && (
				<span class="pp-param-value" data-pp-value aria-live="polite">
					{initialNumber}
					{suffix}
				</span>
			)
		}
	</div>

	{
		kind === 'slider' && (
			<input
				class="pp-slider"
				type="range"
				id={inputId}
				data-pp-input
				min={min}
				max={max}
				step={step}
				value={initialNumber}
			/>
		)
	}

	{
		kind === 'select' && (
			<select class="pp-select" id={inputId} data-pp-input>
				{normalizedOptions.map((o) => (
					<option value={o.value} selected={o.value === selectDefault}>
						{o.label}
					</option>
				))}
			</select>
		)
	}

	{
		kind === 'toggle' && (
			<label class="pp-toggle">
				<input type="checkbox" id={inputId} data-pp-input data-pp-on={on} data-pp-off={off} checked={toggleChecked} />
			</label>
		)
	}

	{kind === 'color' && <input class="pp-color" type="color" id={inputId} data-pp-input value={colorDefault} />}
</div>
