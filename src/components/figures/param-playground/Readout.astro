---
// Labeled chip rendered beside the preview inside a <ParamPlayground>.
// Two modes:
//   - `of`: echoes a single <Param>'s current value (with optional suffix).
//   - `expr`: evaluates a JS expression over the param env (numerics as
//     numbers, others as strings) and renders the result.

interface Props {
	label: string;
	/** Echo a single param's current value. */
	of?: string;
	/** Evaluate a JS expression over the param env. */
	expr?: string;
	/** Appended to the rendered value. */
	suffix?: string;
}

const { label, of = '', expr = '', suffix = '' } = Astro.props;
---

<div
	class="pp-readout"
	data-pp-readout
	data-pp-readout-of={of}
	data-pp-readout-expr={expr}
	data-pp-readout-suffix={suffix}
>
	<span class="pp-readout-label">{label}</span>
	<span class="pp-readout-value" data-pp-readout-value aria-live="polite">—</span>
</div>
