---
// A wrapper pairing a *controls* slot (sliders/dropdowns/toggles/color
// pickers) with a *preview* slot whose CSS reads from the control values
// via custom properties. Optional <Readout> chips beside the preview
// display the current value of a param or a computed expression over
// the param env.
//
// Authoring:
//   <ParamPlayground>
//     <Param id="width" kind="slider" label="Width" min={40} max={400} default={200} suffix="px" />
//     <Param id="hue" kind="slider" label="Hue" min={0} max={360} default={210} />
//     <Preview>
//       <div style="width: var(--width); background: oklch(0.7 0.15 var(--hue));">…</div>
//     </Preview>
//     <Readout label="Hue" of="hue" />
//     <Readout label="Outer width" expr="width" suffix="px" />
//   </ParamPlayground>
//
// Mechanics: <Param> renders its control with data-pp-param attributes
// describing kind, id, suffix, and the raw value type. The root script
// finds every control, threads them through one initial pass to seed
// the preview wrapper with `--{id}` CSS variables, then re-writes on
// every `input` event. The same pass updates each <Readout>.

interface Props {
	/** Optional caption rendered above the playground card. */
	caption?: string;
}

const { caption } = Astro.props;
---

<div class="param-playground not-content" data-pp-root>
	{caption && <div class="pp-caption">{caption}</div>}

	<div class="pp-grid">
		<div class="pp-controls" data-pp-controls>
			<slot name="controls" />
		</div>

		<div class="pp-preview-col">
			<div class="pp-preview-wrap" data-pp-preview-wrap>
				<slot name="preview" />
			</div>
			<div class="pp-readouts" data-pp-readouts>
				<slot name="readouts" />
			</div>
		</div>
	</div>

	{/* Fallback default slot — lets authors write a single tree of children
	    (Param + Preview + Readout) without naming slots. The script reorganizes
	    them into the named slot containers at runtime. */}
	<div class="pp-default-bucket" data-pp-default hidden><slot /></div>
</div>

<style is:global>
	.param-playground {
		--pp-accent: hsl(217, 91%, 60%);
		--pp-chip-bg: var(--sl-color-bg-sidebar);
		/* `--sl-color-hairline` is intentionally near-invisible. Slider tracks
		   and toggle pills need a softly visible neutral that adapts to both
		   color schemes, so they ride on a mix of the page's text color with
		   transparent (dark in light mode, light in dark mode). */
		--pp-track-bg: color-mix(in srgb, var(--sl-color-text) 20%, transparent);
		--pp-track-border: color-mix(in srgb, var(--sl-color-text) 28%, transparent);

		position: relative;
		margin: 1.5rem 0;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 12px;
		padding: 16px 18px 18px;
	}

	.param-playground .pp-caption {
		font: 600 12px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 12px;
	}

	.param-playground .pp-grid {
		display: grid;
		grid-template-columns: minmax(200px, 280px) 1fr;
		gap: 18px;
		align-items: start;
	}

	@media (max-width: 640px) {
		.param-playground .pp-grid {
			grid-template-columns: 1fr;
		}
	}

	/* === Controls column === */
	.param-playground .pp-controls {
		display: flex;
		flex-direction: column;
		gap: 12px;
		min-width: 0;
	}

	/* === Preview column === */
	.param-playground .pp-preview-col {
		display: flex;
		flex-direction: column;
		gap: 10px;
		min-width: 0;
	}
	.param-playground .pp-preview-wrap {
		position: relative;
		min-height: 120px;
		padding: 16px;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	/* === Readouts row === */
	.param-playground .pp-readouts {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}
	.param-playground .pp-readouts:empty {
		display: none;
	}

	/* === Param control (rendered by <Param>) === */
	.param-playground .pp-param {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.param-playground .pp-param-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 10px;
	}
	.param-playground .pp-param-label {
		font: 600 12px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		line-height: 1.2;
	}
	.param-playground .pp-param-value {
		font: 600 11.5px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-gray-3);
		letter-spacing: 0.02em;
	}

	/* Slider */
	.param-playground .pp-slider {
		appearance: none;
		-webkit-appearance: none;
		width: 100%;
		height: 16px;
		background: transparent;
		outline: none;
		margin: 0;
		cursor: pointer;
		display: block;
	}
	.param-playground .pp-slider::-webkit-slider-runnable-track {
		height: 4px;
		background: var(--pp-track-bg);
		border-radius: 2px;
	}
	.param-playground .pp-slider::-moz-range-track {
		height: 4px;
		background: var(--pp-track-bg);
		border-radius: 2px;
	}
	.param-playground .pp-slider::-webkit-slider-thumb {
		appearance: none;
		-webkit-appearance: none;
		width: 16px;
		height: 16px;
		background: var(--pp-accent);
		border: 2px solid var(--sl-color-bg-sidebar);
		border-radius: 50%;
		margin-top: -6px;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
	}
	.param-playground .pp-slider::-moz-range-thumb {
		width: 16px;
		height: 16px;
		background: var(--pp-accent);
		border: 2px solid var(--sl-color-bg-sidebar);
		border-radius: 50%;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
	}
	.param-playground .pp-slider:focus-visible::-webkit-slider-thumb {
		outline: 2px solid var(--pp-accent);
		outline-offset: 2px;
	}

	/* Select */
	.param-playground .pp-select {
		font: 500 12.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 6px;
		padding: 6px 10px;
		cursor: pointer;
		width: 100%;
	}
	.param-playground .pp-select:focus-visible {
		outline: 2px solid var(--pp-accent);
		outline-offset: 1px;
		border-color: var(--pp-accent);
	}

	/* Toggle (switch) */
	.param-playground .pp-toggle {
		position: relative;
		width: 34px;
		height: 20px;
		display: inline-block;
		flex: 0 0 auto;
	}
	.param-playground .pp-toggle input {
		appearance: none;
		-webkit-appearance: none;
		position: absolute;
		inset: 0;
		margin: 0;
		width: 100%;
		height: 100%;
		background: var(--pp-track-bg);
		border: 1px solid var(--pp-track-border);
		border-radius: 999px;
		cursor: pointer;
		transition: background-color 0.14s, border-color 0.14s;
	}
	.param-playground .pp-toggle input::before {
		content: '';
		position: absolute;
		top: 1px;
		left: 1px;
		width: 16px;
		height: 16px;
		background: color-mix(in srgb, var(--sl-color-text) 55%, var(--sl-color-bg));
		border-radius: 50%;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
		transition: transform 0.14s, background-color 0.14s;
	}
	.param-playground .pp-toggle input:checked {
		background: var(--pp-accent);
		border-color: var(--pp-accent);
	}
	.param-playground .pp-toggle input:checked::before {
		background: white;
		transform: translateX(14px);
	}
	.param-playground .pp-toggle input:focus-visible {
		outline: 2px solid var(--pp-accent);
		outline-offset: 2px;
	}

	/* Color */
	.param-playground .pp-color {
		width: 100%;
		height: 28px;
		padding: 0;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 6px;
		background: var(--sl-color-bg);
		cursor: pointer;
	}
	.param-playground .pp-color:focus-visible {
		outline: 2px solid var(--pp-accent);
		outline-offset: 1px;
		border-color: var(--pp-accent);
	}
	.param-playground .pp-color::-webkit-color-swatch-wrapper {
		padding: 3px;
	}
	.param-playground .pp-color::-webkit-color-swatch {
		border: 1px solid var(--sl-color-hairline);
		border-radius: 4px;
	}

	/* === Readout chip === */
	.param-playground .pp-readout {
		display: inline-flex;
		gap: 8px;
		align-items: baseline;
		background: var(--pp-chip-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 999px;
		padding: 4px 12px;
	}
	.param-playground .pp-readout-label {
		font: 600 11px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.param-playground .pp-readout-value {
		font: 600 12px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: var(--sl-color-text);
	}
	.param-playground .pp-readout-value[data-pp-readout-error]::before {
		content: '⚠ ';
		color: hsl(0, 70%, 55%);
	}
</style>

<script>
	type ParamKind = 'slider' | 'select' | 'toggle' | 'color';
	type ParamState = {
		id: string;
		kind: ParamKind;
		suffix: string;
		raw: number | string | boolean;
		input: HTMLInputElement | HTMLSelectElement;
		valueChip: HTMLElement | null;
	};

	function moveDefaultChildren(root: HTMLElement) {
		// Authors who don't use named slots get their tree merged into the
		// right buckets here. Param → controls, Preview → preview, Readout →
		// readouts. Order within each bucket is preserved.
		const bucket = root.querySelector<HTMLElement>('[data-pp-default]');
		const controls = root.querySelector<HTMLElement>('[data-pp-controls]');
		const previewWrap = root.querySelector<HTMLElement>('[data-pp-preview-wrap]');
		const readouts = root.querySelector<HTMLElement>('[data-pp-readouts]');
		if (!bucket || !controls || !previewWrap || !readouts) return;
		Array.from(bucket.children).forEach((child) => {
			const el = child as HTMLElement;
			if (el.matches('[data-pp-param]')) controls.appendChild(el);
			else if (el.matches('[data-pp-preview]')) previewWrap.appendChild(el);
			else if (el.matches('[data-pp-readout]')) readouts.appendChild(el);
			else previewWrap.appendChild(el); // unknown → preview, as a sensible default
		});
		bucket.remove();
	}

	function readRawValue(p: { kind: ParamKind; input: HTMLInputElement | HTMLSelectElement }): number | string | boolean {
		switch (p.kind) {
			case 'slider': {
				const n = Number((p.input as HTMLInputElement).value);
				return Number.isFinite(n) ? n : 0;
			}
			case 'toggle': {
				const cb = p.input as HTMLInputElement;
				const onVal = cb.dataset.ppOn ?? 'true';
				const offVal = cb.dataset.ppOff ?? 'false';
				return cb.checked ? onVal : offVal;
			}
			case 'select':
			case 'color':
				return p.input.value;
		}
	}

	// --- WCAG 2 contrast helpers, exposed to the <Readout expr> evaluator. ---
	// Resolves any CSS color string (`#hex`, `oklch(...)`, `rgb(...)`, named, etc.)
	// to an sRGB triplet in 0..1 via a 1×1 canvas. Canvas forces sRGB resolution
	// regardless of input format — `getComputedStyle` in modern browsers can
	// return the original `oklch(...)` form, which is not directly parseable
	// without OKLCH→sRGB math.
	const PARSE_CANVAS: { ctx: CanvasRenderingContext2D | null } = { ctx: null };
	function parseColorToSRgb(input: string): [number, number, number] | null {
		const s = String(input ?? '').trim();
		if (!s) return null;
		if (!PARSE_CANVAS.ctx) {
			const c = document.createElement('canvas');
			c.width = c.height = 1;
			PARSE_CANVAS.ctx = c.getContext('2d', { willReadFrequently: true });
			if (!PARSE_CANVAS.ctx) return null;
		}
		const ctx = PARSE_CANVAS.ctx;
		// Reset to a sentinel so we can detect "browser rejected the input" — an
		// invalid fillStyle leaves the previous value in place.
		ctx.fillStyle = 'rgba(0, 0, 0, 0)';
		ctx.clearRect(0, 0, 1, 1);
		ctx.fillStyle = s;
		// If the browser rejected the input, fillStyle stays at the sentinel.
		if (ctx.fillStyle === 'rgba(0, 0, 0, 0)' && s !== 'rgba(0, 0, 0, 0)' && s !== 'transparent') {
			return null;
		}
		ctx.fillRect(0, 0, 1, 1);
		const data = ctx.getImageData(0, 0, 1, 1).data;
		return [data[0] / 255, data[1] / 255, data[2] / 255];
	}
	function relativeLuminance(c: [number, number, number]): number {
		const channel = (u: number) => (u <= 0.03928 ? u / 12.92 : Math.pow((u + 0.055) / 1.055, 2.4));
		const [r, g, b] = c.map(channel) as [number, number, number];
		return 0.2126 * r + 0.7152 * g + 0.0722 * b;
	}
	function wcagContrast(a: string, b: string): number {
		const ca = parseColorToSRgb(a);
		const cb = parseColorToSRgb(b);
		if (!ca || !cb) return NaN;
		const la = relativeLuminance(ca);
		const lb = relativeLuminance(cb);
		const [hi, lo] = la >= lb ? [la, lb] : [lb, la];
		const ratio = (hi + 0.05) / (lo + 0.05);
		return Math.round(ratio * 100) / 100;
	}
	function wcagPasses(a: string, b: string, level: 'AA' | 'AAA' = 'AA', size: 'normal' | 'large' = 'normal'): boolean {
		const ratio = wcagContrast(a, b);
		if (!Number.isFinite(ratio)) return false;
		const threshold =
			level === 'AAA' ? (size === 'large' ? 4.5 : 7) : size === 'large' ? 3 : 4.5;
		return ratio >= threshold;
	}
	const EXPR_HELPERS: Record<string, unknown> = {
		wcagContrast,
		wcagPasses,
		Math,
	};

	function formatForCss(raw: number | string | boolean, suffix: string): string {
		if (typeof raw === 'number') return suffix ? `${raw}${suffix}` : String(raw);
		return String(raw);
	}

	function makeExprEvaluator(expr: string, paramIds: string[], helperNames: string[]): (env: Record<string, unknown>) => unknown {
		// Author content is trusted (course MDX); Function constructor over a
		// flat env keyed by param id, plus a fixed set of helper names
		// (wcagContrast, wcagPasses, Math). Any throw is caught at the call site.
		const fn = new Function(...paramIds, ...helperNames, `"use strict"; return (${expr});`);
		const helperValues = helperNames.map((n) => EXPR_HELPERS[n]);
		return (env) => fn(...paramIds.map((id) => env[id]), ...helperValues);
	}

	document.querySelectorAll<HTMLElement>('[data-pp-root]').forEach((root) => {
		moveDefaultChildren(root);

		const previewWrap = root.querySelector<HTMLElement>('[data-pp-preview-wrap]');
		const controls = root.querySelector<HTMLElement>('[data-pp-controls]');
		if (!previewWrap || !controls) return;

		const paramEls = Array.from(controls.querySelectorAll<HTMLElement>('[data-pp-param]'));
		const params: ParamState[] = paramEls
			.map((el) => {
				const id = el.dataset.ppParam ?? '';
				const kind = (el.dataset.ppKind ?? 'slider') as ParamKind;
				const suffix = el.dataset.ppSuffix ?? '';
				const input = el.querySelector<HTMLInputElement | HTMLSelectElement>('[data-pp-input]');
				const valueChip = el.querySelector<HTMLElement>('[data-pp-value]');
				if (!id || !input) return null;
				const state: ParamState = { id, kind, suffix, raw: '' as never, input, valueChip };
				state.raw = readRawValue(state);
				return state;
			})
			.filter((p): p is ParamState => p !== null);

		const env: Record<string, unknown> = {};
		params.forEach((p) => (env[p.id] = p.raw));
		const paramIds = params.map((p) => p.id);
		const helperNames = Object.keys(EXPR_HELPERS);

		const readoutEls = Array.from(root.querySelectorAll<HTMLElement>('[data-pp-readout]'));
		const readouts = readoutEls.map((el) => {
			const valueEl = el.querySelector<HTMLElement>('[data-pp-readout-value]');
			const of = el.dataset.ppReadoutOf ?? '';
			const expr = el.dataset.ppReadoutExpr ?? '';
			const suffix = el.dataset.ppReadoutSuffix ?? '';
			let evaluator: ((env: Record<string, unknown>) => unknown) | null = null;
			if (expr) {
				try {
					evaluator = makeExprEvaluator(expr, paramIds, helperNames);
				} catch (err) {
					if (valueEl) {
						valueEl.textContent = '—';
						valueEl.setAttribute('data-pp-readout-error', String((err as Error).message ?? err));
					}
				}
			}
			return { el, valueEl, of, expr, suffix, evaluator };
		});

		function updateAll() {
			params.forEach((p) => {
				p.raw = readRawValue(p);
				env[p.id] = p.raw;
				const cssVal = formatForCss(p.raw, p.suffix);
				previewWrap!.style.setProperty(`--${p.id}`, cssVal);
				if (p.valueChip) {
					p.valueChip.textContent = cssVal;
				}
			});
			readouts.forEach((r) => {
				if (!r.valueEl) return;
				if (r.evaluator) {
					try {
						const result = r.evaluator(env);
						const text = typeof result === 'number' ? String(result) : String(result ?? '');
						r.valueEl.textContent = text + (r.suffix ?? '');
						r.valueEl.removeAttribute('data-pp-readout-error');
					} catch (err) {
						r.valueEl.textContent = '—';
						r.valueEl.setAttribute('data-pp-readout-error', String((err as Error).message ?? err));
					}
					return;
				}
				if (r.of) {
					const raw = env[r.of];
					r.valueEl.textContent = String(raw ?? '') + (r.suffix ?? '');
				}
			});
		}

		params.forEach((p) => {
			const handler = () => updateAll();
			p.input.addEventListener('input', handler);
			p.input.addEventListener('change', handler);
		});

		updateAll();
	});
</script>
