---
// A click-navigable directed graph of <Question> nodes leading to <Leaf>
// reveal cards. The student walks a path — each click commits to a branch
// and replaces the stage with the next layer; the full graph is never
// visible at once. A breadcrumb above the stage records the path; clicking
// any crumb truncates the path back to that point.
//
// Two framing modes (cosmetic only — same engine):
//   - kind="decision" (default): leaves are recommendations (✓ verdict).
//   - kind="machine": every node is a "state"; transitions can revisit
//     earlier nodes, and the breadcrumb just appends (no dedup). Leaves are
//     rare; cycles are common.
//
// Authoring:
//   <StateMachineWalker title="…" root="cardinality">
//     <Question id="cardinality" prompt="…">
//       <Branch label="…" to="frequency" rationale="…" />
//       <Branch label="…" to="leaf-sse" />
//     </Question>
//     <Question id="frequency" prompt="…">
//       <Branch label="…" to="leaf-poll" />
//     </Question>
//     <Leaf id="leaf-sse" verdict="Server-Sent Events">
//       Unidirectional updates → SSE.
//     </Leaf>
//   </StateMachineWalker>
//
// Mechanics: <Question>, <Branch>, <Leaf> children drop hidden placeholders
// with data-smw-* attributes into the payloads slot; the script reads them
// on mount, builds Node maps, and renders the live UI imperatively from the
// `path` state.

interface Props {
	title?: string;
	/**
	 * Id of the starting <Question> or <Leaf>. Optional — defaults to the first
	 * <Question> child in source order (or first <Leaf> if no questions exist).
	 * Set explicitly when the entry point isn't the first child.
	 */
	root?: string;
	/** Cosmetic framing — "decision" (default) or "machine". */
	kind?: 'decision' | 'machine';
}

const { title, root, kind = 'decision' } = Astro.props;
const hasDiagram = Astro.slots.has('diagram');
---

<div
	class="state-machine-walker not-content"
	data-smw-root
	data-smw-start={root ?? ''}
	data-smw-kind={kind}>
	<div class="smw-header">
		{title && <div class="smw-title">{title}</div>}
		<div class="smw-controls">
			<button
				type="button"
				class="smw-back"
				data-smw-back
				aria-label="Go back one step">
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
					focusable="false">
					<path d="M19 12H5" />
					<path d="M12 19l-7-7 7-7" />
				</svg>
				<span>back</span>
			</button>
			<button
				type="button"
				class="smw-reset"
				data-smw-reset
				aria-label="Start over from the root">
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
					focusable="false">
					<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
					<path d="M3 3v5h5" />
				</svg>
				<span>start over</span>
			</button>
		</div>
	</div>

	{
		hasDiagram && (
			<div class="smw-diagram-slot" data-smw-diagram-slot>
				<slot name="diagram" />
			</div>
		)
	}

	<div class="smw-stage" data-smw-stage></div>

	{/* Hidden payload area: <Question>, <Branch>, <Leaf> children drop
	    placeholder elements here; the script reads them on mount. */}
	<div class="smw-payloads" data-smw-payloads hidden>
		<slot />
	</div>
</div>

<style is:global>
	.state-machine-walker {
		position: relative;
		margin: 1.5rem 0;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 14px;
		padding: 18px 20px 20px;
	}

	/* === Header === */
	.state-machine-walker .smw-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 6px;
		min-height: 24px;
	}
	.state-machine-walker .smw-title {
		font: 500 13px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		letter-spacing: 0.005em;
	}
	.state-machine-walker .smw-header:not(:has(.smw-title)) {
		justify-content: flex-end;
	}
	.state-machine-walker .smw-controls {
		display: inline-flex;
		align-items: center;
		gap: 2px;
	}
	.state-machine-walker .smw-back,
	.state-machine-walker .smw-reset {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font: 500 11.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		background: transparent;
		border: 1px solid transparent;
		border-radius: 6px;
		padding: 4px 9px 4px 7px;
		cursor: pointer;
		transition: color 0.14s, background-color 0.14s, border-color 0.14s;
	}
	.state-machine-walker .smw-back svg,
	.state-machine-walker .smw-reset svg {
		width: 14px;
		height: 14px;
	}
	.state-machine-walker .smw-back:hover,
	.state-machine-walker .smw-reset:hover {
		color: var(--sl-color-text);
		background: var(--sl-color-bg);
		border-color: var(--sl-color-hairline);
	}
	.state-machine-walker .smw-back:focus-visible,
	.state-machine-walker .smw-reset:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	/* Hide back + reset at the root — nothing to go back to. */
	.state-machine-walker[data-smw-at-root='true'] .smw-back,
	.state-machine-walker[data-smw-at-root='true'] .smw-reset {
		visibility: hidden;
	}

	/* === Diagram slot ===
	   Renders inside the walker card, between the header and the stage.
	   The author drops in a Mermaid <Figure slot="diagram">…</Figure>; the
	   sync engine highlights the SVG node matching the current state.

	   The wrapping Figure's container chrome (background, border, padding)
	   is stripped — the walker card already provides the surface. The SVG
	   stretches to the full slot width so small screens don't lose space
	   to dead margins. */
	.state-machine-walker .smw-diagram-slot {
		margin-bottom: 14px;
	}
	.state-machine-walker .smw-diagram-slot .sl-figure {
		margin: 0;
		padding: 0;
		background: transparent;
		border: 0;
		border-radius: 0;
	}
	.state-machine-walker .smw-diagram-slot .mermaid,
	.state-machine-walker .smw-diagram-slot pre.mermaid {
		display: flex;
		justify-content: center;
		margin: 0;
		padding: 0;
		background: transparent;
		min-height: 0;
	}
	.state-machine-walker .smw-diagram-slot .mermaid svg {
		max-width: 100% !important;
		width: 100%;
		height: auto;
		display: block;
	}

	/* === Stage ===
	   No background or border — the outer card already provides the surface.
	   Just a content well with consistent vertical rhythm. */
	.state-machine-walker .smw-stage {
		min-height: 60px;
	}
	.state-machine-walker .smw-stage.is-entering .smw-stage-inner {
		opacity: 0;
		transform: translateY(6px);
	}
	.state-machine-walker .smw-stage-inner {
		opacity: 1;
		transform: translateY(0);
		transition: opacity 0.22s ease-out, transform 0.22s ease-out;
	}

	/* Question stage */
	.state-machine-walker .smw-kind-tag {
		display: block;
		font: 600 10px ui-sans-serif, system-ui, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-accent);
		margin-bottom: 4px;
		background: transparent;
		border: 0;
		padding: 0;
	}
	.state-machine-walker .smw-prompt {
		font: 600 15.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		letter-spacing: -0.005em;
		line-height: 1.35;
		margin: 0 0 10px;
	}
	.state-machine-walker .smw-description {
		font: 400 13.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-2, var(--sl-color-text));
		line-height: 1.5;
		margin: 0 0 14px;
	}
	.state-machine-walker .smw-branches {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.state-machine-walker .smw-branch {
		display: flex;
		flex-direction: column;
		gap: 3px;
		align-items: flex-start;
		font: 500 13.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 9px;
		padding: 10px 14px;
		cursor: pointer;
		text-align: left;
		transition: border-color 0.14s, background-color 0.14s, transform 0.06s;
	}
	.state-machine-walker .smw-branch:hover {
		border-color: var(--sl-color-accent);
		background: color-mix(in srgb, var(--sl-color-accent) 8%, var(--sl-color-bg));
	}
	.state-machine-walker .smw-branch:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	.state-machine-walker .smw-branch:active {
		transform: translateY(1px);
	}
	.state-machine-walker .smw-branch-label {
		font: 600 13.5px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
	}
	.state-machine-walker .smw-branch-rationale {
		font: 400 12px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-gray-3);
		line-height: 1.4;
	}

	/* Leaf stage */
	.state-machine-walker .smw-leaf {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.state-machine-walker .smw-leaf .smw-kind-tag {
		margin-bottom: -4px;
	}
	.state-machine-walker .smw-verdict {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		align-self: flex-start;
		font: 600 14px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-accent);
		background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
		border: none;
		border-radius: 999px;
		padding: 6px 14px 6px 10px;
	}
	.state-machine-walker .smw-verdict svg {
		width: 14px;
		height: 14px;
		flex: 0 0 auto;
	}
	.state-machine-walker .smw-reason {
		font: 400 14px ui-sans-serif, system-ui, sans-serif;
		color: var(--sl-color-text);
		line-height: 1.55;
	}
	.state-machine-walker .smw-reason > :first-child {
		margin-top: 0;
	}
	.state-machine-walker .smw-reason > :last-child {
		margin-bottom: 0;
	}
	.state-machine-walker .smw-reason p {
		margin: 0 0 0.7em;
	}
	.state-machine-walker .smw-reason p:last-child {
		margin-bottom: 0;
	}
	.state-machine-walker .smw-reason code {
		font: 600 0.9em ui-monospace, SFMono-Regular, Menlo, monospace;
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 4px;
		padding: 1px 5px;
	}
	.state-machine-walker .smw-leaf-actions {
		display: flex;
		gap: 8px;
		margin-top: 4px;
	}
	.state-machine-walker .smw-start-over {
		display: inline-flex;
		align-items: center;
		font: 600 13px ui-sans-serif, system-ui, sans-serif;
		color: #fff;
		background: var(--sl-color-accent);
		border: 1px solid var(--sl-color-accent);
		border-radius: 8px;
		padding: 8px 14px;
		cursor: pointer;
		box-shadow: 0 1px 2px color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
		transition: filter 0.14s, transform 0.06s, box-shadow 0.14s;
	}
	.state-machine-walker .smw-start-over:hover {
		filter: brightness(1.08);
	}
	.state-machine-walker .smw-start-over:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
	.state-machine-walker .smw-start-over:active {
		transform: translateY(1px);
	}

	/* === Mermaid diagram sync highlight ===
	   Applied globally so the highlight reaches into the Mermaid SVG, which
	   lives outside the walker's DOM subtree. `.smw-current` is added by the
	   walker's script to the matching <g class="node ..."> on each transition. */
	g.node.smw-current > rect,
	g.node.smw-current > path,
	g.node.smw-current > polygon,
	g.node.smw-current > ellipse,
	g.node.smw-current > circle {
		fill: var(--sl-color-accent) !important;
		stroke: var(--sl-color-accent) !important;
	}
	g.node.smw-current foreignObject,
	g.node.smw-current foreignObject *,
	g.node.smw-current text,
	g.node.smw-current text tspan {
		color: #fff !important;
		fill: #fff !important;
	}

	/* Missing-node error (dev affordance) */
	.state-machine-walker .smw-error {
		font: 600 13px ui-monospace, SFMono-Regular, Menlo, monospace;
		color: #b3261e;
		background: color-mix(in srgb, #b3261e 8%, transparent);
		border: 1px solid color-mix(in srgb, #b3261e 30%, transparent);
		border-radius: 8px;
		padding: 10px 14px;
	}

	/* === Responsive === */
	@media (max-width: 520px) {
		.state-machine-walker .smw-crumb {
			max-width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.state-machine-walker .smw-stage-inner {
			transition: opacity 0.12s linear !important;
			transform: none !important;
		}
		.state-machine-walker .smw-stage.is-entering .smw-stage-inner {
			transform: none !important;
		}
		.state-machine-walker .smw-branch,
		.state-machine-walker .smw-start-over,
		.state-machine-walker .smw-crumb {
			transition: background-color 0.2s linear, color 0.2s linear, border-color 0.2s linear !important;
			transform: none !important;
		}
	}
</style>

<script>
	type BranchDef = { label: string; to: string; rationale: string };
	type QuestionDef = {
		kind: 'question';
		id: string;
		prompt: string;
		description: string;
		branches: BranchDef[];
	};
	type LeafDef = {
		kind: 'leaf';
		id: string;
		verdict: string;
		reasonHtml: string;
	};
	type NodeDef = QuestionDef | LeafDef;

	function parseBranches(scope: HTMLElement): BranchDef[] {
		return Array.from(
			scope.querySelectorAll<HTMLElement>(':scope > [data-smw-branch]'),
		).map((el) => ({
			label: el.dataset.smwLabel ?? '',
			to: el.dataset.smwTo ?? '',
			rationale: el.dataset.smwRationale ?? '',
		}));
	}

	document.querySelectorAll<HTMLElement>('[data-smw-root]').forEach((root) => {
		const stageEl = root.querySelector<HTMLElement>('[data-smw-stage]');
		const backBtn = root.querySelector<HTMLButtonElement>('[data-smw-back]');
		const resetBtn = root.querySelector<HTMLButtonElement>('[data-smw-reset]');
		const payloads = root.querySelector<HTMLElement>('[data-smw-payloads]');

		if (!stageEl || !backBtn || !resetBtn || !payloads) return;

		const nodes = new Map<string, NodeDef>();

		// Parse <Question> nodes
		payloads
			.querySelectorAll<HTMLElement>(':scope > [data-smw-question]')
			.forEach((qEl) => {
				const id = qEl.dataset.smwId ?? '';
				if (!id) return;
				nodes.set(id, {
					kind: 'question',
					id,
					prompt: qEl.dataset.smwPrompt ?? '',
					description: qEl.dataset.smwDescription ?? '',
					branches: parseBranches(qEl),
				});
			});

		// Parse <Leaf> nodes — their slot HTML is the reason body.
		payloads
			.querySelectorAll<HTMLElement>(':scope > [data-smw-leaf]')
			.forEach((lEl) => {
				const id = lEl.dataset.smwId ?? '';
				if (!id) return;
				// Capture inner HTML (slot content). The placeholder element is hidden,
				// so we read its rendered children as the leaf's reason markup.
				const reasonHtml = lEl.innerHTML;
				nodes.set(id, {
					kind: 'leaf',
					id,
					verdict: lEl.dataset.smwVerdict ?? '',
					reasonHtml,
				});
			});

		// Resolve the start id: explicit `root` prop wins; otherwise fall back
		// to the first <Question> in source order, then the first <Leaf>.
		const explicitStart = root.dataset.smwStart ?? '';
		const firstQuestion = payloads
			.querySelector<HTMLElement>(':scope > [data-smw-question]')?.dataset.smwId;
		const firstLeaf = payloads
			.querySelector<HTMLElement>(':scope > [data-smw-leaf]')?.dataset.smwId;
		const startId = explicitStart || firstQuestion || firstLeaf || '';

		if (!startId) return;

		let path: string[] = [startId];
		const diagramContainer = root.querySelector<HTMLElement>(
			'[data-smw-diagram-slot]',
		);
		let diagramObserver: MutationObserver | null = null;

		function updateAtRootAttr() {
			root.setAttribute('data-smw-at-root', path.length <= 1 ? 'true' : 'false');
		}

		function findStateNode(svg: SVGElement, stateId: string): Element | null {
			const normalized = stateId.replace(/-/g, '_');
			// Mermaid stateDiagram-v2 nodes render with ids like
			// "mermaid-{instance}-state-{stateId}-{n}". Match by substring.
			const candidates = svg.querySelectorAll<SVGElement>('g.node');
			for (const c of candidates) {
				if (c.id && c.id.includes(`-state-${normalized}-`)) return c;
			}
			return null;
		}

		function syncDiagram() {
			if (!diagramContainer) return;
			const svg = diagramContainer.querySelector<SVGElement>('svg');
			const currentId = path[path.length - 1] ?? startId;
			const target = svg ? findStateNode(svg, currentId) : null;

			// Keep an observer alive for the lifetime of the walker. Mermaid
			// renders asynchronously and can re-render later (theme flip, resize,
			// SVG node-tree rebuilds), so we re-apply the highlight on every
			// subtree mutation rather than disconnecting after first success.
			if (!diagramObserver) {
				diagramObserver = new MutationObserver(() => syncDiagram());
				diagramObserver.observe(diagramContainer, {
					childList: true,
					subtree: true,
				});
			}

			if (!target) return;

			if (svg) {
				svg.querySelectorAll('g.node.smw-current').forEach((el) => {
					if (el !== target) el.classList.remove('smw-current');
				});
			}
			if (!target.classList.contains('smw-current')) {
				target.classList.add('smw-current');
			}
		}

		function renderStage() {
			const currentId = path[path.length - 1] ?? startId;
			const node = nodes.get(currentId);

			stageEl!.innerHTML = '';
			const inner = document.createElement('div');
			inner.className = 'smw-stage-inner';

			if (!node) {
				const err = document.createElement('div');
				err.className = 'smw-error';
				err.textContent = `missing node: ${currentId}`;
				inner.appendChild(err);
				stageEl!.appendChild(inner);
				return;
			}

			const kindMode = root.dataset.smwKind === 'machine' ? 'machine' : 'decision';

			if (node.kind === 'question') {
				if (kindMode === 'machine') {
					const tag = document.createElement('span');
					tag.className = 'smw-kind-tag';
					tag.textContent = `state · ${node.id}`;
					inner.appendChild(tag);
				}
				const prompt = document.createElement('h3');
				prompt.className = 'smw-prompt';
				prompt.textContent = node.prompt;
				inner.appendChild(prompt);

				if (node.description) {
					const desc = document.createElement('p');
					desc.className = 'smw-description';
					desc.textContent = node.description;
					inner.appendChild(desc);
				}

				const branches = document.createElement('div');
				branches.className = 'smw-branches';
				node.branches.forEach((b) => {
					const btn = document.createElement('button');
					btn.type = 'button';
					btn.className = 'smw-branch';
					const labelEl = document.createElement('span');
					labelEl.className = 'smw-branch-label';
					labelEl.textContent = b.label;
					btn.appendChild(labelEl);
					if (b.rationale) {
						const rEl = document.createElement('span');
						rEl.className = 'smw-branch-rationale';
						rEl.textContent = b.rationale;
						btn.appendChild(rEl);
					}
					btn.addEventListener('click', () => {
						path.push(b.to);
						renderAll(true);
					});
					branches.appendChild(btn);
				});
				inner.appendChild(branches);
			} else {
				// Leaf
				const wrap = document.createElement('div');
				wrap.className = 'smw-leaf';

				if (kindMode === 'decision') {
					const tag = document.createElement('span');
					tag.className = 'smw-kind-tag';
					tag.textContent = 'recommendation';
					wrap.appendChild(tag);
				}

				const verdict = document.createElement('span');
				verdict.className = 'smw-verdict';
				verdict.innerHTML =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>';
				const verdictText = document.createElement('span');
				verdictText.textContent = node.verdict;
				verdict.appendChild(verdictText);
				wrap.appendChild(verdict);

				const reason = document.createElement('div');
				reason.className = 'smw-reason';
				reason.innerHTML = node.reasonHtml;
				wrap.appendChild(reason);

				const actions = document.createElement('div');
				actions.className = 'smw-leaf-actions';
				const startOver = document.createElement('button');
				startOver.type = 'button';
				startOver.className = 'smw-start-over';
				startOver.textContent = 'Start over';
				startOver.addEventListener('click', () => {
					path = [startId];
					renderAll(true);
				});
				actions.appendChild(startOver);
				wrap.appendChild(actions);

				inner.appendChild(wrap);
			}

			stageEl!.appendChild(inner);
		}

		function renderAll(animate = false) {
			if (animate) stageEl!.classList.add('is-entering');
			renderStage();
			updateAtRootAttr();
			syncDiagram();
			if (animate) {
				requestAnimationFrame(() => {
					stageEl!.classList.remove('is-entering');
				});
			} else {
				stageEl!.classList.remove('is-entering');
			}
		}

		backBtn.addEventListener('click', () => {
			if (path.length <= 1) return;
			path.pop();
			renderAll(true);
		});

		resetBtn.addEventListener('click', () => {
			if (path.length <= 1) return;
			path = [startId];
			renderAll(true);
		});

		renderAll();
	});
</script>
