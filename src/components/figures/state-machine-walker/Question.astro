---
// One question node in a <StateMachineWalker>. The parent script reads
// id/prompt/description off the dataset and renders the live UI imperatively
// when this node is the current stage. Branches are declared as nested
// <Branch> children inside the default slot.

interface Props {
	id: string;
	prompt: string;
	/** Optional one- or two-sentence body shown above the branch buttons. */
	description?: string;
}

const { id, prompt, description } = Astro.props;
---

<div
	hidden
	data-smw-question
	data-smw-id={id}
	data-smw-prompt={prompt}
	data-smw-description={description ?? ''}>
	<slot />
</div>
