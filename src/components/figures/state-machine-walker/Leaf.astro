---
// One terminal leaf in a <StateMachineWalker>. The slot is the reason body —
// MDX rich content (paragraphs, code, lists, links) renders inside the leaf
// card when this node is the current stage.

interface Props {
	id: string;
	/** The headline verdict surfaced in the prominent badge. */
	verdict: string;
}

const { id, verdict } = Astro.props;
---

<div hidden data-smw-leaf data-smw-id={id} data-smw-verdict={verdict}>
	<slot />
</div>
