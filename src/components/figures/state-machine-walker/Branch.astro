---
// One branch from a <Question>. Leaf-level placeholder, no slot. The parent
// script reads label/to/rationale off the dataset. `to` is the id of either
// another <Question> or a <Leaf>; the engine resolves the kind at click time.

interface Props {
	/** Button label shown on the branch button. */
	label: string;
	/** NodeId of the target <Question> or <Leaf>. */
	to: string;
	/** Optional one-line rationale surfaced in the breadcrumb crumb for this transition. */
	rationale?: string;
}

const { label, to, rationale } = Astro.props;
---

<span
	hidden
	data-smw-branch
	data-smw-label={label}
	data-smw-to={to}
	data-smw-rationale={rationale ?? ''}></span>
